direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Constant Folding Examples"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  case1: {
    direction: down
    label: "Case 1: WHERE 1=1 (Tautology)"
    before1: {
      label: "Before"
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      filter1: {
        shape: class
        label: "LogicalFilter"
        predicate: "str"
        +children: "List[PlanNode]"
      }
      scan1: {
        shape: class
        label: "Scan"
        +table: "str"
      }
    }
    arrow1: {
      label: "Fold"
      shape: diamond
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    after1: {
      label: "After"
      style.fill: "#E0FFE0"
      style.stroke: "#228B22"
      scan1_result: {
        shape: class
        label: "Scan"
        +table: "str"
        note: "Filter eliminated entirely"
      }
    }
    before1.filter1 -> before1.scan1
    before1 -> arrow1 -> after1
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  case2: {
    direction: down
    label: "Case 2: WHERE 1=0 (Contradiction)"
    before2: {
      label: "Before"
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      filter2: {
        shape: class
        label: "LogicalFilter"
        predicate: "str"
        +children: "List[PlanNode]"
      }
      join2: {
        shape: class
        label: "Join"
        +condition: "str"
        +children: "List[PlanNode]"
      }
    }
    arrow2: {
      label: "Prune"
      shape: diamond
      style.fill: "#FF6B6B"
      style.stroke: "#8B0000"
    }
    after2: {
      label: "After"
      style.fill: "#FFE4E1"
      style.stroke: "#8B0000"
      empty2: {
        shape: class
        label: "EmptyResult"
        +reason: "FALSE predicate"
      }
    }
    before2.filter2 -> before2.join2
    before2 -> arrow2 -> after2
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  case3: {
    direction: down
    label: "Case 3: WHERE 2+3 > x (Partial Fold)"
    before3: {
      label: "Before"
      style.fill: "#FFF8DC"
      style.stroke: "#DAA520"
      ast3: {
        direction: right
        label: "AST"
        gt3: {
          label: ">"
          shape: diamond
          style.fill: "#FFFACD"
        }
        plus3: {
          label: "+"
          shape: circle
          style.fill: "#FFFACD"
        }
        two3: {
          label: "2"
          shape: circle
          style.fill: "#E0E0E0"
        }
        three3: {
          label: "3"
          shape: circle
          style.fill: "#E0E0E0"
        }
        x3: {
          label: "x"
          shape: circle
          style.fill: "#ADD8E6"
        }
        plus3 -> two3
        plus3 -> three3
        gt3 -> plus3
        gt3 -> x3
      }
    }
    arrow3: {
      label: "Fold"
      shape: diamond
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    after3: {
      label: "After"
      style.fill: "#E0FFE0"
      style.stroke: "#228B22"
      ast3_result: {
        direction: right
        label: "AST"
        gt3_result: {
          label: ">"
          shape: diamond
          style.fill: "#FFFACD"
        }
        five3: {
          label: "5"
          shape: circle
          style.fill: "#90EE90"
        }
        x3_result: {
          label: "x"
          shape: circle
          style.fill: "#ADD8E6"
        }
        gt3_result -> five3
        gt3_result -> x3_result
      }
    }
    before3 -> arrow3 -> after3
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: "#666666"
  style.stroke-dash: 3
  legend_title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  literal: {
    label: "Literal"
    shape: circle
    style.fill: "#E0E0E0"
  }
  column: {
    label: "Column"
    shape: circle
    style.fill: "#ADD8E6"
  }
  folded: {
    label: "Folded"
    shape: circle
    style.fill: "#90EE90"
  }
}
row1 -> row2 -> row3: {
  style.stroke: transparent
}