direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Cost Estimation Error Propagation"
  note: "Cascading cardinality underestimation in query plan trees"
  near: top-center
  style.stroke: transparent
  style.fill: transparent
  style.font-size: 24
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  underestimated: {
    direction: down
    label: "Underestimated Plan (Chosen by Optimizer)"
    
    ue_join: {
      label: "HashJoin (exec_join.c)"
      width: 280
      est: |'md
        **Estimated**: 500 rows
        **Cost**: 800 units
      '|
      act: |'md
        **Actual**: 50,000 rows
        **Error**: 100x underestimate
      '|
      style.stroke: red
      style.stroke-width: 3
    }
    
    ue_left: {
      label: "Filter: status = 'active' (nodeFilter.c)"
      width: 220
      est: |'md
        Est: 2,000 rows
        Sel: 0.02
      '|
      act: |'md
        Act: 80,000 rows
        Sel: 0.80
      '|
      style.stroke: red
    }
    
    ue_right: {
      label: "Scan: orders (nodeSeqscan.c)"
      width: 200
      info: |'md
        Est: 100,000 rows
        Act: 100,000 rows
      '|
      style.stroke: green
    }
    
    ue_left_scan: {
      label: "Scan: users"
      width: 180
      info: |'md
        Est: 100,000 rows
        Act: 100,000 rows
      '|
      style.stroke: green
    }

    ue_join -> ue_left: "Left Input"
    ue_join -> ue_right: "Right Input"
    ue_left -> ue_left_scan: "Source"
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  accurate: {
    direction: down
    label: "Accurate Plan (Rejected by Optimizer)"
    
    ac_join: {
      label: "HashJoin (exec_join.c)"
      width: 280
      est: |'md
        **Estimated**: 50,000 rows
        **Cost**: 12,000 units
      '|
      act: |'md
        **Actual**: 50,000 rows
        **Accurate**
      '|
      style.stroke: green
      style.stroke-width: 3
    }
    
    ac_left: {
      label: "Scan: orders"
      width: 180
      info: |'md
        Est: 100,000 rows
        Act: 100,000 rows
      '|
      style.stroke: green
    }
    
    ac_right: {
      label: "Scan: users"
      width: 180
      info: |'md
        Est: 100,000 rows
        Act: 100,000 rows
      '|
      style.stroke: green
    }

    ac_join -> ac_left: "Left Input"
    ac_join -> ac_right: "Right Input"
  }
}

row1 -> row2: "Cost Difference | Rejected Path" {
  style.stroke: blue
  style.stroke-width: 2
  style.stroke-dash: 3
}

error_source: {
  label: "Source of Error (stats.c)"
  width: 320
  code: |'md
    sql
    WHERE status = 'active'
    
    **Statistics said**: 2% selectivity
    **Reality**: 80% selectivity
    Stale histogram from before batch job.
  '|
  style.fill: "#fff3cd"
  style.stroke: "#856404"
}
error_source.near: top-right

propagation: {
  label: "Error Propagation Path"
  width: 350
  flow: |'md
    1. **Filter selectivity wrong** (2% vs 80%)
    2. **Filter output underestimated** (2K vs 80K)
    3. **Join input size wrong** (2K vs 80K)
    4. **Join output underestimated** (500 vs 50K)
    5. **Wrong plan chosen** (cost 800 vs 12,000)
    6. **Actual execution disaster**
  '|
  style.fill: "#f8d7da"
  style.stroke: "#721c24"
}
propagation.near: bottom-center

outcome: {
  label: "Real-World Impact"
  width: 420
  impact: |'md
    | Metric | Estimated | Actual | Impact |
    | :--- | :--- | :--- | :--- |
    | Memory | 50 KB | 5 MB | Hash table spills to disk |
    | Time | 0.8 sec | 45 sec | 56x slower execution |
    | I/O | 100 pgs | 50K pgs | Random access explosion |
  '|
  style.fill: "#cce5ff"
  style.stroke: "#004085"
}
outcome.near: bottom-right

legend: {
  label: "Status Legend"
  correct: "Correct estimate" {
    style.fill: "#d4edda"
  }
  wrong: "Underestimated / Error" {
    style.fill: "#f8d7da"
  }
  decision: "Optimizer decision" {
    style.stroke: blue
    style.stroke-dash: 3
  }
}
legend.near: bottom-left