direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: "# Cost Model: I/O vs CPU Components"
  near: top-center
}

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  formula: {
    label: "Cost Formula"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    
    text: |'md
      **total_cost** = **(io_weight × io_cost)** + **(cpu_weight × cpu_cost)**
      
      Where:
      - `io_cost` = disk pages accessed
      - `cpu_cost` = rows processed
      - `io_weight` = cost per I/O (default: 1.0)
      - `cpu_weight` = cost per tuple (default: 0.01)
    '|
  }

  weights: {
    label: "Default Weights"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    
    params: {
      shape: sql_table
      label: "CostModelConfig"
      w1: "io_weight   | float | 1.0"
      w2: "cpu_weight  | float | 0.01"
      note: "I/O ~100x more expensive than tuple processing"
    }
  }
}

row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  example: {
    label: "Example: Sequential Scan"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 450

    table_info: {
      shape: sql_table
      label: "Table: orders"
      rows: "Row Count    | 50,000"
      pages: "Page Count   | 1,000"
      density: "50 rows/page (typical)"
    }

    calculation: |'md
      **SeqScan Cost Calculation:**
      
      io_cost  = 1,000 pages
      cpu_cost = 50,000 rows
      
      Total = (1.0 × 1,000) + (0.01 × 50,000)
            = 1,000 + 500
            = **1,500 cost units**
      
      **Contribution:** I/O = 67% | CPU = 33%
    '|
  }

  breakdown: {
    label: "Cost Breakdown Visualization"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    
    bar_container: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      io_bar: {
        label: "I/O Cost"
        width: 200
        style.fill: "#2196F3"
        style.stroke: "#1565C0"
        style.font-color: white
        content: |'md
          **1,000**
          (66.7%)
        '|
      }
      
      cpu_bar: {
        label: "CPU Cost"
        width: 100
        style.fill: "#FF9800"
        style.stroke: "#E65100"
        style.font-color: white
        content: |'md
          **500**
          (33.3%)
        '|
      }
    }
    
    total_bar: {
      label: "Total Cost"
      width: 300
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
      content: |'md
        **1,500 cost units**
      '|
    }
  }
}

row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  scenario1: {
    label: "Scenario A: I/O-Heavy (HDD)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    
    config: {
      shape: sql_table
      label: "Config (HDD)"
      c1: "io_weight  | 4.0"
      c2: "cpu_weight | 0.005"
    }
    
    calc: |'md
      total = (4.0 × 1,000) + (0.005 × 50,000)
            = 4,000 + 250 = **4,250**
      *I/O dominates (94%)*
    '|
  }

  scenario2: {
    label: "Scenario B: Balanced (SSD)"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    
    config: {
      shape: sql_table
      label: "Config (SSD)"
      c1: "io_weight  | 1.0"
      c2: "cpu_weight | 0.01"
    }
    
    calc: |'md
      total = (1.0 × 1,000) + (0.01 × 50,000)
            = 1,000 + 500 = **1,500**
      *Balanced (67% I/O)*
    '|
  }

  scenario3: {
    label: "Scenario C: CPU-Heavy (Cached)"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.stroke-width: 2
    
    config: {
      shape: sql_table
      label: "Config (RAM)"
      c1: "io_weight  | 0.1"
      c2: "cpu_weight | 0.05"
    }
    
    calc: |'md
      total = (0.1 × 1,000) + (0.05 × 50,000)
            = 100 + 2,500 = **2,600**
      *CPU dominates (96%)*
    '|
  }
}

row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  insight: {
    label: "Key Insight"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    width: 500
    
    text: |'md
      **Relative costs matter most.**
      
      The optimizer needs correct *rankings* of plans, not exact execution times.
      Weights tune the model to hardware traits (latency/throughput) to ensure
      the faster plan consistently receives the lower cost.
    '|
  }

  tuning: {
    label: "Weight Tuning Guide"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    style.stroke-width: 2
    
    guide: {
      shape: sql_table
      label: "Hardware Presets"
      hdd: "HDD (Slow Random) | io=4.0, cpu=0.005"
      ssd: "SSD (Balanced)    | io=1.0, cpu=0.01"
      nvme: "NVMe (High IOPS) | io=0.5, cpu=0.02"
      cache: "Memory (Cached)  | io=0.1, cpu=0.05"
    }
  }
}

row1.formula -> row2.example: "applied to"
row2.breakdown -> row3.scenario1: "parameter sensitivity"
row2.breakdown -> row3.scenario2
row2.breakdown -> row3.scenario3