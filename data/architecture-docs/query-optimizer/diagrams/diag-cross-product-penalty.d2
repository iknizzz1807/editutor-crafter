direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Cross Product Detection & Penalization"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  left_section: {
    direction: down
    label: "Join Graph Analysis"
    join_graph: {
      label: ""
      style.fill: transparent
      style.stroke: transparent
      component1: {
        label: "Component 1 (Connected)"
        style: {
          fill: "#E8F5E9"
          stroke: "#4CAF50"
          stroke-width: 2
        }
        table_a: {
          label: "orders"
          shape: rectangle
          style: {
            fill: "#C8E6C9"
            stroke: "#388E3C"
          }
        }
        table_b: {
          label: "customers"
          shape: rectangle
          style: {
            fill: "#C8E6C9"
            stroke: "#388E3C"
          }
        }
      }
      component2: {
        label: "Component 2 (Connected)"
        style: {
          fill: "#E3F2FD"
          stroke: "#2196F3"
          stroke-width: 2
        }
        table_c: {
          label: "products"
          shape: rectangle
          style: {
            fill: "#BBDEFB"
            stroke: "#1976D2"
          }
        }
        table_d: {
          label: "categories"
          shape: rectangle
          style: {
            fill: "#BBDEFB"
            stroke: "#1976D2"
          }
        }
      }
      component1.table_a <-> component1.table_b: "orders.customer_id\n= customers.id" {
        style: {
          stroke: "#388E3C"
          stroke-width: 3
        }
      }
      component2.table_c <-> component2.table_d: "products.category_id\n= categories.id" {
        style: {
          stroke: "#1976D2"
          stroke-width: 3
        }
      }
      component1.table_a -> component2.table_c: "NO CONNECTION" {
        style: {
          stroke: "#F44336"
          stroke-dash: 5
          stroke-width: 2
        }
      }
    }
    detection_logic: {
      label: "Detection Logic (optimizer.py)"
      width: 380
      code: |'python
        def _is_cross_product(
            self,
            left_subset: FrozenSet[str],
            right_subset: FrozenSet[str],
            join_graph: Dict[str, Set[str]]
        ) -> bool:
            """Check if joining subsets produces cross product."""
            for left_table in left_subset:
                connected = join_graph.get(left_table, set())
                if connected & right_subset:
                    return False  # Found a connection
            return True  # No connection = cross product
      '|
    }
    penalty_logic: {
      label: "Cost Penalization"
      width: 380
      code: |'python
        # Apply cross product penalty in cost model
        if is_cross_product:
            join_cost *= self.config.cross_product_penalty
            # Default penalty: 1000x multiplier
            # Makes cross product plans unattractive
            # unless no alternative exists
      '|
    }
  }
  right_section: {
    direction: down
    label: ""
    cross_product_result: {
      label: "Cross Product Result (AVOID)"
      style: {
        fill: "#FFEBEE"
        stroke: "#F44336"
        stroke-width: 2
      }
      cp_row: {
        direction: right
        style.fill: transparent
        style.stroke: transparent
        cp_left: {
          label: "orders ⋈ customers"
          shape: rectangle
          style: {
            fill: "#FFCDD2"
            stroke: "#D32F2F"
          }
        }
        cp_x: {
          label: "✕"
          shape: text
          style: {
            font-size: 28
            font-color: "#D32F2F"
            bold: true
          }
        }
        cp_right: {
          label: "products ⋈ categories"
          shape: rectangle
          style: {
            fill: "#FFCDD2"
            stroke: "#D32F2F"
          }
        }
      }
      cp_output: {
        label: "Output: |A| × |B| × |C| × |D| rows\n= 10,000 × 1,000 × 500 × 50\n= 250 BILLION rows"
        shape: rectangle
        style: {
          fill: "#FFCDD2"
          stroke: "#D32F2F"
          stroke-width: 3
        }
      }
      cp_left -> cp_output -> cp_right
    }
    cost_comparison: {
      label: "Cost Comparison"
      shape: sql_table
      row1: "Connected Join | Base Cost | 1,000"
      row2: "Cross Product | Penalized Cost | 1,000,000"
      row3: "Penalty Multiplier | factor | 1000×"
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  legend: {
    label: "Legend"
    style: {
      fill: "#FAFAFA"
      stroke: "#BDBDBD"
    }
    leg_connected: {
      label: "←→  Connected by join predicate"
      shape: text
      style.font-color: "#388E3C"
    }
    leg_disconnected: {
      label: "- - →  No join predicate (cross product)"
      shape: text
      style.font-color: "#F44336"
    }
    leg_component: {
      label: "□  Connected component (tables with paths)"
      shape: text
    }
  }
  handling_strategies: {
    label: "Handling Disconnected Components"
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
    strategy1: "1. Detect components via BFS on join graph"
    strategy2: "2. Join within components first (smallest → largest)"
    strategy3: "3. Apply cross product penalty between components"
    strategy4: "4. Warn user: query may be malformed"
  }
}
join_graph.component1.table_a -> join_graph.component1.table_b: {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
  }
}
join_graph.component2.table_c -> join_graph.component2.table_d: {
  style: {
    stroke: "#1976D2"
    stroke-width: 3
  }
}