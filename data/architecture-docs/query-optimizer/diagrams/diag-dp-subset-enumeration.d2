direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: |'md
    # Dynamic Programming: Subset Enumeration
    DP Table for Tables {A, B, C, D} — 15 non-empty subsets
  '|
  style.stroke: transparent
  style.fill: transparent
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  size1: {
    direction: down
    label: "Size-1 Subsets"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    sA: "{A}" {
      shape: circle
      width: 60
      style.fill: "#C8E6C9"
    }
    sB: "{B}" {
      shape: circle
      width: 60
      style.fill: "#C8E6C9"
    }
    sC: "{C}" {
      shape: circle
      width: 60
      style.fill: "#C8E6C9"
    }
    sD: "{D}" {
      shape: circle
      width: 60
      style.fill: "#C8E6C9"
    }
  }

  size2: {
    direction: down
    label: "Size-2 Subsets"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    sAB: "{A,B}" {
      shape: rectangle
      width: 70
      style.fill: "#BBDEFB"
    }
    sAC: "{A,C}" {
      shape: rectangle
      width: 70
      style.fill: "#BBDEFB"
    }
    sAD: "{A,D}" {
      shape: rectangle
      width: 70
      style.fill: "#BBDEFB"
    }
    sBC: "{B,C}" {
      shape: rectangle
      width: 70
      style.fill: "#BBDEFB"
    }
    sBD: "{B,D}" {
      shape: rectangle
      width: 70
      style.fill: "#BBDEFB"
    }
    sCD: "{C,D}" {
      shape: rectangle
      width: 70
      style.fill: "#BBDEFB"
    }
  }

  size3: {
    direction: down
    label: "Size-3 Subsets"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    sABC: "{A,B,C}" {
      shape: rectangle
      width: 80
      style.fill: "#FFE0B2"
    }
    sABD: "{A,B,D}" {
      shape: rectangle
      width: 80
      style.fill: "#FFE0B2"
    }
    sACD: "{A,C,D}" {
      shape: rectangle
      width: 80
      style.fill: "#FFE0B2"
    }
    sBCD: "{B,C,D}" {
      shape: rectangle
      width: 80
      style.fill: "#FFE0B2"
    }
  }

  size4: {
    direction: down
    label: "Size-4 (Full)"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    sABCD: "{A,B,C,D}" {
      shape: rectangle
      width: 100
      style.fill: "#F8BBD9"
      style.stroke-width: 3
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  expansion: {
    label: "Building {A,B,C}: Three Partition Paths"
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    
    path1: {
      label: "Path 1"
      direction: right
      style.fill: transparent
      p1_left: "{A,B}" {
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      p1_plus: "⋈" {
        shape: circle
        width: 30
      }
      p1_right: "{C}" {
        shape: circle
        style.fill: "#C8E6C9"
      }
      p1_res: "{A,B,C}" {
        shape: rectangle
        style.fill: "#FFE0B2"
      }
      p1_left -> p1_plus
      p1_plus -> p1_right
      p1_right -> p1_res: "merge"
    }

    path2: {
      label: "Path 2"
      direction: right
      style.fill: transparent
      p2_left: "{A,C}" {
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      p2_plus: "⋈" {
        shape: circle
        width: 30
      }
      p2_right: "{B}" {
        shape: circle
        style.fill: "#C8E6C9"
      }
      p2_res: "{A,B,C}" {
        shape: rectangle
        style.fill: "#FFE0B2"
      }
      p2_left -> p2_plus
      p2_plus -> p2_right
      p2_right -> p2_res: "merge"
    }

    path3: {
      label: "Path 3"
      direction: right
      style.fill: transparent
      p3_left: "{B,C}" {
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      p3_plus: "⋈" {
        shape: circle
        width: 30
      }
      p3_right: "{A}" {
        shape: circle
        style.fill: "#C8E6C9"
      }
      p3_res: "{A,B,C}" {
        shape: rectangle
        style.fill: "#FFE0B2"
      }
      p3_left -> p3_plus
      p3_plus -> p3_right
      p3_right -> p3_res: "merge"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  formula: {
    label: |'md
      **Complexity Analysis**
      | Tables | Subsets (2ⁿ - 1) | Partitions |
      |--------|------------------|------------|
      | 4      | 15               | 25         |
      | 8      | 255              | 1,079      |
      | 12     | 4,095            | 23,051     |
      | 15     | 32,767           | 237,510    |
      **Key Insight**: O(3ⁿ) total work — memoization reuses subproblems
    '|
    shape: rectangle
    width: 400
    style.fill: "#F5F5F5"
    style.stroke: "#BDBDBD"
  }

  memoization: {
    label: |'md
      **DP Table Memoization**
      python
      dp_table[subset] = best_plan
      # Reuse {A,B} when building:
      # - {A,B,C} via {A,B} + {C}
      # - {A,B,D} via {A,B} + {D}
      # - {A,B,C,D} via {A,B} + {C,D}
      
      Each subset computed **once**, reused **many times**.
    '|
    shape: rectangle
    width: 400
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}

# Cross-layer Lattice Connections
row1.size1.sA -> row1.size2.sAB: "A" {style.stroke: "#4CAF50"; style.stroke-dash: 2}
row1.size1.sB -> row1.size2.sAB: "B" {style.stroke: "#4CAF50"; style.stroke-dash: 2}
row1.size1.sA -> row1.size2.sAC: "A" {style.stroke: "#4CAF50"; style.stroke-dash: 2}
row1.size1.sC -> row1.size2.sAC: "C" {style.stroke: "#4CAF50"; style.stroke-dash: 2}
row1.size1.sB -> row1.size2.sBC: "B" {style.stroke: "#4CAF50"; style.stroke-dash: 2}
row1.size1.sC -> row1.size2.sBC: "C" {style.stroke: "#4CAF50"; style.stroke-dash: 2}

row1.size2.sAB -> row1.size3.sABC: "Join C" {style.stroke: "#2196F3"}
row1.size2.sAC -> row1.size3.sABC: "Join B" {style.stroke: "#2196F3"}
row1.size2.sBC -> row1.size3.sABC: "Join A" {style.stroke: "#2196F3"}

row1.size3.sABC -> row1.size4.sABCD: "join" {style.stroke: "#E91E63"; style.stroke-width: 2}
row1.size3.sABD -> row1.size4.sABCD: "join" {style.stroke: "#E91E63"; style.stroke-width: 2}
row1.size3.sACD -> row1.size4.sABCD: "join" {style.stroke: "#E91E63"; style.stroke-width: 2}
row1.size3.sBCD -> row1.size4.sABCD: "join" {style.stroke: "#E91E63"; style.stroke-width: 2}