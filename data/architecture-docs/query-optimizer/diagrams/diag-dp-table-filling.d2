direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # DP Table: Best Plan Per Subset
    Dynamic Programming for Join Order Optimization
  '|
}
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  dp_table: "DP Table (memoized results)" {
    direction: down
    
    header: {
      label: |'md
        | Subset | Best Plan | Cost |
        |--------|-----------|------|
      '|
    }
    
    entry_a: {
      label: "| **{A}** | SeqScan(A) | 100 |"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    entry_b: {
      label: "| **{B}** | SeqScan(B) | 500 |"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    entry_c: {
      label: "| **{C}** | IndexScan(C) | 50 |"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    entry_ab: {
      label: "| **{A,B}** | HashJoin(A,B) | 1,800 |"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    entry_ac: {
      label: "| **{A,C}** | HashJoin(A,C) | 350 |"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    entry_bc: {
      label: "| **{B,C}** | HashJoin(B,C) | 2,100 |"
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    entry_abc: {
      label: "| **{A,B,C}** | HashJoin(A,C) ⋈ B | 3,250 |"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      style.bold: true
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  partition_section: "Computing {A,B,C} Entry" {
    direction: down
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    
    partition_title: {
      label: "### Partition {A,B,C} into all valid splits:"
    }
    
    partition: "" {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      p1: "Partition 1" {
        direction: down
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        p1_label: "{A} ⋈ {B,C}"
        p1_left: "left: {A}\ncost: 100"
        p1_right: "right: {B,C}\ncost: 2,100"
        p1_join: "join: 100 × 2,100"
        p1_total: "total: 4,850"
        p1_left -> p1_join
        p1_right -> p1_join
        p1_join -> p1_total
      }
      p2: "Partition 2" {
        direction: down
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        p2_label: "{B} ⋈ {A,C}"
        p2_left: "left: {B}\ncost: 500"
        p2_right: "right: {A,C}\ncost: 350"
        p2_join: "join: 500 × 350"
        p2_total: "total: 3,250"
        p2_left -> p2_join
        p2_right -> p2_join
        p2_join -> p2_total
      }
      p3: "Partition 3" {
        direction: down
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        p3_label: "{C} ⋈ {A,B}"
        p3_left: "left: {C}\ncost: 50"
        p3_right: "right: {A,B}\ncost: 1,800"
        p3_join: "join: 50 × 1,800"
        p3_total: "total: 3,750"
        p3_left -> p3_join
        p3_right -> p3_join
        p3_join -> p3_total
      }
    }
    
    winner: {
      label: |'md
        ✓ Winner: Partition 2
        (minimum cost = 3,250)
      '|
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.bold: true
    }
    
    partition.p2 -> winner: "minimum" {
      style.stroke: "#388E3C"
      style.stroke-width: 3
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  algorithm: "DP Algorithm" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    
    algo_title: {
      label: "### Selinger Algorithm Steps:"
    }
    
    step1: {
      label: "1. Initialize: Single-table plans"
      code: |'python
        for table in tables:
            dp[{table}] = best_scan(table)
      '|
      width: 320
    }
    step2: {
      label: "2. Build up: Larger subsets"
      code: |'python
        for size in 2..N:
            for subset in subsets_of_size(size):
                dp[subset] = min(
                    combine(dp[left], dp[right])
                    for (left, right) in partitions(subset)
                )
      '|
      width: 320
    }
    step3: {
      label: "3. Result: Optimal plan"
      code: |'python
        return dp[{all_tables}]
      '|
      width: 320
    }
    step1 -> step2 -> step3
  }
  
  complexity: "Complexity Analysis" {
    direction: down
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    
    comp_title: {
      label: "### Search Space Reduction:"
    }
    
    naive: |'md
      **Naive enumeration:**
      - 3 tables: 12 orderings
      - 5 tables: 120 orderings
      - 10 tables: 3.6M orderings
      - 15 tables: 1.3T orderings
    '|
    
    dp: |'md
      **Dynamic Programming:**
      - 3 tables: 7 subsets
      - 5 tables: 31 subsets
      - 10 tables: 1,023 subsets
      - 15 tables: 32,767 subsets
    '|
    
    savings: {
      label: |'md
        **Speedup at 15 tables:**
        ~40 million times faster!
      '|
      style.fill: "#B2DFDB"
      style.bold: true
    }
  }
}

legend: {
  direction: down
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  legend_title: "Key Insight"
  legend_text: |'md
    **Optimal Substructure:**
    The best plan for {A,B,C} must use
    the best plans for its constituent subsets.
    If dp[{A,C}] could be improved, we'd use
    that improvement in dp[{A,B,C}] too.
  '|
}
legend.near: bottom-right

row1.dp_table.entry_abc -> row2.partition_section.partition.p2: "computed from" {
  style.stroke-dash: 4
  style.stroke: "#666"
}