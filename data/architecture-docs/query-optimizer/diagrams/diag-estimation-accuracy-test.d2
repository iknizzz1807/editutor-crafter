direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Estimation Accuracy: Estimated vs Actual
  Comparing optimizer cardinality estimates against ground truth
| {near: top-center}
row_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  uniform: {
    direction: down
    label: "Uniform Distribution\n(Good Accuracy)"
    uniform_query: {
      label: "Query: WHERE age BETWEEN 30 AND 40"
      width: 280
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    uniform_table: {
      shape: sql_table
      label: "Estimation Results"
      col1: "Est. Rows | Actual | Error"
      r1: "8,500 | 8,247 | +3.1%"
      r2: "1,200 | 1,156 | +3.8%"
      r3: "450 | 471 | -4.5%"
      r4: "12,000 | 11,892 | +0.9%"
    }
    uniform_hist: {
      direction: right
      label: "Histogram Buckets"
      width: 320
      b1: {
        label: "20-30"
        shape: rectangle
        width: 60
        height: 80
        style.fill: "#BBDEFB"
      }
      b2: {
        label: "30-40"
        shape: rectangle
        width: 60
        height: 85
        style.fill: "#4CAF50"
        style.stroke: "#2E7D32"
        style.stroke-width: 3
      }
      b3: {
        label: "40-50"
        shape: rectangle
        width: 60
        height: 80
        style.fill: "#BBDEFB"
      }
      b4: {
        label: "50-60"
        shape: rectangle
        width: 60
        height: 75
        style.fill: "#BBDEFB"
      }
    }
    uniform_accuracy: {
      label: "Accuracy: 96.7%\nEstimates within 5% of actual"
      width: 280
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      style.bold: true
    }
  }
  skewed: {
    direction: down
    label: "Skewed Distribution\n(Larger Error)"
    skewed_query: {
      label: "Query: WHERE income > 100000"
      width: 280
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
    }
    skewed_table: {
      shape: sql_table
      label: "Estimation Results"
      col1: "Est. Rows | Actual | Error"
      r1: "2,000 | 15,847 | -87.4%"
      r2: "500 | 23 | +2070%"
      r3: "8,000 | 892 | +797%"
      r4: "1,500 | 12,403 | -87.9%"
    }
    skewed_hist: {
      direction: right
      label: "Histogram Buckets"
      width: 320
      s1: {
        label: "0-50K"
        shape: rectangle
        width: 60
        height: 120
        style.fill: "#FFCDD2"
      }
      s2: {
        label: "50-100K"
        shape: rectangle
        width: 60
        height: 90
        style.fill: "#FFCDD2"
      }
      s3: {
        label: "100-150K"
        shape: rectangle
        width: 60
        height: 25
        style.fill: "#F44336"
        style.stroke: "#B71C1C"
        style.stroke-width: 3
      }
      s4: {
        label: "150K+"
        shape: rectangle
        width: 60
        height: 15
        style.fill: "#FFCDD2"
      }
    }
    skewed_accuracy: {
      label: "Accuracy: 23.4%\nIndependence assumption fails"
      width: 280
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.bold: true
    }
  }
}
row_comparison.uniform.uniform_query -> row_comparison.uniform.uniform_hist: "Histogram\nlookup"
row_comparison.skewed.skewed_query -> row_comparison.skewed.skewed_hist: "Histogram\nlookup"
error_sources: {
  label: "Sources of Estimation Error"
  direction: right
  source1: {
    label: "Independence\nAssumption"
    width: 180
    code: |'python
      # Assumes P(A AND B) = P(A) * P(B)
      # Fails when columns correlate
      sel = sel_age * sel_income  # Wrong!
    '|
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  source2: {
    label: "Uniform Within\nBucket"
    width: 180
    code: |'python
      # Assumes even distribution
      # in histogram bucket
      # Actual: 90% at bucket min
    '|
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  source3: {
    label: "Stale\nStatistics"
    width: 180
    code: |'python
      # ANALYZE ran yesterday
      # INSERT added 50% more rows
      # Estimates now systematically low
    '|
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
row_comparison -> error_sources: "Why estimates diverge"
legend_box: {
  near: bottom-center
  direction: right
  label: ""
  style.fill: transparent
  style.stroke: "#9E9E9E"
  leg1: {
    label: "✓ Within 2x"
    shape: rectangle
    width: 100
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  leg2: {
    label: "✗ Outside 2x"
    shape: rectangle
    width: 100
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
  leg3: {
    label: "Highlighted bucket"
    shape: rectangle
    width: 120
    style.fill: "#4CAF50"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }
}
validation: {
  label: "EstimationValidator.check()"
  direction: right
  val_code: {
    width: 450
    code: |'python
      def validate(self, table, column, pred, actual):
          estimated = self.estimate(pred)
          error_ratio = actual / estimated
          if 0.5 <= error_ratio <= 2.0:
              return "PASS"  # Within 2x
          else:
              return "FAIL"  # Investigate!
    '|
  }
  metrics: {
    shape: sql_table
    label: "Validation Metrics"
    m1: "within_2x_pct | 83.3%"
    m2: "mean_error | 1.23x"
    m3: "max_error | 20.7x"
    m4: "overestimates | 2"
    m5: "underestimates | 4"
  }
}
error_sources -> validation: "Track and measure"
footer_note: {
  near: bottom-center
  label: "Production databases use multi-column statistics and query feedback to reduce estimation errors"
  shape: text
  style.italic: true
  style.font-color: "#616161"
}