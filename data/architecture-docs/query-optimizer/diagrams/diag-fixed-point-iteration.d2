direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Rule Engine: Fixed-Point Iteration"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  start: {
    shape: oval
    label: "START\nInput: Logical Plan"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  init: {
    label: "Initialize"
    width: 280
    init_code: |'python
      iteration = 0
      max_iterations = 100
      current_plan = input_plan
      rules = [
        ConstantFoldingRule(),
        RedundantPredicateRule(),
        PredicatePushdownRule(),
      ]
    '|
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  check_limit: {
    shape: diamond
    label: "iteration <\nmax_iterations?"
    width: 140
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  apply_rules: {
    label: "Apply All Rules\n(Post-order Traversal)"
    width: 300
    apply_code: |'python
      modified = False
      for rule in rules:
        result = apply_rule_recursive(
          rule, current_plan, context
        )
        if result.modified:
          current_plan = result.new_plan
          modified = True
          log_transformation(result)
          break  # Restart from top
    '|
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  check_changed: {
    shape: diamond
    label: "Plan\nChanged?"
    width: 120
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  increment: {
    label: "Increment Counter"
    width: 200
    incr_code: |'python
      iteration += 1
      # Continue loop
    '|
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fixed_point: {
    shape: hexagon
    label: "FIXED POINT\nNo More Changes"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  max_reached: {
    shape: hexagon
    label: "MAX ITERATIONS\nSafety Valve\n(100 reached)"
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
  }
}
row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  done: {
    shape: oval
    label: "DONE\nOutput: Optimized Plan"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  legend_content: |md
    - **Green**: Success path
    - **Yellow**: Decision point
    - **Red**: Safety limit reached
    - **Blue**: Rule application
  |
}
flow_label: {
  near: center-left
  label: |md
    **Fixed-Point Iteration**
    Rules are applied until the plan
    stops changing. Each iteration
    may enable new transformations.
  |
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  width: 200
}
start -> init: "Begin"
init -> check_limit: "Ready"
check_limit -> apply_rules: "Yes" {
  style.stroke: "#4CAF50"
}
check_limit -> max_reached: "No (safety)" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 4
}
apply_rules -> check_changed: "Applied"
check_changed -> increment: "Yes" {
  label: "modified=True"
  style.stroke: "#4CAF50"
}
check_changed -> fixed_point: "No" {
  label: "modified=False"
  style.stroke: "#1976D2"
}
increment -> check_limit: "Continue" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}
fixed_point -> done: "Complete" {
  style.stroke: "#4CAF50"
}
max_reached -> done: "Complete\n(with warning)" {
  style.stroke: "#D32F2F"
  style.stroke-dash: 4
}