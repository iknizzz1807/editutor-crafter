direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Greedy Fallback for Large Queries
  When DP becomes intractable, switch to greedy
| {near: top-center}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  dp_section: {
    direction: down
    label: "Dynamic Programming Path"
    style.fill: "#E8F5E9"
    dp_input: {
      label: "Query with N tables"
      width: 180
      style.fill: white
    }
    dp_check: {
      shape: diamond
      label: "N ≤ 8?"
      width: 120
      style.fill: "#C8E6C9"
    }
    dp_execute: {
      label: "Full DP Enumeration"
      width: 180
      code: |'python
        for subset in subsets:
          for partition in partitions:
            compute_cost()
            memoize_best()
      '|
      style.fill: white
    }
    dp_complexity: {
      label: "Complexity: O(3^N)"
      width: 180
      style.fill: "#A5D6A7"
    }
    dp_input -> dp_check
    dp_check -> dp_execute: "Yes"
    dp_execute -> dp_complexity
  }
  greedy_section: {
    direction: down
    label: "Greedy Fallback Path"
    style.fill: "#FFF3E0"
    greedy_trigger: {
      label: "N > 8 tables detected"
      width: 180
      style.fill: "#FFE0B2"
    }
    greedy_algo: {
      label: "Greedy Join Selection"
      width: 200
      code: |'python
        remaining = tables
        current = smallest_table
        while remaining:
          best = min_cost_join(
            current, remaining
          )
          current = join(best)
          remaining.remove(best)
      '|
      style.fill: white
    }
    greedy_complexity: {
      label: "Complexity: O(N²)"
      width: 180
      style.fill: "#FFCC80"
    }
    greedy_trigger -> greedy_algo: "Switch"
    greedy_algo -> greedy_complexity
  }
  dp_check -> greedy_trigger: "No (too many tables)"
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  complexity_chart: {
    direction: down
    label: "Why Greedy is Necessary"
    style.fill: "#FAFAFA"
    chart_title: {
      label: "DP vs Greedy: Operations by Table Count"
      style.fill: transparent
      style.font-size: 14
    }
    chart_data: {
      shape: sql_table
      label: "Complexity Comparison"
      f1: "Tables | DP (3^N)     | Greedy (N²)"
      f2: "4      | 81          | 16"
      f3: "6      | 729         | 36"
      f4: "8      | 6,561       | 64"
      f5: "10     | 59,049      | 100"
      f6: "12     | 531,441     | 144"
      f7: "15     | 14.3M       | 225"
      f8: "20     | 3.5B        | 400"
    }
    chart_note: {
      label: "At N=15: DP needs 14 million subset evaluations\nGreedy needs only 225 join evaluations"
      width: 280
      style.fill: "#FFF9C4"
      style.stroke: "#FBC02D"
    }
    chart_title -> chart_data -> chart_note
  }
  quality_tradeoff: {
    direction: down
    label: "Quality vs Speed Tradeoff"
    style.fill: "#FAFAFA"
    quality_title: {
      label: "What You Trade"
      style.fill: transparent
    }
    dp_guarantee: {
      label: "DP Guarantee"
      width: 200
      code: |'text
        • Provably optimal plan
        • Explores ALL join orders
        • Cost: minutes for N>12
      '|
      style.fill: "#E8F5E9"
    }
    greedy_guarantee: {
      label: "Greedy Tradeoff"
      width: 200
      code: |'text
        • Locally optimal choices
        • May miss global optimum
        • Cost: milliseconds always
      '|
      style.fill: "#FFF3E0"
    }
    quality_note: {
      label: "In practice: greedy often finds\nplans within 10-20% of optimal"
      width: 220
      style.fill: "#E3F2FD"
    }
    quality_title -> dp_guarantee -> greedy_guarantee -> quality_note
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  greedy_detail: {
    direction: down
    label: "Greedy Algorithm Detail"
    style.fill: "#FAFAFA"
    step1: {
      label: "Step 1: Initialize"
      code: |'python
        # Start with smallest table
        current = min(tables, 
          key=lambda t: stats[t].rows)
        remaining = tables - {current}
      '|
      width: 260
      style.fill: "#E1F5FE"
    }
    step2: {
      label: "Step 2: Iterate"
      code: |'python
        while remaining:
          # Find cheapest join partner
          best = argmin(t in remaining,
            cost(join(current, t)))
          current = join(current, best)
          remaining.remove(best)
      '|
      width: 260
      style.fill: "#E1F5FE"
    }
    step3: {
      label: "Step 3: Result"
      code: |'python
        # current is now the full
        # join tree (left-deep only)
        return current
      '|
      width: 260
      style.fill: "#E1F5FE"
    }
    step1 -> step2 -> step3
  }
  example: {
    direction: down
    label: "Example: 10-Table Query"
    style.fill: "#FAFAFA"
    tables_box: {
      label: "Tables (with row counts)"
      code: |'text
        A: 1K    F: 50K
        B: 5K    G: 100K
        C: 10K   H: 200K
        D: 20K   I: 500K
        E: 30K   J: 1M
      '|
      width: 150
      style.fill: white
    }
    greedy_order: {
      label: "Greedy Join Order"
      code: |'text
        1. A (1K) - smallest
        2. A ⋈ B (5K) - best partner
        3. (A⋈B) ⋈ C (10K)
        4. Continue greedily...
        Result: left-deep tree
      '|
      width: 200
      style.fill: "#C8E6C9"
    }
    timing: {
      label: "Performance"
      code: |'text
        DP (3^10):    59K subsets
                      ~500ms
        Greedy:       10 iterations
                      ~5ms
        Speedup:      100x faster
      '|
      width: 160
      style.fill: "#FFCC80"
    }
    tables_box -> greedy_order -> timing
  }
}
dp_complexity -> complexity_chart
greedy_complexity -> quality_tradeoff
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#CCC"
  label: "Legend"
  dp_color: {
    label: "DP path (optimal)"
    style.fill: "#C8E6C9"
  }
  greedy_color: {
    label: "Greedy path (fast)"
    style.fill: "#FFCC80"
  }
}