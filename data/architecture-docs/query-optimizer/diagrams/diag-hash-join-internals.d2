direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  shape: text
  label: "Hash Join: Build and Probe Phase Mechanics (hash_join.c)"
  style: {
    font-size: 32
    bold: true
  }
}

phase_row: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  build_phase: {
    direction: down
    label: "PHASE 1: BUILD (Smaller Input)"
    style.fill: "#F1F8E9"

    build_input: {
      label: "Build Side: Relation R"
      shape: rectangle
      style.fill: "#E8F5E9"
      
      scan: "SeqScan(R)" {
        shape: rectangle
        style.fill: "#C8E6C9"
      }
    }

    build_arrow: " " {
      shape: text
      label: "↓"
      style.font-size: 24
    }

    hash_table_container: {
      label: "In-Memory Hash Table"
      shape: cylinder
      style: {
        fill: "#FFF3E0"
        stroke: "#FF9800"
      }
      
      structure: {
        shape: code
        label: "Internal Layout"
        code: |'md
          [Bucket 0] -> {Key: 101, RowPtr: 0x44}
          [Bucket 1] -> {Key: 205, RowPtr: 0x82}
          [Bucket 2] -> {Key: 101, RowPtr: 0x99}
          ...
          [Bucket N] -> {Key: 305, RowPtr: 0xAC}
        '|
      }
    }

    build_input.scan -> build_arrow
    build_arrow -> hash_table_container: "O(M) inserts"
  }

  separator: {
    width: 60
    style.stroke: transparent
    style.fill: transparent
  }

  probe_phase: {
    direction: down
    label: "PHASE 2: PROBE (Larger Input)"
    style.fill: "#E3F2FD"

    probe_input: {
      label: "Probe Side: Relation S"
      shape: rectangle
      style.fill: "#E3F2FD"
      
      scan: "SeqScan(S)" {
        shape: rectangle
        style.fill: "#BBDEFB"
      }
    }

    probe_arrow: " " {
      shape: text
      label: "↓"
      style.font-size: 24
    }

    probe_engine: {
      label: "Join Engine"
      shape: diamond
      style.fill: "#FCE4EC"
    }

    output_stream: {
      label: "Joined Output"
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
      }
      
      samples: {
        shape: code
        label: "Result Set"
        code: |'md
          (101, 'Alice', 'Dept_A')
          (205, 'Bob', 'Dept_B')
          (101, 'Alice', 'Dept_C')
        '|
      }
    }

    probe_input.scan -> probe_arrow
    probe_arrow -> probe_engine: "O(N) probes"
    probe_engine -> output_stream: "emit matches"
  }
}

# Cross-phase lookup relationship
phase_row.build_phase.hash_table_container -> phase_row.probe_phase.probe_engine: "hash(key) lookup" {
  style: {
    stroke: "#FF9800"
    stroke-width: 3
    animated: true
  }
}

memory_management: {
  direction: down
  label: "Memory & Spill Management"
  style.stroke-dash: 5

  strategy_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent

    optimal: {
      label: "Optimal: Single Pass"
      shape: rectangle
      style.fill: "#E8F5E9"
      description: |'md
        **Constraint:** `M * row_width < work_mem`
        **IO Cost:** (M + N) sequential pages
      '|
    }

    grace_join: {
      label: "Spill: Grace Hash Join"
      shape: rectangle
      style.fill: "#FFEBEE"
      description: |'md
        **Constraint:** `M * row_width > work_mem`
        **Behavior:** Partition to disk -> recursive join
      '|
    }
  }
}

phase_row -> memory_management: "work_mem check"

implementation_logic: {
  label: "Algorithm Implementation (hash_join.c)"
  direction: down
  
  code_block: {
    shape: code
    code: |'c
      // PHASE 1: Build Phase
      for (row_r in build_side) {
          uint32 h = hash(row_r.key) % n_buckets;
          ht_insert(&ht[h], row_r);
      }
      
      // PHASE 2: Probe Phase
      for (row_s in probe_side) {
          uint32 h = hash(row_s.key) % n_buckets;
          for (entry in ht[h]) {
              if (entry.key == row_s.key) {
                  emit_joined_row(entry, row_s);
              }
          }
      }
    '|
  }
}

memory_management -> implementation_logic

analysis: {
  shape: sql_table
  label: "Join Complexity Analysis"
  h1: "Phase | CPU Complexity | Memory Complexity"
  r1: "Build | O(M) | O(M) for hash table"
  r2: "Probe | O(N) | O(1) per lookup"
  r3: "Total | O(M + N) | M = small, N = large"
  r4: "Best | Build on smaller input | Minimizes memory pressure"
}

implementation_logic -> analysis

legend_container: {
  label: "Legend"
  near: bottom-right
  direction: right
  
  l1: "R-Side (Build)" { style.fill: "#E8F5E9" }
  l2: "S-Side (Probe)" { style.fill: "#E3F2FD" }
  l3: "State / HT" { style.fill: "#FFF3E0" }
  l4: "Output" { style.fill: "#C8E6C9" }
}