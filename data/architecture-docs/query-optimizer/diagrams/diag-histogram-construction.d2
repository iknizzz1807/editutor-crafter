direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Equi-Depth Histogram Construction
  Building buckets with equal row counts, adapting to data distribution
| {near: top-center}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: {
    direction: down
    label: "Step 1: Raw Column Values"
    width: 280
    raw_data: {
      shape: sql_table
      label: "price column (stats_collector.c)"
      r1: "0x00 | float   | 5.99"
      r2: "0x04 | float   | 150.00"
