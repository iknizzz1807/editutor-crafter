row1.step1 -> row1.step2: "qsort | sort()"

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step3: {
    direction: down
    label: "Step 3: Compute Bucket Boundaries"
    width: 600
    calc_box: {
      label: "Bucket Size Calculation (stats.h)"
      width: 550
      code: |'python
        n = len(sorted_values)     # n = 20
        bucket_count = 4
        bucket_size = n // bucket_count  # 20 // 4 = 5 rows per bucket
        # Boundaries identified at sorted_values indices:
        # B0: [0] to [4]   | B1: [5] to [9]
        # B2: [10] to [14] | B3: [15] to [19]
      '|
    }
    boundary_viz: {
      direction: right
      label: "Memory Representation of Buckets"
      b0: {
        label: "Bucket 0"
        shape: rectangle
        width: 120
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: "5.99 -> 12.50"
        rows: "Rows: 5"
      }
      b1: {
        label: "Bucket 1"
        shape: rectangle
        width: 180
        style.fill: "#E3F2FD"
        style.stroke: "#2196F3"
        note: "15.00 -> 52.50"
        rows: "Rows: 5"
      }
      b2: {
        label: "Bucket 2"
        shape: rectangle
        width: 200
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
        note: "75.00 -> 150.00"
        rows: "Rows: 5"
      }
      b3: {
        label: "Bucket 3"
        shape: rectangle
        width: 250
        style.fill: "#FFEBEE"
        style.stroke: "#F44336"
        note: "175.00 -> 450.00"
        rows: "Rows: 5"
      }
      b0 -> b1 -> b2 -> b3: {style.stroke-dash: 3}
    }
  }
}

row1.step2 -> row2.step3: "partition"

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step4: {
    direction: down
    label: "Step 4: Final Histogram Structure"
    width: 750
    histogram: {
      shape: sql_table
      label: "struct ColumnHistogram (histogram.h)"
      f1: "0x00 | char*    | col_name // 'price'"
      f2: "0x08 | uint32_t | bucket_count // 4"
      f3: "0x0C | uint32_t | total_rows // 20"
      f4: "0x10 | Bucket*  | buckets // Pointer to array"
      f5: "0x18 | float    | null_frac // 0.0"
      sz: "Size: 32 bytes (header)"
    }
    bucket_array: {
      direction: right
      label: "HistogramBucket buckets[4]"
      
      bucket0: {
        shape: class
        label: "Bucket[0]"
        min: "float | 5.99"
        max: "float | 12.50"
        rows: "uint32 | 5"
        distinct: "uint32 | 5"
      }
      bucket1: {
        shape: class
        label: "Bucket[1]"
        min: "float | 15.00"
        max: "float | 52.50"
        rows: "uint32 | 5"
        distinct: "uint32 | 5"
      }
      bucket2: {
        shape: class
        label: "Bucket[2]"
        min: "float | 75.00"
        max: "float | 150.00"
        rows: "uint32 | 5"
        distinct: "uint32 | 5"
      }
      bucket3: {
        shape: class
        label: "Bucket[3]"
        min: "float | 175.00"
        max: "float | 450.00"
        rows: "uint32 | 5"
        distinct: "uint32 | 5"
      }
    }
    histogram.f4 -> bucket_array.bucket0: "points to"
  }
}

row2.step3 -> row3.step4: "build"

key_insight: {
  near: bottom-center
  label: "Implementation Note"
  insight: |'md
    **Equi-depth adapts to data distribution:**

    | Bucket | Range Size | Rows | Selectivity Prec. |
    |--------|------------|------|-------------------|
    | 0      | 6.51       | 5    | HIGH (Narrow)     |
    | 1      | 37.50      | 5    | MEDIUM            |
    | 2      | 75.00      | 5    | LOW               |
    | 3      | 275.00     | 5    | VERY LOW (Wide)   |

    Dense regions (low values) get **narrow buckets** for precise cost estimation.
    Sparse regions (outliers) get **wide buckets** but maintain row balance.
    
    Equi-width (alternative) would create 4 equal ranges of 112.5 units.
    This would result in skewed bucket row counts (e.g., 14, 2, 1, 3), 
    making selectivity estimation highly inaccurate for the dense region.
  '|
}