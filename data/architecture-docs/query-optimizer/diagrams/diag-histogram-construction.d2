      r4: "0x0C | float   | 8.25"
      r5: "0x10 | float   | 200.00"
      r6: "0x14 | float   | 6.00"
      r7: "0x18 | float   | 45.00"
      r8: "0x1C | float   | 15.00"
      r9: "0x20 | float   | 9.99"
      r10: "0x24 | float   | 175.00"
      dots: "0x28 | ...     | (10 more values)"
      sz: "Total: 20 values (80 bytes)"
    }
  }

  step2: {
    direction: down
    label: "Step 2: Sort Values"
    width: 280
    sorted_data: {
      shape: sql_table
      label: "sorted_prices[] (p_sort.c)"
      s1: "0x00 | float   | 5.99"
      s2: "0x04 | float   | 6.00"
      s3: "0x08 | float   | 8.25"
      s4: "0x0C | float   | 9.99"
      s5: "0x10 | float   | 12.50"
      s6: "0x14 | float   | 15.00"
      s7: "0x18 | float   | 18.75"
      s8: "0x1C | float   | 22.00"
      s9: "0x20 | float   | 45.00"
      s10: "0x24 | float   | 52.50"
      s11: "0x28 | float   | 75.00"
      s12: "0x2C | float   | 88.00"
      s13: "0x30 | float   | 95.00"
      s14: "0x34 | float   | 120.00"
      s15: "0x38 | float   | 150.00"
      s16: "0x3C | float   | 175.00"
      s17: "0x40 | float   | 200.00"
      s18: "0x44 | float   | 250.00"
      s19: "0x48 | float   | 320.00"
      s20: "0x4C | float   | 450.00"
      sz2: "Total: 20 values"
    }
