direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Join Algorithm Selection Decision Tree
| {
  near: top-center
}

classes: {
  decision: {
    shape: diamond
    width: 160
    height: 100
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
      font-size: 14
    }
  }
  algorithm: {
    shape: rectangle
    width: 200
    style: {
      stroke-width: 2
      border-radius: 8
      font-size: 14
      bold: true
    }
  }
  nlj: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  hash: {
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
    }
  }
  merge: {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
    }
  }
  cost_box: {
    shape: rectangle
    width: 240
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      stroke-dash: 2
      font: mono
      font-size: 11
    }
  }
  condition: {
    shape: rectangle
    width: 180
    style: {
      fill: transparent
      stroke: transparent
      font-size: 12
      italic: true
    }
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  start: "Join inputs available" {
    shape: oval
    width: 120
    style: {
      fill: "#E0E0E0"
      stroke: "#757575"
      stroke-width: 2
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dec1: "Small outer?\n(rows < 1000)" {
    class: decision
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    dec2: "Inner indexed\non join col?" {
      class: decision
    }
  }
  right_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    dec3: "Equi-join?\n(= operator)" {
      class: decision
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  nlj_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    nlj_node: "NestedLoopJoin" {
      class: [algorithm; nlj]
    }
    nlj_cost: |md
      cost = outer × inner_io
      where inner_io = log₂(inner)
    | {
      class: cost_box
    }
    nlj_when: "Best: small outer, indexed inner" {
      class: condition
      style.font-color: "#4CAF50"
    }
  }
  nlj_no_index_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    dec4: "Inputs\npre-sorted?" {
      class: decision
    }
  }
  hash_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    hash_node: "HashJoin" {
      class: [algorithm; hash]
    }
    hash_cost: |md
      cost = build + probe
      build = min(M,N) × 2×cpu
      probe = max(M,N) × cpu
    | {
      class: cost_box
    }
    hash_when: "Best: equi-join, unsorted" {
      class: condition
      style.font-color: "#2196F3"
    }
  }
  merge_check_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    dec5: "Output needs\nsorting?" {
      class: decision
    }
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  merge_from_nlj: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    merge1: "SortMergeJoin" {
      class: [algorithm; merge]
    }
    merge1_cost: |md
      cost = sort + merge
      sort = M log M + N log N
    | {
      class: cost_box
    }
    merge1_when: "Best: pre-sorted inputs" {
      class: condition
      style.font-color: "#9C27B0"
    }
  }
  fallback_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    fallback: "HashJoin\n(fallback)" {
      class: [algorithm; hash]
      width: 160
      style.fill: "#FFECB3"
    }
    fallback_cost: |md
      cost = build + probe
      (Grace hash if overflow)
    | {
      class: cost_box
    }
    fallback_when: "Fallback: no index, unsorted" {
      class: condition
      style.font-color: "#2196F3"
    }
  }
  merge_from_hash: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    merge2: "SortMergeJoin" {
      class: [algorithm; merge]
    }
    merge2_cost: |md
      cost = sort + merge
      (avoids downstream sort)
    | {
      class: cost_box
    }
    merge2_when: "Best: need sorted output" {
      class: condition
      style.font-color: "#9C27B0"
    }
  }
  hash_final: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    hash2: "HashJoin" {
      class: [algorithm; hash]
    }
    hash2_cost: |md
      cost = build + probe
      O(M + N) optimal for unsorted
    | {
      class: cost_box
    }
    hash2_when: "Default: unsorted" {
      class: condition
      style.font-color: "#2196F3"
    }
  }
}

legend_container: "" {
  direction: right
  near: bottom-center
  style.stroke: transparent
  style.fill: transparent
  leg_title: "Legend:" {
    shape: text
    style.bold: true
    style.font-size: 14
  }
  leg_nlj: "NestedLoop" {
    class: [algorithm; nlj]
    width: 100
  }
  leg_hash: "HashJoin" {
    class: [algorithm; hash]
    width: 100
  }
  leg_merge: "SortMerge" {
    class: [algorithm; merge]
    width: 100
  }
}

row1.start -> row2.dec1: "evaluate inputs"

row2.dec1 -> row3.left_branch.dec2: "YES" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
row2.dec1 -> row3.right_branch.dec3: "NO" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}

row3.left_branch.dec2 -> row4.nlj_branch.nlj_node: "YES" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
row3.left_branch.dec2 -> row4.nlj_no_index_branch.dec4: "NO" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}

row4.nlj_branch.nlj_node -> row4.nlj_branch.nlj_cost
row4.nlj_branch.nlj_cost -> row4.nlj_branch.nlj_when

row4.nlj_no_index_branch.dec4 -> row5.merge_from_nlj.merge1: "YES" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
row4.nlj_no_index_branch.dec4 -> row5.fallback_branch.fallback: "NO" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}

row5.merge_from_nlj.merge1 -> row5.merge_from_nlj.merge1_cost
row5.merge_from_nlj.merge1_cost -> row5.merge_from_nlj.merge1_when
row5.fallback_branch.fallback -> row5.fallback_branch.fallback_cost
row5.fallback_branch.fallback_cost -> row5.fallback_branch.fallback_when

row3.right_branch.dec3 -> row4.hash_branch.hash_node: "YES" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
row3.right_branch.dec3 -> row4.merge_check_branch.dec5: "NO" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}

row4.hash_branch.hash_node -> row4.hash_branch.hash_cost
row4.hash_branch.hash_cost -> row4.hash_branch.hash_when

row4.merge_check_branch.dec5 -> row5.merge_from_hash.merge2: "YES" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
row4.merge_check_branch.dec5 -> row5.hash_final.hash2: "NO" {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}

row5.merge_from_hash.merge2 -> row5.merge_from_hash.merge2_cost
row5.merge_from_hash.merge2_cost -> row5.merge_from_hash.merge2_when
row5.hash_final.hash2 -> row5.hash_final.hash2_cost
row5.hash_final.hash2_cost -> row5.hash_final.hash2_when