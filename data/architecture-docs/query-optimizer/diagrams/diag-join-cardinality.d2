direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Join Cardinality Estimation
  `output_rows = (rows_A × rows_B) / max(distinct_A, distinct_B)`
| {near: top-center}
row_inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  table_a: {
    direction: down
    label: "Table A: users"
    stats_a: {
      shape: sql_table
      label: "Statistics (users)"
      total_rows: "total_rows | 1,000"
      distinct_id: "distinct(id) | 1,000"
      note: "Primary key: each user unique"
    }
  }
  table_b: {
    direction: down
    label: "Table B: orders"
    stats_b: {
      shape: sql_table
      label: "Statistics (orders)"
      total_rows: "total_rows | 10,000"
      distinct_uid: "distinct(user_id) | 500"
      note: "Foreign key: avg 20 orders/user"
    }
  }
}
formula_box: {
  label: "Cardinality Formula"
  width: 500
  formula: |md
    
    output_rows = (rows_A × rows_B) / max(distinct_A, distinct_B)
                = (1,000 × 10,000) / max(1,000, 500)
                = 10,000,000 / 1,000
                = 10,000 rows
    
  |
}
intuition_box: {
  label: "Intuition"
  width: 500
  explanation: |md
    - Each order joins to exactly **1 user** (FK constraint)
    - So output = number of orders = **10,000 rows**
    - No row explosion because users.id is unique
  |
}
row_inputs -> formula_box: "input stats"
formula_box -> intuition_box: "result"
result_box: {
  label: "Join Result"
  result_stats: {
    shape: sql_table
    label: "Estimated Join Output"
    output: "output_rows | 10,000"
    ratio: "ratio | 1:1 (no explosion)"
  }
  style.fill: "#E8F5E9"
}
intuition_box -> result_box: "validated"
legend: {
  near: bottom-right
  formula_legend: {
    shape: rectangle
    label: |md
      **Why max()?**
      - Uses the **larger** distinct count as denominator
      - Represents "how many unique matches possible"
      - If A has 1000 unique keys, B's 500 values
        each match ~2 rows from A on average
    |
    style.fill: "#FFF3E0"
    width: 280
  }
}