direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Left-Deep vs Bushy Join Trees" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  left_deep: "Left-Deep Tree" {
    direction: down
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"
    ld_desc: {
      label: "Right child always a base table"
      shape: text
      style.font-size: 12
      style.font-color: "#1B5E20"
    }
    ld_root: {
      label: "⋈ (Join)"
      shape: diamond
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
    }
    ld_j2: {
      label: "⋈"
      shape: diamond
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
    }
    ld_j1: {
      label: "⋈"
      shape: diamond
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    ld_a: {
      label: "A"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
    }
    ld_b: {
      label: "B"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
    }
    ld_c: {
      label: "C"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
    }
    ld_d: {
      label: "D"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#388E3C"
    }
    ld_root -> ld_j2
    ld_root -> ld_d
    ld_j2 -> ld_j1
    ld_j2 -> ld_c
    ld_j1 -> ld_a
    ld_j1 -> ld_b
    formula1: "((A ⋈ B) ⋈ C) ⋈ D" {
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#1B5E20"
      }
    }
  }
  bushy: "Bushy Tree" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    bush_desc: {
      label: "Both children can be joins"
      shape: text
      style.font-size: 12
      style.font-color: "#0D47A1"
    }
    bu_root: {
      label: "⋈ (Join)"
      shape: diamond
      style.fill: "#64B5F6"
      style.stroke: "#1565C0"
    }
    bu_left: {
      label: "⋈"
      shape: diamond
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
    bu_right: {
      label: "⋈"
      shape: diamond
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
    bu_a: {
      label: "A"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
    }
    bu_b: {
      label: "B"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
    }
    bu_c: {
      label: "C"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
    }
    bu_d: {
      label: "D"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
    }
    bu_root -> bu_left
    bu_root -> bu_right
    bu_left -> bu_a
    bu_left -> bu_b
    bu_right -> bu_c
    bu_right -> bu_d
    formula2: "(A ⋈ B) ⋈ (C ⋈ D)" {
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#0D47A1"
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  left_deep_traits: "Left-Deep Characteristics" {
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"
    width: 300
    trait1: {
      label: "✓ Simpler implementation"
      shape: text
    }
    trait2: {
      label: "✓ Pipeline-friendly execution"
      shape: text
    }
    trait3: {
      label: "✓ Inner side can use index scan"
      shape: text
    }
    trait4: {
      label: "✗ May miss optimal plans"
      shape: text
      style.font-color: "#B71C1C"
    }
    search1: "Search space: O(N × 2ᴺ)" {
      shape: text
      style.bold: true
    }
  }
  bushy_traits: "Bushy Characteristics" {
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    width: 300
    trait5: {
      label: "✓ Can find better parallel plans"
      shape: text
    }
    trait6: {
      label: "✓ Exploits natural subgroups"
      shape: text
    }
    trait7: {
      label: "✗ More complex to implement"
      shape: text
      style.font-color: "#E65100"
    }
    trait8: {
      label: "✗ Larger search space"
      shape: text
      style.font-color: "#E65100"
    }
    search2: "Search space: O(3ᴺ)" {
      shape: text
      style.bold: true
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  example_box: "When Bushy Wins: (SmallA ⋈ SmallB) ⋈ (SmallC ⋈ SmallD)" {
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
    width: 620
    ex_desc: {
      label: |md
        **Scenario**: Four small tables, each ~100 rows
        **Left-deep**: ((A ⋈ B) ⋈ C) ⋈ D
        - Intermediate: 100 → 10,000 → 1M rows (worst case)
        **Bushy**: (A ⋈ B) ⋈ (C ⋈ D)
        - Parallel: both sides compute ~10,000 rows
        - Final join: 10,000 × 10,000 instead of 1M × 100
      |
      shape: text
      style.font-size: 12
    }
  }
}
legend: "Database Support" {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  pg: "PostgreSQL: Bushy trees ✓" {
    shape: text
  }
  mysql: "MySQL: Left-deep only (historically)" {
    shape: text
  }
  duck: "DuckDB: Both supported ✓" {
    shape: text
  }
}