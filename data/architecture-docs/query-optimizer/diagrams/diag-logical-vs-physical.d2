direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Logical vs Physical Operator Mapping
  **One logical operator → Multiple physical implementations**
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  logical_layer: {
    direction: down
    label: "Logical Operators\n(What to compute)"
    log_scan: {
      shape: rectangle
      label: "Scan(table)"
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
    }
    log_filter: {
      shape: rectangle
      label: "Filter(predicate)"
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
    }
    log_join: {
      shape: rectangle
      label: "Join(type, condition)"
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
    }
    log_agg: {
      shape: rectangle
      label: "Aggregate(group_by,\naggregations)"
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
    }
  }
  mapping_arrows: {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    arrow1: {
      label: "1:N"
      width: 120
      code: |'txt
        ────────────────►
        one-to-many
      '|
    }
    arrow2: {
      width: 120
      code: |'txt
        ────────────────►
        pushed into
        scan predicate
      '|
    }
    arrow3: {
      label: "1:3"
      width: 120
      code: |'txt
        ────────────────►
        one-to-many
      '|
    }
    arrow4: {
      label: "1:2"
      width: 120
      code: |'txt
        ────────────────►
        one-to-many
      '|
    }
  }
  physical_layer: {
    direction: down
    label: "Physical Operators\n(How to compute)"
    phys_scan_group: {
      direction: right
      label: ""
      style.fill: transparent
      style.stroke: transparent
      phys_seqscan: {
        shape: rectangle
        label: "SeqScan"
        width: 140
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **When chosen:**
          • selectivity > 15%
          • no suitable index
          • small table
        |
      }
      phys_idxscan: {
        shape: rectangle
        label: "IndexScan"
        width: 140
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **When chosen:**
          • selectivity < 15%
          • index on predicate col
          • sorted output needed
        |
      }
    }
    phys_filter_note: {
      shape: rectangle
      width: 300
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      label: |md
        **Filter Merging**
        Filter is absorbed into scan:
        `SeqScan(pred)` or `IndexScan(pred)`
        Cost reduction: evaluate predicate
        during row fetch, not after.
      |
    }
    phys_join_group: {
      direction: right
      label: ""
      style.fill: transparent
      style.stroke: transparent
      phys_hashjoin: {
        shape: rectangle
        width: 130
        label: "HashJoin"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **O(M+N)**
          • equi-joins
          • unsorted inputs
          • memory fits
        |
      }
      phys_nljoin: {
        shape: rectangle
        width: 130
        label: "NestedLoop"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **O(M×N)**
          • small outer table
          • indexed inner
          • non-equi joins
        |
      }
      phys_mergejoin: {
        shape: rectangle
        width: 130
        label: "MergeJoin"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **O(M+N) sorted**
          • pre-sorted inputs
          • need sorted output
          • disk-based
        |
      }
    }
    phys_agg_group: {
      direction: right
      label: ""
      style.fill: transparent
      style.stroke: transparent
      phys_hashagg: {
        shape: rectangle
        width: 140
        label: "HashAggregate"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **When chosen:**
          • unsorted input
          • many groups
          • memory fits
        |
      }
      phys_sortagg: {
        shape: rectangle
        width: 140
        label: "SortAggregate"
        style.fill: "#E8F5E9"
        style.stroke: "#4CAF50"
        note: |md
          **When chosen:**
          • sorted input
          • few groups
          • need sorted output
        |
      }
    }
  }
}
# Logical to physical connections
logical_layer.log_scan -> physical_layer.phys_scan_group: "implements" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
logical_layer.log_filter -> physical_layer.phys_filter_note: "absorbed into" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
logical_layer.log_join -> physical_layer.phys_join_group: "implements" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
logical_layer.log_agg -> physical_layer.phys_agg_group: "implements" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  legend_title: "Selection Criteria"
  style.fill: "#FAFAFA"
  style.stroke: "#CCC"
  cost: |md
    **Cost-Based Selection**
    
    total_cost = io_weight × io_cost 
               + cpu_weight × cpu_cost
    
  |
  factors: |md
    **Decision Factors:**
    • Input cardinality (estimated rows)
    • Selectivity (predicate match rate)
    • Available indexes
    • Sort order of inputs
    • Memory constraints
  |
}