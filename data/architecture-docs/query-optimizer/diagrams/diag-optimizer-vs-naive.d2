direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Optimizer vs Naive: 4-Table Join Comparison
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  naive: Naive Left-to-Right {
    direction: down
    style.fill: "#FFE4E4"
    style.stroke: "#C94C4C"
    style.stroke-width: 2
    label: |md
      **Naive Plan**
      Cost: **4,850,000**
    |
    n_join3: "Join (oi ⋈ p)" {
      label: |md
        Join: order_items ⋈ products
        Input: 5M × 1K rows
        Est. Output: 500K rows
        Cost: 2,100,000
      |
    }
    n_join2: "Join (o ⋈ oi)" {
      label: |md
        Join: orders ⋈ order_items
        Input: 1M × 5M rows
        Est. Output: 5M rows
        Cost: 1,500,000
      |
    }
    n_join1: "Join (c ⋈ o)" {
      label: |md
        Join: customers ⋈ orders
        Input: 10K × 1M rows
        Est. Output: 1M rows
        Cost: 800,000
      |
    }
    n_scan_c: "SeqScan: customers\n10,000 rows\ncost: 100" {
      style.fill: "#FFF"
    }
    n_scan_o: "SeqScan: orders\n1,000,000 rows\ncost: 10,000" {
      style.fill: "#FFF"
    }
    n_scan_oi: "SeqScan: order_items\n5,000,000 rows\ncost: 50,000" {
      style.fill: "#FFF"
    }
    n_scan_p: "SeqScan: products\n1,000 rows\ncost: 10" {
      style.fill: "#FFF"
    }
    n_join1 -> n_join2: "1M rows"
    n_join2 -> n_join3: "5M rows"
    n_join1 -> n_scan_c
    n_join1 -> n_scan_o
    n_join2 -> n_scan_oi
    n_join3 -> n_scan_p
  }
  optimized: Optimizer-Selected {
    direction: down
    style.fill: "#E4FFE4"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    label: |md
      **Optimized Plan**
      Cost: **285,000**
    |
    o_join2: "Join (filtered ⋈ filtered)" {
      label: |md
        HashJoin: filtered_p ⋈ filtered_oi
        Input: 100 × 500K rows
        Est. Output: 50K rows
        Cost: 15,000
      |
    }
    o_join1: "Join (filtered ⋈ c)" {
      label: |md
        HashJoin: filtered_o ⋈ customers
        Input: 50K × 10K rows
        Est. Output: 50K rows
        Cost: 8,000
      |
    }
    o_filter_p: "Filter: p.category = 'electronics'\nSelectivity: 10%\n100 rows" {
      style.fill: "#FFF"
    }
    o_scan_p: "SeqScan: products\n1,000 rows" {
      style.fill: "#FFF"
    }
    o_filter_oi: "Filter: oi matches filtered_p\n500,000 rows" {
      style.fill: "#FFF"
    }
    o_scan_oi: "SeqScan: order_items\n5,000,000 rows" {
      style.fill: "#FFF"
    }
    o_filter_o: "Filter: o.status = 'pending'\nSelectivity: 5%\n50,000 rows" {
      style.fill: "#FFF"
    }
    o_scan_o: "SeqScan: orders\n1,000,000 rows" {
      style.fill: "#FFF"
    }
    o_scan_c: "SeqScan: customers\n10,000 rows\ncost: 100" {
      style.fill: "#FFF"
    }
    o_join1 -> o_join2: "50K rows"
    o_join1 -> o_scan_c
    o_join1 -> o_filter_o
    o_filter_o -> o_scan_o
    o_join2 -> o_filter_oi
    o_join2 -> o_filter_p
    o_filter_oi -> o_scan_oi
    o_filter_p -> o_scan_p
  }
}
naive -> optimized: "94% Cost\nReduction" {
  style.stroke: "#2E7D32"
  style.stroke-width: 4
  style.font-size: 20
  style.bold: true
  style.font-color: "#2E7D32"
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
  l1: "SeqScan" {
    shape: rectangle
    style.fill: "#FFF"
    style.stroke: "#666"
  }
  l2: "Filter" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  l3: "Join" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
}
summary: |md
  **Why Optimizer Wins:**
  1. **Predicate pushdown**: Filters applied before joins reduce intermediate sizes
  2. **Join ordering**: Starts with smallest filtered tables (products: 100 rows)
  3. **Avoids cartesian explosion**: Never joins 5M × 1K unfiltered
  **Key Transformation:**
  - Naive: `(c ⋈ o) ⋈ oi) ⋈ p` — grows to 5M rows before filtering
  - Optimized: `((p_filtered ⋈ oi) ⋈ o_filtered) ⋈ c` — stays under 500K throughout
| {near: bottom-center}