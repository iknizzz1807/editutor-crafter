  formatted_section: {
    direction: down
    label: "Formatted EXPLAIN Output"
    explain_box: {
      label: |'python
┌─────────────────────────────────────────────────┐
│ EXPLAIN Output (PostgreSQL-style)               │
├─────────────────────────────────────────────────┤
│ Aggregate [group_by=customer_id]                │
│   (cost=12500.0, rows=150)                      │
│                                                 │
│   └── Project [columns=name, total]             │
│         (cost=12000.0, rows=500)                │
│                                                 │
│         └── Filter [predicate=amount>1000]      │
│               (cost=11000.0, rows=500)          │
│                                                 │
│               └── HashJoin                      │
│                     [cond=c.id=o.customer_id,   │
│                      build=right]               │
│                     (cost=8500.0, rows=5000)    │
│                                                 │
│                     ├── SeqScan: orders         │
│                     │     (cost=500.0,          │
│                     │      rows=50000)          │
│                                                 │
│                     └── SeqScan: customers      │
│                           (cost=100.0,          │
│                            rows=10000)          │
└─────────────────────────────────────────────────┘
      '|
      shape: rectangle
      style.fill: "#263238"
      style.font-color: "#ECEFF1"
      style.font: mono
      style.font-size: 12
      width: 380
    }
    legend: {
      direction: right
      label: ""
      style.fill: transparent
      style.stroke: transparent
      key_cost: {
        label: "cost=N.N"
        shape: rectangle
        style.fill: "#FFCDD2"
        width: 90
      }
