direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LEVEL ANNOTATIONS ---
title: {
  label: |'md
    # Plan Tree Anatomy
    Nodes represent operators; edges represent data flow
  '|
}
title.near: top-center

# --- ROW 1: STRUCTURE & FLOW ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  node_structure: {
    direction: down
    label: "PlanNode Structure (plan_node.py)"
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"

    fields: {
      shape: sql_table
      label: "PlanNode (base class)"
      f1: "0x00 | str           | operator_type"
      f2: "0x08 | List[PlanNode]| children"
      f3: "0x10 | float         | estimated_cost"
      f4: "0x18 | float         | estimated_rows"
      f5: "0x20 | Dict[str,Any] | details"
      sz: "Base fields: 40 bytes"
    }

    annotation: {
      label: |'md
        **Every node carries:**
        - Operator type (Filter, Join, Scan...)
        - Child nodes (inputs)
        - Cost estimate (work units)
        - Cardinality (output rows)
      '|
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
    }
    fields -> annotation: "annotates"
  }

  data_flow: {
    direction: down
    label: "Data Flow Direction"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"

    flow_example: {
      direction: down
      root: {
        label: "Root\n(produces final result)"
        shape: circle
        style.fill: "#4CAF50"
        style.font-color: white
      }
      mid: {
        label: "Intermediate\n(transforms data)"
        shape: circle
        style.fill: "#2196F3"
        style.font-color: white
      }
      leaf: {
        label: "Leaf\n(reads from storage)"
        shape: circle
        style.fill: "#FF9800"
        style.font-color: white
      }
      
      root -> mid: "next()"
      mid -> leaf: "next()"

      arrow_label: {
        label: |'md
          **Parent pulls from children**
          (Volcano model: `next()` call)
        '|
        style.fill: transparent
        style.stroke: transparent
      }
    }
  }
}

# --- ROW 2: IMPLEMENTATION & ANNOTATIONS ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  example_plan: {
    direction: down
    label: "Example: SELECT * FROM orders WHERE amount > 1000"
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"

    filter_node: {
      shape: class
      label: "LogicalFilter (filter_node.py)"
      +predicate: "str"
      -estimated_cost: "float"
      -estimated_rows: "float"
      +operator_type(): "str"
      +details(): "Dict"
    }

    scan_node: {
      shape: class
      label: "LogicalScan (scan_node.py)"
      +table_name: "str"
      +alias: "Optional[str]"
      -estimated_cost: "float"
      -estimated_rows: "float"
      +operator_type(): "str"
      +details(): "Dict"
    }

    filter_node -> scan_node: "children[0]" {
      style.stroke: "#C2185B"
      style.stroke-width: 3
    }
  }

  node_annotations: {
    direction: down
    label: "Node Metrics"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"

    cost_box: {
      label: |'md
        **estimated_cost = 550.0**
        Total work to execute this subtree
        (includes children + this operator)
      '|
      style.fill: "#E1BEE7"
    }
    card_box: {
      label: |'md
        **estimated_rows = 5000**
        Expected output rows from this node
        (used by parent for its cost calc)
      '|
      style.fill: "#CE93D8"
    }
    schema_box: {
      label: |'md
        **Output Schema:**
        `[id, customer_id, amount, status, ...]`
        Columns available to parent node
      '|
      style.fill: "#BA68C8"
      style.font-color: white
    }
  }
}

# --- CONNECTIONS BETWEEN ROWS ---
row2.example_plan.filter_node -> row2.node_annotations.cost_box: "cost annotation" {
  style.stroke-dash: 4
  style.stroke: "#7B1FA2"
}

# --- ROOT LEVEL LEGEND ---
legend: {
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  
  l1: {
    label: "Filter"
    shape: circle
    style.fill: "#4CAF50"
    style.font-color: white
  }
  l2: {
    label: "Scan"
    shape: circle
    style.fill: "#FF9800"
    style.font-color: white
  }
  l3: {
    label: "Data Flow"
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: white
  }
  note: {
    label: |'md
      Edges point **down** (parent → child)
      Data flows **up** (child → parent)
    '|
  }
}
legend.near: bottom-center

edge_semantics: {
  label: |'md
    ### Edge Semantics
    - **Structural**: `parent.children[i] = child`
    - **Execution**: parent calls `child.next()`
    - **Cardinality**: `parent.estimated_rows` depends on `child.estimated_rows`
  '|
  style.fill: "#E0E0E0"
  style.stroke: "#757575"
}
edge_semantics.near: bottom-right