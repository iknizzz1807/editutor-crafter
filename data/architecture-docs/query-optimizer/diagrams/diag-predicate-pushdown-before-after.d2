direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Predicate Pushdown: Before and After
  Filter `orders.amount > 1000` pushed below join reduces intermediate result from 5M to 50K rows
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: {
    direction: down
    label: "BEFORE: Filter Above Join"
    b_filter: {
      shape: rectangle
      label: "Filter"
      width: 280
      style.fill: "#FFE4B5"
      style.stroke: "#D2691E"
      pred: |'sql
        predicate: orders.amount > 1000
      '|
      cost: "cost: 15,000"
      rows: "rows: 5,000"
    }
    b_join: {
      shape: rectangle
      label: "HashJoin"
      width: 280
      style.fill: "#E6E6FA"
      style.stroke: "#9370DB"
      cond: |'sql
        condition: orders.customer_id = customers.id
      '|
      cost: "cost: 12,000"
      rows: "rows: 5,000,000"
    }
    b_orders: {
      shape: rectangle
      label: "SeqScan: orders"
      width: 130
      style.fill: "#E0FFFF"
      style.stroke: "#20B2AA"
      rows: "rows: 500,000"
      cost: "cost: 500"
    }
    b_customers: {
      shape: rectangle
      label: "SeqScan: customers"
      width: 130
      style.fill: "#E0FFFF"
      style.stroke: "#20B2AA"
      rows: "rows: 10,000"
      cost: "cost: 100"
    }
    b_filter -> b_join: "5M rows"
    b_join -> b_orders: "500K rows"
    b_join -> b_customers: "10K rows"
  }
  arrow_container: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    width: 80
    spacer: "" {style.opacity: 0}
    transform_arrow: {
      shape: diamond
      label: "→"
      width: 60
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.font-size: 32
    }
    reduction_label: {
      label: "300x\ncost\nreduction"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#228B22"
      style.font-size: 14
      style.bold: true
    }
    spacer2: "" {style.opacity: 0}
  }
  after: {
    direction: down
    label: "AFTER: Filter Below Join"
    a_join: {
      shape: rectangle
      label: "HashJoin"
      width: 280
      style.fill: "#E6E6FA"
      style.stroke: "#9370DB"
      cond: |'sql
        condition: orders.customer_id = customers.id
      '|
      cost: "cost: 1,200"
      rows: "rows: 50,000"
    }
    a_filter: {
      shape: rectangle
      label: "Filter (pushed)"
      width: 130
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.bold: true
      pred: |'sql
        amount > 1000
      '|
      cost: "cost: 600"
      rows: "rows: 5,000"
    }
    a_orders: {
      shape: rectangle
      label: "SeqScan: orders"
      width: 130
      style.fill: "#E0FFFF"
      style.stroke: "#20B2AA"
      rows: "rows: 500,000"
      cost: "cost: 500"
    }
    a_customers: {
      shape: rectangle
      label: "SeqScan: customers"
      width: 130
      style.fill: "#E0FFFF"
      style.stroke: "#20B2AA"
      rows: "rows: 10,000"
      cost: "cost: 100"
    }
    a_join -> a_filter: "5K rows"
    a_filter -> a_orders: "500K rows"
    a_join -> a_customers: "10K rows"
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  style.border-radius: 8
  l1: {
    shape: rectangle
    label: "Filter"
    width: 60
    style.fill: "#FFE4B5"
    style.stroke: "#D2691E"
  }
  l2: {
    shape: rectangle
    label: "Join"
    width: 60
    style.fill: "#E6E6FA"
    style.stroke: "#9370DB"
  }
  l3: {
    shape: rectangle
    label: "Scan"
    width: 60
    style.fill: "#E0FFFF"
    style.stroke: "#20B2AA"
  }
  l4: {
    shape: rectangle
    label: "Pushed"
    width: 60
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
}
summary: {
  near: bottom-right
  label: "Cost Summary"
  shape: rectangle
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  width: 200
  before_cost: "Before: 15,000 cost units"
  after_cost: "After:  1,900 cost units"
  reduction: "Reduction: 87%"
  before_cost.style.font-color: "#8B0000"
  after_cost.style.font-color: "#006400"
  reduction.style.bold: true
}