direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Projection Pruning: Removing Unused Columns
| {near: top-center}
row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before: "BEFORE PRUNING" {
    direction: down
    style.fill: "#FFF5F5"
    style.stroke: "#E53E3E"
    style.stroke-width: 2
    label: |md
      **Carrying all 10 columns**
      through entire plan
    |
    agg_before: {
      label: "Aggregate\n(GROUP BY customer_id)"
      width: 200
      style.fill: "#FED7D7"
      input_before: "Input: 10 columns"
      output_before: "Output: 2 columns"
    }
    filter_before: {
      label: "Filter\n(amount > 1000)"
      width: 200
      style.fill: "#FED7D7"
      tuple_before: "Tuple: 10 cols × 500K rows"
    }
    join_before: {
      label: "Hash Join\n(o.customer_id = c.id)"
      width: 200
      style.fill: "#FED7D7"
      tuple2_before: "Tuple: 10 cols × 5M rows"
    }
    scan_o_before: {
      label: "SeqScan: orders\n(10 columns)"
      width: 95
      style.fill: "#FEB2B2"
    }
    scan_c_before: {
      label: "SeqScan: customers\n(10 columns)"
      width: 95
      style.fill: "#FEB2B2"
    }
    agg_before -> filter_before
    filter_before -> join_before
    join_before -> scan_o_before
    join_before -> scan_c_before
  }
}
row_arrow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  arrow_container: {
    style.fill: transparent
    style.stroke: transparent
    width: 100
    transform_arrow: {
      label: "→"
      style.font-size: 48
      style.fill: "#38A169"
      style.stroke: transparent
    }
  }
}
row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  after: "AFTER PRUNING" {
    direction: down
    style.fill: "#F0FFF4"
    style.stroke: "#38A169"
    style.stroke-width: 2
    label: |md
      **Only 3 columns carried**
      through intermediate operators
    |
    agg_after: {
      label: "Aggregate\n(GROUP BY customer_id)"
      width: 200
      style.fill: "#C6F6D5"
      input_after: "Input: 3 columns"
      output_after: "Output: 2 columns"
    }
    filter_after: {
      label: "Filter\n(amount > 1000)"
      width: 200
      style.fill: "#C6F6D5"
      tuple_after: "Tuple: 3 cols × 500K rows"
    }
    join_after: {
      label: "Hash Join\n(o.customer_id = c.id)"
      width: 200
      style.fill: "#C6F6D5"
      tuple2_after: "Tuple: 3 cols × 5M rows"
    }
    proj_o: {
      label: "Project\n(customer_id, amount)"
      width: 95
      style.fill: "#9AE6B4"
    }
    proj_c: {
      label: "Project\n(id, name)"
      width: 95
      style.fill: "#9AE6B4"
    }
    scan_o_after: {
      label: "SeqScan: orders\n(10 columns)"
      width: 95
      style.fill: "#B2F5EA"
      note: "Reads all 10"
    }
    scan_c_after: {
      label: "SeqScan: customers\n(10 columns)"
      width: 95
      style.fill: "#B2F5EA"
      note2: "Reads all 10"
    }
    agg_after -> filter_after
    filter_after -> join_after
    join_after -> proj_o
    join_after -> proj_c
    proj_o -> scan_o_after
    proj_c -> scan_c_after
  }
}
row_before -> row_arrow
row_arrow -> row_after
savings: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_box: {
    style.fill: "#EBF8FF"
    style.stroke: "#3182CE"
    label: "Memory Savings"
    before_mem: "Before: 10 cols × 8 bytes × 5M rows = 400 MB"
    after_mem: "After:  3 cols × 8 bytes × 5M rows = 120 MB"
    savings_val: "**70% reduction**"
  }
  io_box: {
    style.fill: "#FAF5FF"
    style.stroke: "#805AD5"
    label: "I/O Savings"
    before_io: "Before: Wide tuples → more temp file writes"
    after_io: "After:  Narrow tuples → fewer page spills"
    benefit: "**Fewer disk seeks**"
  }
}
row_after -> savings: "Impact" {
  style.stroke-dash: 3
  style.stroke: "#718096"
}
legend: {
  near: bottom-right
  style.fill: "#F7FAFC"
  style.stroke: "#CBD5E0"
  title: "Column Reference Tracking"
  required: {
    style.fill: "#38A169"
    label: "● Required columns"
  }
  pruned: {
    style.fill: "#E53E3E"
    label: "● Pruned columns"
  }
  track: "compute_column_usage() walks tree bottom-up"
  propagate: "Parent requirements → Child requirements"
}
col_tracking: {
  near: bottom-left
  style.fill: "#FFFAF0"
  style.stroke: "#DD6B20"
  label: "Column Usage Analysis"
  step1: "1. Final SELECT needs: customer_id, total_amount"
  step2: "2. Aggregate needs: customer_id, amount"
  step3: "3. Filter needs: amount"
  step4: "4. Join needs: customer_id, id"
  result: "**Union = {customer_id, amount, id}**"
}