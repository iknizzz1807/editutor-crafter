direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: "Column Provenance Analysis for Predicate Pushdown (optimizer.c)" {
  style.fill: "#f0f0f0"
  style.stroke-width: 4
}

logic_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  can_push: {
    direction: down
    label: "CASE A: Single-Table Predicate"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2

    pred1: {
      label: "Filter: users.age > 30"
      prov1: {
        shape: sql_table
        label: "Provenance Metadata"
        f1: "0x00 | column_ref | users.age // tbl_id: 1"
        f2: "0x08 | int32_val  | 30        // literal"
        sz: "Total: 16 bytes"
      }
    }

    status_ok: "✓ Valid for Pushdown" {
      shape: callout
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
      style.font-color: "#2E7D32"
    }

    result1: "Pushes to TableScan(users)" {
      shape: parallelogram
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
    }

    pred1 -> status_ok -> result1
  }

  cannot_push: {
    direction: down
    label: "CASE B: Multi-Table Join Condition"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2

    pred2: {
      label: "Filter: users.id = orders.user_id"
      prov2: {
        shape: sql_table
        label: "Provenance Metadata"
        f1: "0x00 | column_ref | users.id       // tbl_id: 1"
        f2: "0x08 | column_ref | orders.user_id // tbl_id: 2"
        sz: "Total: 16 bytes"
      }
    }

    status_fail: "✗ Multi-Table Conflict" {
      shape: callout
      style.fill: "#FFCDD2"
      style.stroke: "#D32F2F"
      style.font-color: "#C62828"
    }

    result2: "Bound to HashJoin Node" {
      shape: parallelogram
      style.fill: "#E57373"
      style.stroke: "#C62828"
    }

    pred2 -> status_fail -> result2
  }
}

plan_execution: "Plan Evolution (Physical Strategy)" {
  direction: right
  style.fill: "#f8f9fa"
  
  initial_tree: {
    direction: down
    label: "Logical Plan (Input)"
    
    filter_op: {
      label: "Analyze Predicates"
      shape: diamond
      code: |'python
        def can_push(pred):
          tables = get_referenced_tables(pred)
          return len(tables) == 1
      '|
    }

    join_op: {
      shape: class
      label: "InnerJoin (join_node.c)"
      +JoinType: "INNER"
      +L_Source: "users"
      +R_Source: "orders"
    }

    u_scan: "TableScan: users"
    o_scan: "TableScan: orders"

    filter_op -> join_op: "pred_list"
    join_op -> u_scan
    join_op -> o_scan
  }

  transformation: "Optimizer Rewrite" {
    shape: callout
    style.stroke-dash: 5
  }

  optimized_tree: {
    direction: down
    label: "Optimized Physical Plan"

    remaining_join: {
      shape: class
      label: "HashJoin (exec_join.c)"
      +Condition: "users.id = orders.user_id"
      +Strategy: "Probe"
    }

    u_scan_pushed: "TableScan: users" {
      pushed_filter: "FILTER (age > 30)" {
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
        style.stroke-dash: 2
      }
    }
    
    o_scan_phys: "TableScan: orders"

    remaining_join -> u_scan_pushed: "filtered stream"
    remaining_join -> o_scan_phys: "raw stream"
  }

  initial_tree -> transformation -> optimized_tree
}

legend: {
  label: "Decision Legend"
  shape: sql_table
  r1: "Green | Single-Table (Safe to push)"
  r2: "Red   | Multi-Table (Must stay above Join)"
  r3: "Blue  | Scan Operation"
  r1.style.fill: "#C8E6C9"
  r2.style.fill: "#FFCDD2"
  r3.style.fill: "#BBDEFB"
}

legend.near: bottom-right

logic_comparison -> plan_execution: "ruleset applied" {
  style.stroke-width: 2
  style.animated: true
}