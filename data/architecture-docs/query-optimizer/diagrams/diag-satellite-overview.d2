direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Query Optimizer: Satellite Map
  *Cost-Based Optimization Pipeline*
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  sql_ast: {
    label: "SQL AST"
    shape: document
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 140
  }
}
row_m1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1: {
    direction: down
    label: "M1: Plan Representation\n& Statistics"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 220
    plan_tree: {
      label: "Plan Tree Builder"
      shape: rectangle
      width: 180
      code: |'python
        class PlanNode:
          estimated_cost: float
          estimated_rows: float
          children: List[PlanNode]
      '|
    }
    analyze: {
      label: "ANALYZE"
      shape: rectangle
      width: 180
      code: |'python
        # Collect statistics:
        # - Row counts
        # - Distinct values
        # - Histograms
      '|
    }
    logical_ops: {
      label: "Logical Operators"
      shape: class
      +Scan(table): "rows"
      +Filter(pred): "filtered"
      +Join(cond): "joined"
      +Aggregate(grp): "aggregated"
    }
    physical_ops: {
      label: "Physical Operators"
      shape: class
      +SeqScan(table): "rows"
      +IndexScan(idx): "rows"
      +HashJoin(cond): "joined"
      +SortMergeJoin(): "joined"
    }
  }
}
row_catalog: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  catalog: {
    label: "Statistics Catalog\n(Persistent Storage)"
    shape: cylinder
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    width: 200
    tables: {
      shape: sql_table
      label: "TableStatistics"
      row_count: "int | row_count"
      page_count: "int | page_count"
      columns: "dict | column_stats"
    }
    cols: {
      shape: sql_table
      label: "ColumnStatistics"
      distinct: "int | distinct_count"
      null_frac: "float | null_fraction"
      histogram: "Histogram | buckets[]"
    }
  }
}
row_m2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m2: {
    direction: down
    label: "M2: Cost Estimation\n& Selectivity"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    width: 220
    cost_model: {
      label: "Cost Model"
      shape: rectangle
      width: 180
      code: |'python
        cost = (io_weight * io_cost) 
             + (cpu_weight * cpu_cost)
      '|
    }
    selectivity: {
      label: "Selectivity Estimator"
      shape: rectangle
      width: 180
      code: |'python
        # Histogram-based:
        # - Equality: col = val
        # - Range: col > val
        # - Compound: AND/OR
      '|
    }
    join_card: {
      label: "Join Cardinality"
      shape: rectangle
      width: 180
      code: |'python
        rows = (A * B) / max(
          distinct_A, distinct_B
        )
      '|
    }
  }
}
row_m3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m3: {
    direction: down
    label: "M3: Logical\nOptimization"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    width: 220
    rules: {
      label: "Rule Engine\n(Fixed-Point)"
      shape: hexagon
      style.fill: "#BBDEFB"
      width: 180
    }
    predicate_push: {
      label: "Predicate Pushdown"
      shape: rectangle
      width: 180
      code: |'python
        # Push filters below joins
        # when columns from single
        # table only
      '|
    }
    proj_prune: {
      label: "Projection Pruning"
      shape: rectangle
      width: 180
      code: |'python
        # Remove unused columns
        # from intermediate results
      '|
    }
    const_fold: {
      label: "Constant Folding"
      shape: rectangle
      width: 180
      code: |'python
        # WHERE 1=1 → eliminate
        # WHERE 1=0 → prune branch
      '|
    }
  }
}
row_m4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m4: {
    direction: down
    label: "M4: Join Ordering\n& Physical Selection"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    width: 220
    dp_optimizer: {
      label: "DP Optimizer\n(Selinger Algorithm)"
      shape: diamond
      style.fill: "#FFCDD2"
      width: 180
    }
    subset_enum: {
      label: "Subset Enumeration"
      shape: rectangle
      width: 180
      code: |'python
        # For N tables:
        # Generate 2^N - 1 subsets
        # Memoize best plan each
      '|
    }
    join_select: {
      label: "Join Algorithm Select"
      shape: rectangle
      width: 180
      code: |'python
        # HashJoin: O(M+N)
        # MergeJoin: sorted inputs
        # NestedLoop: small outer
      '|
    }
    access_path: {
      label: "Access Path Select"
      shape: rectangle
      width: 180
      code: |'python
        # SeqScan: high selectivity
        # IndexScan: < 15% rows
        # Compare costs
      '|
    }
  }
}
row_output: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  physical_plan: {
    label: "Physical\nExecution Plan"
    shape: document
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 160
    plan_example: {
      label: ""
      shape: rectangle
      width: 140
      code: |'
        HashJoin(cost=4500)
        ├── SeqScan(orders)
        └── IndexScan(customers)
      '|
    }
  }
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  label: "Legend"
  flow: "→ Data Flow" {shape: text}
  catalog_arrow: "⇢ Catalog Access" {shape: text}
  io: {
    label: "I/O Cost"
    shape: rectangle
    style.fill: "#FFCDD2"
  }
  cpu: {
    label: "CPU Cost"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
}
sql_ast -> m1.plan_tree: "Parse Tree" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
m1.plan_tree -> m1.analyze: "build"
m1.analyze -> m1.logical_ops: "instantiate"
m1.logical_ops -> m1.physical_ops: "transform"
m1 -> catalog: "ANALYZE\nwrites" {
  style.stroke: "#FF9800"
  style.stroke-dash: 4
}
catalog -> m2.cost_model: "read stats" {
  style.stroke: "#FF9800"
  style.stroke-dash: 4
}
catalog -> m2.selectivity: "histograms" {
  style.stroke: "#FF9800"
  style.stroke-dash: 4
}
catalog -> m4.subset_enum: "row counts\ndistinct values" {
  style.stroke: "#FF9800"
  style.stroke-dash: 4
}
m1 -> m2: "Logical Plan\n+ Statistics" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
m2.cost_model -> m2.selectivity: "selectivity\n× rows"
m2.selectivity -> m2.join_card: "cardinality"
m2.join_card -> m2.cost_model: "output rows"
m2 -> m3: "Annotated Plan\n(cost estimates)" {
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
m3.rules -> m3.predicate_push: "apply"
m3.rules -> m3.proj_prune: "apply"
m3.rules -> m3.const_fold: "apply"
m3.predicate_push -> m3.rules: "iterate"
m3.proj_prune -> m3.rules: "iterate"
m3.const_fold -> m3.rules: "iterate"
m3 -> m4: "Optimized\nLogical Plan" {
  style.stroke: "#F44336"
  style.stroke-width: 2
}
m4.dp_optimizer -> m4.subset_enum: "enumerate"
m4.subset_enum -> m4.join_select: "for each\npartition"
m4.subset_enum -> m4.access_path: "single tables"
m4.join_select -> m4.dp_optimizer: "min cost"
m4.access_path -> m4.dp_optimizer: "best path"
m4 -> physical_plan: "Final Plan" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.animated: true
}