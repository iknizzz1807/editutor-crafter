direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SeqScan vs IndexScan: Cost Crossover
| {near: top-center}
row_graph: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  graph_container: {
    direction: down
    label: ""
    axes: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      y_axis: {
        label: "Cost"
        style.stroke: "#666"
        width: 20
        height: 300
      }
      plot_area: {
        direction: down
        width: 400
        height: 300
        style.fill: "#fafafa"
        style.stroke: "#ccc"
        seqscan_line: {
          label: "SeqScan Cost"
          style.fill: transparent
          style.stroke: "#2563eb"
          style.stroke-width: 3
        }
        indexscan_line: {
          label: "IndexScan Cost"
          style.fill: transparent
          style.stroke: "#dc2626"
          style.stroke-width: 3
          style.stroke-dash: 0
        }
        crossover_point: {
          shape: circle
          width: 16
          style.fill: "#f59e0b"
          style.stroke: "#92400e"
          style.stroke-width: 2
        }
        threshold_region: {
          label: ""
          style.fill: "#dcfce7"
          style.stroke: transparent
          style.opacity: 0.5
        }
      }
      x_axis: {
        label: "Selectivity (% of rows matching)"
        width: 400
        height: 20
        style.stroke: "#666"
      }
    }
  }
}
row_analysis: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  cost_formulas: {
    direction: down
    label: "Cost Formulas"
    seqscan_formula: |md
      **SeqScan Cost** (constant):
      
      cost = pages + (cpu_weight × rows)
      
      - Reads entire table regardless of selectivity
      - Sequential I/O is fast (cache-friendly)
    |
    indexscan_formula: |md
      **IndexScan Cost** (varies with selectivity):
      
      cost = (sel × pages) + (sel × rows × cpu_w)
             + index_height × lookups
      
      - Random I/O for matching rows
      - Index traversal overhead
    |
    width: 280
  }
  crossover_analysis: {
    direction: down
    label: "Crossover Analysis"
    crossover_explanation: |md
      **Crossover Point** (~15% selectivity):
      - Below: IndexScan cheaper
        - Few rows = few random I/Os
        - Index overhead amortized
      - Above: SeqScan cheaper
        - Random I/O dominates
        - Sequential scan wins
    |
    threshold_box: {
      label: "Default Threshold"
      threshold_value: "index_scan_threshold = 0.15"
      style.fill: "#fef3c7"
      style.stroke: "#f59e0b"
      style.stroke-width: 2
    }
    width: 280
  }
}
row_table: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  decision_table: {
    shape: sql_table
    label: "Scan Decision Matrix (100K rows, 1000 pages)"
    sel_1pct: "1% sel | IndexScan | 50 | 10"
    sel_5pct: "5% sel | IndexScan | 250 | 50"
    sel_10pct: "10% sel | IndexScan | 500 | 100"
    sel_15pct: "15% sel | Crossover | 750 | 150"
    sel_25pct: "25% sel | SeqScan | 1250 | 250"
    sel_50pct: "50% sel | SeqScan | 2500 | 500"
    sel_100pct: "100% sel | SeqScan | 5000 | 1000"
  }
  decision_table.width: 380
}
legend: {
  near: bottom-center
  direction: right
  seq_legend: {
    label: "━━ SeqScan"
    style.fill: transparent
    style.stroke: transparent
    style.font-color: "#2563eb"
  }
  idx_legend: {
    label: "━━ IndexScan"
    style.fill: transparent
    style.stroke: transparent
    style.font-color: "#dc2626"
  }
  cross_legend: {
    label: "● Crossover"
    style.fill: transparent
    style.stroke: transparent
    style.font-color: "#f59e0b"
  }
}
annotations: {
  near: bottom-right
  label: ""
  insight: |md
    **Key Insight**: The "indexes are always faster"  
    misconception is dangerous. An index on `gender`  
    (50% M, 50% F) is useless for `WHERE gender = 'M'`  
    — sequential scan is 5-10x faster.
  |
}