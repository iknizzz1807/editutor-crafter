direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

# --- STYLES & CLASSES ---
classes: {
  engine_component: {
    shape: class
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
    }
  }
  data_structure: {
    shape: sql_table
    style: {
      fill: "#FFFFFF"
      stroke: "#37474F"
    }
  }
  metadata: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }
}

# --- ROW 1: INGESTION & PARSING ---
ingestion: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  sql_input: "SELECT name FROM users\nWHERE age > 25" {
    shape: document
    style.fill: "#FFF9C4"
  }

  parser: {
    class: engine_component
    label: "SQL Parser (parser.py)"
    +parse(sql): "ASTNode"
    -lex(sql): "TokenStream"
    -validate(tokens): "bool"
  }

  ast_struct: {
    class: data_structure
    label: "ASTNode (ast.h)"
    f0: "0x00 | NodeType | type // SELECT, JOIN"
    f1: "0x08 | Expr*    | projections"
    f2: "0x10 | Table*   | from_clause"
    f3: "0x18 | Expr*    | where_clause"
    sz: "Total: 32 bytes"
  }

  sql_input -> parser: "string | parse"
  parser -> ast_struct: "AST | build"
}

# --- ROW 2: LOGICAL PLANNING & RBO ---
logical_phase: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  planner: {
    class: engine_component
    label: "Logical Planner"
    +build_tree(ast): "LogicalPlan"
    -resolve_names(catalog): "void"
  }

  rbo_engine: {
    class: engine_component
    label: "Rule Engine (RBO)"
    +optimize(tree): "LogicalPlan"
    -push_predicates(node): "Node"
    -fold_constants(node): "Node"
    -prune_projections(node): "Node"
  }

  pushdown_logic: {
    label: "Predicate Pushdown"
    code: |'python
      def push(filter, join):
          if cols(filter) subset_of left(join):
              join.left = Filter(join.left, filter)
              return join
    '|
  }

  planner -> rbo_engine: "LogicalTree | rewrite"
  rbo_engine -> pushdown_logic: "Recursive | apply"
}

# --- ROW 3: COST-BASED OPTIMIZATION (CBO) ---
cbo_phase: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  catalog: {
    shape: cylinder
    class: metadata
    label: "Catalog (stats.db)"
    row_count: "int64"
    page_count: "int32"
    histograms: "Map<Col, Histogram>"
  }

  cbo_engine: {
    class: engine_component
    label: "CBO Optimizer"
    +find_best_plan(logical): "PhysicalPlan"
    -selinger_search(tables): "MemoTable"
    -estimate_cost(phys_op): "float"
  }

  cost_formula: {
    label: "Cost Equation"
    code: |'python
      # Total Cost = I/O + CPU
      cost = (pages * W_io) + (rows * W_cpu)
      # S = selectivity (0.0 - 1.0)
    '|
  }

  catalog -> cbo_engine: "Stats | lookup"
  cbo_engine -> cost_formula: "Math | evaluate"
}

# --- ROW 4: FINAL PHYSICAL PLAN ---
output_phase: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  physical_plan: {
    class: data_structure
    label: "Physical Plan (Execution Tree)"
    op1: "-> HashJoin (cost=45.2, rows=120)"
    op2: "  -> Filter (age > 25)"
    op3: "    -> SeqScan (users)"
    op4: "  -> IndexScan (orders_idx)"
  }

  execution_engine: {
    shape: person
    label: "Executor"
  }

  physical_plan -> execution_engine: "Plan | execute"
}

# --- GLOBAL CONNECTORS ---
ingestion -> logical_phase: "AST | build_logical"
logical_phase -> cbo_phase: "LogicalPlan | optimize_cost"
cbo_phase -> output_phase: "PhysicalPlan | select"

# --- LEGEND ---
legend: {
  near: bottom-right
  logical: Logical Phase {
    style.fill: "#E1F5FE"
  }
  physical: Physical Phase {
    style.fill: "#F3E5F5"
  }
  data: Data Flow {
    style.stroke: "#01579B"
  }
}