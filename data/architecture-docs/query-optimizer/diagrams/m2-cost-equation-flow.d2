direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- LEGEND & METADATA ---
legend: {
  shape: sql_table
  label: "Cost Model Calibration (optimizer.h)"
  style.stroke: "#333333"
  
  row1: "W_seq  | 1.0  | Sequential Page Read Cost"
  row2: "W_rand | 4.0  | Random Page Read Cost (Seek + Latency)"
  row3: "W_cpu  | 0.01 | CPU Tuple Processing Cost (Filter/Hash)"
  row4: "W_idx  | 0.05 | Index Page CPU Processing Cost"
  
  footer: "Units: Normalized to 1.0 Sequential I/O"
}
legend.near: top-right

# --- INPUT LAYER ---
inputs: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  table_stats: {
    shape: sql_table
    label: "struct TableStats (catalog.h)"
    f0: "0x00 | uint64_t | rel_pages     // Total pages on disk"
    f1: "0x08 | uint64_t | rel_tuples    // Total rows in table"
    f2: "0x10 | double   | rel_width     // Avg bytes per tuple"
    f3: "0x18 | double   | rel_all_vis   // Visibility map fraction"
    sz: "Total: 32 bytes"
    style.fill: "#E1F5FE"
  }

  query_params: {
    shape: sql_table
    label: "struct PredicateMeta"
    f0: "0x00 | double | selectivity   // S: 0.0 to 1.0"
    f1: "0x08 | int    | index_height  // Tree levels for IndexScan"
    f2: "0x0C | bool   | is_clustered  // Impacts random vs seq I/O"
    style.fill: "#FFF9C4"
  }
}

# --- THE COST ENGINE ---
engine: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  logic: {
    shape: class
    label: "CostEstimator (cost.c)"
    +EstimateSeqScan(stats): "double"
    +EstimateIndexScan(stats, idx, S): "double"
    +EstimateHashJoin(l_cost, r_cost): "double"
    -calc_io_cost(pages, weight): "double"
    -calc_cpu_cost(rows, weight): "double"
  }

  formulas: {
    label: "Mathematical Foundation"
    seq_scan_code: {
      label: "SeqScan Cost Formula"
      code: |'c
        // C = (Pages * W_seq) + (Tuples * W_cpu)
        cost = stats->rel_pages * W_seq;
        cost += stats->rel_tuples * W_cpu;
        return cost;
      '|
    }
    index_scan_code: {
      label: "IndexScan Cost Formula"
      code: |'c
        // C = (H * W_rand) + (S * Pages * W_rand) + (S * Tuples * W_cpu)
        cost = meta->index_height * W_rand;
        cost += (S * stats->rel_pages) * W_rand;
        cost += (S * stats->rel_tuples) * W_cpu;
      '|
    }
  }
}

# --- COMPARISON LAYER ---
comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scenario_a: {
    label: "Plan A: Sequential Scan"
    width: 300
    calc: |md
      **Inputs:**
      - Pages: 1,000
      - Tuples: 100,000
      - S: 0.01 (1%)
      
      **Math:**
      - I/O: 1000 * 1.0 = 1000.0
      - CPU: 100,000 * 0.01 = 1000.0
      
      **Total Cost: 2000.0**
    |
    style.stroke: "#EF5350"
    style.stroke-width: 2
  }

  scenario_b: {
    label: "Plan B: Index Scan"
    width: 300
    calc: |md
      **Inputs:**
      - S: 0.01 (1,000 rows)
      - Index Height: 3
      
      **Math:**
      - Seek: 3 * 4.0 = 12.0
      - Data I/O: (0.01 * 1000) * 4.0 = 40.0
      - CPU: (0.01 * 100,000) * 0.01 = 10.0
      
      **Total Cost: 62.0**
    |
    style.stroke: "#66BB6A"
    style.stroke-width: 4
  }
}

# --- CONNECTIONS (DATA FLOW) ---
inputs.table_stats -> engine.logic: "TableMetadata | read"
inputs.query_params -> engine.logic: "Selectivity | read"

engine.logic -> comparison.scenario_a: "double | push cost"
engine.logic -> comparison.scenario_b: "double | push cost"

decision_node: {
  shape: diamond
  label: "Min(Cost)?"
}

comparison.scenario_a -> decision_node: "2000.0" {style.stroke-dash: 3}
comparison.scenario_b -> decision_node: "62.0"

decision_node -> winner: "Select Plan B" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}

winner: {
  shape: step
  label: "Physical Plan Generation"
  style.fill: "#C8E6C9"
}

# Annotations for Engineering Precision
annotation: {
  label: "Cost Unit Conversion"
  explanation: |md
    ### Unit Definitions
    - **1.0 Cost Unit** = Time to read 1 sequential 8KB page from disk.
    - Cost is hardware-independent at the optimizer level.
    - Calibration occurs during DB startup via micro-benchmarking of I/O.
  |
  style.fill: "#ECEFF1"
}
annotation.near: bottom-left