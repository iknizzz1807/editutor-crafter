direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
title: Selectivity Estimation: Area Under the Curve (stats_calc.py) {
  shape: package
  style: {
    stroke-width: 4
    fill: "#f8f9fa"
  }
}

# --- ROW 1: INPUTS AND METADATA ---
inputs: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  predicate: {
    shape: callout
    label: "QUERY PREDICATE\nWHERE price > 50"
    style: {
      fill: "#e3f2fd"
      stroke: "#1565c0"
      bold: true
    }
  }

  stats_obj: {
    shape: sql_table
    label: "struct ColumnStats (catalog.h)"
    f1: "0x00 | uint64_t | total_rows // 1,000,000"
    f2: "0x08 | float    | null_frac  // 0.05"
    f3: "0x10 | double*  | boundaries // Histogram array"
    f4: "0x18 | uint32_t | num_buckets // 100"
    size: "Total: 32 bytes"
  }
}

# --- ROW 2: HISTOGRAM SCAN ---
histogram_visualization: "Equi-Depth Histogram Analysis" {
  direction: right
  style: {
    fill: "#f1f3f4"
    stroke-dash: 5
  }

  b1: "Bucket 1\n[0, 20]" {
    style.fill: "#eeeeee"
    tooltip: "Out of range (ignored)"
  }
  b2: "Bucket 2\n[20, 40]" {
    style.fill: "#eeeeee"
  }
  
  target_bucket: "Target Bucket 3\n[40, 60]" {
    style: {
      fill: "#fff9c4"
      stroke: "#fbc02d"
      stroke-width: 3
    }
    label: "Active Bucket [40, 60]\nValue 50 is inside"
  }

  b4: "Bucket 4\n[60, 80]" {
    style.fill: "#c8e6c9"
    tooltip: "Full inclusion (Price > 60)"
  }
  b5: "Bucket 5\n[80, 100]" {
    style.fill: "#c8e6c9"
  }
}

# --- ROW 3: INTERPOLATION LOGIC ---
calculation_logic: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  interpolation_step: {
    label: "Linear Interpolation (Step 1)"
    width: 400
    code: |'python
      # Logic: Assume uniform distribution within bucket
      low, high = 40.0, 60.0
      val = 50.0
      
      # Portion of bucket matching 'greater than 50'
      match_ratio = (high - val) / (high - low) 
      # Result: (60 - 50) / (60 - 40) = 0.5 (50% of bucket)
    '|
  }

  aggregation_step: {
    label: "Global Selectivity (Step 2)"
    width: 400
    code: |'python
      # Every bucket represents 1/N of total data
      bucket_weight = 1.0 / num_buckets # 0.01 for 100 buckets
      
      partial_sel = match_ratio * bucket_weight # 0.5 * 0.01 = 0.005
      remaining_sel = (num_buckets - target_idx - 1) * bucket_weight
      # Total: 0.005 + (97 * 0.01) = 0.975
    '|
  }
}

# --- ROW 4: FINAL ESTIMATION ---
final_output: {
  shape: step
  label: "Final Selectivity Estimate: 0.975 (97.5%)"
  style: {
    fill: "#e8f5e9"
    stroke: "#2e7d32"
    bold: true
    font-size: 20
  }
}

# --- CONNECTIONS ---
inputs.predicate -> histogram_visualization.target_bucket: "Search | Find index"
inputs.stats_obj -> calculation_logic.interpolation_step: "Metadata | boundaries"

histogram_visualization.target_bucket -> calculation_logic.interpolation_step: "Target: [40, 60]"
calculation_logic.interpolation_step -> calculation_logic.aggregation_step: "match_ratio: 0.5"

histogram_visualization.b4 -> calculation_logic.aggregation_step: "Count full buckets"
histogram_visualization.b5 -> calculation_logic.aggregation_step

calculation_logic.aggregation_step -> final_output: "float64 | result"

# --- ANNOTATIONS ---
legend: {
  near: bottom-right
  item1: "Grey: Discarded (Price < 50)" { style.font-color: gray }
  item2: "Yellow: Interpolated Bucket" { style.font-color: "#fbc02d" }
  item3: "Green: Included Buckets" { style.font-color: green }
}