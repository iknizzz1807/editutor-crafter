direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STYLING CLASSES ---
classes: {
  operator: {
    shape: class
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      stroke-width: 2
    }
  }
  selective_op: {
    shape: class
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
  table_node: {
    shape: sql_table
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }
  data_stream_heavy: {
    style: {
      stroke: "#C62828"
      stroke-width: 4
      animated: true
    }
  }
  data_stream_lean: {
    style: {
      stroke: "#2E7D32"
      stroke-width: 2
      stroke-dash: 0
    }
  }
}

# --- DIAGRAM CONTENT ---

explanation: {
  near: top-center
  label: "RULE: Predicate Pushdown (The Descent)"
  note: |md
    Transformation: `Filter(Join(A, B))` → `Join(Filter(A), B)`
    Goal: Minimize intermediate tuple counts early in the pipeline.
  |
}

# --- BEFORE STATE ---
before_container: {
  label: "PHASE 1: UNOPTIMIZED LOGICAL PLAN"
  style: {
    stroke-dash: 5
    fill: "#FAFAFA"
  }
  
  direction: down

  filter_top: {
    class: operator
    label: "LogicalFilter"
    predicate: "country = 'ISL'"
    selectivity: "0.001 (High)"
  }

  join_node: {
    class: operator
    label: "LogicalJoin (INNER)"
    condition: "users.id = orders.uid"
    output: "1,000,000 rows (Heavy)"
  }

  sources: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    scan_users: {
      shape: sql_table
      label: "LogicalScan: users"
      f0: "0x00 | int | id"
      f1: "0x04 | str | country"
      rows: "Total: 10,000"
    }

    scan_orders: {
      shape: sql_table
      label: "LogicalScan: orders"
      f0: "0x00 | int | id"
      f1: "0x04 | int | uid"
      rows: "Total: 1,000,000"
    }
  }

  # Connections for Before
  filter_top -> join_node: "1M Rows | Filtered late"
  join_node -> sources.scan_users: "10k Rows"
  join_node -> sources.scan_orders: "1M Rows"
  
  (filter_top -> join_node)[0].class: data_stream_heavy
}

# --- TRANSITION INDICATOR ---
transformation_arrow: {
  shape: parallelogram
  label: "RuleEngine.apply(PredicatePushdown)"
  style: {
    fill: "#FFECB3"
    stroke: "#FFA000"
    bold: true
  }
}

# --- AFTER STATE ---
after_container: {
  label: "PHASE 2: OPTIMIZED LOGICAL PLAN (PUSHED)"
  style: {
    fill: "#F1F8E9"
    stroke: "#2E7D32"
  }

  direction: down

  join_top: {
    class: operator
    label: "LogicalJoin (INNER)"
    condition: "users.id = orders.uid"
    benefit: "Joining much smaller sets"
  }

  branches: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    left_branch: {
      direction: down
      style.stroke: transparent
      
      pushed_filter: {
        class: selective_op
        label: "LogicalFilter"
        predicate: "country = 'ISL'"
        reduction: "10,000 -> 10 rows"
      }

      scan_users_low: {
        shape: sql_table
        label: "LogicalScan: users"
        f0: "0x00 | int | id"
        f1: "0x04 | str | country"
      }
      
      pushed_filter -> scan_users_low: "10k Raw Rows"
    }

    scan_orders_right: {
      shape: sql_table
      label: "LogicalScan: orders"
      f0: "0x00 | int | id"
      f1: "0x04 | int | uid"
      rows: "1M Rows"
    }
  }

  # Connections for After
  join_top -> branches.left_branch.pushed_filter: "10 Rows | Pre-filtered"
  join_top -> branches.scan_orders_right: "1M Rows"
  
  # Join output is now small
  final_out: "Result Set"
  final_out <- join_top: "100 Rows (Lean)"
  
  (final_out <- join_top)[0].class: data_stream_lean
  (join_top -> branches.left_branch.pushed_filter)[0].class: data_stream_lean
}

# --- GLOBAL FLOW ---
before_container -> transformation_arrow
transformation_arrow -> after_container: "Fixed-Point Iteration"

legend: {
  shape: package
  label: "Complexity Analysis"
  near: bottom-right
  
  item1: "Red Line: Massive Intermediate Materialization" {
    style.font-color: "#C62828"
  }
  item2: "Green Line: Early Cardinality Reduction" {
    style.font-color: "#2E7D32"
  }
  item3: "Rule: Commutative Property of Selection over Join"
}