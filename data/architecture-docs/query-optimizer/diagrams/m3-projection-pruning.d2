direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STYLES AND LEGEND ---
classes: {
  logic_node: {
    style: {
      fill: "#f8f9fa"
      stroke: "#212529"
      stroke-width: 2
    }
  }
  metadata: {
    style: {
      fill: "#e8f0fe"
      stroke: "#1967d2"
      font-color: "#1967d2"
    }
  }
  removed: {
    style: {
      fill: "#f8d7da"
      stroke: "#721c24"
      stroke-dash: 3
      opacity: 0.5
    }
  }
}

title: "Projection Pruning: The 'Knowledge Cascade' (Milestone 3)" {
  shape: package
}

# --- ROW 1: THE INPUT QUERY ---
input_context: {
  direction: right
  style.stroke: transparent
  
  query_box: {
    label: "SQL User Intent"
    sql: |'sql
      SELECT a 
      FROM users 
      WHERE b > 10;
    '|
  }
  
  initial_tree: {
    label: "Unoptimized Logical Plan"
    project: "LogicalProject(a)"
    filter: "LogicalFilter(b > 10)"
    scan: "LogicalScan(users)"
    
    project -> filter: "Full Tuples {a,b,c,d}"
    filter -> scan: "Full Tuples {a,b,c,d}"
  }
}

# --- ROW 2: THE PRUNING RULE LOGIC ---
optimization_logic: {
  direction: right
  style.stroke: transparent
  
  rule_class: {
    shape: class
    label: "ProjectionPruningRule (optimizer/rules.py)"
    -required_cols: "Set[ColumnID]"
    +apply(node, req): "PlanNode"
    +collect_provenance(expr): "Set[ColumnID]"
    note: "Performs Top-Down traversal to propagate requirements"
  }

  traversal_steps: {
    direction: down
    step1: {
      shape: step
      label: "1. Root: SELECT a"
      desc: "req_set = {a}"
    }
    step2: {
      shape: step
      label: "2. Filter: b > 10"
      desc: "req_set = {a} + {b}"
    }
    step3: {
      shape: step
      label: "3. Scan: users"
      desc: "Final Pruning: {a, b} kept, {c, d} dropped"
    }
    step1 -> step2 -> step3
  }
}

# --- ROW 3: PHYSICAL MEMORY IMPACT (BEFORE vs AFTER) ---
memory_impact: {
  direction: right
  style.stroke: transparent

  before: {
    label: "Unpruned Tuple (32 Bytes)"
    shape: sql_table
    f0: "0x00 | int64 | a // Key"
    f1: "0x08 | int64 | b // Predicate"
    f2: "0x10 | int64 | c // UNUSED"
    f3: "0x18 | int64 | d // UNUSED"
    sz: "Total: 32 bytes/tuple"
  }

  after: {
    label: "Pruned Tuple (16 Bytes)"
    shape: sql_table
    f0: "0x00 | int64 | a // Key"
    f1: "0x08 | int64 | b // Predicate"
    sz: "Total: 16 bytes/tuple"
    note: "Saves 50% Memory/IO"
  }
  
  before -> after: "ProjectionPruningRule | execute" {
    style.stroke-width: 4
  }
}

# --- ROW 4: DATA SQUEEZE VISUALIZATION ---
data_flow_visual: {
  direction: down
  label: "Execution Pipeline Squeeze"
  
  node_project: "Projector (a)" {
    class: logic_node
  }
  
  node_filter: "Evaluator (b > 10)" {
    class: logic_node
  }
  
  node_scan: "Scan (users)" {
    class: logic_node
  }

  # Connection labels show the "width" narrowing
  node_scan -> node_filter: "Tuple{a,b} | 16B" {
    style.stroke-width: 4
  }
  node_filter -> node_project: "Filtered{a,b} | 16B" {
    style.stroke-width: 2
  }
  node_project -> out: "Result{a} | 8B" {
    style.stroke-width: 1
  }
  
  out: "Client Buffer" {
    shape: queue
  }
}

# Connect the stages
input_context -> optimization_logic: "Rule Trigger"
optimization_logic -> memory_impact: "Plan Annotation"
memory_impact -> data_flow_visual: "Execution"

# Floating annotation (inside a container to prevent overlap)
annotation: {
  near: top-right
  note: |md
    **Efficiency Gain**:
    Reducing tuple width increases 
    the number of rows per 8KB page, 
    effectively multiplying 
    Sequential Scan throughput.
  |
}