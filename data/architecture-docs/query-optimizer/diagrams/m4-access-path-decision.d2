direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "Decision Logic: Access Path Selection (optimizer/path.c)"
  style: {
    fill: "#2C3E50"
    font-color: white
    font-size: 18
    bold: true
  }
}

# --- Infrastructure & Parameters ---
row_params: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  cost_weights: {
    shape: sql_table
    label: "Cost Weights (Catalog.h)"
    w_seq_io: "1.0 | float | W_SEQ_IO"
    w_rnd_io: "4.0 | float | W_RND_IO // Random is 4x sequential"
    w_cpu: "0.01 | float | W_CPU"
    total: "Units: Generic Cost Units"
  }

  table_meta: {
    shape: sql_table
    label: "Table Stats (pg_class)"
    n_pages: "0x00 | int | relpages // 8KB pages"
    n_tuples: "0x04 | float | reltuples // Total rows"
    n_index: "0x08 | bool | has_index"
    sz: "Source: ANALYZE Snapshot"
  }
}

# --- Core Decision Logic ---
optimization_flow: {
  direction: down
  label: "Path Selection Logic"

  step_selectivity: {
    label: "Calculate Selectivity (S)"
    shape: step
    code: |'python
      # Histogram Lookup
      S = selectivity_estimator.estimate(predicate)
      # result: 0.0 <= S <= 1.0
    '|
  }

  check_index: "Index Available on Column?" {
    shape: diamond
  }

  calc_costs: {
    shape: rectangle
    label: "Evaluate Cost Equations"
    
    seq_eqn: {
      label: "C_seq = (Pages * W_SEQ_IO) + (Rows * W_CPU)"
      style.font: mono
    }
    
    idx_eqn: {
      label: "C_idx = (Height * W_SEQ_IO) + (S * Pages * W_RND_IO) + (S * Rows * W_CPU)"
      style.font: mono
    }
  }

  compare: "C_idx < C_seq?" {
    shape: diamond
  }

  # Terminal Nodes
  result_seq: {
    shape: parallelogram
    label: "PHYSICAL_SEQ_SCAN"
    style.fill: "#D1E8FF"
  }

  result_idx: {
    shape: parallelogram
    label: "PHYSICAL_INDEX_SCAN"
    style.fill: "#D1FFD1"
  }

  # Connections
  step_selectivity -> check_index: "S_value"
  
  check_index -> result_seq: "No Index | Fallback" {
    style.stroke-dash: 3
  }
  
  check_index -> calc_costs: "Index Exists"
  
  calc_costs -> compare: "float_costs"
  
  compare -> result_idx: "True | Pick Index" {
    style.stroke: green
    style.stroke-width: 3
  }
  
  compare -> result_seq: "False | Heavy Scan" {
    style.stroke: red
    style.stroke-dash: 5
  }
}

# --- Implementation Components ---
row_impl: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  cost_calculator: {
    shape: class
    label: "CostCalculator (cost.py)"
    +w_io: "float"
    +w_cpu: "float"
    +estimate_seq(pages, rows): "float"
    +estimate_index(pages, rows, s, h): "float"
  }

  selectivity_engine: {
    shape: class
    label: "SelectivityEstimator (stats.py)"
    -catalog: "CatalogReference"
    +get_equality_s(col, val): "float"
    +get_range_s(col, op, val): "float"
    +apply_independence(s1, s2): "float"
  }
}

# --- Explanatory Callouts ---
notes: {
  c1: {
    shape: callout
    label: "The Tipping Point: Usually S < 0.15 favors index. Random I/O penalty is key."
  }
}
notes.near: bottom-right

row_params -> optimization_flow: "Metadata | input"
optimization_flow -> row_impl: "Call methods"