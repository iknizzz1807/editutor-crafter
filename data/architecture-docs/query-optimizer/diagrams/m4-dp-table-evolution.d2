direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Selinger Dynamic Programming Optimizer - Memoization Table Evolution
# Implementation Blueprint for Query Optimizer (optimizer.py)

dp_engine: {
  shape: class
  label: "DPOptimizer (optimizer.py)"
  -memo: "Map<Set<Table>, PhysicalPlan>"
  -catalog: "CatalogStats*"
  +find_optimal_plan(tables): "PhysicalPlan"
  +estimate_cost(plan): "float"
  +prune_suboptimal(set): "void"
}

# Row 1: Size 1 Base Relations
# -----------------------------------------------------------------------------
r1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  level_1: "SIZE 1: Base Relations (Scans)" {
    direction: right
    style.stroke: "#333"
    style.fill: "#f8f9fa"

    memo_a: {
      shape: sql_table
      label: "{A} - Users"
      access_1: "SeqScan | Cost: 100.0 | Card: 1000"
      access_2: "IndexScan(id) | Cost: 5.2 | Card: 1000"
      winner: "WINNER: IndexScan | Cost: 5.2"
      style.fill: "#e3f2fd"
    }

    memo_b: {
      shape: sql_table
      label: "{B} - Orders"
      access_1: "SeqScan | Cost: 500.0 | Card: 5000"
      winner: "WINNER: SeqScan | Cost: 500.0"
      style.fill: "#e3f2fd"
    }

    memo_c: {
      shape: sql_table
      label: "{C} - Items"
      access_1: "SeqScan | Cost: 200.0 | Card: 2000"
      access_2: "IndexScan(pk) | Cost: 2.1 | Card: 2000"
      winner: "WINNER: IndexScan | Cost: 2.1"
      style.fill: "#e3f2fd"
    }
  }
}

# Row 2: Size 2 Join Combinations
# -----------------------------------------------------------------------------
r2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  level_2: "SIZE 2: Join Pairs" {
    direction: right
    style.stroke: "#333"
    style.fill: "#f8f9fa"

    memo_ab: {
      shape: sql_table
      label: "{A, B}"
      strat_1: "NLJ({A},{B}) | Cost: 5005.2"
      strat_2: "HashJoin({A},{B}) | Cost: 605.2"
      winner: "WINNER: HashJoin | Cost: 605.2"
      style.fill: "#fff3e0"
    }

    memo_bc: {
      shape: sql_table
      label: "{B, C}"
      strat_1: "HashJoin({B},{C}) | Cost: 702.1"
      strat_2: "MergeJoin({B},{C}) | Cost: 1200.0"
      winner: "WINNER: HashJoin | Cost: 702.1"
      style.fill: "#fff3e0"
    }

    memo_ac: {
      shape: sql_table
      label: "{A, C}"
      strat_1: "NLJ({A},{C}) | Cost: 10.4"
      winner: "WINNER: NLJ | Cost: 10.4"
      style.fill: "#fff3e0"
    }
  }
}

# Row 3: Size 3 Final Join Order
# -----------------------------------------------------------------------------
r3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  level_3: "SIZE 3: Final Optimal Goal" {
    direction: right
    style.stroke: "#333"
    style.fill: "#f8f9fa"

    memo_abc: {
      shape: sql_table
      label: "{A, B, C}"
      split_1: "Split ({A,B} + {C}) | Cost: 607.3"
      split_2: "Split ({B,C} + {A}) | Cost: 707.3"
      split_3: "Split ({A,C} + {B}) | Cost: 510.4"
      winner: "OPTIMAL: ({A,C}) Join {B} | Cost: 1100.5"
      style.fill: "#e8f5e9"
    }
  }
}

# Dependency Connections
# -----------------------------------------------------------------------------
r1.level_1.memo_a -> r2.level_2.memo_ab: "Table A"
r1.level_1.memo_b -> r2.level_2.memo_ab: "Table B"

r1.level_1.memo_b -> r2.level_2.memo_bc: "Table B"
r1.level_1.memo_c -> r2.level_2.memo_bc: "Table C"

r1.level_1.memo_a -> r2.level_2.memo_ac: "Table A"
r1.level_1.memo_c -> r2.level_2.memo_ac: "Table C"

r2.level_2.memo_ab -> r3.level_3.memo_abc: "({A,B}) + {C}"
r2.level_2.memo_bc -> r3.level_3.memo_abc: "({B,C}) + {A}"

# Highlight Optimal Path
r2.level_2.memo_ac -> r3.level_3.memo_abc: "({A,C}) + {B}" {
  style: {
    stroke: green
    stroke-width: 4
    animated: true
  }
}

# Metadata & Legends
# -----------------------------------------------------------------------------
legend: {
  shape: sql_table
  label: "Optimizer Metadata Symbols"
  l1: "Blue Header: Size 1 (Relation Scans)"
  l2: "Orange Header: Size 2 (Binary Joins)"
  l3: "Green Header: Size 3 (Final Order)"
  l4: "Cost Unit: Combined IO + CPU Cycles"
}
legend.near: bottom-right

memo_logic: {
  label: "Memoization Rule (optimizer.py)"
  width: 400
  code: |'python
    # DP Search for k in 2..N:
    # For each subset S of size k:
    #   best_plan = infinity
    #   For each partition {S1, S2} of S:
    #     plan = join(memo[S1], memo[S2])
    #     best_plan = min(best_plan, plan)
    #   memo[S] = best_plan
  '|
}
memo_logic.near: top-right