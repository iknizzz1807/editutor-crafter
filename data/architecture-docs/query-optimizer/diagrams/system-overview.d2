direction: down
# Row 1: Plan Tree Module (Milestone 1)
row_plan: {
    direction: right
    style.fill: transparent
    plan_node: {
        shape: class
        label: PlanNode
        file: "query_optimizer/plan/01_base.py"
        milestone: 1
        node_id: "str"
        node_type: "NodeType"
        children: "List[PlanNode]"
        estimated_rows: "float"
        estimated_cost: "float"
        is_logical: "bool"
        get_output_columns: "() -> List[str]"
        get_input_columns: "() -> List[str]"
        accept: "(visitor) -> Any"
    }
    logical_ops: {
        shape: class
        label: Logical Operators
        file: "query_optimizer/plan/02_logical.py"
        milestone: 1
        LogicalScan: "table_name, columns, alias"
        LogicalFilter: "predicate, input_node"
        LogicalProject: "expressions, input_node"
        LogicalJoin: "join_type, condition, left, right"
        LogicalAggregate: "group_keys, aggregates, input"
    }
    physical_ops: {
        shape: class
        label: Physical Operators
        file: "query_optimizer/plan/03_physical.py"
        milestone: 1
        PhysicalSeqScan: "table_name, filter"
        PhysicalIndexScan: "index_name, bounds"
        PhysicalNestedLoopJoin: "outer, inner, condition"
        PhysicalHashJoin: "build_side, probe_side, hash_key"
        PhysicalSortMergeJoin: "left, right, sort_keys"
        PhysicalSort: "sort_keys, input_node"
    }
    pretty_print: {
        shape: class
        label: Plan Pretty Printer
        file: "query_optimizer/plan/04_pretty_print.py"
        milestone: 1
        format_plan_tree: "(node: PlanNode) -> str"
        format_node: "(node, indent) -> str"
        format_cost: "(cost: float) -> str"
        EXPLAIN_FORMAT: "dict"
    }
}
# Row 2: Statistics Module (Milestone 1)
row_stats: {
    direction: right
    style.fill: transparent
    histogram: {
        shape: sql_table
        label: HistogramBucket
        file: "query_optimizer/stats/05_histogram.py"
        milestone: 1
        lower_bound: "Any"
        upper_bound: "Any"
        frequency: "int"
        distinct_values: "int"
    }
    column_histogram: {
        shape: class
        label: ColumnHistogram
        file: "query_optimizer/stats/05_histogram.py"
        milestone: 1
        column_name: "str"
        buckets: "List[HistogramBucket]"
        min_value: "Any"
        max_value: "Any"
        estimate_selectivity: "(predicate) -> float"
        get_bucket_for_value: "(value) -> HistogramBucket"
    }
    column_stats: {
        shape: sql_table
        label: ColumnStatistics
        file: "query_optimizer/stats/06_statistics.py"
        milestone: 1
        column_name: "str"
        null_fraction: "float"
        distinct_count: "int"
        most_common_vals: "List[Any]"
        most_common_freqs: "List[float]"
        histogram: "ColumnHistogram | None"
    }
    table_stats: {
        shape: sql_table
        label: TableStatistics
        file: "query_optimizer/stats/06_statistics.py"
        milestone: 1
        table_name: "str"
        row_count: "int"
        page_count: "int"
        column_stats: "Dict[str, ColumnStatistics]"
        index_info: "List[IndexInfo]"
    }
    stats_catalog: {
        shape: class
        label: StatisticsCatalog
        file: "query_optimizer/stats/07_catalog.py"
        milestone: 1
        tables: "Dict[str, TableStatistics]"
        get_table_stats: "(table: str) -> TableStatistics"
        get_column_stats: "(table, col) -> ColumnStatistics"
        refresh_stats: "(table: str) -> None"
    }
    analyzer: {
        shape: class
        label: Analyzer
        file: "query_optimizer/stats/08_analyzer.py"
        milestone: 1
        config: "AnalyzerConfig"
        catalog: "StatisticsCatalog"
        analyze_table: "(table: str) -> TableStatistics"
        collect_histogram: "(table, col, nbuckets) -> ColumnHistogram"
        estimate_distinct: "(table, col) -> int"
    }
}
# Row 3: Cost Model Module (Milestone 2)
row_cost: {
    direction: right
    style.fill: transparent
    cost_config: {
        shape: sql_table
        label: CostModelConfig
        file: "query_optimizer/cost/01_config.py"
        milestone: 2
        seq_page_cost: "float = 1.0"
        random_page_cost: "float = 4.0"
        cpu_tuple_cost: "float = 0.01"
        cpu_index_tuple_cost: "float = 0.005"
        cpu_operator_cost: "float = 0.0025"
        parallel_tuple_cost: "float = 0.1"
        memory_context_size: "int = 8192"
    }
    scan_cost: {
        shape: class
        label: Scan Cost Functions
        file: "query_optimizer/cost/02_scan_cost.py"
        milestone: 2
        cost_seq_scan: "(stats, selectivity) -> float"
        cost_index_scan: "(stats, selectivity, index) -> float"
        find_selectivity_threshold: "(table_stats, index) -> float"
    }
    selectivity: {
        shape: class
        label: Selectivity Estimators
        file: "query_optimizer/cost/03_selectivity.py"
        milestone: 2
        selectivity_equality: "(col_stats, value) -> float"
        selectivity_range: "(col_stats, op, value) -> float"
        selectivity_and: "(sel1, sel2, cols) -> float"
        selectivity_or: "(sel1, sel2, cols) -> float"
        selectivity_not: "(selectivity) -> float"
    }
    join_card: {
        shape: class
        label: Join Cardinality
        file: "query_optimizer/cost/04_join_cardinality.py"
        milestone: 2
        cardinality_equijoin: "(left_rows, right_rows, left_ndv, right_ndv) -> float"
        estimate_join_cost: "(left_stats, right_stats, condition) -> Tuple[float, float]"
    }
    cost_estimator: {
        shape: class
        label: CostEstimator
        file: "query_optimizer/cost/05_estimator.py"
        milestone: 2
        config: "CostModelConfig"
        catalog: "StatisticsCatalog"
        estimate_plan_cost: "(plan: PlanNode) -> CostEstimate"
        estimate_scan: "(scan) -> CostEstimate"
        estimate_join: "(join) -> CostEstimate"
        estimate_aggregate: "(agg) -> CostEstimate"
    }
    estimation_validator: {
        shape: class
        label: EstimationValidator
        file: "query_optimizer/cost/06_validator.py"
        milestone: 2
        validate: "(estimated, actual) -> EstimationResult"
        compute_error_rate: "() -> float"
        confidence_interval: "(estimate) -> Tuple[float, float]"
    }
}
# Row 4: Rules Engine Module (Milestone 3)
row_rules: {
    direction: right
    style.fill: transparent
    column_ref: {
        shape: sql_table
        label: ColumnRef
        file: "query_optimizer/rules/01_column_ref.py"
        milestone: 3
        table_name: "str"
        column_name: "str"
        alias: "str | None"
    }
    provenance: {
        shape: class
        label: Column Provenance
        file: "query_optimizer/rules/02_provenance.py"
        milestone: 3
        get_tables_in_subtree: "(node) -> Set[str]"
        compute_column_usage: "(node) -> Dict[str, ColumnUsage]"
        track_column_origin: "(col_ref) -> str"
    }
    rule_base: {
        shape: class
        label: OptimizationRule
        file: "query_optimizer/rules/03_base.py"
        milestone: 3
        rule_name: "str"
        rule_priority: "int"
        matches: "(node: PlanNode) -> bool"
        apply: "(node) -> RuleApplicationResult"
        is_applicable: "(context) -> bool"
    }
    predicate_pushdown: {
        shape: class
        label: PredicatePushdownRule
        file: "query_optimizer/rules/04_predicate_pushdown.py"
        milestone: 3
        push_through_join: "(filter, join) -> PlanNode"
        push_through_project: "(filter, project) -> PlanNode"
        can_push_predicate: "(pred, target) -> bool"
    }
    projection_pruning: {
        shape: class
        label: ProjectionPruningRule
        file: "query_optimizer/rules/05_projection_pruning.py"
        milestone: 3
        compute_required_columns: "(node) -> Set[str]"
        prune_unnecessary: "(project) -> PlanNode"
        is_column_used_above: "(col, node) -> bool"
    }
    constant_folding: {
        shape: class
        label: ConstantFoldingRule
        file: "query_optimizer/rules/06_constant_folding.py"
        milestone: 3
        fold_expression: "(expr) -> Any"
        is_foldable: "(expr) -> bool"
        evaluate_constant: "(op, args) -> Any"
    }
}
# Row 5: Rules Engine Continued + Semantic (Milestone 3)
row_rules2: {
    direction: right
    style.fill: transparent
    redundant_pred: {
        shape: class
        label: RedundantPredicateRule
        file: "query_optimizer/rules/07_redundant_predicates.py"
        milestone: 3
        detect_tautology: "(predicate) -> bool"
        detect_contradiction: "(predicate) -> bool"
        remove_redundant: "(filter) -> PlanNode"
    }
    rule_engine: {
        shape: class
        label: RuleEngine
        file: "query_optimizer/rules/08_engine.py"
        milestone: 3
        rules: "List[OptimizationRule]"
        config: "OptimizerConfig"
        max_iterations: "int"
        optimize: "(plan: PlanNode) -> PlanNode"
        apply_rule: "(plan, rule) -> PlanNode"
        run_to_fixpoint: "(plan) -> PlanNode"
    }
    semantic_verify: {
        shape: class
        label: Semantic Verifier
        file: "query_optimizer/rules/09_semantic_verify.py"
        milestone: 3
        verify_semantic_preservation: "(original, optimized) -> bool"
        check_output_equivalence: "(plan1, plan2) -> bool"
        validate_constraints: "(plan) -> List[str]"
    }
}
# Row 6: Join Optimization Module (Milestone 4)
row_join: {
    direction: right
    style.fill: transparent
    subset_enum: {
        shape: class
        label: Subset Enumeration
        file: "query_optimizer/join/01_subset.py"
        milestone: 4
        enumerate_subsets: "(tables: Set[str]) -> List[Set[str]]"
        enumerate_partitions: "(tables, k) -> List[Tuple]"
        powerset: "(iterable) -> Iterator"
    }
    dp_entry: {
        shape: sql_table
        label: DPTableEntry
        file: "query_optimizer/join/02_dp_entry.py"
        milestone: 4
        tables: "Set[str]"
        best_plan: "PlanNode"
        best_cost: "float"
        interesting_orders: "List[InterestingOrder]"
    }
    join_graph: {
        shape: class
        label: JoinGraph
        file: "query_optimizer/join/03_join_graph.py"
        milestone: 4
        nodes: "Set[str]"
        edges: "List[JoinEdge]"
        build_join_graph: "(plan) -> JoinGraph"
        get_connected_components: "() -> List[Set[str]]"
        get_join_conditions: "(left, right) -> List"
    }
    dp_optimizer: {
        shape: class
        label: DynamicProgrammingOptimizer
        file: "query_optimizer/join/04_dp_optimizer.py"
        milestone: 4
        dp_table: "Dict[frozenset, DPTableEntry]"
        config: "OptimizerConfig"
        max_tables: "int"
        optimize: "(join_graph) -> PlanNode"
        enumerate_plans: "(subset) -> List[PlanNode]"
        compute_entry: "(subset) -> DPTableEntry"
    }
    access_path: {
        shape: class
        label: Access Path Selection
        file: "query_optimizer/join/05_access_path.py"
        milestone: 4
        select_access_path: "(table, predicates, stats) -> PlanNode"
        choose_index: "(table, predicates) -> Index | None"
        compute_index_benefit: "(index, selectivity) -> float"
    }
    join_selection: {
        shape: class
        label: Join Algorithm Selection
        file: "query_optimizer/join/06_join_selection.py"
        milestone: 4
        select_join_algorithm: "(left, right, condition, stats) -> PlanNode"
        estimate_hash_join_cost: "(left, right) -> float"
        estimate_merge_join_cost: "(left, right) -> float"
        estimate_nested_loop_cost: "(left, right) -> float"
    }
}
# Row 7: Interesting Orders + Greedy + Main Optimizer (Milestone 4)
row_opt: {
    direction: right
    style.fill: transparent
    interesting_orders: {
        shape: sql_table
        label: InterestingOrder
        file: "query_optimizer/join/07_interesting_orders.py"
        milestone: 4
        columns: "List[str]"
        direction: "SortDirection"
        benefit: "float"
        source: "str"
    }
    greedy_optimizer: {
        shape: class
        label: Greedy Join Order
        file: "query_optimizer/join/08_greedy.py"
        milestone: 4
        greedy_join_order: "(join_graph) -> PlanNode"
        select_next_table: "(remaining, current) -> str"
        compute_incremental_cost: "(current, candidate) -> float"
    }
    query_optimizer: {
        shape: class
        label: QueryOptimizer
        file: "query_optimizer/join/09_query_optimizer.py"
        milestone: 4
        stats_catalog: "StatisticsCatalog"
        cost_estimator: "CostEstimator"
        rule_engine: "RuleEngine"
        stats: "OptimizationStats"
        optimize: "(query: PlanNode) -> PlanNode"
        run_logical_optimization: "(plan) -> PlanNode"
        run_physical_optimization: "(plan) -> PlanNode"
        generate_plan_alternatives: "(plan) -> List[PlanNode]"
    }
}
# Vertical relationships within rows
row_plan.plan_node -> row_plan.logical_ops: "specializes to" {
    style.stroke: "#4A90D9"
}
row_plan.logical_ops -> row_plan.physical_ops: "transforms to" {
    style.stroke: "#4A90D9"
}
row_stats.analyzer -> row_stats.stats_catalog: "populates" {
    style.stroke: "#50C878"
}
row_stats.column_histogram -> row_stats.column_stats: "embedded in" {
    style.stroke: "#50C878"
}
row_cost.cost_estimator -> row_cost.selectivity: "uses" {
    style.stroke: "#E6A117"
}
row_cost.scan_cost -> row_cost.cost_estimator: "provides" {
    style.stroke: "#E6A117"
}
row_cost.join_card -> row_cost.cost_estimator: "provides" {
    style.stroke: "#E6A117"
}
row_rules.rule_engine -> row_rules.rule_base: "applies" {
    style.stroke: "#9B59B6"
}
row_rules.predicate_pushdown -> row_rules.rule_engine: "registered in" {
    style.stroke: "#9B59B6"
}
row_rules2.semantic_verify -> row_rules.rule_engine: "validates" {
    style.stroke: "#9B59B6"
}
row_join.dp_optimizer -> row_join.dp_entry: "populates" {
    style.stroke: "#E74C3C"
}
row_join.join_graph -> row_join.dp_optimizer: "input to" {
    style.stroke: "#E74C3C"
}
row_join.access_path -> row_join.join_selection: "feeds into" {
    style.stroke: "#E74C3C"
}
row_opt.greedy_optimizer -> row_opt.query_optimizer: "fallback for" {
    style.stroke: "#1ABC9C"
}
row_opt.interesting_orders -> row_join.dp_optimizer: "tracks in" {
    style.stroke: "#1ABC9C"
}
# Cross-row relationships (milestone flow)
row_stats.stats_catalog -> row_cost.cost_estimator: "provides statistics" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
row_plan.plan_node -> row_cost.cost_estimator: "estimates cost of" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
row_plan.physical_ops -> row_rules.rule_engine: "transforms via rules" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
row_cost.cost_estimator -> row_join.dp_optimizer: "guides DP decisions" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
row_rules.rule_engine -> row_opt.query_optimizer: "logical optimization" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
row_join.dp_optimizer -> row_opt.query_optimizer: "physical optimization" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
row_join.join_selection -> row_opt.query_optimizer: "join algorithms" {
    style.stroke: "#666"
    style.stroke-dash: 3
}
# Main optimizer central connections
row_opt.query_optimizer -> row_stats.stats_catalog: "queries" {
    style.stroke: "#333"
}
row_opt.query_optimizer -> row_cost.cost_estimator: "uses" {
    style.stroke: "#333"
}
# Milestone Index Panel
milestone_index: {
    direction: down
    label: "Milestone Index"
    m1: {
        shape: rectangle
        label: "M1: Plan Trees & Statistics"
        style.fill: "#E8F4FD"
    }
    m2: {
        shape: rectangle
        label: "M2: Cost Model & Estimation"
        style.fill: "#FEF9E7"
    }
    m3: {
        shape: rectangle
        label: "M3: Rule-Based Optimization"
        style.fill: "#F5EEF8"
    }
    m4: {
        shape: rectangle
        label: "M4: Join Ordering & Selection"
        style.fill: "#FDEDEC"
    }
    m1 -> m2 -> m3 -> m4
}
theme-id: 3