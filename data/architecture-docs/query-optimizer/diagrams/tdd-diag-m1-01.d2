vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}

direction: up

PlanNode: {
  shape: class
  style: {
    font-color: "#1a1a2e"
    fill: "#e8e8e8"
    stroke: "#4a4a4a"
    stroke-width: 2
  }
  
  " stereotype ": "<<abstract>>"
  estimated_cost: float
  estimated_rows: float
  children: "List[PlanNode]"
  
  operator_type(): str
  details(): dict
  is_leaf(): bool
  depth(): int
  node_count(): int
}

LogicalOperator: {
  shape: class
  style: {
    font-color: "#1a1a2e"
    fill: "#dbeafe"
    stroke: "#2563eb"
  }
  " stereotype ": "<<abstract>>"
}

PhysicalOperator: {
  shape: class
  style: {
    font-color: "#1a1a2e"
    fill: "#dcfce7"
    stroke: "#16a34a"
  }
  " stereotype ": "<<abstract>>"
}

LogicalScan: {
  shape: class
  style.fill: "#bfdbfe"
  table_name: str
  alias: str
  columns: "List[str]"
  filter: "Optional[Expression]"
}

LogicalFilter: {
  shape: class
  style.fill: "#bfdbfe"
  predicate: Expression
}

LogicalProject: {
  shape: class
  style.fill: "#bfdbfe"
  expressions: "List[Tuple[Expression, str]]"
}

LogicalJoin: {
  shape: class
  style.fill: "#bfdbfe"
  join_type: JoinType
  condition: Expression
}

LogicalAggregate: {
  shape: class
  style.fill: "#bfdbfe"
  group_by: "List[Expression]"
  aggregations: "List[Tuple[AggregateFunc, str]]"
}

PhysicalSeqScan: {
  shape: class
  style.fill: "#bbf7d0"
  table_name: str
  alias: str
  columns: "List[str]"
  filter_pred: "Optional[Expression]"
  total_rows: int
}

PhysicalIndexScan: {
  shape: class
  style.fill: "#bbf7d0"
  table_name: str
  index_name: str
  index_columns: "List[str]"
  range_start: "Optional[Any]"
  range_end: "Optional[Any]"
}

PhysicalNestedLoopJoin: {
  shape: class
  style.fill: "#bbf7d0"
  join_type: JoinType
  condition: Expression
  outer_first: bool
}

PhysicalHashJoin: {
  shape: class
  style.fill: "#bbf7d0"
  join_type: JoinType
  hash_keys_left: "List[str]"
  hash_keys_right: "List[str]"
  build_side: str
}

PhysicalSortMergeJoin: {
  shape: class
  style.fill: "#bbf7d0"
  join_type: JoinType
  sort_keys_left: "List[str]"
  sort_keys_right: "List[str]"
}

PhysicalSort: {
  shape: class
  style.fill: "#bbf7d0"
  sort_keys: "List[Tuple[str, SortOrder]]"
  limit: "Optional[int]"
}

# Inheritance Relationships
LogicalOperator -> PlanNode: {
  style.stroke-dash: 3
  style.stroke: "#2563eb"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}

PhysicalOperator -> PlanNode: {
  style.stroke-dash: 3
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}

# Logical operators inheritance
LogicalScan -> LogicalOperator: {
  style.stroke: "#2563eb"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
LogicalFilter -> LogicalOperator: {
  style.stroke: "#2563eb"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
LogicalProject -> LogicalOperator: {
  style.stroke: "#2563eb"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
LogicalJoin -> LogicalOperator: {
  style.stroke: "#2563eb"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
LogicalAggregate -> LogicalOperator: {
  style.stroke: "#2563eb"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}

# Physical operators inheritance
PhysicalSeqScan -> PhysicalOperator: {
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
PhysicalIndexScan -> PhysicalOperator: {
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
PhysicalNestedLoopJoin -> PhysicalOperator: {
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
PhysicalHashJoin -> PhysicalOperator: {
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
PhysicalSortMergeJoin -> PhysicalOperator: {
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}
PhysicalSort -> PhysicalOperator: {
  style.stroke: "#16a34a"
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
}

# Group logical operators
LogicalGroup: "Logical Operators\n(Declarative)" {
  style: {
    stroke: "#2563eb"
    stroke-dash: 4
    fill: "#eff6ff"
  }
  LogicalScan
  LogicalFilter
  LogicalProject
  LogicalJoin
  LogicalAggregate
}

# Group physical operators
PhysicalGroup: "Physical Operators\n(Executable)" {
  style: {
    stroke: "#16a34a"
    stroke-dash: 4
    fill: "#f0fdf4"
  }
  PhysicalSeqScan
  PhysicalIndexScan
  PhysicalNestedLoopJoin
  PhysicalHashJoin
  PhysicalSortMergeJoin
  PhysicalSort
}

# Legend
Legend: {
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#f8fafc"
    stroke: "#94a3b8"
    stroke-width: 1
  }
  
  BaseClass: "Abstract Base Class" {
    style.fill: "#e8e8e8"
  }
  LogicalClass: "Logical (Declarative)" {
    style.fill: "#dbeafe"
  }
  PhysicalClass: "Physical (Executable)" {
    style.fill: "#dcfce7"
  }
  Inheritance: "△ = Inheritance"
  
  BaseClass -> LogicalClass -> PhysicalClass -> Inheritance: {
    style.stroke: "transparent"
  }
}

# Header Labels
Title: "Plan Node Class Hierarchy" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

Subtitle: "Query Optimizer — Logical to Physical Operator Transformation" {
  shape: text
  near: top-center
  style.font-size: 18
}