direction: up
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  plan_node: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  join_node: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  scan_node: {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  filter_node: {
    shape: diamond
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
      shadow: true
    }
  }
  cost_badge: {
    shape: oval
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      font-size: 11
    }
  }
}

# Root: Final Projection
result: {
  class: plan_node
  label: "PROJECT\nid, name, total\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nrows: 1,250\ncost: 4,892.45"
}

# Top-level Hash Join (orders Г— (users Г— products Г— order_items))
hash_join_1: {
  class: join_node
  label: "HASH JOIN\norders.id = order_items.order_id\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ntype: Hash Build/Probe\nrows: 2,500\ncost: 4,245.80\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nbuild: order_items\nprobe: filtered orders"
}

result -> hash_join_1: {
  label: "parent-child\noutput refs"
  style: {
    stroke: "#1976D2"
    stroke-width: 3
  }
}

# Left branch: Filtered Orders Scan
filter_orders: {
  class: filter_node
  label: "FILTER\norders.status = 'completed'\nAND orders.created_at > '2024-01-01'\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nselectivity: 0.35\nrows: 35,000 в†’ 12,250\ncost: 1,850.20"
}

hash_join_1 -> filter_orders: {
  label: "probe input"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
    stroke-dash: 3
  }
}

scan_orders: {
  class: scan_node
  label: "SEQ SCAN\norders\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\npages: 4,200\nrows: 35,000\ncost: 842.00\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nheap fetches: 35,000"
}

filter_orders -> scan_orders: {
  label: "scan input"
  style: {
    stroke: "#F57C00"
    stroke-width: 2
  }
}

# Right branch: Hash Join (users Г— products Г— order_items)
hash_join_2: {
  class: join_node
  label: "HASH JOIN\nusers.id = order_items.user_id\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ntype: Hash Build/Probe\nrows: 5,200\ncost: 2,120.50\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nbuild: users\nprobe: productsГ—items"
}

hash_join_1 -> hash_join_2: {
  label: "build input"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}

# Nested Hash Join for products Г— order_items
hash_join_3: {
  class: join_node
  label: "HASH JOIN\nproducts.id = order_items.product_id\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ntype: Hash Build/Probe\nrows: 15,600\ncost: 1,680.30\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nbuild: products\nprobe: order_items"
}

hash_join_2 -> hash_join_3: {
  label: "probe input"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Scan: Products
scan_products: {
  class: scan_node
  label: "INDEX SCAN\nproducts (idx_category)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nindex cond: category_id = 5\nrows: 850\ncost: 127.50\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nindex pages: 12\nheap fetches: 850"
}

hash_join_3 -> scan_products: {
  label: "build input"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}

# Scan: Order Items
scan_items: {
  class: scan_node
  label: "SEQ SCAN\norder_items\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\npages: 12,500\nrows: 125,000\ncost: 2,500.00\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nfilter: quantity > 0"
}

hash_join_3 -> scan_items: {
  label: "probe input"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Scan: Users (for hash_join_2)
scan_users: {
  class: scan_node
  label: "INDEX SCAN\nusers (pk_users)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nindex cond: active = true\nrows: 10,000\ncost: 320.00\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nindex pages: 45\nheap fetches: 10,000"
}

hash_join_2 -> scan_users: {
  label: "build input"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}

# Cost Propagation Legend
legend: {
  shape: rectangle
  label: "Cost Propagation Legend\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nрџ”µ Plan Node: Final projection\nрџџў Join Node: Multi-way joins\nрџџ  Scan Node: Data access\nрџ”ґ Filter Node: Predicate application\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nCost = IO_cost + CPU_cost\nRows = cardinality estimate\nSelectivity = rows_out / rows_in"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 4
    font-size: 11
  }
}

# Cost annotations floating badges
cost_root: {
  class: cost_badge
  label: "total: 4,892.45\nfinal: 1,250 rows"
}
cost_join1: {
  class: cost_badge
  label: "join cost: 4,245.80\ncard: 2,500"
}
cost_filter: {
  class: cost_badge
  label: "filter cost: 1,850.20\nselectivity: 0.35"
}
cost_scan_orders: {
  class: cost_badge
  label: "scan cost: 842.00\npages: 4,200"
}

result -> cost_root: { style: { opacity: 0 } }
hash_join_1 -> cost_join1: { style: { opacity: 0 } }
filter_orders -> cost_filter: { style: { opacity: 0 } }
scan_orders -> cost_scan_orders: { style: { opacity: 0 } }

# Cardinality flow annotation group
cardinality_flow: {
  shape: rectangle
  label: "Cardinality Flow\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n125K order_items в†’ 15.6K (join) в†’ 5.2K (join) в†’ 2.5K (final join) в†’ 1.25K (project)\n35K orders в†’ 12.25K (filter) в†’ 2.5K (join)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nTotal reduction: 99% (125K в†’ 1.25K)"
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-dash: 3
    font-size: 10
    italic: true
  }
}

# Operator properties table
operator_properties: {
  shape: rectangle
  label: |'md
    # Physical Operator Properties
    | Operator | Build Side | Probe Side | Memory | Best usage |
    | :--- | :--- | :--- | :--- | :--- |
    | **Hash Join** | Smaller input в†’ hash table | Larger input в†’ lookups | O(min(N,M)) | Equi-join, fits memory |
    | **Seq Scan** | N/A | N/A | O(1) | Large % of table needed |
    | **Index Scan** | N/A | N/A | O(1) | Selective predicate |
    | **Filter** | N/A | N/A | O(1) | Reducing cardinality early |
  '|
  style: {
    fill: "#F9FBE7"
    stroke: "#827717"
  }
}

# Position legend at bottom right
legend_pos: {
  width: 280
}