vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Logical vs Physical Operator Mapping" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: "Relational Algebra (WHAT) to Machine Execution (HOW) — Cost-Based Selection" {
  shape: text
  near: top-center
  style: {
    font-size: 16
    italic: true
  }
}

# -----------------------------------------------------------------------------
# LOGICAL LAYER: The Declarative Plan
# -----------------------------------------------------------------------------
logical_layer: "Logical Operators (WHAT)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 4
  }

  LogicalScan: {
    shape: class
    +table: "TableRef"
    +alias: "string"
    +required_columns: "Bitmap"
    "sizeof": "48 bytes"
  }

  LogicalFilter: {
    shape: class
    +input: "RelNode*"
    +predicate: "ExpressionTree"
    +selectivity(): "double"
    "sizeof": "64 bytes"
  }

  LogicalProject: {
    shape: class
    +input: "RelNode*"
    +expressions: "List<Expr>"
    +is_identity(): "bool"
    "sizeof": "56 bytes"
  }

  LogicalJoin: {
    shape: class
    style.fill: "#E8F5E9"
    +left: "RelNode*"
    +right: "RelNode*"
    +condition: "Expression"
    +join_type: "JoinType"
    "sizeof": "128 bytes"
  }

  LogicalAggregate: {
    shape: class
    +input: "RelNode*"
    +group_keys: "ColumnSet"
    +agg_functions: "List<AggCall>"
    "sizeof": "80 bytes"
  }
}

# -----------------------------------------------------------------------------
# MAPPING & OPTIMIZATION ZONE
# -----------------------------------------------------------------------------
optimizer_core: "CBO: Cost-Based Optimizer" {
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    stroke-width: 3
    stroke-dash: 5
  }

  cost_estimator: "Selection Strategy\n(Cost Estimator)" {
    shape: diamond
    tooltip: "Uses Statistics (Histograms, MCV) to select Physical Implementation"
    style: {
      fill: "#FFE0B2"
    }
  }

  stats_db: "Catalog Stats" {
    shape: cylinder
    label: "Catalog / Stats\n(Row count, Width, NDV)"
  }
  
  stats_db -> cost_estimator: "Input Statistics"
}

# -----------------------------------------------------------------------------
# PHYSICAL LAYER: The Execution Implementations
# -----------------------------------------------------------------------------
physical_layer: "Physical Operators (HOW)" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 4
  }

  scan_implementations: "Scan Implementations" {
    PhysicalSeqScan: {
      shape: class
      +table: "TableRef"
      +next_block(): "Status"
      "cpu_cost": "1.0 per tuple"
      "io_cost": "sequential"
    }
    PhysicalIndexScan: {
      shape: class
      +index: "IndexRef"
      +range: "ScanRange"
      "cpu_cost": "log(N)"
      "io_cost": "random/seek"
    }
  }

  join_implementations: "Join Implementations" {
    style.fill: "#FCE4EC"
    
    PhysicalHashJoin: {
      shape: class
      +build_hash_table(): "void"
      +probe(tuple): "Tuple*"
      "mem_overhead": "O(Size(BuildSide))"
      "complexity": "O(M + N)"
    }
    
    PhysicalSortMergeJoin: {
      shape: class
      +left_cursor: "Cursor*"
      +right_cursor: "Cursor*"
      "mem_overhead": "Small (if sorted)"
      "complexity": "O(M log M + N log N)"
    }
    
    PhysicalNestedLoopJoin: {
      shape: class
      +outer_loop(): "void"
      +inner_lookup(): "void"
      "mem_overhead": "O(1)"
      "complexity": "O(M * N)"
    }
  }

  agg_implementations: "Aggregate Implementations" {
    PhysicalHashAgg: {
      shape: class
      +hash_table: "GroupMap"
      "complexity": "O(N)"
    }
    PhysicalSortAgg: {
      shape: class
      +input: "SortedIterator"
      "complexity": "O(N)"
    }
  }
}

# -----------------------------------------------------------------------------
# TRANSITION FLOWS (Logical -> Estimator -> Physical)
# -----------------------------------------------------------------------------

# Scans
logical_layer.LogicalScan -> optimizer_core.cost_estimator: "RelNode"
optimizer_core.cost_estimator -> physical_layer.scan_implementations.PhysicalSeqScan: "IF Cardinality > 15%" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
optimizer_core.cost_estimator -> physical_layer.scan_implementations.PhysicalIndexScan: "IF SARGable Predicate" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}

# Joins
logical_layer.LogicalJoin -> optimizer_core.cost_estimator: "RelNode"
optimizer_core.cost_estimator -> physical_layer.join_implementations.PhysicalHashJoin: "Equi-Join & Small Build Side" {
  style.stroke: "#880E4F"
  style.stroke-width: 3
}
optimizer_core.cost_estimator -> physical_layer.join_implementations.PhysicalSortMergeJoin: "Sorted Inputs / Large Data" {
  style.stroke: "#880E4F"
  style.stroke-width: 1
}
optimizer_core.cost_estimator -> physical_layer.join_implementations.PhysicalNestedLoopJoin: "Non-Equi / Tiny Outer" {
  style.stroke: "#880E4F"
  style.stroke-dash: 2
}

# Aggregates
logical_layer.LogicalAggregate -> optimizer_core.cost_estimator: "RelNode"
optimizer_core.cost_estimator -> physical_layer.agg_implementations.PhysicalHashAgg: "High Group-By NDV"
optimizer_core.cost_estimator -> physical_layer.agg_implementations.PhysicalSortAgg: "Pre-sorted / Low Memory"

# -----------------------------------------------------------------------------
# LEGEND AND DOCUMENTATION
# -----------------------------------------------------------------------------
legend: "Selection Criteria / Costing" {
  near: bottom-right
  
  hash_note: "Hash Implementation: Memory intensive, O(N) average case" {
    shape: text
    style.font-size: 10
  }
  sort_note: "Sort Implementation: Disk-spill friendly, best for large sets" {
    shape: text
    style.font-size: 10
  }
  scan_note: "Index vs Seq: Selected by I/O cost model + Page Statistics" {
    shape: text
    style.font-size: 10
  }
}

annotation_block: |md
  ### The Optimization Process
  1. **Transformation**: Generate equivalent physical candidates (PhysicalProperty enforced).
  2. **Cost Estimation**: Apply formula: `Cost = (W1 * CPU) + (W2 * IO) + (W3 * Net)`.
  3. **Pruning**: Use Dynamic Programming or Cascades (Volcano) to discard high-cost sub-trees.
| {
  near: bottom-center
  style: {
    stroke: "#9E9E9E"
    fill: "#F5F5F5"
    font-size: 12
  }
}