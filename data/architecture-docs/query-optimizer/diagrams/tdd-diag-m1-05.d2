direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL CLASSES: INTEL-SPEC QUALITY ---
classes: {
  header_text: {
    shape: text
    style: {
      bold: true
      font-size: 24
    }
  }
  data_source: {
    shape: cylinder
    style: {
      fill: "#3498db"
      font-color: white
      stroke-width: 2
      shadow: true
    }
  }
  bucket: {
    shape: rectangle
    style: {
      stroke-width: 2
      border-radius: 4
      font: mono
      font-size: 12
    }
  }
  boundary: {
    shape: diamond
    width: 45
    height: 45
    style: {
      fill: "#e74c3c"
      stroke: "#c0392b"
      font-color: white
      bold: true
      font-size: 11
    }
  }
  stats_box: {
    shape: rectangle
    style: {
      fill: "#f8f9fa"
      stroke: "#dee2e6"
      font: mono
      font-size: 11
      stroke-dash: 2
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 13
      italic: true
    }
  }
}

# --- HEADER SECTION ---
top_header: {
  title: "EQUI-DEPTH HISTOGRAM SPECIFICATION" {
    class: header_text
    style.underline: true
  }
  subtitle: "Module: Query Optimizer Statistics - Statistics Generation (TDD-M1-05)" {
    shape: text
    style.italic: true
  }
}

# --- LEGEND ---
legend: {
  near: top-right
  label: "DIAGRAM NOTATION"
  style: {
    stroke-dash: 4
    fill: "#ffffff"
    border-radius: 8
  }
  grid_container: {
    grid-columns: 2
    grid-gap: 15
    style.stroke-width: 0
    
    b_color: "" { shape: rectangle; style.fill: "#4a90d9"; width: 30; height: 15 }
    b_desc: "Valid Bucket (Equal Depth)" { shape: text }
    
    e_color: "" { shape: rectangle; style.fill: "#c0392b"; width: 30; height: 15 }
    e_desc: "Invalid/Skewed Bucket" { shape: text }
    
    a_color: "" { shape: diamond; style.fill: "#e74c3c"; width: 15; height: 15 }
    a_desc: "Adaptive Boundary Marker" { shape: text }
  }
}

# ==========================================
# SCENARIO A: UNIFORM DATA DISTRIBUTION
# ==========================================
uniform_section: {
  label: "SCENARIO A: UNIFORM (Linear Distribution)"
  style: {
    fill: "#e8f4f8"
    stroke: "#2980b9"
    stroke-width: 3
  }

  source: "TABLE: users\n(N=500 total rows)\nStorage: PageAligned" { 
    class: data_source 
    tooltip: "Input stream for histogram generation"
  }

  # Histogram Visualization
  histogram: "Row Frequency Visualization" {
    style.fill: transparent
    style.stroke-dash: 2
    
    bar_grid: {
      grid-columns: 8
      grid-gap: 8
      style.stroke-width: 0
      b1; b2; b3; b4; b5; b6; b7; b8
      b*.label: "||||"
      b*.shape: rectangle
      b*.style.fill: "#2ecc71"
      b*.height: 50
      b*.width: 30
    }
    label.near: top-center
  }

  # Bucket Layout with Memory Offsets
  buckets: "Equi-Depth Storage Model (In-Memory Layout)" {
    style.fill: "#ffffff"
    direction: right
    
    ub1: "Bucket 0\nOffs: 0x00\nRange: [0, 125)\nRows: 125" { class: bucket; style.fill: "#4a90d9"; style.font-color: white }
    ub2: "Bucket 1\nOffs: 0x20\nRange: [125, 250)\nRows: 125" { class: bucket; style.fill: "#4a90d9"; style.font-color: white }
    ub3: "Bucket 2\nOffs: 0x40\nRange: [250, 375)\nRows: 125" { class: bucket; style.fill: "#4a90d9"; style.font-color: white }
    ub4: "Bucket 3\nOffs: 0x60\nRange: [375, 500]\nRows: 125" { class: bucket; style.fill: "#4a90d9"; style.font-color: white }
  }

  # Boundaries
  boundaries: "Discrete Quantiles (B-Array)" {
    style.stroke-width: 0
    direction: right
    b1: "0" { class: boundary }
    b2: "125" { class: boundary }
    b3: "250" { class: boundary }
    b4: "375" { class: boundary }
    b5: "500" { class: boundary }
  }

  stats: {
    class: stats_box
    label: "METADATA PAGE 0x4F\n------------------\nTotalRows: 500\nNumBuckets: 4\nTargetDepth: 125\nErrTolerance: 0.2%"
  }

  source -> histogram: "Full Table Scan"
  histogram -> buckets: "N/B Partitioning"
  buckets -> stats: "Finalize Stats"
}

# ==========================================
# SCENARIO B: SKEWED DATA DISTRIBUTION
# ==========================================
skewed_section: {
  label: "SCENARIO B: SKEWED (Zipfian/Power Law)"
  style: {
    fill: "#fdf2e9"
    stroke: "#e67e22"
    stroke-width: 3
  }

  source: "TABLE: orders\n(N=500 total rows)\nHigh Value Skew" { 
    class: data_source
    style.fill: "#e67e22" 
  }

  histogram: "High-Density Skew Analysis" {
    style.fill: transparent
    
    bar_grid: {
      grid-columns: 8
      grid-gap: 5
      style.stroke-width: 0
      s1: { height: 120; width: 30; style.fill: "#c0392b" }
      s2: { height: 85; width: 30; style.fill: "#cd6155" }
      s3: { height: 60; width: 30; style.fill: "#d98880" }
      s4: { height: 40; width: 30; style.fill: "#e6b0aa" }
      s5: { height: 25; width: 30; style.fill: "#f2d7d5" }
      s6: { height: 18; width: 30; style.fill: "#f5eef8" }
      s7: { height: 12; width: 30; style.fill: "#ebdef0" }
      s8: { height: 8; width: 30; style.fill: "#d7bde2" }
      s*.label: "||"
      s*.shape: rectangle
    }
  }

  # Algorithm State Transition
  calc_state: "Boundary Calculation Logic" {
    step1: "1. Sort Values Ascending\nO(N log N)" { shape: rectangle; style.fill: "#fef9e7" }
    step2: "2. Walk Stride (N/B)\nB=4, Stride=125" { shape: rectangle; style.fill: "#fef9e7" }
    step3: "3. Emit Value at Stride\nO(B)" { shape: rectangle; style.fill: "#fef9e7" }
    
    step1 -> step2 -> step3: "Pipeline"
    
    style.fill: "#fffdf0"
    style.font: mono
  }

  # Comparison of Strategies
  comparison: "Strategy Benchmark" {
    style.stroke-width: 1
    style.stroke-dash: 3
    
    bad_strategy: "Equi-Width (Naive)" {
      ew1: "B0: 300 rows\nRange: [0, 10)" { class: bucket; style.fill: "#c0392b"; style.font-color: white }
      ew2: "B1: 85 rows\nRange: [10, 20)" { class: bucket; style.fill: "#e74c3c"; style.font-color: white }
      ew1 -> ew2: "Skewed Depth (High Variance)" { style.stroke: red; style.bold: true }
    }

    good_strategy: "Equi-Depth (Adaptive)" {
      ed1: "B0: 125 rows\nRange: [0, 4)" { class: bucket; style.fill: "#27ae60"; style.font-color: white }
      ed2: "B1: 125 rows\nRange: [4, 9)" { class: bucket; style.fill: "#2ecc71"; style.font-color: white }
      ed1 -> ed2: "Balanced Depth (Zero Variance)" { style.stroke: green; style.bold: true }
    }
  }

  source -> histogram -> calc_state -> comparison: "Execution Path"
}

# ==========================================
# SELECTIVITY CALCULATION & FORMULA
# ==========================================
math_section: {
  label: "SELECTIVITY ESTIMATION ENGINE (FORMULA SPEC)"
  style.fill: "#f4f6f7"
  style.stroke: "#7f8c8d"
  style.stroke-width: 2

  formula: |md
    ### Range Selectivity Implementation
    For a range predicate `[lo, hi)` on column `C`:
    
    `selectivity(lo, hi) = Σ (matching_bucket_fractions) / TotalBuckets`
    
    **Boundary Intersection Logic:**
    
    `fraction = (min(hi, B_upper) - max(lo, B_lower)) / (B_upper - B_lower)`
    
    *Implementation Detail:*
    - If `lo <= B_lower` AND `hi >= B_upper`, `fraction = 1.0` (Full Bucket).
    - Else, use Linear Interpolation within the adaptive bucket bounds.
  | {
    shape: rectangle
    style.font: mono
    style.fill: "#ffffff"
    style.border-radius: 5
  }

  example: "RUNTIME TRACE\nQUERY: price BETWEEN 50 AND 200\n\n- Intersecting Buckets: 2.1\n- Estimated Cardinality: 216\n- Actual Profile: 220\n- Error Margin: 1.8%" {
    class: stats_box
    style.stroke: "#2ecc71"
    style.stroke-width: 2
  }
}

# --- CROSS-SECTIONAL CONNECTIONS ---
uniform_section -> skewed_section: "Compare Performance" {
  style.stroke: "#8e44ad"
  style.stroke-dash: 5
  style.stroke-width: 2
}

skewed_section -> math_section: "Propagate Adaptive Boundaries" {
  style.stroke-width: 2
  style.animated: true
}

# --- KEY INSIGHT ANNOTATION ---
insight: |md
  **ARCHITECTURAL INVARIANT**
  Equi-depth histograms automatically cluster boundaries in high-density areas, 
  ensuring constant depth per bucket at the cost of variable range widths.
  
  - **Memory:** 256 Buckets = 2KB Cache Footprint.
  - **Search:** Binary search on boundaries O(log B).
  - **Precision:** Superior for join cardinality estimation in skewed catalogs.
| {
  near: bottom-right
  style: {
    fill: "#ebf5fb"
    stroke: "#3498db"
    stroke-width: 4
    font-size: 14
  }
}