vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "HistogramBucket Memory Layout" {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    font-color: "#4B0082"
  }
}

# --- STYLING CLASSES ---
classes: {
  offset_label: {
    shape: text
    style: {
      font-size: 14
      font-family: mono
      font-color: "#666666"
    }
  }
  data_field: {
    width: 320
    style: {
      fill: "#3B82F6"
      stroke: "#1D4ED8"
      stroke-width: 2
      font-color: white
      bold: true
    }
  }
  padding_field: {
    width: 320
    style: {
      fill: "#9CA3AF"
      stroke: "#6B7280"
      stroke-width: 2
      stroke-dash: 4
      font-color: white
      italic: true
    }
  }
  size_label: {
    shape: text
    style: {
      font-size: 14
      font-color: "#1D4ED8"
      bold: true
    }
  }
}

# --- LAYOUT CONTAINER ---
layout_container: {
  style.stroke-width: 0
  style.fill: transparent

  # --- LEFT MARGIN: BYTE OFFSETS ---
  offsets: {
    style.stroke-width: 0
    style.fill: transparent

    o00: "0x00" { class: offset_label }
    o08: "0x08" { class: offset_label }
    o16: "0x10" { class: offset_label }
    o20: "0x14" { class: offset_label }
    o24: "0x18" { class: offset_label }
    o32: "0x20" { class: offset_label }

    o00 -> o08 -> o16 -> o20 -> o24 -> o32: { style.stroke: transparent }
  }

  # --- CENTER: MEMORY BLOCKS ---
  memory: {
    style.stroke-width: 0
    style.fill: transparent

    min_value: "min_value | double\nLow-bound range marker" { 
      class: data_field
      height: 60 
    }
    max_value: "max_value | double\nHigh-bound range marker" { 
      class: data_field
      height: 60 
    }
    row_count: "row_count | int32\nTotal records in bucket" { 
      class: data_field
      height: 40 
    }
    distinct_count: "distinct_count | int32\nEstimated NDV" { 
      class: data_field
      height: 40 
    }
    padding: "Alignment Padding\nEnsuring 8-byte boundary" { 
      class: padding_field
      height: 60 
    }

    min_value -> max_value -> row_count -> distinct_count -> padding: { style.stroke: transparent }
  }

  # --- RIGHT MARGIN: FIELD SIZES ---
  sizes: {
    style.stroke-width: 0
    style.fill: transparent

    s8_1: "8 bytes" { class: size_label }
    s8_2: "8 bytes" { class: size_label }
    s4_1: "4 bytes" { class: size_label }
    s4_2: "4 bytes" { class: size_label }
    s8_p: "8 bytes" { class: size_label; style.font-color: "#6B7280" }

    s8_1 -> s8_2 -> s4_1 -> s4_2 -> s8_p: { style.stroke: transparent }
  }

  # --- HORIZONTAL ALIGNMENT (ROW MARKERS) ---
  offsets.o00 -> memory.min_value -> sizes.s8_1: { style.stroke: "#E5E7EB" }
  offsets.o08 -> memory.max_value -> sizes.s8_2: { style.stroke: "#E5E7EB" }
  offsets.o16 -> memory.row_count -> sizes.s4_1: { style.stroke: "#E5E7EB" }
  offsets.o20 -> memory.distinct_count -> sizes.s4_2: { style.stroke: "#E5E7EB" }
  offsets.o24 -> memory.padding -> sizes.s8_p: { style.stroke: "#E5E7EB" }
}

# --- ANNOTATIONS AND LEGEND ---

summary: {
  near: bottom-right
  # Using double pipes to allow markdown table characters without breaking block string
  label: ||md
### Struct Metadata: HistogramBucket
| Attribute | Value |
| :--- | :--- |
| **Total Size** | 32 Bytes |
| **Alignment** | 8-byte aligned |
| **L1 Cache** | 0.5x Line (64B) |
| **Volatility** | Immutable after Build() |
||
  style: {
    stroke: "#4B0082"
    stroke-width: 2
    fill: "#F3F4F6"
  }
}

legend: {
  near: bottom-left
  direction: right
  data_node: "Data Field (double/int32)" {
    style: {
      fill: "#3B82F6"
      stroke: "#1D4ED8"
      font-color: white
      bold: true
    }
  }
  padding_node: "Alignment Padding" {
    style: {
      fill: "#9CA3AF"
      stroke: "#6B7280"
      stroke-dash: 4
      font-color: white
      italic: true
    }
  }
  
  data_node -> padding_node: { style.stroke: transparent }
}

# Boundary marker for 32B block
layout_container.offsets.o32 -> layout_container.sizes.s8_p: "End of Struct (32B Offset)" {
  style: {
    stroke: "#EF4444"
    stroke-width: 2
    stroke-dash: 2
    font-color: "#EF4444"
    bold: true
  }
}