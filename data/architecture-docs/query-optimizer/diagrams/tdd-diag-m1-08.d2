vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --------------------------------------------------------------------------------------------------
# TITLE & HEADER
# --------------------------------------------------------------------------------------------------
title: |md
  # PlanNode Polymorphic Dispatch
  ## Query Optimizer Pretty-Printing Sequence
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --------------------------------------------------------------------------------------------------
# SEQUENCE DIAGRAM DEFINITION
# --------------------------------------------------------------------------------------------------
dispatch_flow: {
  shape: sequence_diagram

  # Participants (Actors)
  caller: Client Code {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  walker: Tree Walker {
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
  }
  base: "Abstract Base\n(PlanNode)" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-dash: 4
  }
  scan: LogicalScan {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  filter: LogicalFilter {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  hashjoin: PhysicalHashJoin {
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }

  # --- Initial Call ---
  caller -> walker: "explain_plan(node: PlanNode)" {
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
  
  walker -> walker: "pretty_print_plan(node, indent=0)" {
    style.stroke: "#1976D2"
    style.stroke-dash: 2
  }

  # --- Phase 1: LogicalScan Dispatch ---
  group "Resolve Operator Type: LogicalScan" {
    walker -> base: "node->operator_type()" {
      style.stroke: "#4CAF50"
    }
    base -> scan: "vtable_lookup[0x01]" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    scan -> base: "return 'LogicalScan'" {
      style.stroke: "#4CAF50"
      style.stroke-dash: 4
    }
    base -> walker: "'LogicalScan'" {
      style.stroke: "#4CAF50"
    }
  }

  group "Retrieve Details: LogicalScan" {
    walker -> base: "node->details()" {
      style.stroke: "#9C27B0"
    }
    base -> scan: "vtable_lookup[0x02]" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    scan -> base: "return {table: 'users'}" {
      style.stroke: "#9C27B0"
      style.stroke-dash: 4
    }
    base -> walker: "{'table_name': 'users', 'alias': 'u'}" {
      style.stroke: "#9C27B0"
    }
  }

  # --- Phase 2: Recursion & LogicalFilter ---
  walker -> walker: "recurse: pretty_print_plan(child)" {
    style.stroke: "#1976D2"
  }

  group "Resolve Operator Type: LogicalFilter" {
    walker -> base: "child->operator_type()" {
      style.stroke: "#4CAF50"
    }
    base -> filter: "vtable_lookup[0x01]" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    filter -> base: "return 'LogicalFilter'" {
      style.stroke: "#4CAF50"
      style.stroke-dash: 4
    }
    base -> walker: "'LogicalFilter'" {
      style.stroke: "#4CAF50"
    }
  }

  group "Retrieve Details: LogicalFilter" {
    walker -> base: "child->details()" {
      style.stroke: "#9C27B0"
    }
    base -> filter: "vtable_lookup[0x02]" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    filter -> base: "return {pred: 'id > 100'}" {
      style.stroke: "#9C27B0"
      style.stroke-dash: 4
    }
    base -> walker: "{'predicate': 'u.id > 100'}" {
      style.stroke: "#9C27B0"
    }
  }

  # --- Phase 3: PhysicalHashJoin ---
  walker -> walker: "recurse: pretty_print_plan(join_node)"
  
  group "Resolve Operator Type: PhysicalHashJoin" {
    walker -> base: "join->operator_type()" {
      style.stroke: "#4CAF50"
    }
    base -> hashjoin: "vtable_lookup[0x01]" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    hashjoin -> base: "return 'HashJoin'" {
      style.stroke: "#4CAF50"
      style.stroke-dash: 4
    }
    base -> walker: "'HashJoin'" {
      style.stroke: "#4CAF50"
    }
  }

  group "Retrieve Details: PhysicalHashJoin" {
    walker -> base: "join->details()" {
      style.stroke: "#9C27B0"
    }
    base -> hashjoin: "vtable_lookup[0x02]" {
      style.stroke: "#FF9800"
      style.stroke-dash: 3
    }
    hashjoin -> base: "return {cond: 'u.id=o.uid'}" {
      style.stroke: "#9C27B0"
      style.stroke-dash: 4
    }
    base -> walker: "{'condition': 'u.id = o.user_id'}" {
      style.stroke: "#9C27B0"
    }
  }

  # --- Termination ---
  walker -> caller: "formatted indented tree (string)" {
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
}

# --------------------------------------------------------------------------------------------------
# METADATA & ANNOTATIONS
# --------------------------------------------------------------------------------------------------
hierarchy_note: |md
  ### Implementation Notes
  **PlanNode Hierarchy:** 
  `PlanNode (Abstract)` 
  - `LogicalScan` (Overrides `operator_type`, `details`)
  - `LogicalFilter` (Overrides `operator_type`, `details`)
  - `PhysicalHashJoin` (Overrides `operator_type`, `details`)
  
  **Dispatch Mechanism:**
  - Standard C++ VTable pointer jump.
  - O(1) runtime complexity for type identification.
| {
  near: bottom-left
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#FFFDE7"
  }
}

legend: {
  near: bottom-right
  
  virtual_dispatch: "→ Virtual Dispatch (Runtime Polymorphism)" {
    style.stroke: "#FF9800"
    style.stroke-dash: 3
  }
  type_call: "→ operator_type() Execution" {
    style.stroke: "#4CAF50"
  }
  details_call: "→ details() Execution" {
    style.stroke: "#9C27B0"
  }
  recursion: "→ Recursive Tree Traversal" {
    style.stroke: "#1976D2"
    style.stroke-dash: 2
  }
}