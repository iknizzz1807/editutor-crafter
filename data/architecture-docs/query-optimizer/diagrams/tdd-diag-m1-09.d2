direction: right
layout-engine: elk
title: {
  label: Histogram Selectivity Estimation Algorithm
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
subtitle: {
  label: "Query Optimizer M2: Cost Estimation & Selectivity"
  near: top-center
  shape: text
  style: {
    font-size: 14
    italic: true
  }
}
# Input State
input: {
  shape: oval
  label: "INPUT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nvalue: target constant\ncol_hist: ColumnHistogram\ntotal_rows: table cardinality"
  style.fill: "#E8F5E9"
}
# Step 1: Initialize
step1_init: {
  shape: rectangle
  label: "STEP 1: Initialize\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nrows_per_bucket в†ђ total_rows / num_buckets\nlow_val в†ђ col_hist.buckets[0].min_value\ni в†ђ 0"
  style.fill: "#E3F2FD"
}
step1_number: {
  shape: circle
  label: "1"
  style.fill: "#1976D2"
  style.font-color: white
}
step1_init -> step1_number: {style.opacity: 0}
# Step 2: Bucket Search Loop
step2_loop: {
  shape: rectangle
  label: "STEP 2: Iterate Buckets\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFOR i = 0 TO num_buckets - 1:\n  bucket в†ђ buckets[i]\n  IF value < bucket.min_value:\n    в†’ value below range\n  IF value <= bucket.max_value:\n    в†’ found containing bucket"
  style.fill: "#E3F2FD"
}
step2_number: {
  shape: circle
  label: "2"
  style.fill: "#1976D2"
  style.font-color: white
}
step2_loop -> step2_number: {style.opacity: 0}
# Decision: Below Range?
decision_below: {
  shape: diamond
  label: "value < bucket.min_value\nAND i == 0?"
  style.fill: "#FFF3E0"
}
# Decision: Above Range?
decision_above: {
  shape: diamond
  label: "i == num_buckets - 1\nAND value > bucket.max_value?"
  style.fill: "#FFF3E0"
}
# Decision: Found Bucket?
decision_found: {
  shape: diamond
  label: "value в‰¤ bucket.max_value\nAND value в‰Ґ bucket.min_value?"
  style.fill: "#FFF3E0"
}
# Out-of-range handling (low)
out_of_range_low: {
  shape: rectangle
  label: "STEP 3a: Below Histogram Range\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRETURN 0.0\n(selectivity = no rows match)"
  style.fill: "#FFEBEE"
}
# Out-of-range handling (high)
out_of_range_high: {
  shape: rectangle
  label: "STEP 3b: Above Histogram Range\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRETURN 0.0\n(selectivity = no rows match)"
  style.fill: "#FFEBEE"
}
# Step 3: Found Bucket
step3_found: {
  shape: rectangle
  label: "STEP 3: Bucket Located\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nfound_bucket в†ђ buckets[i]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nmin_value: found_bucket.min_value\nmax_value: found_bucket.max_value\ndistinct_count: found_bucket.distinct_count\nrow_count: found_bucket.row_count"
  style.fill: "#E8F5E9"
}
step3_number: {
  shape: circle
  label: "3"
  style.fill: "#388E3C"
  style.font-color: white
}
step3_found -> step3_number: {style.opacity: 0}
# Step 4: Compute Rows Per Value
step4_compute: {
  shape: rectangle
  label: "STEP 4: Compute Rows Per Value\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIF distinct_count > 0:\n  rows_per_value в†ђ row_count / distinct_count\nELSE:\n  rows_per_value в†ђ rows_per_bucket\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFormula:\nrows_per_value = bucket_rows / distinct_values"
  style.fill: "#E8F5E9"
}
step4_number: {
  shape: circle
  label: "4"
  style.fill: "#388E3C"
  style.font-color: white
}
step4_compute -> step4_number: {style.opacity: 0}
# Step 5: Calculate Selectivity
step5_selectivity: {
  shape: rectangle
  label: "STEP 5: Calculate Selectivity\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nselectivity в†ђ rows_per_value / total_rows\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFormula:\nselectivity = (bucket_rows / distinct_count) / total_rows"
  style.fill: "#E8F5E9"
}
step5_number: {
  shape: circle
  label: "5"
  style.fill: "#388E3C"
  style.font-color: white
}
step5_selectivity -> step5_number: {style.opacity: 0}
# Clamp decision
decision_clamp: {
  shape: diamond
  label: "selectivity > 1.0?"
  style.fill: "#FFF3E0"
}
# Clamp handling
step6_clamp: {
  shape: rectangle
  label: "STEP 6: Clamp to Valid Range\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nselectivity в†ђ MIN(selectivity, 1.0)\nselectivity в†ђ MAX(selectivity, 0.0)"
  style.fill: "#FCE4EC"
}
# Output State
output: {
  shape: oval
  label: "OUTPUT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nselectivity: float в€€ [0.0, 1.0]\n(fraction of rows matching\ncol = value predicate)"
  style.fill: "#C8E6C9"
}
# Edge case: Between buckets
between_buckets: {
  shape: rectangle
  label: "STEP 3c: Value Between Buckets\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nvalue > buckets[i-1].max_value\nAND value < buckets[i].min_value\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRETURN 0.0\n(gap in equi-depth histogram)"
  style.fill: "#FFEBEE"
}
# Main Flow
input -> step1_init: {label: "begin estimation"}
step1_init -> step2_loop: {label: "initialized"}
step2_loop -> decision_below: {label: "check bounds"}
decision_below -> out_of_range_low: {label: "YES"; style.stroke: "#D32F2F"}
decision_below -> decision_above: {label: "NO"; style.stroke: "#388E3C"}
decision_above -> out_of_range_high: {label: "YES"; style.stroke: "#D32F2F"}
decision_above -> decision_found: {label: "NO"; style.stroke: "#388E3C"}
decision_found -> step3_found: {label: "YES"; style.stroke: "#388E3C"}
decision_found -> between_buckets: {label: "NO (exhausted)"; style.stroke: "#F57C00"}
decision_found -> step2_loop: {label: "NO (continue loop)"; style.stroke: "#1976D2"; style.stroke-dash: 3}
step3_found -> step4_compute: {label: "bucket found"}
step4_compute -> step5_selectivity: {label: "rows_per_value computed"}
step5_selectivity -> decision_clamp: {label: "selectivity raw"}
decision_clamp -> step6_clamp: {label: "YES"; style.stroke: "#D32F2F"}
decision_clamp -> output: {label: "NO"; style.stroke: "#388E3C"}
step6_clamp -> output: {label: "clamped"}
out_of_range_low -> output: {label: "selectivity = 0.0"; style.stroke-dash: 3}
out_of_range_high -> output: {label: "selectivity = 0.0"; style.stroke-dash: 3}
between_buckets -> output: {label: "selectivity = 0.0"; style.stroke-dash: 3}
# Example Panel
example_panel: {
  label: "EXAMPLE CALCULATION"
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  scenario: {
    label: "Given:\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ntotal_rows = 10,000\nvalue = 42 (looking for rows where col = 42)\n\nHistogram buckets[3]:\nвЂў bucket[0]: min=0, max=30, rows=3333, distinct=15\nвЂў bucket[1]: min=31, max=60, rows=3333, distinct=12\nвЂў bucket[2]: min=61, max=100, rows=3334, distinct=20"
    shape: rectangle
    style.fill: "#FAFAFA"
  }
  execution: {
    label: "Execution:\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. i=0: 42 > bucket[0].max=30 в†’ continue\n2. i=1: 42 в€€ [31, 60] в†’ FOUND!\n3. rows_per_value = 3333 / 12 = 277.75\n4. selectivity = 277.75 / 10,000\n5. selectivity = 0.027775\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nResult: ~2.78% of rows match"
    shape: rectangle
    style.fill: "#FAFAFA"
  }
}
# Connect example to main flow
step5_selectivity -> example_panel: {style.opacity: 0}
# Pseudocode Panel
pseudocode_panel: {
  label: "PSEUDOCODE"
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  code: {
    label: "function selectivity_equality(value, col_hist, total_rows):\n    rows_per_bucket = total_rows / col_hist.num_buckets\n    \n    for i, bucket in enumerate(col_hist.buckets):\n        if value < bucket.min_value:\n            if i == 0: return 0.0  # below range\n            else: continue\n        \n        if value <= bucket.max_value:\n            # Found containing bucket\n            if bucket.distinct_count > 0:\n                rows_per_value = bucket.row_count / bucket.distinct_count\n            else:\n                rows_per_value = rows_per_bucket\n            \n            selectivity = rows_per_value / total_rows\n            return clamp(selectivity, 0.0, 1.0)\n        \n        # value > bucket.max_value, check next\n        if i == col_hist.num_buckets - 1:\n            return 0.0  # above range\n    \n    return 0.0  # between buckets (gap)"
    shape: code
    language: python
  }
}
# Legend
legend: {
  label: "LEGEND"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  oval_key: {shape: oval; label: "Terminal State"; style.fill: "#E8F5E9"}
  rect_key: {shape: rectangle; label: "Processing Step"; style.fill: "#E3F2FD"}
  diamond_key: {shape: diamond; label: "Decision Point"; style.fill: "#FFF3E0"}
  error_key: {shape: rectangle; label: "Error/Edge Case"; style.fill: "#FFEBEE"}
  oval_key -- rect_key -- diamond_key -- error_key: {style.opacity: 0}
}
# Group step numbers visually
step_numbers: {
  shape: rectangle
  label: "STEP SEQUENCE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nв‘  Initialize variables\nв‘Ў Iterate through buckets\nв‘ў Locate containing bucket\nв‘Ј Compute rows per value\nв‘¤ Calculate selectivity\nв‘Ґ Clamp to [0.0, 1.0]"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
}