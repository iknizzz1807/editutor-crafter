vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

direction: right

title: "StatisticsCatalog CRUD State Machine" {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# -----------------------------------------------------------------------------------------
# Initial state marker
# -----------------------------------------------------------------------------------------
initial: ● {
  style: {
    stroke: transparent
    fill: black
  }
}

# -----------------------------------------------------------------------------------------
# States with Invariants
# -----------------------------------------------------------------------------------------
Empty: {
  label: "Empty"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }
  invariant: |md
    **INVARIANT**
    `_tables[table] ∉ catalog`
  | {
    style: {
      font-size: 10
      italic: true
    }
  }
}

Populated: {
  label: "Populated"
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
  invariant: |md
    **INVARIANT**
    `stats ∈ _tables ∧ mod_count == 0`
  | {
    style: {
      font-size: 10
      italic: true
    }
  }
}

Updated: {
  label: "Updated"
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
  }
  invariant: |md
    **INVARIANT**
    `stats ∈ _tables ∧ mod_count ≥ 1`
  | {
    style: {
      font-size: 10
      italic: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# Concurrent Read Region (Shared RLock)
# -----------------------------------------------------------------------------------------
ConcurrentReads: {
  label: "Parallel Reading Context"
  style: {
    stroke: "#9C27B0"
    stroke-dash: 5
    fill: "#FDF7FF"
  }
  
  ReadLock: "Shared RLock Active" {
    shape: text
    style: {
      font-size: 10
      bold: true
    }
  }

  Reader1: "reader.get_table_stats()" {
    shape: diamond
    style.fill: "#F3E5F5"
  }
  Reader2: "reader.get_table_stats()" {
    shape: diamond
    style.fill: "#F3E5F5"
  }
  ReaderN: "reader.get_table_stats()" {
    shape: diamond
    style.fill: "#F3E5F5"
    style.multiple: true
  }
}

# -----------------------------------------------------------------------------------------
# Transitions: trigger + [guard] + /action
# -----------------------------------------------------------------------------------------

initial -> Empty: "initialize()" {
  style.stroke-width: 2
}

Empty -> Populated: "store_table_stats(stats)\n[nil ≠ stats]\n/_tables[table] ← stats\n/mod_count[table] ← 0" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 3
    font-size: 10
  }
}

Populated -> Updated: "store_table_stats(stats)\n[table ∈ _tables]\n/_tables[table] ← stats\n/mod_count[table]++" {
  style: {
    stroke: "#2196F3"
    stroke-width: 3
    font-size: 10
  }
}

Updated -> Updated: "store_table_stats(stats)\n[table ∈ _tables]\n/refresh stats\n/mod_count[table]++" {
  style: {
    stroke: "#FF9800"
    stroke-width: 3
    font-size: 10
  }
}

Populated -> Empty: "clear_table_stats(table)\n[table ∈ _tables]\n/del _tables[table]\n/del mod_count[table]" {
  style: {
    stroke: "#F44336"
    stroke-width: 3
    font-size: 10
  }
}

Updated -> Empty: "clear_table_stats(table)\n[table ∈ _tables]\n/del _tables[table]\n/del mod_count[table]" {
  style: {
    stroke: "#F44336"
    stroke-width: 3
    font-size: 10
  }
}

# -----------------------------------------------------------------------------------------
# Shared Read Transitions (Non-mutating)
# Corrected: Defined connections directly to avoid 'indexed edge does not exist' errors.
# -----------------------------------------------------------------------------------------

Populated <-> ConcurrentReads.Reader1: "non-blocking read" { 
  style.stroke-dash: 3
  style.stroke: "#9C27B0" 
}
Populated <-> ConcurrentReads.Reader2: "non-blocking read" { 
  style.stroke-dash: 3
  style.stroke: "#9C27B0" 
}
Populated <-> ConcurrentReads.ReaderN: "non-blocking read" { 
  style.stroke-dash: 3
  style.stroke: "#9C27B0" 
}

Updated <-> ConcurrentReads.Reader1: "non-blocking read" { 
  style.stroke-dash: 3
  style.stroke: "#9C27B0" 
}
Updated <-> ConcurrentReads.Reader2: "non-blocking read" { 
  style.stroke-dash: 3
  style.stroke: "#9C27B0" 
}
Updated <-> ConcurrentReads.ReaderN: "non-blocking read" { 
  style.stroke-dash: 3
  style.stroke: "#9C27B0" 
}

# -----------------------------------------------------------------------------------------
# Legend
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-width: 1
  }
  
  title: "Notation Guide" {
    shape: text
    style.bold: true
  }
  
  write: "Solid Line: Write Operation (Exclusive Lock)" {
    shape: text
    style.font-size: 10
  }
  
  read: "Dashed Purple: Read Operation (Shared Lock)" {
    shape: text
    style.font-size: 10
  }
  
  logic: "Logic: trigger [guard] / action" {
    shape: text
    style: {
      font-size: 10
      italic: true
    }
  }
}