direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 0
    pad: 20
  }
}

ANALYZE_SAMPLING_STRATEGY: {
  label: "ANALYZE Sampling Strategy Implementation"
  shape: rectangle
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
    font-color: "#E6EDF3"
    stroke-width: 4
  }

  STEP_1_START: {
    label: "1. Initialize Sampling"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#238636"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    config_box: {
      label: "AnalyzerConfig Parameters"
      shape: rectangle
      style.fill: "#21262D"
      style.stroke: "#30363D"
      
      sample_rate: {
        label: "sample_rate: 1.0 (default)\nrange: [0.0, 1.0]"
        shape: text
        style.font-color: "#7EE787"
        style.font: mono
      }
      max_sample: {
        label: "max_sample_rows: 100,000"
        shape: text
        style.font-color: "#7EE787"
        style.font: mono
      }
      min_rows: {
        label: "min_rows_for_histogram: 10"
        shape: text
        style.font-color: "#7EE787"
        style.font: mono
      }
    }
  }

  STEP_2_DECISION: {
    label: "2. Table Size Check"
    shape: diamond
    style: {
      fill: "#161B22"
      stroke: "#58A6FF"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    size_check: {
      label: "total_rows > max_sample_rows?"
      shape: text
      style.font-color: "#79C0FF"
      style.bold: true
    }
  }

  STEP_3A_SIMPLE: {
    label: "3A. Full Scan Path\n(Small Table Opt)"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#8957E5"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    full_scan_logic: {
      label: "Logic Execution:\n• Read 100% of rows\n• sample_rate effectively 1.0\n• Deterministic accuracy"
      shape: text
      style.font-color: "#A371F7"
    }
    scale_full: {
      label: "scale_factor = 1.0"
      shape: rectangle
      style: {
        fill: "#238636"
        font-color: "#FFFFFF"
        stroke: "#2EA043"
        bold: true
      }
    }
  }

  STEP_3B_RESERVOIR: {
    label: "3B. Reservoir Sampling Path\n(Large Table Scalability)"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#F78166"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    reservoir_box: {
      label: "O(N) Reservoir Algorithm"
      shape: rectangle
      style.fill: "#21262D"
      style.stroke: "#F78166"
      
      init: {
        label: "1. Initialize reservoir[0..k-1]\n   where k = max_sample_rows"
        shape: text
        style.font-color: "#FFA657"
      }
      fill_task: {
        label: "2. Fill reservoir with\n   first k rows directly"
        shape: text
        style.font-color: "#FFA657"
      }
      replace: {
        label: "3. For row i > k:\n   • Generate random j ∈ [0, i)\n   • If j < k: reservoir[j] = current_row"
        shape: text
        style.font-color: "#FFA657"
      }
      guarantee: {
        label: "✓ Mathematical guarantee:\n   Each row has equal P(selection)"
        shape: text
        style.font-color: "#7EE787"
        style.italic: true
      }
    }
  }

  STEP_4_SCALING: {
    label: "4. Compute Statistics Scaling"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#58A6FF"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    scale_formula: {
      label: "scale_factor = total_rows / count(sampled_rows)"
      shape: rectangle
      style: {
        fill: "#0D419D"
        stroke: "#58A6FF"
        font-color: "#FFFFFF"
        bold: true
        font: mono
      }
    }
    example: {
      label: "Scenario:\nTotal: 10M rows\nSample: 100K rows\nFactor: 100.0x"
      shape: text
      style.font-color: "#79C0FF"
    }
  }

  STEP_5_ESTIMATES: {
    label: "5. Extrapolate Global Estimates"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#238636"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    scaled_metrics: {
      label: "Final Computed Metrics"
      shape: rectangle
      style.fill: "#21262D"
      
      null_count: {
        label: "nulls = sample_nulls * scale_factor"
        shape: text
        style.font-color: "#7EE787"
      }
      distinct: {
        label: "NDV = sample_NDV * scale_factor"
        shape: text
        style.font-color: "#7EE787"
      }
      freq: {
        label: "MCV_freq = sample_freq * scale_factor"
        shape: text
        style.font-color: "#7EE787"
      }
      total_est: {
        label: "row_count = total_rows (Metadata)"
        shape: text
        style.font-color: "#79C0FF"
      }
    }
  }

  STEP_6_HISTOGRAM: {
    label: "6. Construct Histogram Data"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#8957E5"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    hist_check: {
      label: "Condition: sampled_rows >= min_rows?"
      shape: diamond
      style.fill: "#21262D"
      style.font-color: "#A371F7"
    }
    equi_depth: {
      label: "Generate Equi-Depth Boundaries\nfrom sampled distribution\n(Buckets normalized by scale_factor)"
      shape: rectangle
      style: {
        fill: "#238636"
        font-color: "#FFFFFF"
        stroke: "#2EA043"
      }
    }
  }

  STEP_7_STORE: {
    label: "7. Persist to Stats Catalog"
    shape: rectangle
    style: {
      fill: "#161B22"
      stroke: "#238636"
      stroke-width: 2
      font-color: "#E6EDF3"
    }
    catalog: {
      label: "Optimizer Statistics Store\n(Global Thread-Safe Map)"
      shape: cylinder
      style: {
        fill: "#238636"
        stroke: "#2EA043"
        font-color: "#FFFFFF"
      }
    }
    stored_data: {
      label: "Payload:\n• Column-level Cardinality\n• Equi-depth Buckets\n• Timestamp of Analysis"
      shape: text
      style.font-color: "#7EE787"
    }
  }

  # Workflow Connections
  STEP_1_START -> STEP_2_DECISION: "evaluate metadata" {
    style.stroke: "#8B949E"
  }
  
  STEP_2_DECISION -> STEP_3A_SIMPLE: "NO\n(Fits in Memory)" {
    style.stroke: "#8957E5"
    style.stroke-width: 3
  }
  
  STEP_2_DECISION -> STEP_3B_RESERVOIR: "YES\n(Exceeds limit)" {
    style.stroke: "#F78166"
    style.stroke-width: 3
  }
  
  STEP_3A_SIMPLE.scale_full -> STEP_4_SCALING: "exact data" {
    style.stroke: "#8957E5"
  }
  
  STEP_3B_RESERVOIR -> STEP_4_SCALING: "sampled set" {
    style.stroke: "#F78166"
    style.stroke-dash: 5
  }
  
  STEP_4_SCALING -> STEP_5_ESTIMATES: "apply scaling" {
    style.stroke: "#58A6FF"
    style.stroke-width: 3
  }
  
  STEP_5_ESTIMATES -> STEP_6_HISTOGRAM: "finalized metrics" {
    style.stroke: "#8B949E"
  }
  
  STEP_6_HISTOGRAM -> STEP_7_STORE: "commit stats" {
    style.stroke: "#238636"
    style.stroke-width: 3
  }
}

# Documentation Legend
# FIXED: 'near' set to constant 'bottom-right' for ELK compatibility
LEGEND: {
  label: "Flow Control Legend"
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    font-color: "#E6EDF3"
    border-radius: 8
  }
  
  full_scan: {
    label: "■ Purple: Full Table Path (Small)"
    shape: text
    style.font-color: "#8957E5"
  }
  reservoir: {
    label: "■ Orange: Reservoir Sampling (Large)"
    shape: text
    style.font-color: "#F78166"
  }
  scale: {
    label: "■ Blue: Transformation Logic"
    shape: text
    style.font-color: "#58A6FF"
  }
  store: {
    label: "■ Green: Terminal/Storage State"
    shape: text
    style.font-color: "#238636"
  }
}

# Explicit connection to container to indicate relationship
ANALYZE_SAMPLING_STRATEGY -> LEGEND: {
  style.stroke: "#30363D"
  style.stroke-dash: 4
}