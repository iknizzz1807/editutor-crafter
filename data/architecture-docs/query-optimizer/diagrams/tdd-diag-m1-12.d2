layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: {
  label: "Plan Tree Pretty-Printer Indentation Logic\nState Diagram (Algorithm TDD Spec)"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
  near: top-center
}

# --- SHAPE DEFINITIONS ---

# Initial State
START: {
  label: ""
  shape: circle
  style.fill: "#2E7D32" # Dark Green
  width: 30
  height: 30
}

# Entry State
Entry: {
  label: "1. Entry State\n------------------\nnode: PlanNode\nindent: int = 0\nprefix: string = \"\"\nlines: list = []"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
}

# Format Current Node
FormatNode: {
  label: "2. Format Current Node\n----------------------\ndetails = node.get_details()\ncost = node.get_cost_str()\nline = (\"  \" * indent) + prefix + node.op + details + cost"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
  }
}

# Check Children
CheckChildren: {
  label: "3. Has Children?\n----------------\nn = len(node.children)\nhas_children = n > 0"
  shape: diamond
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
}

# No Children - Return
NoChildren: {
  label: "4a. Terminal Node\n-----------------\nreturn [line]"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
  }
}

# Initialize Loop
InitLoop: {
  label: "4b. Initialize Iterator\n----------------------\ni = 0\nchildren = node.children\nlines.append(line)"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
  }
}

# Check Last Child
CheckLast: {
  label: "5. Iterator Guard\n-----------------\ni == (n - 1)?"
  shape: diamond
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
}

# Set Prefix - Last Child
SetPrefixLast: {
  label: "6a. Selection: LAST\n------------------\n**child_prefix = \"└── \"**\n**new_indent = indent + 1**"
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    font-color: "#C62828"
    bold: true
  }
}

# Set Prefix - Middle Child
SetPrefixMiddle: {
  label: "6b. Selection: MIDDLE\n--------------------\n**child_prefix = \"├── \"**\n**new_indent = indent + 1**"
  shape: rectangle
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    font-color: "#C62828"
    bold: true
  }
}

# Recursive Call
Recurse: {
  label: "7. Recurse(child_i)\n--------------------\nchild_lines = pretty_print(\n  node.children[i],\n  new_indent,\n  child_prefix\n)"
  shape: rectangle
  style: {
    fill: "#B3E5FC"
    stroke: "#0277BD"
    stroke-dash: 5
  }
}

# Accumulate Results
Accumulate: {
  label: "8. Update State\n----------------\nlines.extend(child_lines)\ni = i + 1"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
  }
}

# Check Loop Done
CheckLoopDone: {
  label: "9. Loop Done?\n-------------\ni >= n?"
  shape: diamond
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
}

# Return All Lines
ReturnAll: {
  label: "10. Finalize\n-------------\nreturn lines"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    double-border: true
  }
}

# END
END: {
  label: ""
  shape: circle
  style.fill: "#C62828" # Dark Red
  width: 30
  height: 30
}

# --- TRANSITIONS ---

START -> Entry: "call: explain_plan(root)"
Entry -> FormatNode: "init frame"
FormatNode -> CheckChildren: "buffer current line"

CheckChildren -> NoChildren: "n == 0" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}

CheckChildren -> InitLoop: "n > 0"
InitLoop -> CheckLast: "enter foreach"

CheckLast -> SetPrefixLast: "TRUE" {
  style: {
    stroke: "#C62828"
    stroke-width: 3
  }
}

CheckLast -> SetPrefixMiddle: "FALSE" {
  style: {
    stroke: "#1565C0"
  }
}

SetPrefixLast -> Recurse: "set └──"
SetPrefixMiddle -> Recurse: "set ├──"

Recurse -> Accumulate: "return sub-tree"
Accumulate -> CheckLoopDone: "i++"

CheckLoopDone -> CheckLast: "NO (i < n)" {
  style.stroke-dash: 3
}

CheckLoopDone -> ReturnAll: "YES (i == n)"

NoChildren -> END: "final leaf result"
ReturnAll -> END: "final tree result"

# --- ANNOTATIONS AND LEGEND ---

# Replaced 'near: object' with 'near: constant' to fix ELK compilation error
Example: |md
  ### Example Output Trace
  text
  Seq Scan (cost=0.00, rows=100)
  ├── Filter: id > 10
  │   └── Index Scan (cost=0.01, rows=50)
  └── Sort: name
      └── Seq Scan (cost=0.00, rows=100)
  
  **Logic Summary:**
  1. Root uses `prefix=""`.
  2. Non-last children get `├──`.
  3. Last children get `└──`.
  4. Indent increases by 1 each depth level.
| {
  shape: rectangle
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    border-radius: 8
  }
  near: bottom-right
}

Legend: |md
  ### Decision Logic & State
  *   **Green**: Terminal / Return States
  *   **Blue**: State Initialization
  *   **Orange**: String Construction Logic
  *   **Purple**: Control Flow / Decision
  *   **<span style="color:#C62828">Red</span>**: **Active Logic Selection (TDD Focus)**
  *   **Cyan**: Recursive Context Switch
| {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    font-size: 14
  }
  near: bottom-left
}

# --- STYLING GLOBS ---
(CheckLast -> SetPrefixLast)[0].style.font-color: "#C62828"
(CheckLast -> SetPrefixMiddle)[0].style.font-color: "#1565C0"
(CheckChildren -> NoChildren)[0].style.font-color: "#C62828"