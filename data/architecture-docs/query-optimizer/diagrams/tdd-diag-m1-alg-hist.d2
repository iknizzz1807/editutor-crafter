direction: down
layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# ALGORITHM: EQUI-DEPTH HISTOGRAM CONSTRUCTION
# GOAL: Divide N values into B buckets with ~N/B values each.

Step1: "1. Raw Data & Null Filtering" {
  style: {
    stroke-width: 2
  }
  input_buffer: {
    shape: sql_table
    label: "Input Buffer (V)"
    0: "45"
    1: "12"
    2: "NULL" {style.fill: gray}
    3: "89"
    4: "23"
    5: "56"
    6: "1"
    7: "99"
    8: "34"
  }
  
  action: "Filter NULLs\nCount N=8" {
    shape: text
    style.font-color: red
  }
}

Step2: "2. Sort & Index Alignment" {
  sorted_buffer: {
    shape: sql_table
    label: "Sorted Buffer (Cleaned)"
    index0: "1" {style.stroke: red; style.stroke-width: 4}
    index1: "12"
    index2: "23" {style.stroke: red; style.stroke-width: 4}
    index3: "34"
    index4: "45" {style.stroke: red; style.stroke-width: 4}
    index5: "56"
    index6: "89" {style.stroke: red; style.stroke-width: 4}
    index7: "99" {style.stroke: red; style.stroke-width: 4}
  }
  
  math: |md
    ### Parameters
    - **N** (Rows): 8
    - **B** (Buckets): 4
    - **Step** (N/B): 2.0
  |
}

Step3: "3. Boundary Selection Logic" {
  logic: {
    shape: sql_table
    header: "Calculation"
    i0: "i=0: index=0 * 2 = 0" 
    i1: "i=1: index=1 * 2 = 2"
    i2: "i=2: index=2 * 2 = 4"
    i3: "i=3: index=3 * 2 = 6"
    i_max: "i=max: index=N-1 = 7"
  }
  
  pointers: "Pointers to Sorted Buffer" {
    shape: text
    style.italic: true
  }
}

Step4: "4. Final Histogram Metadata" {
  boundaries: {
    shape: sql_table
    label: "EquiDepthHistogram.boundaries"
    b0: "**1**" {style.fill: "#ffdbdb"}
    b1: "**23**" {style.fill: "#ffdbdb"}
    b2: "**45**" {style.fill: "#ffdbdb"}
    b3: "**89**" {style.fill: "#ffdbdb"}
    b4: "**99**" {style.fill: "#ffdbdb"}
  }
  
  stats: {
    label: "ColumnStats"
    rows: "8"
    null_fraction: "0.11"
    ndv: "8"
  }
}

# Transitions
Step1.input_buffer -> Step2.sorted_buffer: "Sort Ascending"
Step2.sorted_buffer -> Step3.logic: "N=8, B=4"
Step3.logic -> Step4.boundaries: "Extract Values"

# Styling specific elements
Step2.sorted_buffer.index0.style.font-color: red
Step2.sorted_buffer.index2.style.font-color: red
Step2.sorted_buffer.index4.style.font-color: red
Step2.sorted_buffer.index6.style.font-color: red
Step2.sorted_buffer.index7.style.font-color: red

Step4.boundaries.b0.style.font-color: red
Step4.boundaries.b1.style.font-color: red
Step4.boundaries.b2.style.font-color: red
Step4.boundaries.b3.style.font-color: red
Step4.boundaries.b4.style.font-color: red

Step1.action.style.bold: true
Step3.pointers.style.bold: true