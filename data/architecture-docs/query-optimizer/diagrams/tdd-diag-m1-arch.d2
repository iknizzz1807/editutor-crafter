layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- CLASS DEFINITIONS & MEMORY LAYOUT ---

PlanNode: "PlanNode (Base Class)" {
  shape: class
  style: {
    stroke-width: 2
    fill: "#E4DBFE" # Purple Header (Instruction: Header=Purple)
    stroke: "#6C5CE7"
  }
  tooltip: "sizeof=64 bytes (one cache line)"

  # Memory layout representation using byte offsets
  # Colors mapped per instructions: Data=Blue, Padding=Gray
  "0x00: vptr": "void* (8B)" { style.font-color: "#0984e3" }
  "0x08: children": "std::vector<PlanNode*> (24B)" { style.font-color: "#0984e3" }
  "0x20: est_rows": "double (8B)" { style.font-color: "#0984e3" }
  "0x28: est_cost": "double (8B)" { style.font-color: "#0984e3" }
  "0x30: props": "std::unordered_map* (8B)" { style.font-color: "#0984e3" }
  "0x38: padding": "char[8] (8B)" { 
    style: {
      fill: "#DFE6E9" # Gray Padding
      font-color: "#636E72"
    }
  }

  # Method signatures
  "+node_name()": "std::string"
  "+pretty_print(int)": "void"
}

LogicalNode: "LogicalNode" {
  shape: class
  style: {
    stroke-width: 2
    fill: "#ACE1AF" # Green (Instruction: Free/Logic=Green)
    stroke: "#27AE60"
  }
  "+get_output_schema()": "Schema"
}

PhysicalNode: "PhysicalNode" {
  shape: class
  style: {
    stroke-width: 2
    fill: "#C7F1FF" # Blue (Instruction: Data/Physical=Blue)
    stroke: "#0984e3"
  }
  "+get_cost_model()": "CostModel"
  "+next()": "TupleBatch"
}

# --- LOGICAL OPERATORS ---

LogicalScan: {
  shape: class
  style.fill: "#ACE1AF"
  table_name: "std::string"
  "+get_metadata()": "TableMeta"
}

LogicalJoin: {
  shape: class
  style.fill: "#ACE1AF"
  left_keys: "vector<ColRef>"
  right_keys: "vector<ColRef>"
  "join_type": "enum JoinType"
}

LogicalFilter: {
  shape: class
  style.fill: "#ACE1AF"
  predicate: "Expr*"
}

LogicalProject: {
  shape: class
  style.fill: "#ACE1AF"
  expressions: "vector<Expr*>"
}

# --- PHYSICAL OPERATORS ---

PhysicalSeqScan: "PhysicalSeqScan" {
  shape: class
  style.fill: "#C7F1FF"
  "0x40: iter": "HeapIterator (16B)"
}

PhysicalIndexScan: "PhysicalIndexScan" {
  shape: class
  style.fill: "#C7F1FF"
  index_name: "string"
  "index_type": "B-TREE | HASH"
}

PhysicalHashJoin: "PhysicalHashJoin" {
  shape: class
  style.fill: "#C7F1FF"
  "0x40: hash_table": "unique_ptr<HashTable>"
}

# --- RELATIONSHIPS ---

# Inheritance (Solid line, hollow triangle)
LogicalNode -> PlanNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

PhysicalNode -> PlanNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

LogicalScan -> LogicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

LogicalJoin -> LogicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

LogicalFilter -> LogicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

LogicalProject -> LogicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

# Physical specializations
PhysicalSeqScan -> PhysicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

PhysicalIndexScan -> PhysicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

PhysicalHashJoin -> PhysicalNode: {
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
}

# Realization / Implementation cross-links (Dashed line, hollow triangle)
PhysicalSeqScan -> LogicalScan: {
  style.stroke-dash: 5
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
  label: "implements"
}

PhysicalIndexScan -> LogicalScan: {
  style.stroke-dash: 5
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
  label: "implements"
}

PhysicalHashJoin -> LogicalJoin: {
  style.stroke-dash: 5
  target-arrowhead: * {
    shape: triangle
    style.filled: false
  }
  label: "implements"
}

# Composition / Ownership (Filled Diamond)
PlanNode -> PlanNode: {
  label: "owns children"
  source-arrowhead: * {
    shape: diamond
    style.filled: true
  }
  style.stroke: orange
}

# --- DOCUMENTATION & LEGEND ---

legend: {
  near: bottom-right
  
  inheritance: {
    shape: text
    label: "──▷ Inheritance"
  }
  implementation: {
    shape: text
    label: "---▷ Implementation"
  }
  composition: {
    shape: text
    label: "◆── Ownership"
    style.font-color: orange
  }
}

# Fixed: near set to constant 'top-right' to comply with ELK engine constraints
ImplementationNote: |md
  ### M1: System Design Notes
  - **Memory Alignment**: All nodes start with `vptr` (8B) for polymorphism.
  - **Logical vs Physical**: Logical nodes define query intent; Physical nodes contain state (Iterators, Hash Tables).
  - **Cache Locality**: Base `PlanNode` struct is exactly 64B, aligning with x86 cache lines to prevent false sharing.
  - **Growth**: Subclasses extend from offset `0x40`.
| {
  near: top-right
  style: {
    font-size: 14
    stroke: "#6C5CE7"
    fill: "#F8F9FA"
  }
}