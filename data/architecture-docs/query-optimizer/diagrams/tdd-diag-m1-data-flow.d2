direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STYLES & CLASSES ---
classes: {
  header: {
    style: {
      fill: "#6f42c1" # Purple
      font-color: white
      bold: true
    }
  }
  data_field: {
    style: {
      fill: "#cfe2ff" # Blue
      stroke: "#0d6efd"
    }
  }
  process_node: {
    shape: hexagon
    style: {
      fill: "#f8f9fa"
      stroke: "#212529"
      stroke-width: 2
    }
  }
  storage: {
    shape: cylinder
    style: {
      fill: "#e2e3e5"
    }
  }
  pointer: {
    style: {
      stroke: "#fd7e14" # Orange
      stroke-width: 2
      animated: true
    }
  }
}

# --- DIAGRAM START ---

title: |md
  # ANALYZE Command Data Flow
  ## Query Optimizer Milestone 1: Statistics Collection Pipeline
| {near: top-center}

# 1. Raw Data Source (On-Disk/Memory)
raw_table: "Table: 'users' (Raw Data Block)" {
  shape: sql_table
  style.stroke-width: 2
  
  header: "PAGE_HEADER (Offset 0x00)" {class: header}
  
  row_0: "0x40: [ID: 1] [AGE: 25] [NULL: 0]" {class: data_field}
  row_1: "0x80: [ID: 2] [AGE: 42] [NULL: 0]" {class: data_field}
  padding: "0xC0: [PADDING_BYTES]" {style.fill: "#dee2e6"} # Gray
  
  footer: "PAGE_FOOTER (Size 8192B)" {class: header}
}

# 2. Reservoir Sampler (Statistical Sub-sampling)
sampler: "Reservoir Sampler\n(Chaudhuri's Algorithm)" {
  class: process_node
  tooltip: "Maintains a k-size sample by replacing elements with probability k/n"
}

# 3. Sample Buffer (In-Memory)
sample_buffer: "Sample Buffer [k=1000]" {
  grid-rows: 2
  style.fill: "#d1e7dd" # Green (Free/Intermediate)
  
  val_1: "Val: 42"
  val_2: "Val: 25"
  val_n: "..."
  
  annotation: "sizeof=8KB (L1 Cache Optimized)" {
    shape: text
    style.font-size: 10
  }
}

# 4. Sorter (Preprocessing for Histogram)
sorter: "Quicksort / Timsort" {
  class: process_node
}

# 5. Sorted Array (Prerequisite for Equi-Depth)
sorted_data: "Sorted Sample" {
  class: data_field
  style.fill: "#fff3cd" # Yellow/Orange tint
  label: "18, 22, 25, 25, 30, 42, 45, 60..."
}

# 6. Histogram Generator
hist_gen: "Equi-Depth Generator\n(B=100 Buckets)" {
  class: process_node
}

# 7. Metadata Catalog (Persistence)
catalog: "Metadata Catalog\n(catalog.json)" {
  class: storage
  content: |md
    json
    {
      "users.age": {
        "ndv": 85,
        "nulls": 0.02,
        "hist": [18, 25, 45, 60]
      }
    }
    
  |
}

# --- CONNECTIONS (DATA FLOW) ---

raw_table -> sampler: "Linear Scan / Sampling" {
  style: {
    stroke-width: 4
    stroke: "#6c757d"
  }
}

sampler -> sample_buffer: "k/i probability skip" {class: pointer}

sample_buffer -> sorter: "In-place sort"

sorter -> sorted_data: "N log N complexity"

sorted_data -> hist_gen: "Linear Boundary Pick" {
  label: "Pick at index i * (N/B)"
}

hist_gen -> catalog: "Serialize to JSON" {
  style.stroke-dash: 5
}

# Annotations for Engineers
legend: {
  near: bottom-right
  
  header_box: "Purple = Page/Node Header" {class: header}
  data_box: "Blue = Tuple/Field Data" {class: data_field}
  inter_box: "Green = Intermediate Buffer" {style.fill: "#d1e7dd"}
  ptr_line: "Orange = Memory Pointer/Movement" {class: pointer}
}

# Cache Line Visual Aid
raw_table.row_0 -- raw_table.row_1: {
  style.stroke-dash: 3
  label: "64B Cache Line Boundary"
}