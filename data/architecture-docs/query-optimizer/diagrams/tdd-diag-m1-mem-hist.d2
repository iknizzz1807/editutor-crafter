layout-engine: elk

vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
    pad: 20
  }
}

# EQUI-DEPTH HISTOGRAM MEMORY LAYOUT
# Technical Specification for Query Optimizer Statistics Engine

memory_layout: {
  # ---------------------------------------------------------------------------
  # COLUMN STATS OBJECT (L1 Cache Aligned Header)
  # ---------------------------------------------------------------------------
  column_stats: {
    label: "ColumnMetadata Object (Physical Layout)\nsizeof = 64 Bytes (L1 Cache Line)"
    
    header_00: "0x00 | Metadata Header (Magic + Version) | 8B" {
      style.fill: "#9b59b6" # Purple: Header
      style.font-color: white
    }
    
    row_count: "0x08 | total_rows (u64) | 8B" {
      style.fill: "#3498db" # Blue: Data
      style.font-color: white
    }
    
    ndv: "0x10 | ndv (u64) | 8B" {
      style.fill: "#3498db"
      style.font-color: white
    }
    
    null_frac: "0x18 | null_fraction (f64) | 8B" {
      style.fill: "#3498db"
      style.font-color: white
    }
    
    avg_width: "0x20 | avg_width (f64) | 8B" {
      style.fill: "#3498db"
      style.font-color: white
    }
    
    val_range: "0x28 | [min_val, max_val] (f64[2]) | 16B" {
      style.fill: "#3498db"
      style.font-color: white
    }
    
    hist_ptr: "0x38 | *histogram_ptr (u64 pointer) | 8B" {
      style.fill: "#e67e22" # Orange: Pointers
      style.font-color: white
    }
    
    padding: "0x3C | Alignment Padding (Reserved) | 4B" {
      style.fill: "#bdc3c7" # Gray: Padding
    }

    # Physical Sizing Specs
    header_00.width: 500; header_00.height: 40
    row_count.width: 500; row_count.height: 40
    ndv.width: 500; ndv.height: 40
    null_frac.width: 500; null_frac.height: 40
    avg_width.width: 500; avg_width.height: 40
    val_range.width: 500; val_range.height: 80
    hist_ptr.width: 500; hist_ptr.height: 40
    padding.width: 500; padding.height: 20
  }

  cache_line_boundary: "------------------- L1 CACHE LINE BOUNDARY (64B) -------------------" {
    shape: text
    style: {
      font-size: 16
      stroke-dash: 5
      bold: true
      font-color: "#7f8c8d"
    }
  }

  # ---------------------------------------------------------------------------
  # HISTOGRAM DATA OBJECT (Heap Allocated Buffer)
  # ---------------------------------------------------------------------------
  histogram_object: {
    label: "EquiDepthHistogram Buffer (Heap)\nsizeof = 16B + (8B * (bucket_count + 1))"
    
    hist_header: "0x00 | bucket_count (u32) | total_elements (u64) | 16B" {
      style.fill: "#9b59b6"
      style.font-color: white
    }
    
    boundary_0: "0x10 | boundary[0] (f64) - MIN VALUE | 8B" {
      style.fill: "#3498db"
      style.font-color: white
    }
    
    boundary_1: "0x18 | boundary[1] (f64) | 8B" {
      style.fill: "#3498db"
      style.font-color: white
    }
    
    boundary_dots: "..." {
      shape: text
      style.font-size: 24
    }
    
    boundary_n: "0x10 + (N*8) | boundary[N] (f64) - MAX VALUE | 8B" {
      style.fill: "#3498db"
      style.font-color: white
    }

    hist_header.width: 500; hist_header.height: 50
    boundary_0.width: 500; boundary_0.height: 40
    boundary_1.width: 500; boundary_1.height: 40
    boundary_n.width: 500; boundary_n.height: 40
  }

  # Pointer Connection Logic
  column_stats.hist_ptr -> histogram_object.hist_header: "0x38 -> HEAP_ADDR" {
    style: {
      stroke: "#e67e22"
      stroke-width: 4
      animated: true
    }
  }
}

# ---------------------------------------------------------------------------
# IMPLEMENTATION SPECIFICATION (Moved to Root Level to fix 'near' error)
# ---------------------------------------------------------------------------
implementation_notes: |md
  ### Memory Layout Specifications
  - **Alignment**: `ColumnMetadata` MUST be 64-byte aligned. Use `alignas(64)` in C++ or appropriate padding in Rust to prevent **False Sharing** with adjacent metadata during concurrent scans.
  - **Data Types**: All boundary values use IEEE 754 double-precision (`f64`).
  - **Pointer Semantics**: `hist_ptr` is an atomic pointer. Updates during `ANALYZE` use `std::atomic::exchange` to ensure thread-safe transition between old and new histogram buffers.
  - **Access Pattern**:
    1. Load `*histogram_ptr`.
    2. Perform binary search on `boundary_array` (O(log N)).
    3. Use `(val - boundary[i]) / (boundary[i+1] - boundary[i])` for selectivity estimation.
| {
  near: bottom-right
}

# ---------------------------------------------------------------------------
# GLOBAL STYLING & CONSTRAINTS
# ---------------------------------------------------------------------------
memory_layout.** {
  style: {
    font: mono
    font-size: 14
    border-radius: 0
  }
}

memory_layout.column_stats.style.stroke-width: 3
memory_layout.histogram_object.style.stroke-width: 3

# Legend for Byte-Level Mapping (At root level)
legend: {
  near: top-right
  header: "Header / Control" { 
    style.fill: "#9b59b6" 
    style.font-color: white
  }
  data: "Numeric Statistics" { 
    style.fill: "#3498db" 
    style.font-color: white
  }
  pointer: "Heap Reference" { 
    style.fill: "#e67e22" 
    style.font-color: white
  }
  padding: "Alignment Gap" { 
    style.fill: "#bdc3c7" 
    style.font-color: black
  }
}