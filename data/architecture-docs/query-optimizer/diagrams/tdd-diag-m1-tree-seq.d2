vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
  # Global Palette aligned with Intel-Manual Specification
  colors: {
    header_purple: "#553C9A"
    data_blue: "#2B6CB0"
    internal_orange: "#DD6B20"
    metadata_gray: "#4A5568"
    node_fill: "#F7FAFC"
    success_green: "#38A169"
  }
}

# PRETTY-PRINTER RECURSIVE TRAVERSAL
# Purpose: Generate indented Query Plan representation via post-order DFS.

pretty_printer: {
  shape: sequence_diagram
  style.stroke: "#2D3748"
  style.stroke-width: 2
  
  # --- PARTICIPANTS (Actors) ---
  
  Caller: External Developer {
    shape: person
    tooltip: "Initiator of recursive traversal"
    style.stroke: ${vars.colors.data_blue}
    style.fill: "#EBF8FF"
  }
  
  Project: LogicalProject {
    tooltip: "Root Node (depth=0) | Address: 0x7FFF1000 | sizeof=256B"
    style.fill: "#E4DBFE"
    style.stroke: ${vars.colors.header_purple}
  }
  
  Join: LogicalJoin {
    tooltip: "Intermediate Node (depth=1) | Address: 0x7FFF1200 | sizeof=512B"
    style.fill: "#E4DBFE"
    style.stroke: ${vars.colors.header_purple}
  }
  
  ScanA: LogicalScan {
    tooltip: "Leaf Node A (depth=2) | Address: 0x7FFF1400 | sizeof=128B"
    style.fill: "#E4DBFE"
    style.stroke: ${vars.colors.header_purple}
  }
  
  ScanB: LogicalScan {
    tooltip: "Leaf Node B (depth=2) | Address: 0x7FFF1600 | sizeof=128B"
    style.fill: "#E4DBFE"
    style.stroke: ${vars.colors.header_purple}
  }

  # --- ALGORITHM EXECUTION SEQUENCE ---

  # 1. ROOT ENTRY
  Caller -> Project.v1: "1. pretty_print(indent=0)" {
    style: {
      stroke: ${vars.colors.data_blue}
      stroke-width: 4
      bold: true
    }
  }

  # 1.1 LOCAL METADATA
  Project.v1 -> Project.v1: "1.1 Calc Header" {
    style.stroke: ${vars.colors.internal_orange}
  }
  Project.v1.note: "State: indent=0\nHeader: 'LogicalProject'"

  # 2. RECURSION STEP: JOIN
  Project.v1 -> Join.v1: "2. pretty_print(indent=1)" {
    style.stroke: ${vars.colors.metadata_gray}
    style.stroke-width: 2
  }

  Join.v1 -> Join.v1: "2.1 Calc Header" {
    style.stroke: ${vars.colors.internal_orange}
  }
  Join.v1.note: "State: indent=1\nHeader: '-> LogicalJoin'"

  # 3. RECURSION STEP: SCANA
  Join.v1 -> ScanA.v1: "3. pretty_print(indent=2)" {
    style.stroke: ${vars.colors.metadata_gray}
  }
  
  ScanA.v1 -> ScanA.v1: "3.1 Get Leaf Meta" {
    style.stroke: ${vars.colors.internal_orange}
  }
  
  Join.v1 <- ScanA.v1: "3.2 return '    -> LogicalScan (A)'" {
    style.stroke-dash: 5
    style.font-color: "#718096"
  }

  # 4. RECURSION STEP: SCANB
  Join.v1 -> ScanB.v1: "4. pretty_print(indent=2)" {
    style.stroke: ${vars.colors.metadata_gray}
  }
  
  ScanB.v1 -> ScanB.v1: "4.1 Get Leaf Meta" {
    style.stroke: ${vars.colors.internal_orange}
  }
  
  Join.v1 <- ScanB.v1: "4.2 return '    -> LogicalScan (B)'" {
    style.stroke-dash: 5
    style.font-color: "#718096"
  }

  # 5. BOTTOM-UP CONCATENATION
  Join.v1 -> Join.v1: "5. Concatenate(ScanA, ScanB)" {
    style.stroke: ${vars.colors.success_green}
    style.bold: true
  }
  Join.v1.note: "Action: StringBuilder.AppendAll()"

  # 6. RETURN SUBTREE TO ROOT
  Project.v1 <- Join.v1: "6. return JoinSubtreeString" {
    style: {
      stroke-dash: 5
      stroke: ${vars.colors.metadata_gray}
    }
  }

  # 7. FINAL CONCATENATION
  Project.v1 -> Project.v1: "7. Finalize(Project, JoinSubtree)" {
    style.stroke: ${vars.colors.success_green}
    style.bold: true
  }
  Project.v1.note: "Buffer: [ProjectHead][\n][JoinSubtree]"
  
  # 8. EXIT
  Caller <- Project.v1: "8. Final Plan String Result" {
    style: {
      stroke-dash: 5
      stroke: ${vars.colors.data_blue}
      stroke-width: 3
    }
  }
}

# --- DOCUMENTATION OVERLAY ---
# Fixed 'near' error by using constant position 'top-right' for ELK engine compatibility.
explanation: |md
  ### Implementation Technical Specification
  - **Memory Layout**: Each logical node contains `MetaData` (Header) and a list of `ChildNodes`.
  - **Indentation Logic**: `prefix = "  " * depth`.
  - **Concat Strategy**: Post-order traversal ensures child strings are fully realized before parent concatenation.
  - **Complexity**: 
    - **Time**: $O(N)$ where $N$ is the number of nodes in the tree.
    - **Space**: $O(H + S)$ where $H$ is stack depth and $S$ is result string size.
| {
  near: top-right
  style: {
    font-size: 14
    stroke: "#CBD5E0"
    fill: "#F7FAFC"
    border-radius: 8
  }
}

# --- METRICS & LEGEND ---
legend: {
  shape: sql_table
  near: bottom-right
  style.fill: "#F7FAFC"
  
  "Traversal Mode": "Post-Order Depth-First Search"
  "Indentation": "Recursive parameter: depth * 2"
  "Concurrency": "Thread-Unsafe (Local Recursion)"
  "Buffer Type": "java.lang.StringBuilder / go.strings.Builder" {constraint: "Avoid O(N^2) concat"}
  "Stack Safety": "Iterative approach required if H > 1024"
}

# --- GLOBAL STYLING RULES ---
***: {
  style: {
    stroke-width: 1
    font-size: 13
  }
}

(*** -> ***)[*]: {
  style: {
    font-size: 12
    font: mono
  }
}

# Lifeline Dash Styling
pretty_printer.** -> pretty_printer.**: {
  style.stroke-dash: 0
}