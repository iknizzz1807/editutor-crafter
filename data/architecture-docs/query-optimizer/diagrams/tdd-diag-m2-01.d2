direction: right
layout-engine: elk
theme-id: 4
title: Cost Model Components {
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Formula Section
formula_header: Cost Formula {
  shape: rectangle
  style.fill: "#E3F2FD"
}
total_cost: total_cost {
  shape: circle
  style.fill: "#1565C0"
  style.font-color: white
  style.bold: true
}
equals: "=" {
  shape: text
  style.font-size: 20
}
# IO Cost Branch
io_component: IO Component {
  shape: rectangle
  style.fill: "#FFF3E0"
  io_weight: io_weight {
    shape: rectangle
    style.fill: "#FFB74D"
  }
  weight_value: "1.0" {
    shape: text
    style.italic: true
    style.font-color: "#E65100"
  }
  io_weight_note: "(I/O ~100x slower)" {
    shape: text
    style.font-size: 10
    style.font-color: "#666"
  }
  mult_io: "×" {
    shape: text
    style.font-size: 18
  }
  io_cost: io_cost {
    shape: rectangle
    style.fill: "#FFB74D"
  }
}
io_result: io_weight × io_cost {
  shape: rectangle
  style.fill: "#FFE0B2"
  style.stroke-dash: 3
}
# CPU Cost Branch
cpu_component: CPU Component {
  shape: rectangle
  style.fill: "#E8F5E9"
  cpu_weight: cpu_weight {
    shape: rectangle
    style.fill: "#81C784"
  }
  cpu_weight_value: "0.01" {
    shape: text
    style.italic: true
    style.font-color: "#2E7D32"
  }
  mult_cpu: "×" {
    shape: text
    style.font-size: 18
  }
  cpu_cost: cpu_cost {
    shape: rectangle
    style.fill: "#81C784"
  }
}
cpu_result: cpu_weight × cpu_cost {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke-dash: 3
}
plus: "+" {
  shape: text
  style.font-size: 20
}
# Connections for formula
io_component -> io_result
cpu_component -> cpu_result
io_result -> plus
plus -> cpu_result -> total_cost
formula_header -> io_component
formula_header -> cpu_component
# Example Calculations Section
examples_header: Example Calculations {
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
# SeqScan Example
seqscan: SeqScan (Full Table) {
  shape: rectangle
  style.fill: "#FFEBEE"
  seqscan_title: "SELECT * FROM users WHERE age > 30" {
    shape: text
    style.italic: true
    style.font-size: 11
  }
  seqscan_params: Parameters {
    shape: rectangle
    style.fill: "#FFCDD2"
    seq_pages: pages: 500 {
      shape: text
    }
    seq_rows: rows: 50,000 {
      shape: text
    }
    seq_sel: selectivity: 1.0 {
      shape: text
    }
  }
  seqscan_io: io_cost = 500 {
    shape: rectangle
    style.fill: "#EF9A9A"
  }
  seqscan_cpu: cpu_cost = 500 {
    shape: rectangle
    style.fill: "#EF9A9A"
  }
  seqscan_calc: Calculation {
    shape: rectangle
    style.fill: "#E53935"
    style.font-color: white
    seq_formula: "(1.0 × 500) + (0.01 × 500)" {
      shape: text
      style.font-size: 11
    }
    seq_result: "= 505" {
      shape: text
      style.bold: true
    }
  }
}
# IndexScan Example
indexscan: IndexScan (Selective) {
  shape: rectangle
  style.fill: "#E3F2FD"
  indexscan_title: "SELECT * FROM users WHERE id = 42" {
    shape: text
    style.italic: true
    style.font-size: 11
  }
  indexscan_params: Parameters {
    shape: rectangle
    style.fill: "#BBDEFB"
    idx_pages: pages: 8 (random) {
      shape: text
    }
    idx_rows: rows: 1 {
      shape: text
    }
    idx_sel: selectivity: 0.00002 {
      shape: text
    }
  }
  indexscan_io: io_cost = 8 {
    shape: rectangle
    style.fill: "#90CAF9"
  }
  indexscan_cpu: cpu_cost = 1 {
    shape: rectangle
    style.fill: "#90CAF9"
  }
  indexscan_calc: Calculation {
    shape: rectangle
    style.fill: "#1976D2"
    style.font-color: white
    idx_formula: "(1.0 × 8) + (0.01 × 1)" {
      shape: text
      style.font-size: 11
    }
    idx_result: "= 8.01 ✓" {
      shape: text
      style.bold: true
    }
  }
}
# Threshold Note
threshold_note: Index Threshold ~15% Selectivity {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#FBC02D"
  style.stroke-dash: 4
  threshold_desc: "Below 15%: IndexScan cheaper\nAbove 15%: SeqScan cheaper" {
    shape: text
    style.font-size: 10
  }
}
# Cost Comparison
comparison: Cost Comparison {
  shape: rectangle
  style.fill: "#ECEFF1"
  seq_cost: "SeqScan: 505" {
    shape: text
    style.font-color: "#C62828"
  }
  idx_cost: "IndexScan: 8.01" {
    shape: text
    style.font-color: "#2E7D32"
    style.bold: true
  }
  winner: "→ IndexScan wins by 63x" {
    shape: text
    style.bold: true
    style.font-size: 12
  }
}
# Example Connections
examples_header -> seqscan
examples_header -> indexscan
seqscan -> seqscan_params -> seqscan_io -> seqscan_calc
seqscan -> seqscan_cpu -> seqscan_calc
indexscan -> indexscan_params -> indexscan_io -> indexscan_calc
indexscan -> indexscan_cpu -> indexscan_calc
seqscan_calc -> comparison
indexscan_calc -> comparison
comparison -> threshold_note