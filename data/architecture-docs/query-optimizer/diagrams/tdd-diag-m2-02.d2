direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

title: {
  label: "SeqScan vs IndexScan Cost Crossover"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

axes: {
  shape: rectangle
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
    double-border: true
  }
  y_axis: {
    shape: rectangle
    width: 400
    height: 400
    style: {
      fill: "#0D1117"
      stroke: "#30363D"
      double-border: true
    }
    label: ""
  }
}

graph_container: {
  shape: rectangle
  width: 700
  height: 500
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
    double-border: true
  }
  y_label: {
    label: "COST\n│"
    shape: text
    style: {
      font-size: 14
      font-color: "#8B949E"
    }
  }
  x_axis_line: {
    label: "─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────►\n                                                          SELECTIVITY (0 → 1)"
    shape: text
    style: {
      font-size: 12
      font-color: "#8B949E"
    }
  }
  cost_markers: {
    shape: text
    label: |
      100 │
          │
       75 │
          │
       50 │
          │
       25 │
          │
        0 └
    |
    style: {
      font-size: 10
      font-color: "#8B949E"
      font: mono
    }
  }
}

legend: {
  shape: rectangle
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    double-border: true
  }
  legend_title: {
    label: "Legend"
    shape: text
    style: {
      font-size: 14
      bold: true
      font-color: "#C9D1D9"
    }
  }
  seqscan_line: {
    label: "─── SeqScan Cost (constant)"
    shape: text
    style: {
      font-color: "#F97583"
      font-size: 12
    }
  }
  indexscan_line: {
    label: "─── IndexScan Cost (varies)"
    shape: text
    style: {
      font-color: "#79C0FF"
      font-size: 12
    }
  }
  threshold_marker: {
    label: "★ Crossover Threshold (≈15%)"
    shape: text
    style: {
      font-color: "#FFA657"
      font-size: 12
    }
  }
}

seqscan_curve: {
  shape: rectangle
  style: {
    fill: "transparent"
    stroke: "transparent"
  }
  label: |
    ┌─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐
    │                                                                                                                                     │
    │   ████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████  │
    │   ████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████  │
    │   ████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████  │
    │   ████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████  │
    │                                                                                                                                     │
    └─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘
  |
  style: {
    font: mono
    font-size: 8
    font-color: "#F97583"
  }
}

indexscan_curve: {
  shape: rectangle
  style: {
    fill: "transparent"
    stroke: "transparent"
  }
  label: |
    ┌─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┐
    │   ▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄                                                                                                              │
    │   ██████████████████████████████████▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄                                                                          │
    │   ██████████████████████████████████████████████████████████████▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄                                          │
    │   ████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████████  │
    │                                                                                                                                     │
    └─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────┘
  |
  style: {
    font: mono
    font-size: 8
    font-color: "#79C0FF"
  }
}

crossover_zone: {
  shape: circle
  style: {
    fill: "#FFA657"
    stroke: "#FFA657"
    shadow: true
  }
  crossover_point: {
    label: "★\nCrossover\n≈15%"
    shape: text
    style: {
      font-color: "#FFA657"
      bold: true
      font-size: 11
    }
  }
}

formula_box: {
  shape: rectangle
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    double-border: true
  }
  title: {
    label: "Cost Formulas"
    shape: text
    style: {
      font-size: 14
      bold: true
      font-color: "#C9D1D9"
    }
  }
  seqscan_formula: {
    label: "SeqScan Cost = page_count × io_weight + row_count × cpu_weight\n(Constant: reads all pages regardless of selectivity)"
    shape: text
    style: {
      font-color: "#F97583"
      font-size: 11
    }
  }
  indexscan_formula: {
    label: "IndexScan Cost = matching_pages × io_weight + matching_rows × cpu_weight + index_lookup\n(Variable: decreases as selectivity decreases)"
    shape: text
    style: {
      font-color: "#79C0FF"
      font-size: 11
    }
  }
}

decision_zones: {
  shape: rectangle
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    double-border: true
  }
  title: {
    label: "Optimizer Decision Zones"
    shape: text
    style: {
      font-size: 14
      bold: true
      font-color: "#C9D1D9"
    }
  }
  indexscan_zone: {
    label: "◄── LOW SELECTIVITY (< 15%)\n    IndexScan is CHEAPER\n    Use index for few matching rows"
    shape: text
    style: {
      font-color: "#79C0FF"
      font-size: 11
    }
  }
  seqscan_zone: {
    label: "HIGH SELECTIVITY (> 15%) ──►\nSeqScan is CHEAPER\nRead all pages directly"
    shape: text
    style: {
      font-color: "#F97583"
      font-size: 11
    }
  }
}

binary_search_note: {
  shape: rectangle
  style: {
    fill: "#161B22"
    stroke: "#30363D"
    double-border: true
  }
  label: |
    Binary Search for Exact Threshold

    find_threshold():
      lo = 0.0, hi = 1.0
      while (hi - lo > epsilon):
        mid = (lo + hi) / 2
        if cost(SeqScan, mid) > cost(IndexScan, mid):
          lo = mid  # IndexScan cheaper
        else:
          hi = mid  # SeqScan cheaper
      return mid  # Crossover point
  |
  style: {
    font-color: "#8B949E"
    font-size: 10
    font: mono
  }
}

key_insight: {
  shape: rectangle
  style: {
    fill: "#238636"
    stroke: "#238636"
    double-border: true
  }
  label: "💡 KEY INSIGHT: The crossover threshold is NOT fixed at 15%.\nIt varies based on: index depth, page clustering, I/O vs CPU costs.\nThe optimizer must compute this dynamically per query."
  style: {
    font-color: "#FFFFFF"
    font-size: 11
    bold: true
  }
}

axes -- graph_container: {
  style: {
    stroke: "transparent"
  }
}
graph_container -- legend: {
  style: {
    stroke: "transparent"
  }
}
legend -- formula_box: {
  style: {
    stroke: "transparent"
  }
}
formula_box -- decision_zones: {
  style: {
    stroke: "transparent"
  }
}
decision_zones -- binary_search_note: {
  style: {
    stroke: "transparent"
  }
}
binary_search_note -- key_insight: {
  style: {
    stroke: "transparent"
  }
}