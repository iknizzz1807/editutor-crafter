layout-engine: elk
direction: right

vars: {
  d2-config: {
    theme-id: 200
    pad: 40
  }
  # Technical Design Palette - Intel Manual Style
  colors: {
    step_current: "#0071C5" # Intel Blue
    step_done: "#107C10"
    step_pending: "#505050"
    highlight: "#C8102E" # Alert Red
    data_struct: "#F3F3F3"
    decision: "#FFD400"
    code_bg: "#00171F"
    code_text: "#00AEEF"
    padding: "#E5E5E5"
  }
}

classes: {
  step: {
    shape: rectangle
    style: {
      stroke-width: 3
      border-radius: 0
      font-size: 14
      bold: true
    }
  }
  code_box: {
    shape: code
    style: {
      fill: ${colors.code_bg}
      font-color: ${colors.code_text}
      stroke: ${colors.step_current}
      stroke-width: 1
      font: mono
    }
  }
  data_container: {
    style: {
      fill: ${colors.data_struct}
      stroke: "#000000"
      stroke-width: 2
    }
  }
}

title: {
  label: "HISTOGRAM SELECTIVITY LOOKUP ALGORITHM\nKernel-Level Specification v1.0.4"
  shape: text
  style.font-size: 32
  style.bold: true
}

# --- STEP 1: INPUT ACQUISITION ---
step_1: {
  class: step
  label: "STEP 01: LATCH INPUT"
  style.fill: ${colors.step_current}
  style.font-color: white
}

input_reg: {
  class: data_container
  label: "Register: %eax"
  val: "42" {
    style.font-color: ${colors.highlight}
    style.bold: true
  }
}

input_code: |python
  # Target Value: 42
  target_value = reg.eax 
| {
  class: code_box
}

# --- STEP 2: BINARY SEARCH LOGIC ---
step_2: {
  class: step
  label: "STEP 02: BINARY SEARCH (O(log N))"
  style.fill: ${colors.step_pending}
}

buckets_visual: {
  class: data_container
  label: "Histogram Memory Map (Physical Layout)"
  
  b0: "OFFSET 0x00\n[0, 25]" { style.fill: ${colors.padding} }
  b1: "OFFSET 0x40\n[26, 50]" { 
    label: "**SELECTED: [26, 50]**"
    style: {
      fill: ${colors.decision}
      stroke: ${colors.highlight}
      stroke-width: 4
      bold: true
    }
  }
  b2: "OFFSET 0x80\n[51, 75]" { style.fill: ${colors.padding} }
  b3: "OFFSET 0xC0\n[76, 100]" { style.fill: ${colors.padding} }
  
  b0 -- b1 -- b2 -- b3: { style.stroke-dash: 3 }
}

search_code: |python
  def find_bucket(v, buckets):
    low, high = 0, 3
    while low <= high:
      mid = (low + high) >> 1
      curr = buckets[mid]
      if curr.min <= v <= curr.max:
        return mid # Index 1 matched
| {
  class: code_box
}

# --- STEP 3: BOUNDS VERIFICATION ---
step_3: {
  label: "STEP 03: VALIDATE\nRANGE MATCH?"
  shape: diamond
  style: {
    fill: ${colors.decision}
    stroke: "#000000"
    bold: true
  }
}

bounds_check: |python
  # Logical Verification
  if not (26 <= 42 <= 50):
     return ERR_OUT_OF_BOUNDS
  # Status: PASS
| {
  class: code_box
}

branch_found: {
  label: "PASS: LATCH METADATA"
  class: step
  style.fill: ${colors.step_done}
  style.font-color: white
}

branch_fail: {
  label: "FAIL: EXCEPTION"
  class: step
  style.fill: ${colors.highlight}
  style.font-color: white
}

# --- STEP 4: DENSITY DERIVATION ---
step_4: {
  class: step
  label: "STEP 04: CALCULATE DENSITY"
  style.fill: ${colors.step_pending}
}

bucket_metadata: {
  class: data_container
  label: "Bucket_1 Descriptor"
  row_count: "rows: 1000"
  ndv: "ndv: 25"
  range: "range: 24"
}

compute_logic: |python
  # Assuming uniform distribution
  # Density = row_count / distinct_values
  density = 1000 / 25
  return 40.0 # Rows per unique value
| {
  class: code_box
  style.stroke: ${colors.highlight}
  style.stroke-width: 2
}

# --- STEP 5: NORMALIZATION ---
step_5: {
  class: step
  label: "STEP 05: SCALE TO GLOBAL"
  style.fill: ${colors.step_done}
  style.font-color: white
}

global_stats: {
  class: data_container
  label: "Global Table Statistics"
  total_rows: "T_ROWS = 4000"
}

final_formula: |python
  # Selectivity = density / total_rows
  sel = 40.0 / 4000.0
  # Result = 0.01 (1%)
| {
  class: code_box
  style.stroke: ${colors.step_done}
  style.stroke-width: 3
}

output_result: "RETURN: 0.01" {
  shape: oval
  style: {
    fill: ${colors.step_done}
    font-color: white
    bold: true
    font-size: 20
    double-border: true
  }
}

# --- FLOW CONNECTIONS ---

step_1 -> input_reg
input_reg -> input_code
input_code -> step_2: "value latched" {style.stroke-width: 2}

step_2 -> buckets_visual
step_2 -> search_code
search_code -> step_3: "index=1" {style.stroke-width: 2}

step_3 -> bounds_check
bounds_check -> branch_found: "TRUE" {
  style.stroke: ${colors.step_done}
  style.stroke-width: 3
}
bounds_check -> branch_fail: "FALSE" {
  style.stroke: ${colors.highlight}
  style.stroke-dash: 5
}

branch_found -> step_4: "load metadata"

step_4 -> bucket_metadata
step_4 -> compute_logic
compute_logic -> step_5: "DENSITY=40.0" {style.stroke-width: 2}

step_5 -> global_stats
step_5 -> final_formula
final_formula -> output_result: "0.01" {
  style.stroke: ${colors.step_done}
  style.stroke-width: 4
}

# --- DOCUMENTATION & LEGEND ---

legend: {
  label: "Execution Legend"
  near: bottom-right
  
  l1: "Current Step" { style.fill: ${colors.step_current}; style.font-color: white }
  l2: "Success" { style.fill: ${colors.step_done}; style.font-color: white }
  l3: "Constraint Check" { shape: diamond; style.fill: ${colors.decision} }
  l4: "Memory Segment" { style.fill: ${colors.padding} }
  
  l1 -> l2 -> l3 -> l4: {style.stroke-width: 0}
}

summary: |md
  ### HistSelect(V) Architecture
  **Complexity**: $O(\log_{2} B)$ where $B$ is bucket count.
  **Registers**:
  - `%eax`: Search Key
  - `%ebx`: Bucket Pointer
  - `%xmm0`: Density Result (FP)
| {
  near: top-right
  style: {
    fill: ${colors.code_bg}
    font-color: white
    stroke: ${colors.step_current}
  }
}