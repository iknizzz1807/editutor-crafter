direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: {
  label: "Range Predicate Bucket Interpolation: Selectivity Estimation"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------
# INPUT STATE
# -----------------------------------------------------------------------------
input_context: "STATE 0: Query & Metadata" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2

  predicate: {
    shape: rectangle
    label: "Predicate: col_val > 45"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      bold: true
    }
  }

  bucket_metadata: {
    shape: sql_table
    label: "Histogram Bucket [i]"
    lower_bound: 20
    upper_bound: 80
    frequency: 1000
    distinct_values: 12
    style.fill: "#E8EAF6"
  }
}

# -----------------------------------------------------------------------------
# VISUAL EXECUTION BLOCK
# -----------------------------------------------------------------------------
execution: "ALGORITHM STEPS: Linear Interpolation" {
  
  step1: "1. RANGE CALCULATION" {
    shape: rectangle
    style.fill: "#E8F5E9"
    formula: |md
      **Range ($R$):**
      $R = Upper - Lower$
      $R = 80 - 20 = 60$
    |
  }

  step2: "2. DISTANCE TO BOUNDARY" {
    shape: rectangle
    style.fill: "#E8F5E9"
    # For '>' we measure distance from value to Upper Bound
    formula: |md
      **Distance ($D$):**
      $D = Upper - Predicate$
      $D = 80 - 45 = 35$
    |
  }

  step3: "3. INTERPOLATION FRACTION" {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 4
    }
    formula: |md
      **Fraction ($F$):**
      $F = D / R$
      $F = 35 / 60 \approx 0.5833$
    |
  }

  step4: "4. ESTIMATED CARDINALITY" {
    shape: rectangle
    style.fill: "#FFF9C4"
    formula: |md
      **Rows ($N$):**
      $N = F \times Frequency$
      $N = 0.5833 \times 1000 \approx 583$
    |
  }

  step1 -> step2 -> step3 -> step4
}

# -----------------------------------------------------------------------------
# MEMORY/LOGICAL LAYOUT VIZ
# -----------------------------------------------------------------------------
bucket_viz: "BUCKET BITMAP REPRESENTATION" {
  width: 600
  style.fill: "#FAFAFA"
  
  # The physical span of the bucket in the histogram
  physical_span: {
    grid-columns: 60
    grid-gap: 0
    
    # Range 20 to 45 (25 units) - Unmatched
    unmatched: "" {
      width: 250
      height: 60
      label: "Excluded (Value ≤ 45)"
      style: {
        fill: "#EEEEEE"
        stroke: "#9E9E9E"
        fill-pattern: lines
      }
    }

    # The marker for the predicate value
    # Fixed: 'triangle' is often only valid for arrowheads in certain D2 parsers.
    # Using 'diamond' as a marker shape.
    predicate_marker: "X=45" {
      shape: diamond
      width: 40
      height: 40
      style.fill: "#D32F2F"
      style.font-color: white
      style.bold: true
    }

    # Range 45 to 80 (35 units) - Matched
    matched: "" {
      width: 350
      height: 60
      label: "Selected (Value > 45)"
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
        stroke-width: 3
      }
    }
  }

  labels: {
    shape: text
    label: "20 [Lower]                                           45 [Pred]                                           80 [Upper]"
    style.font-size: 14
    style.font: mono
  }
}

# -----------------------------------------------------------------------------
# FINAL OUTPUT
# -----------------------------------------------------------------------------
result_summary: "FINAL ESTIMATE" {
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#E1BEE7"
    stroke: "#4A148C"
    stroke-width: 5
    shadow: true
  }
  
  stat: |md
    ### Selectivity Result
    - **Fraction:** 58.33%
    - **Rows:** 583
    - **Assumptions:** Continuous Uniform Distribution
  |
}

# -----------------------------------------------------------------------------
# LEGEND & NOTES
# -----------------------------------------------------------------------------
legend: {
  near: bottom-left
  header: "Legend" { shape: text; style.bold: true }
  
  color_data: "Data/Matched" { style.fill: "#BBDEFB" }
  color_padding: "Padding/Excluded" { style.fill: "#EEEEEE" }
  color_calc: "Process Logic" { style.fill: "#E8F5E9" }
}

algorithm_note: {
  shape: rectangle
  near: top-right
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-dash: 5
  }
  label: |md
    **Linear Interpolation Rule**
    If operator is **>** :
    $Selectivity = \frac{High - Value}{High - Low}$

    If operator is **<** :
    $Selectivity = \frac{Value - Low}{High - Low}$
  |
}

# -----------------------------------------------------------------------------
# CONNECTIONS
# -----------------------------------------------------------------------------
input_context -> execution: "Execute Estimate"
execution -> result_summary: "Return Rows"
input_context -> bucket_viz: "Map to physical bounds" {
  style.stroke-dash: 3
}

# Link the marker to the visual breakdown
bucket_viz.physical_span.predicate_marker -> execution.step2: "Value Binding" {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
}