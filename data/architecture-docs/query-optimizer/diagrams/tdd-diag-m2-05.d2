direction: right
layout-engine: elk
theme-id: 300
# Classes
classes: {
  predicate_box: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 8
    }
  }
  result_box: {
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 3
      border-radius: 8
    }
  }
  warning_box: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
      border-radius: 8
      stroke-dash: 4
    }
  }
  formula_box: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      border-radius: 4
    }
  }
  operator: {
    shape: circle
    style: {
      fill: "#1976D2"
      font-color: white
      stroke: "#0D47A1"
      stroke-width: 2
      bold: true
    }
  }
}
# Title
title: {
  label: "AND Predicate Selectivity Combination\nIndependence Assumption"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
    font-color: "#1565C0"
  }
}
# Input Predicates
predicate_a: {
  class: predicate_box
  label: "Predicate A\n─────────────\nColumn: age > 30\nSelectivity: 0.35\nP(A) = 35%"
}
predicate_b: {
  class: predicate_box
  label: "Predicate B\n─────────────\nColumn: status = 'active'\nSelectivity: 0.20\nP(B) = 20%"
}
# Multiplication Operator
multiply_op: {
  class: operator
  label: "×"
}
# Independence Assumption Container
independence_container: {
  label: "Independence Assumption"
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-width: 1
    border-radius: 12
  }
  assumption_text: {
    label: "Events A and B are statistically\nindependent → no correlation"
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#616161"
    }
  }
  formula: {
    class: formula_box
    label: "P(A ∧ B) = P(A) × P(B)"
    style: {
      font-size: 18
      bold: true
    }
  }
  calculation: {
    label: "= 0.35 × 0.20\n= 0.07 (7%)"
    shape: text
    style: {
      font-size: 16
      font-color: "#388E3C"
      bold: true
    }
  }
}
# Combined Result
combined_result: {
  class: result_box
  label: "Combined Selectivity\n─────────────────────\nResult: 7%\nRows filtered: 93%\n✓ Valid under independence"
}
# Warning Container
warning_container: {
  class: warning_box
  label: "⚠️ CORRELATION WARNING"
  warning_icon: {
    shape: diamond
    label: "!"
    style: {
      fill: "#FF9800"
      font-color: white
      bold: true
    }
  }
  warning_text: {
    label: "Independence assumption FAILS when:\n\n• age ↔ income (correlated)\n• city ↔ zipcode (functional dep)\n• category ↔ subcategory (hierarchy)\n\nIn these cases, actual selectivity\ncan be MUCH different!"
    shape: text
    style: {
      font-size: 12
      font-color: "#E65100"
    }
  }
  example_bad: {
    label: "Example: Correlated\nage > 30 AND income > 50K\n─────────────────────────\nActual P: ~25% (not 7%)\nIndependence UNDERESTIMATES"
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
      border-radius: 6
      font-size: 11
    }
  }
}
# Flow Connections
predicate_a -> multiply_op: {
  label: "P(A)"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
predicate_b -> multiply_op: {
  label: "P(B)"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
multiply_op -> independence_container.formula: {
  label: "combine"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
  }
}
independence_container.formula -> independence_container.calculation -> combined_result: {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
  }
}
# Warning connection
independence_container -> warning_container: {
  label: " assumption\n validity"
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    stroke-dash: 4
  }
}
# Legend
legend: {
  label: "Legend"
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  legend_independent: {
    label: "□ Blue = Input predicates"
    shape: text
  }
  legend_result: {
    label: "□ Green = Valid result"
    shape: text
  }
  legend_warning: {
    label: "□ Orange dashed = Warning zone"
    shape: text
  }
}
# Implementation note
impl_note: {
  label: "Implementation: SelectivityEstimator.combine_predicates(preds, 'AND')"
  shape: text
  style: {
    font-size: 11
    italic: true
    font-color: "#757575"
  }
}