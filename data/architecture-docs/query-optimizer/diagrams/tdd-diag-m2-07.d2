direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header_purple: "#512DA8"
    data_blue: "#1976D2"
    step_orange: "#F57C00"
    formula_green: "#388E3C"
    logic_red: "#D32F2F"
    padding_gray: "#9E9E9E"
    table_bg_a: "#E3F2FD"
    table_bg_b: "#E8F5E9"
  }
}

title: {
  label: "JOIN CARDINALITY FORMULA DERIVATION\n(Equijoin Uniform Distribution Model)"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# --- SECTION 1: INPUT DATASETS ---
section_inputs: {
  label: "I. Input Source Analysis"
  style: {
    stroke-width: 2
    stroke: "#333333"
    fill: "#F5F5F5"
  }
  
  table_A: {
    label: |'md
### Table A (LHS)
| offset | id (PK) | join_col | data |
|:---|:---|:---|:---|
| 0x00 | 1 | **100** | "row1" |
| 0x10 | 2 | **100** | "row2" |
| 0x20 | 3 | **200** | "row3" |
| 0x30 | 4 | **200** | "row4" |
| 0x40 | 5 | **200** | "row5" |
| 0x50 | 6 | **300** | "row6" |
| **TOTAL** | **N_a=6** | **D_a=3** | |
    '|
    style.fill: ${colors.table_bg_a}
    style.stroke: ${colors.data_blue}
  }

  table_B: {
    label: |'md
### Table B (RHS)
| offset | id (PK) | join_col | value |
|:---|:---|:---|:---|
| 0x00 | 1 | **100** | "val1" |
| 0x08 | 2 | **100** | "val2" |
| 0x10 | 3 | **200** | "val3" |
| 0x18 | 4 | **300** | "val4" |
| **TOTAL** | **N_b=4** | **D_b=3** | |
    '|
    style.fill: ${colors.table_bg_b}
    style.stroke: ${colors.formula_green}
  }

  stats_A: {
    label: |'md
**Table A Metadata (Stats)**
- Rows (N_a): 6
- Distinct (D_a): 3
- Density: 2.0 (N_a/D_a)
    '|
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: ${colors.data_blue}
    style.stroke-width: 2
  }

  stats_B: {
    label: |'md
**Table B Metadata (Stats)**
- Rows (N_b): 4
- Distinct (D_b): 3
- Density: 1.33 (N_b/D_b)
    '|
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: ${colors.formula_green}
    style.stroke-width: 2
  }
}

# --- SECTION 2: THE DERIVATION PATHWAY ---
section_derivation: {
  label: "II. Mathematical Derivation Steps"
  style.fill: "#FFFFFF"
  
  step1: "01. CROSS PRODUCT BOUND" {
    label: "1. Cartesian Product\nMaximum possible join space\nΩ = N_a × N_b\n6 × 4 = 24 combinations"
    style.fill: "#FFF3E0"
    style.stroke: ${colors.step_orange}
  }
  
  step2: "02. SELECTIVITY FILTER" {
    label: "2. Selectivity (S)\nFraction of combinations\nthat satisfy A.key = B.key\nS = 1 / MAX(D_a, D_b)"
    style.fill: "#FCE4EC"
    style.stroke: ${colors.logic_red}
  }
  
  step3: "03. EXPECTED VALUE" {
    label: "3. Per-Value Match Rate\nE[matches | val=v]\n(N_a / D_a) × (N_b / D_b)"
    style.fill: "#F3E5F5"
    style.stroke: ${colors.header_purple}
  }
  
  step4: "04. AGGREGATION" {
    label: "4. Total Estimated Rows\nE[Total] = matches_per_val × overlaps\nAssuming full overlap (min(D_a, D_b))"
    style.fill: "#E0F7FA"
    style.stroke: ${colors.data_blue}
  }

  step1 -> step2: "Apply predicate"
  step2 -> step3: "Calc density"
  step3 -> step4: "Sum over D"
}

# --- SECTION 3: FORMULA SYNTHESIS ---
section_formula: {
  label: "III. Formula Assembly"
  style.fill: "#F9F9F9"
  
  intermediate: {
    label: "Calculated Ratio:\n(N_a * N_b) / (D_a * D_b) * overlap"
    shape: rectangle
    style.stroke-dash: 3
    style.fill: "#ECEFF1"
  }

  key_insight: {
    label: "CRITICAL LOGIC: MAX(D_a, D_b)\n───────────────────────────────\nEnsures we don't overestimate\nwhen one set of values is a\nsparse subset of the other."
    style.fill: "#FFECB3"
    style.bold: true
    style.double-border: true
    style.stroke: ${colors.step_orange}
  }

  final_formula: {
    label: "ESTIMATED CARDINALITY (C)\n══════════════════════════\nC = (N_a × N_b) / MAX(D_a, D_b)\n══════════════════════════"
    shape: rectangle
    style: {
      fill: ${colors.formula_green}
      font-color: white
      bold: true
      font-size: 20
      stroke-width: 3
      stroke: "#1B5E20"
    }
  }

  intermediate -> key_insight: "Simplify"
  key_insight -> final_formula: "Output"
}

# --- SECTION 4: VALIDATION ---
section_example: {
  label: "IV. Verification Against Sample"
  
  example_calc: {
    label: "Input: Na=6, Nb=4, Da=3, Db=3\nCalculation: (6 * 4) / 3\nResult: 8.0"
    style.fill: "#E8EAF6"
    style.stroke: ${colors.data_blue}
  }

  actual_result: {
    label: "Observed Join Reality:\nValue 100: 2(A) * 2(B) = 4\nValue 200: 3(A) * 1(B) = 3\nValue 300: 1(A) * 1(B) = 1\nSum: 4 + 3 + 1 = 8\nESTIMATE IS 100% ACCURATE"
    style.fill: "#C8E6C9"
    style.bold: true
    style.stroke: ${colors.formula_green}
  }

  example_calc -> actual_result: "Compare" {
    style.stroke-dash: 5
    style.stroke: ${colors.padding_gray}
  }
}

# --- SECTION 5: VISUAL INTUITION (GRID) ---
section_intuition: {
  label: "V. Visual Logic (Join Matrix)"
  
  grid_container: {
    grid-columns: 3
    grid-rows: 3
    grid-gap: 10
    
    cell1: "Value 100" { style.fill: ${colors.table_bg_a} }
    cell2: "Value 100" { style.fill: ${colors.table_bg_a} }
    cell3: "Value 200" { style.fill: "#C5CAE9" }
    cell4: "Value 100" { style.fill: ${colors.table_bg_a} }
    cell5: "Value 100" { style.fill: ${colors.table_bg_a} }
    cell6: "Value 200" { style.fill: "#C5CAE9" }
    cell7: "Value 200" { style.fill: "#C5CAE9" }
    cell8: "Value 200" { style.fill: "#C5CAE9" }
    cell9: "Value 300" { style.fill: "#DCEDC8" }
  }

  legend: {
    label: "Matrix Interpretation:\nEach cell represents a cluster of matches\nArea of colored blocks = total result set size"
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      font-size: 14
      stroke-dash: 2
      border-radius: 4
    }
  }
}

# --- SECTION 6: BOUNDARY CONDITIONS ---
section_edge: {
  label: "VI. Boundary & Error Conditions"
  
  case1: {
    label: "ZERO OVERLAP\n(A: {1}, B: {2})\nFormula: (1/1)=1\nActual: 0\nError: Overestimate"
    style.fill: "#FFCDD2"
    style.stroke: ${colors.logic_red}
  }
  
  case2: {
    label: "PRIMARY KEY JOIN\n(A: {1,2}, B: {1})\nFormula: (2*1)/MAX(2,1)=1\nActual: 1\nResult: Perfect"
    style.fill: "#C8E6C9"
    style.stroke: ${colors.formula_green}
  }

  case1 -> case2: "Scenario Shift"
}

# --- FINAL SUMMARY BOX ---
summary_box: {
  label: |'md
### Implementation Specification: `estimate_join_rows`
**Inputs:** `rows_a`, `rows_b`, `dist_a`, `dist_b`
**Complexity:** O(1)
**Assumptions:** 
1. Uniform distribution of values (no heavy skew)
2. Inclusion Principle (values in smaller domain exist in larger domain)
**Logic:**
python
def estimate(na, nb, da, db):
    max_d = max(da, db)
    if max_d == 0: return 0
    return ceil((na * nb) / max_d)

  '|
  style: {
    fill: "#263238"
    font-color: "#ECEFF1"
    stroke: "#000000"
    stroke-width: 4
  }
}

# --- TOP-LEVEL FLOW CONNECTIONS ---
section_inputs.table_A -> section_inputs.stats_A: "Scan"
section_inputs.table_B -> section_inputs.stats_B: "Scan"

section_inputs.stats_A -> section_derivation.step1: "In: N_a, D_a"
section_inputs.stats_B -> section_derivation.step1: "In: N_b, D_b"

section_derivation.step4 -> section_formula.intermediate: "Synthesize"

section_formula.final_formula -> section_example.example_calc: "Validate" {
  style.stroke: ${colors.formula_green}
  style.stroke-width: 3
}

section_example.actual_result -> section_intuition.grid_container: "Mapping"

section_intuition.legend -> section_edge.case1: "Logic check"

section_edge.case2 -> summary_box: "Final Spec" {
  style.stroke-width: 5
  style.stroke: "#000000"
}

# Styling Globs
(section_derivation.** -> section_derivation.**)[*]: {
  style.stroke: ${colors.padding_gray}
  style.stroke-width: 2
}

(section_formula.** -> section_formula.**)[*]: {
  style.stroke: ${colors.padding_gray}
  style.stroke-width: 2
}