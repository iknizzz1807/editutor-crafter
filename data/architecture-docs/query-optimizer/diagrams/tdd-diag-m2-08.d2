vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 40
  }
}

direction: right

# -----------------------------------------------------------------------------------------
# GLOBAL CLASSES: Intel-Manual Implementation Spec
# -----------------------------------------------------------------------------------------
classes: {
  logic_component: {
    shape: class
    style: {
      fill: "#F3E5F5"        # Header: Purple (Logic/Header)
      stroke: "#7B1FA2"      # Border: Deep Purple
      font-color: "#4A148C"  # Text: Dark Purple
      stroke-width: 2
      shadow: true
    }
  }
  data_component: {
    shape: class
    style: {
      fill: "#E3F2FD"        # Data: Blue
      stroke: "#1565C0"      # Border: Deep Blue
      font-color: "#0D47A1"  # Text: Dark Blue
    }
  }
  config_component: {
    shape: class
    style: {
      fill: "#FFF3E0"        # Pointers/Config: Orange
      stroke: "#E65100"      # Border: Dark Orange
      font-color: "#BF360C"  # Text: Deep Orange
    }
  }
}

# -----------------------------------------------------------------------------------------
# SHAPES: Memory-Aware Architecture
# -----------------------------------------------------------------------------------------

CostEstimator: {
  class: logic_component
  label: "CostEstimator\nsizeof=128 bytes (heap)"
  tooltip: "Primary cost modeling logic for the query execution engine."

  # Field Declarations with Byte Offsets
  "-catalog": "StatisticsCatalog* [offset: 00, size: 08]"
  "-config": "CostModelConfig* [offset: 08, size: 08]"
  "-local_cache": "LRUCache<PlanNode, float> [offset: 16, size: 40]"
  "-padding": "uint64_t[9] [offset: 56, size: 72]" # Grey-style Padding in logic

  # Method Signatures
  "+estimate_scan_cost(table_name: str, predicate: Optional[str], index_name: Optional[str])": "ScanEstimate"
  "+estimate_join_cost(left_rows: float, right_rows: float, left_distinct: int, right_distinct: int, join_type: JoinType, left_sorted: bool, right_sorted: bool)": "Tuple[float, float]"
  "+estimate_total_plan_cost(plan: PlanNode)": "Tuple[float, float]"
  "+select_access_path(table_name: str, predicate: str, available_indexes: List[Index])": "Tuple[PlanNode, float, float]"
}

StatisticsCatalog: {
  class: data_component
  label: "StatisticsCatalog\nsizeof=256 bytes"
  tooltip: "Global registry for metadata and cardinality estimates."

  # Methods
  "+get_table_stats(table_name: str)": "TableStatistics"
  "+get_column_stats(table_name: str, column: str)": "ColumnStatistics"
  "+get_index_stats(table_name: str, index_name: str)": "IndexStatistics"
}

CostModelConfig: {
  class: config_component
  label: "CostModelConfig\nsizeof=64B (cache line alignment)"
  tooltip: "Static heuristics parameters for hardware-specific cost calculation."

  # Performance Fields (All float64 - 8 bytes each)
  "+seq_page_cost": "float64 [0.0 - 1.0]"
  "+random_page_cost": "float64 [0.0 - 4.0]"
  "+cpu_tuple_cost": "float64 [0.0 - 0.1]"
  "+cpu_index_tuple_cost": "float64 [0.0 - 0.05]"
  "+cpu_operator_cost": "float64 [0.0 - 0.01]"
}

# -----------------------------------------------------------------------------------------
# RELATIONSHIPS: Structural Coupling
# -----------------------------------------------------------------------------------------

# StatisticsCatalog is referenced by CostEstimator (Dashed = Reference)
StatisticsCatalog <- CostEstimator: "provides metadata" {
  source-arrowhead: 1
  target-arrowhead: 0..1
  style: {
    stroke: "#1565C0"
    stroke-dash: 5
  }
}

# CostModelConfig is referenced by CostEstimator (Dashed = Reference)
CostModelConfig <- CostEstimator: "configures heuristics" {
  source-arrowhead: 1
  target-arrowhead: 1
  style: {
    stroke: "#7B1FA2"
    stroke-dash: 5
  }
}

# -----------------------------------------------------------------------------------------
# ANNOTATIONS: Implementation Context (Fixed 'near' for ELK compatibility)
# -----------------------------------------------------------------------------------------

Annotation: |md
  ### Query Optimizer Cost Model (Technical Spec)
  Engineers must implement methods based on the following byte-aligned structures:

  - **Scan Cost Calculation**: $C_{scan} = (N_{pages} \times seq\_page\_cost) + (N_{tuples} \times cpu\_tuple\_cost)$
  - **Memory Layout**: `CostModelConfig` is explicitly padded to 64 bytes to prevent false sharing in multi-threaded planning environments.
  - **Index Selectivity**: `StatisticsCatalog` uses HyperLogLog for distinct value estimations.

  **Legend:**
  - **Purple**: Controller Logic
  - **Blue**: State/Metadata
  - **Orange**: Configuration/Pointers
| {
  near: top-right
  shape: text
  style: {
    font-size: 14
    stroke: "#CCCCCC"
    stroke-width: 1
    border-radius: 4
  }
}