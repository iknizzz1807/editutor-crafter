layout-engine: elk
direction: right
title: CostEstimator State Machine {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}
# Initial state marker
initial: {
  shape: circle
  style.fill: "#1f2937"
  width: 20
  height: 20
}
# Main states
Uninitialized: {
  label: "Uninitialized"
  style: {
    fill: "#374151"
    stroke: "#6b7280"
    font-color: white
  }
  invariant: "estimator = null"
}
Configured: {
  label: "Configured"
  style: {
    fill: "#1e3a5f"
    stroke: "#3b82f6"
    font-color: white
  }
  invariant: "catalog, stats_manager ready"
}
Estimating: {
  label: "Estimating"
  style: {
    fill: "#1e3a5f"
    stroke: "#3b82f6"
    font-color: white
  }
  invariant: "computing plan costs"
  # Sub-states for different operation types
  ScanEstimating: {
    label: "Scan Estimating"
    style: {
      fill: "#1e4d3a"
      stroke: "#10b981"
      font-color: white
    }
    invariant: "selectivity × cardinality"
  }
  JoinEstimating: {
    label: "Join Estimating"
    style: {
      fill: "#1e4d3a"
      stroke: "#10b981"
      font-color: white
    }
    invariant: "join_selectivity(left, right)"
  }
  SortEstimating: {
    label: "Sort Estimating"
    style: {
      fill: "#1e4d3a"
      stroke: "#10b981"
      font-color: white
    }
    invariant: "N × log(N) × sort_mem_factor"
  }
}
Complete: {
  label: "Complete"
  style: {
    fill: "#166534"
    stroke: "#22c55e"
    font-color: white
  }
  invariant: "total_cost computed"
}
# Error states
StatsMissingError: {
  label: "Statistics Missing"
  style: {
    fill: "#7f1d1d"
    stroke: "#ef4444"
    font-color: white
    stroke-dash: 4
  }
  invariant: "table_stats = null"
}
CatalogError: {
  label: "Catalog Error"
  style: {
    fill: "#7f1d1d"
    stroke: "#ef4444"
    font-color: white
    stroke-dash: 4
  }
  invariant: "catalog.lookup_failed = true"
}
# Initial transition
initial -> Uninitialized: {
  label: "create"
}
# Transitions
Uninitialized -> Configured: {
  label: "configure(catalog, stats_manager)"
  style.stroke: "#3b82f6"
}
Uninitialized -> CatalogError: {
  label: "catalog = null"
  style.stroke: "#ef4444"
}
Configured -> Estimating: {
  label: "estimate(plan)"
  style.stroke: "#3b82f6"
}
Configured -> StatsMissingError: {
  label: "stats_manager.is_empty()"
  style.stroke: "#ef4444"
}
# Estimating sub-state transitions
Estimating -> Estimating.ScanEstimating: {
  label: "node.type = SCAN"
}
Estimating -> Estimating.JoinEstimating: {
  label: "node.type = JOIN"
}
Estimating -> Estimating.SortEstimating: {
  label: "node.type = SORT"
}
Estimating.ScanEstimating -> Estimating: {
  label: "cost += scan_cost"
}
Estimating.JoinEstimating -> Estimating: {
  label: "cost += join_cost"
}
Estimating.SortEstimating -> Estimating: {
  label: "cost += sort_cost"
}
Estimating -> Complete: {
  label: "all_nodes_processed"
  style.stroke: "#22c55e"
}
# Error transitions from Estimating
Estimating.ScanEstimating -> StatsMissingError: {
  label: "histogram_missing"
  style.stroke: "#ef4444"
}
Estimating.JoinEstimating -> StatsMissingError: {
  label: "ndv_missing"
  style.stroke: "#ef4444"
}
# Recovery transitions
StatsMissingError -> Configured: {
  label: "run_analyze()"
  style.stroke: "#f59e0b"
}
StatsMissingError -> Uninitialized: {
  label: "reset()"
  style.stroke: "#f59e0b"
}
CatalogError -> Uninitialized: {
  label: "reset()"
  style.stroke: "#f59e0b"
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style: {
    fill: "#1f2937"
    stroke: "#4b5563"
    font-color: white
  }
  normal_state: {
    label: "Normal State"
    style: {
      fill: "#1e3a5f"
      stroke: "#3b82f6"
      font-color: white
    }
  }
  sub_state: {
    label: "Sub-State"
    style: {
      fill: "#1e4d3a"
      stroke: "#10b981"
      font-color: white
    }
  }
  error_state: {
    label: "Error State"
    style: {
      fill: "#7f1d1d"
      stroke: "#ef4444"
      font-color: white
      stroke-dash: 4
    }
  }
  terminal_state: {
    label: "Terminal State"
    style: {
      fill: "#166534"
      stroke: "#22c55e"
      font-color: white
    }
  }
}
# Position legend
legend.near: bottom-right