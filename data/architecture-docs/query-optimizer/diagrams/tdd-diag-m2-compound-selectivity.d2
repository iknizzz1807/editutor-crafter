layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6a0dad"
    logic_gate: "#4CAF50"
    data_stream: "#2196F3"
    math_op: "#FF9800"
    annotation: "#607D8B"
    padding: "#cccccc"
  }
}

classes: {
  operator_gate: {
    style: {
      stroke-width: 2
      border-radius: 5
      fill: "#e8f5e9"
      font-size: 14
      bold: true
    }
  }
  math_block: {
    shape: parallelogram
    style: {
      fill: "#fff3e0"
      stroke: "#ef6c00"
      font-size: 12
    }
  }
  terminal: {
    shape: circle
    style: {
      fill: "#bbdefb"
      stroke: "#1976d2"
      font-size: 11
    }
  }
  annotation_box: {
    shape: sticky_note
    style: {
      fill: "#ffffff"
      stroke: "#607D8B"
      stroke-dash: 3
    }
  }
  struct_field: {
    style: {
      font: mono
      font-size: 10
    }
  }
}

# --- DIAGRAM START ---

Selectivity_Logic_Engine: "M2: SELECTIVITY PROBABILITY TREE (Query Optimizer Model)" {
  style: {
    stroke: "${colors.header}"
    stroke-width: 4
    fill: "#fcfcfc"
  }

  input_layer: "1. INPUT PREDICATES (AST Nodes)" {
    style.fill: "#f8f9fa"
    p1: "WHERE age > 30" {
      class: terminal
      tooltip: "NodeID: 0x442A | Type: GT_OP"
    }
    p2: "WHERE country = 'USA'" {
      class: terminal
      tooltip: "NodeID: 0x442B | Type: EQ_OP"
    }
    
    metadata: "AST Node Memory Layout" {
      shape: sql_table
      offset_00: "void*: left_child [Bytes 0-7]"
      offset_08: "void*: right_child [Bytes 8-15]"
      offset_16: "uint16: opcode [Bytes 16-17]"
      offset_18: "uint16: flags [Bytes 18-19]"
      padding: "byte[12]: alignment_pad" {
        style.fill: "${colors.padding}"
      }
    }
  }

  histogram_lookup: "2. SINGLE SELECTIVITY EXTRACTION (Sᵢ)" {
    style.fill: "#f1f3f4"
    s1_calc: "Histogram(age).interpolate(30, '>')" {class: math_block}
    s2_calc: "Histogram(country).match('USA')" {class: math_block}
    
    val_s1: "S₁ = 0.40" {
      style.font-color: blue
      style.bold: true
    }
    val_s2: "S₂ = 0.10" {
      style.font-color: blue
      style.bold: true
    }

    s1_calc -> val_s1
    s2_calc -> val_s2
    
    formula_box: {
      label: |md
        **Selectivity Calculation**
        $S = \frac{count(range)}{count(total)}$
      |
    }
  }

  boolean_gates: "3. BOOLEAN COMBINATION LOGIC" {
    style.fill: "#e8f5e9"
    grid-columns: 2
    
    and_gate: "AND GATE\n(Intersection)" {
      class: operator_gate
      tooltip: "Intersection formula logic applied"
    }

    or_gate: "OR GATE\n(Union)" {
      class: operator_gate
      tooltip: "Union formula logic applied"
    }

    not_gate: "NOT GATE\n(Inversion)" {
      class: operator_gate
    }
    
    gate_logic: "Logic Invariants" {
      shape: sql_table
      and_op: "Result = S₁ * S₂"
      or_op: "Result = S₁ + S₂ - (S₁ * S₂)"
      not_op: "Result = 1.0 - S₁"
    }
  }

  output_calculation: "4. FINAL CARDINALITY ESTIMATE" {
    style.fill: "#fffde7"
    card_formula: "Rows_out = Total_Rows * S_total" {
      class: math_block
      style: {
        fill: "#c8e6c9"
        stroke-width: 3
      }
    }
    constraint: "Invariant: max(1.0, Rows_out)" {
      style: {
        font-size: 10
        italic: true
        font-color: "#7f8c8d"
      }
    }
    
    result_struct: "Cardinality Output Struct" {
      shape: sql_table
      rows_count: "double: 8 bytes"
      selectivity: "double: 8 bytes"
      cpu_cost: "double: 8 bytes"
      sizeof: "Total: 24 bytes" {
        style.bold: true
      }
    }
  }

  # Internal Data Flow Connections
  input_layer.p1 -> histogram_lookup.s1_calc
  input_layer.p2 -> histogram_lookup.s2_calc

  histogram_lookup.val_s1 -> boolean_gates.and_gate
  histogram_lookup.val_s2 -> boolean_gates.and_gate
  
  histogram_lookup.val_s1 -> boolean_gates.or_gate
  histogram_lookup.val_s2 -> boolean_gates.or_gate

  boolean_gates.and_gate -> output_calculation.card_formula: "S_total = 0.04" {
    style: {
      stroke: "#2e7d32"
      stroke-width: 2
    }
  }
  boolean_gates.or_gate -> output_calculation.card_formula: "S_total = 0.46" {
    style: {
      stroke: "#d32f2f"
      stroke-width: 2
    }
  }

  # Technical Specification Annotations
  independence_assumption: {
    class: annotation_box
    label: |md
      ### The Independence Assumption
      The optimizer assumes that $P(A|B) = P(A)$.
      
      **Example Case:**
      `age > 30` AND `country = 'USA'`
      Result: $0.40 \times 0.10 = 0.04$
      
      **Risks:**
      Highly correlated columns (e.g. `City` and `Zip`) 
      will lead to underestimation of cardinality.
    | 
  }
  independence_assumption.near: boolean_gates.and_gate

  null_correction: {
    class: annotation_box
    label: |md
      ### NULL Correction
      Before combining, single selectivity is adjusted:
      $S_{adjusted} = S_{raw} \times (1.0 - NullFraction)$
    | 
  }
  null_correction.near: histogram_lookup
}

# Implementation Legend
legend: "Diagram Notation Guide" {
  near: bottom-right
  direction: right
  
  l_t1: Input {class: terminal}
  l_t2: Transform {class: math_block}
  l_t3: Logic {class: operator_gate}
  
  l_t1 -> l_t2: Data flow
  l_t2 -> l_t3: Result vector
}

# Explicit styling for connection labels to ensure readability
(Selectivity_Logic_Engine.boolean_gates.and_gate -> Selectivity_Logic_Engine.output_calculation.card_formula)[0].style.font-color: "#2e7d32"
(Selectivity_Logic_Engine.boolean_gates.or_gate -> Selectivity_Logic_Engine.output_calculation.card_formula)[0].style.font-color: "#d32f2f"