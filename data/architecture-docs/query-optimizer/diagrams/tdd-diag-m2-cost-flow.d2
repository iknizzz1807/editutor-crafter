direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- MEMORY STRUCTURES (Intel Manual Style) ---

HardwareStats: {
  shape: sql_table
  label: "struct HardwareExecutionStats (Size=32B)"
  
  # Offsets and Types clearly defined for implementation
  0x00: "pages_read" {constraint: "uint64_t"}
  0x08: "random_seeks" {constraint: "uint64_t"}
  0x10: "tuples_fetched" {constraint: "uint64_t"}
  0x18: "tuples_processed" {constraint: "uint64_t"}
  
  style: {
    fill: "#DEE1EB"
    stroke: "#2A3143"
    stroke-width: 2
  }
}

WeightConfig: {
  shape: sql_table
  label: "struct CostModelWeights (Size=32B)"
  
  0x00: "w_io_seq" {constraint: "float64"}
  0x08: "w_io_rand" {constraint: "float64"}
  0x10: "w_cpu_tuple" {constraint: "float64"}
  0x18: "w_cpu_index" {constraint: "float64"}
  
  style: {
    fill: "#FCE7C6"
    stroke: "#B58105"
    stroke-width: 2
  }
}

# --- TRANSFORMATION ENGINE ---

CostCalculationEngine: {
  label: "Weighting & Accumulation Logic"
  
  IOMult: {
    label: "I/O WEIGHTING\n(Pages * W_io)"
    style.fill: "#C7F1FF"
    style.stroke: "#007BFF"
    tooltip: "Result = HardwareStats[0x00] * WeightConfig[0x00]"
  }
  
  CPUMult: {
    label: "CPU WEIGHTING\n(Tuples * W_cpu)"
    style.fill: "#E4DBFE"
    style.stroke: "#6F42C1"
    tooltip: "Result = HardwareStats[0x18] * WeightConfig[0x10]"
  }
  
  Accumulator: {
    shape: circle
    label: "Σ"
    style: {
      stroke-width: 4
      stroke: "#333333"
      fill: "#FFFFFF"
    }
  }

  IOMult -> Accumulator: "Cost_io"
  CPUMult -> Accumulator: "Cost_cpu"
  
  style: {
    stroke-dash: 5
    stroke: "#999999"
    fill: "#FBFBFB"
  }
}

# --- OUTPUT RESULT ---

EstimatedCost: {
  shape: sql_table
  label: "Annotated Plan Metadata"
  
  # Result mapping
  cardinality: "f64 rows_out" {constraint: "1250.4"}
  total_cost: "f64 total_cost" {constraint: "452.12"}
  
  style: {
    fill: "#ACE1AF"
    stroke: "#167C3C"
    stroke-width: 2
  }
}

# --- COMPREHENSIVE DATA FLOW ---

# Data Bus: Mapping memory fields to logic blocks
HardwareStats.0x00 -> CostCalculationEngine.IOMult: "uint64 raw"
WeightConfig.0x00 -> CostCalculationEngine.IOMult: "w_factor"

HardwareStats.0x18 -> CostCalculationEngine.CPUMult: "uint64 raw"
WeightConfig.0x10 -> CostCalculationEngine.CPUMult: "w_factor"

# Final result stream
CostCalculationEngine.Accumulator -> EstimatedCost.total_cost: "abstract cost units"

# --- ANNOTATIONS ---

# FIX: Changed 'near: CostCalculationEngine' to constant 'bottom-center' for ELK compatibility
CalculationContext: |md
  ### Costing Calculation Logic
  The optimizer transforms physical hardware metrics into an abstract **Cost Score**.
  
  **Equations:**
  1. $Cost_{io} = Pages \times W_{io}$
  2. $Cost_{cpu} = Tuples \times W_{cpu}$
  3. $Total = Cost_{io} + Cost_{cpu}$
  
  **Hardware Tuning Matrix:**
  - **NVMe/SSD**: Set $W_{io}$ low (e.g., 0.5) to favor disk scans.
  - **HDD (Mechanical)**: Set $W_{io}$ high (e.g., 4.0) to favor index-only paths.
| {
  near: bottom-center
  style: {
    font-size: 14
    stroke: "#EEEEEE"
    fill: "#FDFDFD"
  }
}

# --- VISUAL CUES ---

(HardwareStats.0x00 -> CostCalculationEngine.IOMult)[0].style: {
  stroke: "#007BFF"
  stroke-width: 3
  animated: true
}

(HardwareStats.0x18 -> CostCalculationEngine.CPUMult)[0].style: {
  stroke: "#6F42C1"
  stroke-width: 3
  animated: true
}

(CostCalculationEngine.Accumulator -> EstimatedCost.total_cost)[0].style: {
  stroke: "#167C3C"
  stroke-width: 4
  stroke-dash: 5
}

# Legend for Quick Reference
Legend: {
  near: bottom-right
  io_path: "I/O Weighted Path" {
    style.fill: "#C7F1FF"
  }
  cpu_path: "CPU Weighted Path" {
    style.fill: "#E4DBFE"
  }
  style.fill: "#FFFFFF"
}