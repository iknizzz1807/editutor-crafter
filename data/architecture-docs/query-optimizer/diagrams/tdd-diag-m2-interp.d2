layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# -----------------------------------------------------------------------------------------
# ALGORITHM: LINEAR INTERPOLATION FOR SELECTIVITY ESTIMATION
# Logic: Estimating the selectivity fraction for a Range Predicate (Col > V) 
# within a specific Histogram Bucket using the Uniformity Assumption.
# -----------------------------------------------------------------------------------------

direction: right

interpolation_logic: {
  label: "LINEAR INTERPOLATION COMPONENT: HISTOGRAM SELECTIVITY ESTIMATOR"
  
  # --- STEP 1: PHYSICAL BUCKET MAPPING ---
  bucket_view: {
    label: "STEP 1: PHYSICAL PREDICATE MAPPING"
    tooltip: "Locating the target value V within the persistent histogram structure."
    
    bucket_range: {
      shape: sql_table
      style: {
        fill: "#DEE1EB"
        stroke: "#2D3436"
        stroke-width: 2
      }
      
      # Memory Layout: 8-byte aligned fields for FLOAT64
      0x00: "BUCKET_HEADER" {style.fill: "#6C5CE7"; style.font-color: white; style.bold: true; constraint: "8 bytes"}
      0x08: "B_low: 20.0" {constraint: "FLOAT64 (8B)"; tooltip: "Lower boundary of the current bucket"}
      0x10: "B_high: 40.0" {constraint: "FLOAT64 (8B)"; tooltip: "Upper boundary of the current bucket"}
      0x18: "Weight: 0.01" {constraint: "FLOAT64 (8B)"; tooltip: "Weight/Density of the bucket relative to total dataset"}
      0x20: "Padding" {style.fill: "#D3D3D3"; constraint: "8 bytes (64B Cache Line Alignment)"}
    }

    predicate_marker: "Predicate Value (V): 30.0" {
      shape: parallelogram
      style: {
        fill: orange
        bold: true
        stroke-width: 3
        shadow: true
      }
    }

    predicate_marker -> bucket_view.bucket_range.0x08: "Constraint Check: B_low <= V < B_high" {
      style.stroke-dash: 4
      style.font-size: 14
      style.bold: true
    }
  }

  # --- STEP 2: FRACTIONAL AREA COMPUTATION ---
  area_calc: {
    label: "STEP 2: UNIFORMITY AREA INTEGRATION"
    tooltip: "Calculating the matched fraction based on the assumption of uniform data density."
    
    # Visual representation of the data distribution within the bucket
    visual_bar: {
      label: "INTERNAL BUCKET AREA (UNIFORMITY VIEW)"
      grid-columns: 10
      grid-gap: 0
      width: 600
      
      # DISCARDED REGION (Values < V)
      p1: " " { style.fill: "#D3D3D3"; style.opacity: 0.4; tooltip: "Discarded: 10%" }
      p2: " " { style.fill: "#D3D3D3"; style.opacity: 0.4; tooltip: "Discarded: 20%" }
      p3: " " { style.fill: "#D3D3D3"; style.opacity: 0.4; tooltip: "Discarded: 30%" }
      p4: " " { style.fill: "#D3D3D3"; style.opacity: 0.4; tooltip: "Discarded: 40%" }
      p5: " " { style.fill: "#D3D3D3"; style.opacity: 0.4; tooltip: "Discarded: 50%" }
      
      # The Interpolation Cut Point
      cut: "V=30.0" {
        style: {
          fill: "#D63031"
          font-color: white
          bold: true
          stroke-width: 4
        }
      }

      # MATCHED REGION (Values > V)
      m1: "MATCH" { style.fill: "#0984E3"; style.font-color: white; style.bold: true }
      m2: "MATCH" { style.fill: "#0984E3"; style.font-color: white; style.bold: true }
      m3: "MATCH" { style.fill: "#0984E3"; style.font-color: white; style.bold: true }
      m4: "MATCH" { style.fill: "#0984E3"; style.font-color: white; style.bold: true }
    }

    interpolation_specs: |md
      ### SELECTIVITY INTERPOLATION LOGIC
      Under the **Uniformity Assumption**, data density is constant within the range $[B_{low}, B_{high}]$.

      **1. Bucket Width ($W$):**  
      $W = B_{high} - B_{low} = 40.0 - 20.0 = 20.0$
      
      **2. Match Width ($M$):**  
      $M = B_{high} - V = 40.0 - 30.0 = 10.0$
      
      **3. Fraction Result:**  
      $F = M / W = 10.0 / 20.0 = 0.5$ (50.0%)
    | {
      shape: text
    }
  }

  # --- STEP 3: GLOBAL AGGREGATION ---
  aggregation: {
    label: "STEP 3: GLOBAL SELECTIVITY SYNTHESIS"
    
    formula_block: |latex
      \text{Selectivity} (S) = \frac{(F \times W_i) + \sum_{j=i+1}^{n} W_j}{W_{total}}
    | {
      style.font-size: 28
      style.fill: transparent
      style.stroke-width: 0
    }

    final_stats: {
      shape: sql_table
      style.fill: "#C7F1FF"
      
      0x00: "AGGREGATION RESULTS" {style.fill: "#0984E3"; style.font-color: white; style.bold: true}
      interpolated: "Fractional Rows (Bucket i): 0.005" {constraint: "0.5 (F) * 0.01 (W_i)"}
      trailing: "Full Buckets (i+1 to N): 0.600" {constraint: "Sum of following buckets"}
      # Fixed: double-border removed as it is illegal on sql_table rows/cells
      result: "TOTAL SELECTIVITY (S): 0.605" {
        style.fill: "#00B894"
        style.font-color: white
        style.bold: true
        style.stroke-width: 4
        tooltip: "Final scalar value exported to Query Optimizer cost model"
      }
    }
    
    formula_block -> aggregation.final_stats: "Input to Scalar Pipeline"
  }

  # Transitions showing technical data flow
  bucket_view -> area_calc: "Binary Search -> Bucket[i]"
  area_calc -> aggregation: "Yield Fractional Weight"
}

# --- DOCUMENTATION METADATA & VISUAL KEY ---
legend: {
  near: bottom-right
  style.fill: "#FDFEFE"
  style.stroke: gray
  
  title: "TECHNICAL LEGEND" {shape: text; style.bold: true; style.font-size: 18}
  
  predicate: "INPUT PREDICATE (V)" {
    style.fill: orange
    style.bold: true
  }
  matching_data: "MATCHING REGION" {
    style.fill: "#0984E3"
    style.font-color: white
  }
  discarded_data: "DISCARDED REGION" {
    style.fill: gray
    style.opacity: 0.3
  }
  scalar_result: "OPTIMIZER OUTPUT" {
    style.fill: "#00B894"
    style.font-color: white
  }
}

# --- GLOBAL STYLING RULES ---
***.style.font: mono
interpolation_logic.**.style.border-radius: 4
interpolation_logic.**.style.stroke-width: 2

# Connection styling for data paths
(interpolation_logic.** -> interpolation_logic.**): {
  style.stroke: "#2D3436"
  style.stroke-width: 2
  style.font-size: 14
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}

# Annotation for Page Boundary
# Fixed: double-border removed from sql_table as it's not a supported basic shape for that style
interpolation_logic.bucket_view.bucket_range.style.stroke-width: 4
interpolation_logic.bucket_view.bucket_range.0x00.style.underline: true