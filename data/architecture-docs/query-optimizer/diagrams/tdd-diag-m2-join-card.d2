vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    highlight: "#ef4444"
    neutral: "#475569"
    success: "#22c55e"
    header: "#6366f1"
    background: "#f8fafc"
    container: "#f1f5f9"
    stats_fill: "#f8fafc"
  }
}

direction: right

# -----------------------------------------------------------------------------
# Algorithm Header & Logical Specification
# -----------------------------------------------------------------------------
explanation: |md
  ### Join Cardinality Estimation Algorithm
  **Logical Model**: Inner Join (Equi-join)
  **Formula**: `(Rows_A * Rows_B) / max(NDV_A, NDV_B)`
  
  *Diversity Factor Principle*: The estimation assumes that every value in the smaller domain has a match in the larger domain, thus the match probability is `1 / max(NDV_A, NDV_B)`.
| {
  near: top-center
  shape: text
  style: {
    stroke: "#6366f1"
    stroke-width: 1
    fill: "#f8fafc"
    font-size: 14
  }
}

# -----------------------------------------------------------------------------
# STEP 1: Metadata Extraction
# State: NDVs and Row Counts are pulled from Catalog Statistics
# -----------------------------------------------------------------------------
step_1: "1. Metadata Extraction" {
  style: {
    stroke: ${colors.neutral}
    fill: ${colors.container}
    stroke-width: 2
  }
  
  table_a: "Table A (Users)" {
    shape: sql_table
    style.fill: ${colors.header}
    id: "UUID" {constraint: PK}
    rows: "1000"
    ndv_id: "100"
  }
  
  table_b: "Table B (Orders)" {
    shape: sql_table
    style.fill: ${colors.header}
    user_id: "UUID" {constraint: FK}
    rows: "500"
    ndv_uid: "50"
  }

  calc: "Stats Register" {
    rows_a: "1,000"
    rows_b: "500"
    ndv_a: "100"
    ndv_b: "50"
    style: {
      fill: white
      stroke: ${colors.neutral}
      stroke-dash: 0
    }
  }

  table_a.ndv_id -> calc.ndv_a: "Lookup NDV" {
    style: {
      stroke-dash: 3
      font-size: 10
    }
  }
  table_b.ndv_uid -> calc.ndv_b: "Lookup NDV" {
    style: {
      stroke-dash: 3
      font-size: 10
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 2: Cartesian Product (Theoretical Max State)
# State: Initial cross-product calculation ignoring filters
# -----------------------------------------------------------------------------
step_2: "2. Cartesian Foundation" {
  style: {
    stroke: ${colors.neutral}
    fill: ${colors.container}
    stroke-width: 2
  }

  calc: "Calculation State" {
    rows_a: "1,000"
    rows_b: "500"
    
    # Changed element: Cartesian Product is newly computed
    cartesian_product: "**500,000**" {
      label: "Cartesian: 500,000"
      style: {
        font-color: ${colors.highlight}
        bold: true
        stroke: ${colors.highlight}
        stroke-width: 3
        fill: "#fff1f2"
      }
    }
    style.fill: white
  }
  
  formula_note: "Logic: Rows_A * Rows_B" {
    shape: text
    style: {
      font-size: 11
      font-color: ${colors.neutral}
      italic: true
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 3: Inclusion Principle (Diversity Factor)
# State: Determining the selection divisor based on NDV overlap
# -----------------------------------------------------------------------------
step_3: "3. Selection of Diversity" {
  style: {
    stroke: ${colors.neutral}
    fill: ${colors.container}
    stroke-width: 2
  }

  calc: "Calculation State" {
    ndv_a: "100"
    ndv_b: "50"
    
    # Changed element: Divisor is determined from max(NDV)
    divisor_max_ndv: "**100**" {
      label: "Divisor (Max NDV): 100"
      style: {
        font-color: ${colors.highlight}
        bold: true
        stroke: ${colors.highlight}
        stroke-width: 3
        fill: "#fff1f2"
      }
    }
    style.fill: white
  }
  
  formula_note: "Logic: max(NDV_A, NDV_B)" {
    shape: text
    style: {
      font-size: 11
      font-color: ${colors.neutral}
      italic: true
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 4: Probability Application & Floor Invariants
# State: Final estimation result
# -----------------------------------------------------------------------------
step_4: "4. Final Cardinality" {
  style: {
    stroke: ${colors.success}
    fill: "#f0fdf4" 
    stroke-width: 2
  }

  calc: "Final Output Register" {
    raw_estimate: "500,000 / 100"
    
    # Changed element: Final result finalized
    final_cardinality: "**5,000**" {
      label: "ESTIMATED ROWS: 5,000"
      style: {
        font-color: "#166534"
        bold: true
        stroke: ${colors.success}
        stroke-width: 4
        fill: white
      }
    }
    
    invariant: "max(Result, 1.0)" {
      style: {
        font-size: 10
        italic: true
        font-color: ${colors.neutral}
      }
    }
    style.fill: white
    style.stroke: ${colors.success}
  }
}

# -----------------------------------------------------------------------------
# Transitions (Numbered sequence per TDD spec)
# -----------------------------------------------------------------------------
step_1 -> step_2: "1. Compute Product" {
  style: {
    stroke: ${colors.neutral}
    stroke-width: 2
    font-size: 12
  }
}
step_2 -> step_3: "2. Analyze Distinctness" {
  style: {
    stroke: ${colors.neutral}
    stroke-width: 2
    font-size: 12
  }
}
step_3 -> step_4: "3. Apply Selection Filter" {
  style: {
    stroke: ${colors.neutral}
    stroke-width: 2
    font-size: 12
  }
}

# -----------------------------------------------------------------------------
# Legend & Global Styling
# -----------------------------------------------------------------------------
***: {
  style: {
    border-radius: 4
    font: mono
  }
}

legend: "Algorithm Legend" {
  near: bottom-right
  
  changed: "Calculation Delta" {
    style: {
      font-color: ${colors.highlight}
      bold: true
      stroke: ${colors.highlight}
      stroke-width: 2
      fill: "#fff1f2"
    }
  }
  
  final: "Final Estimated State" {
    style: {
      font-color: "#166534"
      bold: true
      stroke: ${colors.success}
      stroke-width: 2
      fill: "#f0fdf4"
    }
  }
  
  style: {
    fill: "#f8fafc"
    stroke: ${colors.neutral}
    stroke-width: 1
    font-size: 12
  }
}