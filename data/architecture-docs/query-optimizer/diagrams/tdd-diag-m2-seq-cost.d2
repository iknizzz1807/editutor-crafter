layout-engine: elk
vars: {
  d2-config: {
    theme-id: 0
    sketch: false
    pad: 20
  }
}

cost_calculation_flow: {
  shape: sequence_diagram
  label: "Sequence: Cost and Cardinality Estimation (Milestone 2)"

  optimizer: Optimizer {
    shape: person
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      stroke-width: 2
    }
  }
  catalog: Catalog {
    style: {
      fill: "#F3E5F5"
      stroke: "#4A148C"
    }
  }
  estimator: SelectivityEstimator {
    style: {
      fill: "#E8F5E9"
      stroke: "#1B5E20"
    }
  }
  model: CostModel {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
    }
  }
  node: PlanNode {
    style: {
      fill: "#ECEFF1"
      stroke: "#263238"
    }
  }

  # 1. Statistics Retrieval
  optimizer.t1 -> catalog.t1: "get_table_stats(table_name: string)" {
    tooltip: "Retrieves metadata for base table: page count, tuple count, and histogram data"
    style.font-color: "#0D47A1"
    style.bold: true
  }
  catalog.t1 -> optimizer.t1: "TableMetadata { pages: u64, rows: u64, ColumnStats[] }" {
    style.stroke-dash: 3
  }

  # 2. Selectivity Computation
  optimizer.t2 -> estimator.t2: "estimate_selectivity(col_stats: struct, op: enum, val: any)" {
    tooltip: "Calculates probability (0.0 - 1.0) using histograms/MCVs"
    style.font-color: "#0D47A1"
    style.bold: true
  }
  
  estimator.t2 -> estimator.t2: "interpolate_buckets(val, low, high)" {
    tooltip: "Linear interpolation within histogram buckets to find fraction"
    style.stroke: "#2E7D32"
    style.animated: true
  }
  
  estimator.t2 -> optimizer.t2: "selectivity: float64 (range: [0, 1])" {
    style.stroke-dash: 3
  }

  # 3. Cardinality Calculation
  optimizer.t3 -> optimizer.t3: "apply_cardinality_rules(rows, selectivity)" {
    tooltip: "Formula: rows * selectivity. Result becomes the base for cost calculation."
    style.bold: true
  }

  # 4. Physical Costing
  optimizer.t4 -> model.t4: "estimate_physical_cost(cardinality: f64, pages: u64)" {
    tooltip: "Applies hardware weights (W_io, W_cpu) to derive generic cost units"
    style.font-color: "#0D47A1"
    style.bold: true
  }
  
  model."Cost Model Equation": |md
    ### Cost Model Equation
    `Cost = (Pages * W_io) + (Rows * W_cpu)`
    *W_io default: 1.0 (Sequential IO)*
    *W_cpu default: 0.01 (Tuple processing)*
  | {
    style: {
      fill: "#FFFDE7"
      stroke: "#FBC02D"
      border-radius: 4
    }
  }
  
  model.t4 -> optimizer.t4: "total_cost: float64 (Generic Units)" {
    style.stroke-dash: 3
  }

  # 5. Plan Annotation
  optimizer.t5 -> node.t5: "annotate(est_rows: f64, est_cost: f64)" {
    tooltip: "Finalize metadata on the Plan Tree for the plan explorer"
    style.bold: true
  }

  node."At-Least-One-Row Rule": |md
    ### At-Least-One-Row Rule
    Ensures `est_rows >= 1.0` to avoid 
    zero-cost optimization traps in 
    nested loops or index scans.
  | {
    style: {
      fill: "#FFEBEE"
      stroke: "#B71C1C"
      border-radius: 4
    }
  }
}

# Participant Lifeline Styling
cost_calculation_flow.optimizer.style.stroke-width: 3
cost_calculation_flow.node.style.double-border: true

# Global Sequence Legend / Metadata - FIX: Changed 'near' to constant value
metadata: |md
  ## Implementation Context
  - **Weights**: Configurable via `pg_cost_constants`
  - **Estimator**: Supports range, equality, and null-check operators
  - **Unit**: All costs relative to single-page sequential read
  - **Validation**: Ensures row counts never drop to zero to prevent optimizer bypass
| {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#757575"
    stroke-width: 1
    border-radius: 8
  }
}