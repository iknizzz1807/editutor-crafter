direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# ---------------------------------------------------------------------------------------
# DOCUMENT HEADER
# ---------------------------------------------------------------------------------------
title: |md
  # Query Execution Plan Optimization
  ## Physical Operator Level: Predicate Pushdown (Filter Migration)
  *Spec v1.02 - Engine: Distributed-SQL-v4*
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# ---------------------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# ---------------------------------------------------------------------------------------
classes: {
  plan_node: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  scan_node: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
      border-radius: 4
    }
  }
  join_node: {
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 3
      border-radius: 8
    }
  }
  filter_node: {
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
      stroke-width: 2
      border-radius: 8
    }
  }
  optimized_filter: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 8
      bold: true
    }
  }
  metric_label: {
    shape: text
    style: {
      font-size: 11
      font-color: "#546E7A"
    }
  }
}

# ---------------------------------------------------------------------------------------
# STAGE 1: UNOPTIMIZED (ROOT FILTER)
# ---------------------------------------------------------------------------------------
before_section: {
  label: "STAGE 1: Unoptimized Plan (Late Filtering)"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-width: 2
    stroke-dash: 3
  }
  
  before_root: "Result Projection\n[Buffer: 64KB]" {
    class: plan_node
    tooltip: "Final stage before output"
  }
  
  before_filter: "Filter Stage\n(orders.amount > 1000)\nOUT: 5,000 rows" {
    class: filter_node
    tooltip: "Inefficient: Filters after join"
  }
  
  before_join: "Hash Join (Inner)\norders.cid = cust.id\nIN: 510,000 rows" {
    class: join_node
    tooltip: "Bottleneck: Large Hash Table"
  }
  
  # Leaf nodes
  before_scan_orders: "Seq Scan: Orders\n[500,000 tuples]\n8-byte Header | 128-byte Data" {
    class: scan_node
  }
  
  before_scan_customers: "Seq Scan: Customers\n[10,000 tuples]\nIndex: Primary (id)" {
    class: scan_node
  }

  # Logic Flow with Data Volume Metrics
  before_root -> before_filter: "5,000 tuples" {
    style.stroke: "#1976D2"
  }
  
  before_filter -> before_join: "510,000 tuples (JOINED)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 5
      animated: true
    }
  }
  
  before_join -> before_scan_orders: "Probe: 500k"
  before_join -> before_scan_customers: "Build: 10k"
}

# ---------------------------------------------------------------------------------------
# TRANSFORMATION SYMBOL
# ---------------------------------------------------------------------------------------
optimizer_action: {
  transform_arrow: "══════════►" {
    shape: text
    style: {
      font-size: 40
      bold: true
      font-color: "#1976D2"
    }
  }
  transform_label: "Cost-Based Optimizer\nPushing Predicate ↓" {
    shape: text
    style: {
      font-size: 14
      bold: true
      font-color: "#1976D2"
    }
  }
}

# ---------------------------------------------------------------------------------------
# STAGE 2: OPTIMIZED (PREDICATE PUSHDOWN)
# ---------------------------------------------------------------------------------------
after_section: {
  label: "STAGE 2: Optimized Plan (Predicate Pushdown)"
  style: {
    fill: "#F1F8E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }
  
  after_root: "Result Projection\n[Buffer: 64KB]" {
    class: plan_node
  }
  
  after_join: "Hash Join (Inner)\nIN: 15,000 rows" {
    class: join_node
    tooltip: "Optimized: Memory reduction"
  }
  
  after_filter: "Pushed Filter\n(amount > 1000)\nOUT: 5,000 rows" {
    class: optimized_filter
  }
  
  after_scan_orders: "Seq Scan: Orders\n[500,000 tuples]" {
    class: scan_node
  }
  
  after_scan_customers: "Seq Scan: Customers\n[10,000 tuples]" {
    class: scan_node
  }
  
  # Status annotation inside container (NO 'near' property here to avoid error)
  opt_msg: "OPTIMIZATION APPLIED:\nFilter pushed below Hash Join\nto reduce probe set cardinality." {
    shape: text
    style: {
      font-size: 11
      italic: true
      font-color: "#2E7D32"
    }
  }

  # Optimized Logic Flow
  after_root -> after_join: "5,000 tuples" {
    style: {
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
  
  after_join -> after_filter: "Probe: 5,000 filtered" {
    style: {
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  
  after_join -> after_scan_customers: "Build: 10k"
  
  after_filter -> after_scan_orders: "500k raw stream" {
    style.stroke: "#F57C00"
  }
}

# ---------------------------------------------------------------------------------------
# ANALYTICS PANEL
# ---------------------------------------------------------------------------------------
metrics_panel: {
  label: "Operator Efficiency Metrics"
  grid-columns: 2
  grid-gap: 20
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-width: 2
  }
  
  before_stats: |md
    ### UNOPTIMIZED (ROOT FILTER)
    - **Joined Count**: 510,000
    - **HashTable Size**: 1.2 GB
    - **CPU Utilization**: 88%
    - **I/O Wait**: High (Filter Backpressure)
  | {
    style.font-size: 12
  }
  
  after_stats: |md
    ### OPTIMIZED (PUSHED FILTER)
    - **Joined Count**: 15,000
    - **HashTable Size**: 34 MB
    - **CPU Utilization**: 12%
    - **I/O Wait**: Nominal (Streaming Filter)
  | {
    style.font-size: 12
  }
  
  summary: |md
    ## PERFORMANCE IMPACT: 34x Speedup in Query Latency
  | {
    grid-columns: 2
    style: {
      bold: true
      font-color: "#1B5E20"
      text-transform: uppercase
    }
  }
}

# ---------------------------------------------------------------------------------------
# LEGEND & ROOT METADATA (NEAR allowed here)
# ---------------------------------------------------------------------------------------
legend: {
  label: "Plan Operator Legend"
  near: bottom-left
  style: {
    fill: "#FFFFFF"
    stroke: "#9E9E9E"
  }
  
  l1: "Filter (Unoptimized)" { class: filter_node }
  l2: "Filter (Optimized)" { class: optimized_filter }
  l3: "Physical Join" { class: join_node }
  l4: "I/O Scan" { class: scan_node }
}

# ---------------------------------------------------------------------------------------
# STRUCTURAL LAYOUT CONNECTIONS
# ---------------------------------------------------------------------------------------
before_section -> optimizer_action.transform_arrow: { style.stroke-width: 0 }
optimizer_action.transform_arrow -> after_section: { style.stroke-width: 0 }
after_section -> metrics_panel: { style.stroke-width: 0 }

# Global annotations for Technical Manual quality
annotation_layer: {
  near: bottom-right
  shape: text
  label: "Confidential: Intel Internal Implementation Details\nRevision: 0.7.2-B"
  style.font-size: 10
}