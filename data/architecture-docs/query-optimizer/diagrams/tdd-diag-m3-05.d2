layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
  colors: {
    header_purple: "#512DA8"
    logic_blue: "#1976D2"
    action_orange: "#F57C00"
    success_green: "#388E3C"
    error_red: "#D32F2F"
    padding_gray: "#9E9E9E"
  }
}

direction: right

# -----------------------------------------------------------------------------
# DEFINITIONS & CLASSES
# -----------------------------------------------------------------------------
classes: {
  input_node: {
    shape: class
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
  process_node: {
    shape: class
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-dash: 0
    }
  }
  transformation_node: {
    shape: class
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      italic: true
    }
  }
  terminal_node: {
    shape: class
    style: {
      bold: true
      font-size: 16
      shadow: true
    }
  }
}

# -----------------------------------------------------------------------------
# CASE 1: TAUTOLOGY (1=1)
# -----------------------------------------------------------------------------
case1: "CASE 1: TAUTOLOGY ELIMINATION" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    double-border: true
  }

  c1_in: "WHERE 1 = 1" {
    class: input_node
  }

  c1_eval: "EvalBinaryExpr" {
    class: process_node
    definition: "L: Const(1), R: Const(1), Op: EQ"
    result: "Literal(TRUE)"
  }

  c1_act: "EliminateFilterRule" {
    class: transformation_node
    action: "Removes FilterNode from Plan"
    optimization: "I/O Reduction"
  }

  c1_out: "PLAN: CHILD_STREAM" {
    class: terminal_node
    style.fill: "#C8E6C9"
    style.stroke: "#1B5E20"
  }

  c1_in -> c1_eval: "parser output"
  c1_eval -> c1_act: "is_tautology=true"
  c1_act -> c1_out: "rewrite"
}

# -----------------------------------------------------------------------------
# CASE 2: CONTRADICTION (1=0)
# -----------------------------------------------------------------------------
case2: "CASE 2: CONTRADICTION PRUNING" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    double-border: true
  }

  c2_in: "WHERE 1 = 0" {
    class: input_node
  }

  c2_eval: "EvalBinaryExpr" {
    class: process_node
    definition: "L: Const(1), R: Const(0), Op: EQ"
    result: "Literal(FALSE)"
  }

  c2_act: "PruneSubtreeRule" {
    class: transformation_node
    action: "Replace Root with EmptyValues"
  }

  c2_out: "PLAN: EMPTY_SET" {
    class: terminal_node
    style.fill: "#FFCDD2"
    style.stroke: "#B71C1C"
  }

  c2_in -> c2_eval: "parser output"
  c2_eval -> c2_act: "is_contradiction=true"
  c2_act -> c2_out: "rewrite"
}

# -----------------------------------------------------------------------------
# CASE 3: ARITHMETIC FOLDING (2+3 > 4)
# -----------------------------------------------------------------------------
case3: "CASE 3: ARITHMETIC RECURSION" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 3
    double-border: true
  }

  c3_in: "WHERE 2 + 3 > 4" {
    class: input_node
  }

  c3_fold_l: "Fold(2+3)" {
    class: process_node
    intermediate: "5"
  }

  c3_fold_r: "Fold(5 > 4)" {
    class: process_node
    intermediate: "TRUE"
  }

  c3_out: "PLAN: CHILD_STREAM" {
    class: terminal_node
    style.fill: "#C8E6C9"
    style.stroke: "#1B5E20"
  }

  c3_in -> c3_fold_l: "depth-first traversal"
  c3_fold_l -> c3_fold_r: "bubble up constant"
  c3_fold_r -> c3_out: "reduce to Case 1"
}

# -----------------------------------------------------------------------------
# CASE 4: PARTIAL FOLDING (x=5 AND 1=1)
# -----------------------------------------------------------------------------
case4: "CASE 4: PARTIAL IDENTITY FOLDING" {
  style: {
    fill: "#FFF8E1"
    stroke: "#F57F17"
    stroke-width: 3
    double-border: true
  }

  c4_in: "x=5 AND 1=1" {
    class: input_node
  }

  c4_split: "DecomposeLogical" {
    class: process_node
    left: "col(x)=5"
    right: "lit(TRUE)"
  }

  c4_act: "IdentityApply: (P AND TRUE) -> P" {
    class: transformation_node
  }

  c4_out: "WHERE x = 5" {
    class: terminal_node
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
  }

  c4_in -> c4_split: "logical and"
  c4_split -> c4_act: "detect foldable branch"
  c4_act -> c4_out: "strip identity"
}

# -----------------------------------------------------------------------------
# ALGORITHM IMPLEMENTATION (RECURSIVE)
# -----------------------------------------------------------------------------
algorithm_logic: {
  label: "CORE FOLDING ALGORITHM (GOLANG)"
  style: {
    fill: "#263238"
    stroke: "#B0BEC5"
    font-color: "#FFFFFF"
  }

  code_impl: |go
func Fold(expr Expr) Expr {
    // 1. Base Case: Literal
    if expr.IsLiteral() { return expr }

    // 2. Recursive Step
    switch e := expr.(type) {
    case *BinaryExpr:
        e.Left = Fold(e.Left)
        e.Right = Fold(e.Right)
        
        // 3. Evaluation Step
        if e.Left.IsLit() && e.Right.IsLit() {
            return Eval(e.Op, e.Left, e.Right)
        }
    case *LogicalAnd:
        L, R := Fold(e.Left), Fold(e.Right)
        if L.IsFalse() || R.IsFalse() { return FalseLit }
        if L.IsTrue() { return R }
        if R.IsTrue() { return L }
        return &LogicalAnd{L, R}
    }
    return expr
}
|
  code_impl.shape: code
}

# -----------------------------------------------------------------------------
# LOGICAL MATRIX (MD)
# -----------------------------------------------------------------------------
logical_matrix: {
  label: "OPTIMIZATION DECISION MATRIX"
  content: |md
| Pattern | Optimized Result | Action Taken |
| :--- | :--- | :--- |
| `P AND TRUE` | `P` | Identity Elimination |
| `P AND FALSE` | `FALSE` | Contradiction Pruning |
| `P OR TRUE` | `TRUE` | Tautology Promotion |
| `P OR FALSE` | `P` | Identity Elimination |
| `lit OP lit` | `EvaluatedLit` | Constant Folding |
| `col OP lit` | `No Change` | Predicate Pushdown (Next Phase) |
| `NULL OP lit` | `NULL` | Null Propagation |
| `NULL AND P` | `depends(P)` | Three-Valued Logic |
|
  content.shape: rectangle
  style.fill: "#FAFAFA"
}

# -----------------------------------------------------------------------------
# GLOBAL CONNECTIONS & ANNOTATIONS
# -----------------------------------------------------------------------------

# Vertical grouping of cases
case1 -> case2 -> case3 -> case4: {
  style: {
    stroke-dash: 5
    stroke: "#9E9E9E"
  }
}

# Mapping of algorithm steps to diagram locations
algorithm_logic -> case3: "Step 2 & 3: Recursion + Eval" {
  style.stroke-dash: 2
}

logical_matrix -> case4: "Identity Laws" {
  style.stroke-dash: 2
}

note: |md
### Engineering Specification: Constant Folding
1. **Recursion Depth:** Maximum depth of 256 levels to avoid Stack Overflow on malicious nested expressions.
2. **Type Safety:** Only fold if types are compatible (e.g., don't fold `string + int` unless cast exists).
3. **Volatility:** Do NOT fold non-deterministic functions (e.g., `RAND()`, `NOW()`).
4. **Phase:** Must occur after `Binding` and before `Join Ordering`.
|
note.shape: sticky_note
note.near: logical_matrix

title: "SQL OPTIMIZER: CONSTANT FOLDING & PREDICATE SIMPLIFICATION" {
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    font-color: "#1A237E"
  }
}