direction: right
title: {
  label: Fixed-Point Iteration Loop\nRule-Based Query Optimization
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
vars: {
  state-fill: "#E8D5F0"
  decision-fill: "#FFF4E6"
  warning-fill: "#FFE4E4"
  start-end-fill: "#D4F0D4"
}
Start: {
  shape: circle
  style.fill: ${state-fill}
}
StartMarker: {
  shape: circle
  style.fill: "#333"
  style.stroke: "#333"
}
StartMarker -> Start
Initialize: {
  label: "Initialize\n• current_plan = input\n• iteration = 0"
  shape: rectangle
  style.fill: ${state-fill}
  style.stroke-dash: 0
}
Start -> Initialize: "Begin optimization"
ApplyRules: {
  label: "Apply Rules\n• Predicate Pushdown\n• Projection Pruning\n• Constant Folding\n• Join Reordering"
  shape: rectangle
  style.fill: ${state-fill}
}
Initialize -> ApplyRules: "For each rule in ruleset"
CheckModified: {
  label: "Modified?"
  shape: diamond
  style.fill: ${decision-fill}
}
ApplyRules -> CheckModified: "Rule application\ncomplete"
CheckModified -> End: "No modifications\n(Fixed Point\nReached)"
CheckModified -> CheckMaxIterations: "Modifications\nmade" {
  style.stroke: "#4A90D9"
  style.stroke-width: 3
}
CheckMaxIterations: {
  label: "iteration <\nmax_iterations?"
  shape: diamond
  style.fill: ${decision-fill}
}
CheckMaxIterations -> IncrementAndLoop: "Yes" {
  style.stroke: "#4A90D9"
}
CheckMaxIterations -> SafetyValve: "No\n(Safety triggered)" {
  style.stroke: "#D94A4A"
  style.stroke-width: 2
}
IncrementAndLoop: {
  label: "iteration++\nRestart loop"
  shape: rectangle
  style.fill: ${state-fill}
}
IncrementAndLoop -> ApplyRules: "Continue with\nupdated plan" {
  style.stroke-dash: 4
}
SafetyValve: {
  label: "⚠️ Max Iterations\nReached"
  shape: rectangle
  style.fill: ${warning-fill}
  style.stroke: "#D94A4A"
  style.stroke-width: 2
}
SafetyValve -> End: "Emit warning\nand exit"
End: {
  label: "End\n• Return optimized plan\n• Log iteration count"
  shape: rectangle
  style.fill: ${start-end-fill}
}
EndMarker: {
  shape: circle
  style.fill: "#333"
  style.stroke: "#333"
}
End -> EndMarker
Legend: {
  label: |md
    ### Legend
    - **Fixed Point**: No rules modified the plan
    - **max_iterations**: Safety valve (default: 100)
    - Prevents infinite loops from cyclic rule interactions
  |
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#CCC"
  near: bottom-right
}
IterationCounter: {
  label: "iteration: 0\nmax: 100"
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke-dash: 3
  near: top-right
}
CheckMaxIterations -- IterationCounter: {
  style.stroke-dash: 3
  style.stroke: "#888"
  label: ""
}