layout-engine: elk
direction: down
# Title
title: {
  label: "Rule Engine Class Hierarchy\nQuery Optimizer Logical Optimization"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Legend
legend: {
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#F8F9FA"
    font-size: 11
  }
  inheritance_label: {
    shape: text
    label: "━━━━━▶ Inheritance\n(hollow triangle)"
  }
  composition_label: {
    shape: text
    label: "━━━━─◆ Composition\n(filled diamond)"
  }
}
# Abstract base class
OptimizationRule: {
  shape: class
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    font-color: "#0D47A1"
  }
  # Stereotype for abstract class
  stereotype: <<abstract>>
  # Properties
  name: str
  priority: int
  # Separator
  sep: |
  # Abstract methods
  applies_to: applies_to(node: PlanNode) -> bool
  apply: apply(node: PlanNode, context: Dict) -> RuleApplicationResult
}
# Concrete rule subclasses
ConstantFoldingRule: {
  shape: class
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    font-color: "#1B5E20"
  }
  name: "\"constant_folding\""
  priority: 100
  sep: |
  applies_to: "applies_to(node) -> bool"
  apply: "apply(node, ctx) -> Result"
  "_evaluate_constant": "_evaluate_constant(expr)"
}
RedundantPredicateRule: {
  shape: class
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    font-color: "#1B5E20"
  }
  name: "\"redundant_predicate\""
  priority: 50
  sep: |
  applies_to: "applies_to(node) -> bool"
  apply: "apply(node, ctx) -> Result"
  "_is_tautology": "_is_tautology(pred)"
  "_is_contradiction": "_is_contradiction(pred)"
}
PredicatePushdownRule: {
  shape: class
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    font-color: "#1B5E20"
  }
  name: "\"predicate_pushdown\""
  priority: 10
  sep: |
  applies_to: "applies_to(node) -> bool"
  apply: "apply(node, ctx) -> Result"
  "_extract_predicates": "_extract_predicates(node)"
  "_push_through_join": "_push_through_join(pred, join)"
}
ProjectionPruningRule: {
  shape: class
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    font-color: "#1B5E20"
  }
  name: "\"projection_pruning\""
  priority: 0
  sep: |
  applies_to: "applies_to(node) -> bool"
  apply: "apply(node, ctx) -> Result"
  "_collect_required": "_collect_required(plan)"
  "_prune_unnecessary": "_prune_unnecessary(proj, required)"
}
# RuleEngine with composition
RuleEngine: {
  shape: class
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
    font-color: "#BF360C"
  }
  rules: "rules: List[OptimizationRule]"
  max_iterations: "max_iterations: int = 100"
  sep: |
  optimize: "optimize(plan: PlanNode, ctx: Dict) -> PlanNode"
  "_apply_single_pass": "_apply_single_pass(plan, ctx)"
  "_has_changes": "_has_changes(results)"
}
# Inheritance arrows (hollow triangle style via arrowhead)
OptimizationRule <- ConstantFoldingRule: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
  label: ""
}
OptimizationRule <- RedundantPredicateRule: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
  label: ""
}
OptimizationRule <- PredicatePushdownRule: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
  label: ""
}
OptimizationRule <- ProjectionPruningRule: {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
  target-arrowhead: {
    shape: triangle
    style.filled: false
  }
  label: ""
}
# Composition arrow (filled diamond)
RuleEngine o-> OptimizationRule: {
  label: "  owns 1..*"
  style: {
    stroke: "#E65100"
    stroke-width: 2
  }
}
# Priority ordering annotation
priority_flow: {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
    font-size: 10
  }
  label: "Priority Order:\n100 → 50 → 10 → 0\n(High → Low)"
}
priority_flow -> ConstantFoldingRule: {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
  label: "first"
}
ProjectionPruningRule -> priority_flow: {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
  label: "last"
}