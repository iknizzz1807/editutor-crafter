vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
# Fixed 'near' logic by grouping into a single container positioned at top-center
header: {
  near: top-center
  title: "Transformation Cost Reduction" {
    shape: text
    style: {
      font-size: 28
      bold: true
      underline: true
    }
  }
  subtitle: "Query Optimizer Performance Analysis: Plan cost comparison (lower is better)" {
    shape: text
    style: {
      font-size: 16
      italic: true
    }
  }
}

# --- GLOBAL CLASSES ---
classes: {
  pattern_container: {
    style: {
      fill: "#f8f9fa"
      stroke: "#343a40"
      stroke-width: 2
      border-radius: 8
    }
  }
  bar_before: {
    shape: rectangle
    style: {
      fill: "#dc3545" # Red for high cost
      stroke: "#a71d2a"
      font-color: white
      bold: true
      shadow: true
    }
  }
  bar_after: {
    shape: rectangle
    style: {
      fill: "#28a745" # Green for optimized cost
      stroke: "#1e7e34"
      font-color: white
      bold: true
      shadow: true
    }
  }
  metric_text: {
    shape: text
    style: {
      font-size: 11
      font-color: "#495057"
      font: mono
    }
  }
}

# --- LEGEND ---
legend_container: {
  label: "Cost Metric Legend"
  near: top-left
  style: {
    stroke-dash: 3
    fill: "#ffffff"
  }
  legend_items: {
    grid-columns: 1
    before: "■ Before Optimization (Unoptimized Logical Plan)" {
      style.font-color: "#dc3545"
    }
    after: "■ After Optimization (M4 Physical Plan)" {
      style.font-color: "#28a745"
    }
    reduction: "→ Efficiency Gain (10x - 100x)" {
      style.font-color: "#6c757d"
    }
  }
}

# --- PERFORMANCE PATTERNS ---

pattern_1: Simple Predicate {
  class: pattern_container
  tooltip: "WHERE id = 42"
  
  before: "847.3" {
    class: bar_before
    width: 280
  }
  after: "12.4" {
    class: bar_after
    width: 10
  }
  reduction: "68x reduction" {
    class: metric_text
  }
  annotation: "Transformation: Predicate Pushdown + Index Scan" {
    class: metric_text
    style.italic: true
  }
  
  before -> after: { style.stroke-dash: 4 }
}

pattern_2: Multi-Table Join {
  class: pattern_container
  tooltip: "4-way equi-join"
  
  before: "15,243.8" {
    class: bar_before
    width: 320
  }
  after: "187.2" {
    class: bar_after
    width: 20
  }
  reduction: "81x reduction" {
    class: metric_text
  }
  annotation: "Transformation: Join Order Optimization (DP) + Hash Join" {
    class: metric_text
    style.italic: true
  }
  
  before -> after: { style.stroke-dash: 4 }
}

pattern_3: Aggregation {
  class: pattern_container
  tooltip: "GROUP BY + HAVING"
  
  before: "3,891.5" {
    class: bar_before
    width: 200
  }
  after: "45.6" {
    class: bar_after
    width: 12
  }
  reduction: "85x reduction" {
    class: metric_text
  }
  annotation: "Transformation: Early Aggregation + Projection Pruning" {
    class: metric_text
    style.italic: true
  }
  
  before -> after: { style.stroke-dash: 4 }
}

pattern_4: Subquery {
  class: pattern_container
  tooltip: "Correlated Subquery"
  
  before: "12,567.2" {
    class: bar_before
    width: 300
  }
  after: "124.8" {
    class: bar_after
    width: 18
  }
  reduction: "101x reduction" {
    class: metric_text
  }
  annotation: "Transformation: Subquery Decorrelation + Semi-join Conversion" {
    class: metric_text
    style.italic: true
  }
  
  before -> after: { style.stroke-dash: 4 }
}

pattern_5: Complex Filter {
  class: pattern_container
  tooltip: "Multiple logical AND/OR predicates"
  
  before: "2,134.7" {
    class: bar_before
    width: 140
  }
  after: "78.3" {
    class: bar_after
    width: 15
  }
  reduction: "27x reduction" {
    class: metric_text
  }
  annotation: "Transformation: Constant Folding + CNF Normalization" {
    class: metric_text
    style.italic: true
  }
  
  before -> after: { style.stroke-dash: 4 }
}

pattern_6: Range Query {
  class: pattern_container
  tooltip: "BETWEEN ... ORDER BY"
  
  before: "6,712.9" {
    class: bar_before
    width: 240
  }
  after: "234.1" {
    class: bar_after
    width: 25
  }
  reduction: "29x reduction" {
    class: metric_text
  }
  annotation: "Transformation: Range Scan Selection + Top-N Sort" {
    class: metric_text
    style.italic: true
  }
  
  before -> after: { style.stroke-dash: 4 }
}

# --- PIPELINE FLOW ---
pattern_1 -> pattern_2 -> pattern_3 -> pattern_4 -> pattern_5 -> pattern_6: {
  style: {
    stroke: "#adb5bd"
    stroke-width: 2
    stroke-dash: 5
  }
}

# --- SUMMARY & STATISTICS ---
stats_container: {
  near: bottom-center
  direction: right
  
  summary_stats: "Performance Summary" {
    style: { fill: "#fff3cd"; stroke: "#ffc107"; stroke-width: 2 }
    grid-columns: 2
    avg: "Avg Reduction: 65.2x" { style.bold: true }
    max: "Peak Reduction: 101.4x" { style.font-color: "#28a745" }
    min: "Floor Reduction: 27.1x" { style.font-color: "#dc3545" }
    time: "Latency Overhead: <5ms" { style.italic: true }
  }
  
  applied_rules: "Optimization Pipeline Status" {
    style: { fill: "#d4edda"; stroke: "#28a745"; stroke-width: 2 }
    grid-columns: 3
    r1: "✓ Predicate Pushdown"
    r2: "✓ Projection Pruning"
    r3: "✓ Constant Folding"
    r4: "✓ Join Reordering"
    r5: "✓ Decorrelation"
    r6: "✓ Physical Selection"
  }
}

# --- SCALE REFERENCE ---
cost_scale: {
  label: "Computational Cost Units (Normalized I/O + CPU)"
  near: bottom-left
  scale: "0 ──── 2500 ──── 5000 ──── 7500 ──── 10000 ──── 15000+" {
    shape: text
    style: { font: mono; font-size: 10; font-color: "#6c757d" }
  }
}

# Layout constraints to ensure logical flow
legend_container -> pattern_1
pattern_6 -> stats_container
stats_container -> cost_scale