direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 6
    layout-engine: elk
    sketch: false
    pad: 20
  }
  colors: {
    header: "#6e4d9c"
    state_fill: "#f3e5f5"
    error_red: "#d32f2f"
    active_green: "#2e7d32"
    border_gray: "#455a64"
    pointer_orange: "#ef6c00"
    padding_gray: "#eeeeee"
  }
}

# ------------------------------------------------------------------------------------------
# OPTIMIZATION CONTEXT: MEMORY LAYOUT (Intel Manual Specification)
# ------------------------------------------------------------------------------------------
OptimizationContext: {
  shape: sql_table
  style: {
    stroke: ${colors.border_gray}
    fill: "white"
    stroke-width: 2
  }
  
  header: "OptimizationContext Memory Layout | sizeof=32 bytes" {
    style.fill: ${colors.header}
    style.font-color: "white"
    style.bold: true
  }
  
  0x00: "iteration_count (int32)" {
    constraint: "current iteration index"
    style.fill: "#e3f2fd"
  }
  0x04: "max_iterations (int32)" {
    constraint: "safety threshold (default=100)"
    style.fill: "#e3f2fd"
  }
  0x08: "changed_flag (bool/u8)" {
    constraint: "dirty bit for fixed-point check"
    style.fill: "#e8f5e9"
  }
  0x09: "padding (u8[7])" {
    style.fill: ${colors.padding_gray}
  }
  0x10: "plan_root_ptr (uint64)" {
    constraint: "pointer to LogicalPlanNode root"
    style.fill: "#fff3e0"
  }
  0x18: "rule_list_ptr (uint64)" {
    constraint: "pointer to vector<OptimizationRule*>"
    style.fill: "#fff3e0"
  }
}

# ------------------------------------------------------------------------------------------
# RULE ENGINE STATE MACHINE: FIXED-POINT ITERATION
# ------------------------------------------------------------------------------------------
RuleEngine: {
  label: "Query Optimizer: Rule-Based Logic State Machine"
  
  # Initial Entry Point
  start: "" {
    shape: circle
    width: 20
    height: 20
    style.fill: ${colors.border_gray}
  }

  LoadingRules: {
    label: "1. LOADING_RULES"
    tooltip: "Load ConstantFolding, PredicatePushdown, and ProjectionPruning rules."
    style: {
      fill: ${colors.state_fill}
      stroke: ${colors.header}
      stroke-width: 2
    }
    invariant: |md
      - Rule set must be ordered
      - Rules must be semantic-preserving
    |
  }

  ApplyPass: {
    label: "2. APPLY_PASS"
    tooltip: "Execute a single transformation pass across the Logical Plan tree."
    style: {
      fill: ${colors.state_fill}
      stroke: ${colors.header}
      stroke-width: 2
    }
    action: |md
      For each Rule R:
        - Tree traversal (Bottom-Up/Top-Down)
        - If R(Node) transforms: set changed_flag = true
    |
  }

  CheckForChanges: {
    label: "3. CHECK_FOR_CHANGES"
    tooltip: "Fixed-Point Logic: Has the tree converged?"
    shape: diamond
    style: {
      fill: "#fff9c4"
      stroke: "#fbc02d"
    }
  }

  Finalize: {
    label: "4. FINALIZE"
    tooltip: "Optimization complete. Pass refined tree to CBO."
    style: {
      fill: "#e8f5e9"
      stroke: ${colors.active_green}
      stroke-width: 3
    }
    invariant: "Result is a well-formed LogicalPlanNode tree"
  }

  MaxIterationsReached: {
    label: "ERROR: MAX_ITER_REACHED"
    tooltip: "Infinite loop detected in rule transformations."
    style: {
      fill: "#ffcdd2"
      stroke: ${colors.error_red}
      font-color: ${colors.error_red}
      stroke-width: 2
      bold: true
    }
  }

  # Transitions
  start -> LoadingRules: "optimize(plan_root) call"
  
  LoadingRules -> ApplyPass: "Initialize ctx.iteration_count = 0"
  
  ApplyPass -> CheckForChanges: "Pass i complete"
  
  CheckForChanges -> ApplyPass: "Guard: [changed == true AND i < max]" {
    style: {
      stroke: ${colors.header}
      animated: true
    }
    label: "Action: Increment i"
  }
  
  CheckForChanges -> Finalize: "Guard: [changed == false]" {
    label: "CONVERGED"
    style.stroke: ${colors.active_green}
  }
  
  CheckForChanges -> MaxIterationsReached: "Guard: [i >= max]" {
    label: "SAFETY BREAK"
    style.stroke: ${colors.error_red}
  }

  # Illegal State Definition
  LoadingRules -> Finalize: "ILLEGAL" {
    style: {
      stroke: ${colors.error_red}
      stroke-dash: 5
    }
    source-arrowhead: none
    target-arrowhead: cross
  }
}

# ------------------------------------------------------------------------------------------
# ANNOTATIONS & LEGEND
# ------------------------------------------------------------------------------------------
# FIXED: "near" set to constant "top-right" for ELK compatibility
Legend: {
  near: top-right
  shape: rectangle
  style: {
    fill: "#ffffff"
    stroke: ${colors.border_gray}
    stroke-dash: 2
    shadow: true
  }
  
  label: |md
    ### RBO Engine Logic (Intel-Grade Spec)
    - **Fixed-Point Iteration**: Logic keeps looping until the tree stops changing.
    - **Changed Flag**: Any successful transformation sets this to true.
    - **Convergence**: Reached when a full pass results in no modifications.
    - **Safety Break**: Prevents infinite recursion in oscillating rule sets.
  |
}

# Cross-reference pointers showing data movement
OptimizationContext.0x10 -> RuleEngine.ApplyPass: "Updates plan_root reference" {
  style.stroke: ${colors.pointer_orange}
  style.stroke-dash: 3
  style.animated: true
}

OptimizationContext.0x08 -> RuleEngine.CheckForChanges: "Read dirty bit" {
  style.stroke: "#4caf50"
  style.stroke-dash: 3
}