direction: down
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    pad: 40
  }
}

# -----------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# -----------------------------------------------------------------------------
classes: {
  logical_op: {
    shape: rectangle
    style: {
      fill: "#E1BEE7" # Purple Header / Structural
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  expr_op: {
    shape: oval
    style: {
      fill: "#E3F2FD" # Blue Expression Data
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  literal: {
    shape: rectangle
    style: {
      fill: "#C8E6C9" # Green Literal / Data
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 20
    }
  }
  # CRITICAL: Changed elements RED + bold for Algorithm State Diagrams
  changed: {
    style: {
      stroke: "#D32F2F"
      stroke-width: 5
      font-color: "#D32F2F"
      bold: true
      shadow: true
    }
  }
  removed: {
    style: {
      stroke-dash: 5
      opacity: 0.4
      fill: "#F5F5F5" # Gray Padding / Pruned
      stroke: "#9E9E9E"
    }
  }
  annotation_box: {
    shape: rectangle
    style: {
      fill: "#FFFDE7"
      stroke: "#FBC02D"
      font-size: 13
      stroke-dash: 2
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 1: RECURSIVE ARITHMETIC FOLDING
# -----------------------------------------------------------------------------
Step_1: {
  label: "1. Arithmetic Folding Stage"
  
  Comparison: {
    grid-columns: 2
    grid-gap: 80
    
    Before: {
      label: "Input AST (0x00A1)"
      root: "LogicalFilter" {
        class: logical_op
        pred: "BinaryOp (>)" {
          class: expr_op
          lhs: "BinaryOp (+)" {
            class: expr_op
            v1: "Literal(5)" { class: literal }
            v2: "Literal(10)" { class: literal }
          }
          rhs: "Literal(20)" { class: literal }
        }
      }
      
      Trace: |md
        ### Execution Trace
        - **Rule**: `CONST_FOLD_ARITH`
        - **Target**: `BinaryOp(+)` @ depth 2
        - **Reason**: `isStatic(lhs) && isStatic(rhs)`
        - **Eval**: `5 + 10 = 15`
      | { class: annotation_box }
    }

    After: {
      label: "Folded AST (0x00A2)"
      root: "LogicalFilter" {
        class: logical_op
        pred: "BinaryOp (>)" {
          class: expr_op
          lhs: "Literal(15)" { 
            class: [literal; changed]
            tooltip: "Computed constant result"
          }
          rhs: "Literal(20)" { class: literal }
        }
      }
    }
  }
  
  (Comparison.Before.root.pred.lhs -> Comparison.After.root.pred.lhs): "eval(5+10)" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      bold: true
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 2: BOOLEAN SIMPLIFICATION
# -----------------------------------------------------------------------------
Step_2: {
  label: "2. Boolean Simplification Stage"

  Comparison: {
    grid-columns: 2
    grid-gap: 80
    
    Before: {
      label: "Pre-Simplification"
      root: "LogicalFilter" {
        class: logical_op
        pred: "BinaryOp (>)" {
          class: expr_op
          lhs: "Literal(15)" { class: literal }
          rhs: "Literal(20)" { class: literal }
        }
      }
    }

    After: {
      label: "Logical Reduction"
      root: "LogicalFilter" {
        class: logical_op
        pred: "Literal(False)" { 
          class: [literal; changed]
          tooltip: "Static analysis: constant comparison result"
        }
      }
      
      Trace: |md
        ### Logic Reduction
        - **Rule**: `REDUCE_COMPARISON`
        - **Comparison**: `15 > 20`
        - **Result**: `Boolean(False)`
        - **Complexity**: `O(1)`
      | { class: annotation_box }
    }
  }

  (Comparison.Before.root.pred -> Comparison.After.root.pred): "Reduce Predicate" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      bold: true
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 3: BRANCH PRUNING (DEAD CODE ELIMINATION)
# -----------------------------------------------------------------------------
Step_3: {
  label: "3. Dead Code Elimination (Pruning)"

  Comparison: {
    grid-columns: 2
    grid-gap: 80
    
    Before: {
      label: "Contradictory Plan"
      root: "LogicalFilter" {
        class: logical_op
        pred: "Literal(False)" { class: literal }
        child: "LogicalScan(users)" {
          class: [logical_op; removed]
        }
      }
      root -> root.child: "Data Flow (Unreachable)" { style.stroke-dash: 5 }
    }

    After: {
      label: "Final Physical Plan"
      root: "EmptyRelation" {
        class: [logical_op; changed]
        tooltip: "Zero-cost operator replacing subtree"
      }
      
      Trace: |md
        ### Subtree Pruning
        - **Optimizer**: `PruningOptimizer`
        - **Trigger**: `Filter.Predicate == False`
        - **Action**: Drop scan; inject `EmptyRelation`
        - **Savings**: `O(TotalRows)` I/O removed
      | { class: annotation_box }
    }
  }

  (Comparison.Before.root -> Comparison.After.root): "Prune Tree" {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      bold: true
      animated: true
    }
  }
}

# -----------------------------------------------------------------------------
# FLOW & IMPLEMENTATION
# -----------------------------------------------------------------------------
Step_1 -> Step_2: "AST Transformation"
Step_2 -> Step_3: "Logical Simplification"

Implementation_Logic: |md
  ## Optimizer Implementation (Go)
  go
  // Core optimization loop
  func Optimize(n Node) Node {
      // 1. Recursive Constant Folding
      n = ConstantFolder(n)
      
      // 2. Boolean Logic Reduction
      n = BooleanReducer(n)
      
      // 3. Subtree Pruning Logic
      if f, ok := n.(*LogicalFilter); ok {
          if lit, ok := f.Predicate.(*Literal); ok {
              if lit.Value == false {
                  // Eliminate unreachable data path
                  return &EmptyRelation{Schema: f.Schema()}
              }
          }
      }
      return n
  }
  
| {
  near: bottom-left
  style.font-size: 14
}

Global_Legend: {
  label: "Operator Legend"
  L1: "Logical Operator" { class: logical_op }
  L2: "Expression Node" { class: expr_op }
  L3: "Literal Value" { class: literal }
  L4: "CHANGED/FOLDED" { class: changed }
  L5: "PRUNED/GRAYED" { class: removed }
  
  near: top-right
}

# Size and Metadata Annotation
Metadata: |md
  ### Analysis Metrics
  - **Optimizer Rule**: `rules/const_fold.go`
  - **Tree Traversal**: Post-Order (Bottom-Up)
  - **Memory Usage**: `O(D)` where D = tree depth
  - **Constraint**: Literal values must be deterministic
| {
  near: bottom-right
  style.stroke: orange
  style.fill: "#FFF3E0"
}