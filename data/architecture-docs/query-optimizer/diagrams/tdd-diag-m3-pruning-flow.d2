direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    sketch: false
    pad: 20
  }
}

title: |md
  # ALGORITHM: TOP-DOWN PROJECTION PRUNING
  **Logic: Minimizing Tuple Width by Propagating Column Requirements**
  *Implementation Spec v1.0.6 - Memory-Efficient Optimizer Pipeline*
| {near: top-center}

# --- Global Style Classes ---
classes: {
  logical_op: {
    style: {
      stroke-width: 3
      border-radius: 8
      shadow: true
      fill: "#ffffff"
    }
  }
  req_box: {
    style: {
      font: mono
      fill: "#eef2ff"
      stroke: "#4f46e5"
      stroke-width: 2
      border-radius: 4
    }
  }
  added_col: {
    style: {
      font-color: "#e11d48"
      bold: true
    }
  }
  header_text: {
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  physical_table: {
    style: {
      stroke: "#334155"
      stroke-width: 2
    }
  }
}

# --- State Legend ---
legend: {
  near: top-right
  required: "Required Set (Cumulative)" {
    style: {
      stroke: "#2ecc71"
      stroke-width: 2
      fill: "#e8f8f5"
    }
  }
  addition: "Newly Injected Column" {
    style: {
      font-color: "#e11d48"
      bold: true
    }
  }
  pruned: "Pruned Field (Dropped)" {
    style: {
      opacity: 0.4
      stroke-dash: 3
      fill: "#f1f5f9"
    }
  }
}

# --- Optimizer Hierarchy (Logical Flow) ---

optimizer_tree: {
  root: {
    label: "STEP 1: QUERY ROOT (Sink)"
    class: logical_op
    
    meta: "Output Schema: [name, total]"
    
    req: "REQUIRED_SET: { name, total }" {
      class: req_box
    }
  }

  project: {
    label: "STEP 2: LOGICAL PROJECT"
    class: logical_op
    
    expr: "total := price * tax"
    
    req: "REQUIRED_SET: { name, **price**, **tax** }" {
      class: req_box
      style.font-color: "#e11d48"
    }
    
    note: "Pop: total | Push: price, tax"
  }

  filter: {
    label: "STEP 3: LOGICAL FILTER"
    class: logical_op
    
    predicate: "WHERE user_id > 100"
    
    req: "REQUIRED_SET: { name, price, tax, **user_id** }" {
      class: req_box
      style.font-color: "#e11d48"
    }
  }

  join: {
    label: "STEP 4: LOGICAL JOIN (HashJoin)"
    class: logical_op
    
    on: "ON users.id = orders.u_id"
    
    split: {
      direction: right
      l_stream: "L_PROBE: {name, user_id, **id**}" {
        style: {
          stroke: "#3498db"
          fill: "#f0f9ff"
          font: mono
        }
      }
      r_stream: "R_BUILD: {price, tax, **u_id**}" {
        style: {
          stroke: "#e67e22"
          fill: "#fff7ed"
          font: mono
        }
      }
    }
  }
}

# --- Physical Layer: Memory Layouts ---

scans: {
  grid-columns: 2
  grid-gap: 80
  
  user_scan: {
    label: "PHYSICAL SCAN: USERS_TABLE (0x00 - 0x58)"
    shape: sql_table
    class: physical_table
    style.fill: "#f8fafc"
    
    # Offsets | Field (Size) | Status
    "0x00": "id (UINT64)" {constraint: "FETCH [8B]"; style.fill: "#3498db"; style.font-color: white}
    "0x08": "name (VARCHAR)" {constraint: "FETCH [32B]"; style.fill: "#3498db"; style.font-color: white}
    "0x28": "email (VARCHAR)" {label: "email (PRUNED)"; style.opacity: 0.3}
    "0x48": "age (INT32)" {label: "age (PRUNED)"; style.opacity: 0.3}
    "0x4C": "user_id (UINT32)" {constraint: "FETCH [4B]"; style.fill: "#3498db"; style.font-color: white}
    "0x50": "padding (8B)" {style.fill: "#cbd5e1"}
    
    footer: "ACTIVE TUPLE: 44 bytes | IO_SAVED: 36 bytes" {
      style.fill: "#ecfdf5"
      style.stroke: "#10b981"
    }
  }

  order_scan: {
    label: "PHYSICAL SCAN: ORDERS_TABLE (0x00 - 0x30)"
    shape: sql_table
    class: physical_table
    style.fill: "#f8fafc"
    
    # Offsets | Field (Size) | Status
    "0x00": "u_id (UINT32)" {constraint: "FETCH [4B]"; style.fill: "#e67e22"; style.font-color: white}
    "0x04": "price (FLOAT64)" {constraint: "FETCH [8B]"; style.fill: "#e67e22"; style.font-color: white}
    "0x0C": "tax (FLOAT64)" {constraint: "FETCH [8B]"; style.fill: "#e67e22"; style.font-color: white}
    "0x14": "timestamp (INT64)" {label: "ts (PRUNED)"; style.opacity: 0.3}
    "0x1C": "pkg_id (INT32)" {label: "pkg_id (PRUNED)"; style.opacity: 0.3}
    "0x20": "metadata (16B)" {label: "meta (PRUNED)"; style.opacity: 0.3}
    
    footer: "ACTIVE TUPLE: 20 bytes | IO_SAVED: 28 bytes" {
      style.fill: "#ecfdf5"
      style.stroke: "#10b981"
    }
  }
}

# --- Metadata Overlays ---
cache_line: "⚠️ 64-BYTE CACHE LINE BOUNDARY" {
  shape: text
  style.font-size: 11
  style.font-color: "#e11d48"
  style.bold: true
  near: bottom-left
}

# --- Data & Control Flow Connections ---

optimizer_tree.root -> optimizer_tree.project: "1. ANALYZE REQ: {name, total}" {
  style: {
    stroke-width: 4
    animated: true
    stroke: "#6366f1"
  }
}

optimizer_tree.project -> optimizer_tree.filter: "2. EXPAND REQ: {name, price, tax}" {
  style.stroke-dash: 3
}

optimizer_tree.filter -> optimizer_tree.join: "3. EXPAND REQ: {name, price, tax, user_id}" {
  style.stroke-dash: 3
}

optimizer_tree.join.split.l_stream -> scans.user_scan: "PUSH REQ: {id, name, user_id}" {
  style: {
    stroke: "#3498db"
    stroke-width: 3
    animated: true
  }
}

optimizer_tree.join.split.r_stream -> scans.order_scan: "PUSH REQ: {u_id, price, tax}" {
  style: {
    stroke: "#e67e22"
    stroke-width: 3
    animated: true
  }
}

# --- Annotations ---

explain: |md
  ### TOP-DOWN PRUNING MECHANICS
  The optimizer performs a depth-first traversal of the logical tree, carrying a "Required Columns" set downwards.
  
  **Implementation Impacts:**
  1. **IO Efficiency**: Only marked `[FETCH]` bytes are loaded into the buffer pool from the storage layer.
  2. **Memory Density**: Optimized tuples (20-44B) increase cache-line occupancy versus raw tuples (80B+).
  3. **Zero-Copy**: Projection happens at the Physical Scan layer, avoiding mid-pipeline re-materialization.
| {
  shape: rectangle
  near: optimizer_tree.filter
  style: {
    stroke: "#1e293b"
    fill: "#ffffff"
    stroke-width: 2
    double-border: true
  }
}

# --- Technical Overlays & Arrow Styling ---

(optimizer_tree.root -> optimizer_tree.project)[0].target-arrowhead: * {
  shape: arrow
  style.filled: true
}

(optimizer_tree.join.split.l_stream -> scans.user_scan)[0].source-arrowhead: * {
  label: "PROBE_SIDE"
  style.font-size: 10
}

(optimizer_tree.join.split.r_stream -> scans.order_scan)[0].source-arrowhead: * {
  label: "BUILD_SIDE"
  style.font-size: 10
}

# Note on pruning logic to replace the illegal self-connection
pruning_note: "Pruning logic identifies contiguous ranges in [0x28 - 0x4C] for skip-scan if supported by hardware." {
  shape: text
  style.font-size: 10
  style.italic: true
  near: scans.user_scan
}