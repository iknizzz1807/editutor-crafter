layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# GLOBAL CLASSES (Intel Manual Quality Styles)
# -----------------------------------------------------------------------------
classes: {
  operator: {
    style: {
      stroke-width: 2
      border-radius: 4
      font-size: 14
    }
  }
  logical_op: {
    style: {
      fill: "#E1D5E7"
      stroke: "#9673A6"
    }
  }
  scan_op: {
    style: {
      fill: "#D5E8D4"
      stroke: "#82B366"
    }
  }
  filter_op: {
    style: {
      fill: "#FFF2CC"
      stroke: "#D6B656"
    }
  }
  changed_state: {
    style: {
      stroke: "#FF0000"
      stroke-width: 5
      bold: true
      font-color: "#FF0000"
      shadow: true
    }
  }
  annotation: {
    shape: rectangle
    style: {
      fill: "#F8CECC"
      stroke: "#B85450"
      stroke-dash: 2
      opacity: 0.9
    }
  }
  data_flow: {
    style: {
      stroke-width: 2
      font-size: 12
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 1: UNOPTIMIZED LOGICAL PLAN
# -----------------------------------------------------------------------------
Transformation_Step_1: {
  label: "STEP 1: UNOPTIMIZED LOGICAL PLAN (Late Predicate Evaluation)"
  style: {
    fill: "#F9F9F9"
    stroke-width: 2
    stroke-dash: 5
  }
  
  Project: LogicalProject {
    class: [operator; logical_op]
    label: "LogicalProject\nCOLUMNS: [u.name, o.id]"
  }

  Filter: LogicalFilter {
    class: [operator; filter_op]
    label: "LogicalFilter\nPREDICATE: country = 'Iceland'"
  }

  Join: LogicalJoin {
    class: [operator; logical_op]
    label: "LogicalJoin (INNER)\nON: u.id = o.user_id"
  }

  Scan_Users: LogicalScan {
    class: [operator; scan_op]
    label: "LogicalScan (Table: users)\nCARDINALITY: 1,000,000"
  }

  Scan_Orders: LogicalScan {
    class: [operator; scan_op]
    label: "LogicalScan (Table: orders)\nCARDINALITY: 1,000,000"
  }

  # Execution Flow Routing
  Project -> Filter: "1.0M rows" {class: data_flow}
  Filter -> Join: "1.0M rows" {class: data_flow}
  Join -> Scan_Users: "Probe (Left)" {class: data_flow}
  Join -> Scan_Orders: "Build (Right)" {class: data_flow}

  Analysis: |md
    ### PLAN ANALYSIS (STEP 1)
    - **Bottleneck:** The Join operator processes **1,000,000 rows** from both relations.
    - **Resource Usage:** High memory for Join Hash Table (1M entries).
    - **Inefficiency:** Non-Icelandic users are joined and then immediately discarded by the Filter.
  | {
    class: annotation
  }
}

# -----------------------------------------------------------------------------
# STEP 2: PREDICATE PUSHDOWN APPLIED
# -----------------------------------------------------------------------------
Transformation_Step_2: {
  label: "STEP 2: OPTIMIZED LOGICAL PLAN (Pushdown Transformation)"
  style: {
    fill: "#F0FFF0"
    stroke-width: 3
    double-border: true
  }

  Project: LogicalProject {
    class: [operator; logical_op]
    label: "LogicalProject\nCOLUMNS: [u.name, o.id]"
  }

  Join: LogicalJoin {
    class: [operator; logical_op]
    label: "LogicalJoin (INNER)\nON: u.id = o.user_id"
  }

  Filter: LogicalFilter {
    class: [operator; filter_op; changed_state]
    label: "LogicalFilter\ncountry = 'Iceland'\n[STATUS: PUSHED]"
  }

  Scan_Users: LogicalScan {
    class: [operator; scan_op]
    label: "LogicalScan (Table: users)\nCARDINALITY: 1,000,000"
  }

  Scan_Orders: LogicalScan {
    class: [operator; scan_op]
    label: "LogicalScan (Table: orders)\nCARDINALITY: 1,000,000"
  }

  # Optimized Execution Flow Routing
  Project -> Join: "1,000 rows" {
    style: {
      stroke: "#2E75B6"
      stroke-width: 4
      bold: true
    }
  }
  
  Join -> Filter: "REDUCED INPUT (L)" {
    style: {
      stroke: "#FF0000"
      stroke-width: 4
      bold: true
      animated: true
    }
  }
  
  Filter -> Scan_Users: "Filtered Scan" {class: data_flow}
  Join -> Scan_Orders: "Right Child" {class: data_flow}

  Results: |md
    ### OPTIMIZATION RESULTS (STEP 2)
    - **Pushdown Rule:** Filter moved below Join based on attribute ownership (`users.country`).
    - **Cardinality Reduction:** Input to Join reduced from **1M** to **1,000** rows.
    - **Performance Gain:** 99.9% reduction in join complexity and memory buffer.
  | {
    class: annotation
  }
}

# -----------------------------------------------------------------------------
# TRANSITIONS AND GLOBAL LEGEND
# -----------------------------------------------------------------------------

Transformation_Step_1 -> Transformation_Step_2: "Transformation Rule: PushPredicateThroughJoin" {
  style: {
    stroke: "#2E75B6"
    stroke-width: 6
    animated: true
  }
}

Global_Legend: {
  label: "Query Optimizer Legend"
  near: bottom-right
  
  Logical_Op: "Logical Operator" { 
    class: [operator; logical_op]
  }
  Filter_Op: "Predicate/Filter" { 
    class: [operator; filter_op]
  }
  Scan_Op: "Table Scan (I/O)" { 
    class: [operator; scan_op] 
  }
  Change_Indicator: "Optimized / Pushed" { 
    class: [operator; filter_op; changed_state] 
  }
}