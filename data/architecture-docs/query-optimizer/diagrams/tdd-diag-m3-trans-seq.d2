direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

# ---------------------------------------------------------------------------------------
# RECURSIVE RULE APPLICATION SEQUENCE: PREDICATE PUSHDOWN
# ---------------------------------------------------------------------------------------
# Technical Goal: Illustrate Fixed-Point Iteration, Bottom-Up Recursion, and 
# node-swapping logic for Query Optimizer Milestone 3.
# ---------------------------------------------------------------------------------------

Recursive_Optimization_Process: {
  shape: sequence_diagram

  # Participants with Explicit Type Definitions
  Engine: QueryOptimizer {
    shape: person
    tooltip: "The main Fixed-Point Iteration Controller (C++17 Singleton)"
  }
  Rule: PushdownPredicateRule {
    style: {
      fill: "#E4DBFE"
      stroke: "#6A5ACD"
      stroke-width: 2
    }
    tooltip: "Implements RewriteRule interface"
  }
  Node: LogicalPlanNode {
    tooltip: "Target Pattern: LogicalFilter(child=LogicalJoin)"
    style.fill: "#C7F1FF"
  }
  Resolver: SchemaResolver {
    style.stroke-dash: 3
    tooltip: "Validates column availability in subtrees via Catalog lookup"
  }
  User: SQLClient {
    shape: person
  }

  # 1. Entry Point
  Engine -> Engine: "optimize(root: LogicalPlan*): LogicalPlan*" {
    tooltip: "Entry point for optimization phase. Complexity: O(N * Rules)"
  }
  
  Engine."STATE: [Iterations=0, Changed=False, Root=0x4A2F]"

  # 2. Iteration Wrapper (Fragment)
  Iteration_Loop: {
    label: "Fixed-Point Loop (Max=100 Iterations)"
    
    Engine -> Engine: "set_changed(false)"
    
    # Start of recursive rule application
    Engine -> Rule.apply: "apply(node: LogicalPlan*): RuleResult" 
    
    # Internal Recursion (Bottom-Up Implementation)
    Rule.apply -> Rule.recurse: "apply(node.child): RuleResult" 
    Rule.recurse."INVARIANT: Subtrees are fully\nsimplified (Fixed-Point reached)\nbefore current node eval"
      
    # Pattern Matching Logic
    Rule.apply -> Node: "match(NodeType::LogicalFilter) -> bool"
    Node -> Rule.apply: "MATCH_SUCCESS" {
      style.font-color: "#167c3c"
      style.bold: true
    }
      
    Rule.apply -> Node: "child.match(NodeType::LogicalJoin) -> bool"
    Node -> Rule.apply: "MATCH_SUCCESS"
      
    # Extraction & Analysis
    Rule.apply -> Rule.apply: "split_conjunctions(Expression* pred): vector<Expr*>"
    Rule.apply."Decompose Filter into\n[PushableToLeft, PushableToRight, NonPushable]"
      
    Rule.apply -> Resolver: "get_schema(join.left): const Schema&"
    Resolver -> Rule.apply: "ColumnSet{0, 1, 4, 12} // ID, Name, DeptID"
      
    Rule.apply -> Rule.apply: "can_push(Expr* e, const Schema& s): bool"
      
    # Success Case Fragment
    Pushdown_Success: {
      label: "Node Transformation (Pointer Swapping/Atomic Update)"
      
      Rule.apply -> Node: "new LogicalFilter(join.left, pushable_expr)"
      Node -> Rule.apply: "filter_prime: LogicalFilter*"
        
      Rule.apply -> Node: "join.set_left(filter_prime)" {
        style: {
          stroke: "#167c3c"
          stroke-width: 3
        }
        tooltip: "Update parent pointer to new Filter node"
      }
        
      Rule.apply -> Engine: "RuleResult(new_root=join, changed=true)" {
        style: {
          font-color: "#167c3c"
          bold: true
        }
      }
    }
    
    # State Update
    Engine -> Engine: "update_plan_state(result.node, result.changed)"
    Engine."STATE: [Changed=True, Iteration++]"
  }

  # 3. Completion
  Engine -> Engine: "loop_until(changed == false || max_iters)"
  Engine."CONVERGENCE: Plan stable (Fixed-Point)"

  Engine -> User: "return optimized_root: LogicalPlan*" {
    style.stroke: "#167c3c"
  }
}

# ---------------------------------------------------------------------------------------
# IMPLEMENTATION MANUAL
# ---------------------------------------------------------------------------------------
Implementation_Manual: |md
  ### Phase 3: Recursive Rewrite Logic Implementation Details
  
  **1. Fixed-Point Iteration (Convergence)**
  The `RuleEngine` continues applying the set of rules until no rule reports a `changed=true` status. This allows cascading optimizations (e.g., *Constant Folding* enabling a *Predicate Pushdown*).
  
  **2. Pattern Matching Protocol**
  Rules must be idempotent. The pattern match `Filter(Join(L, R))` is checked via type-erasure safe visitors or `NodeType` enum checks.
  
  **3. Recursive Descent (Bottom-Up)**
  Rule application must be recursive. By calling `apply(node.child)` before evaluating the current `node`, we ensure that deep nested subqueries are simplified before the parent attempts to re-route predicates.
  
  **4. Schema Safety (M3.4)**
  The `SchemaResolver` is critical. A filter can only be pushed into a `Join` branch if all identifiers referenced in the expression are present in that branch's output schema.
| {
  near: bottom-center
  style: {
    font-size: 14
    fill: "#F5F5F5"
    stroke: "#D3D3D3"
  }
}

# ---------------------------------------------------------------------------------------
# LEGEND AND COMPONENT SPECIFICATIONS
# ---------------------------------------------------------------------------------------
Sequence_Legend: {
  near: top-right
  grid-columns: 1
  style.stroke: "#6A5ACD"
  
  Match_Success: {
    label: "Pattern Match & Push Success"
    style: {
      stroke: "#167c3c"
      stroke-width: 4
      fill: "#EFFFFF"
    }
  }
  
  Recursion_Call: {
    label: "Deep Recursive Call (Bottom-Up)"
    style: {
      stroke-dash: 5
      fill: "#F5F5F5"
    }
  }
  
  Engine_Configuration: {
    label: "Fixed-Point Limit: 100 Iterations\nSafety Timeout: 500ms"
    shape: callout
    style: {
      fill: "#FFF9C9"
      stroke: "#E6DB74"
    }
  }
  
  Memory_Layout_Note: {
    label: "LogicalFilter Node Layout (Size: 48B)\n+00 [8B] vtable_ptr\n+08 [8B] child_ptr (LogicalPlanNode*)\n+16 [8B] predicate_ptr (Expression*)\n+24 [8B] schema_ptr (Schema*)\n+32 [8B] cost_estimate (double)\n+40 [8B] metadata_map (shared_ptr)"
    shape: rectangle
    style: {
      font: mono
      fill: "#DEE1EB"
      font-size: 12
    }
  }
}

# Global Styling
***.style.font-size: 16
Recursive_Optimization_Process.Iteration_Loop.style.fill: "#FDF4FF"
Recursive_Optimization_Process.Pushdown_Success.style.fill: "#ECFDF5"