    style.font-color: "#f1f5f9"
  }
  size1: "Size 1 (Singles): 4 subsets (4 choose 1)" {
    shape: text
    style.font-color: "#60a5fa"
  }
  size2: "Size 2 (Pairs): 6 subsets (4 choose 2)" {
    shape: text
    style.font-color: "#a78bfa"
  }
  size3: "Size 3 (Triples): 4 subsets (4 choose 3)" {
    shape: text
    style.font-color: "#34d399"
  }
  size4: "Size 4 (All): 1 subset (4 choose 4)" {
    shape: text
    style.font-color: "#f87171"
  }
  total: "TOTAL: 15 = 2^4 - 1" {
    shape: text
    style.bold: true
    style.font-color: "#fbbf24"
    style.font-size: 14
  }
  count_label -> size1 -> size2 -> size3 -> size4 -> total
}
