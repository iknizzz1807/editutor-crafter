# Algorithm pseudocode panel
algorithm: {
  label: "Enumeration Algorithm"
  shape: rectangle
  style.fill: "#1e293b"
  style.stroke: "#475569"
  style.border-radius: 8
  code: {
    shape: code
    language: python
    style.fill: "#0f172a"
    style.font-color: "#e2e8f0"
    """
    def enumerate_subsets(tables):
        n = len(tables)
        all_subsets = []
        # Process by increasing size
        for size in range(1, n + 1):
            for subset in combinations(tables, size):
                all_subsets.append(subset)
                # DP: try all bipartitions
                for k in range(1, size):
                    for left in combinations(subset, k):
                        right = subset - left
                        cost = dp[left] + dp[right] + join_cost
                        if cost < best[subset]:
                            best[subset] = cost
        return all_subsets  # 2^n - 1 subsets
    """
  }
}
# Statistics panel
stats: {
  shape: rectangle
