vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # DP Table Filling Process
  ## Selinger Algorithm: Subset Enumeration & Plan Combination
| {near: top-center}

# Legend - Positioned at Root
legend: {
  near: bottom-left
  legend_entry: |md
    **Color Key:**
    🟣 Purple: Size 1 (Single tables)
    🔵 Blue: Size 2 (Two-table joins)
    🟢 Green: Size 3 (Three-table joins)
    🔴 Red: Size 4 (Full join / Result)
    
    **Arrow Types:**
    ──▶ Combine to form larger subset
    ──▶ DP state transition
  |
}

# -----------------------------------------------------------------------------
# MAIN DP LATTICE
# -----------------------------------------------------------------------------

# Size 1: Single Table Initialization
size1_container: {
  label: "SIZE 1: Single Tables (Base Cases)"
  style.fill: "#E8D5E8"
  style.stroke: "#8B5A8B"
  style.stroke-width: 2
  
  table_a: "{A}" {
    shape: rectangle
    style.fill: "#D4A5D4"
    style.stroke: "#8B5A8B"
  }
  table_b: "{B}" {
    shape: rectangle
    style.fill: "#D4A5D4"
    style.stroke: "#8B5A8B"
  }
  table_c: "{C}" {
    shape: rectangle
    style.fill: "#D4A5D4"
    style.stroke: "#8B5A8B"
  }
  table_d: "{D}" {
    shape: rectangle
    style.fill: "#D4A5D4"
    style.stroke: "#8B5A8B"
  }
}

# Size 2: Two-Table Joins
size2_container: {
  label: "SIZE 2: Two-Table Subsets"
  style.fill: "#D5E8FF"
  style.stroke: "#5A7BA8"
  style.stroke-width: 2
  
  ab: "{A,B}" { style.fill: "#A5C6D4"; style.stroke: "#5A7BA8" }
  ac: "{A,C}" { style.fill: "#A5C6D4"; style.stroke: "#5A7BA8" }
  ad: "{A,D}" { style.fill: "#A5C6D4"; style.stroke: "#5A7BA8" }
  bc: "{B,C}" { style.fill: "#A5C6D4"; style.stroke: "#5A7BA8" }
  bd: "{B,D}" { style.fill: "#A5C6D4"; style.stroke: "#5A7BA8" }
  cd: "{C,D}" { style.fill: "#A5C6D4"; style.stroke: "#5A7BA8" }
}

# Size 3: Three-Table Joins
size3_container: {
  label: "SIZE 3: Three-Table Subsets"
  style.fill: "#D5FFD5"
  style.stroke: "#5A8B5A"
  style.stroke-width: 2
  
  abc: "{A,B,C}" { style.fill: "#A5D4A5"; style.stroke: "#5A8B5A" }
  abd: "{A,B,D}" { style.fill: "#A5D4A5"; style.stroke: "#5A8B5A" }
  acd: "{A,C,D}" { style.fill: "#A5D4A5"; style.stroke: "#5A8B5A" }
  bcd: "{B,C,D}" { style.fill: "#A5D4A5"; style.stroke: "#5A8B5A" }
}

# Size 4: Full Join
size4_container: {
  label: "SIZE 4: Full Join (Final Solution)"
  style.fill: "#FFE8E8"
  style.stroke: "#8B5A5A"
  style.stroke-width: 3
  
  abcd: "{A,B,C,D}\n★ OPTIMAL" {
    shape: rectangle
    style.fill: "#D4A5A5"
    style.stroke: "#8B5A5A"
    style.stroke-width: 3
    style.bold: true
  }
}

# -----------------------------------------------------------------------------
# TRANSITIONS (DP STATE COMBINATIONS)
# -----------------------------------------------------------------------------

# Size 1 -> Size 2 (Pairwise)
size1_container.table_a -> size2_container.ab: "Join(A,B)"
size1_container.table_b -> size2_container.ab
size1_container.table_a -> size2_container.ac: "Join(A,C)"
size1_container.table_c -> size2_container.ac
size1_container.table_b -> size2_container.bc: "Join(B,C)"
size1_container.table_c -> size2_container.bc
size1_container.table_c -> size2_container.cd: "Join(C,D)"
size1_container.table_d -> size2_container.cd

# Size 2 -> Size 3 (Augmentation)
size2_container.ab -> size3_container.abc: "Join({A,B}, C)"
size1_container.table_c -> size3_container.abc
size2_container.ac -> size3_container.abc: "Join({A,C}, B)"
size1_container.table_b -> size3_container.abc

size2_container.bc -> size3_container.bcd: "Join({B,C}, D)"
size1_container.table_d -> size3_container.bcd

# Size 3 -> Size 4 (Completion)
size3_container.abc -> size4_container.abcd: "Join({A,B,C}, D)"
size1_container.table_d -> size4_container.abcd
size2_container.ab -> size4_container.abcd: "Join({A,B}, {C,D})"
size2_container.cd -> size4_container.abcd

# -----------------------------------------------------------------------------
# SUPPLEMENTARY DATA & METADATA
# -----------------------------------------------------------------------------

# DP Table Entry Internal Layout
dp_table_detail: {
  near: bottom-right
  label: "Physical DP Entry Layout"
  
  entry: {
    shape: sql_table
    style.fill: "#F5F5F5"
    
    0x00: "subset_bitmask [4-bit]" {constraint: "ID"}
    0x04: "cost [double]" {constraint: "MinCost"}
    0x0C: "left_child_ptr [pointer]" {constraint: "PlanTree"}
    0x14: "right_child_ptr [pointer]" {constraint: "PlanTree"}
    0x1C: "join_method_id [uint8]" {constraint: "Hash/NL/Merge"}
    0x1D: "output_sort_order [enum]" {constraint: "Prop"}
  }
  
  metadata: |md
    **Invariants:**
    - Entry `E[subset]` stores only the cheapest plan for `subset`.
    - If multiple plans have same cost, prioritize by `interesting orders`.
  | {shape: text}
}

# Algorithm Execution Flow
algorithm_steps: {
  near: top-left
  label: "Phase Pipeline"
  style.fill: "#F0F0F0"
  
  step1: "1. Init S1" { style.fill: "#E8D5E8" }
  step2: "2. Enumerate S=2..N" { style.fill: "#D5E8FF" }
  step3: "3. Prune Plans" { style.fill: "#D5FFD5" }
  step4: "4. Return S=N" { style.fill: "#FFE8E8" }
  
  step1 -> step2 -> step3 -> step4: {style.stroke-dash: 3}
}

# Complexity Analysis
complexity_info: {
  near: bottom-center
  label: "Resource Estimation"
  style.fill: "#FFFEE0"
  
  analysis: |md
    **Search Space:**
    - Subsets Enumerated: $2^n - 1$
    - Time Complexity (Bushy): $O(3^n)$
    - Time Complexity (Linear): $O(n \cdot 2^n)$
    
    **For n=4:**
    - 15 DP Slots
    - ~50 Plan combinations costed
  | {shape: text}
}

# Lattice Level Connections (Structural Hints)
size1_container -> size2_container: "Level 1 Processing" {style.stroke-width: 2; style.stroke: "#666666"}
size2_container -> size3_container: "Level 2 Processing" {style.stroke-width: 2; style.stroke: "#666666"}
size3_container -> size4_container: "Level 3 Processing" {style.stroke-width: 2; style.stroke: "#666666"}