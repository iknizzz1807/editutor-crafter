direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Query Optimizer: Join Tree Shape Physical Layouts"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

# Implementation-grade style definitions
classes: {
  join_node: {
    shape: diamond
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      bold: true
    }
    tooltip: "Binary Join Operator (e.g., HashJoin, NestedLoop)"
  }
  base_table: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    tooltip: "Base Relation Scan"
  }
  subjoin: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
}

# LEFT-DEEP TREE (Linear Join)
left_deep_container: {
  label: "Left-Deep Join Tree (Linear Search Space)"
  style: {
    fill: "#FAFAFA"
    stroke: "#1565C0"
    stroke-width: 3
  }
  
  annotation: {
    label: |md
      **Invariants:**
      - Right child is ALWAYS a base table scan.
      - Enables pipelined execution (Left = Probe, Right = Build).
      - Memory: O(n) stack depth for nested loops.
    |
    shape: rectangle
    style: {
      font-size: 14
      italic: true
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-dash: 2
    }
  }

  # Root join
  J1: {
    label: "⋈₁\n[0x40B2]"
    class: join_node
  }
  
  # Level 1
  J2: {
    label: "⋈₂\n[0x40C8]"
    class: join_node
  }
  R: {
    label: "Relation R\n(Build Input)"
    class: base_table
  }

  # Level 2
  J3: {
    label: "⋈₃\n[0x40D4]"
    class: join_node
  }
  S: {
    label: "Relation S\n(Build Input)"
    class: base_table
  }

  # Base tables at leaf
  T: {
    label: "Relation T\n(Outer)"
    class: base_table
  }
  U: {
    label: "Relation U\n(Inner)"
    class: base_table
  }

  # Physical Pointers
  J1 -> J2: {label: "leftChild*"; style.stroke: "#1565C0"}
  J1 -> R: {label: "rightChild* (Base)"; style.stroke: "#2E7D32"; style.stroke-dash: 3}
  J2 -> J3: {label: "leftChild*"; style.stroke: "#1565C0"}
  J2 -> S: {label: "rightChild* (Base)"; style.stroke: "#2E7D32"; style.stroke-dash: 3}
  J3 -> T: {label: "leftChild*"; style.stroke: "#1565C0"}
  J3 -> U: {label: "rightChild* (Base)"; style.stroke: "#2E7D32"; style.stroke-dash: 3}
}

# BUSHY TREE (Non-Linear Join)
bushy_container: {
  label: "Bushy Join Tree (Full Search Space)"
  style: {
    fill: "#FAFAFA"
    stroke: "#E65100"
    stroke-width: 3
  }

  annotation: {
    label: |md
      **Invariants:**
      - Arbitrary join combinations.
      - Intermediate results can serve as Build inputs.
      - Necessary for optimal Star/Snowflake schemas.
    |
    shape: rectangle
    style: {
      font-size: 14
      italic: true
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-dash: 2
    }
  }

  # Root join
  BJ1: {
    label: "⋈_Root\n[0x90A1]"
    class: join_node
  }

  # Sub-trees
  BJ2: {
    label: "⋈_LeftSub\n[0x90B2]"
    class: subjoin
  }
  BJ3: {
    label: "⋈_RightSub\n[0x90C4]"
    class: subjoin
  }

  # Leaf tables
  A: { label: "Table A"; class: base_table }
  B: { label: "Table B"; class: base_table }
  C: { label: "Table C"; class: base_table }
  D: { label: "Table D"; class: base_table }

  # Connections - symmetric joins
  BJ1 -> BJ2: {label: "ptr_lhs"; style.stroke: "#E65100"; style.stroke-dash: 3}
  BJ1 -> BJ3: {label: "ptr_rhs"; style.stroke: "#E65100"; style.stroke-dash: 3}
  BJ2 -> A: {style.stroke: "#2E7D32"}
  BJ2 -> B: {style.stroke: "#2E7D32"}
  BJ3 -> C: {style.stroke: "#2E7D32"}
  BJ3 -> D: {style.stroke: "#2E7D32"}
}

# LEGEND & METADATA
legend: {
  label: "Node Metadata Specifications"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"

  join_legend: {
    label: "⋈ (sizeof=128B)\nJoin Header: 16B\nL_Child_Ptr: 8B\nR_Child_Ptr: 8B"
    class: join_node
  }
  table_legend: {
    label: "Base Table Scan\n(Leaf Node)\nStats_Ptr: 8B"
    class: base_table
  }
  subjoin_legend: {
    label: "Intermediate Join\n(Bushy Build Input)"
    class: subjoin
  }
  
  join_legend -- table_legend -- subjoin_legend: {style.opacity: 0}
}

# COMPARISON TABLE
comparison: {
  label: "DP Search Complexity & Hardware Trade-offs"
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  
  left_deep_details: {
    label: |md
      ### Left-Deep Characteristics
      - **DP Search:** $O(2^n \cdot n)$ states
      - **Instruction Cache:** High locality (linear traversal)
      - **Parallelism:** Inter-operator pipeline
      - **Optimizer Cost:** Low memory overhead
    |
    shape: rectangle
    style.fill: "#E3F2FD"
  }
  
  bushy_details: {
    label: |md
      ### Bushy Characteristics
      - **DP Search:** $O(3^n)$ or $O(2^n \cdot n^2)$ states
      - **Instruction Cache:** Lower locality (recursion)
      - **Parallelism:** Intra-tree independent joins
      - **Optimizer Cost:** High DP table memory
    |
    shape: rectangle
    style.fill: "#FFF3E0"
  }
  
  left_deep_details <-> bushy_details: {
    label: "Cost vs Flex"
    style.stroke: "#C2185B"
    style.stroke-width: 2
  }
}

# DP COMPLEXITY METRICS
formula_box: {
  label: "Dynamic Programming Table Complexity"
  shape: rectangle
  style.fill: "#EDE7F6"
  style.stroke: "#7B1FA2"
  
  left_formula: {
    label: "Linear Space Complexity: N * 2^(N-1)"
    shape: text
    style: {
      font-size: 16
      fill: "#E3F2FD"
      bold: true
    }
  }
  bushy_formula: {
    label: "Full Space Complexity: (3^N - 2^(N+1) + 1) / 2"
    shape: text
    style: {
      font-size: 16
      fill: "#FFF3E0"
      bold: true
    }
  }
  left_formula -- bushy_formula: {style.opacity: 0}
}

# Structural Alignment
left_deep_container <-> bushy_container: {style.opacity: 0}
legend <-> comparison: {style.opacity: 0}
comparison <-> formula_box: {style.opacity: 0}