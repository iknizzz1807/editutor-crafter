layout-engine: tala
vars: {
  d2-config: {
    layout-engine: tala
    theme-id: 4
    pad: 40
  }
}

title: {
  label: |md
    # Query Optimizer: Join Graph Connectivity Analysis
    ## Detection of Cartesian Products via Disjoint Set Forest / BFS
  |
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# --- STYLING CLASSES ---
classes: {
  table_header: {
    style: {
      fill: "#673AB7"
      font-color: white
      bold: true
    }
  }
  primary_key_col: {
    style: {
      fill: "#E8EAF6"
      stroke: "#3F51B5"
      stroke-width: 2
    }
  }
  foreign_key_col: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-dash: 2
    }
  }
  warning_node: {
    style: {
      fill: "#FFEBEE"
      stroke: "#B71C1C"
      stroke-width: 5
      double-border: true
    }
  }
}

# --- DATA STRUCTURES: COMPONENT 1 ---
component_1: {
  label: "Connected Component Alpha: Operational Store"
  tooltip: "Tables reachable via defined Foreign Key constraints"
  style: {
    stroke: "#4CAF50"
    stroke-width: 4
    fill: "#F1F8E9"
    border-radius: 10
    shadow: true
  }
  
  customers: {
    shape: sql_table
    id: "0x00 | INT64 (8B)" {constraint: primary_key; class: primary_key_col}
    name: "0x08 | VARCHAR(255)"
    email: "0x18 | VARCHAR(255)" {constraint: unique}
    created_at: "0x28 | TIMESTAMP"
  }
  
  orders: {
    shape: sql_table
    id: "0x00 | INT64 (8B)" {constraint: primary_key; class: primary_key_col}
    customer_id: "0x08 | INT64 (8B)" {constraint: foreign_key; class: foreign_key_col}
    order_date: "0x10 | DATE"
    total_cents: "0x18 | INT32"
  }
  
  order_items: {
    shape: sql_table
    id: "0x00 | INT64 (8B)" {constraint: primary_key; class: primary_key_col}
    order_id: "0x08 | INT64 (8B)" {constraint: foreign_key; class: foreign_key_col}
    sku: "0x10 | VARCHAR(64)" {constraint: foreign_key}
    quantity: "0x18 | INT16"
  }
  
  # Join Predicates
  customers.id -- orders.customer_id: "INNER JOIN [c.id = o.customer_id]" {
    style: {
      stroke: "#1A237E"
      stroke-width: 3
    }
  }
  orders.id -- order_items.order_id: "INNER JOIN [o.id = oi.order_id]" {
    style: {
      stroke: "#1A237E"
      stroke-width: 3
    }
  }
}

# --- DATA STRUCTURES: COMPONENT 2 ---
component_2: {
  label: "Connected Component Beta: Analytics Metadata"
  tooltip: "Isolated island; no join path to Component Alpha"
  style: {
    stroke: "#D32F2F"
    stroke-width: 4
    fill: "#FFEBEE"
    border-radius: 10
    shadow: true
  }
  
  product_catalog: {
    shape: sql_table
    sku: "0x00 | VARCHAR(64)" {constraint: primary_key; class: primary_key_col}
    product_name: "0x08 | TEXT"
    category_id: "0x18 | INT32" {class: foreign_key_col}
  }
  
  categories: {
    shape: sql_table
    category_id: "0x00 | INT32" {constraint: primary_key; class: primary_key_col}
    category_name: "0x04 | VARCHAR(100)"
  }
  
  product_catalog.category_id -- categories.category_id: "JOIN [p.cat_id = c.cat_id]" {
    style: {
      stroke: "#1A237E"
      stroke-width: 2
    }
  }
}

# --- DIAGNOSTIC INDICATOR ---
cross_product_indicator: {
  label: "CRITICAL ALERT:\nISOLATED GRAPH ISLANDS\n(CARTESIAN PRODUCT RISK)"
  class: warning_node
  shape: diamond
  icon: https://icons.terrastruct.com/essentials%2F007-warning.svg
}

# Link components to warning to show disconnection
component_1 -- cross_product_indicator: "GRAPH_COMPONENT_ID: 0x01" {
  style: {
    stroke-dash: 5
    stroke: "#D32F2F"
    stroke-width: 2
  }
}

cross_product_indicator -- component_2: "GRAPH_COMPONENT_ID: 0x02" {
  style: {
    stroke-dash: 5
    stroke: "#D32F2F"
    stroke-width: 2
  }
}

# --- ALGORITHM STATE MACHINE ---
algorithm_viz: {
  label: "Optimizer Pass: Component Discovery"
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    border-radius: 5
  }
  
  init: "1. START: FindComponents(QueryGraph G)" {
    shape: circle
    style.fill: "#CFD8DC"
  }
  
  for_each: "2. Iterate v ∈ G.Vertices" {
    shape: parallelogram
    style.fill: "#E1F5FE"
  }
  
  check_visited: "3. v ∈ Visited?" {
    shape: diamond
    style.fill: "#FFF9C4"
  }
  
  traverse: "4. BFS_Traverse(v)\nMark reachable nodes" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  
  finalize: "5. Calculate N_Components" {
    shape: rectangle
  }
  
  check_cross: "6. N_Components > 1?" {
    shape: diamond
    style: {
      fill: "#FFCCBC"
      bold: true
    }
  }
  
  alert: "7. Raise CrossProductWarning" {
    shape: rectangle
    style.fill: "#FFCDD2"
  }
  
  safe: "8. Proceed to Costing" {
    shape: circle
    style.fill: "#A5D6A7"
  }

  init -> for_each
  for_each -> check_visited
  check_visited -> traverse: "False"
  check_visited -> for_each: "True"
  traverse -> for_each
  for_each -> finalize: "End Loop"
  finalize -> check_cross
  check_cross -> alert: "True"
  check_cross -> safe: "False"
}

# --- IMPLEMENTATION & LOGIC BLOCKS ---
implementation: {
  style.stroke-width: 0
  
  # Using multi-pipe block string to safely handle pipes inside code/math
  python_source: {
    label: ||python
      # Engineering Spec: Component Identification for Query Planner
      def check_plan_integrity(nodes: List[TableNode], edges: List[JoinEdge]):
          adj = build_adjacency_list(nodes, edges)
          visited = set()
          islands = []
          
          for node in nodes:
              if node not in visited:
                  # Discovered a new disconnected component
                  current_island = bfs_flood_fill(node, adj, visited)
                  islands.append(current_island)
          
          if len(islands) > 1:
              log.warn("Cartesian Join detected!")
              return Status.UNSAFE_CROSS_PRODUCT
          return Status.OK
    ||
    style: {
      font: mono
      fill: "#263238"
      font-color: "#ECEFF1"
    }
  }
  
  mathematical_proof: {
    label: ||md
      ### Logical Invariant
      Let $G = (V, E)$ be the join graph.
      The total row count of result set $R$ is bounded by:
      $$\prod_{C \in Components(G)} \left( \text{Rows in Component } C \right)$$
      If $|Components(G)| > 1$, the result is a **Cartesian Product**.
    ||
  }
}

# --- POSITIONING ---
implementation.near: component_1
algorithm_viz.near: component_2

legend: {
  label: "Engineering Symbology"
  near: algorithm_viz
  
  pk: "Primary Key Index" {
    class: primary_key_col
  }
  fk: "Foreign Key Ref" {
    class: foreign_key_col
  }
  join_symbol: "Join Predicate (Edge)" {
    style: {
      stroke: "#1A237E"
      stroke-width: 3
    }
  }
}

