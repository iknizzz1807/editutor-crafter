vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# ⚠️ CRITICAL: Classes must be defined at the root scope
classes: {
  build_phase: {
    style: {
      stroke: "#2563eb"
      font-color: "#2563eb"
      stroke-width: 2
      stroke-dash: 0
    }
  }
  probe_phase: {
    style: {
      stroke: "#059669"
      font-color: "#059669"
      stroke-width: 2
      stroke-dash: 0
    }
  }
  data_flow: {
    style: {
      stroke-dash: 4
      stroke: "#6b7280"
    }
  }
  match_event: {
    style: {
      stroke: "#dc2626"
      bold: true
      stroke-width: 3
    }
  }
}

"Hash Join Build/Probe Phases": {
  shape: sequence_diagram
  
  # === PARTICIPANTS (Lifelines) ===
  # Intel-grade technical manual specifications for components
  qe: Query Executor {
    shape: person
    style: {
      fill: "#f3f4f6"
      stroke: "#374151"
    }
  }
  build_input: Build Input {
    shape: cylinder
    label: "Build Input\n(Smaller Table R)"
    tooltip: "Inner relation used to populate the hash table"
    style.fill: "#dbeafe"
  }
  hash_table: Hash Table {
    shape: stored_data
    label: "Hash Table\n(In-Memory)"
    tooltip: "Directory mapping join-key hashes to row pointers"
    style.fill: "#fee2e2"
  }
  probe_input: Probe Input {
    shape: cylinder
    label: "Probe Input\n(Larger Table S)"
    tooltip: "Outer relation used to stream through the hash table"
    style.fill: "#dcfce7"
  }
  out_buffer: Output Buffer {
    shape: queue
    label: "Output Buffer\n(Matches)"
    style.fill: "#fef9c3"
  }

  # === PHASE 1: BUILD PHASE ===
  # Requirement: Step-by-step numbered logic for engineering implementation
  Build_Phase: "BUILD PHASE - Time: O(M), Space: O(M)" {
    qe -> build_input: "1. Scan smaller input (Table R)" { class: build_phase }
    
    # Self-message for iteration
    build_input -> build_input: "2. Read row R_i into memory" { class: build_phase }
    
    # Hash and Store
    build_input -> hash_table: "3. hash(R_i.key) -> bucket_idx" { 
      class: build_phase 
      tooltip: "Compute hash function on join attribute"
    }
    
    hash_table -> hash_table: "4. Store tuple {key, row_ptr} in Bucket" { 
      class: build_phase 
      tooltip: "Handles collisions via chaining or open addressing"
    }
    
    # Loop representation
    build_input -> build_input: "5. Repeat for all M rows in R" { 
      class: build_phase 
      style.stroke-dash: 5
    }
    
    qe <- hash_table: "ACK: Build Complete" { 
      class: build_phase 
      style.stroke-dash: 2
    }
  }

  # === PHASE 2: PROBE PHASE ===
  # High-detail state transition for probing logic
  Probe_Phase: "PROBE PHASE - Time: O(N)" {
    qe -> probe_input: "6. Stream larger input (Table S)" { class: probe_phase }
    
    probe_input -> probe_input: "7. Fetch row S_j" { class: probe_phase }
    
    # Lookup
    probe_input -> hash_table: "8. hash(S_j.key) -> lookup bucket" { 
      class: probe_phase 
      tooltip: "Direct O(1) memory address access"
    }
    
    # Data return path
    hash_table -> probe_input: "9. Return potential matches {R_i...}" { 
      class: data_flow 
    }
    
    # Validation
    probe_input -> probe_input: "10. Binary comparison (Exact Key Match)" { 
      class: probe_phase 
      tooltip: "Eliminate hash collisions"
    }
    
    # Result generation
    probe_input -> out_buffer: "11. Emit JOIN(R_i, S_j) to Results" { 
      class: match_event 
    }
    
    # Loop
    probe_input -> probe_input: "12. Iterate until Table S EOF" { 
      class: probe_phase
      style.stroke-dash: 5
    }
    
    qe <- out_buffer: "ACK: Probe Complete (Stream Closed)" { class: probe_phase }
  }

  # Global summary annotation for technical reference
  qe -> qe: "Algorithm Invariant: Total Cost = O(M + N)" {
    style: {
      stroke: "#7c3aed"
      stroke-width: 4
      bold: true
      font-size: 18
      stroke-dash: 0
    }
  }
}