vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

direction: right

M1_Statistics_Architecture: {
  label: "M1: Statistics Collection Architecture"
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
    font-color: "#C9D1D9"
    stroke-width: 2
  }

  header: {
    shape: rectangle
    label: "Statistics Collection Architecture\nMilestone 1"
    style: {
      fill: "#238636"
      stroke: "#2EA043"
      font-color: "#FFFFFF"
      bold: true
      font-size: 24
    }
  }

  entry_point: {
    shape: rectangle
    label: "ANALYZE Command\nEntry Point"
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
      shadow: true
    }
  }

  analyzer: {
    shape: rectangle
    label: "08_analyzer.py\nStatisticsAnalyzer"
    style: {
      fill: "#1F6FEB"
      stroke: "#388BFD"
      font-color: "#FFFFFF"
    }
    methods: {
      shape: rectangle
      label: "analyze_table(table_name)\ncompute_column_stats(column)\nbuild_histogram(values, buckets)"
      style: {
        fill: "#161B22"
        stroke: "#30363D"
        font-color: "#7EE787"
        font-size: 11
        font: mono
      }
    }
  }

  table_reader: {
    shape: rectangle
    label: "TableReader\n06_table_reader.py"
    style: {
      fill: "#1F6FEB"
      stroke: "#388BFD"
      font-color: "#FFFFFF"
    }
  }

  sample_buffer: {
    shape: rectangle
    label: "Sample Buffer\n(100KB / 1000 rows)"
    style: {
      fill: "#238636"
      stroke: "#2EA043"
      font-color: "#FFFFFF"
      stroke-dash: 3
    }
  }

  histogram_builder: {
    shape: rectangle
    label: "HistogramBuilder\n05_histogram.py"
    style: {
      fill: "#1F6FEB"
      stroke: "#388BFD"
      font-color: "#FFFFFF"
    }
  }

  stats_store: {
    shape: cylinder
    label: "StatisticsStore\n07_stats_store.py"
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
    }
  }

  pg_stats: {
    shape: cylinder
    label: "pg_statistics\n(Catalog Table)"
    style: {
      fill: "#30363D"
      stroke: "#484F58"
      font-color: "#C9D1D9"
    }
  }

  entry_point -> analyzer: "1. analyze_table()"
  analyzer -> table_reader: "2. read_samples()"
  table_reader -> sample_buffer: "3. fill_buffer()"
  sample_buffer -> histogram_builder: "4. sorted_values"
  histogram_builder -> analyzer: "5. Histogram"
  analyzer -> stats_store: "6. store_stats()"
  stats_store -> pg_stats: "7. persist"
}

stats_class_layout: {
  label: "Statistics Class Memory Layout (sizeof=56 bytes)"
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
    font-color: "#C9D1D9"
  }

  stats_header: {
    shape: rectangle
    label: "ColumnStatistics Struct\n[vtable_ptr]"
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
      bold: true
    }
  }

  field_table_id: {
    shape: rectangle
    label: "0x08 | table_id: int32"
    width: 300
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
    }
  }

  field_col_id: {
    shape: rectangle
    label: "0x0C | column_id: int32"
    width: 300
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
    }
  }

  field_null_frac: {
    shape: rectangle
    label: "0x10 | null_fraction: float64"
    width: 300
    style: {
      fill: "#1F6FEB"
      stroke: "#388BFD"
      font-color: "#FFFFFF"
    }
  }

  field_distinct: {
    shape: rectangle
    label: "0x18 | distinct_count: int64"
    width: 300
    style: {
      fill: "#1F6FEB"
      stroke: "#388BFD"
      font-color: "#FFFFFF"
    }
  }

  field_min: {
    shape: rectangle
    label: "0x20 | min_val_ptr: *void"
    width: 300
    style: {
      fill: "#F78166"
      stroke: "#FFA657"
      font-color: "#FFFFFF"
    }
  }

  field_max: {
    shape: rectangle
    label: "0x28 | max_val_ptr: *void"
    width: 300
    style: {
      fill: "#F78166"
      stroke: "#FFA657"
      font-color: "#FFFFFF"
    }
  }

  field_histogram: {
    shape: rectangle
    label: "0x30 | histogram_ptr: *Histogram"
    width: 300
    style: {
      fill: "#F78166"
      stroke: "#FFA657"
      font-color: "#FFFFFF"
    }
  }

  field_mcv: {
    shape: rectangle
    label: "0x38 | mcv_list_ptr: *MCVList"
    width: 300
    style: {
      fill: "#F78166"
      stroke: "#FFA657"
      font-color: "#FFFFFF"
    }
  }

  stats_header -> field_table_id
  field_table_id -> field_col_id
  field_col_id -> field_null_frac
  field_null_frac -> field_distinct
  field_distinct -> field_min
  field_min -> field_max
  field_max -> field_histogram
  field_histogram -> field_mcv
}

histogram_structure: {
  label: "Histogram Bucket Structure"
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
    font-color: "#C9D1D9"
  }

  hist_header: {
    shape: rectangle
    label: "Histogram\n05_histogram.py"
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
      bold: true
    }
  }

  bucket_array: {
    shape: rectangle
    label: "buckets: List[HistogramBucket]"
    style: {
      fill: "#161B22"
      stroke: "#30363D"
    }
  }

  bucket_0: {
    shape: rectangle
    label: "Bucket[0]"
    style: {
      fill: "#238636"
      stroke: "#2EA043"
      font-color: "#FFFFFF"
    }
  }

  bucket_1: {
    shape: rectangle
    label: "Bucket[1]"
    style: {
      fill: "#238636"
      stroke: "#2EA043"
      font-color: "#FFFFFF"
    }
  }

  bucket_n: {
    shape: rectangle
    label: "Bucket[n]"
    style: {
      fill: "#238636"
      stroke: "#2EA043"
      font-color: "#FFFFFF"
    }
  }

  bucket_detail: {
    shape: rectangle
    label: "HistogramBucket {\n  lower_bound: Any\n  upper_bound: Any\n  frequency: float\n  distinct: int\n}"
    style: {
      fill: "#161B22"
      stroke: "#30363D"
      font-color: "#7EE787"
      font-size: 11
      font: mono
    }
  }

  hist_header -> bucket_array
  bucket_array -> bucket_0: "[0]"
  bucket_0 -> bucket_1: "[1]"
  bucket_1 -> bucket_n: "...[n]"
  bucket_0 -> bucket_detail: "Memory View"
}

legend: {
  label: "Color Legend"
  near: bottom-center
  style: {
    fill: "#0D1117"
    stroke: "#30363D"
  }

  header_box: {
    shape: rectangle
    label: "Metadata / Offset"
    style: {
      fill: "#6E40C9"
      stroke: "#8957E5"
      font-color: "#FFFFFF"
    }
  }

  data_box: {
    shape: rectangle
    label: "Scalar Values"
    style: {
      fill: "#1F6FEB"
      stroke: "#388BFD"
      font-color: "#FFFFFF"
    }
  }

  ptr_box: {
    shape: rectangle
    label: "Pointer / Reference"
    style: {
      fill: "#F78166"
      stroke: "#FFA657"
      font-color: "#FFFFFF"
    }
  }

  free_box: {
    shape: rectangle
    label: "Heap / Buffer"
    style: {
      fill: "#238636"
      stroke: "#2EA043"
      font-color: "#FFFFFF"
    }
  }

  header_box -> data_box -> ptr_box -> free_box
}