layout-engine: elk
theme-id: 4

direction: right

title: |md
  # DPTableEntry Memory Layout
  *Intel Manual Quality Specification*
| {
  near: top-center
}

classes: {
  offset_col: {
    style: {
      fill: "#1a1a2e"
      stroke: "#4a4a6a"
      font-color: "#8888aa"
      font: mono
    }
  }
  field_ptr: {
    style: {
      fill: "#ff9500" # Orange as per instructions
      font-color: "#000000"
      bold: true
      stroke: "#cc7a00"
    }
  }
  field_data: {
    style: {
      fill: "#3b82f6" # Blue as per instructions
      font-color: "#ffffff"
      bold: true
      stroke: "#2563eb"
    }
  }
  field_optional: {
    style: {
      fill: "#c084fc"
      font-color: "#000000"
      bold: true
      stroke: "#a855f7"
    }
  }
  field_header: {
    style: {
      fill: "#a855f7" # Purple as per instructions
      font-color: "#ffffff"
      bold: true
      stroke: "#7e22ce"
    }
  }
  field_padding: {
    style: {
      fill: "#3a3a4a" # Gray as per instructions
      font-color: "#888888"
      stroke-dash: 2
    }
  }
  type_label: {
    style: {
      fill: "#1a1a2e"
      stroke: "#4a4a6a"
      font-color: "#88ccff"
      font: mono
    }
  }
  size_label: {
    style: {
      fill: "#1a1a2e"
      stroke: "#4a4a6a"
      font-color: "#aaaaaa"
      font: mono
    }
  }
  cache_boundary: {
    style: {
      fill: "#2d1b1b"
      stroke: "#ef4444"
      stroke-width: 4
      stroke-dash: 5
      font-color: "#f87171"
      bold: true
    }
  }
}

# Memory layout visualization grid
# Columns: Offset (Left), Field Name, Type Info, Byte Size (Right)
layout: {
  grid-columns: 4
  grid-gap: 0
  style.stroke: "#4a4a6a"
  style.stroke-width: 2

  # ROW 0
  o0: "0x00" {class: offset_col}
  f0: "subset" {class: field_ptr}
  t0: "FrozenSet[str]" {class: type_label}
  s0: "8 bytes" {class: size_label}

  # ROW 1
  o8: "0x08" {class: offset_col}
  f8: "plan" {class: field_ptr}
  t8: "PlanNode*" {class: type_label}
  s8: "8 bytes" {class: size_label}

  # ROW 2
  o16: "0x10" {class: offset_col}
  f16: "cost" {class: field_data}
  t16: "float64" {class: type_label}
  s16: "8 bytes" {class: size_label}

  # ROW 3
  o24: "0x18" {class: offset_col}
  f24: "output_rows" {class: field_data}
  t24: "float64" {class: type_label}
  s24: "8 bytes" {class: size_label}

  # ROW 4
  o32: "0x20" {class: offset_col}
  f32: "output_order" {class: field_ptr}
  t32: "Optional[List]*" {class: type_label}
  s32: "8 bytes" {class: size_label}

  # ROW 5
  o40: "0x28" {class: offset_col}
  f40: "left_subset" {class: field_optional}
  t40: "Optional[FS]*" {class: type_label}
  s40: "8 bytes" {class: size_label}

  # ROW 6
  o48: "0x30" {class: offset_col}
  f48: "right_subset" {class: field_optional}
  t48: "Optional[FS]*" {class: type_label}
  s48: "8 bytes" {class: size_label}

  # ROW 7
  o56: "0x38" {class: offset_col}
  f56: "join_operator" {class: field_ptr}
  t56: "Optional[str]*" {class: type_label}
  s56: "8 bytes" {class: size_label}

  # ROW 8: CACHE LINE BOUNDARY (64B)
  # Spanning the entire row to emphasize the boundary
  boundary: "─── L1 CACHE LINE BOUNDARY (64 BYTES) ───" {
    class: cache_boundary
    grid-columns: 4
  }

  # ROW 9
  o72: "0x40" {class: offset_col}
  f72: "_padding" {class: field_padding}
  t72: "alignment" {class: type_label}
  s72: "16 bytes" {class: size_label}

  # ROW 10
  o80: "0x50" {class: offset_col}
  f80: "PyObject_HEAD" {class: field_header}
  t80: "ob_refcnt/type" {class: type_label}
  s80: "16 bytes" {class: size_label}

  # ROW 11
  o88: "0x60" {class: offset_col}
  f88: "__dict__" {class: field_ptr}
  t88: "dict*" {class: type_label}
  s88: "8 bytes" {class: size_label}
}

# Detailed Inspection Views (Heap Objects)
inspection: {
  near: center-right
  
  plan_target: {
    shape: class
    label: "PlanNode (Heap Object)"
    style.fill: "#1e1e2e"
    style.stroke: "#ff9500"
    style.stroke-width: 2
    
    node_type: "str"
    children: "List[PlanNode]"
    operator: "Optional[Operator]"
    estimated_cost: "float"
  }

  frozenset_detail: {
    shape: class
    label: "FrozenSet Implementation"
    style.fill: "#1e1e2e"
    style.stroke: "#ff9500"
    style.stroke-width: 2
    
    _hash: "int (cached)"
    _members: "tuple[str, ...]"
  }
}

# Logical Reference Connections (Orange Pointers)
layout.f8 -> inspection.plan_target: {
  label: "dereference"
  style.stroke: "#ff9500"
  style.stroke-dash: 3
  style.animated: true
}

layout.f0 -> inspection.frozenset_detail: {
  label: "canonical_ref"
  style.stroke: "#ff9500"
  style.stroke-dash: 3
}

# Annotations and Engineering Notes
notes: {
  near: bottom-left
  
  subset_note: |md
    ### Hashing Optimization
    **subset** stores a pointer to a FrozenSet.
    Lookup in DP table is **O(1)** as hashes are
    precomputed during set creation.
  |
  
  recon_note: |md
    ### Reconstruction
    `left_subset` and `right_subset` are used
    during the backtracking phase to build
    the physical plan tree.
  |
}

# Code Implementation Reference
class_def: |python
  @dataclass(slots=True)
  class DPTableEntry:
      subset: FrozenSet[str]
      plan: PlanNode
      cost: float
      output_rows: float
      output_order: Optional[List[Tuple[str, str]]]
      left_subset: Optional[FrozenSet[str]]
      right_subset: Optional[FrozenSet[str]]
      join_operator: Optional[str]
| {
  shape: text
  near: top-right
  style.font-size: 11
  style.font: mono
}

# Footer Metrics
total_size: "Total footprint: 104 bytes (Python Object Overhead included)" {
  near: bottom-right
  style: {
    fill: "#1a2a1a"
    stroke: "#22c55e"
    font-color: "#22c55e"
    bold: true
    border-radius: 4
  }
}

# Engineering Legend
legend: {
  near: bottom-center
  grid-columns: 5
  grid-gap: 15
  style.stroke: "#4a4a6a"
  style.fill: "#0f172a"
  style.stroke-dash: 3
  
  l1: "Pointer (8B)" {class: field_ptr}
  l2: "Native Data" {class: field_data}
  l3: "Optional Ptr" {class: field_optional}
  l4: "PyHeader" {class: field_header}
  l5: "Padding" {class: field_padding}
}