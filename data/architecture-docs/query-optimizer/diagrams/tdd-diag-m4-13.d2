direction: right
title: Shell Tokenizer Flow
input: {
  label: "Raw Input"
  shape: text
  style: {
    font-size: 28
    bold: true
    fill: "#E8F5E9"
  }
}
char_reader: {
  label: "Character\nReader"
  shape: rectangle
  style.fill: "#BBDEFB"
}
state_machine: {
  label: "State Machine\n(STATE_DEFAULT\nSTATE_IN_QUOTE\nSTATE_IN_DQUOTE\nSTATE_IN_ESCAPE)"
  shape: rectangle
  style.fill: "#C5CAE9"
  transitions: {
    label: ""
    shape: sequence_diagram
    default: "STATE_DEFAULT"
    quote: "on '\"' → STATE_IN_DQUOTE"
    squote: "on '\\'' → STATE_IN_QUOTE"
    escape: "on '\\' → STATE_IN_ESCAPE"
    space: "on ' ' → emit token"
  }
}
token_buffer: {
  label: "Token Buffer"
  shape: cylinder
  style.fill: "#FFF9C4"
}
output: {
  label: "Token Array\n[\"echo\", \"hello\", \"world\"]"
  shape: text
  style: {
    font-size: 20
    fill: "#E8F5E9"
  }
}
input -> char_reader: "stream"
char_reader -> state_machine: "char by char"
state_machine -> token_buffer: "append char"
token_buffer -> output: "flush on delimiter"
edge: {
  style.stroke-dash: 3
}