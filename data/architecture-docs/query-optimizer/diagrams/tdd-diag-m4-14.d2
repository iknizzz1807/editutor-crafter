layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
  colors: {
    header_purple: "#E8D8F0"
    data_blue: "#B6DDF6"
    free_green: "#ACE1AF"
    padding_gray: "#D3D3D3"
    pointer_orange: "#FFB347"
    hot_path_gold: "#FFD700"
    logical_join: "#DDA0DD"
  }
}

# --------------------------------------------------------------------------------------------
# GLOBAL STYLES & CLASSES
# --------------------------------------------------------------------------------------------
classes: {
  cache_line: {
    style: {
      fill: "#FDFDFD"
      stroke: "#333333"
      stroke-width: 2
      stroke-dash: 5
      border-radius: 4
    }
  }
  mem_header: { style.fill: ${colors.header_purple} }
  mem_data: { style.fill: ${colors.data_blue} }
  mem_free: { style.fill: ${colors.free_green} }
  mem_pad: { style.fill: ${colors.padding_gray} }
  mem_ptr: { style.fill: ${colors.pointer_orange} }
  mem_hot: { style.fill: ${colors.hot_path_gold} }
}

# --------------------------------------------------------------------------------------------
# TOP LEVEL ANNOTATIONS
# --------------------------------------------------------------------------------------------
title: "Query Optimizer Memory Layout & Alignment Analysis" {
  shape: text
  near: top-center
  style: {
    font-size: 26
    bold: true
    underline: true
  }
}

# --------------------------------------------------------------------------------------------
# CACHE LINE 0: BASE PLAN NODE (64 BYTES)
# --------------------------------------------------------------------------------------------
cache_line_0: {
  label: "Cache Line 0 (0x00 - 0x3F) | PlanNode Base | sizeof=64B"
  class: cache_line

  header: {
    label: "PlanNode Header (24 Bytes)"
    class: mem_header
    
    offset_0: "0x00: node_type (enum)" { class: mem_header; tooltip: "4 bytes" }
    offset_4: "0x04: flags (uint32)" { class: mem_header; tooltip: "4 bytes" }
    offset_8: "0x08: cost (float64)" { class: mem_header; tooltip: "8 bytes" }
    offset_16: "0x10: est_rows (float64)" { class: mem_header; tooltip: "8 bytes" }
  }

  data_section: {
    label: "Base Pointers (32 Bytes)"
    class: mem_data
    
    children_ptr: "0x18: children_ptr (void*)" { class: mem_ptr }
    parent_ptr: "0x20: parent_ptr (void*)" { class: mem_ptr }
    predicate_ptr: "0x28: predicate_ptr (void*)" { class: mem_ptr }
    reserved: "0x30: reserved (uint64)" { class: mem_pad }
  }

  padding_64: "0x38: Alignment Padding (8B)" {
    class: mem_pad
    tooltip: "Ensures 64B cache line boundary"
  }
}

# --------------------------------------------------------------------------------------------
# CACHE LINE 1: LOGICAL SCAN (64 BYTES)
# --------------------------------------------------------------------------------------------
cache_line_1: {
  label: "Cache Line 1 (0x40 - 0x7F) | LogicalScan Fields | sizeof=64B"
  class: cache_line

  scan_header: {
    label: "LogicalScan Source (24 Bytes)"
    class: mem_data
    
    table_name_ptr: "0x40: table_name (char*)" { class: mem_ptr }
    alias_ptr: "0x48: alias (char*)" { class: mem_ptr }
    columns_ptr: "0x50: columns (ColumnList*)" { class: mem_ptr }
  }

  scan_data: {
    label: "Scan Statistics (32 Bytes)"
    class: mem_data
    
    row_count: "0x58: row_count (uint64)" { class: mem_data }
    page_count: "0x60: page_count (uint64)" { class: mem_data }
    selectivity: "0x68: selectivity (float64)" { class: mem_data }
    index_id: "0x70: index_id (int32)" { class: mem_data }
  }

  free_space: "0x74: Free (4B)" { class: mem_free }
  padding_128: "0x78: Padding (8B)" { class: mem_pad }
}

# --------------------------------------------------------------------------------------------
# CACHE LINE 2: LOGICAL JOIN (64 BYTES)
# --------------------------------------------------------------------------------------------
cache_line_2: {
  label: "Cache Line 2 (0x80 - 0xBF) | LogicalJoin | sizeof=64B"
  class: cache_line

  join_header: {
    label: "Join Logic (40 Bytes)"
    style.fill: ${colors.logical_join}
    join_type: "0x80: type (enum)" { style.fill: ${colors.logical_join} }
    left_child: "0x84: left_child*" { class: mem_ptr }
    right_child: "0x8C: right_child*" { class: mem_ptr }
    condition: "0x94: condition*" { class: mem_ptr }
    cardinality: "0x9C: est_card" { class: mem_data }
  }
  
  histograms: {
    label: "Histograms (24 Bytes)"
    class: mem_data
    hist_l: "0xA8: left_hist*" { class: mem_ptr }
    hist_r: "0xB0: right_hist*" { class: mem_ptr }
    mcv: "0xB8: mcv (u32)" { class: mem_data }
    ndv: "0xBC: ndv (u32)" { class: mem_data }
  }
}

# --------------------------------------------------------------------------------------------
# CACHE LINE 3: DP TABLE HOT PATH
# --------------------------------------------------------------------------------------------
cache_line_4: {
  label: "Cache Line 3 (0xC0 - 0xFF) | DP Table Entry (Hot Path)"
  style: {
    fill: "#FFF9C9"
    stroke: "#FFD700"
    stroke-width: 3
    stroke-dash: 5
  }

  dp_entry: {
    grid-columns: 2
    style.fill: ${colors.hot_path_gold}
    
    tables_field: "0x00: BitSet (8B)" { class: mem_hot }
    cost_field: "0x08: cost (8B)" { class: mem_hot }
    card_field: "0x10: cardinality (8B)" { class: mem_hot }
    plan_field: "0x18: best_plan* (8B)" { class: mem_ptr }
    left_node: "0x20: left_idx (4B)" { class: mem_hot }
    right_node: "0x24: right_idx (4B)" { class: mem_hot }
    flags_field: "0x28: flags (4B)" { class: mem_hot }
    pad_field: "0x2C: Padding (20B)" { class: mem_pad }
  }
}

# --------------------------------------------------------------------------------------------
# LEGEND & CONNECTIONS
# --------------------------------------------------------------------------------------------
legend: {
  near: bottom-center
  label: "Memory Map Color Legend"
  grid-columns: 3
  grid-gap: 15
  
  l1: "Header/Metadata" { class: mem_header }
  l2: "Data Fields" { class: mem_data }
  l3: "Pointers (8B)" { class: mem_ptr }
  l4: "Free Space" { class: mem_free }
  l5: "Padding/Alignment" { class: mem_pad }
  l6: "DP Hot Path" { class: mem_hot }
}

# Logical Inheritance/Extension Relationship
cache_line_0 -> cache_line_1: "extends" {
  style.stroke: "#333333"
  style.stroke-width: 2
}
cache_line_1 -> cache_line_2: "extends" {
  style.stroke: "#333333"
  style.stroke-width: 2
}

# Operational Reference
cache_line_2 -> cache_line_4: "populates" {
  style.stroke: "#FFB347"
  style.stroke-dash: 3
}

# Explicit sizing note
implementation_notes: |md
  ### Implementation Notes
  - **Sizeof(PlanNode)** = 64 Bytes (Matches Architecture-specific L1 Cache Line).
  - **Alignment**: Standard 8-byte boundary enforced for all `void*` and `float64` types.
  - **Cache Locality**: The Dynamic Programming (DP) Table Hot Path is explicitly packed into a single 64B cache line to prevent *False Sharing* in multi-threaded optimization and to minimize L1 Data Cache misses during the search phase.
  - **Memory Growth**: Structs grow downwards (increasing offsets).
| {
  near: center-right
  shape: text
}