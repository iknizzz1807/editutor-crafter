direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

Query_Optimizer_Architecture: {
  shape: rectangle
  label: "Query Optimizer Architecture"
  
  Stages: {
    API_Layer: {
      shape: rectangle
      label: "API Layer"
      style.stroke-dash: 5
      QueryOptimizer: {
        shape: rectangle
        label: "QueryOptimizer"
        style.fill: "#E3F2FD"
        methods: {
          shape: rectangle
          label: "Methods"
          "optimize(logical_plan)": {shape: text}
          "_apply_logical_rules()": {shape: text}
          "_optimize_joins()": {shape: text}
          "_select_physical_ops()": {shape: text}
        }
        outputs: {
          shape: rectangle
          label: "Returns"
          physical_plan: {shape: text}
          OptimizationStats: {shape: text}
        }
      }
    }
    Logical_Layer: {
      shape: rectangle
      label: "Logical Optimization"
      style.stroke-dash: 5
      Plan_Nodes: {
        shape: rectangle
        label: "Plan Nodes"
        PlanNode: {
          shape: class
          style.fill: "#FFF3E0"
          estimated_cost: float
          estimated_rows: float
          children: "List[PlanNode]"
          depth(): int
          node_count(): int
          is_leaf(): bool
        }
        LogicalScan: {
          shape: class
          style.fill: "#FFF3E0"
          table_name: str
          alias: str
        }
        LogicalFilter: {
          shape: class
          style.fill: "#FFF3E0"
          predicate: str
        }
        LogicalJoin: {
          shape: class
          style.fill: "#FFF3E0"
          join_type: str
          condition: str
        }
        LogicalAggregate: {
          shape: class
          style.fill: "#FFF3E0"
          group_by_columns: "List[str]"
          aggregations: Dict
        }
      }
      Rules_Engine: {
        shape: rectangle
        label: "Rule Engine"
        RuleEngine: {
          shape: rectangle
          style.fill: "#E8F5E9"
          label: "RuleEngine\n(fixed-point iteration)"
        }
        rules: {
          shape: rectangle
          label: "Transformation Rules"
          style.fill: "#C8E6C9"
          PredicatePushdown: {
            shape: text
            label: "PredicatePushdownRule"
          }
          ProjectionPruning: {
            shape: text
            label: "ProjectionPruningRule"
          }
          ConstantFolding: {
            shape: text
            label: "ConstantFoldingRule"
          }
          RedundantPredicate: {
            shape: text
            label: "RedundantPredicateRule"
          }
        }
      }
    }
    Cost_Layer: {
      shape: rectangle
      label: "Cost Estimation"
      style.stroke-dash: 5
      CostEstimator: {
        shape: rectangle
        style.fill: "#F3E5F5"
        config: CostModelConfig
        catalog: StatisticsCatalog
        methods_list: {
          shape: rectangle
          label: "Methods"
          "estimate_scan_cost()": {shape: text}
          "estimate_join_cost()": {shape: text}
          "estimate_aggregate_cost()": {shape: text}
        }
      }
      Selectivity: {
        shape: rectangle
        style.fill: "#F3E5F5"
        label: "Selectivity Functions"
        sel_funcs: {
          selectivity_equality: {shape: text}
          selectivity_range: {shape: text}
          selectivity_and: {shape: text}
          selectivity_or: {shape: text}
        }
      }
      Cardinality: {
        shape: rectangle
        style.fill: "#F3E5F5"
        label: "Cardinality Functions"
        card_funcs: {
          cardinality_equijoin: {shape: text}
          cardinality_filter: {shape: text}
        }
      }
    }
    Join_Layer: {
      shape: rectangle
      label: "Join Optimization"
      style.stroke-dash: 5
      DP_Optimizer: {
        shape: rectangle
        style.fill: "#FFEBEE"
        label: "DynamicProgrammingOptimizer\n(Selinger Algorithm)"
        dp_methods: {
          "optimize_join_order()": {shape: text}
          "_enumerate_partitions()": {shape: text}
          "_compute_best_plan()": {shape: text}
          "_greedy_fallback()": {shape: text}
        }
      }
      Join_Graph: {
        shape: rectangle
        style.fill: "#FFEBEE"
        label: "JoinGraph"
        graph_methods: {
          "get_connected_components()": {shape: text}
          "are_connected()": {shape: text}
          "is_cross_product()": {shape: text}
        }
      }
      DPTableEntry: {
        shape: class
        style.fill: "#FFCDD2"
        subset: "FrozenSet[str]"
        plan: PhysicalOperator
        cost: float
        output_rows: float
        output_order: List
      }
    }
    Physical_Layer: {
      shape: rectangle
      label: "Physical Operators"
      style.stroke-dash: 5
      Scans: {
        shape: rectangle
        label: "Access Paths"
        PhysicalSeqScan: {
          shape: class
          style.fill: "#E0F7FA"
          table_name: str
        }
        PhysicalIndexScan: {
          shape: class
          style.fill: "#E0F7FA"
          table_name: str
          index_name: str
          predicate: str
        }
      }
      Joins: {
        shape: rectangle
        label: "Join Algorithms"
        PhysicalHashJoin: {
          shape: class
          style.fill: "#B2EBF2"
          condition: str
          build_side: str
        }
        PhysicalSortMergeJoin: {
          shape: class
          style.fill: "#B2EBF2"
          condition: str
        }
        PhysicalNestedLoopJoin: {
          shape: class
          style.fill: "#B2EBF2"
          condition: str
        }
      }
      Other: {
        shape: rectangle
        label: "Other Operators"
        PhysicalSort: {
          shape: class
          style.fill: "#80DEEA"
          sort_keys: List
        }
        PhysicalAggregate: {
          shape: class
          style.fill: "#80DEEA"
          group_by: List
          aggregations: Dict
        }
      }
    }
    Stats_Layer: {
      shape: rectangle
      label: "Statistics"
      style.stroke-dash: 5
      StatisticsCatalog: {
        shape: rectangle
        style.fill: "#FFF8E1"
        cat_methods: {
          "get_table_stats()": {shape: text}
          "store_table_stats()": {shape: text}
          "is_stats_stale()": {shape: text}
          "record_modification()": {shape: text}
        }
      }
      TableStatistics: {
        shape: class
        style.fill: "#FFECB3"
        table_name: str
        row_count: int
        page_count: int
        columns: "Dict[str, ColumnStatistics]"
      }
      ColumnStatistics: {
        shape: class
        style.fill: "#FFE082"
        column_name: str
        distinct_count: int
        null_count: int
        histogram: ColumnHistogram
      }
      Histogram: {
        shape: rectangle
        style.fill: "#FFD54F"
        label: "Equi-Depth Histogram"
        HistogramBucket: {
          shape: class
          min_value: float
          max_value: float
          row_count: int
          distinct_count: int
        }
      }
      Analyzer: {
        shape: rectangle
        style.fill: "#FFF8E1"
        label: "ANALYZE Command"
        analyze_methods: {
          "execute_analyze()": {shape: text}
          "_build_histogram()": {shape: text}
          "_collect_stats()": {shape: text}
        }
      }
    }
  }
}

Data_Flow: {
  shape: rectangle
  label: "Optimization Pipeline Flow"
  direction: down
  Input: {
    shape: rectangle
    style.fill: "#BBDEFB"
    label: "Logical Plan Tree\n(SQL → Relational Algebra)"
  }
  Step1: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: "1. Logical Rules\n(Pushdown, Pruning, Folding)"
  }
  Step2: {
    shape: rectangle
    style.fill: "#E1BEE7"
    label: "2. Join Ordering\n(DP with cost estimation)"
  }
  Step3: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: "3. Physical Selection\n(Scan type, Join algorithm)"
  }
  Output: {
    shape: rectangle
    style.fill: "#B2DFDB"
    label: "Physical Plan Tree\n(Executor-ready)"
  }
  Input -> Step1 -> Step2 -> Step3 -> Output
}

Join_Ordering_DP: {
  shape: rectangle
  label: "Dynamic Programming Join Ordering"
  direction: down
  Tables: {
    shape: rectangle
    style.fill: "#E3F2FD"
    label: "Tables: {A, B, C}"
  }
  DP_Table: {
    shape: rectangle
    label: "DP Table"
    Entry_1: {
      shape: rectangle
      style.fill: "#FFF3E0"
      label: "{A} → SeqScan(A)\ncost: 100"
    }
    Entry_2: {
      shape: rectangle
      style.fill: "#FFF3E0"
      label: "{B} → SeqScan(B)\ncost: 200"
    }
    Entry_3: {
      shape: rectangle
      style.fill: "#FFF3E0"
      label: "{C} → SeqScan(C)\ncost: 150"
    }
    Entry_4: {
      shape: rectangle
      style.fill: "#E8F5E9"
      label: "{A,B} → HashJoin(A,B)\ncost: 450"
    }
    Entry_5: {
      shape: rectangle
      style.fill: "#E8F5E9"
      label: "{B,C} → HashJoin(B,C)\ncost: 400"
    }
    Entry_6: {
      shape: rectangle
      style.fill: "#F3E5F5"
      label: "{A,B,C} → HashJoin(\n  HashJoin(A,B), C)\ncost: 950"
    }
  }
  Tables -> DP_Table
}

Predicate_Pushdown: {
  shape: rectangle
  label: "Predicate Pushdown Example"
  Before: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: "Before"
    tree_before: {
      shape: rectangle
      direction: down
      Filter_top: {
        shape: rectangle
        label: "Filter\namount > 1000"
      }
      Join_node: {
        shape: rectangle
        label: "Join\norders × customers"
      }
      Scan_o: {
        shape: rectangle
        label: "Scan orders"
      }
      Scan_c: {
        shape: rectangle
        label: "Scan customers"
      }
      Filter_top -> Join_node
      Join_node -> Scan_o
      Join_node -> Scan_c
    }
  }
  Arrow: {
    shape: text
    label: "→"
  }
  After: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: "After"
    tree_after: {
      shape: rectangle
      direction: down
      Join_after: {
        shape: rectangle
        label: "Join"
      }
      Filter_o: {
        shape: rectangle
        label: "Filter\namount > 1000"
      }
      Scan_o2: {
        shape: rectangle
        label: "Scan orders"
      }
      Scan_c2: {
        shape: rectangle
        label: "Scan customers"
      }
      Join_after -> Filter_o
      Join_after -> Scan_c2
      Filter_o -> Scan_o2
    }
  }
  Before -> Arrow -> After
}

Cost_Model: {
  shape: rectangle
  label: "Cost Model Components"
  Formula: {
    shape: rectangle
    style.fill: "#E8F5E9"
    label: "Total Cost = (I/O × IO_WEIGHT) + (CPU × CPU_WEIGHT)"
  }
  Scan_Costs: {
    shape: rectangle
    label: "Scan Costs"
    SeqScan: {
      shape: text
      label: "SeqScan: pages × IO_WEIGHT + rows × CPU_WEIGHT"
    }
    IndexScan: {
      shape: text
      label: "IndexScan: height × selectivity + rows × CPU_WEIGHT"
    }
  }
  Join_Costs: {
    shape: rectangle
    label: "Join Costs"
    HashJoin: {
      shape: text
      label: "HashJoin: build_cost + probe_cost"
    }
    MergeJoin: {
      shape: text
      label: "MergeJoin: sort_cost + merge_cost"
    }
    NestedLoop: {
      shape: text
      label: "NestedLoop: outer_rows × inner_cost"
    }
  }
  Selectivity_Estimation: {
    shape: rectangle
    label: "Selectivity Estimation"
    Equality: {
      shape: text
      label: "Equality: 1 / distinct_count"
    }
    Range: {
      shape: text
      label: "Range: histogram lookup"
    }
    AND: {
      shape: text
      label: "AND: s1 × s2 (independence)"
    }
    OR: {
      shape: text
      label: "OR: s1 + s2 - (s1 × s2)"
    }
  }
}

connections: {
  Query_Optimizer_Architecture.Stages.API_Layer.QueryOptimizer -> Query_Optimizer_Architecture.Stages.Logical_Layer.Rules_Engine.RuleEngine: "1. apply rules"
  Query_Optimizer_Architecture.Stages.Logical_Layer.Rules_Engine.RuleEngine -> Query_Optimizer_Architecture.Stages.Join_Layer.DP_Optimizer: "2. optimize joins"
  Query_Optimizer_Architecture.Stages.Join_Layer.DP_Optimizer -> Query_Optimizer_Architecture.Stages.Cost_Layer.CostEstimator: "uses"
  Query_Optimizer_Architecture.Stages.Cost_Layer.CostEstimator -> Query_Optimizer_Architecture.Stages.Stats_Layer.StatisticsCatalog: "queries"
  Query_Optimizer_Architecture.Stages.Join_Layer.DP_Optimizer -> Query_Optimizer_Architecture.Stages.Physical_Layer: "3. select operators"
}