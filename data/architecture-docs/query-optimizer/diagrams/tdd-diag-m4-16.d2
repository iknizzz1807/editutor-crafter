vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
  colors: {
    background: "#0d1117"
    module: "#161b22"
    module_border: "#30363d"
    plan_module: "#1f6feb"
    cost_module: "#8957e5"
    logical_module: "#238636"
    join_module: "#d29922"
    data: "#0d419d"
    border: "#f85149"
    header: "#58a6ff"
    text: "#c9d1d9"
    accent: "#ffa657"
    success: "#3fb950"
    warning: "#d29922"
    highlight: "#aff5b4"
  }
}

title: "Query Optimizer Architecture & Execution Pipeline" {
  shape: rectangle
  style: {
    fill: "${colors.background}"
    stroke: "${colors.header}"
    stroke-width: 4
    font-size: 36
    font-color: "${colors.header}"
    bold: true
  }
}

direction: right

Query_Optimizer_Pipeline: {
  style.fill: "${colors.background}"
  style.stroke: "${colors.module_border}"
  style.stroke-width: 1

  Input: {
    shape: rectangle
    style.fill: "${colors.module}"
    style.stroke: "${colors.plan_module}"
    style.font-color: "${colors.text}"
    label: "Step 1: SQL Interface"
    
    SQL_Text: {
      shape: code
      language: sql
      label: |sql
        SELECT o.id, c.name, SUM(oi.price)
        FROM orders o
        JOIN customers c ON o.customer_id = c.id
        JOIN order_items oi ON o.id = oi.order_id
        WHERE o.amount > 1000
          AND c.status = 'active'
        GROUP BY o.id, c.name
      |
    }
  }

  Parser: {
    shape: hexagon
    style.fill: "${colors.logical_module}"
    style.stroke: "${colors.module_border}"
    style.font-color: "${colors.text}"
    label: "SQL Parser & Binder"
    
    Parse_Tree: {
      shape: rectangle
      style.fill: "${colors.data}"
      style.font-color: "${colors.text}"
      label: "AST → Logical Query Plan (LQP)"
    }
  }

  Statistics_Catalog: {
    shape: cylinder
    style.fill: "${colors.cost_module}"
    style.stroke: "${colors.module_border}"
    style.font-color: "${colors.text}"
    label: "Statistics Catalog"
    
    Table_Stats: {
      shape: sql_table
      style.fill: "${colors.data}"
      orders: "Rows: 1.0M | Pages: 50.0k"
      customers: "Rows: 50.0k | Pages: 2.5k"
      order_items: "Rows: 5.0M | Pages: 250.0k"
    }
    
    Column_Stats: {
      shape: sql_table
      style.fill: "${colors.data}"
      column_name: "TEXT {PK}"
      null_fraction: "FLOAT"
      distinct_count: "INT64"
      min_max: "RANGE"
      histograms: "JSONB"
    }
  }

  Logical_Optimizer: {
    style.fill: "${colors.module}"
    style.stroke: "${colors.logical_module}"
    style.stroke-width: 2
    style.font-color: "${colors.text}"
    label: "Logical Optimizer (RBO)"
    
    Rules: {
      label: "Transformation Ruleset"
      Predicate_Pushdown: {
        label: "Rule: Predicate Pushdown"
        tooltip: "Move WHERE filters below JOINs"
      }
      Projection_Pruning: {
        label: "Rule: Column Pruning"
        tooltip: "Remove unused attributes"
      }
      Constant_Folding: {
        label: "Rule: Constant Folding"
      }
    }
    
    Fixed_Point_Loop: {
      shape: circle
      style.fill: "${colors.accent}"
      style.font-color: "${colors.background}"
      label: "Iterate to\nFixed Point"
    }
  }

  Cost_Estimator: {
    style.fill: "${colors.module}"
    style.stroke: "${colors.cost_module}"
    style.stroke-width: 2
    style.font-color: "${colors.text}"
    label: "Cost Estimator (CBO)"
    
    Cost_Model: {
      label: "Cost = Σ(I/O + CPU)"
      IO_Cost: "Weight: 1.0 (Random) | 0.1 (Seq)"
      CPU_Cost: "Weight: 0.01 (Tuple) | 0.002 (Op)"
    }
    
    Selectivity: {
      label: "Selectivity Logic"
      Hist_Lookup: "Density estimation"
      Join_Selectivity: "Cartesian / MaxDistinct"
    }
  }

  Join_Order_Optimizer: {
    style.fill: "${colors.module}"
    style.stroke: "${colors.join_module}"
    style.stroke-width: 2
    label: "Join Order (DP/Greedy)"
    
    DP_Table: {
      Subset_A: "{o} | 1000"
      Subset_B: "{c} | 500"
      Subset_AB: "{o,c} | 1500"
      Subset_ABC: "{o,c,oi} | 3500 {OPTIMAL}"
    }
    
    Fallback: {
      shape: diamond
      style.fill: "${colors.warning}"
      label: "N > 12?"
    }
  }

  Physical_Plan_Generator: {
    style.fill: "${colors.module}"
    style.stroke: "${colors.join_module}"
    label: "Physical Plan Engine"
    
    Access_Paths: {
      SeqScan: "Full Scan"
      IndexScan: "B-Tree Search"
      BitmapScan: "Index -> Heap"
    }
    
    Join_Algos: {
      NestedLoop: "O(N*M)"
      HashJoin: "O(N+M)"
      MergeJoin: "O(NlogN)"
    }
  }

  Output: {
    style.fill: "${colors.success}"
    style.stroke: "${colors.module_border}"
    label: "Optimized Physical Plan"
    
    Plan_Tree: {
      Root: "Aggregate (SUM)"
      L1: "HashJoin (orders x customers)"
      L2: "HashJoin (prev x order_items)"
      Leaves: "IndexScan(o), IndexScan(c), SeqScan(oi)"
    }
  }

  # --- FLOW CONNECTIONS ---
  Input -> Parser: "SQL Query String"
  Parser -> Logical_Optimizer: "Unoptimized LQP"
  
  Statistics_Catalog -> Logical_Optimizer: "Metadata" { style.stroke-dash: 3 }
  Statistics_Catalog -> Cost_Estimator: "Card/Hist" { style.stroke-dash: 3 }
  
  Logical_Optimizer -> Join_Order_Optimizer: "Simplified LQP"
  Cost_Estimator -> Join_Order_Optimizer: "Selectivity Maps"
  
  Join_Order_Optimizer -> Physical_Plan_Generator: "Optimal Sequence"
  Physical_Plan_Generator -> Output: "Executable Bytecode"

  # --- INTERNAL LOGIC ---
  Logical_Optimizer.Rules -> Logical_Optimizer.Fixed_Point_Loop: "Delta check"
  Logical_Optimizer.Fixed_Point_Loop -> Logical_Optimizer.Rules: "Next pass"
  
  Join_Order_Optimizer.Fallback -> Join_Order_Optimizer.DP_Table: "No"
  
  Output.Plan_Tree.Root -> Output.Plan_Tree.L1
  Output.Plan_Tree.L1 -> Output.Plan_Tree.L2
  Output.Plan_Tree.L2 -> Output.Plan_Tree.Leaves
}