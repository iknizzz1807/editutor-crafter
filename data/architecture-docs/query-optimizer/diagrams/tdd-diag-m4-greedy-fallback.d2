direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

# --- GREEDY JOIN ORDERING FLOW (IMPLEMENTATION SPEC) ---
# Physical Plan Selection Logic for Large Join Graphs (N > 12)
# Ref: Milestone 4 - Physical Plan Optimizer Fallback

GreedyOptimizer: {
  # FIX: Using single quotes to prevent D2 from interpreting '$(' as a failed variable substitution
  label: 'Join Order Greedy Heuristic ($O(N^2)$)'
  tooltip: "Physical plan selection when Selinger DP search space exceeds memory limits."
  
  # --- Step 1: Initialize Search Pool ---
  Step1: "1. Initialize Join Pool" {
    shape: rectangle
    style: {
      fill: "#E4DBFE"
      stroke: "#B5AFF6"
      stroke-width: 2
      border-radius: 4
    }
    tooltip: "Pool starts with N single-relation plan groups (SeqScan/IndexScan)."
  }

  # --- Iterative Loop Container ---
  MainSearchLoop: {
    label: "Main Search Loop"
    style: {
      stroke: "#B5AFF6"
      stroke-dash: 5
      fill: "#f8f9fa"
    }

    # Step 2: Termination Guard
    Step2: "2. Size Check" {
      label: "Is Pool.size() > 1?"
      shape: diamond
      style.fill: "#C7F1FF"
    }

    # Step 3: Candidate Evaluation
    Step3: "3. Evaluate Pairs" {
      label: "Evaluate All Pairs (Pi, Pj)"
      tooltip: |md
        **Costing Equation:**
        $Cost(P_{ij}) = Cost(P_i) + Cost(P_j) + JoinCost(P_i, P_j)$
        
        *Join Methods Considered:*
        1. Hash Join (Equi-joins)
        2. Sort-Merge Join (Ordered inputs)
        3. Nested Loop Join (Fallback/Cross)
      |
      style.fill: "#DEE1EB"
    }

    # Step 4: Greedy Selection
    Step4: "4. Select Minimum" {
      label: "**Find argmin(ΔCost)**"
      tooltip: "Select pair (Pi, Pj) that yields the lowest incremental cost increase."
      style: {
        fill: "#88DCF7"
        stroke: red
        stroke-width: 4
        bold: true
      }
    }

    # Step 5: State Mutation
    Step5: "5. Mutate Pool" {
      # FIX: Using single quotes to prevent interpretation of braces { } as D2 map syntax or substitutions
      label: 'Pool = (Pool \ {Pi, Pj}) ∪ {Pij}'
      tooltip: "Replace the two chosen plans with their optimal joined representation."
      style: {
        fill: "#B5AFF6"
        bold: true
      }
    }
  }

  # --- Exit Sequence ---
  Step6: "6. Extract Root" {
    label: "Extract Final Plan"
    style.fill: "#ACE1AF"
  }

  TerminalNode: "●" {
    shape: circle
    style.fill: "#167c3c"
  }

  # --- Connection Sequencing ---
  Step1 -> MainSearchLoop.Step2
  
  MainSearchLoop.Step2 -> MainSearchLoop.Step3: "TRUE (Iterate)" {
    style.stroke: blue
  }
  
  MainSearchLoop.Step3 -> MainSearchLoop.Step4
  MainSearchLoop.Step4 -> MainSearchLoop.Step5: "ΔCost is Minimized"
  
  # Back-edge for Loop
  MainSearchLoop.Step5 -> MainSearchLoop.Step2: "Recursive Descent" {
    style.stroke-dash: 3
    style.animated: true
  }

  MainSearchLoop.Step2 -> Step6: "FALSE (Pool Size = 1)" {
    style.stroke: "#167c3c"
    style.stroke-width: 3
  }
  
  Step6 -> TerminalNode
}

# --- Technical Specification Block ---
TechnicalSpecs: |md
  ### Search Complexity & Guardrails
  - **Complexity:** $O(N^2)$ iterations, where $N$ is number of relations.
  - **Memory:** $O(N)$ space required for the plan pool.
  
  **Optimization Constraints:**
  - **Cross-Product Penalty:** A $1000.0x$ cost multiplier is applied to joins without predicates.
  - **Bus-Tub Heuristic:** Left-deep trees are preferred by the cost model to minimize pipeline stalls.
| {
  near: top-right
  style: {
    fill: "#FFF9C9"
    stroke: "#9D341E"
    stroke-width: 1
  }
}

# --- State Change Legend ---
Legend: {
  near: bottom-right
  
  Input: "Initial State" { 
    style.fill: "#E4DBFE" 
  }
  Process: "Eval Logic" { 
    style.fill: "#DEE1EB" 
  }
  Decision: "Condition" { 
    shape: diamond
    style.fill: "#C7F1FF" 
  }
  Critical: "Greedy Choice" { 
    style: {
      fill: "#88DCF7"
      stroke: red
      stroke-width: 2
    }
  }
  Mutation: "Pool Update" { 
    style.fill: "#B5AFF6" 
  }
}

# --- Explicit Implementation Hints ---
GreedyOptimizer.MainSearchLoop.Step4.style.animated: true
GreedyOptimizer.Step1.style.double-border: true
GreedyOptimizer.TerminalNode.style.shadow: true

# Annotations for Engineers
ImplementationNote: |md
  **Dev Note:**
  Ensure `JoinCost` method caches results for `(Pi, Pj)` to avoid redundant calculations within the same iteration level.
| {
  near: top-left
  style.font-size: 12
}