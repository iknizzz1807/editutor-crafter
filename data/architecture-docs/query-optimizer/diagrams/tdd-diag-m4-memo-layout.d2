layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 20
  }
}

# --- TECHNICAL CLASSES ---
classes: {
  header: {
    style: {
      fill: "#6A0DAD"
      font-color: white
      bold: true
      stroke-width: 2
    }
  }
  data: {
    style: {
      fill: "#007FFF"
      font-color: white
      stroke-width: 1
    }
  }
  pointer: {
    style: {
      fill: "#FFA500"
      font-color: black
      italic: true
      stroke-width: 2
    }
  }
  padding: {
    style: {
      fill: "#808080"
      opacity: 0.4
      stroke-dash: 3
    }
  }
  note_box: {
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      border-radius: 4
      font-size: 12
    }
  }
}

# --- MEMORY LAYOUT DEFINITION ---
# Total sizeof = 64 bytes (One Cache Line)
dp_memo_entry: "DP_MEMO_ENTRY (64B Cache-Aligned)" {
  shape: sql_table
  style: {
    stroke-width: 3
    stroke: black
    shadow: true
  }

  # Offset | Field Name | Type/Size Annotation
  "0x00": "Entry Lock / Status Flag" {
    class: header
    constraint: "uint64 (8B)"
  }
  "0x08": "Table Set Bitmask (Key)" {
    class: data
    constraint: "uint64 (8B)"
  }
  "0x10": "Estimated Total Cost" {
    class: data
    constraint: "float64 (8B)"
  }
  "0x18": "Estimated Cardinality" {
    class: data
    constraint: "float64 (8B)"
  }
  "0x20": "*PhysicalPlanNode (Ptr)" {
    class: pointer
    constraint: "uintptr (8B)"
  }
  "0x28": "*InterestingOrders (Ptr)" {
    class: pointer
    constraint: "uintptr (8B)"
  }
  "0x30": "Alignment Padding" {
    class: padding
    constraint: "16 Bytes"
  }
}

# --- ANNOTATIONS AND NOTES ---
# Grouped into a container to maintain proximity to the table
annotations: "Implementation Details" {
  near: top-right

  bitmask_note: |md
    ### Table Bitmask (Key)
    Used for sub-plan lookup.
    - `0b0001`: Table A
    - `0b0010`: Table B
    - `0b0111`: Join {A,B,C}
  | {
    class: note_box
  }

  cost_note: |md
    ### Cost & Cardinality
    - Double precision (64-bit)
    - Normalized units
    - Cardinality $\ge$ 1.0
  | {
    class: note_box
  }

  order_note: |md
    ### Pointer Logic
    Points to the root of the
    Physical Operator tree 
    assigned to this subset.
  | {
    class: note_box
  }
}

# --- BOUNDARY VISUALIZATION ---
# Since near cannot target internal rows directly, we use connections to associate notes
annotations.bitmask_note -> dp_memo_entry."0x08": { style.stroke: grey; style.stroke-dash: 2 }
annotations.cost_note -> dp_memo_entry."0x10": { style.stroke: grey; style.stroke-dash: 2 }
annotations.order_note -> dp_memo_entry."0x20": { style.stroke: grey; style.stroke-dash: 2 }

cache_line_info: "-------------------------- 64B CACHE LINE BOUNDARY --------------------------" {
  shape: text
  near: bottom-center
  style: {
    font-size: 16
    font-color: red
    bold: true
  }
}

# --- LEGEND ---
legend: "Layout Legend" {
  near: bottom-right
  header: "Header/Mutex (Purple)" { class: header }
  data: "Query Stats (Blue)" { class: data }
  ptr: "Memory Pointer (Orange)" { class: pointer }
  pad: "Memory Padding (Gray)" { class: padding }
}

# --- EXTERNAL MEMORY REFERENCES ---
dp_memo_entry."0x20" -> physical_plan_heap.node: "dereference [ptr]" {
  style: {
    stroke: orange
    stroke-width: 2
    animated: true
  }
}

physical_plan_heap: "PHYSICAL PLAN HEAP" {
  style: {
    fill: white
    stroke: "#333333"
    stroke-dash: 5
  }
  node: "HashJoinNode (A ⋈ B)" {
    shape: rectangle
    style: {
      fill: "#E1EBEE"
      stroke: "#007FFF"
      stroke-width: 2
    }
  }
  
  metadata: "Plan Metadata" {
    shape: rectangle
    style.fill: "#F0F0F0"
  }
  
  node -> metadata: "owns"
}

# --- GLOBAL STYLING ---
style: {
  fill: "#FDFDFD"
}

# Ensure spacing is sufficient for high-detail manual view
dp_memo_entry.width: 500
annotations.width: 250