vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    center: true
  }
}

# --- GLOBAL CLASSES & INTEL-SPEC STYLING ---
classes: {
  decision: {
    shape: diamond
    width: 280
    height: 180
    style: {
      fill: "#E4DBFE"
      stroke: "#3B1E7B"
      stroke-width: 3
      font-size: 14
      bold: true
    }
  }
  operator: {
    shape: rectangle
    width: 350
    height: 160
    style: {
      fill: "#C7F1FF"
      stroke: "#007291"
      border-radius: 6
      double-border: true
      stroke-width: 3
      font-size: 14
    }
  }
  terminal: {
    shape: circle
    style: {
      fill: "#B6F6B6"
      stroke: "#167C3C"
      stroke-width: 4
      bold: true
    }
  }
  note_box: {
    shape: package
    style: {
      fill: "#FFF9C9"
      stroke: "#B8B06B"
      stroke-dash: 3
      font-size: 13
    }
  }
  path_true: {
    label: "TRUE"
    style: {
      stroke: "#167C3C"
      stroke-width: 3
      font-color: "#167C3C"
      bold: true
    }
  }
  path_false: {
    label: "FALSE"
    style: {
      stroke: "#CA052B"
      stroke-width: 3
      font-color: "#CA052B"
      bold: true
    }
  }
  dp_state: {
    style: {
      fill: "#F0F0F0"
      stroke: "#666666"
      stroke-dash: 2
      font-size: 12
    }
  }
}

# --- ARCHITECTURE HEADER ---
header_container: {
  style: {
    stroke-width: 0
    fill: transparent
  }
  title: |md
    # Physical Operator Decision Tree (Join Selection Strategy)
    **Subsystem:** Query Optimizer / Cost-Based Optimizer (CBO)
    **Context:** Milestone 4 Implementation - Physical Planning Phase
    **Target Hardware:** Intel® Xeon® Scalable Processors (AVX-512 Optimized)
    **Objective:** Select most efficient physical join implementation based on relational metadata.
  | {
    shape: text
  }
}

direction: down

# --- LOGIC FLOW: DECISION TREE ---

# Entry Point: Logical Join Operator
start: ● {
  class: terminal
  label: "Logical Join Input\n(L ⨝ R)"
}

# Step 1: Connectivity Analysis
start -> connectivity_check: "Fetch Predicate Set"

connectivity_check: "Check: Connectivity\n(Join Predicate Exists?)" {
  class: decision
  tooltip: "Verification of join condition existence to prevent accidental Cartesian Products."
}

connectivity_check -> equi_join_check: {
  class: path_true
}
connectivity_check -> cross_join_penalty: {
  class: path_false
}

cross_join_penalty: "Logic: APPLY_CARTESIAN_PENALTY" {
  label: "Apply 1000x Cost Multiplier\nSet Join Type: CROSS\n(Cartesian Product)"
  style: {
    fill: "#FFC7C7"
    font-color: "#CA052B"
    bold: true
    stroke: "#CA052B"
    border-radius: 4
  }
}
cross_join_penalty -> nested_loop_join: "Fallback Path\n(Highest Cost)"

# Step 2: Equi-Join Analysis
equi_join_check: "Check: Comparison Operator\n(Predicate Is '=' ?)" {
  class: decision
  tooltip: "Hash Joins and Merge Joins require equi-join semantics (Theta-joins use NLJ)."
}

equi_join_check -> index_check: {
  class: path_true
}
equi_join_check -> nested_loop_join: {
  class: path_false
}

# Step 3: Index Path Evaluation
index_check: "Check: Inner Index Coverage\n(L.key IN Inner_Idx?)" {
  class: decision
  tooltip: "Searching for B+Tree or Hash Index on the join columns of the inner relation."
}

index_check -> index_nlj: "Index Available" {
  class: path_true
}
index_check -> build_side_size: "No Index Coverage" {
  class: path_false
}

# Step 4: Cardinality & Memory Thresholds
build_side_size: "Check: Memory Budget\n(Est_Size < working_mem?)" {
  class: decision
  tooltip: "Calculate (Estimated_Rows * Avg_Tuple_Width) * Slack_Factor."
}

build_side_size -> hash_join: "Fits in RAM" {
  class: path_true
}
build_side_size -> sort_check: "Memory Spill Risk" {
  class: path_false
}

# Step 5: Interesting Orders (Physical Sort Alignment)
sort_check: "Check: Sort Alignment\n(Inputs Pre-sorted?)" {
  class: decision
  tooltip: "Identify if Child nodes (e.g., IndexScan) provide required sort order."
}

sort_check -> sort_merge_join: "Aligned / Sort Inherent" {
  class: path_true
}
sort_check -> sort_cost_eval: "Inputs Unsorted" {
  class: path_false
}

sort_cost_eval: "Eval: Cost(Sort + Merge)\nVS Cost(DiskHashJoin)" {
  class: decision
}

sort_cost_eval -> sort_merge_join: "Merge Wins" {
  class: path_true
}
sort_cost_eval -> hash_join: "Grace Hash Wins" {
  class: path_false
}

# --- PHYSICAL IMPLEMENTATION NODES (LEAF OPERATORS) ---

nested_loop_join: "PhysicalNLJoin" {
  class: operator
  label: |md
    ### PhysicalNLJoin
    **Complexity:** O(N * M)
    **Strategy:** Brute force nested iteration.
    **Constraint:** Used for non-equi joins or tiny relations (< 10 tuples).
    **AVX-512:** Limited vectorization (SIMD-IF).
  |
}

index_nlj: "PhysicalIndexNLJoin" {
  class: operator
  label: |md
    ### PhysicalIndexNLJoin
    **Complexity:** O(N * log M)
    **Strategy:** Outer scan, Inner index probe.
    **Requirement:** Index on join column of the inner table.
    **Cache:** Inner index blocks stay in L3 Cache.
  |
}

hash_join: "PhysicalHashJoin" {
  class: operator
  label: |md
    ### PhysicalHashJoin
    **Complexity:** O(N + M)
    **Strategy:** Build phase (Hash Table) + Probe phase.
    **I/O:** Sequential scan. Memory-intensive.
    **Grace Variant:** Spills buckets to disk if partition > RAM.
  |
}

sort_merge_join: "PhysicalSortMergeJoin" {
  class: operator
  label: |md
    ### PhysicalSortMergeJoin
    **Complexity:** O(N log N + M log M)
    **Strategy:** Sort phases + Linear merge scan.
    **Advantage:** Produces sorted output (Interesting Order).
    **I/O:** High Sort Overhead; Minimal Join Overhead.
  |
}

# --- ALGORITHM STATE: SELINGER DYNAMIC PROGRAMMING ---

selinger_context: "Selinger DP State Engine" {
  style: {
    stroke-dash: 5
    fill: "#F8F9FA"
  }
  
  level1: "Base Table Scan Costs\n(Sequential vs Index Scan)" { class: dp_state }
  level2: "Join Pairs {R1 ⨝ R2}\n(Evaluate Physical Ops)" { class: dp_state }
  level3: "Triple Joins {R1 ⨝ R2 ⨝ R3}\n(Bushy vs Left-Deep)" { class: dp_state }
  levelN: "Final Plan Selection\n(Min Total Cost Path)" { class: dp_state }
  
  level1 -> level2: "Permutation Space"
  level2 -> level3: "Permutation Space"
  level3 -> levelN: "Min-Cost Pruning"
}

# Connection from DP to Decision Tree logic
selinger_context.level2 -> equi_join_check: "Branch Evaluation" {
  style: {
    stroke: "#F9D8A7"
    stroke-width: 5
    animated: true
  }
}

# --- ENGINEERING METADATA & SPECS ---

cost_legend: {
  near: bottom-right
  class: note_box
  label: |md
    ### Cost Constants (M4 Spec)
    - **PAGE_READ**: 1.0 (Ref: HDD 8ms avg)
    - **TUPLE_CPU**: 0.01 (Ref: 2.4GHz Clock)
    - **HASH_BUILD**: 0.05 per tuple (SipHash-2-4)
    - **SORT_FACTOR**: 1.2 * log(N) (Quicksort overhead)
    
    ### Implementation Invariants
    1. **Outer/Inner**: HashJoin MUST 
       use smaller table as BUILD side.
    2. **Pruning**: Discard plans with 
       cost > 1.5x current global minimum.
  |
}

implementation_notes: |md
  ### Milestone 4 Requirements
  - **Grace Hash Join**: Must support recursive partitioning if bucket > `working_mem`.
  - **Early Exit**: If `NLJoin` cost exceeds current best plan during scan, terminate loop immediately.
  - **Block NLJ**: Default to Block-Nested Loop (BNLJ) with 64-page buffer for any theta join.
  - **Thread-Safety**: All physical operators must support `GetNext()` in a multi-threaded execution context.
| {
  near: bottom-left
  class: note_box
}

# Footnote for HW context
intel_hw_spec: |md
  **Hardware Optimization Note:**
  Hash Tables use SIMD-masked comparisons 
  to resolve collisions at 8-key intervals 
  using AVX-512 `_mm512_mask_cmpeq_epi64_mask`.
| {
  near: top-right
  class: note_box
}