direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

# ---------------------------------------------------------------------------------------
# JOIN PATH EXPLORATION SEQUENCE: Selinger-style Dynamic Programming (DP) Search
# ---------------------------------------------------------------------------------------
# Purpose: Illustrates subset enumeration, physical operator selection, and memoization.
# Actors represent core engine components in a modern analytical query optimizer.
# ---------------------------------------------------------------------------------------

search_process: {
  shape: sequence_diagram

  # Participants (Actors)
  opt: "DPOptimizer\n(PlanGenerator)" {
    shape: person
    style.stroke: "#4B0082"
    style.stroke-width: 3
  }
  cat: "Catalog\n(Metadata)" {
    style.fill: "#C6E2FF"
    style.stroke: "#336699"
    style.double-border: true
  }
  memo: "DPTable\n(Memoization)" {
    style.fill: "#E4DBFE"
    style.stroke: "#663399"
    style.stroke-dash: 2
  }
  sel: "JoinSelector\n(PhysicalLayer)" {
    style.fill: "#FFF9C9"
    style.stroke: "#999900"
  }
  cost: "CostModel\n(CPU/IO Weight)" {
    style.fill: "#FFE0F5"
    style.stroke: "#993366"
  }

  # --- PHASE 1: INITIALIZATION (SIZE 1) ---
  initialization: {
    opt -> cat: "get_table_stats(table_id: uint32)"
    cat -> opt: "TableMetadata {rows: 10M, pages: 125k, indices: [PK, IDX_A]}"
    
    opt -> opt: "generate_access_paths(table_id)"
    opt -> memo: "update_size_1({T1}, PhysSeqScan, cost: 5000)"
    
    memo_lock: {
      memo -> memo: "▼ Lock(bitmask: 0x01)"
      memo -> memo: "store_cheapest(ScanCandidate)"
      memo -> memo: "▲ Unlock(bitmask: 0x01)"
    }
  }

  # --- PHASE 2: DP ENUMERATION (SIZE K) ---
  dp_loop: {
    opt."Outer Loop: Subset size k = 2..N"
    opt."Inner Loop: Subsets S where |S| = k"
    
    opt -> opt: "generate_splits(subset_S) -> (L_mask, R_mask)"
    
    opt -> memo: "get_best(L_mask)"
    memo -> opt: "{BestPlan: IndexScan(T1), Cost: 120, Order: T1.id}"
    
    opt -> memo: "get_best(R_mask)"
    memo -> opt: "{BestPlan: SeqScan(T2), Cost: 800, Order: None}"
    
    # --- PHASE 3: PHYSICAL ALGORITHM SELECTION ---
    join_selection: {
      opt -> sel: "enumerate_joins(L_plan, R_plan, join_conds)"
      
      sel -> cost: "estimate_hash_join(L, R, bucket_count: 1024)"
      cost -> sel: "HJ_Cost {cpu: 450, io: 20, mem: 12MB}"
      
      # Logic for Sort-Merge Join (Interesting Orders)
      sort_merge_check: {
        sel."Branch: If L.is_sorted_on(cond) AND R.is_sorted_on(cond)"
        sel -> cost: "estimate_merge_join(L, R)"
        cost -> sel: "MJ_Cost {cpu: 150, io: 5, mem: 1MB}"
      }
      
      fallback_logic: {
        sel."Else: Sort Overhead Required"
        sel -> cost: "estimate_external_sort(R) + MJ_Cost"
        cost -> sel: "Total_Cost {cpu: 1200, io: 300}"
      }
      
      # Cross-Product Penalty (Red Alert Path)
      cross_product_check: {
        sel."Constraint: If NOT has_join_predicate(L, R)"
        sel -> sel: "apply_penalty(1000.0x)" {
          style: {
            stroke: red
            font-color: red
            bold: true
          }
        }
      }
      
      sel -> opt: "List[PhysicalJoinCandidate {Algorithm, Cost, SortOrder}]"
    }

    # --- PHASE 4: MEMOIZATION & CONCURRENCY ---
    memo_update: {
      opt -> memo: "update(subset_S_mask, Candidate)"
      
      memo_critical_section: {
        memo -> memo: "▼ Lock(subset_S_mask)"
        memo -> memo: "compare_cost(Candidate.total, current_best.total)"
        
        cheapest_path: {
          memo."Branch: If Candidate.cost < current_best.cost"
          memo -> memo: "replace_cheapest_overall(bitmask, Candidate)"
          memo.style.stroke: "#FF0000"
        }
        
        interesting_path: {
          memo."Branch: If Candidate.has_new_sort_order()"
          memo -> memo: "store_interesting_order(bitmask, Candidate)"
          memo.style.stroke: "#0000FF"
        }
        
        memo -> memo: "▲ Unlock(subset_S_mask)"
      }
    }
  }

  # --- FINALIZATION ---
  completion: {
    opt -> memo: "get_best(frozenset(all_tables))"
    memo -> opt: "RootPhysicalNode"
    opt -> opt: "build_physical_tree(RootPhysicalNode)"
  }
}

# ---------------------------------------------------------------------------------------
# IMPLEMENTATION ANNOTATIONS FOR ENGINEERS
# ---------------------------------------------------------------------------------------
# Changed "near: search_process" to "near: bottom-center" to satisfy ELK constraints.
# ---------------------------------------------------------------------------------------
annotations: {
  near: bottom-center
  
  complexity: |'md'
    ### Combinatorial Complexity
    - **Search Space**: $O(3^N)$ for left-deep, $O(4^N)$ for bushy trees.
    - **Memoization**: Prevents re-computing subproblems. Key: `bitmask` (uint64).
    - **Interesting Orders**: An expensive plan is preserved if its `SortOrder` satisfies a parent's `ORDER BY` or `JOIN` requirement, potentially reducing downstream `Sort` nodes.
  '| {
    style: {
      fill: "#f8f9fa"
      stroke: "#dee2e6"
      border-radius: 5
    }
  }
  
  locking_logic: |'md'
    ### Concurrency Rules
    1. **Task Parallelism**: Threads process Subsets of Size $K$ in parallel.
    2. **Dependency**: Level $K$ depends on Level $1 \dots K-1$.
    3. **Synchronization**: Barrier sync required after completing all subsets of size $K$.
    4. **Memory Management**: DP Table uses a lock-striped hash map or `std::atomic<Plan*>` per bitmask entry.
  '| {
    style: {
      fill: "#f8f9fa"
      stroke: "#dee2e6"
      border-radius: 5
    }
  }
}

# Styling Globs
search_process.** -> search_process.**: {
  style: {
    stroke: "#444444"
    font-size: 13
  }
}

(search_process.dp_loop -> *)[*]: {
  style.stroke-width: 2
}

# Highlighting specific logic paths
(search_process.dp_loop.join_selection.cross_product_check -> *)[*]: {
  style.stroke: red
  style.animated: true
}

# Implementation Details for Sequence Lifelines
search_process.opt.style.stroke: "#4B0082"
search_process.cat.style.stroke: "#336699"
search_process.memo.style.stroke: "#663399"
search_process.sel.style.stroke: "#999900"
search_process.cost.style.stroke: "#993366"