direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 25
  }
}

# --- GLOBAL CLASSES ---
classes: {
  logical_op: {
    style: {
      fill: "#E4DBFE"
      stroke: "#5D2AB2"
      stroke-width: 2
    }
  }
  physical_join: {
    shape: parallelogram
    style: {
      fill: "#C7F1FF"
      stroke: "#007BFF"
      stroke-width: 2
      bold: true
      font-size: 14
    }
  }
  base_scan: {
    shape: cylinder
    style: {
      fill: "#D1FFD1"
      stroke: "#28A745"
      stroke-width: 2
    }
  }
  data_flow: {
    style: {
      stroke: "#FF8C00"
      stroke-width: 3
      animated: true
    }
  }
  annotation: {
    shape: rectangle
    style: {
      fill: "#FFF9C9"
      font-size: 12
      border-radius: 4
      stroke-dash: 2
    }
  }
}

# --- DIAGRAM LAYOUT ---

Legend: {
  near: top-left
  scan: "Base Table Scan (Cylinder)" { class: base_scan }
  join: "Physical Join Operator" { class: physical_join }
  flow: "Tuple Stream (Active Pipelining)" { 
    style: { stroke: "#FF8C00"; stroke-width: 3 }
  }
}

# --- ROOT LEVEL NOTES (Fixing "near" constraint) ---
LD_Note: |md
  **Left-Deep Characteristics**
  - Right child is ALWAYS a base relation.
  - Optimized for **Pipelining**.
  - Search Space: $N!$
  - Memory: Minimized (Build side is small).
| { 
  class: annotation
  near: top-right 
}

BS_Note: |md
  **Bushy Characteristics**
  - Children can both be Join results.
  - Better for **Parallel Execution**.
  - Search Space: Catalan Number ($C_n$).
  - Handles massive joins symmetrically.
| { 
  class: annotation
  near: bottom-right
}

Topologies: {
  style.stroke: "#BDC3C7"
  style.fill: "transparent"
  
  LeftDeep: "Left-Deep Tree Topology" {
    style.stroke-dash: 5
    style.fill: "#F8F9FA"
    
    J3: "HashJoin (J3)" { class: physical_join }
    J2: "HashJoin (J2)" { class: physical_join }
    J1: "HashJoin (J1)" { class: physical_join }

    ScanA: "Scan(A)" { class: base_scan }
    ScanB: "Scan(B)" { class: base_scan }
    ScanC: "Scan(C)" { class: base_scan }
    ScanD: "Scan(D)" { class: base_scan }

    # Topology connections
    ScanA -> J1: "Build Side" { class: data_flow }
    ScanB -> J1: "Probe Side" { class: data_flow }
    
    J1 -> J2: "Probe Side" { class: data_flow }
    ScanC -> J2: "Build Side" { class: data_flow }
    
    J2 -> J3: "Probe Side" { class: data_flow }
    ScanD -> J3: "Build Side" { class: data_flow }

    J3 -> Output: "Final Result" { 
      style.stroke: "#28A745"
      style.stroke-width: 4
    }
    Output: { shape: oval; style.fill: "#E8F5E9" }
  }

  Bushy: "Bushy Tree Topology" {
    style.stroke-dash: 5
    style.fill: "#F8F9FA"

    BJ3: "HashJoin (J3)" { class: physical_join }
    BJ1: "HashJoin (J1)" { class: physical_join }
    BJ2: "HashJoin (J2)" { class: physical_join }

    BScanA: "Scan(A)" { class: base_scan }
    BScanB: "Scan(B)" { class: base_scan }
    BScanC: "Scan(C)" { class: base_scan }
    BScanD: "Scan(D)" { class: base_scan }

    # Topology connections
    BScanA -> BJ1: "Build" { class: data_flow }
    BScanB -> BJ1: "Probe" { class: data_flow }
    
    BScanC -> BJ2: "Build" { class: data_flow }
    BScanD -> BJ2: "Probe" { class: data_flow }
    
    BJ1 -> BJ3: "Build Side Result" { class: data_flow }
    BJ2 -> BJ3: "Probe Side Result" { class: data_flow }

    BJ3 -> BOutput: "Final Result" { 
      style.stroke: "#28A745"
      style.stroke-width: 4
    }
    BOutput: { shape: oval; style.fill: "#E8F5E9" }
  }
}

# Engineering Trade-offs table
Comparison: ||md
  ### Engineering Trade-offs
  
  | Feature | Left-Deep | Bushy |
  | :--- | :--- | :--- |
  | **Pipelining** | Excellent - 1 tuple at a time | Partial - Materialization required |
  | **Complexity** | $O(N!)$ | $O(4^N / N^{3/2})$ |
  | **Memory** | Lower (single hash table) | Higher (multiple active hash tables) |
  | **Use Case** | OLTP / Standard SQL | OLAP / Star Schema / Distributed |
|| {
  near: bottom-center
  shape: text
}

# --- Implementation Details for DP Search ---
SelingerDP: "Selinger DP Selection Process" {
  style.fill: "#FDFEFE"
  style.stroke: "#2E86C1"
  style.stroke-width: 2
  
  Step1: "Size 1: Access Paths" { class: logical_op }
  Step2: "Size 2: Pair Joins" { class: logical_op }
  Step3: "Size N: Subset Merging" { class: logical_op }

  Step1 -> Step2: "Permute"
  Step2 -> Step3: "Recurse"
  
  Step3 -> Pruning: "Prune by Cost + Sort Order" {
    style.stroke: "#E74C3C"
    style.stroke-width: 2
  }
  
  Pruning: {
    shape: diamond
    style.fill: "#FDEDEC"
    style.stroke: "#CB4335"
  }
  
  Pruning -> Topologies.LeftDeep: "Optimal Path (Min Cost)" {
    style.stroke-dash: 4
    style.stroke: "#27AE60"
    style.bold: true
  }
}