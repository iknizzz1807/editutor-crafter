direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    register-blue: "#4A90D9"
    m1-green: "#5CB85C"
    m2-orange: "#F0AD4E"
    m3-purple: "#9B59B6"
    m4-red: "#E74C3C"
    cache-gray: "#7F8C8D"
    data-cyan: "#17A2B8"
  }
}
title: "SIMD Optimization Library: System Map" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_main: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  cache_hierarchy: Cache Hierarchy {
    direction: down
    style.fill: ${colors.cache-gray}
    style.opacity: 0.3
    l1: L1 Cache {
      shape: rectangle
      label: "L1 Cache\n32 KB/core\n~4 cycles"
      width: 120
    }
    l2: L2 Cache {
      shape: rectangle
      label: "L2 Cache\n256 KB/core\n~12 cycles"
      width: 120
    }
    l3: L3 Cache {
      shape: rectangle
      label: "L3 Cache\n8-32 MB shared\n~40 cycles"
      width: 120
    }
    ram: Main Memory {
      shape: cylinder
      label: "RAM\nDDR4/DDR5\n~100+ ns"
      width: 120
    }
    l1 -> l2: "miss"
    l2 -> l3: "miss"
    l3 -> ram: "miss"
  }
  core_system: "" {
    direction: down
    style: {
      stroke: transparent
      fill: transparent
    }
    register_hub: XMM/YMM Register File {
      direction: down
      style.fill: ${colors.register-blue}
      style.stroke: "#2E5A8C"
      style.stroke-width: 3
      width: 400
      label: "XMM/YMM Register File\n(Central Processing Hub)"
      xmm_regs: {
        shape: sql_table
        label: "XMM Registers (128-bit)"
        r0: "xmm0  | 4x float | 16 bytes"
        r1: "xmm1  | 4x float | 16 bytes"
        r2: "...   | ...      | ..."
        r15: "xmm15 | 4x float | 16 bytes"
        total: "16 registers | SSE2+"
      }
      ymm_regs: {
        shape: sql_table
        label: "YMM Registers (256-bit)"
        r0: "ymm0  | 8x float | 32 bytes"
        r1: "ymm1  | 8x float | 32 bytes"
        r2: "...   | ...      | ..."
        r15: "ymm15 | 8x float | 32 bytes"
        total: "16 registers | AVX+"
      }
      xmm_regs -> ymm_regs: "extends (lower 128b alias)"
    }
    milestones_row: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      m1_region: M1 Memory Operations {
        direction: down
        style.fill: ${colors.m1-green}
        style.opacity: 0.7
        width: 280
        m1_label: {
          label: "M1: memset & memcpy"
          shape: rectangle
          style.bold: true
        }
        m1_input: {
          shape: class
          label: "Input"
          src: "void* src"
          dst: "void* dst"
          count: "size_t n"
          value: "int c (memset)"
        }
        m1_ops: {
          label: "Key Operations"
          shape: rectangle
          width: 240
          code: |'c
            _mm_set1_epi8(c)    // broadcast
            _mm_load_si128()    // aligned load
            _mm_store_si128()   // aligned store
            _mm_stream_si128()  // non-temporal
          '|
        }
        m1_pattern: {
          label: "Pattern"
          shape: rectangle
          width: 240
          code: |'c
            // Prologue: scalar align
            // Body: 16B/cycle
            // Epilogue: scalar tail
          '|
        }
        m1_output: {
          shape: class
          label: "Output"
          result: "void* (dest ptr)"
          effect: "Memory copied/filled"
        }
        m1_input -> m1_ops -> m1_pattern -> m1_output
      }
      m2_region: M2 String Operations {
        direction: down
        style.fill: ${colors.m2-orange}
        style.opacity: 0.7
        width: 280
        m2_label: {
          label: "M2: strlen & memchr"
          shape: rectangle
          style.bold: true
        }
        m2_input: {
          shape: class
          label: "Input"
          str: "const char* s"
          c: "int c (memchr)"
          n: "size_t n (memchr)"
        }
        m2_ops: {
          label: "Key Operations"
          shape: rectangle
          width: 240
          code: |'c
            _mm_cmpeq_epi8()    // compare
            _mm_movemask_epi8() // bitmask
            __builtin_ctz()     // find first
          '|
        }
        m2_pattern: {
          label: "Pattern"
          shape: rectangle
          width: 240
          code: |'c
            // Aligned-from-below read
            // Mask out pre-start bytes
            // Safe page-boundary handling
          '|
        }
        m2_output: {
          shape: class
          label: "Output"
          length: "size_t (strlen)"
          position: "void* (memchr)"
        }
        m2_input -> m2_ops -> m2_pattern -> m2_output
      }
      m3_region: M3 Math Operations {
        direction: down
        style.fill: ${colors.m3-purple}
        style.opacity: 0.7
        width: 280
        m3_label: {
          label: "M3: dot & matmul"
          shape: rectangle
          style.bold: true
        }
        m3_input: {
          shape: class
          label: "Input"
          a: "const float* a"
          b: "const float* b"
          n: "size_t n"
          m: "size_t m, k (matmul)"
        }
        m3_ops: {
          label: "Key Operations"
          shape: rectangle
          width: 240
          code: |'c
            _mm_mul_ps()        // multiply
            _mm_add_ps()        // accumulate
            _mm_shuffle_ps()    // reduction
            _mm_fmadd_ps()      // FMA
          '|
        }
        m3_pattern: {
          label: "Reduction Pattern"
          shape: rectangle
          width: 240
          code: |'c
            // Shuffle+Add (NOT hadd!)
            // Tree reduction: log2(lanes)
            // 4 floats -> 1 scalar
          '|
        }
        m3_output: {
          shape: class
          label: "Output"
          dot: "float (dot product)"
          matrix: "float* C (matmul)"
        }
        m3_input -> m3_ops -> m3_pattern -> m3_output
      }
      m4_region: M4 Compiler Analysis {
        direction: down
        style.fill: ${colors.m4-red}
        style.opacity: 0.7
        width: 280
        m4_label: {
          label: "M4: Auto-vectorization"
          shape: rectangle
          style.bold: true
        }
        m4_input: {
          shape: class
          label: "Input"
          code: "scalar C loops"
          flags: "compiler flags"
        }
        m4_analysis: {
          label: "Compiler Analysis"
          shape: rectangle
          width: 240
          code: |'c
            // Alias analysis
            // Dependency analysis  
            // Alignment analysis
            // Trip count analysis
            // Cost modeling
          '|
        }
        m4_decision: {
          label: "Decision Tree"
          shape: diamond
          width: 200
        }
        m4_output: {
          shape: class
          label: "Output"
          vectorized: "SIMD instructions"
          scalar: "original loop"
          report: "vectorization report"
        }
        m4_input -> m4_analysis -> m4_decision -> m4_output
      }
    }
  }
}
connections: "" {
  direction: down
  style: {
    stroke: transparent
    fill: transparent
  }
  register_to_m1: register_hub -> m1_region: "load/store" {
    style.stroke: ${colors.m1-green}
    style.stroke-width: 3
  }
  register_to_m2: register_hub -> m2_region: "load/cmp" {
    style.stroke: ${colors.m2-orange}
    style.stroke-width: 3
  }
  register_to_m3: register_hub -> m3_region: "fma/shuffle" {
    style.stroke: ${colors.m3-purple}
    style.stroke-width: 3
  }
  register_to_m4: register_hub -> m4_region: "generates" {
    style.stroke: ${colors.m4-red}
    style.stroke-width: 2
    style.stroke-dash: 5
  }
  cache_to_registers: cache_hierarchy.l1 -> register_hub: "data flow" {
    style.stroke: ${colors.cache-gray}
    style.stroke-dash: 3
  }
}
cross_milestone: "" {
  direction: down
  style: {
    stroke: transparent
    fill: transparent
  }
  m1_to_m2: m1_region -> m2_region: "alignment pattern" {
    style.stroke: ${colors.data-cyan}
    style.stroke-dash: 4
    label: "prologue/epilogue"
  }
  m2_to_m3: m2_region -> m3_region: "reduction" {
    style.stroke: ${colors.data-cyan}
    style.stroke-dash: 4
    label: "movemask+ctz"
  }
  m3_to_m4: m3_region -> m4_region: "analysis" {
    style.stroke: ${colors.data-cyan}
    style.stroke-dash: 4
    label: "hadd vs shuffle+add"
  }
  m4_to_all: m4_region -> m1_region: "optimizes" {
    style.stroke: ${colors.m4-red}
    style.stroke-dash: 3
    style.opacity: 0.5
  }
}
legend: Legend {
  near: bottom-right
  style.fill: white
  style.stroke: black
  leg_m1: M1 Memory {
    shape: rectangle
    style.fill: ${colors.m1-green}
  }
  leg_m2: M2 Strings {
    shape: rectangle
    style.fill: ${colors.m2-orange}
  }
  leg_m3: M3 Math {
    shape: rectangle
    style.fill: ${colors.m3-purple}
  }
  leg_m4: M4 Compiler {
    shape: rectangle
    style.fill: ${colors.m4-red}
  }
  leg_cache: Cache {
    shape: rectangle
    style.fill: ${colors.cache-gray}
    style.opacity: 0.3
  }
  leg_data: Data Flow {
    shape: rectangle
    style.fill: ${colors.data-cyan}
  }
}