direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Hardware Soul: Cache Line Boundaries in SIMD
  64-byte cache lines determine whether a single SIMD load touches one or two memory blocks
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  aligned_load: {
    direction: down
    label: "Aligned Load (Single Cache Line)"
    addr_aligned: {
      label: "Address: 0x38"
      width: 120
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    cache_line_1: {
      label: "Cache Line 0: 0x00–0x3F (64 bytes)"
      width: 400
      style.fill: "#E3F2FD"
      style.stroke: "#1565C0"
      bytes_1: {
        grid-columns: 8
        grid-gap: 0
        width: 400
        b00: "0x00" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b08: "0x08" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b10: "0x10" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b18: "0x18" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b20: "0x20" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b28: "0x28" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b30: "0x30" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
        b38: "0x38" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.bold: true}
      }
    }
    load_region_1: {
      label: "_mm_load_si128: 16 bytes"
      width: 100
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      style.font-color: "#1B5E20"
    }
    result_1: {
      label: "Result: L1 Cache HIT"
      width: 160
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.font-color: "#1B5E20"
      style.bold: true
    }
    latency_1: {
      label: "Latency: ~4 cycles"
      width: 120
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
    }
    addr_aligned -> cache_line_1: "load from"
    cache_line_1.bytes_1.b38 -> load_region_1: "16B"
    load_region_1 -> result_1
    result_1 -> latency_1
  }
  split_load: {
    direction: down
    label: "Split Load (Two Cache Lines)"
    addr_split: {
      label: "Address: 0x3C"
      width: 120
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
    }
    cache_pair: {
      direction: right
      label: ""
      cache_line_2: {
        direction: down
        label: "Cache Line 0: 0x00–0x3F"
        width: 200
        style.fill: "#E3F2FD"
        style.stroke: "#1565C0"
        bytes_2a: {
          grid-columns: 4
          grid-gap: 0
          width: 200
          b00a: "0x00" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b08a: "0x08" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b10a: "0x10" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b18a: "0x18" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b20a: "0x20" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b28a: "0x28" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b30a: "0x30" {style.fill: "#BBDEFB"; style.stroke: "#1565C0"}
          b38a: "0x38" {style.fill: "#FFCDD2"; style.stroke: "#C62828"; style.bold: true}
        }
      }
      cache_line_3: {
        direction: down
        label: "Cache Line 1: 0x40–0x7F"
        width: 200
        style.fill: "#FFF3E0"
        style.stroke: "#E65100"
        bytes_2b: {
          grid-columns: 4
          grid-gap: 0
          width: 200
          b40: "0x40" {style.fill: "#FFCDD2"; style.stroke: "#C62828"; style.bold: true}
          b48: "0x48" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
          b50: "0x50" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
          b58: "0x58" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
          b60: "0x60" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
          b68: "0x68" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
          b70: "0x70" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
          b78: "0x78" {style.fill: "#FFE0B2"; style.stroke: "#E65100"}
        }
      }
    }
    load_split: {
      label: "_mm_loadu_si128: 16 bytes"
      width: 180
      style.fill: "#EF5350"
      style.stroke: "#C62828"
      style.font-color: white
    }
    split_arrow: {
      direction: right
      label: ""
      part1: {
        label: "4 bytes"
        width: 60
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
      }
      part2: {
        label: "12 bytes"
        width: 80
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
      }
    }
    result_2: {
      label: "Result: TWO L1 Cache Hits"
      width: 180
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.font-color: "#B71C1C"
      style.bold: true
    }
    latency_2: {
      label: "Latency: ~6-8 cycles"
      width: 130
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
    }
    addr_split -> cache_pair
    cache_line_2.bytes_2a.b38a -> load_split: "4B"
    cache_line_3.bytes_2b.b40 -> load_split: "12B"
    load_split -> split_arrow
    split_arrow -> result_2
    result_2 -> latency_2
  }
}
row1.aligned_load -> row1.split_load: "same 16B load\nwrong address" {
  style.stroke-dash: 4
  style.stroke: "#757575"
}
cache_structure: {
  direction: right
  label: "L1 Data Cache Structure (Typical x86)"
  l1d: {
    direction: down
    label: "L1d Cache: 32KB, 8-way"
    set0: {
      label: "Set 0"
      width: 100
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    set1: {
      label: "Set 1"
      width: 100
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    setN: {
      label: "Set 63"
      width: 100
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    dots: {
      label: "..."
      shape: text
    }
    set0 -> set1 -> dots -> setN
  }
  line_detail: {
    direction: down
    label: "Each Cache Line: 64 bytes"
    line_box: {
      width: 300
      label: "[Tag][Valid][Dirty][  64 bytes of data  ]"
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      style.font: mono
    }
    alignment_note: {
      label: "Cache line starts at address % 64 == 0"
      width: 280
      style.fill: "#EDE7F6"
      style.stroke: "#7B1FA2"
    }
  }
  l1d -> line_detail
}
alignment_table: {
  direction: right
  label: "Alignment Requirements by SIMD Width"
  col_header: {
    grid-columns: 4
    grid-gap: 0
    h1: "SIMD" {style.fill: "#37474F"; style.font-color: white; style.bold: true}
    h2: "Width" {style.fill: "#37474F"; style.font-color: white; style.bold: true}
    h3: "Alignment" {style.fill: "#37474F"; style.font-color: white; style.bold: true}
    h4: "Cache Lines" {style.fill: "#37474F"; style.font-color: white; style.bold: true}
  }
  row_sse: {
    grid-columns: 4
    grid-gap: 0
    r1a: "SSE2" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
    r1b: "128-bit" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
    r1c: "16-byte" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"}
    r1d: "1 max" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
  }
  row_avx: {
    grid-columns: 4
    grid-gap: 0
    r2a: "AVX" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
    r2b: "256-bit" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
    r2c: "32-byte" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"}
    r2d: "1 max" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
  }
  row_avx512: {
    grid-columns: 4
    grid-gap: 0
    r3a: "AVX-512" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
    r3b: "512-bit" {style.fill: "#E3F2FD"; style.stroke: "#1565C0"}
    r3c: "64-byte" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"}
    r3d: "1 (exact!)" {style.fill: "#C8E6C9"; style.stroke: "#2E7D32"; style.bold: true}
  }
}
key_insight: {
  label: "Key Insight: 64-byte aligned loads NEVER span cache lines"
  width: 450
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
  style.bold: true
  style.border-radius: 8
}
legend: {
  near: bottom-right
  direction: right
  label: ""
  leg_hit: {
    label: "Single cache line"
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    width: 120
  }
  leg_split: {
    label: "Split across lines"
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    width: 120
  }
}
cache_structure -> alignment_table
alignment_table -> key_insight