execution_flow: {
  label: "Execution Flow"
  style.fill: transparent
  style.stroke: transparent
  direction: down
  step1: {
    label: "Step 1: Scalar Prologue"
    width: 600
    style.fill: "#FFF8DC"
    style.stroke: "#FF8C00"
    desc: |md
      **Goal**: Reach 16-byte alignment
      - Input: `ptr = 0x1003` (offset 3 from 16-byte boundary)
      - Calculate: `align_offset = (16 - (0x1003 & 15)) & 15 = 13`
      - Process bytes `0x1003` to `0x100F` (13 bytes) one-at-a-time
      - After: `ptr = 0x1010` (aligned!)
    |
  }
  step1_code: {
    label: "Prologue Code"
    width: 600
    code: |'c
      size_t align_offset = (16 - ((size_t)ptr & 15)) & 15;
      for (size_t i = 0; i < align_offset; i++) {
          dst[i] = value;  // Scalar byte store
      }
      ptr += align_offset;  // Now aligned to 0x1010
    '|
    style.fill: "#FFFACD"
  }
  step2: {
    label: "Step 2: SIMD Body (Aligned)"
    width: 600
    style.fill: "#E0F0FF"
    style.stroke: "#0066CC"
    desc: |md
      **Goal**: Process 16 bytes per iteration
      - `ptr = 0x1010` (16-byte aligned)
      - `remaining = 47 - 13 = 34 bytes`
      - `vector_count = 34 / 16 = 2` iterations
      - Vector 1: `0x1010 - 0x101F` (16 bytes)
      - Vector 2: `0x1020 - 0x102F` (16 bytes)
      - Total processed: 32 bytes
    |
  }
  step2_code: {
    label: "SIMD Body Code"
    width: 600
    code: |'c
      __m128i fill = _mm_set1_epi8((char)c);
      __m128i* d_vec = (__m128i*)ptr;  // Safe cast: aligned!
      for (size_t i = 0; i < vector_count; i++) {
          _mm_store_si128(&d_vec[i], fill);  // Aligned store
      }
    '|
    style.fill: "#E6F3FF"
  }
  step3: {
    label: "Step 3: Scalar Epilogue"
    width: 600
    style.fill: "#FFF8DC"
    style.stroke: "#FF8C00"
    desc: |md
      **Goal**: Process remaining bytes
      - `remaining = 34 & 15 = 2` bytes
      - Process `0x1030 - 0x1031` (2 bytes) one-at-a-time
      - Total bytes processed: 13 + 32 + 2 = 47 ✓
    |
  }
  step3_code: {
    label: "Epilogue Code"
    width: 600
    code: |'c
      size_t remaining = count & 15;  // 34 & 15 = 2
      unsigned char* tail = ptr + (vector_count * 16);
      for (size_t i = 0; i < remaining; i++) {
          tail[i] = (unsigned char)c;  // Scalar byte store
      }
    '|
    style.fill: "#FFFACD"
  }
  step1 -> step1_code -> step2 -> step2_code -> step3 -> step3_code: "flow"
}
summary_table: {
  label: "Summary"
  shape: sql_table
  phase: "Phase | Range | Bytes | Method"
  prologue_row: "Prologue | 0x1003-0x100F | 13 | Scalar (byte-by-byte)"
  simd_row: "SIMD Body | 0x1010-0x102F | 32 | Vector (16 bytes/store)"
  epilogue_row: "Epilogue | 0x1030-0x1031 | 2 | Scalar (byte-by-byte)"
  total_row: "Total | 0x1003-0x1031 | 47 | —"
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  scalar_legend: {
    label: "Scalar (orange)"
    shape: rectangle
    width: 100
    height: 20
    style.fill: "#FFD700"
    style.stroke: "#FF8C00"
  }
  simd_legend: {
    label: "SIMD (blue)"
    shape: rectangle
    width: 100
    height: 20
    style.fill: "#ADD8E6"
    style.stroke: "#0066CC"
  }
}
key_insight: {
  label: |md
    **Key Insight**: Aligned `_mm_store_si128` requires 16-byte alignment.
    The prologue ensures the pointer is aligned before the SIMD loop.
    Formula: `align_offset = (16 - ((size_t)ptr & 15)) & 15`
  |
  near: bottom-center
  style.fill: "#F0FFF0"
  style.stroke: "#228B22"
  style.stroke-width: 2
  width: 500
}