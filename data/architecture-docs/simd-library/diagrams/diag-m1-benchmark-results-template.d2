legend: "" {
  direction: right
  style.stroke: "#ccc"
  style.fill: "#f5f5f5"
  legend_title: |md
    **Key Findings**
  |
  findings: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    f1: "1. libc wins everywhere: glibc memset uses AVX-512, REP STOSB, and CPU dispatch"
    f2: "2. SSE2 beats scalar 4-5× for buffers >1KB where loop overhead dominates"
    f3: "3. Memory bandwidth bound at >1MB: all converge to ~25 GB/s (DDR4-3200)"
    f4: "4. Streaming stores win at >16MB: non-temporal stores bypass cache"
  }
}
legend.near: bottom-center

data_table: {
  shape: sql_table
  label: "memset Benchmark Results (Intel i7, DDR4-3200, CPU pinned 2.4GHz)"
  col_header: "Size | Scalar | SSE2 | libc | Streaming"
  row_64: "64 B | 1.2 GB/s | 2.1 GB/s | 5.3 GB/s | —"
  row_256: "256 B | 1.4 GB/s | 4.2 GB/s | 12.1 GB/s | —"
  row_1k: "1 KB | 1.5 GB/s | 8.4 GB/s | 18.7 GB/s | —"
  row_4k: "4 KB | 1.6 GB/s | 14.2 GB/s | 22.1 GB/s | 10.3 GB/s"
  row_16k: "16 KB | 1.7 GB/s | 18.9 GB/s | 24.3 GB/s | 16.8 GB/s"
  row_64k: "64 KB | 2.1 GB/s | 21.5 GB/s | 24.8 GB/s | 22.1 GB/s"
  row_256k: "256 KB | 4.8 GB/s | 23.2 GB/s | 25.1 GB/s | 24.3 GB/s"
  row_1m: "1 MB | 6.2 GB/s | 24.1 GB/s | 25.3 GB/s | 25.0 GB/s"
  row_4m: "4 MB | 7.8 GB/s | 24.8 GB/s | 25.4 GB/s | 25.6 GB/s"
  row_16m: "16 MB | 8.4 GB/s | 25.0 GB/s | 25.5 GB/s | 25.8 GB/s"
  note: "Note: Streaming used for >64KB where cache bypass provides measurable gains."
}

insights: "" {
  direction: right
  style.fill: "#fff9e6"
  style.stroke: "#e6c200"
  
  insight1: {
    label: "Why libc wins"
    width: 250
    code: |'c
      if (cpu_has_avx512) {
        __m512i v = _mm512_set1_epi8(c);
        _mm512_store_si512(dst, v);
      } else if (cpu_has_avx) {
        __m256i v = _mm256_set1_epi8(c);
        _mm256_store_si256(dst, v);
      }
      // Plus REP STOSB for tiny buffers
    '|
  }
  
  insight2: {
    label: "Instruction Density"
    width: 250
    code: |'c
      // Hand-written SSE2 (16B/store)
      __m128i fill = _mm_set1_epi8(c);
      _mm_store_si128(dst++, fill);

      // libc AVX-512 (64B/store)
      // 4x fewer loop iterations
      // 4x less branch/loop overhead
    '|
  }
  
  insight3: {
    label: "The Memory Wall"
    width: 250
    code: |'c
      // Hit DDR4 bandwidth limit:
      // DDR4-3200: ~25.6 GB/s
      // Dual-channel: ~51 GB/s
      // CPU computes faster than 
      // RAM can supply data!
    '|
  }
}

takeaway: |md
  ### The Honest Truth
  **You won't beat libc's memset/memcpy on production systems.**
  The purpose of hand-written SIMD is to master the patterns libc uses:
  - Prologue/epilogue alignment handling
  - Non-temporal stores for cache bypass
  - Instruction density optimization
  Master them here to build algorithms libc doesn't provide: string scanning, custom filters, and matrix math.
| {
  style.fill: "#f0f0f0"
  style.stroke: "#999"
  width: 780
}
takeaway.near: bottom-center