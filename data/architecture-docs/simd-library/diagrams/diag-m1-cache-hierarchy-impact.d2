direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
header: {
  style.stroke: transparent
  style.fill: transparent
  title: "Non-Temporal Stores: Cache Hierarchy Impact" {
    shape: rectangle
    style: {
      font-size: 28
      bold: true
      underline: true
      stroke: transparent
      fill: transparent
    }
  }
}

# --- COMPARISON ROW ---
row_before_after: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  before: "BEFORE: Normal Store" {
    direction: down
    style: {
      fill: "#FFF5F5"
      stroke: "#E53E3E"
      stroke-width: 2
    }
    b_cpu: CPU (Execution Core) {
      shape: rectangle
      style.fill: "#E2E8F0"
    }
    b_l1: L1 Cache (32 KB) {
      shape: rectangle
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
      }
    }
    b_l2: L2 Cache (256 KB) {
      shape: rectangle
      style: {
        fill: "#BEE3F8"
        stroke: "#3182CE"
      }
    }
    b_l3: L3 Cache (Shared) {
      shape: rectangle
      style: {
        fill: "#E9D8FD"
        stroke: "#805AD5"
      }
    }
    b_ram: Main Memory (DRAM) {
      shape: cylinder
      style: {
        fill: "#FED7AA"
        stroke: "#DD6B20"
      }
    }
    
    b_cpu -> b_l1: "Cached Store" {
      style.stroke: "#38A169"
      style.stroke-width: 3
    }
    b_l1 -> b_l2: "Write-back"
    b_l2 -> b_l3: "Write-back"
    b_l3 -> b_ram: "Write-back"
    
    b_evicted: "Hot Data Evicted!" {
      shape: callout
      style: {
        fill: "#FED7D7"
        stroke: "#C53030"
      }
    }
    b_l1 -> b_evicted: "Collateral Damage" {
      style.stroke-dash: 3
      style.stroke: "#C53030"
    }
  }

  after: "AFTER: Non-Temporal Store" {
    direction: down
    style: {
      fill: "#F0FFF4"
      stroke: "#38A169"
      stroke-width: 2
    }
    a_cpu: CPU (Execution Core) {
      shape: rectangle
      style.fill: "#E2E8F0"
    }
    a_l1: L1 Cache (Untouched) {
      shape: rectangle
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
        opacity: 0.4
      }
    }
    a_l2: L2 Cache (Untouched) {
      shape: rectangle
      style: {
        fill: "#BEE3F8"
        stroke: "#3182CE"
        opacity: 0.4
      }
    }
    a_l3: L3 Cache (Untouched) {
      shape: rectangle
      style: {
        fill: "#E9D8FD"
        stroke: "#805AD5"
        opacity: 0.4
      }
    }
    a_ram: Main Memory (DRAM) {
      shape: cylinder
      style: {
        fill: "#FED7AA"
        stroke: "#DD6B20"
      }
    }
    
    a_cpu -> a_ram: "Streaming Store" {
      style: {
        stroke: "#38A169"
        stroke-width: 4
        animated: true
      }
    }
    
    a_preserved: "Hot Data Preserved!" {
      shape: callout
      style: {
        fill: "#C6F6D5"
        stroke: "#38A169"
      }
    }
    a_l1 -> a_preserved: "Zero Pollution" {
      style.stroke: "#38A169"
      style.stroke-dash: 3
    }
  }
}

# --- DECISION AND ANALYSIS SECTION ---
decision_section: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  decision_table: Decision Logic {
    shape: rectangle
    width: 450
    style: {
      fill: "#FFFFF0"
      stroke: "#D69E2E"
    }
    content: |'md
      | Buffer Size | Cache Fit | Strategy |
      | :--- | :--- | :--- |
      | < 64 KB | L1/L2 | **Normal Store** |
      | 64KB - 1MB | Borderline | Profile & Measure |
      | > 1 MB | L3/RAM | **NT Store** |

      **Guideline**: Non-temporal stores (`_mm_stream_*`) prevent heavy write workloads from evicting the active instruction/data set from L1/L2 caches.
    '|
  }

  bandwidth_graph: Performance Characteristic {
    shape: rectangle
    width: 450
    style: {
      fill: "#F7FAFC"
      stroke: "#4A5568"
    }
    content: |'md
      **Bandwidth Performance**
      
      BW |        _______ NT (Streaming)
         |       /
         |      /
      GB/s|    /   ____ Normal (Cached)
         |   /   /
         |  /   /
         |_/___/_________________
           0  L2sz   L3sz   RAM
      
      **Key Insight**: NT stores provide stable throughput once buffer exceeds private cache capacity.
    '|
  }
}

# --- IMPLEMENTATION SECTION ---
code_example: "SIMD Implementation (Intrinsics)" {
  direction: right
  style: {
    fill: "#EDF2F7"
    stroke: "#4A5568"
  }
  normal_code: "Normal (Cached)" {
    width: 380
    code: |'c
      // Pollutes hierarchy
      for (size_t i = 0; i < n/16; i++) {
        __m128i data = _mm_loadu_si128(&src[i]);
        _mm_store_si128(&dst[i], data);
        // Writes to L1 -> L2 -> L3
        // Displaces hot working set!
      }
    '|
  }
  streaming_code: "Streaming (NT)" {
    width: 380
    code: |'c
      // Bypasses hierarchy
      for (size_t i = 0; i < n/16; i++) {
        __m128i data = _mm_loadu_si128(&src[i]);
        _mm_stream_si128(&dst[i], data);
        // Writes directly to RAM
        // Caches remain clean
      }
      _mm_sfence(); // MANDATORY
    '|
  }
}

# --- FOOTER ANNOTATIONS ---
warning_box: "Critical: SFENCE Requirement" {
  shape: callout
  style: {
    fill: "#FED7D7"
    stroke: "#C53030"
  }
  content: |'md
    **SFENCE is non-negotiable.** 
    NT stores use weakly-ordered memory semantics. 
    Without `_mm_sfence()`, other threads or DMA devices may read inconsistent state from memory before the NT stores are actually globally visible.
  '|
}
warning_box.near: bottom-center

legend_box: Legend {
  style: {
    fill: "#FFFFFF"
    stroke: "#718096"
  }
  content: |'md
    - 🟢 Green: Path Optimized
    - 🔴 Red: Resource Contention
    - 🟠 Orange: Persistent Storage
    - ⚪ Faded: Bypassed Logic
  '|
}
legend_box.near: bottom-right