direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Aligned Read with Byte Masking {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
subtitle: "String 'hello\\0' at unaligned address 0x1003" {
  near: top-center
  shape: text
  style.font-size: 16
}
step1: {
  label: "Step 1: Compute Aligned Base Address"
  width: 480
  code: |'c
    const char* str = (const char*)0x1003;  // Input string
    uintptr_t addr = (uintptr_t)str;         // addr = 0x1003
    // Align down to 16-byte boundary
    uintptr_t aligned = addr & ~15;          // 0x1003 & ~0xF = 0x1000
    // Compute byte offset within the 16-byte block
    unsigned int offset = addr & 15;         // 0x1003 & 0xF = 3
  '|
}
step2: {
  label: "Step 2: Safe Aligned Load (Cannot Cross Page Boundary)"
  width: 480
  code: |'c
    // Read 16 bytes FROM the aligned address
    // This is SAFE: 0x1000 is 16-byte aligned
    // Cannot fault even if 0x100F is near a page boundary
    const char* aligned_ptr = (const char*)0x1000;
    __m128i chunk = _mm_load_si128((__m128i*)aligned_ptr);
  '|
}
memory_layout: {
  label: "Memory Layout After Aligned Load"
  width: 560
  style.fill: "#E8F4E8"
  addr_col: {
    label: "Address"
    shape: sql_table
    f0: "0x1000"
    f1: "0x1001"
    f2: "0x1002"
    f3: "0x1003"
    f4: "0x1004"
    f5: "0x1005"
    f6: "0x1006"
    f7: "0x1007"
    f8: "0x1008"
    f9: "..."
    f10: "0x100E"
    f11: "0x100F"
    style.fill: "#D4E8D4"
  }
  byte_col: {
    label: "Byte Value"
    shape: sql_table
    f0: "0x??"
    f1: "0x??"
    f2: "0x??"
    f3: "'h' (0x68)"
    f4: "'e' (0x65)"
    f5: "'l' (0x6C)"
    f6: "'l' (0x6C)"
    f7: "'o' (0x6F)"
    f8: "'\\0' (0x00)"
    f9: "..."
    f10: "0x??"
    f11: "0x??"
    style.fill: "#FFF8DC"
  }
  note_col: {
    label: "Notes"
    shape: sql_table
    f0: "garbage (before string)"
    f1: "garbage (before string)"
    f2: "garbage (before string)"
    f3: "string start"
    f4: ""
    f5: ""
    f6: ""
    f7: ""
    f8: "null terminator"
    f9: ""
    f10: "garbage"
    f11: "garbage"
    style.fill: "#E8E8E8"
  }
  direction: right
  addr_col -> byte_col -> note_col: {
    style.opacity: 0
  }
}
step3: {
  label: "Step 3: Create Ignore Mask for Pre-String Bytes"
  width: 480
  code: |'c
    // offset = 3 (string starts at byte index 3)
    // Create mask that IGNORES bytes 0, 1, 2
    // (1 << 3) - 1 = 0b00000111 = 0x07
    unsigned int ignore_mask = (1U << offset) - 1;  // 0x07
    // Invert to get KEEP mask
    // ~0x07 = 0xFFFFFFF8 (keeps bytes 3-15)
    unsigned int keep_mask = ~ignore_mask;
  '|
}
step4: {
  label: "Step 4: Compare All 16 Bytes Against Null"
  width: 480
  code: |'c
    __m128i zero = _mm_setzero_si128();     // [0,0,0,...,0]
    __m128i cmp = _mm_cmpeq_epi8(chunk, zero);
    // Result: 0xFF where byte == 0, 0x00 otherwise
  '|
}
comparison_result: {
  label: "Comparison Result Vector"
  width: 560
  style.fill: "#FFE8E8"
  idx_col: {
    label: "Byte Index"
    shape: sql_table
    f0: "0"
    f1: "1"
    f2: "2"
    f3: "3"
    f4: "4"
    f5: "5"
    f6: "6"
    f7: "7"
    f8: "8"
    f9: "..."
    f10: "14"
    f11: "15"
    style.fill: "#E8D4D4"
  }
  val_col: {
    label: "Byte Value"
    shape: sql_table
    f0: "0x??"
    f1: "0x??"
    f2: "0x??"
    f3: "'h'"
    f4: "'e'"
    f5: "'l'"
    f6: "'l'"
    f7: "'o'"
    f8: "'\\0'"
    f9: "..."
    f10: "0x??"
    f11: "0x??"
    style.fill: "#FFF8DC"
  }
  cmp_col: {
    label: "cmpeq Result"
    shape: sql_table
    f0: "0x00"
    f1: "0x00"
    f2: "0x00"
    f3: "0x00"
    f4: "0x00"
    f5: "0x00"
    f6: "0x00"
    f7: "0x00"
    f8: "0xFF"
    f9: "0x00"
    f10: "0x00"
    f11: "0x00"
    style.fill: "#90EE90"
  }
  direction: right
  idx_col -> val_col -> cmp_col: {
    style.opacity: 0
  }
}
step5: {
  label: "Step 5: Extract Bitmask and Apply Mask"
  width: 480
  code: |'c
    // Extract high bit from each byte into 16-bit integer
    int mask = _mm_movemask_epi8(cmp);  // mask = 0x0100
    // Binary: 0b0000_0001_0000_0000
    // Bit 8 is set (null at index 8)
    // Apply keep_mask to ignore bytes before string start
    // keep_mask for offset=3: ~0x07 = 0xFFFFFFF8
    mask &= keep_mask;  // mask = 0x0100 (unchanged, bit 8 > bit 3)
    // Alternative: right-shift to remove ignored bits
    // mask >>= offset;  // mask = 0x0100 >> 3 = 0x0020
  '|
}
bitmask_trace: {
  label: "Bitmask Value Trace"
  width: 560
  style.fill: "#E8E8F4"
  step_col: {
    label: "Step"
    shape: sql_table
    f0: "After movemask"
    f1: "ignore_mask"
    f2: "keep_mask"
    f3: "Final mask"
    f4: "mask >> offset"
    style.fill: "#D4D4E8"
  }
  hex_col: {
    label: "Hex Value"
    shape: sql_table
    f0: "0x0100"
    f1: "0x0007"
    f2: "0xFFF8"
    f3: "0x0100"
    f4: "0x0020"
    style.fill: "#FFF8DC"
  }
  binary_col: {
    label: "Binary (lower 16 bits)"
    shape: sql_table
    f0: "0b0000000100000000"
    f1: "0b0000000000000111"
    f2: "0b1111111111111000"
    f3: "0b0000000100000000"
    f4: "0b0000000000100000"
    style.fill: "#FFF8DC"
  }
  meaning_col: {
    label: "Meaning"
    shape: sql_table
    f0: "Bit 8 = null at byte 8"
    f1: "Bits 0-2 to ignore"
    f2: "Bits 3-15 to keep"
    f3: "Null still at bit 8"
    f4: "Null now at bit 5 (position from str start)"
    style.fill: "#E8E8E8"
  }
  direction: right
  step_col -> hex_col -> binary_col -> meaning_col: {
    style.opacity: 0
  }
}
final_result: {
  label: "Final Result Computation"
  width: 480
  style.fill: "#E8F4E8"
  code: |'c
    if (mask != 0) {
        // Find position of first null from string start
        int pos = __builtin_ctz(mask);  // Count trailing zeros
        // ctz(0x0020) = 5
        return pos;  // String length = 5 ("hello")
    }
    // Alternative without shifting:
    // int pos = __builtin_ctz(mask) - offset;
    // ctz(0x0100) - 3 = 8 - 3 = 5
  '|
}
summary: {
  label: "Summary: Why This Works"
  width: 560
  style.fill: "#F0F8FF"
  content: |md
    **Key Insight**: The aligned load at 0x1000 is *always safe* because:
    1. 16-byte aligned reads cannot cross a 4KB page boundary
    2. The aligned address is in the *same page* as the original pointer
    **Masking Logic**:
    - Bytes 0-2 are "garbage" before our string
    - We ignore them by masking or shifting
    - The null at byte 8 is found correctly
    - Position 5 is returned (length of "hello")
    **Page Safety Proof**:
    - Original: 0x1003 (page offset = 0x003)
    - Aligned: 0x1000 (page offset = 0x000)
    - Both in same 4KB page (0x1000-0x1FFF)
  |
}
step1 -> step2 -> memory_layout -> step3 -> step4 -> comparison_result -> step5 -> bitmask_trace -> final_result -> summary