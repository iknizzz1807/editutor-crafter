direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # From Comparison to Position: movemask + ctz
  **O(1) Position Finding in SIMD String Operations**
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  step1: {
    direction: down
    label: "1. Parallel Compare"
    input: {
      shape: rectangle
      label: "Input: 'abcd\\0efghijklmno'"
      width: 280
      style.fill: "#E8F4E8"
    }
    compare_instr: {
      label: "_mm_cmpeq_epi8(chunk, zero)"
      width: 280
      style.fill: "#FFF9E6"
      style.stroke: "#E6A800"
    }
    compare_result: {
      shape: sql_table
      label: "Comparison Result (16 bytes)"
      b0: "0x00 | byte 0  | 'a' ≠ 0"
      b1: "0x00 | byte 1  | 'b' ≠ 0"
      b2: "0x00 | byte 2  | 'c' ≠ 0"
      b3: "0x00 | byte 3  | 'd' ≠ 0"
      b4: "0xFF | byte 4  | '\\0' = 0 ✓"
      b5: "0x00 | byte 5  | 'e' ≠ 0"
      b6: "0x00 | byte 6  | 'f' ≠ 0"
      b7: "0x00 | byte 7  | 'g' ≠ 0"
      b8: "0x00 | byte 8  | 'h' ≠ 0"
      note: "... remaining bytes ..."
      width: 240
    }
    input -> compare_instr: "16 bytes"
    compare_instr -> compare_result: "__m128i"
  }
  arrow1: {
    shape: rectangle
    label: "→"
    width: 40
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 32
  }
  step2: {
    direction: down
    label: "2. Extract Bitmask"
    movemask_instr: {
      label: "_mm_movemask_epi8(cmp)"
      width: 260
      style.fill: "#E6F0FF"
      style.stroke: "#0066CC"
    }
    bit_extraction: {
      label: |md
        Extract high bit from each byte:
        - Byte with 0x00 → bit = 0
        - Byte with 0xFF → bit = 1
      |
      width: 260
      style.fill: "#F5F5F5"
    }
    mask_result: {
      shape: rectangle
      label: "Mask: 0b_0000_0000_0001_0000\n= 0x0010 = 16"
      width: 260
      style.fill: "#FFE6E6"
      style.stroke: "#CC0000"
    }
    movemask_instr -> bit_extraction: "extract"
    bit_extraction -> mask_result: "int (16-bit)"
  }
  arrow2: {
    shape: rectangle
    label: "→"
    width: 40
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 32
  }
  step3: {
    direction: down
    label: "3. Find Position"
    ctz_instr: {
      label: "__builtin_ctz(mask)"
      width: 240
      style.fill: "#F0E6FF"
      style.stroke: "#6600CC"
    }
    ctz_explanation: {
      label: |md
        Count Trailing Zeros:
        Find index of lowest set bit
      |
      width: 240
      style.fill: "#F5F5F5"
    }
    position_result: {
      shape: rectangle
      label: "Position: 4\n(null terminator found!)"
      width: 240
      style.fill: "#E6FFE6"
      style.stroke: "#009900"
      style.bold: true
    }
    ctz_instr -> ctz_explanation: "hardware\ninstruction"
    ctz_explanation -> position_result: "int"
  }
}
row1.step1.compare_result -> row1.step2.movemask_instr: "16 bytes\nof 0x00/0xFF"
row1.step2.mask_result -> row1.step3.ctz_instr: "0x0010"
bottom_section: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  complexity: {
    label: |md
      ## Time Complexity: O(1)
      Each step is a **single hardware instruction**:
      1. `pcmpeqb` - 1 cycle (16 parallel compares)
      2. `pmovmskb` - 3 cycles (bit extraction)
      3. `bsf` - 3 cycles (find first set bit)
      **Total: ~7 cycles** regardless of string length
    |
    width: 300
    style.fill: "#E6F9FF"
    style.stroke: "#0099CC"
  }
  vs_scalar: {
    label: |md
      ## vs. Scalar Search
      Scalar approach checks each byte:
      c
      for (int i = 0; i < n; i++) {
        if (s[i] == '\0') return i;
      }
      
      - **Best case**: O(1) if null at position 0
      - **Worst case**: O(n) for long strings
      - **Branch mispredictions** on random data
      SIMD: Always O(1) per 16-byte chunk!
    |
    width: 300
    style.fill: "#FFF0E6"
    style.stroke: "#CC6600"
  }
  key_insight: {
    label: |md
      ## The Key Insight
      **Data-dependent logic without branches**
      Instead of branching on each comparison:
      c
      if (s[i] == '\0') return i; // branch!
      
      We convert to bitmask and compute position:
      c
      mask = _mm_movemask_epi8(cmp);
      return __builtin_ctz(mask); // no branch!
      
      One predictable branch at the end, not N branches.
    |
    width: 300
    style.fill: "#E8FFE8"
    style.stroke: "#009900"
  }
}
