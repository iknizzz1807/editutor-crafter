    label: "Green = Match found"
    shape: rectangle
    width: 100
    style.fill: "#E6FFE6"
  }
  yellow: {
    label: "Yellow = Comparison"
    shape: rectangle
    width: 100
    style.fill: "#FFF9E6"
  }
  blue: {
    label: "Blue = Bit extraction"
    shape: rectangle
    width: 100
    style.fill: "#E6F0FF"
  }
  purple: {
    label: "Purple = Position find"
    shape: rectangle
    width: 100
    style.fill: "#F0E6FF"
  }
}