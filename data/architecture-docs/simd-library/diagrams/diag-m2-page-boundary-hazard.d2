direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Page Boundary Hazard: Why Unaligned Reads Fault"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
title.near: top-center

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  danger_scenario: {
    direction: down
    label: "DANGEROUS: Unaligned Read Crosses Page Boundary"
    danger_explanation: {
      width: 420
      label: "The Problem"
      explanation: |'md
        A 16-byte SIMD load starting at `0x4FF0` reads bytes `0x4FF0` through `0x4FFF` (in Page 1) **AND** `0x5000` through `0x500F` (in Page 2).
        If Page 2 is unmapped → **SIGSEGV** (segmentation fault)
        The CPU cannot partially complete the load—it's all-or-nothing.
      '|
    }
    danger_memory: {
      direction: right
      label: "Memory Layout"
      page1_danger: {
        label: "Page 1 (4KB)"
        shape: rectangle
        width: 200
        height: 180
        style: {
          fill: "#90EE90"
          stroke: "#228B22"
          stroke-width: 3
        }
        p1_header_d: "0x4000 - 0x4FFF" {
          style.font-size: 14
        }
        p1_status_d: "MAPPED ✓" {
          style: {
            font-size: 18
            bold: true
            font-color: "#228B22"
          }
        }
        p1_data_d: "[valid data]" {
          style.font-size: 12
        }
      }
      read_arrow_danger: {
        shape: rectangle
        width: 120
        height: 180
        style: {
          fill: transparent
          stroke: transparent
        }
        arrow_label_d: "16-byte\nload at\n0x4FF0" {
          style: {
            font-size: 11
            font-color: "#8B0000"
            bold: true
          }
        }
      }
      page2_danger: {
        label: "Page 2 (4KB)"
        shape: rectangle
        width: 200
        height: 180
        style: {
          fill: "#FF6B6B"
          stroke: "#8B0000"
          stroke-width: 3
        }
        p2_header_d: "0x5000 - 0x5FFF" {
          style.font-size: 14
        }
        p2_status_d: "UNMAPPED ✗" {
          style: {
            font-size: 18
            bold: true
            font-color: "#8B0000"
          }
        }
        p2_fault_d: "→ SIGSEGV!" {
          style: {
            font-size: 14
            bold: true
            font-color: "#8B0000"
          }
        }
      }
    }
    danger_detail: {
      width: 420
      label: "Read Spans Both Pages"
      code: |'c
        // _mm_loadu_si128 at address 0x4FF0
        // Reads: 0x4FF0, 0x4FF1, ..., 0x4FFF, 0x5000, ..., 0x500F
        //                    ^--- Page 1 ends ---^  ^-- Page 2 --^
        // 
        // If Page 2 is unmapped → CPU raises page fault → SIGSEGV
      '|
    }
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  safe_scenario: {
    direction: down
    label: "SAFE: Aligned Reads Stay Within Page"
    safe_explanation: {
      width: 420
      label: "The Solution"
      explanation: |'md
        **Key Insight**: 4KB pages are multiples of 16 bytes (4096 = 256 × 16).
        Therefore: a 16-byte **aligned** read (address % 16 == 0) can **never** cross a page boundary.
        The aligned address `0x4FF0` reads `0x4FF0-0x4FFF` — entirely within Page 1.
      '|
    }
    safe_memory: {
      direction: right
      label: "Memory Layout"
      page1_safe: {
        label: "Page 1 (4KB)"
        shape: rectangle
        width: 200
        height: 180
        style: {
          fill: "#90EE90"
          stroke: "#228B22"
          stroke-width: 3
        }
        p1_header_s: "0x4000 - 0x4FFF" {
          style.font-size: 14
        }
        p1_aligned_s: "0x4FF0 (aligned)" {
          style: {
            font-size: 12
            font-color: "#006400"
            bold: true
          }
        }
        p1_range_s: "Read: 0x4FF0→0x4FFF" {
          style: {
            font-size: 11
            font-color: "#228B22"
          }
        }
      }
      read_arrow_safe: {
        shape: rectangle
        width: 120
        height: 180
        style: {
          fill: transparent
          stroke: transparent
        }
        arrow_label_s: "16-byte\naligned\nload ✓" {
          style: {
            font-size: 11
            font-color: "#228B22"
            bold: true
          }
        }
      }
      page2_safe: {
        label: "Page 2 (4KB)"
        shape: rectangle
        width: 200
        height: 180
        style: {
          fill: "#FF6B6B"
          stroke: "#8B0000"
          stroke-width: 3
          stroke-dash: 5
        }
        p2_header_s: "0x5000 - 0x5FFF" {
          style.font-size: 14
        }
        p2_status_s: "UNMAPPED" {
          style: {
            font-size: 14
            font-color: "#8B0000"
          }
        }
        p2_note_s: "(not accessed)" {
          style: {
            font-size: 11
            font-color: "#666"
            italic: true
          }
        }
      }
    }
    safe_detail: {
      width: 420
      label: "Aligned Read is Safe"
      code: |'c
        // Aligned load at 0x4FF0 (0x4FF0 % 16 == 0)
        // Reads ONLY: 0x4FF0, 0x4FF1, ..., 0x4FFF
        //             ^--- All within Page 1 ---^
        //
        // NEVER touches Page 2 → Safe even if unmapped!
      '|
    }
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  alignment_table: {
    direction: down
    label: "Alignment Safety Reference"
    table_container: {
      width: 500
      table: {
        shape: sql_table
        label: "Address Alignment vs Page Safety"
        row1: "0x4FF0 | 16-byte aligned | SAFE | Stays in Page 1"
        row2: "0x4FF8 | NOT aligned | DANGER | Crosses to Page 2"
        row3: "0x5000 | 16-byte aligned | SAFE | Fully in Page 2 (if mapped)"
        row4: "0x4F01 | NOT aligned | DANGER | May cross boundary"
      }
    }
    key_insight: {
      width: 500
      label: "The Mathematical Guarantee"
      insight: |'md
        **Why alignment guarantees safety:**
        - Page size: 4096 bytes = 2¹²
        - 16-byte alignment: address % 16 == 0
        - 4096 % 16 = 0 (pages are exact multiples of 16)
        Therefore: Any 16-byte aligned address `A` where `A mod 4096 ≤ 4080` will have `A + 15` in the **same page**.
        The aligned read can never span two pages.
      '|
    }
  }
}

legend: {
  direction: right
  style: {
    fill: "#F5F5F5"
    stroke: "#CCC"
    border-radius: 8
  }
  green_box: {
    shape: rectangle
    width: 60
    height: 20
    style.fill: "#90EE90"
  }
  green_label: "Mapped" {
    style.font-size: 10
  }
  red_box: {
    shape: rectangle
    width: 60
    height: 20
    style.fill: "#FF6B6B"
  }
  red_label: "Unmapped" {
    style.font-size: 10
  }
}
legend.near: bottom-center

danger_scenario -> safe_scenario: "Fix: Use Aligned Reads" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
    stroke-dash: 4
  }
}