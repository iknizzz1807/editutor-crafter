direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # SIMD strlen: State Machine
  Aligned-read-with-masking pattern for page-safe string scanning
| {near: top-center}
states: {
  direction: down
  s0: {
    shape: diamond
    label: "S0: Distance to\nPage Boundary?"
    width: 160
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
  s1: {
    label: "S1: Scalar Prologue"
    width: 340
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    code: |'c
      // < 16 bytes to page boundary
      while (((uintptr_t)p & 15) != 0) {
        if (*p == '\0') return p - str;
        p++;
      }
      // Now p is 16-byte aligned
    '|
  }
  s2: {
    label: "S2: Load Aligned Vector"
    width: 340
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    code: |'c
      // Safe: p is 16-byte aligned
      // Cannot cross page boundary!
      __m128i chunk = _mm_load_si128(
        (const __m128i*)p
      );
    '|
  }
  s3: {
    label: "S3: Compare Against Zero"
    width: 340
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    code: |'c
      __m128i zero = _mm_setzero_si128();
      __m128i cmp = _mm_cmpeq_epi8(
        chunk, zero
      );
      int mask = _mm_movemask_epi8(cmp);
    '|
  }
  s4: {
    shape: diamond
    label: "S4: Null Found?\n(mask != 0)"
    width: 160
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  s5: {
    label: "S5: Return Position"
    width: 340
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.font-color: "#1B5E20"
    code: |'c
      // Found null terminator!
      int pos = __builtin_ctz(mask);
      return (p - str) + pos;
    '|
  }
  s6: {
    label: "S6: Advance Pointer"
    width: 340
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    code: |'c
      // No null in this chunk
      p += 16;  // Next aligned block
      // Loop back to S2
    '|
  }
}
start: {
  shape: circle
  style.fill: "#4CAF50"
  style.stroke: "#388E3C"
}
end: {
  shape: circle
  style.fill: "#F44336"
  style.stroke: "#D32F2F"
  label: "Return\nlength"
}
start -> states.s0: "Input: str pointer"
states.s0 -> states.s1: "< 16 bytes\nto boundary"
states.s0 -> states.s2: ">= 16 bytes\n(safe zone)"
states.s1 -> states.s2: "Aligned"
states.s2 -> states.s3: "chunk"
states.s3 -> states.s4: "mask"
states.s4 -> states.s5: "Yes\n(mask != 0)"
states.s4 -> states.s6: "No\n(mask == 0)"
states.s5 -> end: "length"
states.s6 -> states.s2: "Continue\nloop" {
  style.stroke-dash: 3
  style.animated: true
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  safe: "Safe (aligned)" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    width: 120
  }
  scalar: "Scalar fallback" {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 120
  }
  decision: "Decision point" {
    shape: diamond
    width: 80
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
}
safety_note: {
  near: bottom-left
  width: 380
  label: "Page Safety Guarantee"
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  note: |md
    **Key Insight**: A 16-byte aligned read
    cannot cross a 4KB page boundary.
    - Page size: 4096 bytes = 256 × 16
    - Aligned address: `p & 15 == 0`
    - Read spans: `[p, p+15]`
    - Always within same page!
    This is why we align before the SIMD loop.
  |
}