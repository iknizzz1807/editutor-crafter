direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # String Length Test Coverage Matrix
    ### SIMD strlen: Why These Specific Lengths Matter
  |
  near: top-center
  shape: text
  style.font-size: 28
}
grid-rows: 9
grid-columns: 6
grid-gap: 0
classes: {
  header: {
    style: {
      bold: true
      fill: "#2C3E50"
      font-color: white
      font-size: 14
    }
  }
  category: {
    style: {
      fill: "#34495E"
      font-color: white
      bold: true
      font-size: 12
    }
  }
  safe: {
    style: {
      fill: "#27AE60"
      font-color: white
      font-size: 11
    }
  }
  boundary: {
    style: {
      fill: "#F39C12"
      font-color: white
      font-size: 11
    }
  }
  critical: {
    style: {
      fill: "#E74C3C"
      font-color: white
      font-size: 11
    }
  }
  edge: {
    style: {
      fill: "#9B59B6"
      font-color: white
      font-size: 11
    }
  }
}
h_len: "Length" {class: header}
h_chunk: "Within\nFirst Chunk\n(<16 bytes)" {class: header}
h_spans: "Spans\nChunks" {class: header}
h_page: "At Page\nBoundary" {class: header}
h_crosses: "Crosses\nPage\nBoundary" {class: header}
h_why: "Why This Test?" {class: header}
len0: "0" {class: category}
len0_chunk: "✓ N/A\n(empty)" {class: safe}
len0_spans: "✗ No" {class: safe}
len0_page: "✗ No" {class: safe}
len0_crosses: "✗ No" {class: safe}
len0_why: |md
Edge case: immediate return
handles NULL terminator at start
| {class: edge; style.fill: "#1ABC9C"}
len1: "1" {class: category}
len1_chunk: "✓ Yes\n(single byte)" {class: safe}
len1_spans: "✗ No" {class: safe}
len1_page: "✗ No" {class: safe}
len1_crosses: "✗ No" {class: safe}
len1_why: |md
Prologue handles tiny strings
no SIMD loop entered
| {class: edge; style.fill: "#1ABC9C"}
len15: "15" {class: category}
len15_chunk: "✓ Yes\n(1 byte shy)" {class: safe}
len15_spans: "✗ No" {class: safe}
len15_page: "⚠ Maybe\n(depends on align)" {class: boundary}
len15_crosses: "✗ No" {class: safe}
len15_why: |md
Max length before SIMD needed
tests prologue-only path
| {class: boundary}
len16: "16" {class: category}
len16_chunk: "✓ Exactly\n1 chunk" {class: boundary}
len16_spans: "✗ No" {class: safe}
len16_page: "⚠ Maybe\n(depends on align)" {class: boundary}
len16_crosses: "⚠ Risk\n(if unaligned)" {class: critical}
len16_why: |md
Exact vector width match
tests single SIMD iteration
| {class: boundary}
len17: "17" {class: category}
len17_chunk: "✗ No" {class: safe}
len17_spans: "✓ Yes\n(2 chunks)" {class: boundary}
len17_page: "⚠ Maybe" {class: boundary}
len17_crosses: "⚠ Risk" {class: critical}
len17_why: |md
First multi-chunk case
tests loop continuation
| {class: boundary}
len4095: "4095" {class: category}
len4095_chunk: "✗ No" {class: safe}
len4095_spans: "✓ Yes\n(256 chunks)" {class: boundary}
len4095_page: "✓ Likely\n(1 byte before)" {class: critical}
len4095_crosses: "⚠ Depends\non start addr" {class: critical}
len4095_why: |md
Ends at page boundary
tests aligned-from-below
| {class: critical}
len4096: "4096" {class: category}
len4096_chunk: "✗ No" {class: safe}
len4096_spans: "✓ Yes\n(256 chunks)" {class: boundary}
len4096_page: "✓ Critical\n(spans pages)" {class: critical}
len4096_crosses: "✓ YES\n(page boundary)" {class: critical}
len4096_why: |md
Exactly one 4KB page
tests page-crossing safety
| {class: critical}
len4097: "4097" {class: category}
len4097_chunk: "✗ No" {class: safe}
len4097_spans: "✓ Yes\n(257 chunks)" {class: boundary}
len4097_page: "✓ Critical\n(1 byte into)" {class: critical}
len4097_crosses: "✓ YES\n(definitely)" {class: critical}
len4097_why: |md
Definitely crosses page
tests post-boundary handling
| {class: critical}
legend_container: {
  near: bottom-center
  legend_title: "Legend" {
    style: {
      bold: true
      underline: true
    }
  }
  grid-columns: 4
  grid-gap: 8
  leg_safe: "✓ Safe Path" {class: safe}
  leg_boundary: "⚠ Boundary" {class: boundary}
  leg_critical: "✗ Critical" {class: critical}
  leg_edge: "◇ Edge Case" {class: edge}
}
note: |md
  **Key Insight**: Lengths 0-17 test algorithm correctness; lengths 4095-4097 test memory safety.
  - **Page size**: 4096 bytes (4KB) on x86
  - **SIMD chunk**: 16 bytes (128 bits) for SSE2
  - **Critical invariant**: Aligned reads cannot cross page boundaries
| {
  near: bottom-center
  shape: rectangle
  style.fill: "#ECF0F1"
  style.stroke: "#BDC3C7"
  style.stroke-dash: 3
}