direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: AVX-SSE Transition Penalty: The vzeroupper Problem
title.shape: text
title.near: top-center
title.style: {
  font-size: 28
  bold: true
  underline: true
}

row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  before_section: {
    direction: down
    label: "WITHOUT vzeroupper (Penalty Path)"
    
    before_timeline: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      t1: {
        direction: down
        label: "T1"
        avx_code: {
          label: "AVX Code"
          style.fill: "#B6DDF6"
          style.stroke: "#2E86AB"
          code: |'c
            __m256 v = _mm256_loadu_ps(data);
            v = _mm256_mul_ps(v, v);
          '|
          width: 200
        }
        ymm_state1: {
          label: "YMM0 State"
          shape: sql_table
          style.fill: "#E8F4F8"
          low128: "0x00-0x7F | LOW  | valid"
          high128: "0x80-0xFF | HIGH | DIRTY"
        }
      }
      
      spacer1: {
        label: " "
        shape: rectangle
        style.stroke: transparent
        style.fill: transparent
        width: 40
      }
      
      t2: {
        direction: down
        label: "T2"
        sse_code: {
          label: "SSE Code"
          style.fill: "#FFE5E5"
          style.stroke: "#D64545"
          style.stroke-dash: 3
          code: |'c
            __m128 x = _mm_loadu_ps(data);
            // PENALTY!
          '|
          width: 200
        }
        cpu_penalty: {
          label: "CPU Action"
          shape: diamond
          style.fill: "#FF6B6B"
          style.font-color: white
        }
      }
      
      spacer2: {
        label: " "
        shape: rectangle
        style.stroke: transparent
        style.fill: transparent
        width: 40
      }
      
      t3: {
        direction: down
        label: "T3"
        penalty_box: {
          label: "70-CYCLE PENALTY"
          shape: rectangle
          style.fill: "#D64545"
          style.font-color: white
          style.bold: true
          width: 250
          desc: "Action: Save upper 128b to buffer"
        }
      }
    }
    
    t1.ymm_state1 -> t2.cpu_penalty: "Dirty upper" {
      style.stroke: "#D64545"
      style.stroke-dash: 4
    }
    t2.cpu_penalty -> t3.penalty_box: "Mismatch" {
      style.stroke: "#D64545"
    }
  }
}

row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  after_section: {
    direction: down
    label: "WITH vzeroupper (Clean Path)"
    
    after_timeline: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      at1: {
        direction: down
        label: "T1"
        avx_code2: {
          label: "AVX Code"
          style.fill: "#B6DDF6"
          style.stroke: "#2E86AB"
          code: |'c
            __m256 v = _mm256_loadu_ps(data);
            v = _mm256_mul_ps(v, v);
          '|
          width: 200
        }
        ymm_state2: {
          label: "YMM0 State"
          shape: sql_table
          style.fill: "#E8F4F8"
          low128: "0x00-0x7F | LOW  | valid"
          high128: "0x80-0xFF | HIGH | DIRTY"
        }
      }
      
      aspacer1: {
        label: " "
        shape: rectangle
        style.stroke: transparent
        style.fill: transparent
        width: 40
      }
      
      at2: {
        direction: down
        label: "T2"
        vzeroupper_box: {
          label: "vzeroupper"
          style.fill: "#90EE90"
          style.stroke: "#228B22"
          style.bold: true
          code: |'c
            _mm256_zeroupper();
          '|
          width: 200
        }
        ymm_state3: {
          label: "YMM0 State"
          shape: sql_table
          style.fill: "#E8FFE8"
          low128: "0x00-0x7F | LOW  | valid"
          high128: "0x80-0xFF | HIGH | CLEAN"
        }
      }
      
      aspacer2: {
        label: " "
        shape: rectangle
        style.stroke: transparent
        style.fill: transparent
        width: 40
      }
      
      at3: {
        direction: down
        label: "T3"
        sse_code2: {
          label: "SSE Code"
          style.fill: "#E8FFE8"
          style.stroke: "#228B22"
          code: |'c
            __m128 x = _mm_loadu_ps(data);
            // NO PENALTY!
          '|
          width: 200
        }
        clean_exec: {
          label: "Clean Execution"
          shape: oval
          style.fill: "#228B22"
          style.font-color: white
        }
      }
    }
    
    at1.ymm_state2 -> at2.vzeroupper_box: "Cleanup" {
      style.stroke: "#228B22"
    }
    at2.ymm_state3 -> at3.clean_exec: "Clean bit" {
      style.stroke: "#228B22"
    }
  }
}

state_machine_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  state_machine_section: {
    direction: down
    label: "CPU Internal State Machine"
    state_clean: {
      label: "CLEAN State"
      shape: circle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 3
    }
    state_dirty: {
      label: "DIRTY State\n(Upper 128b modified)"
      shape: circle
      style.fill: "#FF6B6B"
      style.stroke: "#D64545"
      style.stroke-width: 3
    }
    state_clean -> state_dirty: "AVX write" {
      style.stroke: "#2E86AB"
    }
    state_dirty -> state_clean: "vzeroupper (1-2 cyc)" {
      style.stroke: "#228B22"
    }
    state_dirty -> state_clean: "SSE Penalty (~70 cyc)" {
      style.stroke: "#D64545"
      style.stroke-dash: 4
    }
  }
}

legend: {
  label: "Legend"
  l1: "Clean = Upper bits zeroed" {
    shape: rectangle
    style.fill: "#90EE90"
  }
  l2: "Dirty = Upper bits AVX data" {
    shape: rectangle
    style.fill: "#FF6B6B"
  }
  l3: "Dashed = CPU Stall/Penalty" {
    shape: rectangle
    style.stroke-dash: 4
  }
}
legend.near: bottom-right

key_insight: {
  label: "Implementation Insight"
  content: |md
    **Why this happens:** XMM registers are the lower 128 bits of YMM registers.
    When AVX code writes YMM0, the upper half becomes "dirty". If SSE code
    then reads XMM0, the CPU must save the dirty upper half before the SSE
    operation can proceed—this save/restore costs ~70 cycles on Intel Sandy Bridge
    through Skylake. `vzeroupper` clears the upper bits, avoiding the stall.
  |
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  style.border-radius: 8
  width: 500
}
key_insight.near: bottom-center

note_modern: {
  label: "Modern CPUs"
  content: |md
    Zen 2+ and Ice Lake+
    have reduced penalty.
    Keep vzeroupper for
    legacy/portable compat.
  |
  style.fill: "#E8E8E8"
  style.stroke: "#888"
  style.border-radius: 4
  width: 200
}
note_modern.near: bottom-left

row_before -> row_after: "The Fix" {
  style.stroke: "#666"
  style.stroke-width: 3
  style.stroke-dash: 5
}