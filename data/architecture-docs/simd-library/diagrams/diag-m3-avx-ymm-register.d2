direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "AVX YMM Register: 256-bit Vector Extension"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: { fill: transparent; stroke: transparent }
  ymm_panel: {
    direction: down
    label: ""
    ymm_reg: {
      shape: sql_table
      label: "YMM0 Register (ymm0.h)"
      lane7: "255:224 | float | Lane 7 [f7]"
      lane6: "223:192 | float | Lane 6 [f6]"
      lane5: "191:160 | float | Lane 5 [f5]"
      lane4: "159:128 | float | Lane 4 [f4]"
      lane3: "127:96  | float | Lane 3 [f3]"
      lane2: "95:64   | float | Lane 2 [f2]"
      lane1: "63:32   | float | Lane 1 [f1]"
      lane0: "31:0    | float | Lane 0 [f0]"
      sz: "Total: 256 bits (32 bytes)"
    }
    upper_label: {
      label: "YMM0[255:128] = Upper 128 bits (AVX only)"
      shape: rectangle
      style: { fill: "#E8D4F0"; stroke: "#9B59B6"; stroke-width: 2 }
    }
    lower_label: {
      label: "YMM0[127:0] = XMM0 (SSE compatible)"
      shape: rectangle
      style: { fill: "#D5E8D4"; stroke: "#27AE60"; stroke-width: 2 }
    }
  }
  xmm_panel: {
    direction: down
    label: ""
    xmm_reg: {
      shape: sql_table
      label: "XMM0 Register (xmm0.h)"
      xlane3: "127:96  | float | Lane 3 [f3]"
      xlane2: "95:64   | float | Lane 2 [f2]"
      xlane1: "63:32   | float | Lane 1 [f1]"
      xlane0: "31:0    | float | Lane 0 [f0]"
      xsz: "Total: 128 bits (16 bytes)"
    }
    note_alias: {
      label: "XMM0 aliases YMM0[127:0]\nSame physical register!"
      shape: rectangle
      width: 200
      style: { fill: "#FFF9C4"; stroke: "#F57C00"; stroke-dash: 3 }
    }
  }
}
row2: "" {
  direction: right
  style: { fill: transparent; stroke: transparent }
  avx_op: {
    direction: down
    label: "_mm256_mul_ps (AVX)"
    avx_input_a: {
      shape: sql_table
      label: "YMM0 (src A)"
      a7: "f7a"
      a6: "f6a"
      a5: "f5a"
      a4: "f4a"
      a3: "f3a"
      a2: "f2a"
      a1: "f1a"
      a0: "f0a"
    }
    avx_input_b: {
      shape: sql_table
      label: "YMM1 (src B)"
      b7: "f7b"
      b6: "f6b"
      b5: "f5b"
      b4: "f4b"
      b3: "f3b"
      b2: "f2b"
      b1: "f1b"
      b0: "f0b"
    }
    avx_result: {
      shape: sql_table
      label: "YMM0 (result)"
      r7: "f7a*f7b"
      r6: "f6a*f6b"
      r5: "f5a*f5b"
      r4: "f4a*f4b"
      r3: "f3a*f3b"
      r2: "f2a*f2b"
      r1: "f1a*f1b"
      r0: "f0a*f0b"
    }
    avx_mul: {
      label: "vmulps ymm0, ymm0, ymm1"
      shape: rectangle
      style: { fill: "#E3F2FD"; stroke: "#1976D2"; font: mono }
    }
    avx_count: {
      label: "8 parallel multiplies per instruction"
      shape: rectangle
      style: { fill: "#C8E6C9"; stroke: "#388E3C"; bold: true }
    }
    avx_input_a -> avx_mul
    avx_input_b -> avx_mul
    avx_mul -> avx_result
    avx_result -> avx_count
  }
  sse_op: {
    direction: down
    label: "_mm_mul_ps (SSE)"
    sse_input_a: {
      shape: sql_table
      label: "XMM0 (src A)"
      sa3: "f3a"
      sa2: "f2a"
      sa1: "f1a"
      sa0: "f0a"
    }
    sse_input_b: {
      shape: sql_table
      label: "XMM1 (src B)"
      sb3: "f3b"
      sb2: "f2b"
      sb1: "f1b"
      sb0: "f0b"
    }
    sse_result: {
      shape: sql_table
      label: "XMM0 (result)"
      sr3: "f3a*f3b"
      sr2: "f2a*f2b"
      sr1: "f1a*f1b"
      sr0: "f0a*f0b"
    }
    sse_mul: {
      label: "mulps xmm0, xmm1"
      shape: rectangle
      style: { fill: "#FFF3E0"; stroke: "#F57C00"; font: mono }
    }
    sse_count: {
      label: "4 parallel multiplies per instruction"
      shape: rectangle
      style: { fill: "#FFECB3"; stroke: "#FFA000"; bold: true }
    }
    sse_input_a -> sse_mul
    sse_input_b -> sse_mul
    sse_mul -> sse_result
    sse_result -> sse_count
  }
}
aliasing_section: {
  direction: down
  label: "Register Aliasing and Transition Penalty"
  aliasing_box: {
    direction: down
    label: ""
    before_state: {
      shape: sql_table
      label: "After AVX instruction"
      b_upper: "YMM0[255:128] | VALID DATA"
      b_lower: "YMM0[127:0]   | VALID DATA"
    }
    sse_access: {
      label: "SSE instruction touches XMM0"
      shape: rectangle
      style: { fill: "#FFCDD2"; stroke: "#C62828"; stroke-width: 3 }
    }
    after_state: {
      shape: sql_table
      label: "CPU state (Sandy Bridge - Skylake)"
      a_upper: "YMM0[255:128] | UNKNOWN (dirty)"
      a_lower: "YMM0[127:0]   | Updated"
      penalty: "PENALTY: ~70 cycles to save/restore upper bits!"
    }
    before_state -> sse_access
    sse_access -> after_state
  }
  solution_box: {
    direction: down
    label: ""
    vzeroupper: {
      label: "_mm256_zeroupper()"
      shape: rectangle
      style: { fill: "#C8E6C9"; stroke: "#2E7D32"; font: mono; bold: true }
    }
    vzeroupper_desc: {
      label: "Clears upper 128 bits of all YMM registers\nEliminates transition penalty before SSE code"
      shape: rectangle
      style: { fill: transparent; stroke: transparent }
    }
    vzeroupper -> vzeroupper_desc
  }
  aliasing_box -> solution_box: "FIX"
}
usage_guide: {
  direction: down
  label: "Best Practice"
  code_example: {
    label: "Mixed AVX/SSE Code Pattern"
    width: 420
    code: |'c
      void process_mixed(float* data, size_t n) {
          // AVX section
          __m256 v = _mm256_loadu_ps(data);
          // ... AVX operations ...
          // CRITICAL: Zero upper bits before SSE
          _mm256_zeroupper();
          // Now safe to use SSE
          __m128 s = _mm_loadu_ps(data + 8);
          // ... SSE operations ...
      }
    '|
  }
}
legend: {
  near: bottom-right
  label: "Lane Colors"
  avx_lanes: {
    label: "AVX: 8 float lanes (256-bit)"
    shape: rectangle
    style: { fill: "#E3F2FD"; stroke: "#1976D2" }
  }
  sse_lanes: {
    label: "SSE: 4 float lanes (128-bit)"
    shape: rectangle
    style: { fill: "#FFF3E0"; stroke: "#F57C00" }
  }
  danger: {
    label: "Transition Penalty Zone"
    shape: rectangle
    style: { fill: "#FFCDD2"; stroke: "#C62828" }
  }
}