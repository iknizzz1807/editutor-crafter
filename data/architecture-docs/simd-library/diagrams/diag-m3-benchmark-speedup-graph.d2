direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Benchmark Results: Scalar vs SSE vs AVX {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: Dot Product Speedup (relative to scalar = 1.0) {
  near: top-center
  shape: text
  style.font-size: 16
}
chart_frame: "" {
  style: {
    stroke: transparent
    fill: transparent
  }
  direction: right
  y_axis_label: Speedup {
    shape: text
    style.font-size: 14
    style.bold: true
  }
  grid_lines: "" {
    direction: down
    style: {
      stroke: transparent
      fill: transparent
    }
    row_4x: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      line_4: "──────────────────────────────────────────────────────────── 4x" {
        shape: text
        style: {
          font-color: "#666666"
          font-size: 11
        }
      }
    }
    row_3x: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      line_3: "──────────────────────────────────────────────────────────── 3x (AVX target)" {
        shape: text
        style: {
          font-color: "#3d85c6"
          font-size: 11
        }
      }
    }
    row_2x: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      line_2: "──────────────────────────────────────────────────────────── 2x (SSE target)" {
        shape: text
        style: {
          font-color: "#6aa84f"
          font-size: 11
        }
      }
    }
    row_1x: "" {
      direction: right
      style: {
        stroke: transparent
        fill: transparent
      }
      line_1: "──────────────────────────────────────────────────────────── 1x (scalar baseline)" {
        shape: text
        style: {
          font-color: "#cc0000"
          font-size: 11
        }
      }
    }
  }
  bars_container: "" {
    direction: right
    style: {
      stroke: transparent
      fill: transparent
    }
    grid-gap: 60
    size_4: "n=4" {
      direction: down
      style: {
        stroke: transparent
        fill: transparent
      }
      bar_group_4: "" {
        direction: right
        style: {
          stroke: transparent
          fill: transparent
        }
        grid-gap: 8
        scalar_4: "1.0" {
          shape: rectangle
          width: 30
          height: 20
          style: {
            fill: "#cc0000"
            stroke: "#990000"
            font-color: white
            font-size: 10
          }
        }
        sse_4: "1.1" {
          shape: rectangle
          width: 30
          height: 22
          style: {
            fill: "#6aa84f"
            stroke: "#38761d"
            font-color: white
            font-size: 10
          }
        }
        avx_4: "0.9" {
          shape: rectangle
          width: 30
          height: 18
          style: {
            fill: "#3d85c6"
            stroke: "#1155cc"
            font-color: white
            font-size: 10
          }
          note: "overhead!" {
            shape: text
            style: {
              font-size: 9
              font-color: "#666666"
            }
          }
        }
      }
      label_4: "n = 4" {
        shape: text
        style: {
          font-size: 12
          bold: true
        }
      }
    }
    size_16: "n=16" {
      direction: down
      style: {
        stroke: transparent
        fill: transparent
      }
      bar_group_16: "" {
        direction: right
        style: {
          stroke: transparent
          fill: transparent
        }
        grid-gap: 8
        scalar_16: "1.0" {
          shape: rectangle
          width: 30
          height: 20
          style: {
            fill: "#cc0000"
            stroke: "#990000"
            font-color: white
            font-size: 10
          }
        }
        sse_16: "2.5" {
          shape: rectangle
          width: 30
          height: 50
          style: {
            fill: "#6aa84f"
            stroke: "#38761d"
            font-color: white
            font-size: 10
          }
        }
        avx_16: "2.3" {
          shape: rectangle
          width: 30
          height: 46
          style: {
            fill: "#3d85c6"
            stroke: "#1155cc"
            font-color: white
            font-size: 10
          }
        }
      }
      label_16: "n = 16" {
        shape: text
        style: {
          font-size: 12
          bold: true
        }
      }
    }
    size_64: "n=64" {
      direction: down
      style: {
        stroke: transparent
        fill: transparent
      }
      bar_group_64: "" {
        direction: right
        style: {
          stroke: transparent
          fill: transparent
        }
        grid-gap: 8
        scalar_64: "1.0" {
          shape: rectangle
          width: 30
          height: 20
          style: {
            fill: "#cc0000"
            stroke: "#990000"
            font-color: white
            font-size: 10
          }
        }
        sse_64: "3.8" {
          shape: rectangle
          width: 30
          height: 76
          style: {
            fill: "#6aa84f"
            stroke: "#38761d"
            font-color: white
            font-size: 10
          }
        }
        avx_64: "5.5" {
          shape: rectangle
          width: 30
          height: 110
          style: {
            fill: "#3d85c6"
            stroke: "#1155cc"
            font-color: white
            font-size: 10
          }
        }
      }
      label_64: "n = 64" {
        shape: text
        style: {
          font-size: 12
          bold: true
        }
      }
    }
    size_256: "n=256" {
      direction: down
      style: {
        stroke: transparent
        fill: transparent
      }
      bar_group_256: "" {
        direction: right
        style: {
          stroke: transparent
          fill: transparent
        }
        grid-gap: 8
        scalar_256: "1.0" {
          shape: rectangle
          width: 30
          height: 20
          style: {
            fill: "#cc0000"
            stroke: "#990000"
            font-color: white
            font-size: 10
          }
        }
        sse_256: "4.5" {
          shape: rectangle
          width: 30
          height: 90
          style: {
            fill: "#6aa84f"
            stroke: "#38761d"
            font-color: white
            font-size: 10
          }
        }
        avx_256: "8.2" {
          shape: rectangle
          width: 30
          height: 164
          style: {
            fill: "#3d85c6"
            stroke: "#1155cc"
            font-color: white
            font-size: 10
          }
        }
      }
      label_256: "n = 256" {
        shape: text
        style: {
          font-size: 12
          bold: true
        }
      }
    }
    size_1024: "n=1024" {
      direction: down
      style: {
        stroke: transparent
        fill: transparent
      }
      bar_group_1024: "" {
        direction: right
        style: {
          stroke: transparent
          fill: transparent
        }
        grid-gap: 8
        scalar_1024: "1.0" {
          shape: rectangle
          width: 30
          height: 20
          style: {
            fill: "#cc0000"
            stroke: "#990000"
            font-color: white
            font-size: 10
          }
        }
        sse_1024: "4.8" {
          shape: rectangle
          width: 30
          height: 96
          style: {
            fill: "#6aa84f"
            stroke: "#38761d"
            font-color: white
            font-size: 10
          }
          note: "approaches 4x limit" {
            shape: text
            style: {
              font-size: 9
              font-color: "#38761d"
            }
          }
        }
        avx_1024: "9.5" {
          shape: rectangle
          width: 30
          height: 190
          style: {
            fill: "#3d85c6"
            stroke: "#1155cc"
            font-color: white
            font-size: 10
          }
          note: "approaches 8x limit" {
            shape: text
            style: {
              font-size: 9
              font-color: "#1155cc"
            }
          }
        }
      }
      label_1024: "n = 1024" {
        shape: text
        style: {
          font-size: 12
          bold: true
        }
      }
    }
  }
}
legend_frame: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  near: bottom-center
  legend_scalar: "Scalar (baseline)" {
    shape: rectangle
    width: 20
    height: 14
    style: {
      fill: "#cc0000"
      stroke: "#990000"
      font-size: 11
    }
  }
  legend_sse: "SSE (4 floats/cycle)" {
    shape: rectangle
    width: 20
    height: 14
    style: {
      fill: "#6aa84f"
      stroke: "#38761d"
      font-size: 11
    }
  }
  legend_avx: "AVX (8 floats/cycle)" {
    shape: rectangle
    width: 20
    height: 14
    style: {
      fill: "#3d85c6"
      stroke: "#1155cc"
      font-size: 11
    }
  }
}
insights: "" {
  direction: down
  near: bottom-center
  style: {
    stroke: "#e0e0e0"
    fill: "#f8f8f8"
    border-radius: 8
  }
  insight_title: "Key Insights" {
    shape: text
    style: {
      font-size: 14
      bold: true
    }
  }
  insight_1: "1. Small arrays (n=4): AVX overhead exceeds benefit — SSE or scalar is optimal" {
    shape: text
    style.font-size: 11
  }
  insight_2: "2. SSE approaches 4x speedup (theoretical max: 4 floats per operation)" {
    shape: text
    style.font-size: 11
  }
  insight_3: "3. AVX approaches 8x speedup (theoretical max: 8 floats per operation)" {
    shape: text
    style.font-size: 11
  }
  insight_4: "4. Memory bandwidth becomes bottleneck at large sizes — diminishing returns" {
    shape: text
    style.font-size: 11
  }
}