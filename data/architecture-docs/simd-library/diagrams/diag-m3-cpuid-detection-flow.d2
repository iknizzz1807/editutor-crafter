direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Runtime CPU Feature Detection Flow {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
start: {
  shape: oval
  label: "Program Start"
}
init_simd: {
  label: "init_simd()"
  shape: rectangle
  width: 180
}
cpuid_leaf1: {
  label: |'c
    __get_cpuid(1, &eax, &ebx, &ecx, &edx)
  '|
  width: 320
  style.fill: "#E8F4FD"
}
check_sse2: {
  shape: diamond
  label: "EDX bit 26\n(SSE2)?"
  width: 120
}
check_avx: {
  shape: diamond
  label: "ECX bit 28\n(AVX)?"
  width: 120
}
cpuid_leaf7: {
  label: |'c
    __get_cpuid_count(7, 0, &eax, &ebx, &ecx, &edx)
  '|
  width: 340
  style.fill: "#E8F4FD"
}
check_avx2: {
  shape: diamond
  label: "EBX bit 5\n(AVX2)?"
  width: 120
}
check_avx512: {
  shape: diamond
  label: "EBX bit 16\n(AVX-512F)?"
  width: 140
}
features_sse2: {
  shape: class
  label: "cpu_features_t"
  sse2: "bool = true"
  avx: "bool = false"
  avx2: "bool = false"
  avx512: "bool = false"
}
features_avx: {
  shape: class
  label: "cpu_features_t"
  sse2: "bool = true"
  avx: "bool = true"
  avx2: "bool = false"
  avx512: "bool = false"
}
features_avx2: {
  shape: class
  label: "cpu_features_t"
  sse2: "bool = true"
  avx: "bool = true"
  avx2: "bool = true"
  avx512: "bool = false"
}
features_avx512: {
  shape: class
  label: "cpu_features_t"
  sse2: "bool = true"
  avx: "bool = true"
  avx2: "bool = true"
  avx512: "bool = true"
}
dispatch_section: {
  label: "Function Pointer Dispatch"
  style.stroke-dash: 3
  style.fill: "#F5F5F5"
  dispatch_check: {
    shape: diamond
    label: "features.avx512?"
    width: 130
  }
  dispatch_avx2: {
    shape: diamond
    label: "features.avx2?"
    width: 120
  }
  dispatch_avx: {
    shape: diamond
    label: "features.avx?"
    width: 120
  }
  set_avx512: {
    label: |'c
      dot_product_fn = dot_product_avx512;
      memset_fn = simd_memset_avx512;
    '|
    width: 280
    style.fill: "#C8E6C9"
  }
  set_avx2: {
    label: |'c
      dot_product_fn = dot_product_avx2;
      memset_fn = simd_memset_avx2;
    '|
    width: 260
    style.fill: "#C8E6C9"
  }
  set_avx: {
    label: |'c
      dot_product_fn = dot_product_avx;
      memset_fn = simd_memset_avx;
    '|
    width: 240
    style.fill: "#C8E6C9"
  }
  set_sse2: {
    label: |'c
      dot_product_fn = dot_product_sse;
      memset_fn = simd_memset;
    '|
    width: 230
    style.fill: "#FFF9C4"
  }
}
dispatch_done: {
  shape: oval
  label: "Dispatch\nComplete"
}
call_runtime: {
  label: |'c
    // Later: use function pointers
    float result = dot_product_fn(a, b, n);
    memset_fn(buf, 0, size);
  '|
  width: 300
  style.fill: "#E8F4FD"
}
return: {
  shape: oval
  label: "Return"
}
start -> init_simd: "first call"
init_simd -> cpuid_leaf1
cpuid_leaf1 -> check_sse2
check_sse2 -> check_avx: "Yes" {
  style.stroke: "#4CAF50"
}
check_sse2 -> features_sse2: "No (ancient CPU)" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
check_avx -> cpuid_leaf7: "Yes" {
  style.stroke: "#4CAF50"
}
check_avx -> features_sse2: "No" {
  style.stroke: "#FF9800"
}
cpuid_leaf7 -> check_avx2
check_avx2 -> check_avx512: "Yes" {
  style.stroke: "#4CAF50"
}
check_avx2 -> features_avx: "No" {
  style.stroke: "#FF9800"
}
check_avx512 -> features_avx512: "Yes" {
  style.stroke: "#4CAF50"
}
check_avx512 -> features_avx2: "No" {
  style.stroke: "#FF9800"
}
features_sse2 -> dispatch_section.dispatch_check
features_avx -> dispatch_section.dispatch_check
features_avx2 -> dispatch_section.dispatch_check
features_avx512 -> dispatch_section.dispatch_check
dispatch_section.dispatch_check -> dispatch_section.set_avx512: "Yes" {
  style.stroke: "#4CAF50"
}
dispatch_section.dispatch_check -> dispatch_section.dispatch_avx2: "No" {
  style.stroke: "#FF9800"
}
dispatch_section.dispatch_avx2 -> dispatch_section.set_avx2: "Yes" {
  style.stroke: "#4CAF50"
}
dispatch_section.dispatch_avx2 -> dispatch_section.dispatch_avx: "No" {
  style.stroke: "#FF9800"
}
dispatch_section.dispatch_avx -> dispatch_section.set_avx: "Yes" {
  style.stroke: "#4CAF50"
}
dispatch_section.dispatch_avx -> dispatch_section.set_sse2: "No" {
  style.stroke: "#FF9800"
}
dispatch_section.set_avx512 -> dispatch_done
dispatch_section.set_avx2 -> dispatch_done
dispatch_section.set_avx -> dispatch_done
dispatch_section.set_sse2 -> dispatch_done
dispatch_done -> call_runtime: "subsequent calls"
call_runtime -> return
legend: {
  near: bottom-right
  label: "Legend"
  style.stroke: "#666"
  yes_path: "Yes path (feature present)" {
    style.stroke: "#4CAF50"
  }
  no_path: "No path (feature absent)" {
    style.stroke: "#FF9800"
  }
  error_path: "Error path (unsupported)" {
    style.stroke: "#F44336"
    style.stroke-dash: 4
  }
}
notes: {
  near: bottom-center
  label: |md
    **CPUID Bit Positions:**
    - **SSE2**: CPUID.01H:EDX[26]
    - **AVX**: CPUID.01H:ECX[28]
    - **AVX2**: CPUID.07H:EBX[5]
    - **AVX-512F**: CPUID.07H:EBX[16]
    **Header:** `#include <cpuid.h>` (GCC/Clang)
  |
  width: 400
}