direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Matrix Layout: Row-Major vs Column-Major Access
  4×4 Matrix Storage and Cache Behavior for C = A × B
|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  row_major: {
    direction: down
    label: "Row-Major Layout (C/C++ default)"
    
    rm_explain: {
      label: |md
        Memory order: row 0, then row 1, etc.
        Address formula: `M[i][j] = base + i*4 + j`
      |
      width: 250
    }
    
    rm_matrix: {
      grid-columns: 4
      grid-gap: 0
      r0c0: "0x00 [0,0]" {style.fill: "#E8F5E9"}
      r0c1: "0x04 [0,1]" {style.fill: "#E8F5E9"}
      r0c2: "0x08 [0,2]" {style.fill: "#E8F5E9"}
      r0c3: "0x0C [0,3]" {style.fill: "#E8F5E9"}
      r1c0: "0x10 [1,0]" {style.fill: "#E3F2FD"}
      r1c1: "0x14 [1,1]" {style.fill: "#E3F2FD"}
      r1c2: "0x18 [1,2]" {style.fill: "#E3F2FD"}
      r1c3: "0x1C [1,3]" {style.fill: "#E3F2FD"}
      r2c0: "0x20 [2,0]" {style.fill: "#FFF3E0"}
      r2c1: "0x24 [2,1]" {style.fill: "#FFF3E0"}
      r2c2: "0x28 [2,2]" {style.fill: "#FFF3E0"}
      r2c3: "0x2C [2,3]" {style.fill: "#FFF3E0"}
      r3c0: "0x30 [3,0]" {style.fill: "#F3E5F5"}
      r3c1: "0x34 [3,1]" {style.fill: "#F3E5F5"}
      r3c2: "0x38 [3,2]" {style.fill: "#F3E5F5"}
      r3c3: "0x3C [3,3]" {style.fill: "#F3E5F5"}
    }
    
    rm_cache: {
      label: "Cache Line Mapping (64 bytes)"
      cl0: {
        shape: sql_table
        label: "64-Byte Cache Line (L1)"
        f0: "0x00 | 16 bytes | Row 0 [Contiguous]"
        f1: "0x10 | 16 bytes | Row 1 [Contiguous]"
        f2: "0x20 | 16 bytes | Row 2 [Contiguous]"
        f3: "0x30 | 16 bytes | Row 3 [Contiguous]"
        note: "Total: 64 bytes (Entire 4x4 Fits)"
      }
    }

    rm_access: {
      direction: right
      style.stroke: transparent
      row_proc: {
        label: "Row Access (A[i][0..3])"
        width: 250
        code: |'c
          // CONTIGUOUS LOAD
          // Single cache line fetch
          // SIMD-friendly (128-bit load)
          __m128 r = _mm_loadu_ps(&A[i][0]);
        '|
      }
      col_proc: {
        label: "Col Access (A[0..3][j])"
        width: 250
        code: |'c
          // STRIDED ACCESS
          // Indices: 0, 4, 8, 12
          // Offsets: +0, +16, +32, +48
          // Still 1 line here, but N lines for NxN
        '|
      }
    }
  }

  col_major: {
    direction: down
    label: "Column-Major Layout (Fortran/MATLAB)"
    
    cm_explain: {
      label: |md
        Memory order: col 0, then col 1, etc.
        Address formula: `M[i][j] = base + j*4 + i`
      |
      width: 250
    }
    
    cm_matrix: {
      grid-columns: 4
      grid-gap: 0
      c0r0: "0x00 [0,0]" {style.fill: "#E8F5E9"}
      c0r1: "0x04 [1,0]" {style.fill: "#E8F5E9"}
      c0r2: "0x08 [2,0]" {style.fill: "#E8F5E9"}
      c0r3: "0x0C [3,0]" {style.fill: "#E8F5E9"}
      c1r0: "0x10 [0,1]" {style.fill: "#E3F2FD"}
      c1r1: "0x14 [1,1]" {style.fill: "#E3F2FD"}
      c1r2: "0x18 [2,1]" {style.fill: "#E3F2FD"}
      c1r3: "0x1C [3,1]" {style.fill: "#E3F2FD"}
      c2r0: "0x20 [0,2]" {style.fill: "#FFF3E0"}
      c2r1: "0x24 [1,2]" {style.fill: "#FFF3E0"}
      c2r2: "0x28 [2,2]" {style.fill: "#FFF3E0"}
      c2r3: "0x2C [3,2]" {style.fill: "#FFF3E0"}
      c3r0: "0x30 [0,3]" {style.fill: "#F3E5F5"}
      c3r1: "0x34 [1,3]" {style.fill: "#F3E5F5"}
      c3r2: "0x38 [2,3]" {style.fill: "#F3E5F5"}
      c3r3: "0x3C [3,3]" {style.fill: "#F3E5F5"}
    }

    cm_cache: {
      label: "Cache Line Mapping (64 bytes)"
      cl0_cm: {
        shape: sql_table
        label: "64-Byte Cache Line (L1)"
        f0: "0x00 | 16 bytes | Col 0 [Contiguous]"
        f1: "0x10 | 16 bytes | Col 1 [Contiguous]"
        f2: "0x20 | 16 bytes | Col 2 [Contiguous]"
        f3: "0x30 | 16 bytes | Col 3 [Contiguous]"
        note: "Total: 64 bytes (Entire 4x4 Fits)"
      }
    }

    cm_access: {
      direction: right
      style.stroke: transparent
      col_proc: {
        label: "Col Access (A[0..3][j])"
        width: 250
        code: |'c
          // CONTIGUOUS LOAD
          // Single cache line fetch
          // SIMD-friendly (128-bit load)
          __m128 c = _mm_loadu_ps(&A[0][j]);
        '|
      }
      row_proc: {
        label: "Row Access (A[i][0..3])"
        width: 250
        code: |'c
          // STRIDED ACCESS
          // Offsets: +0, +16, +32, +48
          // ⚠ Larger matrices: touches N cache lines
        '|
      }
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  matmul_eq: {
    direction: down
    label: "Matrix Multiply Mechanics: C = A x B"
    formula: {
      label: |'md
        Each element **C[i][j]** is a dot product:
        - **Row i of A**: A[i][0..k]
        - **Column j of B**: B[0..k][j]

        | Storage | Operand A (Row) | Operand B (Col) |
        |---------|-----------------|-----------------|
        | Row-Maj | Contiguous ✓    | Strided ✗       |
        | Col-Maj | Strided ✗       | Contiguous ✓    |
      '|
      width: 400
    }
    access_pattern: {
      shape: class
      label: "Access Pattern Summary"
      -a_stride: "1 (Contiguous)"
      -b_stride: "N (Strided)"
      -total_ops: "N^3 multiplications"
      +optimize(): "Transpose or Layout Mix"
    }
  }

  layout_combo: {
    direction: down
    label: "The Performance Secret"
    best_case: {
      label: "✓ OPTIMAL: Mix (RM-A + CM-B)"
      width: 400
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      code: |'c
        // Both A row and B col are CONTIGUOUS
        // Peak performance: N cache lines total
        // Perfect for SIMD hardware
      '|
    }
    worst_case: {
      label: "✗ SUBOPTIMAL: Default (RM-A + RM-B)"
      width: 400
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      code: |'c
        // B col access is strided.
        // For N=1024, touches 1024 cache lines
        // per dot product. Cache thrashing!
      '|
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scaling_analysis: {
    direction: down
    label: "Cache Scaling Problem (Strided Access)"
    explain: {
      label: |'md
        ### Why 4x4 is deceptive
        A 4x4 matrix fits in **one** cache line. Strided access hits the 
        same L1 cache line anyway. But matrices grow:

        | Matrix Size | Row Stride | Cache Lines per Column Access |
        |-------------|------------|-------------------------------|
        | 4x4         | 16 bytes   | 1 (Hits same line)            |
        | 8x8         | 32 bytes   | 2 (Split across lines)        |
        | 16x16       | 64 bytes   | 16 (Every element = New Line) |
        | 256x256     | 1024 bytes | 256 (Major Cache Thrashing)   |
      '|
      width: 450
    }
  }

  solutions: {
    direction: down
    label: "Production Implementation Strategies"
    sol1: {
      label: "1. Explicit Transpose (Pre-multiply)"
      width: 380
      code: |'c
        transpose(B, B_T); // Precompute once O(N^2)
        // Now use B_T row-major access!
        C[i][j] = dot(A_row_i, B_T_row_j);
      '|
    }
    sol2: {
      label: "2. Blocked Algorithms (Tiling)"
      width: 380
      code: |'c
        // Process 64x64 sub-blocks
        // Keep working set within L1/L2
        // Standard in Intel MKL / OpenBLAS
      '|
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  benchmark: {
    direction: down
    label: "Benchmark: 16x16 Matrix Multiplications"
    bench_table: {
      shape: sql_table
      label: "Instruction Cycles per Op"
      h: "Config | Access | Cycles | Speedup"
      r1: "RM-A + RM-B | Strided B | 3200 | 1.0x"
      r2: "RM-A + CM-B | Contiguous | 1200 | 2.7x"
      r3: "AVX Optimized | SIMD | 450 | 7.1x"
      note: "Conclusion: Layout > Instruction count"
    }
  }

  simd_kernel: {
    direction: down
    label: "Optimized Implementation (Intel SSE)"
    code_block: {
      label: "SIMD Dot-Product (A: Row, B: Col)"
      width: 450
      code: |'c
        void matmul_sse(float* C, float* A, float* B_Col) {
          for (int i=0; i<4; i++) {
            __m128 sum = _mm_setzero_ps();
            for (int k=0; k<4; k++) {
              __m128 a = _mm_set1_ps(A[i*4 + k]);
              __m128 b = _mm_loadu_ps(B_Col + k*4);
              sum = _mm_add_ps(sum, _mm_mul_ps(a, b));
            }
            _mm_storeu_ps(C + i*4, sum);
          }
        }
      '|
    }
  }
}

legend: {
  label: "Memory Block Legend"
  colors: {
    grid-columns: 2
    grid-gap: 8
    g0: { label: ""; width: 20; height: 15; style.fill: "#E8F5E9" }
    g0l: "Segment 0 (Row/Col 0)"
    g1: { label: ""; width: 20; height: 15; style.fill: "#E3F2FD" }
    g1l: "Segment 1 (Row/Col 1)"
    g2: { label: ""; width: 20; height: 15; style.fill: "#FFF3E0" }
    g2l: "Segment 2 (Row/Col 2)"
    g3: { label: ""; width: 20; height: 15; style.fill: "#F3E5F5" }
    g3l: "Segment 3 (Row/Col 3)"
  }
}
legend.near: bottom-right