direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Pointer Aliasing: What the Compiler Must Prove
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  without_restrict: {
    direction: down
    label: "WITHOUT restrict"
    style.stroke: "#E74C3C"
    style.fill: "#FDEDEC"
    style.stroke-width: 2
    code_no_restrict: {
      label: "C Source"
      width: 320
      code: |'c
        void add(float* a, float* b, 
                 float* c, int n) {
          for (int i = 0; i < n; i++) {
            c[i] = a[i] + b[i];
          }
        }
      '|
    }
    question: {
      shape: diamond
      label: "Can a, b, c\noverlap?"
      style.fill: "#F5B7B1"
    }
    analysis: {
      label: "Compiler Analysis"
      width: 320
      code: |'c
        // What if c == a + 1?
        // Iteration 0: c[0] = a[0] + b[0]
        // Iteration 1: c[1] = a[1] + b[1]
        //              BUT a[1] == c[0]!
        // Vectorized read would see
        // OLD a[1], not updated c[0]
        // RESULT: WRONG ANSWER
      '|
    }
    decision_no: {
      shape: diamond
      label: "Can prove\nno alias?"
      style.fill: "#F5B7B1"
    }
    result_no: {
      label: "Result"
      width: 320
      code: |'c
        // Generated: SCALAR LOOP
        // Cannot vectorize safely
      '|
      style.fill: "#FADBD8"
    }
    question -> analysis
    analysis -> decision_no
    decision_no -> result_no: "NO"
  }
  with_restrict: {
    direction: down
    label: "WITH restrict"
    style.stroke: "#27AE60"
    style.fill: "#E9F7EF"
    style.stroke-width: 2
    code_restrict: {
      label: "C Source"
      width: 350
      code: |'c
        void add(float* restrict a, 
                 float* restrict b, 
                 float* restrict c, 
                 int n) {
          for (int i = 0; i < n; i++) {
            c[i] = a[i] + b[i];
          }
        }
      '|
    }
    promise: {
      label: "restrict Keyword"
      width: 350
      code: |'c
        // restrict is a CONTRACT:
        // "I promise these pointers
        //  do NOT alias each other"
        // Compiler TRUSTS you.
        // If you lie: UNDEFINED BEHAVIOR
      '|
    }
    decision_yes: {
      shape: diamond
      label: "Can prove\nno alias?"
      style.fill: "#ABEBC6"
    }
    result_yes: {
      label: "Result"
      width: 350
      code: |'c
        // Generated: VECTORIZED LOOP
        // Safe to process 4/8 at once
      '|
      style.fill: "#D5F5E3"
    }
    code_restrict -> promise
    promise -> decision_yes
    decision_yes -> result_yes: "YES (trusted)"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  asm_scalar: {
    direction: down
    label: "Assembly: SCALAR (no restrict)"
    style.stroke: "#E74C3C"
    style.fill: "#FDEDEC"
    style.stroke-width: 2
    width: 380
    asm_code_scalar: {
      label: "x86-64 Assembly"
      code: |'asm
        add:                      ; Scalar loop
          testl   %ecx, %ecx
          jle     .L_return
          xorl    %eax, %eax
        .L_loop:
          movss   (%rdi,%rax,4), %xmm0  ; 1 float
          addss   (%rsi,%rax,4), %xmm0  ; + 1 float
          movss   %xmm0, (%rdx,%rax,4)  ; store 1
          incq    %rax
          cmpl    %eax, %ecx
          jg      .L_loop               ; repeat n times
        .L_return:
          ret
      '|
    }
    note_scalar: {
      label: "Note"
      width: 380
      code: |'c
        // 1 float per iteration
        // 5+ instructions per element
        // Loop overhead per iteration
      '|
    }
  }
  asm_vector: {
    direction: down
    label: "Assembly: VECTOR (with restrict)"
    style.stroke: "#27AE60"
    style.fill: "#E9F7EF"
    style.stroke-width: 2
    width: 420
    asm_code_vector: {
      label: "x86-64 Assembly (AVX)"
      code: |'asm
        add:                      ; Vectorized loop
          testl   %ecx, %ecx
          jle     .L_return
          xorl    %eax, %eax
        .L_vec_loop:
          vmovups (%rdi,%rax,4), %ymm0  ; 8 floats
          vaddps  (%rsi,%rax,4), %ymm0, %ymm0
          vmovups %ymm0, (%rdx,%rax,4)  ; store 8
          addq    $8, %rax
          cmpl    %eax, %ecx
          jg      .L_vec_loop
          vzeroupper
        .L_return:
          ret
      '|
    }
    note_vector: {
      label: "Note"
      width: 420
      code: |'c
        // 8 floats per iteration (AVX)
        // 3 instructions per 8 elements
        // ~5x fewer loop iterations
      '|
    }
  }
}
comparison: {
  label: "Performance Comparison"
  width: 900
  perf_table: {
    shape: sql_table
    label: "Throughput Analysis"
    f1: "Version | Floats/Iter | Instructions/Element | Speedup"
    f2: "Scalar (no restrict) | 1 | 5+ | 1.0x (baseline)"
    f3: "Vector (restrict) | 8 (AVX) | ~0.4 | ~8x"
  }
}
key_insight: {
  label: "Key Insight"
  width: 900
  code: |'c
    // The compiler is NOT stupid—it's CONSERVATIVE.
    // It must preserve EXACT program semantics.
    // 
    // Without restrict: "I cannot PROVE these don't alias,
    //                    so I must assume they MIGHT."
    //                    → Generate safe scalar code
    //
    // With restrict:    "The programmer PROMISES no alias.
    //                    I trust them and vectorize."
    //                    → Generate fast vector code
    //
    // WARNING: If you lie with restrict and pointers DO alias,
    //          the compiler generates wrong code silently.
    //          This is UNDEFINED BEHAVIOR.
  '|
}
row1 -> row2: "Compiler Decision"
row2 -> comparison: "Generated Code"
comparison -> key_insight