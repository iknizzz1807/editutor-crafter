direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Rigorous Benchmarking: Methodology Checklist
| {near: top-center}
row_pre: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pre_benchmark: Pre-Benchmark Setup {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    step1: {
      label: "1. Disable Turbo Boost"
      width: 280
      code: |'bash
        sudo cpupower frequency-set \
          -g performance
        sudo cpupower frequency-set \
          -d 2.4GHz -u 2.4GHz
      '|
    }
    step2: {
      label: "2. Verify Frequency Locked"
      width: 280
      code: |'bash
        cpupower frequency-info
        # Confirm: current freq = 2.4 GHz
      '|
    }
    step3: {
      label: "3. Disable Hyperthreading"
      width: 280
      code: |'bash
        # One thread per core
        for i in /sys/devices/system/\
        cpu/cpu*/online; do
          echo 0 > $i  # if HT sibling
        done
      '|
    }
    step4: {
      label: "4. Clear Filesystem Caches"
      width: 280
      code: |'bash
        sync
        echo 3 | sudo tee \
          /proc/sys/vm/drop_caches
      '|
    }
    step5: {
      label: "5. Pin Process to CPU Core"
      width: 280
      code: |'bash
        taskset -c 0 ./benchmark
        # Prevents migration noise
      '|
    }
  }
}
row_warmup: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  warmup_phase: Warmup Phase {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    warmup_desc: {
      label: "Run 3+ Untimed Iterations"
      width: 300
      code: |'c
        // Warmup: populate caches
        #define WARMUP_RUNS 3
        for (int i = 0; i < WARMUP_RUNS; i++) {
            volatile result = func(data);
            (void)result;  // prevent DCE
        }
      '|
    }
    warmup_why: |md
      **Why warmup?**
      - Loads data into L1/L2 cache
      - Triggers CPU frequency ramp-up
      - Branch predictor trains on loop pattern
    |
  }
}
row_measure: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  measurement: Measurement Phase {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    measure_code: {
      label: "Median of 10+ Timed Runs"
      width: 380
      code: |'c
        #define TIMED_RUNS 15
        int64_t times[TIMED_RUNS];
        for (int i = 0; i < TIMED_RUNS; i++) {
            int64_t start = get_ns();
            volatile result = func(data);
            int64_t end = get_ns();
            times[i] = end - start;
        }
        // Sort for median
        qsort(times, TIMED_RUNS, 
              sizeof(int64_t), cmp);
        int64_t median = times[TIMED_RUNS/2];
      '|
    }
    stats: {
      label: "Compute Statistics"
      width: 380
      code: |'c
        double mean = 0;
        for (int i = 0; i < TIMED_RUNS; i++)
            mean += times[i];
        mean /= TIMED_RUNS;
        double variance = 0;
        for (int i = 0; i < TIMED_RUNS; i++) {
            double d = times[i] - mean;
            variance += d * d;
        }
        double stddev = sqrt(variance/TIMED_RUNS);
        double cv = (stddev / median) * 100.0;
      '|
    }
  }
}
row_post: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  post_process: Post-Processing {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    outlier_check: {
      label: "Detect Outliers"
      width: 320
      code: |'c
        // Flag runs > 2 stddev from median
        int outliers = 0;
        for (int i = 0; i < TIMED_RUNS; i++) {
            if (abs(times[i] - median) > 2*stddev) {
                outliers++;
                printf("Outlier: run %d = %lld ns\n",
                       i, times[i]);
            }
        }
        if (outliers > TIMED_RUNS * 0.2) {
            printf("WARNING: Too many outliers!\n");
        }
      '|
    }
    verify_freq: {
      label: "Verify Frequency Stability"
      width: 320
      code: |'bash
        # Check frequency stayed constant
        grep MHz /proc/cpuinfo
        # All cores should show 2400 MHz
      '|
    }
    cv_check: {
      label: "Acceptable Variance?"
      shape: diamond
      width: 160
    }
    cv_pass: Good Result {
      style.fill: "#C8E6C9"
      code: |'
        CV < 2%  → Measurements reliable
        Report: median + stddev
      '|
    }
    cv_fail: Bad Result {
      style.fill: "#FFCDD2"
      code: |'
        CV > 2%  → Too much noise
        Fix: re-pin CPU, check for
        background processes
      '|
    }
    cv_check -> cv_pass: Yes
    cv_check -> cv_fail: No
  }
}
row_mistakes: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mistakes: Common Mistakes & Symptoms {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    mistake1: {
      label: "No Warmup"
      code: |'
        Symptom: First run 10-100x slower
        Cause: Cold cache, CPU at idle freq
      '|
      width: 280
    }
    mistake2: {
      label: "Turbo Boost Active"
      code: |'
        Symptom: CV > 10%, results vary
        Cause: CPU frequency fluctuates
        2.4 GHz → 4.5 GHz randomly
      '|
      width: 280
    }
    mistake3: {
      label: "Using Average Not Median"
      code: |'
        Symptom: Result skewed by one
        slow run (GC, interrupt)
        Fix: Use median (robust)
      '|
      width: 280
    }
    mistake4: {
      label: "No Statistics Reported"
      code: |'
        Symptom: "It takes 500ns"
        Reality: 500ns ± 300ns
        Always report stddev/CV!
      '|
      width: 280
    }
    mistake5: {
      label: "Measuring Tiny Intervals"
      code: |'
        Symptom: Negative times, variance
        Cause: clock_gettime overhead ~30ns
        Fix: measure loop of 1000+ calls
      '|
      width: 280
    }
    mistake6: {
      label: "Compiler Optimizes Away"
      code: |'
        Symptom: Impossibly fast (0ns)
        Cause: Dead code elimination
        Fix: use volatile or sink variable
      '|
      width: 280
    }
  }
}
row_example: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  good_bad: Example Output Comparison {
    direction: down
    good: Good Benchmark {
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      code: |'
        === Array Addition (10000 floats) ===
        median=1650 ns  stddev=12.8 ns  CV=0.8%
        ✓ CV < 2%: measurements reliable
        ✓ Frequency stable at 2400 MHz
        ✓ 0 outliers detected
      '|
      width: 340
    }
    bad: Bad Benchmark {
      style.fill: "#FFEBEE"
      style.stroke: "#F44336"
      code: |'
        === Array Addition (10000 floats) ===
        median=1200 ns  stddev=487 ns  CV=40.6%
        ✗ CV > 10%: NOISE, not signal
        ✗ Frequency varied 800-4500 MHz
        ✗ 3/15 runs were outliers
        ✗ Turbo boost was ENABLED
      '|
      width: 340
    }
  }
}
# Flow arrows
pre_benchmark -> warmup_phase: "Environment ready"
warmup_phase -> measurement: "Caches hot"
measurement -> post_process: "Raw times"
post_process -> mistakes: "Check quality"
# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  l1: "Green = Required step" {shape: text}
  l2: "Orange = Warmup phase" {shape: text}
  l3: "Blue = Measurement" {shape: text}
  l4: "Purple = Validation" {shape: text}
  l5: "Red = Pitfalls" {shape: text}
}