direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # `-ffast-math`: Performance vs Correctness Trade-offs
| {near: top-center}
row_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  without: {
    direction: down
    label: "Without `-ffast-math`"
    header: {
      style.fill: "#E8F4E8"
      style.stroke: "#2E7D32"
      label: "IEEE 754 Exact Semantics"
    }
    semantics: {
      label: "Semantics Guarantees"
      shape: rectangle
      width: 280
      s1: "(a + b) + c ≠ a + (b + c)"
      s2: "Rounding preserved exactly"
      s3: "Compiler cannot reorder FP ops"
      s4: "NaN/Inf handling per IEEE 754"
      s1.style.font: mono
      s2.style.font: mono
      s3.style.font: mono
      s4.style.font: mono
    }
    compiler_behavior: {
      label: "Compiler Behavior"
      shape: rectangle
      width: 280
      cb1: "Scalar loop for reductions"
      cb2: "No FP reassociation"
      cb3: "Conservative optimization"
      cb1.style.font: mono
      cb2.style.font: mono
      cb3.style.font: mono
    }
    code_example: {
      label: "Generated Code"
      width: 300
      code: |'c
        // Dot product - SCALAR
        xorps  %xmm0, %xmm0
      loop:
        vmovss (%rdi,%rax,4), %xmm1
        vmulss (%rsi,%rax,4), %xmm1, %xmm1
        vaddss %xmm1, %xmm0, %xmm0  // sequential
        incq   %rax
        cmpq   %rdx, %rax
        jne    loop
      '|
    }
    result_check: {
      label: "Result Verification"
      shape: diamond
      width: 200
      style.fill: "#C8E6C9"
      check: "✓ Bit-exact reproducible"
    }
    semantics -> compiler_behavior
    compiler_behavior -> code_example
    code_example -> result_check
  }
  with: {
    direction: down
    label: "With `-ffast-math`"
    header: {
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      label: "Aggressive Optimization"
    }
    semantics: {
      label: "Semantics Changes"
      shape: rectangle
      width: 280
      s1: "Reassociation: (a+b)+c = a+(b+c)"
      s2: "Rounding order may differ"
      s3: "FP ops can be reordered"
      s4: "NaN/Inf simplified"
      s1.style.font: mono
      s2.style.font: mono
      s3.style.font: mono
      s4.style.font: mono
      s1.style.fill: "#FFCDD2"
      s2.style.fill: "#FFCDD2"
      s3.style.fill: "#FFCDD2"
      s4.style.fill: "#FFCDD2"
    }
    compiler_behavior: {
      label: "Compiler Behavior"
      shape: rectangle
      width: 280
      cb1: "AVX vectorization enabled"
      cb2: "FP reassociation allowed"
      cb3: "Aggressive transformation"
      cb1.style.font: mono
      cb2.style.font: mono
      cb3.style.font: mono
    }
    code_example: {
      label: "Generated Code"
      width: 300
      code: |'c
        // Dot product - VECTORIZED
        vxorps %ymm0, %ymm0, %ymm0
      loop:
        vmovups (%rdi,%rax,4), %ymm1
        vmovups (%rsi,%rax,4), %ymm2
        vfmadd231ps %ymm2, %ymm1, %ymm0
        addq   $8, %rax
        cmpq   %rdx, %rax
        jb     loop
        // hadd reduction...
      '|
    }
    result_check: {
      label: "Result Verification"
      shape: diamond
      width: 200
      style.fill: "#FFCDD2"
      check: "⚠ Results may differ"
    }
    semantics -> compiler_behavior
    compiler_behavior -> code_example
    code_example -> result_check
  }
}
arrow_compare: without.result_check -> with.result_check: "Enabling flag" {
  style.stroke: "#FF6F00"
  style.stroke-width: 3
  style.stroke-dash: 5
}
row_benchmark: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  benchmark_title: {
    label: "Benchmark: Dot Product (10,000 floats)"
    shape: rectangle
    width: 600
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
  }
}
row_benchmark2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  bench_scalar: {
    label: "Scalar (no flag)"
    shape: rectangle
    width: 200
    time: "14,200 ns"
    speedup: "1.0× baseline"
    time.style.font: mono
    speedup.style.font: mono
  }
  bench_vector: {
    label: "Vectorized (-ffast-math)"
    shape: rectangle
    width: 200
    style.fill: "#C8E6C9"
    time: "2,100 ns"
    speedup: "6.8× speedup!"
    time.style.font: mono
    speedup.style.font: mono
    time.style.bold: true
  }
  bench_hand: {
    label: "Hand-written (optimal)"
    shape: rectangle
    width: 200
    style.fill: "#E8F5E9"
    time: "1,850 ns"
    speedup: "7.7× speedup"
    time.style.font: mono
    speedup.style.font: mono
  }
  bench_scalar -> bench_vector: "6.8× faster" {
    style.stroke: "#2E7D32"
    style.stroke-width: 2
  }
  bench_vector -> bench_hand: "12% faster" {
    style.stroke: "#1565C0"
    style.stroke-dash: 3
  }
}
row_counterexample: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  counter: {
    label: "⚠ Counter-Example: When Results Diverge"
    shape: rectangle
    width: 800
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    description: {
      label: |md
        **Input:** `a = 1e30, b = 1.0, c = -1e30`
        **Without `-ffast-math` (sequential):**
        
        (1e30 + 1.0) + (-1e30) = 1e30 + (-1e30) = 0.0
        
        The `1.0` gets absorbed into `1e30` due to precision limits.
        **With `-ffast-math` (vectorized, reordered):**
        
        1e30 + (1.0 + (-1e30)) = 1e30 + 0.0 = 1e30
        
        The `1.0` and `-1e30` cancel first, leaving `1e30`.
        **Result:** `0.0` vs `1e30` — completely different!
      |
      width: 750
    }
  }
}
row_recommendation: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  use_safe: {
    label: "✓ Use Without Flag"
    shape: rectangle
    width: 350
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    cases: {
      label: |md
        - Scientific computing
        - Financial calculations
        - Any reproducibility requirement
        - Cross-platform consistency
        - Debugging numerical issues
      |
    }
  }
  use_fast: {
    label: "⚠ Use With Caution"
    shape: rectangle
    width: 350
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    cases: {
      label: |md
        - Game physics (tolerant)
        - Graphics rendering
        - Machine learning training
        - Real-time audio/video
        - When speed > precision
      |
    }
  }
  use_safe -> use_fast: "Trade-off decision" {
    style.stroke-dash: 3
  }
}
legend: {
  near: bottom-right
  label: "Key Insight"
  shape: rectangle
  width: 300
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  insight: {
    label: |md
      `-ffast-math` is not "faster math" —
      it's **different math**.
      The compiler transforms your algorithm
      into one that's faster but semantically
      distinct. Only use when you understand
      and accept the numerical consequences.
    |
  }
}
row_comparison -> row_benchmark
row_benchmark -> row_benchmark2
row_benchmark2 -> row_counterexample
row_counterexample -> row_recommendation