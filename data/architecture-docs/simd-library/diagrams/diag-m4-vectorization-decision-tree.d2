direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Compiler Vectorization Decision Tree
| {near: top-center}
start: "Loop Entered" {
  shape: oval
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
}
trip_count: "Is trip count known?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
trip_unknown: "Generate runtime\ncheck version" {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
}
trip_known: "Is count >= vector width?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
too_small: "Skip vectorization\n(not beneficial)" {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
}
func_calls: "Any function calls\nin loop body?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
func_safe: "Are calls known safe?\n(math.h, intrinsics)" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
func_unsafe: "Skip vectorization\n(unknown side effects)" {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
}
aliasing: "Can pointers alias?" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
alias_runtime: "Generate version\nwith runtime checks" {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
}
alias_restrict: "Add restrict hints\nor prove independence" {
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
}
fp_assoc: "FP reduction?\n(requires reassociation)" {
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
fp_strict: "Require -ffast-math\nor skip vectorization" {
  shape: rectangle
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
}
vectorize: "VECTORIZE!\nGenerate SIMD code" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
  style.bold: true
}
success: "SIMD Loop\nEmitted" {
  shape: oval
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
}
fail: "Scalar Fallback\nUsed" {
  shape: oval
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
start -> trip_count: "begin analysis"
trip_count -> trip_unknown: "No"
trip_count -> trip_known: "Yes"
trip_unknown -> trip_known: "with guards"
trip_known -> too_small: "No"
trip_known -> func_calls: "Yes"
too_small -> fail
func_calls -> func_safe: "Yes"
func_calls -> aliasing: "No"
func_safe -> aliasing: "Yes"
func_safe -> func_unsafe: "No"
func_unsafe -> fail
aliasing -> alias_runtime: "Maybe"
aliasing -> fp_assoc: "Proven safe"
alias_runtime -> fp_assoc: "if checks pass"
alias_runtime -> fail: "if checks fail"
alias_restrict -> fp_assoc: "apply hints"
fp_assoc -> fp_strict: "Yes"
fp_assoc -> vectorize: "No"
fp_strict -> vectorize: "-ffast-math"
fp_strict -> fail: "strict FP"
vectorize -> success: "emit mulps/addps\nvmovups/vaddps"
legend: {
  near: bottom-right
  label: "Decision Tree Legend"
  decision: "Diamond = Decision Point" {
    shape: text
    style.fill: "#FFF3E0"
  }
  success_node: "Green = Vectorization Path" {
    shape: text
    style.fill: "#E8F5E9"
  }
  warning_node: "Yellow = Runtime Check Needed" {
    shape: text
    style.fill: "#FFF8E1"
  }
  fail_node: "Red = Vectorization Blocked" {
    shape: text
    style.fill: "#FFEBEE"
  }
}
example_simple: "Example: Simple Loop (VECTORIZES)" {
  width: 320
  code: |'c
    void add(float* restrict a,
             float* restrict b, int n) {
      for (int i = 0; i < n; i++) {
        a[i] += b[i];  // All checks pass!
      }
    }
  '|
  style.fill: "#E8F5E9"
  style.stroke: "#4CAF50"
}
example_alias: "Example: Aliasing Risk (BLOCKED)" {
  width: 320
  code: |'c
    void add(float* a, float* b, int n) {
      for (int i = 0; i < n; i++) {
        a[i] += b[i];
        // Cannot prove a != b+1
        // Compiler conservatively skips
      }
    }
  '|
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
}
example_fp: "Example: FP Reduction (NEEDS FLAG)" {
  width: 320
  code: |'c
    float sum(float* a, int n) {
      float s = 0.0f;
      for (int i = 0; i < n; i++) {
        s += a[i];  // FP not associative!
        // Requires -ffast-math
      }
      return s;
    }
  '|
  style.fill: "#FFF8E1"
  style.stroke: "#FFC107"
}
examples_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  example_simple
  example_alias
  example_fp
}
notes: {
  near: bottom-center
  label: "Why Simple Loops Vectorize"
  simple: "Simple loops pass all checks: known trip count, no function calls, restrict pointers, integer ops" {
    shape: text
  }
  complex: "Complex loops fail at: aliasing (most common), FP reduction, early exits, indirect calls, unknown trip count" {
    shape: text
  }
}