vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Module Architecture: SSE2 Memory Operations (M1)" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
header_dep: emmintrin.h {
  near: top-right
  shape: hexagon
  style: {
    fill: "#E8D5E0"
    stroke: "#8B5A8B"
    stroke-width: 2
    font: mono
    font-size: 18
  }
  tooltip: "SSE2 intrinsics header\nProvides: __m128i, _mm_load_*, _mm_store_*, _mm_set1_epi8"
}
simd_memops: "SSE2 Memory Operations Module" {
  direction: right
  style: {
    fill: "#F5F5F5"
    stroke: "#333333"
    stroke-width: 3
    border-radius: 8
  }
  memset: "simd_memset" {
    direction: down
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 6
    }
    memset_tiny: "Tiny Buffer Check\n(count < 16)" {
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
      }
    }
    memset_prologue: "Scalar Prologue\n(align to 16B boundary)" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
      tooltip: "Process bytes one-at-a-time\nuntil pointer is 16-byte aligned"
    }
    memset_vector: "Vector Loop\n(_mm_store_si128)" {
      style: {
        fill: "#BBDEFB"
        stroke: "#1565C0"
        border-radius: 4
        bold: true
      }
      tooltip: "Process 16 bytes per store\nUsing aligned store instruction"
    }
    memset_epilogue: "Scalar Epilogue\n(remaining 0-15 bytes)" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
    }
    memset_tiny -> memset_prologue: "≥16B" {
      style.stroke: "#2E7D32"
    }
    memset_tiny -> "return" {
      style.stroke: "#F9A825"
      style.stroke-dash: 3
    }
    memset_prologue -> memset_vector
    memset_vector -> memset_epilogue
  }
  memcpy: "simd_memcpy" {
    direction: down
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 6
    }
    memcpy_tiny: "Tiny Buffer Check\n(count < 16)" {
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
      }
    }
    memcpy_prologue: "Scalar Prologue\n(align dest to 16B)" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
      tooltip: "Copy bytes until destination\nis 16-byte aligned"
    }
    memcpy_vector: "Vector Loop\n(_mm_loadu + _mm_store)" {
      style: {
        fill: "#BBDEFB"
        stroke: "#1565C0"
        border-radius: 4
        bold: true
      }
      tooltip: "Load 16B (unaligned source)\nStore 16B (aligned dest)"
    }
    memcpy_epilogue: "Scalar Epilogue\n(remaining 0-15 bytes)" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
    }
    memcpy_tiny -> memcpy_prologue: "≥16B" {
      style.stroke: "#2E7D32"
    }
    memcpy_tiny -> "return" {
      style.stroke: "#F9A825"
      style.stroke-dash: 3
    }
    memcpy_prologue -> memcpy_vector
    memcpy_vector -> memcpy_epilogue
  }
  memset_stream: "simd_memset_stream" {
    direction: down
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      border-radius: 6
    }
    stream_tiny: "Tiny Buffer Check" {
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
      }
    }
    stream_prologue: "Scalar Prologue" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
    }
    stream_vector: "Vector Loop\n(_mm_stream_si128)" {
      style: {
        fill: "#FFCDD2"
        stroke: "#C62828"
        border-radius: 4
        bold: true
      }
      tooltip: "Non-temporal store (MOVNTDQ)\nBypasses cache hierarchy"
    }
    stream_fence: "_mm_sfence()" {
      shape: circle
      style: {
        fill: "#FF8A65"
        stroke: "#BF360C"
        bold: true
      }
      tooltip: "CRITICAL: Memory fence ensures\nstores visible before return"
    }
    stream_epilogue: "Scalar Epilogue" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
    }
    stream_tiny -> stream_prologue: "≥16B"
    stream_prologue -> stream_vector
    stream_vector -> stream_fence
    stream_fence -> stream_epilogue
  }
  memcpy_stream: "simd_memcpy_stream" {
    direction: down
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      border-radius: 6
    }
    cpy_stream_tiny: "Tiny Buffer Check" {
      shape: diamond
      style: {
        fill: "#FFF9C4"
        stroke: "#F9A825"
      }
    }
    cpy_stream_prologue: "Scalar Prologue" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
    }
    cpy_stream_vector: "Vector Loop\n(load + stream store)" {
      style: {
        fill: "#FFCDD2"
        stroke: "#C62828"
        border-radius: 4
        bold: true
      }
    }
    cpy_stream_fence: "_mm_sfence()" {
      shape: circle
      style: {
        fill: "#FF8A65"
        stroke: "#BF360C"
        bold: true
      }
    }
    cpy_stream_epilogue: "Scalar Epilogue" {
      style: {
        fill: "#C8E6C9"
        stroke: "#2E7D32"
        border-radius: 4
      }
    }
    cpy_stream_tiny -> cpy_stream_prologue: "≥16B"
    cpy_stream_prologue -> cpy_stream_vector
    cpy_stream_vector -> cpy_stream_fence
    cpy_stream_fence -> cpy_stream_epilogue
  }
}
header_dep -> simd_memops.memset_vector: "provides intrinsics" {
  style.stroke-dash: 5
  style.stroke: "#8B5A8B"
}
header_dep -> simd_memops.memcpy_vector: "provides intrinsics" {
  style.stroke-dash: 5
  style.stroke: "#8B5A8B"
}
header_dep -> simd_memops.stream_vector: "provides intrinsics" {
  style.stroke-dash: 5
  style.stroke: "#8B5A8B"
}
header_dep -> simd_memops.cpy_stream_vector: "provides intrinsics" {
  style.stroke-dash: 5
  style.stroke: "#8B5A8B"
}
legend: "Legend" {
  near: bottom-center
  style.fill: white
  style.stroke: "#666666"
  style.stroke-dash: 3
  leg1: "Prologue/Epilogue (scalar)" {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  leg2: "Vector Loop (SIMD)" {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  leg3: "Non-temporal (streaming)" {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  leg4: "Decision point" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
  leg1 -- leg2 -- leg3 -- leg4
}
notes: |md
  **Key Invariants:**
  - All `_mm_store_si128` calls use **provably 16-byte aligned** addresses
  - Streaming stores always followed by `_mm_sfence()` before return
  - Buffers < 16 bytes use pure scalar (SIMD overhead exceeds benefit)
  **Alignment Pattern:**
  
  offset = (uintptr_t)ptr & 15     // 0-15
  prologue_bytes = (16 - offset) & 15
  
| {
  near: bottom-left
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
}