vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    free: "#10B981"
    padding: "#6B7280"
    pointer: "#F59E0B"
    scalar: "#6366F1"
    vector: "#EC4899"
    changed: "#EF4444"
  }
}

title: ||md
  # SIMD memcpy: Data Flow Through Memory Hierarchy
  Scalar Prologue → Vector Body → Scalar Epilogue
||
title.near: top-center
title.shape: text

direction: right

source_memory: "Source Memory (src)" {
  style.fill: "${colors.data}"
  style.stroke: "#1E40AF"
  style.font-color: white
  src_block_0: "Byte 0-15" {
    style.fill: "#60A5FA"
    style.stroke: "#1E40AF"
  }
  src_block_1: "Byte 16-31" {
    style.fill: "#60A5FA"
    style.stroke: "#1E40AF"
  }
  src_block_2: "Byte 32-47" {
    style.fill: "#60A5FA"
    style.stroke: "#1E40AF"
  }
  src_tail: "Byte 48-52\n(5 bytes)" {
    style.fill: "#93C5FD"
    style.stroke: "#1E40AF"
    style.stroke-dash: 3
  }
}

xmm_reg: "XMM Register (128-bit)" {
  style.fill: "${colors.pointer}"
  style.stroke: "#D97706"
  style.font-color: white
  lane0: "Lane 0" {style.fill: "#FBBF24"}
  lane1: "Lane 1" {style.fill: "#FBBF24"}
  lane2: "Lane 2" {style.fill: "#FBBF24"}
  lane3: "Lane 3" {style.fill: "#FBBF24"}
  lane0 -- lane1 -- lane2 -- lane3 {style.opacity: 0}
}

dest_memory: "Destination Memory (dst)" {
  style.fill: "${colors.data}"
  style.stroke: "#1E40AF"
  style.font-color: white
  prologue: "Prologue\nBytes 0-6\n(scalar)" {
    style.fill: "${colors.scalar}"
    style.stroke: "#4338CA"
  }
  vec_block_0: "Byte 7-22\n(aligned)" {
    style.fill: "#60A5FA"
    style.stroke: "#1E40AF"
    style.bold: true
  }
  vec_block_1: "Byte 23-38" {
    style.fill: "#60A5FA"
    style.stroke: "#1E40AF"
  }
  vec_block_2: "Byte 39-54" {
    style.fill: "#60A5FA"
    style.stroke: "#1E40AF"
  }
  epilogue: "Epilogue\nByte 55-58\n(scalar)" {
    style.fill: "${colors.scalar}"
    style.stroke: "#4338CA"
  }
}

phase_labels: "Copy Phases" {
  style.fill: transparent
  style.stroke: transparent
  phase1: "Phase 1:\nScalar Prologue" {
    shape: text
    style.font-color: "${colors.scalar}"
    style.bold: true
  }
  phase2: "Phase 2:\nVector Body" {
    shape: text
    style.font-color: "${colors.vector}"
    style.bold: true
  }
  phase3: "Phase 3:\nScalar Epilogue" {
    shape: text
    style.font-color: "${colors.scalar}"
    style.bold: true
  }
  phase1 -> phase2 -> phase3 {style.opacity: 0}
}

cache_hierarchy: "Cache Hierarchy" {
  style.fill: "${colors.padding}"
  style.stroke: "#374151"
  l1: "L1 Cache\n(32 KB)" {
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
  }
  l2: "L2 Cache\n(256 KB)" {
    style.fill: "#A7F3D0"
    style.stroke: "#059669"
  }
  l3: "L3 Cache\n(8 MB)" {
    style.fill: "#6EE7B7"
    style.stroke: "#059669"
  }
  ram: "Main Memory\n(DDR4)" {
    style.fill: "#34D399"
    style.stroke: "#059669"
  }
  l1 -> l2: "miss" {style.stroke-dash: 3}
  l2 -> l3: "miss" {style.stroke-dash: 3}
  l3 -> ram: "miss" {style.stroke-dash: 3}
}

execution_ports: "CPU Execution Ports" {
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  port_desc: ||md
    **Skylake Port Utilization:**
    - Port 2, 3: Load (2 per cycle)
    - Port 4: Store (1 per cycle)
    - Port 5: Shuffle
  ||
  port_desc.shape: text
}

# Data flow arrows
source_memory.src_block_0 -> xmm_reg: "_mm_loadu_si128\n(unaligned load)" {
  style.stroke: "${colors.vector}"
  style.stroke-width: 3
  style.animated: true
  label.near: top-center
}
xmm_reg -> dest_memory.vec_block_0: "_mm_store_si128\n(aligned store)" {
  style.stroke: "${colors.vector}"
  style.stroke-width: 3
  style.animated: true
  label.near: top-center
}
source_memory -> dest_memory.prologue: "scalar copy\n(bytes 0-6)" {
  style.stroke: "${colors.scalar}"
  style.stroke-width: 2
  style.stroke-dash: 5
}
source_memory.src_tail -> dest_memory.epilogue: "scalar copy\n(bytes 55-58)" {
  style.stroke: "${colors.scalar}"
  style.stroke-width: 2
  style.stroke-dash: 5
}

# Cache interactions
cache_hierarchy.l1 -> source_memory: "cache line fetch" {
  style.stroke: "#059669"
  style.stroke-dash: 3
}
dest_memory -> cache_hierarchy.l1: "write-back" {
  style.stroke: "#059669"
  style.stroke-dash: 3
}

# Legend
legend: "Legend" {
  style.fill: "#F3F4F6"
  style.stroke: "#9CA3AF"
  scalar_key: "Scalar (byte-by-byte)" {
    style.fill: "${colors.scalar}"
  }
  vector_key: "Vector (16 bytes)" {
    style.fill: "${colors.vector}"
  }
  aligned_key: "Aligned Store" {
    style.fill: "#60A5FA"
    style.bold: true
  }
  unaligned_key: "Unaligned Load" {
    style.fill: "#93C5FD"
    style.stroke-dash: 3
  }
  scalar_key -- vector_key -- aligned_key -- unaligned_key {style.opacity: 0}
}

annotation: ||md
  **Alignment Strategy:**
  - Destination alignment prioritized over source
  - Aligned stores (`movdqa`) require 16-byte boundary
  - Unaligned loads (`movdqu`) work on any address
  - Prologue: scalar until dst % 16 == 0
  - Epilogue: scalar for remaining 0-15 bytes
||
annotation.near: bottom-center
annotation.shape: rectangle
annotation.style.fill: "#FEF3C7"
annotation.style.stroke: "#D97706"
annotation.style.font-size: 14

byte_layout: "Memory Layout Example" {
  style.fill: "#F9FAFB"
  style.stroke: "#E5E7EB"
  layout_desc: ||md
    **Input:** src=0x1001 (misaligned), n=59 bytes
    | Phase | Dst Addr | Bytes | Method |
    |-------|----------|-------|--------|
    | Prologue | 0x2000-0x2006 | 7 | scalar |
    | Vector | 0x2007-0x203A | 52 | SIMD (3×16 + 4) |
    | Epilogue | 0x203B-0x203E | 4 | scalar |
    **Alignment:** dst becomes 16-byte aligned at 0x2010
  ||
  layout_desc.shape: text
}