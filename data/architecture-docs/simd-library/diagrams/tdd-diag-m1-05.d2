layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL STYLES & CLASSES ---
classes: {
  byte_node: {
    width: 100
    height: 70
    style: {
      font-size: 14
      stroke-width: 1
      border-radius: 4
    }
  }
  lane_view: {
    style: {
      bold: true
      font-size: 16
      font-color: white
      text-transform: uppercase
    }
  }
  hex_val: {
    width: 60
    height: 40
    style: {
      font-color: white
      bold: true
    }
  }
}

# --- 1. PRIMARY XMM REGISTER STRUCTURE ---
header_spec: {
  shape: rectangle
  near: top-center
  style: {
    stroke-width: 0
    fill: transparent
  }
  label: |md
    # Memory Layout: XMM Register (128-bit)
    ### Intel SSE2 Vector Register Byte-Level Specification
    **sizeof=16 bytes (128 bits)**
  |
}

xmm_register: {
  label: "XMM0 Register (Physical Mapping)"
  style: {
    stroke: "#4A90D9"
    stroke-width: 4
    fill: "#F0F7FF"
    double-border: true
  }
  
  # Byte-level visualization: LSB to MSB
  byte_grid: {
    grid-columns: 8
    grid-gap: 4
    
    # Low Addresses (Bytes 0-7)
    b0: "Offset 0\n[00:07]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b1: "Offset 1\n[08:15]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b2: "Offset 2\n[16:23]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b3: "Offset 3\n[24:31]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b4: "Offset 4\n[32:39]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b5: "Offset 5\n[40:47]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b6: "Offset 6\n[48:55]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    b7: "Offset 7\n[56:63]" { class: byte_node; style.fill: "#4A90D9"; style.font-color: white }
    
    # High Addresses (Bytes 8-15)
    b8: "Offset 8\n[64:71]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b9: "Offset 9\n[72:79]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b10: "Offset 10\n[80:87]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b11: "Offset 11\n[88:95]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b12: "Offset 12\n[96:103]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b13: "Offset 13\n[104:111]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b14: "Offset 14\n[112:119]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
    b15: "Offset 15\n[120:127]" { class: byte_node; style.fill: "#3A7BC8"; style.font-color: white }
  }

  views: {
    label: "Logical SIMD Subdivisions"
    grid-columns: 1
    grid-gap: 10
    as_floats: "4 x float32 (Lanes: f0 | f1 | f2 | f3)" { class: lane_view; style.fill: "#9B59B6" }
    as_doubles: "2 x float64 (Lanes: d0 | d1)" { class: lane_view; style.fill: "#8E44AD" }
    as_int32: "4 x int32 (Lanes: i0 | i1 | i2 | i3)" { class: lane_view; style.fill: "#6C3483" }
  }
}

low_addr_note: {
  shape: rectangle
  style.stroke-dash: 3
  label: |md
    ### Low Address (LSB)
    - Byte Offset 0
    - Register Bits [0:7]
    - `movdqa [mem], xmm0`
  |
}
low_addr_note -> xmm_register.byte_grid.b0

high_addr_note: {
  shape: rectangle
  style.stroke-dash: 3
  label: |md
    ### High Address (MSB)
    - Byte Offset 15
    - Bit 127
  |
}
high_addr_note -> xmm_register.byte_grid.b15

# --- 2. STATE TRANSITION: BROADCAST FILL ---
broadcast_op: {
  label: "Algorithm State: _mm_set1_epi8(0x42)"
  style: {
    stroke: "#E67E22"
    stroke-width: 4
    fill: "#FFF5EB"
  }
  
  grid: {
    grid-columns: 8
    grid-gap: 2
    
    # Lanes populated with same value
    f0: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f1: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f2: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f3: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f4: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f5: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f6: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f7: "0x42" { class: hex_val; style.fill: "#E67E22" }
    f8: "0x42" { class: hex_val; style.fill: "#D35400" }
    f9: "0x42" { class: hex_val; style.fill: "#D35400" }
    f10: "0x42" { class: hex_val; style.fill: "#D35400" }
    f11: "0x42" { class: hex_val; style.fill: "#D35400" }
    f12: "0x42" { class: hex_val; style.fill: "#D35400" }
    f13: "0x42" { class: hex_val; style.fill: "#D35400" }
    f14: "0x42" { class: hex_val; style.fill: "#D35400" }
    f15: "0x42" { class: hex_val; style.fill: "#D35400" }
  }
}

broadcast_info: {
  shape: rectangle
  label: |md
    **Broadcast Logic**:
    Input scalar is duplicated across the entire 128-bit span.
    Used for SIMD masking or global scaling.
  |
}
broadcast_op -> broadcast_info

# --- 3. MEMORY CONTEXT: CACHE ALIGNMENT ---
cache_line_view: {
  label: "Memory Hierarchy: 64B Cache Line Context"
  style: {
    stroke-dash: 5
    stroke: "#7F8C8D"
    fill: "#FDFEFE"
  }
  
  context: {
    grid-columns: 4
    grid-gap: 8
    x0: "XMM0 (0x00-0x0F)" { style.fill: "#4A90D9"; style.font-color: white; width: 140; height: 60 }
    x1: "XMM1 (0x10-0x1F)" { style.fill: "#5BA0E9"; style.font-color: white; width: 140; height: 60 }
    x2: "XMM2 (0x20-0x2F)" { style.fill: "#6CB0F9"; style.font-color: white; width: 140; height: 60 }
    x3: "XMM3 (0x30-0x3F)" { style.fill: "#7DC0FF"; style.font-color: white; width: 140; height: 60 }
  }
}

cache_penalty_note: {
  shape: rectangle
  label: |md
    **Cache Boundary (64B)**
    Loads crossing 0x3F into 0x40 result in 
    **Dual Cache-Line Fetch Penalty**.
  |
}
cache_line_view -> cache_penalty_note

# --- 4. ALIGNMENT & FAULT CONDITIONS ---
alignment_specs: {
  label: "Virtual Memory Alignment (4KB Page Context)"
  style: {
    stroke-width: 6 
    stroke: "#2C3E50"
    fill: "#FAFAFA"
  }
  
  mem_grid: {
    grid-columns: 4
    grid-gap: 0
    a0: "0x0FF0\n(Unaligned)" { style.fill: "#ECF0F1"; width: 120; height: 60 }
    a1: "0x1000\n(PAGE START)" { style.fill: "#27AE60"; style.font-color: white; style.bold: true; width: 120; height: 60 }
    a2: "0x1010\n(ALIGNED)" { style.fill: "#2ECC71"; style.font-color: white; width: 120; height: 60 }
    a3: "0x1018\n(Unaligned)" { style.fill: "#ECF0F1"; width: 120; height: 60 }
  }
}

fault_note: {
  shape: rectangle
  label: |md
    ### Fault Conditions
    - **MOVDQA**: Requires `addr % 16 == 0`.
    - Violation causes **#GP(0)** fault.
    - **MOVDQU**: Use for unaligned (slower).
  |
}
alignment_specs -> fault_note

# --- 5. TECHNICAL METRICS TABLE ---
metrics_panel: {
  shape: rectangle
  near: top-right
  label: ||md
    ### Register Specs
    | Type | Count | Lane |
    | :--- | :--- | :--- |
    | **uint8** | 16 | 8-bit |
    | **uint32** | 4 | 32-bit |
    | **float32**| 4 | 32-bit |
    | **float64**| 2 | 64-bit |
  ||
}

# --- 6. ISA INSTRUCTION REFERENCE ---
isa_logic: {
  label: "Instruction Set Reference (ISA)"
  style.fill: "#FFF9E3"
  
  instruction_grid: {
    grid-columns: 1
    grid-gap: 15
    
    i1: {
      shape: rectangle
      label: |md
        `MOVDQA xmm0, [rax]`
        **Load Aligned 128-bit**
      |
    }
    i2: {
      shape: rectangle
      label: |md
        `MOVDQU xmm0, [rbx]`
        **Load Unaligned 128-bit**
      |
    }
    i3: {
      shape: rectangle
      label: |md
        `PSHUFB xmm0, xmm1`
        **SSSE3 Byte Shuffle**
      |
    }
  }
}