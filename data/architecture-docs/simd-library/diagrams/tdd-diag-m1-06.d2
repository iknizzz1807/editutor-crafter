vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Algorithm Steps: Alignment Prologue Calculation
  SSE2 16-byte alignment sequence
| {
  near: top-center
  shape: text
}

direction: right

# === BEFORE STATE ===
before_container: {
  label: "BEFORE"
  style: {
    fill: "#E8E8E8"
    stroke: "#666666"
    stroke-dash: 3
  }

  before_note: |md
    **Input State**
    - Pointer `p` at arbitrary address
    - Alignment unknown (0-15 offset)
  |
  before_note.shape: text

  ptr_before: {
    label: "p"
    shape: hexagon
    style.fill: "#FFB366"
    style.stroke: "#CC8800"
    width: 60
  }

  mem_before: {
    label: "Memory Buffer"
    shape: rectangle
    width: 400
    height: 60
    style.fill: "#E6F3FF"
    style.stroke: "#0066CC"

    addr_labels_before: |'md
      `0x1000` | `0x1001` | `0x1002` | ... | `0x100F` | `0x1010`
    '|
    addr_labels_before.shape: text
    addr_labels_before.style.font-size: 12
  }

  question_mark: {
    label: "?"
    shape: circle
    style.fill: "#FFE0B3"
    style.stroke: "#CC8800"
    style.font-size: 24
    style.bold: true
  }

  ptr_before -> mem_before: "points to\nunknown offset"
  question_mark -> ptr_before: "alignment?"
}

# === STEP 1 ===
step1_container: {
  label: "STEP 1: Compute Offset"
  style.fill: "#FFF9E6"
  style.stroke: "#E6B800"

  step1_code: |c
    // Extract low 4 bits (SSE 16-byte)
    size_t offset = (uintptr_t)p & 15;
  |
  step1_code.shape: text

  step1_operation: {
    label: "p & 15"
    shape: diamond
    style.fill: "#FFE066"
    style.stroke: "#CC9900"
    width: 100
  }

  step1_example: {
    label: "Example\np = 0x1007\noffset = 7 & 15 = 7"
    shape: rectangle
    style.fill: "#E6F9E6"
    style.stroke: "#00CC00"
    style.font-size: 12
  }

  result1: {
    label: "offset\n∈ [0,15]"
    shape: oval
    style.fill: "#CCE5FF"
    style.stroke: "#0066CC"
  }

  step1_operation -> result1: "produces"
}

# === STEP 2 ===
step2_container: {
  label: "STEP 2: Calculate Prologue Bytes"
  style.fill: "#E6FFE6"
  style.stroke: "#00CC00"

  step2_code: |c
    // Bytes needed to reach alignment
    size_t prologue_bytes = (16 - offset) & 15;
  |
  step2_code.shape: text

  step2_operation: {
    label: "(16 - offset) & 15"
    shape: diamond
    style.fill: "#99FF99"
    style.stroke: "#009900"
    width: 160
  }

  step2_table: {
    label: "Prologue Mapping"
    grid-columns: 2
    style.fill: "#F0FFF0"
    
    header1: "offset" {shape: text; style.bold: true}
    header2: "prologue" {shape: text; style.bold: true}
    row0a: "0" {shape: text}
    row0b: "0 (Aligned)" {shape: text}
    row1a: "1" {shape: text}
    row1b: "15" {shape: text}
    row7a: "7" {shape: text}
    row7b: "9" {shape: text}
    row15a: "15" {shape: text}
    row15b: "1" {shape: text}
  }

  step2_example: {
    label: "Example\noffset = 7\nprologue = (16-7) & 15 = 9"
    shape: rectangle
    style.fill: "#E6F9E6"
    style.stroke: "#00CC00"
    style.font-size: 12
  }

  result2: {
    label: "prologue_bytes\n∈ [0,15]"
    shape: oval
    style.fill: "#CCFFCC"
    style.stroke: "#009900"
  }

  step2_operation -> step2_table: "lookup"
  step2_table -> result2: "produces"
}

# === STEP 3 ===
step3_container: {
  label: "STEP 3: Scalar Prologue Writes"
  style.fill: "#FFE6F0"
  style.stroke: "#CC0066"

  step3_code: |c
    // Write bytes individually
    for (size_t i = 0; i < prologue_bytes; i++) {
        dest[i] = (unsigned char)c;
    }
    p += prologue_bytes;  // Advance p
  |
  step3_code.shape: text

  step3_loop: {
    label: "SCALAR\nLOOP"
    shape: rectangle
    style.fill: "#FFB3D9"
    style.stroke: "#CC0066"
    width: 100
    height: 60
  }

  step3_bytes: {
    label: "Write individual\nprologue bytes"
    shape: rectangle
    style.fill: "#FFE6F0"
    style.stroke: "#CC0066"
    width: 140
  }

  step3_advance: {
    label: "p += prologue_bytes"
    shape: rectangle
    style.fill: "#FFD9EC"
    style.stroke: "#990066"
  }

  step3_loop -> step3_bytes: "iteration"
  step3_bytes -> step3_advance: "final"
}

# === AFTER STATE ===
after_container: {
  label: "AFTER"
  style: {
    fill: "#E6FFE6"
    stroke: "#009900"
    stroke-width: 3
  }

  after_note: |md
    **Output State**
    - Pointer `p` is now 16-byte aligned
    - `(uintptr_t)p % 16 == 0`
  |
  after_note.shape: text

  ptr_after: {
    label: "p"
    shape: hexagon
    style.fill: "#66FF66"
    style.stroke: "#009900"
    width: 60
  }

  mem_after: {
    label: "Aligned Memory"
    shape: rectangle
    width: 400
    height: 60
    style.fill: "#E6FFE6"
    style.stroke: "#00CC00"

    addr_labels_after: |'md
      `0x1010` | `0x1020` | `0x1030` | `0x1040` | ...
    '|
    addr_labels_after.shape: text
    addr_labels_after.style.font-size: 12
  }

  checkmark: {
    label: "✓"
    shape: circle
    style.fill: "#66FF66"
    style.stroke: "#009900"
    style.font-size: 24
    style.bold: true
    style.font-color: "#006600"
  }

  aligned_box: {
    label: "16-BYTE\nALIGNED"
    shape: rectangle
    style.fill: "#CCFFCC"
    style.stroke: "#009900"
    style.bold: true
  }

  ptr_after -> mem_after: "now at\naligned boundary"
  checkmark -> aligned_box
}

# === FLOW ARROWS ===
before_container -> step1_container: "1" {
  style.stroke: "#0066CC"
  style.stroke-width: 3
  style.animated: true
}
step1_container -> step2_container: "2" {
  style.stroke: "#009900"
  style.stroke-width: 3
  style.animated: true
}
step2_container -> step3_container: "3" {
  style.stroke: "#CC0066"
  style.stroke-width: 3
  style.animated: true
}
step3_container -> after_container: "4" {
  style.stroke: "#009900"
  style.stroke-width: 3
  style.animated: true
}

# === INVARIANT BOX ===
invariant: |md
  **Invariant**: After Step 3, pointer `p` satisfies `(uintptr_t)p & 15 == 0`
  This enables optimized SIMD instructions like `_mm_load_si128` or `vmovdqa`.
|
invariant.shape: rectangle
invariant.style: {
  fill: "#FFFFCC"
  stroke: "#E6B800"
  stroke-width: 2
}
invariant.near: bottom-center
invariant.width: 500

# === KEY INSIGHT ===
key_insight: |md
  **Key Insight**: Edge Case `offset == 0`
  `(16 - 0) & 15 = 16 & 15 = 0`
  Result is 0, meaning we correctly perform 
  zero scalar writes if already aligned.
|
key_insight.shape: rectangle
key_insight.style: {
  fill: "#E6F3FF"
  stroke: "#0066CC"
}
key_insight.near: top-right
key_insight.width: 320