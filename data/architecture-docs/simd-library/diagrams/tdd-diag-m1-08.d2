layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Sequence Diagram: Benchmark Execution Flow"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

benchmark_flow: {
  shape: sequence_diagram
  
  # Actor Definitions
  Caller: Caller (Test Runner)
  Harness: Execution Harness
  Timer: OS/Hardware Clock
  SortStats: Sort & Statistical Analysis
  Report: Results Reporter

  # Initial Call
  Caller.entry -> Harness.init: "benchmark_function(name, func, params)"

  "Warmup Phase": {
    Harness.init -> Harness.init: "run 1 (untimed)"
    Harness.init -> Harness.init: "run 2 (untimed)"
    Harness.init -> Harness.init: "run 3 (untimed)"
    
    Harness."**Purpose**: Populate L1/L2/L3 caches and stabilize CPU P-states/Turbo frequencies."
  }

  "Timed Runs": {
    # Run 1
    Harness.init -> Timer.r1_start: "clock_gettime(START_CLK_ID)"
    Timer.r1_start -> Harness.r1_exec: "return start_ns"
    Harness.r1_exec -> Harness.r1_exec: "execute func(params)"
    Harness.r1_exec -> Timer.r1_end: "clock_gettime(END_CLK_ID)"
    Timer.r1_end -> Harness.r1_exec: "return end_ns"
    Harness.r1_exec -> Harness.r1_exec: "times[0] = (end - start)"

    # Run 2
    Harness.r1_exec -> Timer.r2_start: "clock_gettime(START_CLK_ID)"
    Timer.r2_start -> Harness.r2_exec: "return start_ns"
    Harness.r2_exec -> Harness.r2_exec: "execute func(params)"
    Harness.r2_exec -> Timer.r2_end: "clock_gettime(END_CLK_ID)"
    Timer.r2_end -> Harness.r2_exec: "return end_ns"
    Harness.r2_exec -> Harness.r2_exec: "times[1] = (end - start)"

    Harness."**Iteration Loop**: Repeat for remaining iterations (N=10)."
    
    Harness.r2_exec -> Harness.loop: "runs 3-10..."
    Harness.loop -> Harness.loop: "times[2..9] collected"
  }

  "Statistical Analysis": {
    Harness.loop -> SortStats.calc: "sort(times[], 10)"
    SortStats.calc -> SortStats.calc: "median = times[5]"
    SortStats.calc -> SortStats.calc: "mean = sum(times) / 10"
    SortStats.calc -> SortStats.calc: "stddev = sqrt(variance)"
    SortStats.calc -> SortStats.calc: "CV% = (stddev / median) * 100"
    
    SortStats."**Quality Check**: Reject if CV > 10% (High Jitter)"
  }

  # Finalization
  SortStats.calc -> Report.gen: "format_result(median, stddev, cv)"
  Report.gen -> Report.gen: "append to results table"
  Report.gen -> Caller.exit: "return benchmark_result_t"

  Caller."**Output Schema**:\n{ median_ns: 1650, stddev_ns: 12.8, cv_pct: 0.78 }"
}

# Styling
benchmark_flow.Caller.style.fill: "#D0E7FF"
benchmark_flow.Harness.style.fill: "#DFFFD6"
benchmark_flow.Timer.style.fill: "#FFF2CC"
benchmark_flow.SortStats.style.fill: "#F8CECC"
benchmark_flow.Report.style.fill: "#E1D5E7"

# Technical Annotations
benchmark_flow."Timed Runs" -> benchmark_flow."Statistical Analysis": {
  style: {
    stroke: "#2D3436"
    stroke-width: 2
  }
}