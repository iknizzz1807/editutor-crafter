vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  # Base properties for different shape types
  state: {
    shape: rectangle
    style: {
      stroke-width: 2
      font-size: 20
      bold: true
    }
  }
  initial_state: {
    shape: circle
    width: 40
    height: 40
    style: {
      fill: "#4A90D9"
      stroke: "#2E5A8B"
      stroke-width: 3
    }
  }
  # Color variants for states
  tiny_color: {
    style: {
      fill: "#FFE4B5"
      stroke: "#D4881A"
    }
  }
  small_color: {
    style: {
      fill: "#B5D8EB"
      stroke: "#4A90D9"
    }
  }
  large_color: {
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  decision: {
    shape: diamond
    width: 140
    height: 100
    style: {
      fill: "#F5F5F5"
      stroke: "#9E9E9E"
      stroke-width: 2
      font-size: 16
    }
  }
  # Connection styles
  transition: {
    style: {
      stroke-width: 2
      font-size: 14
      font-color: "#424242"
    }
  }
  true_path: {
    style: {
      stroke: "#4CAF50"
    }
  }
  false_path: {
    style: {
      stroke: "#F44336"
    }
  }
}

title: |md
  # State Machine: Buffer Size Threshold Decision
  ## Memory Operation Path Selection
| {near: top-center}

# Logical Nodes
START: {
  class: initial_state
  label: ""
}

check_size: {
  class: decision
  label: "count < 16?"
}

TINY: {
  class: [state; tiny_color]
  label: "TINY\n(<16 bytes)"
  scalar_only: |md
    **Scalar Only**
    - Byte-by-byte loop
    - No SIMD overhead
    - Fastest for small n
  |
}

check_medium: {
  class: decision
  label: "count < 256KB?"
}

SMALL: {
  class: [state; small_color]
  label: "SMALL\n(16B - 256KB)"
  simd_standard: |md
    **Standard SIMD**
    - Prologue/Epilogue pattern
    - Aligned stores
    - Cache-friendly
  |
}

LARGE: {
  class: [state; large_color]
  label: "LARGE\n(>256KB)"
  simd_streaming: |md
    **Streaming SIMD**
    - Non-temporal stores
    - Bypass cache
    - `_mm_stream_si128`
    - `_mm_sfence` required
  |
}

END_SCALAR: {
  class: initial_state
  label: ""
}

END_SIMD: {
  class: initial_state
  label: ""
}

# Flow Connections
START -> check_size

check_size -> TINY: "true (n < 16)" {
  class: [transition; true_path]
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}

check_size -> check_medium: "false (n ≥ 16)" {
  class: [transition; false_path]
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}

TINY -> END_SCALAR: "return" {
  class: transition
  style.stroke-dash: 3
}

check_medium -> SMALL: "true (16B ≤ n < 256KB)" {
  class: [transition; true_path]
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}

check_medium -> LARGE: "false (n ≥ 256KB)" {
  class: [transition; false_path]
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}

SMALL -> END_SIMD: "return" {
  class: transition
  style.stroke-dash: 3
}

LARGE -> END_SIMD: "return" {
  class: transition
  style.stroke-dash: 3
}

# Documentation and Metadata Containers
legend: {
  near: bottom-right
  label: |md
    ### Legend
    **State Colors:**
    - 🟠 Orange: TINY (scalar fallback)
    - 🔵 Blue: SMALL (standard SIMD)
    - 🟢 Green: LARGE (streaming)
    **Thresholds:**
    - `SIMD_MEMSET_MIN_SIZE = 16`
    - `SIMD_STREAM_THRESHOLD = 262144`
    **Transitions:**
    - Green arrow = condition true
    - Red arrow = condition false
  |
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
    stroke-dash: 2
  }
}

# Grouping threshold info to avoid constant near key conflicts
threshold_info: {
  near: bottom-left
  threshold_table: {
    shape: sql_table
    label: "Buffer Size Strategy Map"
    threshold: int {constraint: primary_key}
    description: string
    strategy: string
    0: 0
    desc0: "Zero count"
    strat0: "Immediate return"
    1: 16
    desc1: "SIMD_MEMSET_MIN_SIZE"
    strat1: "Scalar fallback"
    2: 262144
    desc2: "SIMD_STREAM_THRESHOLD (256KB)"
    strat2: "Non-temporal stores"
  }
  
  threshold_note: |md
    **Key Insight:** L2 cache is typically 256KB.
    Buffers larger than L2 benefit from
    streaming stores to avoid cache pollution.
  | {
    style: {
      fill: transparent
      font-size: 12
      italic: true
    }
  }
  
  threshold_table -> threshold_note: {style.stroke-width: 0}
}