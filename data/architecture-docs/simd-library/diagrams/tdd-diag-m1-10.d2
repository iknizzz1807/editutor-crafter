vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Execution Ports: SIMD Store Instruction Flow
  Store instruction decoded → address calculation → store data execution
|
direction: right
classes: {
  port: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 4
      font: mono
    }
  }
  data: {
    shape: parallelogram
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  control: {
    shape: diamond
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
    }
  }
  nontemporal: {
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-dash: 4
    }
  }
  cache: {
    shape: cylinder
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
}
decoder: "Instruction Decoder" {
  class: port
  width: 140
}
decoded: "_mm_store_si128\nMOVAPS/MOVAPS" {
  class: data
  width: 160
}
decoded_nt: "_mm_stream_si128\nMOVNTDQ (non-temporal)" {
  class: data
  class: nontemporal
  width: 180
}
dispatch: "Dispatch /\nROB Entry" {
  class: control
  width: 120
}
ports_addr: "Ports 2, 3\nAddress Calculation" {
  class: port
  width: 140
  calc: "AGU: Calculate\neffective address" {
    style.fill: transparent
    style.stroke: "#2196F3"
    style.stroke-dash: 2
  }
}
ports_data: "Port 4\nStore Data" {
  class: port
  width: 120
  store_unit: "Store Unit\n16B write" {
    style.fill: transparent
    style.stroke: "#2196F3"
    style.stroke-dash: 2
  }
}
microcode_check: "Microcode\nPath Check" {
  class: control
  width: 100
}
normal_path: "Normal Store\nPath" {
  class: port
  width: 100
}
nt_path: "Non-Temporal\nPath (bypass)" {
  class: port
  class: nontemporal
  width: 140
}
l1_cache: "L1 Cache\n(32KB)" {
  class: cache
  width: 100
}
write_combining: "Write Combining\nBuffer (WC)" {
  class: cache
  class: nontemporal
  width: 130
}
l2_cache: "L2 Cache\n(256KB)" {
  class: cache
  width: 100
}
memory: "Main Memory\n(RAM)" {
  class: cache
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
  width: 100
}
decoder -> decoded: "decoded"
decoder -> decoded_nt: "decoded"
decoded -> dispatch
decoded_nt -> dispatch
dispatch -> ports_addr: "dispatch to\naddress ports"
dispatch -> microcode_check: "check\ninstruction type"
ports_addr -> ports_data: "address ready"
microcode_check -> normal_path: "MOVAPS\n(normal)"
microcode_check -> nt_path: "MOVNTDQ\n(non-temporal)"
normal_path -> l1_cache: "store to\ncache"
l1_cache -> l2_cache: "evict/writeback"
l2_cache -> memory: "eventual\nwriteback"
nt_path -> write_combining: "WC buffer\naccumulate"
write_combining -> memory: "direct to\nRAM (bypass)"
ports_data -> normal_path: "data\nready"
ports_data -> nt_path: "data\nready"
legend: |md
  **Legend:**
  - Blue boxes: Execution ports
  - Orange parallelograms: Decoded instructions
  - Purple diamonds: Control/decision points
  - Red dashed: Non-temporal (streaming) path
  - Green cylinders: Cache/memory hierarchy
  **Key Insight:** Normal stores go through L1→L2→RAM.
  Non-temporal stores bypass cache via WC buffer.
| {
  near: bottom-center
  shape: text
  style.font-size: 14
}
throughput_note: |md
  **Throughput (Skylake):**
  - Store address: 2 per cycle (ports 2, 3)
  - Store data: 1 per cycle (port 4)
  - Non-temporal: 1 per cycle (port 4)
| {
  near: top-right
  shape: text
  style.font-size: 12
  style.fill: "#FFFDE7"
  style.stroke: "#FFC107"
}