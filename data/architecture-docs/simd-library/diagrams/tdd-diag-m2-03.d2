layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    page-mapped: "#E8F5E9"
    page-unmapped: "#FFEBEE"
    string-data: "#BBDEFB"
    danger-zone: "#FFCDD2"
    safe-read: "#C8E6C9"
    header-bg: "#E1BEE7"
    pointer-color: "#FF5722"
    text-dark: "#212121"
    text-muted: "#757575"
    border-mapped: "#4CAF50"
    border-unmapped: "#F44336"
  }
}

title: {
  shape: text
  near: top-center
  label: |md
    # Memory Layout: Page Boundary Hazard
    **16-byte unaligned read crosses page boundary → potential SIGSEGV**
  |
}

direction: right

# -----------------------------------------------------------------------------
# PAGE 1 DEFINITION (0x4000 - 0x4FFF)
# -----------------------------------------------------------------------------
page1: {
  label: "Page 1 (0x4000-0x4FFF) | Mapped: READ_ONLY"
  style: {
    fill: "${colors.page-mapped}"
    stroke: "${colors.border-mapped}"
    stroke-width: 4
  }

  header1: {
    shape: rectangle
    label: |md
      ### Page Descriptor (VPO 0x000)
      | Attr | Value |
      | :--- | :--- |
      | Start | 0x4000 |
      | End | 0x4FFF |
      | Flags | R-- |
      | PTE | 0x80004 |
    |
    style: {
      fill: "${colors.header-bg}"
      font-size: 14
    }
  }

  string_region: {
    label: "Page 1: Trailing 16-byte Window"
    grid-columns: 16
    grid-gap: 0
    style.fill: "${colors.string-data}"
    
    c4ff0: { label: "4FF0"; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff1: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff2: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff3: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff4: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff5: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff6: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff7: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff8: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ff9: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ffa: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ffb: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ffc: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ffd: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4ffe: { label: "."; style: { fill: "${colors.safe-read}"; font-size: 8 } }
    c4fff: { 
      label: "4FFF\n'H'"
      style: { 
        fill: "${colors.string-data}"
        stroke: "${colors.pointer-color}"
        stroke-width: 4
        font-size: 10
        bold: true 
      } 
    }
  }
}

# -----------------------------------------------------------------------------
# PAGE 2 DEFINITION (0x5000 - 0x5FFF)
# -----------------------------------------------------------------------------
page2: {
  label: "Page 2 (0x5000-0x5FFF) | Unmapped: NO_ACCESS"
  style: {
    fill: "${colors.page-unmapped}"
    stroke: "${colors.border-unmapped}"
    stroke-width: 4
  }

  danger_region: {
    label: "Page 2: Leading 16-byte Window"
    grid-columns: 16
    grid-gap: 0
    style.fill: "${colors.danger-zone}"
    
    c5000: { 
      label: "5000\nERR"
      style: { 
        fill: "${colors.danger-zone}"
        stroke: "${colors.border-unmapped}"
        stroke-width: 4
        font-size: 10
        bold: true 
      } 
    }
    c5001: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5002: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5003: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5004: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5005: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5006: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5007: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5008: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c5009: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c500a: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c500b: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c500c: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c500d: { label: "??"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c500e: { label: "500E"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
    c500f: { label: "500F"; style: { fill: "${colors.danger-zone}"; font-size: 8 } }
  }

  header2: {
    shape: rectangle
    label: |md
      ### Page Descriptor (VPO 0x000)
      | Attr | Value |
      | :--- | :--- |
      | Start | 0x5000 |
      | End | 0x5FFF |
      | State | UNMAPPED |
      | PTE | 0x00000 |
    |
    style: {
      fill: "${colors.header-bg}"
      font-size: 14
    }
  }
}

# -----------------------------------------------------------------------------
# LOGIC & ANALYSIS BLOCKS
# -----------------------------------------------------------------------------
danger_read: {
  label: |md
    ## ❌ UNALIGNED READ: 0x4FFF
    `_mm_loadu_si128((__m128i*)0x4FFF)`
    
    *   **Range:** [0x4FFF, 0x500E] (16 Bytes)
    *   **Boundary Crossing:** YES
    *   **MMU Behavior:**
        1. Fetch [0x4FFF] (Page 1) → **HIT**
        2. Fetch [0x5000] (Page 2) → **MISS/PROTECTION FAULT**
    *   **Result:** SIGSEGV (Segmentation Fault)
  |
  style: {
    fill: "${colors.danger-zone}"
    stroke: "${colors.border-unmapped}"
    stroke-width: 3
  }
}

safe_read_block: {
  label: |md
    ## ✓ ALIGNED READ: 0x4FF0
    `_mm_load_si128((__m128i*)0x4FF0)`
    
    *   **Range:** [0x4FF0, 0x4FFF] (16 Bytes)
    *   **Boundary Crossing:** NO
    *   **Invariants:** 
        - $Address \pmod{16} == 0$
        - $PageSize \pmod{16} == 0$
    *   **Safety:** Atomic within single page entry.
  |
  style: {
    fill: "${colors.safe-read}"
    stroke: "${colors.border-mapped}"
    stroke-width: 3
  }
}

proof: {
  label: |md
    ## Physical Constraints Proof
    Let $P$ be page size ($4096$) and $W$ be read width ($16$).
    Page boundaries occur at addresses $A$ where $A \equiv 0 \pmod P$.
    
    If address $S$ is aligned to $W$ ($S \equiv 0 \pmod W$), then since $P$ is a multiple of $W$ ($4096 / 16 = 256$), the range $[S, S+W-1]$ cannot contain any address $A \equiv 0 \pmod P$ unless $S$ itself is $A$.
  |
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# RELATIONSHIPS
# -----------------------------------------------------------------------------
page1 -- page2: "4KB MMU BOUNDARY" {
  style: {
    stroke: "${colors.border-unmapped}"
    stroke-width: 8
    stroke-dash: 5
  }
}

danger_read -> page1.string_region.c4fff: "Start Pointer" {
  style.stroke: "${colors.pointer-color}"
  style.stroke-width: 3
}

page2.danger_region.c5000 -> danger_read: "Violation Trigger" {
  style.stroke: "${colors.border-unmapped}"
  style.stroke-width: 3
  style.animated: true
}

safe_read_block -> page1.string_region.c4ff0: "Aligned Load" {
  style.stroke: "${colors.border-mapped}"
  style.stroke-width: 3
}

summary: {
  near: bottom-center
  label: |md
    ### Engineering Guideline: "Aligned-From-Below" Strategy
    When performing SIMD operations near buffer edges:
    1. Calculate `aligned_ptr = ptr & ~0xF`
    2. Perform `_mm_load_si128(aligned_ptr)` (Guaranteed safe on same page)
    3. Use bitwise shifts or `_mm_alignr_epi8` to extract the target unaligned bytes.
    4. **Never** use `_mm_loadu_si128` within 15 bytes of a page boundary.
  |
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    stroke-width: 3
  }
}