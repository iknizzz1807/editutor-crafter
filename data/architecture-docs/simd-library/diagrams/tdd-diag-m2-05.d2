vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Algorithm Steps: movemask to Position
  *Low-level SIMD string processing (SSE2/AVX)*
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# BEFORE STATE
# -----------------------------------------------------------------------------------------
before: {
  label: "INPUT: 16-byte XMM Register (xmm0)"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
  }

  grid-columns: 8
  grid-gap: 5

  lane0: "H [00]" {style.fill: "#BBDEFB"}
  lane1: "e [01]" {style.fill: "#BBDEFB"}
  lane2: "l [02]" {style.fill: "#BBDEFB"}
  lane3: "l [03]" {style.fill: "#BBDEFB"}
  lane4: "o [04]" {style.fill: "#BBDEFB"}
  lane5: "\\0 [05]" {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
      bold: true
    }
  }
  lane6: "w [06]" {style.fill: "#BBDEFB"}
  lane7: "o [07]" {style.fill: "#BBDEFB"}
  lane8: "r [08]" {style.fill: "#BBDEFB"}
  lane9: "l [09]" {style.fill: "#BBDEFB"}
  lane10: "d [10]" {style.fill: "#BBDEFB"}
  lane11: "\\0 [11]" {style.fill: "#C8E6C9"}
  lane12: "? [12]" {style.fill: "#E0E0E0"}
  lane13: "? [13]" {style.fill: "#E0E0E0"}
  lane14: "? [14]" {style.fill: "#E0E0E0"}
  lane15: "? [15]" {style.fill: "#E0E0E0"}

  note0: |md
    **Input String:** "hello\0world\0"
    **Target Byte:** 0x00 (NULL)
  |
}

# -----------------------------------------------------------------------------------------
# STEP 1: SIMD COMPARISON
# -----------------------------------------------------------------------------------------
step1: {
  label: "STEP 1: _mm_cmpeq_epi8 (PCMPEQB)"
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
  }

  grid-columns: 8
  grid-gap: 5

  cmp0: "0x00" {style.fill: "#FFE0B2"}
  cmp1: "0x00" {style.fill: "#FFE0B2"}
  cmp2: "0x00" {style.fill: "#FFE0B2"}
  cmp3: "0x00" {style.fill: "#FFE0B2"}
  cmp4: "0x00" {style.fill: "#FFE0B2"}
  cmp5: "0xFF" {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
      bold: true
    }
  }
  cmp6: "0x00" {style.fill: "#FFE0B2"}
  cmp7: "0x00" {style.fill: "#FFE0B2"}
  cmp8: "0x00" {style.fill: "#FFE0B2"}
  cmp9: "0x00" {style.fill: "#FFE0B2"}
  cmp10: "0x00" {style.fill: "#FFE0B2"}
  cmp11: "0xFF" {style.fill: "#C8E6C9"}
  cmp12: "0x00" {style.fill: "#FFE0B2"}
  cmp13: "0x00" {style.fill: "#FFE0B2"}
  cmp14: "0x00" {style.fill: "#FFE0B2"}
  cmp15: "0x00" {style.fill: "#FFE0B2"}

  note1: |md
    Parallel byte-wise comparison.
    - Match Found: 0xFF (11111111b)
    - No Match: 0x00 (00000000b)
  |
}

# -----------------------------------------------------------------------------------------
# STEP 2: MOVEMASK
# -----------------------------------------------------------------------------------------
step2: {
  label: "STEP 2: _mm_movemask_epi8 (PMOVMSKB)"
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
  }

  register: {
    grid-columns: 16
    grid-gap: 2
    
    bit15: "0" {shape: square; style.fill: "#E1BEE7"}
    bit14: "0" {shape: square; style.fill: "#E1BEE7"}
    bit13: "0" {shape: square; style.fill: "#E1BEE7"}
    bit12: "0" {shape: square; style.fill: "#E1BEE7"}
    bit11: "1" {shape: square; style.fill: "#C8E6C9"}
    bit10: "0" {shape: square; style.fill: "#E1BEE7"}
    bit9: "0" {shape: square; style.fill: "#E1BEE7"}
    bit8: "0" {shape: square; style.fill: "#E1BEE7"}
    bit7: "0" {shape: square; style.fill: "#E1BEE7"}
    bit6: "0" {shape: square; style.fill: "#E1BEE7"}
    bit5: "1" {
      shape: square
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
        stroke-width: 3
        bold: true
      }
    }
    bit4: "0" {shape: square; style.fill: "#E1BEE7"}
    bit3: "0" {shape: square; style.fill: "#E1BEE7"}
    bit2: "0" {shape: square; style.fill: "#E1BEE7"}
    bit1: "0" {shape: square; style.fill: "#E1BEE7"}
    bit0: "0" {shape: square; style.fill: "#E1BEE7"}
  }

  hex_result: "Resulting Mask: 0x0820" {
    style: {
      fill: "#9C27B0"
      font-color: white
      bold: true
      border-radius: 4
    }
  }

  note2: |md
    Extracts the Most Significant Bit (MSB) 
    of each of the 16 bytes and packs them 
    into a single 16-bit integer.
  |
}

# -----------------------------------------------------------------------------------------
# STEP 3: COUNT TRAILING ZEROS
# -----------------------------------------------------------------------------------------
step3: {
  label: "STEP 3: __builtin_ctz (BSF / TZCNT)"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
  }

  calculation: |md
    **Binary View:**
    `0000 1000 0010 0000`
    `              ^ bit 5`
    
    Trailing zeros count: **5**
  |

  ctz_result: "Index: 5" {
    style: {
      fill: "#4CAF50"
      font-color: white
      bold: true
      font-size: 24
      border-radius: 10
    }
  }

  note3: |md
    CTZ returns the number of zero bits 
    preceding the least significant set bit.
  |
}

# -----------------------------------------------------------------------------------------
# FINAL STATE
# -----------------------------------------------------------------------------------------
after: {
  label: "OUTPUT: Offset Found"
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 3
  }

  result_box: "Position = 5" {
    style: {
      fill: "#4CAF50"
      font-color: white
      bold: true
      font-size: 28
      border-radius: 5
    }
  }

  summary: |md
    **Success:** Null terminator found at `offset 5`.
    
    **Architectural Impact:**
    - Branchless execution.
    - Constant time complexity O(1) for 16-byte blocks.
    - Utilizes full width of the ALU.
  |
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS & FLOW
# -----------------------------------------------------------------------------------------
before -> step1: "PCMPEQB" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
step1 -> step2: "PMOVMSKB" {
  style.stroke: "#9C27B0"
  style.stroke-width: 2
}
step2 -> step3: "TZCNT" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
step3 -> after: "Return index" {
  style: {
    stroke: "#388E3C"
    stroke-width: 4
    animated: true
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  
  title: "**Legend**"
  
  match: "First Match (Null)" {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
  
  secondary: "Subsequent Matches" {
    style: {
      fill: "#C8E6C9"
    }
  }
  
  data: "Standard Data" {
    style: {
      fill: "#BBDEFB"
    }
  }
}