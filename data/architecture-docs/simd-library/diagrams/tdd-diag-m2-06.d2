direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Algorithm Steps: Mask Shifting for Alignment
  **Simulating `mask >>= offset` to adjust bitmask for unaligned string start**
  *Instruction Context: Intel® AVX-512 / SSE VPCMPB / PMOVMSKB Emulation*
| {near: top-center}

# --- GLOBAL CLASSES ---
classes: {
  header_style: {
    style: {
      fill: "#B5AFF6"
      bold: true
      font-size: 18
      stroke: "#333"
    }
  }
  bit_active: {
    label: "1"
    style: {
      fill: "#FF6B6B"
      stroke: "#CC0000"
      font-color: white
      bold: true
    }
  }
  bit_padding: {
    label: "0"
    style: {
      fill: "#808080"
      stroke: "#333"
      font-color: "#DDD"
    }
  }
  bit_empty: {
    label: "0"
    style: {
      fill: "#D3D3D3"
      stroke: "#999"
      font-color: "#666"
    }
  }
  valid_range: {
    style: {
      stroke: "#2E86AB"
      stroke-width: 3
    }
  }
  changed_node: {
    label: "1"
    style: {
      fill: "#FF0000"
      stroke: "#900"
      font-color: "#FFF"
      bold: true
      shadow: true
    }
  }
  ptr_label: {
    shape: hexagon
    style: {
      fill: "#FFE5B4"
      stroke: "#FF8C00"
      font: mono
      bold: true
    }
  }
}

# --- BEFORE STATE ---
before_state: {
  label: "1. BEFORE: Unaligned Load Result"
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    stroke-width: 2
  }

  reg_label: "Register: %k1 (Opmask)" {
    class: header_style
    shape: package
  }

  offset_ptr: {
    label: "ptr % 16 = 8"
    class: ptr_label
  }

  bit_grid_before: {
    label: "16-bit Vector Mask (Initial)"
    grid-columns: 16
    grid-gap: 2
    
    # MSB (Left) to LSB (Right)
    # Bits 15-8: Valid String Data
    b15: { class: bit_empty }
    b14: { class: bit_empty }
    b13: { class: bit_empty }
    b12: { class: bit_empty }
    b11: { class: bit_active; tooltip: "Match at string index 3" }
    b10: { class: bit_empty }
    b9: { class: bit_empty }
    b8: { class: bit_empty }
    
    # Bits 7-0: Padding / Garbage (Discarded via shift)
    b7: { class: bit_padding }
    b6: { class: bit_padding }
    b5: { class: bit_active; tooltip: "False match in padding" }
    b4: { class: bit_padding }
    b3: { class: bit_padding }
    b2: { class: bit_padding }
    b1: { class: bit_padding }
    b0: { class: bit_padding }

    # Individual styling for valid range to avoid bracket errors
    b15.class: [bit_empty; valid_range]
    b14.class: [bit_empty; valid_range]
    b13.class: [bit_empty; valid_range]
    b12.class: [bit_empty; valid_range]
    b11.class: [bit_active; valid_range]
    b10.class: [bit_empty; valid_range]
    b9.class: [bit_empty; valid_range]
    b8.class: [bit_empty; valid_range]
  }

  markers: "|--- Valid Data (8 bits) ---|--- Padding (8 bits) ---|" {
    shape: text
    style.font: mono
  }
}

# --- TRANSITION STEP ---
step_logic: {
  label: "2. OPERATION: Logical Right Shift"
  style: {
    fill: "#FDF5E6"
    stroke: "#B8860B"
    stroke-width: 4
    stroke-dash: 5
  }

  op: "KSHIFTRW %k1, 8, %k2" {
    shape: oval
    style: {
      fill: "#FFD700"
      stroke: "#B8860B"
      font: mono
      bold: true
      font-size: 20
    }
  }

  internal_flow: {
    direction: right
    bits_in: "0x0820" { 
      shape: parallelogram
      style: { fill: "#D0E1F9"; font: mono }
    }
    shift_engine: "SHR 8" { 
      shape: step
      style.fill: orange
    }
    bits_out: "0x0008" { 
      shape: parallelogram
      style: { fill: "#AFE1AF"; font: mono }
    }
    
    bits_in -> shift_engine -> bits_out
  }
}

# --- AFTER STATE ---
after_state: {
  label: "3. AFTER: Normalized for Leading Zero Count"
  style: {
    fill: "#F0FFF0"
    stroke: "#228B22"
    stroke-width: 2
  }

  reg_label: "Result: %k2 (Normalized)" {
    class: header_style
    shape: package
    style.fill: "#AFE1AF"
  }

  bit_grid_after: {
    label: "Shifted Mask (Base 0 Alignment)"
    grid-columns: 16
    grid-gap: 2
    
    # High bits are now zeroed out
    a15: "0"; a14: "0"; a13: "0"; a12: "0"
    a11: "0"; a10: "0"; a9: "0"; a8: "0"
    
    # Low bits contain the shifted data
    a7: "0"; a6: "0"; a5: "0"; a4: "0"
    a3: { 
      class: changed_node
      tooltip: "Original Bit 11 shifted to Bit 3"
    }
    a2: "0"; a1: "0"; a0: "0"
    
    # Style bits 15-0 as mono
    a15.style.font: mono; a14.style.font: mono; a13.style.font: mono; a12.style.font: mono
    a11.style.font: mono; a10.style.font: mono; a9.style.font: mono; a8.style.font: mono
    a7.style.font: mono; a6.style.font: mono; a5.style.font: mono; a4.style.font: mono
    a3.style.font: mono; a2.style.font: mono; a1.style.font: mono; a0.style.font: mono
  }

  calc_box: {
    label: "result_idx = _tzcnt_u32(k2) = 3"
    shape: rectangle
    style: {
      fill: "#FFF"
      stroke: "#228B22"
      bold: true
      font: mono
      font-size: 16
    }
  }
}

# --- CONNECTIONS ---
before_state -> step_logic: "Discard Low 8 Bits" {
  style: {
    stroke: "#FF8C00"
    stroke-width: 3
    animated: true
  }
}

step_logic -> after_state: "Align Valid String Data to Bit 0" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
  }
}

# --- LEGEND ---
legend: {
  near: bottom-right
  style.fill: "#F9F9F9"
  style.stroke: "#CCC"
  
  items: {
    grid-columns: 2
    grid-gap: 10
    
    l1_c: { style: { fill: "#FF6B6B"; stroke: "#CC0000" }; width: 20; height: 15 }
    l1_t: "SIMD Match Found" { shape: text }
    
    l2_c: { style: { fill: "#808080"; stroke: "#333" }; width: 20; height: 15 }
    l2_t: "Unaligned Padding" { shape: text }
    
    l3_c: { style: { fill: "#FF0000"; stroke: "#900"; shadow: true }; width: 20; height: 15 }
    l3_t: "Normalized Position" { shape: text }
  }
}

# --- ANNOTATIONS ---
ann1: |md
  ### SIMD Alignment Logic
  - **Memory offset:** 8 bytes.
  - The vector load contains garbage from `[ptr-8, ptr-1]`.
  - To ignore this, we `KSHIFTRW` right by the byte offset.
  - Bit 11 corresponds to the 4th valid byte (8+3).
| {
  style.font-size: 14
}

ann2: |md
  ### Post-Condition
  - Logic: `(Mask & ~0) >> offset`.
  - `0x0820 >> 8 = 0x0008`.
  - Trailing Zero Count (`tzcnt`) on `0x0008` correctly yields **Index 3**.
  - This index is relative to the *logical* start of the string.
| {
  style.font-size: 14
}

# --- BYTE OFFSETS / REGISTER MARGINS ---
"0x00_Offset": "0 bytes" { 
  shape: text 
  style.font: mono
}
"0x08_Offset": "8 bytes (ptr start)" { 
  shape: text 
  style.font: mono
}
"0x10_Offset": "16 bytes" { 
  shape: text 
  style.font: mono
}