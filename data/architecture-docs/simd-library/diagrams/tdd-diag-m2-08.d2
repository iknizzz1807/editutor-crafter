vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Data Flow: memchr with Size Limit {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Input stage
input: Input {
  shape: class
  "ptr p": "const void*"
  "target c": "int (byte value)"
  "size n": "size_t"
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
}
# Initial check
check_size: "n >= 16?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
# Scalar prologue path
scalar_prologue: Scalar Prologue {
  shape: rectangle
  "loop i = 0 to min(16-offset, n)": "byte-by-byte compare"
  "if (p[i] == c)": "return (void*)(p + i)"
  "p += prologue_bytes": "advance pointer"
  "n -= prologue_bytes": "decrement remaining"
  style.fill: "#FFCCBC"
  style.stroke: "#E64A19"
}
# SIMD loop
simd_loop: SIMD Main Loop {
  shape: rectangle
  "while (n >= 16)": "vectorized search"
  "chunk = load_si128(p)": "load 16 bytes (aligned)"
  "cmp = cmpeq_epi8(chunk, target_vec)": "parallel compare"
  "mask = movemask_epi8(cmp)": "extract match bits"
  style.fill: "#B2DFDB"
  style.stroke: "#00897B"
}
# Mask check
check_mask: "mask != 0?" {
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
}
# Found path
found_pos: Found {
  shape: rectangle
  "pos = ctz(mask)": "first match position"
  "return (void*)(p + pos)": "pointer to match"
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
}
# Continue loop
continue_loop: Continue {
  shape: rectangle
  "p += 16": "advance pointer"
  "n -= 16": "decrement remaining"
  style.fill: "#BBDEFB"
  style.stroke: "#1976D2"
}
# Scalar epilogue
scalar_epilogue: Scalar Epilogue {
  shape: rectangle
  "loop i = 0 to n-1": "remaining 0-15 bytes"
  "if (p[i] == c)": "return (void*)(p + i)"
  "return NULL": "not found"
  style.fill: "#FFCCBC"
  style.stroke: "#E64A19"
}
# Not found return
not_found: "return NULL" {
  shape: circle
  style.fill: "#FFCDD2"
  style.stroke: "#D32F2F"
}
# Connections
input -> check_size: "start search"
check_size -> scalar_prologue: "n < 16"
check_size -> simd_loop: "n >= 16"
scalar_prologue -> scalar_epilogue: "n exhausted\nor aligned"
scalar_prologue -> simd_loop: "aligned, n >= 16"
simd_loop -> check_mask: "mask computed"
check_mask -> found_pos: "mask != 0\n(found)"
check_mask -> continue_loop: "mask == 0\n(not in chunk)"
continue_loop -> simd_loop: "n >= 16\n(continue loop)"
continue_loop -> scalar_epilogue: "n < 16\n(exit loop)"
scalar_epilogue -> found_pos: "found in\nepilogue"
scalar_epilogue -> not_found: "not found"
# Annotations
annotation: |md
  **Size Tracking:**
  - `n` decremented at every stage
  - SIMD loop: `n -= 16` per iteration
  - Scalar: `n -= 1` per byte
  - Loop exits when `n < 16`
  **Safety Guarantee:**
  - Never reads beyond `n` bytes
  - SIMD only when `n >= 16`
| {
  near: bottom-center
  shape: text
  style: {
    font-size: 14
    italic: true
  }
}
# Legend
legend: {
  near: bottom-right
  style.fill: transparent
  label: Legend
  simdblk: SIMD Path {
    style.fill: "#B2DFDB"
  }
  scalarblk: Scalar Path {
    style.fill: "#FFCCBC"
  }
  decision: Decision {
    shape: diamond
    style.fill: "#FFF9C4"
  }
  result: Result {
    shape: circle
    style.fill: "#C8E6C9"
  }
}