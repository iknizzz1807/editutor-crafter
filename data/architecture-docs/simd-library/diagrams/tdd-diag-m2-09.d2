direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

title: |md
  # String Alignment Test Coverage Matrix
  Testing all combinations of alignment offset and string length
| {near: top-center}

classes: {
  cell: {
    style: {
      fill: "#f0f0f0"
      stroke: "#333333"
      stroke-width: 1
      font-size: 14
    }
  }
  pass: {
    style: {
      fill: "#c8e6c9"
      stroke: "#2e7d32"
      font-color: "#1b5e20"
      bold: true
    }
  }
  fail: {
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
      font-color: "#b71c1c"
    }
  }
  header: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      bold: true
      font-size: 12
    }
  }
}

grid-columns: 17
grid-rows: 17
grid-gap: 0

# Header row - string lengths (Columns 1-17)
