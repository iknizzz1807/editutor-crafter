layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

direction: right

title: {
  label: |md
    # Memory Layout: SIMD Page Boundary Hazard
    **Technical Spec: SIMD reads must not cross page boundaries into unmapped memory.**
  |
  near: top-center
  style: {
    font-size: 28
    bold: true
    stroke-width: 0
    fill: transparent
  }
}

classes: {
  mapped: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  unmapped: {
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  valid_read: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
    }
  }
  label_box: {
    style: {
      fill: white
      stroke: "#9E9E9E"
      stroke-width: 1
      border-radius: 4
      font: mono
      font-size: 14
    }
  }
  hex_offset: {
    shape: text
    style: {
      font: mono
      font-size: 12
      font-color: "#757575"
    }
  }
}

# 1. Virtual Memory Segmentation
virtual_memory: {
  label: "Virtual Address Space Layout"
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
  
  o1: "0x4000" { class: hex_offset }
  o2: "0x5000" { class: hex_offset }

  pages: {
    page1: "Page 4 (0x4000 - 0x4FFF)" {
      class: mapped
      width: 400
      height: 120
      info: {
        label: |md
          **PROT_READ | PROT_WRITE**
          - Physical Frame: 0x1A2B
          - Final Byte: **0x4FFF**
        |
        near: center-center
      }
    }

    page2: "Page 5 (0x5000 - 0x5FFF)" {
      class: unmapped
      width: 400
      height: 120
      info: {
        label: |md
          **UNMAPPED / GUARD PAGE**
          - No PTE Entry
          - Access -> **SIGSEGV**
        |
        near: center-center
      }
    }
    
    page1 -> page2: "PAGE BOUNDARY" {
      style: {
        stroke: "#B71C1C"
        stroke-width: 6
        stroke-dash: 10
      }
    }
  }
  
  o1 -> pages.page1
  o2 -> pages.page2
}

# 2. Byte-Level Detail
byte_view: {
  label: "Byte-Level View at 4KB Boundary"
  style.fill: "#FAFAFA"
  
  memory_grid: {
    grid-columns: 8
    grid-gap: 10
    
    b1: "..." { class: label_box; style.fill: "#EEEEEE" }
    b2: "..." { class: label_box; style.fill: "#EEEEEE" }
    b3: "0x4FFC" { class: label_box }
    b4: "0x4FFD" { class: label_box }
    b5: "0x4FFE" { class: label_box }
    
    # THE CRITICAL BYTE
    target: "0x4FFF" { 
      class: label_box
      style: {
        fill: "#FFECB3"
        stroke: "#FF8F00"
        stroke-width: 4
      }
    }
    
    h1: "0x5000" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    h2: "0x5001" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
  }
}

# 3. SIMD Request Mapping and Fault Analysis
simd_hazard: {
  label: "Fault Analysis: MOVUPS xmm, [0x4FFF]"
  style.fill: "#FFFDE7"
  
  register_xmm: "XMM Register (128-bit)" {
    grid-columns: 8
    grid-gap: 2
    
    lane0: "B0" { class: label_box; style.fill: "#BBDEFB"; style.stroke: "#1565C0"; style.stroke-width: 3 }
    lane1: "B1" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    lane2: "B2" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    lane3: "B3" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    lane4: "B4" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    lane5: "B5" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    lane6: "B6" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
    lane7: "B7" { class: label_box; style.fill: "#FFCDD2"; style.stroke: "#C62828" }
  }
  
  analysis: {
    label: |md
      ### Hardware Fault Analysis
      1. **Instruction:** `MOVUPS xmm, [0x4FFF]`
      2. **Split Load:** MMU requests 16B.
      3. **Crossing:** Bytes [1:15] fall in Page 5.
      4. **Exception:** MMU detects unmapped Page 5.
      5. **Result:** CPU traps to OS -> **SIGSEGV**.
    |
    style: {
      font-size: 14
      stroke-width: 0
      fill: transparent
    }
  }
}

# 4. Mitigation Logic
mitigation: {
  label: "Safe Implementation: Aligned Boundary Check"
  style.fill: "#E8F5E9"
  
  logic: {
    label: |md
      ### Aligned Reading Strategy
      - **Step 1:** Calculate `aligned_ptr = ptr & ~15`
      - **Step 2:** Load from `aligned_ptr` (Safe: Page size is multiple of 16)
      - **Step 3:** Use `PEXTRB` or bit-shifts to extract target byte.
    |
    style: {
      font-size: 14
      stroke-width: 0
      fill: transparent
    }
  }
}

# 5. Global Legend / Invariants
architectural_rule: {
  label: |md
    ## Hardware Invariant
    - **SIMD Width:** 16 Bytes
    - **Page Alignment:** 4096 Bytes
    - **Hazard Condition:** `(Addr & 0xFFF) > 0xFF0`
  |
  near: bottom-right
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    border-radius: 8
  }
}

# Logic Flow Connections
virtual_memory.pages.page1 -> byte_view.memory_grid.target: "Zoom: Last mapped byte" {
  style.stroke: "#FF8F00"
  style.stroke-dash: 3
}

byte_view.memory_grid.target -> simd_hazard.register_xmm.lane0: "Request Base (0x4FFF)" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}

simd_hazard -> mitigation: "FIX: Use Aligned Read" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
}