vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Execution Ports: SIMD Compare and Movemask
  pcmpeqb → pmovmskb → bsf latency chain
| {near: top-center}
direction: right
CPU_Ports: {
  label: ""
  style.fill: transparent
  style.stroke: transparent
  Port0_1: "Port 0/1\n(Integer SIMD)" {
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    shape: rectangle
    width: 160
    height: 120
    pcmpeqb: "pcmpeqb\n(Compare 16 bytes)" {
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      style.bold: true
    }
    pmovmskb: "pmovmskb\n(Extract mask)" {
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      style.bold: true
    }
  }
  Port1: "Port 1\n(Integer)" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    shape: rectangle
    width: 140
    height: 80
    bsf: "bsf (ctz)\n(Find first set)" {
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      style.bold: true
    }
  }
}
Latency_Chain: {
  label: "Latency Chain (cycles)"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  Step1: "1 cycle\ncompare" {
    shape: circle
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
  Step2: "3 cycles\nmask extract" {
    shape: circle
    style.fill: "#FF9800"
    style.font-color: white
    style.bold: true
  }
  Step3: "3 cycles\nfind position" {
    shape: circle
    style.fill: "#F44336"
    style.font-color: white
    style.bold: true
  }
  Total: "Total: 7 cycles\nlatency" {
    shape: rectangle
    style.fill: "#3F51B5"
    style.font-color: white
    style.bold: true
  }
  Step1 -> Step2: {
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }
  Step2 -> Step3: {
    style.stroke: "#FF9800"
    style.stroke-width: 3
  }
  Step3 -> Total: {
    style.stroke: "#F44336"
    style.stroke-width: 3
  }
}
Data_Flow: {
  label: "Data Flow"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  Input: "__m128i chunk\n[16 bytes]" {
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
  Compare_Result: "0x00/0xFF per byte\n[16 comparison results]" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  Mask_Result: "16-bit integer\n[bitmask of matches]" {
    shape: rectangle
    style.fill: "#B3E5FC"
    style.stroke: "#0277BD"
  }
  Position: "int position\n[index of first match]" {
    shape: rectangle
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
  }
  Input -> Compare_Result: "pcmpeqb" {
    style.stroke-width: 2
    style.stroke: "#7B1FA2"
  }
  Compare_Result -> Mask_Result: "pmovmskb" {
    style.stroke-width: 2
    style.stroke: "#388E3C"
  }
  Mask_Result -> Position: "bsf (__builtin_ctz)" {
    style.stroke-width: 2
    style.stroke: "#0277BD"
  }
}
Throughput_Info: |md
  **Throughput:**
  - pcmpeqb: 3 per cycle (ports 0, 1, 5)
  - pmovmskb: 1 per cycle (port 0)
  - bsf: 1 per cycle (port 1)
  **Bottleneck:** pmovmskb on port 0
| {near: bottom-center}