vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    data_array: "#E8F4FD"
    load_op: "#FFF3E0"
    compute_op: "#E8F5E9"
    reduction_op: "#F3E5F5"
    result: "#FFEBEE"
    arrow: "#455A64"
  }
}
direction: right
title: |md
  # Data Flow: SIMD Dot Product
  SSE2 processing 4 floats per operation
| {near: top-center}
# Input Arrays
input_arrays: {
  style.fill: ${colors.data_array}
  style.stroke: "#1976D2"
  style.stroke-width: 2
  array_a: {
    label: "Array a[]\n(float × 4)"
    shape: rectangle
    width: 100
    height: 60
  }
  array_b: {
    label: "Array b[]\n(float × 4)"
    shape: rectangle
    width: 100
    height: 60
  }
  array_a -> array_b: "same index range\ni, i+1, i+2, i+3" {
    style.stroke-dash: 3
    style.stroke: "#90A4AE"
  }
}
# Load Stage
load_stage: {
  style.fill: ${colors.load_op}
  style.stroke: "#F57C00"
  style.stroke-width: 2
  label: "LOAD Stage\n(4 × 32-bit = 128-bit)"
  load_a: {
    label: "_mm_loadu_ps(a+i)\n__m128"
    shape: rectangle
    width: 140
    height: 50
  }
  load_b: {
    label: "_mm_loadu_ps(b+i)\n__m128"
    shape: rectangle
    width: 140
    height: 50
  }
}
# Multiply Stage
multiply_stage: {
  style.fill: ${colors.compute_op}
  style.stroke: "#388E3C"
  style.stroke-width: 2
  label: "MULTIPLY Stage\n(4 parallel × 4 cycles)"
  mul_op: {
    label: "_mm_mul_ps(va, vb)\n4 simultaneous FPs"
    shape: rectangle
    width: 160
    height: 60
  }
  mul_detail: {
    shape: rectangle
    width: 200
    height: 80
    label: |md
      text
      [a0×b0, a1×b1, a2×b2, a3×b3]
            ↓
      __m128: 4 × float32
      
    |
    style.fill: "#C8E6C9"
  }
  mul_op -> mul_detail
}
# Accumulate Stage
accumulate_stage: {
  style.fill: ${colors.compute_op}
  style.stroke: "#388E3C"
  style.stroke-width: 2
  label: "ACCUMULATE Stage\n(loop iterations)"
  acc_init: {
    label: "__m128 sum\n= setzero_ps()"
    shape: rectangle
    width: 120
    height: 40
  }
  acc_op: {
    label: "_mm_add_ps(sum, prod)"
    shape: rectangle
    width: 160
    height: 50
  }
  acc_result: {
    label: "sum = [s0, s1, s2, s3]\n(partial sums)"
    shape: rectangle
    width: 140
    height: 50
  }
  acc_init -> acc_op
  acc_op -> acc_result
  loop_back: {
    shape: circle
    width: 30
    label: ""
    style.fill: "#81C784"
  }
  acc_result -> loop_back: "repeat\nn/4 times" {
    style.stroke-dash: 3
    style.animated: true
  }
  loop_back -> acc_op
}
# Horizontal Reduction Stage
reduction_stage: {
  style.fill: ${colors.reduction_op}
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  label: "HORIZONTAL REDUCTION\n(shuffle+add, NOT hadd)"
  shuffle1: {
    label: "shuffle [s0,s1,s2,s3]\n     → [s2,s3,s0,s1]"
    shape: rectangle
    width: 160
    height: 45
  }
  add1: {
    label: "_mm_add_ps\n[s0+s2, s1+s3, ...]"
    shape: rectangle
    width: 140
    height: 45
  }
  shuffle2: {
    label: "_mm_movehl_ps\nextract high 64"
    shape: rectangle
    width: 140
    height: 45
  }
  add2: {
    label: "_mm_add_ss\nfinal scalar add"
    shape: rectangle
    width: 140
    height: 45
  }
  shuffle1 -> add1
  add1 -> shuffle2
  shuffle2 -> add2
}
# Final Result
final_result: {
  style.fill: ${colors.result}
  style.stroke: "#C62828"
  style.stroke-width: 2
  result: {
    label: "float result\n= Σ(a[i]×b[i])"
    shape: rectangle
    width: 120
    height: 50
    style.font: mono
    style.bold: true
  }
  width_annotation: {
    shape: text
    label: "32-bit scalar\n(single float)"
    style.font-size: 12
    style.italic: true
  }
}
# Data Flow Connections
input_arrays.array_a -> load_stage.load_a: "float*\npointer" {
  label.near: outside-top-left
}
input_arrays.array_b -> load_stage.load_b: "float*\npointer" {
  label.near: outside-bottom-left
}
load_stage.load_a -> multiply_stage.mul_op: "__m128\n128-bit" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
load_stage.load_b -> multiply_stage.mul_op: "__m128\n128-bit" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
multiply_stage.mul_op -> accumulate_stage.acc_op: "__m128\n128-bit" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
  label: "prod"
}
accumulate_stage.acc_result -> reduction_stage.shuffle1: "__m128\n[s0,s1,s2,s3]" {
  style.stroke: ${colors.arrow}
  style.stroke-width: 2
}
reduction_stage.add2 -> final_result.result: "float\n32-bit" {
  style.stroke: "#C62828"
  style.stroke-width: 3
}
# Width Annotations
width_legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  label: "Data Width at Each Stage"
  w1: "4×float32 = 128-bit (XMM)"
  w2: "4×float32 = 128-bit (XMM)"
  w3: "4×float32 = 128-bit (XMM)"
  w4: "1×float32 = 32-bit (scalar)"
  w1.style.fill: ${colors.data_array}
  w2.style.fill: ${colors.load_op}
  w3.style.fill: ${colors.compute_op}
  w4.style.fill: ${colors.result}
}
# Cycle Count Annotation
cycle_annotation: |md
  **Throughput Analysis (Skylake):**
  - Load: 2 per cycle (ports 2,3)
  - Multiply: 2 per cycle (ports 0,1)
  - Add: 2 per cycle (ports 0,1)
  - **Bottleneck: Memory bandwidth**
| {near: bottom-right}