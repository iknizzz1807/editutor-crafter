layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: ||md
  # Memory Layout: YMM Register (256-bit AVX)
  `sizeof=32 bytes (256 bits)`
|| {near: top-center}

direction: right

classes: {
  header: {
    style: {
      fill: "#9B59B6"
      font-color: white
      bold: true
    }
  }
  data_lane: {
    style: {
      fill: "#3498DB"
      font-color: white
      stroke: "#2980B9"
    }
  }
  pointer: {
    style: {
      fill: "#E67E22"
      font-color: white
    }
  }
  alias_zone: {
    style: {
      fill: "#1ABC9C"
      font-color: white
      stroke: "#16A085"
    }
  }
  byte_box: {
    width: 60
    height: 40
    style: {
      font: mono
      font-size: 12
    }
  }
}

YMM_Register: {
  label: "YMM[n] Hardware Register (32 Bytes)"
  style: {
    stroke: "#2C3E50"
    stroke-width: 4
    fill: "#ECF0F1"
    border-radius: 8
  }

  # High 128 Bits (AVX specific)
  High128: {
    label: "High 128 bits (Upper Lane)\nYMM[n][255:128]"
    style: {
      fill: "#D6EAF8"
      stroke: "#2E86C1"
      stroke-dash: 5
    }
    
    # 32-bit Float Lanes
    Float7: "f7 [255:224]" { class: data_lane }
    Float6: "f6 [223:192]" { class: data_lane }
    Float5: "f5 [191:160]" { class: data_lane }
    Float4: "f4 [159:128]" { class: data_lane }
  }

  # Low 128 Bits (Aliased to SSE)
  Low128: {
    label: "Low 128 bits (Lower Lane)\nYMM[n][127:0] ≡ XMM[n]"
    style: {
      fill: "#D1F2EB"
      stroke: "#16A085"
      stroke-width: 3
    }
    
    # 32-bit Float Lanes
    Float3: "f3 [127:96]" { class: data_lane }
    Float2: "f2 [95:64]" { class: data_lane }
    Float1: "f1 [63:32]" { class: data_lane }
    Float0: "f0 [31:0]" { 
      style.fill: "#2980B9"
      style.bold: true
      label: "f0 (LSB)\n[31:0]"
    }
  }
}

XMM_Alias: {
  label: "XMM[n] Legacy View\n(128-bit SSE)"
  class: alias_zone
  style.stroke-dash: 3
  
  L3: "f3"
  L2: "f2"
  L1: "f1"
  L0: "f0"
}

Extraction_Ops: {
  label: "Extraction Operations"
  style.fill: "#F4ECF7"
  style.stroke: "#9B59B6"
  
  extractf128: ||md
    ### _mm256_extractf128_ps
    **Latency:** ~1-3 cycles
    **Action:** Copies YMM[255:128] to an XMM register.
  ||
  cast256_128: ||md
    ### _mm256_castps256_ps128
    **Latency:** 0 (Compile-time)
    **Action:** Treats YMM as XMM (low 128 bits).
  ||
  zeroupper: ||md
    ### _mm256_zeroupper
    **Action:** Clears bits [255:128]. 
    *Crucial for preventing SSE/AVX transition penalties.*
  ||
}

Insertion_Ops: {
  label: "Insertion Operations"
  style.fill: "#FEF9E7"
  style.stroke: "#F1C40F"
  
  insertf128: "`_mm256_insertf128_ps`"
  set_m128: "`_mm256_set_m128(hi, lo)`"
  broadcast: "`_mm256_broadcast_ss`"
}

Memory_Layout_Grid: {
  label: "Byte Offsets (Little-Endian Memory Order)"
  grid-columns: 8
  grid-gap: 2
  
  # Row 1 (Low 128)
  B00: "0x00"; B01: "0x01"; B02: "0x02"; B03: "0x03"
  B04: "0x04"; B05: "0x05"; B06: "0x06"; B07: "0x07"
  B08: "0x08"; B09: "0x09"; B0A: "0x0A"; B0B: "0x0B"
  B0C: "0x0C"; B0D: "0x0D"; B0E: "0x0E"; B0F: "0x0F"
  
  # Row 2 (High 128)
  B10: "0x10"; B11: "0x11"; B12: "0x12"; B13: "0x13"
  B14: "0x14"; B15: "0x15"; B16: "0x16"; B17: "0x17"
  B18: "0x18"; B19: "0x19"; B1A: "0x1A"; B1B: "0x1B"
  B1C: "0x1C"; B1D: "0x1D"; B1E: "0x1E"; B1F: "0x1F"

  # FIX: Replaced invalid range syntax with standard D2 globs
  "B0*": {
    class: byte_box
    style.fill: "#D1F2EB"
  }
  
  "B1*": {
    class: byte_box
    style.fill: "#D6EAF8"
  }
}

Notes: {
  near: center-right
  
  Aliasing: ||md
    ### Aliasing Rules
    - **XMM0** is physical bits [127:0] of **YMM0**.
    - Modifying XMM0 via legacy SSE (non-VEX) instructions **zeroes** the upper 128 bits [255:128] of YMM0 to maintain compatibility.
    - Modifying XMM0 via VEX-encoded SSE instructions (e.g., `vmovaps`) also zeroes the upper bits.
  ||
  
  Transition: ||md
    ### SSE/AVX Transition State
    1. **Clean:** Upper 128 bits zeroed.
    2. **Dirty:** Upper 128 bits contain data.
    - Transitions from **Dirty** to **Legacy SSE** trigger a hardware state save (decoding penalty).
  ||
}

# Connections and Flows
YMM_Register.Low128 -> XMM_Alias: "Physical Alias" {
  style: {
    stroke: "#16A085"
    stroke-width: 3
    stroke-dash: 2
  }
}

YMM_Register.High128 -> Extraction_Ops.extractf128: "Extract upper" {
  style.stroke: "#9B59B6"
  target-arrowhead: triangle
}

XMM_Alias -> Extraction_Ops.cast256_128: "Logical Cast" {
  style.stroke: "#9B59B6"
}

YMM_Register -> Memory_Layout_Grid: "Mapped to Memory" {
  style.stroke: "#34495E"
  style.stroke-dash: 4
}

TechnicalSpecs: ||md
  ## Technical Specifications (Intel® AVX)
  | Property | Requirement / Value |
  | :--- | :--- |
  | **Total Size** | 32 Bytes (256 bits) |
  | **Alignment** | 32-byte alignment for `vmovaps` |
  | **Lanes** | 8 x 32-bit (Single Precision) / 4 x 64-bit (Double) |
  | **Addressing** | Little-Endian (f0 at lowest address 0x00) |
  | **Instruction Set** | Intel AVX / AVX2 / AVX-512 (as YMM) |

  **Alignment Note:** Failure to align `__m256` data on a 32-byte boundary when using aligned load instructions will result in a **General Protection Fault (#GP)**.
|| {
  near: bottom-center
  style: {
    stroke: "#7F8C8D"
    fill: "#FDFEFE"
    border-radius: 5
  }
}