vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B5B95"
    data: "#4A90A4"
    changed: "#D32F2F"
    arrow: "#F69E03"
    note: "#F8F9FA"
    padding: "#E0E0E0"
    success: "#2E7D32"
  }
}

title: {
  near: top-center
  shape: text
  label: ||md
    # Algorithm Steps: Shuffle+Add Horizontal Reduction
    **Target:** SSE2 `__m128` (XMM) → scalar `float` using optimal bit-tree pattern.
    *Constraint:* Avoid SSE3 `hadd_ps` to minimize micro-op latency and maximize port pressure distribution.
  ||
}

direction: down

classes: {
  step: {
    style: {
      fill: "${colors.note}"
      stroke: "#CCCCCC"
      stroke-width: 2
      border-radius: 8
    }
  }
  before: {
    style: {
      fill: "${colors.data}"
      stroke: "#4A90A4"
      stroke-width: 2
      font-color: white
    }
  }
  after: {
    style: {
      fill: "#E8F5E9"
      stroke: "${colors.success}"
      stroke-width: 2
    }
  }
  lane_header: {
    style: {
      fill: "${colors.header}"
      font-color: white
      bold: true
      font-size: 11
    }
  }
  changed_val: {
    style: {
      fill: "${colors.changed}"
      font-color: white
      bold: true
      stroke-width: 2
    }
  }
  opcode: {
    shape: parallelogram
    style: {
      fill: "#333333"
      font-color: white
      font: mono
      bold: true
    }
  }
}

# Initial State - Input Register
before_container: {
  label: "INPUT: __m128 v"
  class: before
  
  bits: "Bits: [127:96] | [95:64] | [63:32] | [31:0]" {
    shape: text
    style.font-size: 10
  }

  reg_v: {
    grid-columns: 4
    l3: "Lane 3 (32b)" {class: lane_header}
    l2: "Lane 2 (32b)" {class: lane_header}
    l1: "Lane 1 (32b)" {class: lane_header}
    l0: "Lane 0 (32b)" {class: lane_header}
    
    val3: "s3" {style.fill: "#BBDEFB"}
    val2: "s2" {style.fill: "#BBDEFB"}
    val1: "s1" {style.fill: "#BBDEFB"}
    val0: "s0" {style.fill: "#BBDEFB"}
  }
}

# Step 1: Internal Pair Shuffle
step1_container: {
  label: "STEP 1: Pair Swap"
  class: step
  
  opcode1: "_mm_shuffle_ps(v, v, _MM_SHUFFLE(2, 3, 0, 1))" {
    class: opcode
  }
  
  shuf_result: "XMM Shuffled (s2, s3, s0, s1)" {
    grid-columns: 4
    sl3: "Lane 3" {class: lane_header}
    sl2: "Lane 2" {class: lane_header}
    sl1: "Lane 1" {class: lane_header}
    sl0: "Lane 0" {class: lane_header}
    
    sv2: "s2" {class: changed_val}
    sv3: "s3" {class: changed_val}
    sv0: "s0" {class: changed_val}
    sv1: "s1" {class: changed_val}
  }
  
  opcode1 -> shuf_result
}

# Step 2: Parallel Summation
step2_container: {
  label: "STEP 2: Parallel Add"
  class: step
  
  opcode2: "_mm_add_ps(v, shuf)" {
    class: opcode
  }
  
  sums_result: "XMM Partial Sums" {
    grid-columns: 4
    rl3: "Lane 3" {class: lane_header}
    rl2: "Lane 2" {class: lane_header}
    rl1: "Lane 1" {class: lane_header}
    rl0: "Lane 0" {class: lane_header}
    
    sum31: "s3+s1" {class: changed_val}
    sum20: "s2+s0" {class: changed_val}
    sum13: "s1+s3" {class: changed_val}
    sum02: "s0+s2" {class: changed_val}
  }
  
  opcode2 -> sums_result
}

# Step 3: High-to-Low Extraction
step3_container: {
  label: "STEP 3: Move High to Low"
  class: step
  
  opcode3: "_mm_movehl_ps(sums, sums)" {
    class: opcode
  }
  
  high_result: "XMM High-to-Low" {
    grid-columns: 4
    hl3: "Unchanged" {style.fill: "${colors.padding}"}
    hl2: "Unchanged" {style.fill: "${colors.padding}"}
    hl1: "Lane 1" {class: lane_header}
    hl0: "Lane 0" {class: lane_header}
    
    p3: "s3+s1" {style.fill: "${colors.padding}"}
    p2: "s2+s0" {style.fill: "${colors.padding}"}
    h_v1: "s3+s1" {class: changed_val}
    h_v0: "s2+s0" {class: changed_val}
  }
  
  note3: {
    shape: text
    label: ||md
      **movehl_ps logic:**
      Copies bits [127:64] (high half)
      to bits [63:0] (low half).
    ||
  }
  
  opcode3 -> high_result
}

# Step 4: Final Scalar Addition
step4_container: {
  label: "STEP 4: Final Scalar Add"
  class: step
  
  opcode4: "_mm_add_ss(sums, high)" {
    class: opcode
  }
  
  final_reg: "XMM Final Scalar" {
    grid-columns: 4
    fl3: "Ignore" {style.fill: "${colors.padding}"}
    fl2: "Ignore" {style.fill: "${colors.padding}"}
    fl1: "Ignore" {style.fill: "${colors.padding}"}
    fl0: "Active (Scalar)" {class: lane_header}
    
    dp3: "sums[3]" {style.fill: "${colors.padding}"}
    dp2: "sums[2]" {style.fill: "${colors.padding}"}
    dp1: "sums[1]" {style.fill: "${colors.padding}"}
    res: "Σ(s0..s3)" {class: changed_val}
  }
  
  note4: {
    shape: text
    label: ||md
      **add_ss (Scalar Single):**
      Only sums the low 32-bits.
      `(s0+s2) + (s1+s3)`
    ||
  }
  
  opcode4 -> final_reg
}

# Final Output State
after_container: {
  label: "OUTPUT"
  class: after
  
  extract_op: "_mm_cvtss_f32(final_reg)" {
    class: opcode
    style.fill: "${colors.success}"
  }
  
  scalar_float: "float result = s0+s1+s2+s3" {
    shape: oval
    style: {
      fill: "#4CAF50"
      font-color: white
      bold: true
    }
  }
  
  extract_op -> scalar_float
}

# Pipeline Flow
before_container -> step1_container: "Load v" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 4
}
step1_container -> step2_container: "shuffle" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 4
}
step2_container -> step3_container: "sums" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 4
}
step3_container -> step4_container: "high" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 4
}
step4_container -> after_container: "XMM[0]" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 4
}

# Technical Specs Legend
legend: {
  near: bottom-center
  shape: text
  label: ||md
    ### Implementation Grade Specs
    | Opcode | Latency (Cycles) | Throughput | Ports |
    | :--- | :--- | :--- | :--- |
    | `shufps` | 1 | 1/cycle | p5 |
    | `addps` | 3 | 1/cycle | p0, p1 |
    | `movehl` | 1 | 1/cycle | p5 |
    | `addss` | 3 | 1/cycle | p0, p1 |
    
    **Comparison with `hadd_ps` (SSE3):**
    - `hadd_ps` is micro-coded as multiple shuffles + adds (~2-3 uOps).
    - This manual tree exploits Port 0/1/5 concurrency.
    - **Total Latency:** ~8 cycles vs ~13 cycles.
    - **Throughput:** ~2x higher on Skylake/Zen architectures.
  ||
}