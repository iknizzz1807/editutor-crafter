layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Algorithm Steps: AVX 8-Float Horizontal Reduction
  YMM → Scalar Sum via Extract + SSE Reduction
| {near: top-center}

direction: right

states: {
  before: BEFORE {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
    }
    label: |md
      **State: Initial YMM Register**
      YMM0: `[s0, s1, s2, s3, s4, s5, s6, s7]`
      8 partial sums from parallel lanes
    |
  }

  step1: "Step 1: Extract High 128" {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
    label: |md
      **Operation: `_mm256_extractf128_ps(v, 1)`**
      Extract upper 128 bits (lanes 4-7)
      
      XMM_hi = [s4, s5, s6, s7]
      
      Low 128 bits remain in YMM:
      
      XMM_lo = [s0, s1, s2, s3]
    |
  }

  step2: "Step 2: Add Halves" {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    label: |md
      **Operation: `_mm_add_ps(lo, hi)`**
      Vertically add 128-bit halves:
      
      [s0, s1, s2, s3] +
      [s4, s5, s6, s7]
      ─────────────────
      **[s0+s4, s1+s5, s2+s6, s3+s7]**
      
      Now in XMM: 4 reduced sums
    |
  }

  step3: "Step 3: SSE 4-Float Reduction" {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    label: |md
      **Shuffle+Add Pattern (NOT hadd!):**
      
      // Shuffle: [s0+s4, s1+s5, s2+s6, s3+s7]
      //        → [s2+s6, s3+s7, s0+s4, s1+s5]
      shuf = _mm_shuffle_ps(v, v, _MM_SHUFFLE(1,0,3,2))
      // Add: pair-wise sums
      tmp = _mm_add_ps(v, shuf)
      // Final scalar extraction
      result = _mm_cvtss_f32(_mm_add_ss(...))
    |
  }

  after: AFTER {
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
    }
    label: |md
      **State: Scalar Result**
      `float sum = s0 + s1 + s2 + s3 + s4 + s5 + s6 + s7`
      Single scalar in `xmm0[0]`
    |
  }
}

states.before -> states.step1: "extract high\n128 bits" {
  style: {
    stroke: "#E65100"
    stroke-width: 2
    animated: true
  }
}
states.step1 -> states.step2: "vertical add\n128-bit halves" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    animated: true
  }
}
states.step2 -> states.step3: "apply SSE\nreduction" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
    animated: true
  }
}
states.step3 -> states.after: "extract\nscalar" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    animated: true
  }
}

register_layout: {
  label: "Register Layout Visual"
  ymm_before: {
    label: |md
      **YMM Register (256-bit)**
      
      ┌────────┬────────┬────────┬────────┬────────┬────────┬────────┬────────┐
      │ Lane 7 │ Lane 6 │ Lane 5 │ Lane 4 │ Lane 3 │ Lane 2 │ Lane 1 │ Lane 0 │
      │   s7   │   s6   │   s5   │   s4   │   s3   │   s2   │   s1   │   s0   │
      └────────┴────────┴────────┴────────┴────────┴────────┴────────┴────────┘
                    ↑ High 128 (extract) ↑        ↑ Low 128 (cast) ↑
    |
    style.fill: "#E3F2FD"
  }
  
  xmm_after: {
    label: |md
      **After Step 2: XMM Register (128-bit)**
      
      ┌───────────────┬───────────────┬───────────────┬───────────────┐
      │ Lane 3        │ Lane 2        │ Lane 1        │ Lane 0        │
      │ **s3+s7**     │ **s2+s6**     │ **s1+s5**     │ **s0+s4**     │
      └───────────────┴───────────────┴───────────────┴───────────────┘
    |
    style.fill: "#E8F5E9"
  }
  
  ymm_before -> xmm_after: "reduce 8→4"
}

complexity: {
  label: |'md
    **Complexity Analysis**
    | Step | Instructions | Latency |
    |------|--------------|---------|
    | Extract | `vextractf128` | 3 cycles |
    | Add halves | `vaddps` | 4 cycles |
    | SSE reduction | 2 shuffle + 2 add | ~6 cycles |
    | **Total** | 5 instructions | **~13 cycles** |
    
    **vs hadd chain: 2× `vhaddps` = 10+ cycles, higher port contention**
  '|
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
  }
  near: bottom-center
}