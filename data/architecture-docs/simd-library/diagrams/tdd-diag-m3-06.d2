layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 30
  }
  colors: {
    row0: "#E8F5E9"
    row1: "#C8E6C9"
    row2: "#A5D6A7"
    row3: "#81C784"
    col0: "#E3F2FD"
    col1: "#BBDEFB"
    col2: "#90CAF9"
    col3: "#64B5F6"
    header: "#6A1B9A"
    highlight: "#FF5722"
    padding: "#ECEFF1"
    cache_line: "#B0BEC5"
    byte_offset: "#607D8B"
  }
}

title: {
  label: ||md
    # Memory Layout: 4×4 Matrix Row-Major vs Column-Major
    **Technical Specification for SIMD Data Alignment**
    *Total Matrix Size: 64 Bytes (16 elements × 4 bytes)*
    *One Full CPU Cache Line (L1D)*
  ||
  shape: text
  near: top-center
}

classes: {
  cell: {
    width: 140
    height: 90
    style: {
      stroke: "#455A64"
      stroke-width: 1
      font-size: 14
      border-radius: 4
      shadow: true
    }
  }
  access_note: {
    shape: text
    style: {
      font-size: 15
      italic: true
      font-color: "#37474F"
      bold: true
    }
  }
  container_box: {
    style: {
      stroke: "#263238"
      stroke-width: 3
      fill: "#FAFAFA"
      stroke-dash: 0
      shadow: true
      border-radius: 12
    }
  }
  byte_marker: {
    shape: text
    style: {
      font-size: 11
      font-color: "${colors.byte_offset}"
      font: mono
    }
  }
}

row_major: {
  label: "Row-Major Layout (C/C++/Rust/Python Default)\nLinear Address = Base + (row * width + col) * sizeof(T)\n[Boundary: 64 Bytes / 16 Floats]"
  class: container_box
  
  grid-columns: 4
  grid-gap: 12

  # Row 0: Contiguous Group 1
  r0c0: "M[0][0]\nOffset: +0x00\n[Bytes 0-3]" { class: cell; style.fill: "${colors.row0}"; style.stroke: "${colors.header}" }
  r0c1: "M[0][1]\nOffset: +0x04\n[Bytes 4-7]" { class: cell; style.fill: "${colors.row0}" }
  r0c2: "M[0][2]\nOffset: +0x08\n[Bytes 8-11]" { class: cell; style.fill: "${colors.row0}" }
  r0c3: "M[0][3]\nOffset: +0x0C\n[Bytes 12-15]" { class: cell; style.fill: "${colors.row0}" }
  
  # Row 1: Contiguous Group 2
  r1c0: "M[1][0]\nOffset: +0x10\n[Bytes 16-19]" { class: cell; style.fill: "${colors.row1}" }
  r1c1: "M[1][1]\nOffset: +0x14\n[Bytes 20-23]" { class: cell; style.fill: "${colors.row1}" }
  r1c2: "M[1][2]\nOffset: +0x18\n[Bytes 24-27]" { class: cell; style.fill: "${colors.row1}" }
  r1c3: "M[1][3]\nOffset: +0x1C\n[Bytes 28-31]" { class: cell; style.fill: "${colors.row1}" }

  # Row 2: Contiguous Group 3
  r2c0: "M[2][0]\nOffset: +0x20\n[Bytes 32-35]" { class: cell; style.fill: "${colors.row2}" }
  r2c1: "M[2][1]\nOffset: +0x24\n[Bytes 36-39]" { class: cell; style.fill: "${colors.row2}" }
  r2c2: "M[2][2]\nOffset: +0x28\n[Bytes 40-43]" { class: cell; style.fill: "${colors.row2}" }
  r2c3: "M[2][3]\nOffset: +0x2C\n[Bytes 44-47]" { class: cell; style.fill: "${colors.row2}" }

  # Row 3: Contiguous Group 4
  r3c0: "M[3][0]\nOffset: +0x30\n[Bytes 48-51]" { class: cell; style.fill: "${colors.row3}" }
  r3c1: "M[3][1]\nOffset: +0x34\n[Bytes 52-55]" { class: cell; style.fill: "${colors.row3}" }
  r3c2: "M[3][2]\nOffset: +0x38\n[Bytes 56-59]" { class: cell; style.fill: "${colors.row3}" }
  r3c3: "M[3][3]\nOffset: +0x3C\n[Bytes 60-63]" { class: cell; style.fill: "${colors.row3}" }

  row_major_simd: {
    label: ||md
      **Row-Major SIMD Access Pattern**
      1. `MOVAPS xmm0, [base]` : Load M[0][0-3]
      2. `VADDPS ymm1, ymm1, [base+32]` : Row 2 vector add
      ---
      ✓ Contiguous Row Access (Spatial Locality)
      ✓ Direct DMA Mapping
    ||
    class: access_note
  }
}

col_major: {
  label: "Column-Major Layout (Fortran/OpenGL/MATLAB Default)\nLinear Address = Base + (col * height + row) * sizeof(T)\n[Cache Line Boundary: 64 Bytes]"
  class: container_box

  grid-columns: 4
  grid-gap: 12

  # Memory-Contiguous Column 0 (Linear scan in memory)
  c0r0: "M[0][0]\nOffset: +0x00" { class: cell; style.fill: "${colors.col0}"; style.stroke: "${colors.header}" }
  c1r0: "M[0][1]\nOffset: +0x10" { class: cell; style.fill: "${colors.col1}" }
  c2r0: "M[0][2]\nOffset: +0x20" { class: cell; style.fill: "${colors.col2}" }
  c3r0: "M[0][3]\nOffset: +0x30" { class: cell; style.fill: "${colors.col3}" }

  # Column 1
  c0r1: "M[1][0]\nOffset: +0x04" { class: cell; style.fill: "${colors.col0}" }
  c1r1: "M[1][1]\nOffset: +0x14" { class: cell; style.fill: "${colors.col1}" }
  c2r1: "M[1][2]\nOffset: +0x24" { class: cell; style.fill: "${colors.col2}" }
  c3r1: "M[1][3]\nOffset: +0x34" { class: cell; style.fill: "${colors.col3}" }

  # Column 2
  c0r2: "M[2][0]\nOffset: +0x08" { class: cell; style.fill: "${colors.col0}" }
  c1r2: "M[2][1]\nOffset: +0x18" { class: cell; style.fill: "${colors.col1}" }
  c2r2: "M[2][2]\nOffset: +0x28" { class: cell; style.fill: "${colors.col2}" }
  c3r2: "M[2][3]\nOffset: +0x38" { class: cell; style.fill: "${colors.col3}" }

  # Column 3
  c0r3: "M[3][0]\nOffset: +0x0C" { class: cell; style.fill: "${colors.col0}" }
  c1r3: "M[3][1]\nOffset: +0x1C" { class: cell; style.fill: "${colors.col1}" }
  c2r3: "M[3][2]\nOffset: +0x2C" { class: cell; style.fill: "${colors.col2}" }
  c3r3: "M[3][3]\nOffset: +0x3C" { class: cell; style.fill: "${colors.col3}" }

  col_major_simd: {
    label: ||md
      **Column-Major SIMD Access Pattern**
      1. `VLD1.32 {q0}, [ptr]` : Load M[0-3][0]
      2. Efficient for Matrix-Vector Multiply $Ax$
      ---
      ✓ Contiguous Column Access
      ✗ Strided Row Access (L1 Cache Miss Risk in C loops)
    ||
    class: access_note
  }
}

# Cross-container logical relationship
row_major.r0c1 -> col_major.c1r0: "Index Mapping [0][1] → Offset +16" {
  style.stroke: "${colors.header}"
  style.stroke-dash: 3
  style.stroke-width: 2
}

perf_table: {
  label: ||md
    ### Matrix Multiply (C = A × B) Performance Analysis
    *For element $C_{ij} = \sum A_{ik} B_{kj}$, access pattern efficiency determines GFLOPS.*
    
    | A Layout (LHS) | B Layout (RHS) | Inner Loop Access | SIMD Instruction Type | Performance |
    | :--- | :--- | :--- | :--- | :--- |
    | Row-Major | Row-Major | A: Seq ✓, B: Stride ✗ | `VGATHERDPS` (High Latency) | Suboptimal |
    | **Row-Major** | **Col-Major** | **A: Seq ✓, B: Seq ✓** | **Linear `VFMADD` (FMA)** | **Maximum (Peak)** |
    | Col-Major | Row-Major | A: Stride ✗, B: Stride ✗ | Heavy Register Shuffling | Worst |
    | Col-Major | Col-Major | A: Stride ✗, B: Seq ✓ | `VINSERTPS` / Broadcasters | Suboptimal |
    
    **Architectural Optimization:** Transposing the RHS matrix (B) to Column-Major format is a standard 
    pre-processing step in BLAS libraries (Intel MKL/OpenBLAS) to ensure L1 Cache spatial locality.
  ||
  shape: text
  near: bottom-center
  style: {
    stroke: "#CFD8DC"
    stroke-width: 2
    fill: "#F5F7F9"
    border-radius: 8
    shadow: true
  }
}

legend: {
  near: center-right
  contig: "Contiguous Memory Block" {
    style.fill: "${colors.row0}"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
  }
  strided: "Strided Offset (+16 bytes)" {
    style.fill: "${colors.col1}"
    style.stroke: "#2196F3"
    style.stroke-dash: 4
  }
  cache: "64B Cache Line (L1D)" {
    style.stroke: "${colors.cache_line}"
    style.stroke-dash: 5
    style.fill: transparent
  }
}