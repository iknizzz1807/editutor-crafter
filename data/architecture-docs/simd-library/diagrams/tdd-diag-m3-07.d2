vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Data Flow: Matrix Multiply Cache Access Locality
  ## Optimization: Row-Major A × Column-Major B (Tiling Primitive)
| {near: top-center}

direction: right

# ---------------------------------------------------------------------------------------
# MATRIX A: ROW-MAJOR (CONTIGUOUS READS)
# ---------------------------------------------------------------------------------------
matrix_a: "Matrix A (Row-Major Storage)" {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  
  memory_map: "Physical Memory Layout" {
    row0: "Row 0 | Offset 0x00" {
      a00: "a₀₀"; a01: "a₀₁"; a02: "a₀₂"; a03: "a₀₃"
      style.fill: "#B8D4E8"
    }
    row1: "Row 1 | Offset 0x10" {
      a10: "a₁₀"; a11: "a₁₁"; a12: "a₁₂"; a13: "a₁₃"
      style.fill: "#B8D4E8"
    }
    row2: "Row 2 | Offset 0x20" {
      a20: "a₂₀"; a21: "a₂₁"; a22: "a₂₂"; a23: "a₂₃"
      style.fill: "#B8D4E8"
    }
    
    # Visual sequence of access
    row0.a00 -> row0.a01 -> row0.a02 -> row0.a03: "SIMD Load / Contiguous" {
      style: {
        stroke: green
        stroke-width: 3
        animated: true
      }
    }
  }
  
  access_pattern: |md
    ### Row-Major Access Pattern
    - Inner loop `k` increments: `A[i][k]`
    - Memory distance: `sizeof(T)` (Contiguous)
    - ✓ **Spatial Locality: 100%**
    - 16 floats per 64B cache line fetch.
  | {
    style.fill: "#D4EDDA"
  }
}

# ---------------------------------------------------------------------------------------
# SCENARIO 1: STRIDED ACCESS (B IS ROW-MAJOR)
# ---------------------------------------------------------------------------------------
scenario_rowmajor: "Scenario 1: B is Row-Major (Naive Path)" {
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  
  b_memory: "Matrix B Memory (Row-Major)" {
    cl0: "CL 0 (0x00): [b₀₀, b₀₁, b₀₂, b₀₃]" { style.fill: "#F8D7DA" }
    cl1: "CL 1 (0x40): [b₁₀, b₁₁, b₁₂, b₁₃]" { style.fill: "#F8D7DA" }
    cl2: "CL 2 (0x80): [b₂₀, b₂₁, b₂₂, b₂₃]" { style.fill: "#F8D7DA" }
    cl3: "CL 3 (0xC0): [b₃₀, b₃₁, b₃₂, b₃₃]" { style.fill: "#F8D7DA" }
    
    # Path of column access
    cl0 -> cl1 -> cl2 -> cl3: "STRIDED ACCESS" {
      style: {
        stroke: red
        stroke-width: 5
        stroke-dash: 2
      }
    }
  }
  
  problem_desc: |md
    ### The "Strided" Penalty
    - Dot product needs **Column j**: `B[0][j], B[1][j]...`
    - Elements are `N * sizeof(T)` bytes apart.
    - **Each read triggers a Cache Miss** if N is large.
    - ✗ Cache lines fetched but 93% of data unused.
  | {
    style.fill: "#F5C6CB"
  }

  result_bad: "POOR Performance" {
    style: {
      fill: "#721C24"
      font-color: white
      bold: true
    }
    label: "Execution: 4.2 GFLOPS"
  }
}

# ---------------------------------------------------------------------------------------
# SCENARIO 2: SEQUENTIAL ACCESS (B IS COL-MAJOR)
# ---------------------------------------------------------------------------------------
scenario_colmajor: "Scenario 2: B is Col-Major (Optimized Path)" {
  style.fill: "#D4EDDA"
  style.stroke: "#155724"
  
  b_memory_opt: "Matrix B Memory (Column-Major)" {
    cl_opt: "CL 0 (0x00): [b₀₀, b₁₀, b₂₀, b₃₀]" { 
      style: {
        fill: "#28A745"
        font-color: white
        double-border: true
      }
    }
    cl_opt_1: "CL 1 (0x10): [b₀₁, b₁₁, b₂₁, b₃₁]" { style.fill: "#C3E6CB" }
    
    cl_opt -> cl_opt_1: "Linear Column Access" {
      style.stroke: green
    }
  }
  
  benefit_desc: |md
    ### The "Contiguous" Benefit
    - Dot product needs **Column j**: `B[0][j], B[1][j]...`
    - Elements are contiguous in memory.
    - ✓ **Read B[0][j]** → Fetches entire column.
    - ✓ **Read B[1][j]** → **L1 CACHE HIT**.
    - ✓ **Read B[2][j]** → **L1 CACHE HIT**.
  | {
    style.fill: "#C3E6CB"
  }

  result_good: "HIGH Performance" {
    style: {
      fill: "#155724"
      font-color: white
      bold: true
    }
    label: "Execution: 12.8 GFLOPS"
  }
}

# ---------------------------------------------------------------------------------------
# INTER-COMPONENT CONNECTIONS
# ---------------------------------------------------------------------------------------
matrix_a -> scenario_rowmajor: "Outer Loop [i]\nInner Loop [k]" {
  style.stroke: "#721C24"
}

matrix_a -> scenario_colmajor: "Outer Loop [i]\nInner Loop [k]" {
  style.stroke: "#155724"
}

# ---------------------------------------------------------------------------------------
# LEGEND & BYTE OFFSETS
# ---------------------------------------------------------------------------------------
legend: "Memory Locality Legend" {
  near: bottom-right
  
  cache_line: "Cache Line (64B)" {
    style: {
      stroke-dash: 4
      stroke: "#6c757d"
    }
  }
  
  hit_indicator: "L1 Cache Hit" {
    style: {
      fill: "#28A745"
      font-color: white
    }
  }
  
  miss_indicator: "L1 Cache Miss" {
    style: {
      fill: "#DC3545"
      font-color: white
    }
  }
}

footer: |md
  ### Implementation Note for Engineers
  - If source matrices are Row-Major, pre-transpose **Matrix B** once.
  - Cost of `O(N²)` transpose is negligible compared to `O(N³)` multiply speedup.
  - Enables SIMD vectorization (AVX-512) for inner-product kernels.
| {
  near: bottom-left
  style.stroke: orange
}