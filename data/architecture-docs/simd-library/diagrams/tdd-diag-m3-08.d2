vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # State Machine: CPU Feature Detection
  Runtime dispatch path based on CPUID query results
| {near: top-center}
direction: right
# States
UNINITIALIZED: {
  shape: circle
  style: {
    fill: "#E8E8E8"
    stroke: "#666666"
    stroke-width: 2
  }
}
CHECKING_CPUID: {
  label: "CHECKING_CPUID\n(CPUID Leaf 1)"
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}
SSE2_ONLY: {
  label: "SSE2_ONLY\n(Baseline x86-64)"
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 2
  }
}
SSE41_AVAILABLE: {
  label: "SSE41_AVAILABLE\n(Blend, floor, etc.)"
  style: {
    fill: "#B3E5FC"
    stroke: "#0288D1"
    stroke-width: 2
  }
}
AVX_AVAILABLE: {
  label: "AVX_AVAILABLE\n(YMM 256-bit)"
  style: {
    fill: "#B39DDB"
    stroke: "#512DA8"
    stroke-width: 2
  }
}
AVX2_AVAILABLE: {
  label: "AVX2_AVAILABLE\n(Integer AVX)"
  style: {
    fill: "#FFCCBC"
    stroke: "#E64A19"
    stroke-width: 2
  }
}
CACHED_RESULT: {
  label: "CACHED_RESULT\n(static cpu_features_t)"
  style: {
    fill: "#CFD8DC"
    stroke: "#455A64"
    stroke-width: 2
    stroke-dash: 3
  }
}
# Initial state marker
start: {
  shape: circle
  style: {
    fill: "#333333"
    stroke: "#333333"
  }
}
# Transitions
start -> UNINITIALIZED: "program start"
UNINITIALIZED -> CHECKING_CPUID: "first call to\nsimd_get_features()" {
  style: {
    stroke: "#333333"
    stroke-width: 2
  }
}
CHECKING_CPUID -> SSE2_ONLY: "EDX bit 26 = 1\n(SSE2 always present\non x86-64)" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
SSE2_ONLY -> SSE41_AVAILABLE: "ECX bit 19 = 1" {
  style: {
    stroke: "#0288D1"
    stroke-width: 2
  }
}
SSE41_AVAILABLE -> AVX_AVAILABLE: "ECX bit 28 = 1\n&& OSXSAVE = 1\n&& XGETBV enables YMM" {
  style: {
    stroke: "#512DA8"
    stroke-width: 2
  }
}
AVX_AVAILABLE -> AVX2_AVAILABLE: "CPUID Leaf 7\nEBX bit 5 = 1" {
  style: {
    stroke: "#E64A19"
    stroke-width: 2
  }
}
# Short-circuit paths (feature not available)
CHECKING_CPUID -> SSE2_ONLY: "EDX bit 26 = 0\n(ILLEGAL on x86-64)" {
  style: {
    stroke: "#B71C1C"
    stroke-dash: 4
  }
  label: "ILLEGAL"
}
SSE41_AVAILABLE -> CACHED_RESULT: "ECX bit 19 = 0" {
  style: {
    stroke: "#666666"
    stroke-dash: 3
  }
}
AVX_AVAILABLE -> CACHED_RESULT: "ECX bit 28 = 0\nor OS disabled" {
  style: {
    stroke: "#666666"
    stroke-dash: 3
  }
}
AVX2_AVAILABLE -> CACHED_RESULT: "EBX bit 5 = 0" {
  style: {
    stroke: "#666666"
    stroke-dash: 3
  }
}
# Final cached state
SSE2_ONLY -> CACHED_RESULT: "cache result" {
  style: {
    stroke: "#455A64"
    stroke-dash: 3
  }
}
# Self-loop for cached state
CACHED_RESULT -> CACHED_RESULT: "subsequent calls\nreturn cached value" {
  style: {
    stroke: "#455A64"
    stroke-width: 2
  }
}
# Legend
legend: {
  near: bottom-right
  label: |md
    **Transition Types:**
    - **Solid**: Feature detected, continue
    - **Dashed**: Feature absent, cache and return
    - **Red dashed**: Should never occur on x86-64
  |
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
  }
}
# Invariant note
invariant: {
  near: bottom-left
  label: |md
    **Invariant:**
    Once CACHED_RESULT is reached,
    all subsequent calls return the
    same `cpu_features_t*` pointer.
  |
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
  }
}