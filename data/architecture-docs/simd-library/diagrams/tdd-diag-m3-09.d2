vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Sequence Diagram - Runtime Dispatch {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
shape: sequence_diagram
Caller
Dispatcher
Cache: "Feature Cache\n(null initially)"
CPUID: "CPUID\nDetection"
Impl_SSE: "SSE\nImplementation"
Impl_AVX: "AVX\nImplementation"
First_Call: "First Call" {
  Caller -> Dispatcher.t1: simd_dot_product(a, b, n)
  Dispatcher.t1 -> Cache.t1: get_cached_features()
  Cache.t1 --> Dispatcher.t1: NULL
  Dispatcher.t1 -> CPUID.t1: detect_cpu_features()
  CPUID.t1 -> CPUID.t1: __get_cpuid(1, ...)
  CPUID.t1 -> CPUID.t1: check AVX, FMA bits
  CPUID.t1 --> Dispatcher.t1: has_avx=true, has_fma=true
  Dispatcher.t1 -> Cache.t2: cache_features(result)
  Cache.t2 --> Dispatcher.t2: cached
  Dispatcher.t1 -> Dispatcher.t1: select_implementation()
  Dispatcher.t1 -> Impl_AVX.t1: dot_product_avx(a, b, n)
  Impl_AVX.t1 --> Dispatcher.t1: float result
  Dispatcher.t1 --> Caller.t1: return result
}
Subsequent_Calls: "Subsequent Calls" {
  Caller.t2 -> Dispatcher.t3: simd_dot_product(a, b, n)
  Dispatcher.t3 -> Cache.t3: get_cached_features()
  Cache.t3 --> Dispatcher.t3: has_avx=true (cached)
  Dispatcher.t3 -> Impl_AVX.t2: dot_product_avx(a, b, n)
  Impl_AVX.t2 --> Dispatcher.t3: float result
  Dispatcher.t3 --> Caller.t2: return result
  Caller.t3 -> Dispatcher.t4: simd_dot_product(a, b, n)
  Dispatcher.t4 -> Cache.t4: get_cached_features()
  Cache.t4 --> Dispatcher.t4: has_avx=true (cached)
  Dispatcher.t4 -> Impl_AVX.t3: dot_product_avx(a, b, n)
  Impl_AVX.t3 --> Dispatcher.t4: float result
  Dispatcher.t4 --> Caller.t3: return result
}
Cache.style.fill: "#E8F4E8"
Cache.style.stroke: "#4CAF50"
CPUID.style.fill: "#FFF3E0"
CPUID.style.stroke: "#FF9800"
Impl_SSE.style.fill: "#E3F2FD"
Impl_SSE.style.stroke: "#2196F3"
Impl_AVX.style.fill: "#F3E5F5"
Impl_AVX.style.stroke: "#9C27B0"
Dispatcher.style.fill: "#FFF8E1"
Dispatcher.style.stroke: "#FFC107"