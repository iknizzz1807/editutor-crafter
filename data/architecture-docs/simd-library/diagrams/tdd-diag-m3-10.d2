vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Algorithm Steps: Matrix Transpose 4x4
  SSE2 In-Place Transpose using `_mm_unpacklo_ps` and `_mm_unpackhi_ps`
| {near: top-center}
direction: right
# ============================================
# BEFORE STATE: Original Matrix (Row-Major)
# ============================================
before: {
  label: "BEFORE\nRow-Major Layout"
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  row0: {
    shape: sql_table
    label: "Row 0"
    r0c0: float {label: "m[0]"}
    r0c1: float {label: "m[1]"}
    r0c2: float {label: "m[2]"}
    r0c3: float {label: "m[3]"}
  }
  row1: {
    shape: sql_table
    label: "Row 1"
    r1c0: float {label: "m[4]"}
    r1c1: float {label: "m[5]"}
    r1c2: float {label: "m[6]"}
    r1c3: float {label: "m[7]"}
  }
  row2: {
    shape: sql_table
    label: "Row 2"
    r2c0: float {label: "m[8]"}
    r2c1: float {label: "m[9]"}
    r2c2: float {label: "m[10]"}
    r2c3: float {label: "m[11]"}
  }
  row3: {
    shape: sql_table
    label: "Row 3"
    r3c0: float {label: "m[12]"}
    r3c1: float {label: "m[13]"}
    r3c2: float {label: "m[14]"}
    r3c3: float {label: "m[15]"}
  }
}
# ============================================
# STEP 1: Load and unpacklo rows 0,1
# ============================================
step1: {
  label: "STEP 1\nunpacklo(row0, row1)"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  load01: |md
    c
    row0 = _mm_loadu_ps(m + 0)
    row1 = _mm_loadu_ps(m + 4)
    
  |
  unpack01: |md
    c
    tmp0 = _mm_unpacklo_ps(row0, row1)
    // [r0[0], r1[0], r0[1], r1[1]]
    
  |
  result1: {
    shape: sql_table
    label: "tmp0"
    t0: float {label: "m[0]"}
    t1: float {label: "m[4]"}
    t2: float {label: "m[1]"}
    t3: float {label: "m[5]"}
  }
  result1.style.fill: "#FFE0B2"
}
# ============================================
# STEP 2: unpackhi rows 0,1
# ============================================
step2: {
  label: "STEP 2\nunpackhi(row0, row1)"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  unpack01hi: |md
    c
    tmp1 = _mm_unpackhi_ps(row0, row1)
    // [r0[2], r1[2], r0[3], r1[3]]
    
  |
  result2: {
    shape: sql_table
    label: "tmp1"
    t0: float {label: "m[2]"}
    t1: float {label: "m[6]"}
    t2: float {label: "m[3]"}
    t3: float {label: "m[7]"}
  }
  result2.style.fill: "#FFE0B2"
}
# ============================================
# STEP 3: unpacklo/hi rows 2,3
# ============================================
step3: {
  label: "STEP 3\nProcess Rows 2,3"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  load23: |md
    c
    row2 = _mm_loadu_ps(m + 8)
    row3 = _mm_loadu_ps(m + 12)
    tmp2 = _mm_unpacklo_ps(row2, row3)
    tmp3 = _mm_unpackhi_ps(row2, row3)
    
  |
  result3a: {
    shape: sql_table
    label: "tmp2"
    t0: float {label: "m[8]"}
    t1: float {label: "m[12]"}
    t2: float {label: "m[9]"}
    t3: float {label: "m[13]"}
  }
  result3a.style.fill: "#C8E6C9"
  result3b: {
    shape: sql_table
    label: "tmp3"
    t0: float {label: "m[10]"}
    t1: float {label: "m[14]"}
    t2: float {label: "m[11]"}
    t3: float {label: "m[15]"}
  }
  result3b.style.fill: "#C8E6C9"
}
# ============================================
# STEP 4: Final combine for columns
# ============================================
step4: {
  label: "STEP 4\nFinal Column Combine"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  combine: |md
    c
    col0 = _mm_unpacklo_ps(tmp0, tmp2)
    col1 = _mm_unpackhi_ps(tmp0, tmp2)
    col2 = _mm_unpacklo_ps(tmp1, tmp3)
    col3 = _mm_unpackhi_ps(tmp1, tmp3)
    
  |
  col0: {
    shape: sql_table
    label: "Col 0"
    c0: float {label: "m[0]"}
    c1: float {label: "m[4]"}
    c2: float {label: "m[8]"}
    c3: float {label: "m[12]"}
  }
  col0.style.fill: "#E1BEE7"
  col1: {
    shape: sql_table
    label: "Col 1"
    c0: float {label: "m[1]"}
    c1: float {label: "m[5]"}
    c2: float {label: "m[9]"}
    c3: float {label: "m[13]"}
  }
  col1.style.fill: "#E1BEE7"
  col2: {
    shape: sql_table
    label: "Col 2"
    c0: float {label: "m[2]"}
    c1: float {label: "m[6]"}
    c2: float {label: "m[10]"}
    c3: float {label: "m[14]"}
  }
  col2.style.fill: "#E1BEE7"
  col3: {
    shape: sql_table
    label: "Col 3"
    c0: float {label: "m[3]"}
    c1: float {label: "m[7]"}
    c2: float {label: "m[11]"}
    c3: float {label: "m[15]"}
  }
  col3.style.fill: "#E1BEE7"
}
# ============================================
# AFTER STATE: Transposed Matrix (Column-Major)
# ============================================
after: {
  label: "AFTER\nColumn-Major Layout"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  store: |md
    c
    _mm_storeu_ps(m + 0,  col0)
    _mm_storeu_ps(m + 4,  col1)
    _mm_storeu_ps(m + 8,  col2)
    _mm_storeu_ps(m + 12, col3)
    
  |
  final0: {
    shape: sql_table
    label: "Col 0 (m[0-3])"
    f0: float {label: "m[0]"}
    f1: float {label: "m[4]"}
    f2: float {label: "m[8]"}
    f3: float {label: "m[12]"}
  }
  final0.style.fill: "#BBDEFB"
  final1: {
    shape: sql_table
    label: "Col 1 (m[4-7])"
    f0: float {label: "m[1]"}
    f1: float {label: "m[5]"}
    f2: float {label: "m[9]"}
    f3: float {label: "m[13]"}
  }
  final1.style.fill: "#BBDEFB"
  final2: {
    shape: sql_table
    label: "Col 2 (m[8-11])"
    f0: float {label: "m[2]"}
    f1: float {label: "m[6]"}
    f2: float {label: "m[10]"}
    f3: float {label: "m[14]"}
  }
  final2.style.fill: "#BBDEFB"
  final3: {
    shape: sql_table
    label: "Col 3 (m[12-15])"
    f0: float {label: "m[3]"}
    f1: float {label: "m[7]"}
    f2: float {label: "m[11]"}
    f3: float {label: "m[15]"}
  }
  final3.style.fill: "#BBDEFB"
}
# ============================================
# Flow connections
# ============================================
before -> step1: "Load rows\n0,1" {
  style.stroke: "#2E86AB"
  style.stroke-width: 2
}
step1 -> step2: "tmp0 ready" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
}
step2 -> step3: "tmp1 ready\nLoad rows 2,3" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
step3 -> step4: "tmp2, tmp3 ready" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
step4 -> after: "Store\ncolumns" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
# ============================================
# Legend
# ============================================
legend: {
  near: bottom-center
  style.fill: "transparent"
  note: |md
    **`_mm_unpacklo_ps(a, b)`**: Interleaves lower halves → `[a0, b0, a1, b1]`  
    **`_mm_unpackhi_ps(a, b)`**: Interleaves upper halves → `[a2, b2, a3, b3]`
    **Memory layout change**: Row index `i*4+j` becomes column index `j*4+i`
  |
}