layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: ||md
    # Benchmark Results Template: Scalar vs SSE vs AVX
    ### Comparative Throughput Analysis Across Vector Widths
    *Hardware: Intel Core i9-9900K @ 2.4GHz Fixed | Memory: DDR4-3200 CL16*
  ||
  near: top-center
  shape: rectangle
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 18
  }
}

# Container for performance grid
simd_performance_grid: {
  grid-columns: 7
  grid-gap: 15
  style.stroke: "#DDDDDD"
  style.fill: "#FFFFFF"
  style.shadow: true

  # --- HEADER ROW (Byte Widths / Problem Size) ---
  h_0: { 
    label: "Vector Size (n)"
    style: {
      fill: transparent
      stroke: transparent
      bold: true
    }
  }
  h_1: { 
    label: |md
      **n = 4**
      *(16B - Single SSE)*
    |
    style: { fill: "#E8E8E8"; stroke: "#CCCCCC" }
  }
  h_2: { 
    label: |md
      **n = 16**
      *(64B - 1 Cache Line)*
    |
    style: { fill: "#E8E8E8"; stroke: "#CCCCCC" }
  }
  h_3: { 
    label: |md
      **n = 64**
      *(256B - 4 Lines)*
    |
    style: { fill: "#E8E8E8"; stroke: "#CCCCCC" }
  }
  h_4: { 
    label: |md
      **n = 256**
      *(1KB)*
    |
    style: { fill: "#E8E8E8"; stroke: "#CCCCCC" }
  }
  h_5: { 
    label: |md
      **n = 1024**
      *(4KB - 1 Page)*
    |
    style: { fill: "#E8E8E8"; stroke: "#CCCCCC" }
  }
  h_6: { 
    label: |md
      **n = 4096**
      *(16KB - L1 Limit)*
    |
    style: { fill: "#E8E8E8"; stroke: "#CCCCCC" }
  }

  # --- SCALAR ROW ---
  r1_L: { 
    label: |md
      **Scalar Path**
      *(x86_64 ALU)*
    |
    style: { fill: "#F5F5F5"; stroke: "#CCCCCC"; bold: true }
  }
  
  s_4: { label: "1.00×\n~15.2ns"; style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white } }
  s_16: { label: "1.00×\n~48.5ns"; style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white } }
  s_64: { label: "1.00×\n~182.1ns"; style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white } }
  s_256: { label: "1.00×\n~712.4ns"; style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white } }
  s_1024: { label: "1.00×\n~2.81μs"; style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white } }
  s_4096: { label: "1.00×\n~11.24μs"; style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white } }

  # --- SSE ROW (128-bit) ---
  r2_L: { 
    label: |md
      **SSE Path**
      *(XMM / 128-bit)*
    |
    style: { fill: "#F5F5F5"; stroke: "#CCCCCC"; bold: true }
  }
  
  sse_4: { label: "1.25×\n~12.1ns"; style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white; multiple: true } }
  sse_16: { label: "2.81×\n~17.2ns"; style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white; multiple: true } }
  sse_64: { label: "4.02×\n~45.3ns"; style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white; multiple: true } }
  sse_256: { label: "4.71×\n~151.2ns"; style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white; multiple: true } }
  sse_1024: { label: "5.10×\n~551.4ns"; style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white; multiple: true } }
  sse_4096: { label: "5.21×\n~2.15μs"; style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white; multiple: true } }

  # --- AVX ROW (256-bit) ---
  r3_L: { 
    label: |md
      **AVX-256 Path**
      *(YMM / 256-bit)*
    |
    style: { fill: "#F5F5F5"; stroke: "#CCCCCC"; bold: true }
  }
  
  avx_4: { label: "0.83×\n~18.3ns"; style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333"; multiple: true } }
  avx_16: { label: "2.45×\n~19.8ns"; style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333"; multiple: true } }
  avx_64: { label: "6.01×\n~30.2ns"; style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333"; multiple: true } }
  avx_256: { label: "8.85×\n~80.5ns"; style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333"; multiple: true } }
  avx_1024: { label: "10.03×\n~280.1ns"; style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333"; multiple: true } }
  avx_4096: { label: "10.15×\n~1.11μs"; style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333"; multiple: true } }
}

warning_box: {
  label: |md
    ⚠️ **SIMD Warm-up / Setup Overhead**
    For small **n (< 16)**, AVX latency is dominated by:
    - `VZEROUPPER` transition penalties (AVX-SSE bridge)
    - 256-bit register powering state transitions
    - Memory alignment prologue (PEEL loop for 32B boundaries)
  |
  shape: rectangle
  style: {
    fill: "#FFF3CD"
    stroke: "#FFCC00"
    stroke-dash: 2
    font-color: "#856404"
  }
}

plateau_box: {
  label: |md
    📊 **Asymptotic Memory Bound**
    At **n ≥ 4096**, performance gains decouple from 
    instruction width. Both paths converge on 
    **DDR4 Peak Bandwidth Limit** (~25.6 GB/s).
    Optimization required: *Software Prefetching / Cache Tiling*.
  |
  shape: rectangle
  style: {
    fill: "#D4EDDA"
    stroke: "#28A745"
    stroke-dash: 2
    font-color: "#155724"
  }
}

annotations: {
  near: bottom-center
  
  notes: {
    label: |md
      ### Engineering Implementation Notes
      **1. Crossover Dynamics:**
      - At $n=4$: Scalar and SSE are comparable due to loop overhead.
      - At $n=64$: AVX's 8-wide throughput overcomes setup costs.
      
      **2. Instruction Efficiency:**
      - SSE Speedup > 4.0x: Achieved via aggressive loop unrolling (4x2) and dual-port FMA execution.
      - AVX Speedup > 8.0x: Theoretical peak reached through ILP and reduced instruction count per cache line.
    |
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#DDDDDD"
      stroke-dash: 3
    }
  }
  
  legend: {
    direction: right
    scalar_legend: {
      label: "Scalar (Baseline)"
      style: { fill: "#FF6B6B"; stroke: "#CC5555"; font-color: white }
    }
    sse_legend: {
      label: "SSE (128-bit)"
      style: { fill: "#4ECDC4"; stroke: "#3BA39C"; font-color: white }
    }
    avx_legend: {
      label: "AVX (256-bit)"
      style: { fill: "#95E1D3"; stroke: "#77B4A9"; font-color: "#333333" }
    }
  }
}

methodology: {
  label: |md
    **Validation Parameters**
    - **Tool:** Google Benchmark / Criterion.rs
    - **Cold Cache:** No (Data hot in L1/L2)
    - **Compiler:** `gcc-12 -O3 -march=haswell`
    - **Iterations:** 1,000,000 per sample
    - **Stat:** Median (MAD < 1.5%)
  |
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#E2E3E5"
    stroke: "#6C757D"
    font-color: "#383D41"
  }
}