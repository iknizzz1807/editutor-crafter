layout-engine: elk
theme-id: 4

direction: right

title: |'md
  ### SIMD Register Architecture: XMM Vector Lane & Memory Mapping
  **Target:** SSE2/SSE4.1 Instruction Set Architecture (ISA)
'| {
  near: top-center
  shape: text
}

vars: {
  colors: {
    header: "#6B5B95"
    lane0: "#4A90D9"
    lane1: "#5BA3E0"
    lane2: "#6CB6E7"
    lane3: "#7DC9EE"
    register_bg: "#F8F9FA"
    padding: "#E2E8F0"
    label: "#1E293B"
    mem_fill: "#F1F5F9"
  }
}

classes: {
  lane_base: {
    style: {
      stroke: "#475569"
      stroke-width: 2
      border-radius: 2
    }
  }
  register_frame: {
    style: {
      stroke: "#0F172A"
      stroke-width: 4
      fill: "${colors.register_bg}"
      shadow: true
    }
  }
  bit_label: {
    style: {
      font-size: 10
      font: mono
      font-color: "#64748B"
    }
  }
  sub_text: {
    style: {
      font-size: 12
      font-color: "#475569"
      italic: true
    }
  }
}

# --- REGISTER COMPONENT ---
xmm_register: {
  class: register_frame
  label: "XMM Register (128-bit)" {
    style.bold: true
    style.font-size: 18
  }
  
  lanes: {
    grid-columns: 4
    grid-gap: 10
    
    # MSB Lane
    lane3: {
      class: lane_base
      style.fill: "${colors.lane3}"
      bits: "bits [127:96]" { class: bit_label }
      content: "Lane 3 (Float32)" { style.bold: true }
      offset: "Offset +12" { class: sub_text }
    }
    
    lane2: {
      class: lane_base
      style.fill: "${colors.lane2}"
      bits: "bits [95:64]" { class: bit_label }
      content: "Lane 2 (Float32)" { style.bold: true }
      offset: "Offset +8" { class: sub_text }
    }
    
    lane1: {
      class: lane_base
      style.fill: "${colors.lane1}"
      bits: "bits [63:32]" { class: bit_label }
      content: "Lane 1 (Float32)" { style.bold: true }
      offset: "Offset +4" { class: sub_text }
    }
    
    # LSB Lane
    lane0: {
      class: lane_base
      style.fill: "${colors.lane0}"
      bits: "bits [31:0]" { class: bit_label }
      content: "Lane 0 (Float32)" { style.bold: true }
      offset: "Offset +0" { class: sub_text }
    }
  }
}

# --- DOCUMENTATION BLOCK ---
annotations: {
  near: bottom-center
  type_table: |'md
    | Intrinsic Type | Elements | Lane Partitioning | Bit Width |
    | :--- | :--- | :--- | :--- |
    | `__m128i` | 16 | `uint8_t` | 8-bit |
    | `__m128i` | 8 | `uint16_t` | 16-bit |
    | `__m128i` | 4 | `uint32_t` | 32-bit |
    | `__m128` | 4 | `float` (single) | 32-bit |
    | `__m128d` | 2 | `double` (double) | 64-bit |
  '| {
    shape: text
    style.font-size: 14
  }
}

# --- MEMORY LAYOUT COMPONENT ---
memory_layout: {
  near: center-right
  label: "System Memory (Little-Endian)" {
    style.bold: true
  }
  
  stack: {
    grid-rows: 4
    grid-gap: 0
    
    m3: "0x0C: Byte 12..15" { style.fill: "${colors.lane3}"; class: lane_base }
    m2: "0x08: Byte 8..11" { style.fill: "${colors.lane2}"; class: lane_base }
    m1: "0x04: Byte 4..7" { style.fill: "${colors.lane1}"; class: lane_base }
    m0: "0x00: Byte 0..3" { style.fill: "${colors.lane0}"; class: lane_base }
  }
  
  # Base address label as a sibling to the stack inside the container
  base_addr: "Base Address (16-byte aligned)" {
    class: sub_text
  }
}

# --- MAPPING CONNECTION ---
# Pointing from the register lanes container to the memory stack container
xmm_register.lanes -> memory_layout.stack: "_mm_store_ps / _mm_store_si128" {
  style: {
    stroke: "#334155"
    stroke-width: 2
    stroke-dash: 5
    animated: true
  }
}

# --- IMPLEMENTATION HINT ---
footer: |'md
  **Implementation Note:** 
  For `__m128` (float), memory must be 16-byte aligned unless using `_mm_loadu_ps` (unaligned).
  The little-endian mapping ensures Lane 0 corresponds to the lowest memory address.
'| {
  near: bottom-left
  shape: text
  style.font-size: 12
}