vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # State Machine: Vectorization Report States
  Compiler analysis progression for loop vectorization decisions
| {near: top-center}

# States
NOT_ANALYZED: {
  shape: circle
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.stroke-width: 2
}

ANALYZING: {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
  label: "ANALYZING\n(Compiler Analysis)"
}

VECTORIZED: {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  label: |md
    **VECTORIZED**
    ✓ SIMD Code Generated
    - Vectorization width determined
    - SIMD instructions emitted
    - Loop transformed
  |
}

NOT_VECTORIZED_ALIASING: {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 2
  label: |md
    **NOT_VECTORIZED**
    (Pointer Aliasing)
    - Cannot prove pointers distinct
    - Possible data dependency
    - Fix: Use `restrict` keyword
  |
}

NOT_VECTORIZED_DEPENDENCY: {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 2
  label: |md
    **NOT_VECTORIZED**
    (Data Dependency)
    - Loop-carried dependency
    - Iteration i depends on i-1
    - Example: `sum += a[i]`
  |
}

NOT_VECTORIZED_COST: {
  shape: rectangle
  style.fill: "#FFE0B2"
  style.stroke: "#EF6C00"
  style.stroke-width: 2
  label: |md
    **NOT_VECTORIZED**
    (Cost Model)
    - Vectorization overhead > benefit
    - Loop too small
    - Not profitable
  |
}

NOT_VECTORIZED_CONTROL_FLOW: {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 2
  label: |md
    **NOT_VECTORIZED**
    (Control Flow)
    - Complex branching
    - Early exits (break/return)
    - Function calls in loop
  |
}

# Initial state indicator
initial: {
  shape: circle
  style.fill: "#333333"
  width: 20
  height: 20
}

initial -> NOT_ANALYZED: "Loop Entry"

# Main flow
NOT_ANALYZED -> ANALYZING: "Begin\nCompiler\nAnalysis"

# Analysis transitions
ANALYZING -> VECTORIZED: "✓ All checks\npass" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}

ANALYZING -> NOT_VECTORIZED_ALIASING: "✗ Pointer\naliasing\ndetected" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}

ANALYZING -> NOT_VECTORIZED_DEPENDENCY: "✗ Loop-carried\ndependency" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}

ANALYZING -> NOT_VECTORIZED_COST: "✗ Cost model\nsays no" {
  style.stroke: "#EF6C00"
  style.stroke-dash: 3
}

ANALYZING -> NOT_VECTORIZED_CONTROL_FLOW: "✗ Complex\ncontrol flow" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}

# Recovery transitions
NOT_VECTORIZED_ALIASING -> ANALYZING: "Add `restrict`\nkeyword" {
  style.stroke: "#1976D2"
  style.stroke-dash: 5
  style.animated: true
}

NOT_VECTORIZED_DEPENDENCY -> ANALYZING: "Restructure\nloop or use\n-ffast-math*" {
  style.stroke: "#1976D2"
  style.stroke-dash: 5
  style.animated: true
}

# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  
  success: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: "Success State"
  }
  failure: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: "Failure State"
  }
  warning: {
    shape: rectangle
    style.fill: "#FFE0B2"
    label: "Warning State"
  }
  recovery: {
    shape: rectangle
    style.fill: "#E3F2FD"
    label: "Recovery Path\n(dashed)"
  }
  
  success -> failure -> warning -> recovery: {style.opacity: 0}
}

# Annotation
annotation: |md
  **Key Insight:** The compiler must *prove* vectorization is safe.
  When it cannot, the loop falls back to scalar execution.
  * -ffast-math allows FP reassociation but changes semantics
| {near: bottom-left}