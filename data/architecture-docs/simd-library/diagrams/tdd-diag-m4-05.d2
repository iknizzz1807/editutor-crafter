vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
Benchmark_Runner: "Benchmark Runner" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  setup: "Setup" {
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
  freq_pinner: "CPU Frequency\nPinner" {
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
  }
  timer: "High-Resolution\nTimer" {
    style.fill: "#B3E5FC"
    style.stroke: "#0277BD"
  }
  stats: "Statistics\nCalculator" {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  validator: "CV Validator" {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  reporter: "Results\nReporter" {
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
}
shape: sequence_diagram
Benchmark_Runner.setup
Benchmark_Runner.freq_pinner
Benchmark_Runner.timer
Benchmark_Runner.stats
Benchmark_Runner.validator
Benchmark_Runner.reporter
initialization: {
  Benchmark_Runner.setup -> Benchmark_Runner.freq_pinner: "1. pin_cpu_frequency(governor=performance)"
  Benchmark_Runner.freq_pinner -> Benchmark_Runner.setup: "2. success/failure status"
  Benchmark_Runner.setup -> Benchmark_Runner.setup: "3. allocate aligned buffers\n   initialize test data"
}
warmup_phase: {
  Benchmark_Runner.setup -> Benchmark_Runner.timer: "4. start warmup (3 iterations)"
  Benchmark_Runner.timer.t1 -> Benchmark_Runner.setup: "5. call function_under_test()"
  Benchmark_Runner.setup -> Benchmark_Runner.timer.t1: "6. complete (untimed)"
  Benchmark_Runner.timer.t1 -> Benchmark_Runner.setup: "7. call function_under_test()"
  Benchmark_Runner.setup -> Benchmark_Runner.timer.t1: "8. complete (untimed)"
  Benchmark_Runner.timer.t1 -> Benchmark_Runner.setup: "9. call function_under_test()"
  Benchmark_Runner.setup -> Benchmark_Runner.timer.t1: "10. complete (untimed)"
  Benchmark_Runner.timer.t1 -> Benchmark_Runner.setup: "11. warmup complete\n    caches populated"
}
timed_phase: {
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.setup: "12. start timed loop (10-15 iterations)"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.setup: "13. call function_under_test()"
  Benchmark_Runner.setup -> Benchmark_Runner.timer.t2: "14. return result"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.timer.t2: "15. record time_ns[0]"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.setup: "16. call function_under_test()"
  Benchmark_Runner.setup -> Benchmark_Runner.timer.t2: "17. return result"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.timer.t2: "18. record time_ns[1]"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.setup: "19. ... repeat for N runs ..."
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.setup: "20. call function_under_test()"
  Benchmark_Runner.setup -> Benchmark_Runner.timer.t2: "21. return result"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.timer.t2: "22. record time_ns[N-1]"
  Benchmark_Runner.timer.t2 -> Benchmark_Runner.stats: "23. times_ns[] array"
}
statistics_phase: {
  Benchmark_Runner.stats -> Benchmark_Runner.stats: "24. sort(times_ns)"
  Benchmark_Runner.stats -> Benchmark_Runner.stats: "25. median = times[n/2]"
  Benchmark_Runner.stats -> Benchmark_Runner.stats: "26. mean = sum(times) / n"
  Benchmark_Runner.stats -> Benchmark_Runner.stats: "27. variance = Σ(time-mean)² / n"
  Benchmark_Runner.stats -> Benchmark_Runner.stats: "28. stddev = √variance"
  Benchmark_Runner.stats -> Benchmark_Runner.stats: "29. CV% = (stddev/median) × 100"
  Benchmark_Runner.stats -> Benchmark_Runner.validator: "30. {median, mean, stddev, CV%}"
}
validation_phase: {
  Benchmark_Runner.validator -> Benchmark_Runner.validator: "31. check: CV < 2.0%?"
  Benchmark_Runner.validator.yes -> Benchmark_Runner.reporter: "32a. VALID: proceed to report"
  Benchmark_Runner.validator.no -> Benchmark_Runner.reporter: "32b. WARNING: high variance\n    recommend: more runs,\n    larger input, or\n    frequency check"
}
reporting_phase: {
  Benchmark_Runner.reporter -> Benchmark_Runner.reporter: "33. format results table"
  Benchmark_Runner.reporter -> Benchmark_Runner.reporter: "34. compute speedup ratios"
  Benchmark_Runner.reporter -> Benchmark_Runner.reporter: "35. write CSV file"
}
legend: |md
  ## Benchmark Methodology
  **Constants:**
  - `WARMUP_RUNS = 3`
  - `TIMED_RUNS = 10-15`
  - `CV_WARNING_THRESHOLD = 2.0%`
  - `CV_REJECT_THRESHOLD = 10.0%`
  **Timer:** `clock_gettime(CLOCK_MONOTONIC_RAW)`
  **Statistics:**
  - Median (robust to outliers)
  - Standard deviation
  - Coefficient of Variation (CV%)
  **Quality Gate:** CV < 2% required
| {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.stroke-dash: 3
}