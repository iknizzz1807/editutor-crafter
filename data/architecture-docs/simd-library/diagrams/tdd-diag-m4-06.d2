vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Layout: Pointer Aliasing Scenarios
  Compiler must analyze these cases to determine vectorization safety
| {near: top-center}
direction: right
scenario_1: {
  label: "Scenario 1: No Aliasing\n(SAFE for vectorization)"
  src_array: {
    shape: rectangle
    label: "src[0..n-1]"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  dst_array: {
    shape: rectangle
    label: "dst[0..n-1]"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  arrow: src_array -> dst_array: "copy\n(parallel)" {
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }
  status1: |md
    ✓ **SAFE**
    - Separate memory regions
    - No read-after-write hazard
    - Compiler can vectorize with `restrict`
  | {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    shape: rectangle
  }
}
scenario_2: {
  label: "Scenario 2: Partial Overlap\n(UNSAFE for forward copy)"
  src_partial: {
    shape: rectangle
    label: "src[0..n-1]"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  overlap_zone: {
    shape: rectangle
    label: "OVERLAP ZONE\nsrc[i] == dst[i-1]"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-dash: 3
  }
  dst_partial: {
    shape: rectangle
    label: "dst[0..n-1]\n(dst = src + 1)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  src_partial -> overlap_zone
  overlap_zone -> dst_partial
  status2: |md
    ✗ **UNSAFE** for forward copy
    - dst[0] overwrites src[1]
    - Then src[1] read gives wrong value
    - Must use memmove (copy backward)
    - Example: `dst = src + 1`
  | {
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    shape: rectangle
  }
}
scenario_3: {
  label: "Scenario 3: Full Overlap\n(In-place operation)"
  single_array: {
    shape: rectangle
    label: "data[0..n-1]\n(same array)"
    style.fill: "#E1F5FE"
    style.stroke: "#03A9F4"
  }
  self_ref: single_array -> single_array: "read & write\nsame location" {
    style.stroke: "#03A9F4"
    style.stroke-dash: 5
  }
  status3: |md
    ✓ **SAFE** (element-wise)
    - dst[i] = f(src[i])
    - No cross-element dependency
    - Each element independent
    - Example: `for(i) a[i] *= 2`
  | {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    shape: rectangle
  }
}
scenario_4: {
  label: "Scenario 4: Exact Same Pointer\n(Aliased pointers)"
  ptr_box: {
    shape: rectangle
    label: "ptr → [data[0..n-1]]"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }
  alias_label: |md
    `float* dst = src;`
    `dst[i] = src[i];`
  | {
    shape: text
    style.font: mono
  }
  status4: |md
    ✓ **SAFE** (identity copy)
    - No actual data movement
    - Compiler may optimize away
    - BUT: hard to prove without `restrict`
    - Aliasing analysis needed
  | {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    shape: rectangle
  }
}
legend: {
  near: bottom-center
  key_safe: "✓ Green = Safe for SIMD" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  key_unsafe: "✗ Red = Unsafe / Requires memmove" {
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
  }
  key_warn: "⚠ Orange = Requires analysis" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
analysis: |md
  ## Compiler Aliasing Analysis
  **Without `restrict`:** Compiler assumes worst case (any overlap possible)
  c
  void copy(float* dst, float* src, size_t n) {
      for (size_t i = 0; i < n; i++)
          dst[i] = src[i];  // May NOT vectorize!
  }
  
  **With `restrict`:** Compiler trusts no aliasing
  c
  void copy(float* restrict dst, 
            const float* restrict src, size_t n) {
      for (size_t i = 0; i < n; i++)
          dst[i] = src[i];  // WILL vectorize!
  }
  
  **The `restrict` promise:** "This pointer does not alias any other pointer in this scope"
| {near: bottom-center}