vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # -ffast-math: Performance vs Correctness Trade-offs
| {near: top-center}
direction: right
source_loop: |md
  c
  float sum = 0.0f;
  for (i = 0; i < n; i++) {
    sum += a[i] * b[i];  // FP reduction
  }
  
| {
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
    border-radius: 8
  }
}
decision: Compiler Analysis {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
}
without_fastmath: WITHOUT -ffast-math {
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
    stroke-width: 2
    border-radius: 8
  }
  status: NOT VECTORIZED {
    style: {
      fill: "#FFCDD2"
      bold: true
      font-color: "#C62828"
    }
  }
  semantics: |md
    **Semantics: PRESERVED**
    IEEE 754 associativity honored:
    
    (a + b) + c ≠ a + (b + c)
    
    Sequential accumulation enforced.
  | {
    style.fill: "#FFCDD2"
  }
}
with_fastmath: WITH -ffast-math {
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }
  status: VECTORIZED {
    style: {
      fill: "#C8E6C9"
      bold: true
      font-color: "#2E7D32"
    }
  }
  semantics: |md
    **Semantics: CHANGED**
    Associativity assumed:
    
    (a + b) + c ≈ a + (b + c)
    
    Parallel reduction enabled.
  | {
    style.fill: "#C8E6C9"
  }
}
source_loop -> decision: "FP reduction\nloop"
decision -> without_fastmath: "Strict IEEE 754"
decision -> with_fastmath: "Allow reassociation"
associativity_box: Associativity Assumption {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
    border-radius: 8
  }
  example: |md
    **Example where order matters:**
    `a = 1e30, b = 1.0, c = -1e30`
    Sequential:
    
    (1e30 + 1.0) + (-1e30) = 1e30 + (-1e30) = 0.0
    
    Reassociated (SIMD):
    
    1e30 + (1.0 + (-1e30)) = 1e30 + 0.0 = 1e30
    
    **Result differs by 1e30!**
  | {
    style.fill: "#F3E5F5"
  }
}
with_fastmath -> associativity_box: "Enables"
warning_box: |md
  **⚠️ Use -ffast-math only when:**
  - Game graphics (visual approximations OK)
  - Machine learning (model robust to FP variation)
  - Signal processing (small errors acceptable)
  **❌ AVOID for:**
  - Scientific computing
  - Financial calculations
  - Any domain requiring bit-exact reproducibility
| {
  near: bottom-center
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 2
    border-radius: 8
  }
}
legend: Legend {
  style.fill: transparent
  style.stroke: "#9E9E9E"
  preserved: Semantics Preserved {
    style.fill: "#FFCDD2"
  }
  changed: Semantics Changed {
    style.fill: "#C8E6C9"
  }
  preserved -- changed: {
    style.stroke-dash: 3
  }
}
legend.near: bottom-right