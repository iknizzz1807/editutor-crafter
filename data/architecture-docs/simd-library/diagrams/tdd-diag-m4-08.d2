vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Algorithm Steps: Assembly Annotation Process
| {near: top-center}

direction: right

classes: {
  before_state: {
    style: {
      fill: "#FFF9C4"
      stroke: "#F57F17"
      stroke-width: 2
    }
  }
  after_state: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  step_box: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 8
    }
  }
  arrow_style: {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
      animated: true
    }
  }
  code_block_style: {
    style: {
      fill: "#263238"
      font-color: "#ECEFF1"
      font: mono
      font-size: 11
    }
  }
}

before: "Before:\nRaw Assembly" {
  class: before_state
  
  raw_asm: {
    shape: rectangle
    class: code_block_style
    label: |md
      1189:   48 8b 45 f0    mov    rax,QWORD PTR [rbp-0x10]
      118d:   48 8b 55 f8    mov    rdx,QWORD PTR [rbp-0x8]
      1191:   48 8d 4a 10    lea    rcx,[rdx+0x10]
      1195:   c5 fc 10 00    vmovups ymm0,[rax]
      1199:   c5 fc 10 4a 20 vmovups ymm1,[rdx+0x20]
      119e:   c5 f4 58 c1    vaddps ymm0,ymm1,ymm0
      11a2:   c5 fc 11 07    vmovups [rdi],ymm0
      11a6:   48 83 c7 20    add    rdi,0x20
      11aa:   75 e9          jne    1195
    |
    width: 420
  }
  
  note_before: |md
    **Input:** Raw objdump output
    - No semantic information
    - Opcodes without context
    - No SIMD categorization
  |
}

step1: "Step 1:\nIdentify Vector\nInstructions" {
  class: step_box
  instructions: {
    shape: rectangle
    style.fill: "#BBDEFB"
    label: |md
      **Pattern Matching:**
      - Scan for `v` prefix (AVX)
      - Scan for `ps` suffix (packed single)
      - Scan for `mm` prefix (SSE)
      **Found in sample:**
      - `vmovups` × 3
      - `vaddps` × 1
    |
  }
  simd_db: {
    shape: rectangle
    style.fill: "#E1F5FE"
    label: |md
      **SIMD Database Lookup:**
      vmovups → load, "AVX unaligned load"
      vaddps  → compute, "AVX add 8 floats"
      vmovups → store, "AVX unaligned store"
    |
  }
}

step2: "Step 2:\nMap to Source\nLines" {
  class: step_box
  mapping: {
    shape: rectangle
    style.fill: "#BBDEFB"
    label: |md
      **DWARF Debug Info:**
      - Use `objdump -S` for interleaved source
      - Match address ranges to source lines
      **Result:**
      0x1195-0x11aa → loop body
      Source line 42: dst[i] = a[i] + b[i]
    |
  }
}

step3: "Step 3:\nIdentify Loop\nStructure" {
  class: step_box
  loop_analysis: {
    shape: rectangle
    style.fill: "#BBDEFB"
    label: |md
      **Control Flow Analysis:**
      - `jne 1195` → backward branch
      - `add rdi, 0x20` → stride 32 bytes
      - Loop processes 8 floats/iteration
      **Pattern:**
      - Load → Compute → Store → Increment
      - Vectorization width: 8 (AVX-256)
    |
  }
}

step4: "Step 4:\nNote Alignment\nChoices" {
  class: step_box
  alignment: {
    shape: rectangle
    style.fill: "#BBDEFB"
    label: |md
      **Instruction Selection:**
      - `vmovups` = **unaligned** load/store
      - Compiler chose safe path
      - No `vmovaps` (aligned variant)
      **Implication:**
      - Works for any pointer alignment
      - Slight latency penalty on older CPUs
    |
  }
}

after: "After:\nAnnotated Assembly" {
  class: after_state
  
  annotated_asm: {
    shape: rectangle
    class: code_block_style
    label: |md
      1195: vmovups ymm0,[rax]     # [load] AVX unaligned load
      1199: vmovups ymm1,[rdx+0x20] # [load] AVX unaligned load
      119e: vaddps ymm0,ymm1,ymm0  # [compute] AVX add 8 floats
      11a2: vmovups [rdi],ymm0     # [store] AVX unaligned store
      11a6: add    rdi,0x20        # [loop] stride 32 bytes
      11aa: jne    1195            # [branch] loop back
      # ───────────────────────────────────────────
      # Pattern: Vectorized loop (width=8)
      # Source: dst[i] = a[i] + b[i]
      # Latency estimate: ~12 cycles/iteration
    |
    width: 460
  }
  
  note_after: |md
    **Output:** Fully annotated assembly
    - SIMD category tags: [load], [compute], [store]
    - Loop structure identified
    - Latency estimates included
    - Source line correlation
  |
}

# Process Flow Connections
before -> step1: "Parse\nobjdump" {class: arrow_style}
step1 -> step2: "Extract\nmnemonics" {class: arrow_style}
step2 -> step3: "Build\nmapping" {class: arrow_style}
step3 -> step4: "Analyze\ncontrol flow" {class: arrow_style}
step4 -> after: "Add\nannotations" {class: arrow_style}

# Legend Shape
legend: {
  near: bottom-right
  style.fill: "transparent"
  label: |md
    ### Legend
    - **Yellow**: Input state (before)
    - **Blue**: Processing steps
    - **Green**: Output state (after)
    - **→**: Data flow direction
  |
}