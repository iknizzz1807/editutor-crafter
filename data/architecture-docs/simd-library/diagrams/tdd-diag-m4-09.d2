vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Rigorous Benchmark Methodology Checklist
'| {near: top-center}

checklist: {
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.stroke-width: 2

  step1: {
    label: "1. CPU Frequency Pinned?"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    check1: |'md
✓ Disable turbo boost
✓ Set performance governor
✓ Pin to fixed frequency (e.g., 2.4GHz)
✓ Verify with `cpupower frequency-info`
'| {shape: text}
  }

  step2: {
    label: "2. Warmup Runs Complete?"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    check2: |'md
✓ 3+ warmup iterations
✓ Populates CPU caches
✓ Stabilizes CPU state
✓ NOT included in timing
'| {shape: text}
  }

  step3: {
    label: "3. 10+ Timed Runs?"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    check3: |'md
✓ Minimum 10 timed runs
✓ Recommended: 15 runs
✓ More runs = better statistics
✓ Captures timing variance
'| {shape: text}
  }

  step4: {
    label: "4. Median Calculated?"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    check4: |'md
✓ Sort timing array
✓ Take middle value
✓ Robust to outliers
✓ NOT arithmetic mean
'| {shape: text}
  }

  step5: {
    label: "5. Stddev Reported?"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    check5: |'md
✓ Calculate variance
✓ sqrt(variance/n)
✓ Report in nanoseconds
✓ Shows measurement spread
'| {shape: text}
  }

  step6: {
    label: "6. CV < 2%?"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
    check6: |'md
**CRITICAL QUALITY GATE**
CV = (stddev / median) × 100
✓ CV < 2% = Valid measurement
⚠ CV 2-5% = Warning, investigate
✗ CV > 10% = Reject, re-run
'| {shape: text}
  }

  step7: {
    label: "7. Auto-Vec Disabled for Baseline?"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    check7: |'md
✓ Use `__attribute__((optimize("no-tree-vectorize")))`
✓ Or compile with `-fno-tree-vectorize`
✓ Ensures fair scalar comparison
✓ Prevents compiler cheating
'| {shape: text}
  }

  step1 -> step2: "then"
  step2 -> step3: "then"
  step3 -> step4: "then"
  step4 -> step5: "then"
  step5 -> step6: "then"
  step6 -> step7: "then"
}

valid: {
  label: |'md
## ✓ VALID BENCHMARK
All checklist items passed.
Results are statistically sound.
Speedup ratios are meaningful.
'|
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.font-color: "#1B5E20"
  near: bottom-right
}

invalid: {
  label: |'md
## ✗ INVALID BENCHMARK
CV > 10% or checklist failed.
Results are noise.
Must re-run with fixes.
'|
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 3
  style.font-color: "#B71C1C"
  near: bottom-left
}

checklist.step7 -> valid: "All Pass" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}

checklist.step6 -> invalid: "CV > 10%" {
  style.stroke: "#F44336"
  style.stroke-width: 3
  style.stroke-dash: 5
}

legend: {
  near: bottom-center
  label: |'md
### Quality Thresholds
| Metric | Pass | Warn | Fail |
|--------|------|------|------|
| CV | < 2% | 2-10% | > 10% |
| Warmup | ≥ 3 | 1-2 | 0 |
| Runs | ≥ 10 | 5-9 | < 5 |
'|
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
}