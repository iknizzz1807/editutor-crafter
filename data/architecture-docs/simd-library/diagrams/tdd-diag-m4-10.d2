vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Comparison Matrix: Hand-Written vs Auto-Vectorized SIMD
| {near: top-center}
comparison_matrix: {
  grid-columns: 5
  grid-gap: 0
  # Header row
  hdr_op: "Operation" {
    style: {
      fill: "#2E3440"
      font-color: "#ECEFF4"
      bold: true
      font-size: 18
    }
  }
  hdr_vec: "Vectorized?" {
    style: {
      fill: "#2E3440"
      font-color: "#ECEFF4"
      bold: true
      font-size: 18
    }
  }
  hdr_hadd: "hadd Used?" {
    style: {
      fill: "#2E3440"
      font-color: "#ECEFF4"
      bold: true
      font-size: 18
    }
  }
  hdr_optimal: "Optimal?" {
    style: {
      fill: "#2E3440"
      font-color: "#ECEFF4"
      bold: true
      font-size: 18
    }
  }
  hdr_winner: "Winner" {
    style: {
      fill: "#2E3440"
      font-color: "#ECEFF4"
      bold: true
      font-size: 18
    }
  }
  # Row 1: add_arrays
  op_add: "add_arrays\n(float × float)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  add_vec: "✓ Yes\n(AVX2, width=8)" {
    style: {
      fill: "#A3BE8C"
      font-color: "#2E3440"
    }
  }
  add_hadd: "N/A\n(element-wise)" {
    style: {
      fill: "#E5E9F0"
      font-color: "#4C566A"
    }
  }
  add_optimal: "✓ Yes\n(vaddps loop)" {
    style: {
      fill: "#A3BE8C"
      font-color: "#2E3440"
    }
  }
  add_winner: "TIE\nAuto ≈ Hand" {
    style: {
      fill: "#EBCB8B"
      font-color: "#2E3440"
      bold: true
    }
  }
  # Row 2: dot_product
  op_dot: "dot_product\n(FP reduction)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  dot_vec: "✓ Yes\n(requires -ffast-math)" {
    style: {
      fill: "#A3BE8C"
      font-color: "#2E3440"
    }
  }
  dot_hadd: "✗ Yes\n(vhaddps chain)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  dot_optimal: "✗ No\n(slow reduction)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  dot_winner: "HAND-WRITTEN\nshuffle+add (2-3×)" {
    style: {
      fill: "#B48EAD"
      font-color: "#ECEFF4"
      bold: true
    }
  }
  # Row 3: conditional_sum
  op_cond: "conditional_sum\n(if > threshold)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  cond_vec: "✗ No\n(control flow)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  cond_hadd: "N/A\n(not vectorized)" {
    style: {
      fill: "#E5E9F0"
      font-color: "#4C566A"
    }
  }
  cond_optimal: "✗ No\n(scalar loop)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  cond_winner: "HAND-WRITTEN\nbranch-free SIMD (3-4×)" {
    style: {
      fill: "#B48EAD"
      font-color: "#ECEFF4"
      bold: true
    }
  }
  # Row 4: memset_pattern
  op_memset: "memset_pattern\n(byte fill)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  memset_vec: "✓ Yes\n(recognized pattern)" {
    style: {
      fill: "#A3BE8C"
      font-color: "#2E3440"
    }
  }
  memset_hadd: "N/A\n(no reduction)" {
    style: {
      fill: "#E5E9F0"
      font-color: "#4C566A"
    }
  }
  memset_optimal: "✓ Yes\n(calls libc!)" {
    style: {
      fill: "#A3BE8C"
      font-color: "#2E3440"
    }
  }
  memset_winner: "AUTO-VEC\nlibc AVX-512 beats SSE2" {
    style: {
      fill: "#88C0D0"
      font-color: "#2E3440"
      bold: true
    }
  }
  # Row 5: strlen
  op_strlen: "strlen\n(null search)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  strlen_vec: "✗ No\n(can't prove safety)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  strlen_hadd: "N/A\n(not vectorized)" {
    style: {
      fill: "#E5E9F0"
      font-color: "#4C566A"
    }
  }
  strlen_optimal: "✗ No\n(scalar loop)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  strlen_winner: "HAND-WRITTEN\naligned-read + mask" {
    style: {
      fill: "#B48EAD"
      font-color: "#ECEFF4"
      bold: true
    }
  }
  # Row 6: memchr
  op_memchr: "memchr\n(byte search + limit)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  memchr_vec: "✗ No\n(size limit + aliasing)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  memchr_hadd: "N/A\n(not vectorized)" {
    style: {
      fill: "#E5E9F0"
      font-color: "#4C566A"
    }
  }
  memchr_optimal: "✗ No\n(scalar loop)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  memchr_winner: "HAND-WRITTEN\nSIMD + size limit" {
    style: {
      fill: "#B48EAD"
      font-color: "#ECEFF4"
      bold: true
    }
  }
  # Row 7: matrix_mul
  op_matmul: "matmul_4x4\n(row × col)" {
    style: {
      fill: "#D8DEE9"
      bold: true
    }
  }
  matmul_vec: "⚠ Partial\n(aliasing uncertain)" {
    style: {
      fill: "#EBCB8B"
      font-color: "#2E3440"
    }
  }
  matmul_hadd: "✗ Yes\n(suboptimal)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  matmul_optimal: "✗ No\n(missed transpose)" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  matmul_winner: "HAND-WRITTEN\ncol-major layout (2.5×)" {
    style: {
      fill: "#B48EAD"
      font-color: "#ECEFF4"
      bold: true
    }
  }
}
# Legend
legend: {
  near: bottom-center
  legend_title: "Legend" {
    style: {
      bold: true
      font-size: 16
    }
  }
  leg_auto: "AUTO-VEC WINS" {
    style: {
      fill: "#88C0D0"
    }
  }
  leg_hand: "HAND-WRITTEN WINS" {
    style: {
      fill: "#B48EAD"
      font-color: "#ECEFF4"
    }
  }
  leg_tie: "TIE (equivalent)" {
    style: {
      fill: "#EBCB8B"
    }
  }
  leg_good: "✓ Optimal choice" {
    style: {
      fill: "#A3BE8C"
    }
  }
  leg_bad: "✗ Suboptimal" {
    style: {
      fill: "#BF616A"
      font-color: "#ECEFF4"
    }
  }
  leg_auto -- leg_hand -- leg_tie -- leg_good -- leg_bad
}
# Summary box
summary: {
  near: top-right
  sum_title: "Key Findings" {
    style: {
      bold: true
      fill: "#3B4252"
      font-color: "#ECEFF4"
    }
  }
  sum_1: |md
    **Hand-written wins when:**
    • Horizontal reduction (hadd slow)
    • Complex control flow
    • Page-boundary safety needed
    • Known alignment/layout
  | {
    style: {
      fill: "#434C5E"
      font-color: "#ECEFF4"
    }
  }
  sum_2: |md
    **Auto-vec wins/matches when:**
    • Simple element-wise ops
    • Recognized libc patterns
    • Compiler has AVX, you used SSE
  | {
    style: {
      fill: "#434C5E"
      font-color: "#ECEFF4"
    }
  }
  sum_title -- sum_1 -- sum_2
}