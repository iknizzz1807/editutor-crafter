layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    pad: 40
    sketch: false
  }
}

classes: {
  header_cell: {
    style: {
      fill: "#673AB7"
      font-color: white
      bold: true
    }
  }
  changed_data: {
    style: {
      font-color: "#D32F2F"
      bold: true
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
  memory_block: {
    style: {
      font: mono
      fill: "#E1F5FE"
      stroke: "#01579B"
    }
  }
  logic_step: {
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
}

title: ||md
  # Algorithm Design: Statistical Measurement Pipeline
  **Architecture Specification: ISO-26262 Timing Validation**
  `sizeof(buffer) = 120 bytes | N = 15 | Precision: 1ns`
| {
  near: top-center
  style: {
    font-size: 22
    bold: true
  }
}

# -----------------------------------------------------------------------------
# BEFORE STATE: Raw Memory Input
# -----------------------------------------------------------------------------
input_state: {
  label: "INPUT: Raw Linear Buffer (int64_t[15])"
  style: {
    fill: "#F5F5F5"
    stroke: "#757575"
    double-border: true
  }

  mem_layout: {
    shape: sql_table
    "Offset": "Value (Nanoseconds)" {constraint: "Type"}
    "0x00": "1520" {constraint: "int64"}
    "0x08": "1485" {constraint: "int64"}
    "0x10": "1590" {constraint: "int64"}
    "0x18": "1510" {constraint: "int64"}
    "0x20": "1512" {constraint: "int64"}
    "0x28": "1605" {constraint: "int64"}
    "0x30": "1490" {constraint: "int64"}
    "0x38": "..." {constraint: "..."}
  }

  buffer_meta: |md
    ### Buffer Context
    - **Base Address**: `0x7ffee120`
    - **Alignment**: 8-Byte (QWORD)
    - **State**: Unordered / High Entropy
    - **Entropy H(x)**: 3.87 bits
  | {
    shape: text
    style.font-size: 12
  }
}

# -----------------------------------------------------------------------------
# STEP 1: QUICKSORT
# -----------------------------------------------------------------------------
step1_sorting: {
  class: logic_step
  label: "Step 1: In-Place Quicksort (O(N log N))"
  style.fill: "#FFF3E0"
  
  algorithm: |go
    func Sort(data []int64) {
      if len(data) < 2 { return }
      pivot := data[len(data)/2]
      // Partitions around pivot
      // Swapping indices to achieve 
      // strictly increasing order.
    }
  ||
  
  sorted_buffer: {
    shape: sql_table
    "Index": "Value"
    "0": "1485"
    "1": "1490"
    "2": "1510"
    "...": "..."
    "14": "1605"
  }
  # Highlight the changes
  sorted_buffer."0".class: changed_data
  sorted_buffer."1".class: changed_data
  sorted_buffer."2".class: changed_data
  sorted_buffer."14".class: changed_data
# REMOVED (extra closing brace): }

# -----------------------------------------------------------------------------
# STEP 2: MEDIAN EXTRACTION
# -----------------------------------------------------------------------------
step2_median: {
  class: logic_step
  label: "Step 2: Median Estimation"
  style.fill: "#E8F5E9"
  
  extraction_code: |c
    // O(1) Access after sorting
    // For odd N=15, median is at N/2
    const int mid_idx = 15 >> 1; // 7
    int64_t median = buffer[mid_idx];
  |
  
  pointer_logic: {
    shape: rectangle
    label: "Register [R0]\nValue: 1520\nIndex: [7]"
    style: {
      fill: "#C8E6C9"
      bold: true
      stroke: "#2E7D32"
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 3: MEAN & VARIANCE
# -----------------------------------------------------------------------------
step3_arithmetic: {
  class: logic_step
  label: "Step 3: Vector Math (Summation)"
  style.fill: "#E3F2FD"

  simd_code: |c
    // Accumulate sum for μ
    double sum = v_sum_int64(buffer, 15);
    double mu = sum / 15.0;

    // Accumulate M2 for σ²
    double m2 = 0.0;
    for(i=0; i<15; i++) {
        double d = (double)buffer[i] - mu;
        m2 += (d * d);
    }
  |
  
  accumulator: {
    label: "μ = 1522.0 ns\nσ² = 845.3 ns²"
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 4: STDDEV & CV VALIDATION
# -----------------------------------------------------------------------------
step4_validation: {
  class: logic_step
  label: "Step 4: Precision Quality Check"
  style.fill: "#FCE4EC"

  calc: |c
    double sigma = sqrt(m2 / 15.0);
    // Coefficient of Variation
    // (Relative Standard Deviation)
    double cv = (sigma / median) * 100.0;
  |

  metric_card: {
    label: "σ: 29.1 ns\nCV: 1.91%"
    style: {
      bold: true
      font-size: 16
      fill: "#F8BBD0"
      stroke: "#C2185B"
    }
  }
}

# -----------------------------------------------------------------------------
# FINAL REPORT
# -----------------------------------------------------------------------------
final_report: {
  label: "OUTPUT: Validation Report"
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 3
    shadow: true
  }
  
  summary: |md
    ### Status: PASS
    - **Safety Level**: ASIL-D
    - **Stability**: High (CV < 2.0%)
    - **Jitter Check**: Passed
  |
}

# -----------------------------------------------------------------------------
# DATA FLOW & RELATIONSHIPS
# -----------------------------------------------------------------------------

# Main execution pipeline
input_state -> step1_sorting: "int64[15] (Raw)"
step1_sorting -> step2_median: "int64[15] (Sorted)"
step2_median -> step3_arithmetic: "Median Reference"
step3_arithmetic -> step4_validation: "μ, σ² params"
step4_validation -> final_report: "CV % Metric"

# Data dependency annotations
(step3_arithmetic -> step4_validation)[0].style: {
  stroke: "#1976D2"
  stroke-dash: 5
}

# Logic Groupings and Placement
step1_sorting.algorithm -> step1_sorting.sorted_buffer: "Sort Operation"
step2_median.extraction_code -> step2_median.pointer_logic: "Direct Index"
step4_validation.calc -> step4_validation.metric_card: "CV Calculation"

# Complexity Labels
step1_sorting_complexity: ||md
  **Complexity**: ${O}(N \log N)$
| {
  near: step1_sorting
  style.font-size: 10
}

step3_arithmetic_complexity: |md
  **Complexity**: ${O}(N)$
| {
  near: step3_arithmetic
  style.font-size: 10
}

# Threshold Legend
threshold_legend: {
  near: bottom-right
  shape: sql_table
  "Metric (CV%)": "Status" {constraint: "Action"}
  " < 2.0%": "ACCEPT" {constraint: "Proceed"}
  " 2% - 5%": "WARN" {constraint: "Log"}
  " > 5.0%": "REJECT" {constraint: "Fault"}
}

# Technical Invariants
footer_note: |md
  **Implementation Note**: Uses the Median as the denominator for Coefficient of Variation (CV) to 
  increase robustness against interrupt-driven timing spikes (outliers).
| {
  near: threshold_legend
  style.font-size: 11
}
||