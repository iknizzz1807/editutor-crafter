vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # Execution Ports: Compiler-Generated hadd vs Shuffle+Add
  **Horizontal Reduction Latency Comparison**
|| {near: top-center}

direction: right

classes: {
  port-box: {
    style: {
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
      border-radius: 4
    }
  }
  hadd-inst: {
    style: {
      fill: "#FF6B6B"
      stroke: "#CC0000"
      stroke-width: 2
      font-color: "#FFFFFF"
      bold: true
    }
  }
  shuffle-inst: {
    style: {
      fill: "#4ECDC4"
      stroke: "#008B8B"
      stroke-width: 2
      font-color: "#FFFFFF"
      bold: true
    }
  }
  add-inst: {
    style: {
      fill: "#45B7D1"
      stroke: "#0066CC"
      stroke-width: 2
      font-color: "#FFFFFF"
      bold: true
    }
  }
  arrow-bad: {
    style: {
      stroke: "#CC0000"
      stroke-width: 3
    }
  }
  arrow-good: {
    style: {
      stroke: "#228B22"
      stroke-width: 3
    }
  }
  latency-box: {
    style: {
      fill: "#FFF8DC"
      stroke: "#DAA520"
      stroke-width: 2
      border-radius: 8
    }
  }
}

hadd_approach: "Approach 1: hadd_ps (Compiler Default)" {
  direction: down
  style.fill: "#FFE4E1"
  style.stroke: "#CC0000"
  style.stroke-width: 3
  style.border-radius: 8
  
  ports: "CPU Execution Ports" {
    class: port-box
    direction: right
    p5: "Port 5\n(Shuffle Unit)" {
      class: port-box
      style.fill: "#D3D3D3"
      hadd1: "hadd_ps #1\n3-5 cycles" {
        class: hadd-inst
      }
      hadd2: "hadd_ps #2\n3-5 cycles" {
        class: hadd-inst
      }
    }
    p01: "Ports 0/1\n(FMA Units)" {
      class: port-box
      style.fill: "#D3D3D3"
      style.fill-pattern: dots
      idle: "IDLE\n(waiting)" {
        style.fill: "#F5F5F5"
        style.stroke-dash: 3
        style.font-color: "#999999"
      }
    }
  }
  
  hadd_latency: "Total Latency: 10-15 cycles" {
    class: latency-box
    style.fill: "#FFE4E1"
    style.stroke: "#CC0000"
    style.font-color: "#CC0000"
    style.bold: true
    style.font-size: 20
  }
}

hadd_approach.ports.p5.hadd1 -> hadd_approach.ports.p5.hadd2: "SERIALIZED\nmust wait" {class: arrow-bad}
hadd_approach.ports.p5.hadd2 -> hadd_approach.hadd_latency: {class: arrow-bad}

shuffle_approach: "Approach 2: shuffle + add (Optimal)" {
  direction: down
  style.fill: "#E8F5E9"
  style.stroke: "#228B22"
  style.stroke-width: 3
  style.border-radius: 8
  
  ports2: "CPU Execution Ports" {
    class: port-box
    direction: right
    p5_2: "Port 5\n(Shuffle Unit)" {
      class: port-box
      style.fill: "#D3D3D3"
      shuf1: "shuffle_ps\n1 cycle" {
        class: shuffle-inst
      }
      shuf2: "shuffle_ps\n1 cycle" {
        class: shuffle-inst
      }
    }
    p01_2: "Ports 0/1\n(FMA Units)" {
      class: port-box
      style.fill: "#D3D3D3"
      add1: "add_ps\n4 cycles" {
        class: add-inst
      }
      add2: "add_ss\n4 cycles" {
        class: add-inst
      }
    }
  }
  
  shuffle_latency: "Total Latency: ~6 cycles" {
    class: latency-box
    style.fill: "#E8F5E9"
    style.stroke: "#228B22"
    style.font-color: "#228B22"
    style.bold: true
    style.font-size: 20
  }
}

shuffle_approach.ports2.p5_2.shuf1 -> shuffle_approach.ports2.p01_2.add1: "PARALLEL\noverlap" {class: arrow-good}
shuffle_approach.ports2.p01_2.add1 -> shuffle_approach.ports2.p5_2.shuf2: {class: arrow-good}
shuffle_approach.ports2.p5_2.shuf2 -> shuffle_approach.ports2.p01_2.add2: {class: arrow-good}
shuffle_approach.ports2.p01_2.add2 -> shuffle_approach.shuffle_latency: {class: arrow-good}

hadd_approach -> shuffle_approach: ||md
  **2-3× faster**
|| {
  style: {
    stroke: "#4B0082"
    stroke-width: 4
    stroke-dash: 5
    animated: true
  }
  style.font-color: "#4B0082"
  style.bold: true
  style.font-size: 24
}

legend: ||md
  ### Key Insight
  **hadd_ps** is a horizontal operation that only executes on Port 5 (shuffle unit). 
  Multiple hadd instructions must serialize, creating a dependency chain.
  
  **shuffle + add** splits the work:
  - Shuffle operates on Port 5 (1 cycle)
  - Add operates on Ports 0/1 (4 cycles, parallel with next shuffle)
  
  The compiler's default `hadd` chain is 2-3× slower than hand-written shuffle+add.
|| {
  near: bottom-center
  style.fill: "#F0F8FF"
  style.stroke: "#4169E1"
  style.border-radius: 8
  style.stroke-width: 2
}

timing_table: ||md
  | Instruction | Port | Latency | Throughput |
  |-------------|------|---------|------------|
  | `haddps`    | 5    | 3-5 cyc | 1/cycle    |
  | `shufps`    | 5    | 1 cyc   | 1/cycle    |
  | `addps`     | 0, 1 | 4 cyc   | 2/cycle    |
  | `addss`     | 0, 1 | 4 cyc   | 2/cycle    |
|| {
  near: bottom-right
  style.fill: "#FFFACD"
  style.stroke: "#B8860B"
  style.border-radius: 4
}