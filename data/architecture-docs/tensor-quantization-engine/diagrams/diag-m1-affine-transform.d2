direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "The Affine Quantization Transform: FP32 to INT8 Pipeline"
  style: {
    font-size: 28
    bold: true
    font-color: "#2C3E50"
    stroke: transparent
    fill: transparent
  }
}

# --- ROW 1: INPUT REPRESENTATION ---
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  fp32_section: {
    direction: down
    label: "High-Precision Input (FP32 Continuous Range)"
    fp32_numberline: {
      label: "Continuous Floating Point Axis"
      shape: rectangle
      width: 600
      height: 40
      style: {
        fill: "#E8F4FD"
        stroke: "#3498DB"
        stroke-width: 2
      }
    }
    fp32_markers: {
      direction: right
      width: 600
      style.fill: transparent
      style.stroke: transparent
      rmin: {
        label: "r_min (-0.5)"
        shape: text
        style.font-color: "#2980B9"
      }
      spacer1: { label: ""; width: 200 }
      rzero: {
        label: "0.0 (Origin)"
        shape: text
        style.font-color: "#27AE60"
      }
      spacer2: { label: ""; width: 200 }
      rmax: {
        label: "r_max (+0.5)"
        shape: text
        style.font-color: "#2980B9"
      }
    }
    fp32_desc: {
      label: |'md
        **Continuous Input State**
        - Standard IEEE 754 Representation
        - Calibrated Dynamic Range: [r_min, r_max]
      '|
      width: 600
      style.fill: transparent
    }
  }
}

# --- ROW 2: CORE TRANSFORMATION STEPS ---
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  transform_section: {
    direction: down
    label: "Quantization Kernel (Affine Logic)"
    
    step1: {
      label: "S1: Scale Normalization"
      width: 600
      code: |'c
        // Map FP32 range to integer bucket indices
        // scale = (r_max - r_min) / (q_max - q_min)
        float normalized = r_input / scale;
      '|
      style: { fill: "#FEF9E7"; stroke: "#F39C12"; stroke-width: 2 }
    }
    step2: {
      label: "S2: Zero-Point Translation"
      width: 600
      code: |'c
        // Ensure FP32 zero maps exactly to an integer
        // zp = round(q_min - r_min / scale)
        float shifted = normalized + zero_point;
      '|
      style: { fill: "#E8F8F5"; stroke: "#1ABC9C"; stroke-width: 2 }
    }
    step3: {
      label: "S3: Stochastic/Nearest Rounding"
      width: 600
      code: |'c
        // Discretize to the integer grid
        // This is the non-differentiable step (Straight-Through Estimator used in QAT)
        int32_t rounded = round(shifted);
      '|
      style: { fill: "#F5EEF8"; stroke: "#9B59B6"; stroke-width: 2 }
    }
    step4: {
      label: "S4: Saturation / Clipping"
      width: 600
      code: |'c
        // Prevent wrap-around overflow
        // q = max(q_min, min(q_max, rounded))
        int8_t q_out = clamp(rounded, -128, 127);
      '|
      style: { fill: "#FDEDEC"; stroke: "#E74C3C"; stroke-width: 2 }
    }
    
    step1 -> step2: "FP32 | normalized"
    step2 -> step3: "FP32 | shifted"
    step3 -> step4: "INT32 | rounded"
  }
}

# --- ROW 3: OUTPUT REPRESENTATION ---
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  int8_section: {
    direction: down
    label: "Low-Precision Output (INT8 Discrete Grid)"
    int8_numberline: {
      label: "Discrete Quantization Buckets"
      shape: rectangle
      width: 600
      height: 40
      style: {
        fill: "#FDEBD0"
        stroke: "#E67E22"
        stroke-width: 2
        fill-pattern: lines
      }
    }
    int8_markers: {
      direction: right
      width: 600
      style.fill: transparent
      style.stroke: transparent
      qmin: {
        label: "q_min (-128)"
        shape: text
        style.font-color: "#C0392B"
      }
      spacer1: { label: ""; width: 150 }
      qzero: {
        label: "Zero-Point (zp)"
        shape: text
        style.font-color: "#27AE60"
      }
      spacer2: { label: ""; width: 150 }
      qmax: {
        label: "q_max (+127)"
        shape: text
        style.font-color: "#C0392B"
      }
    }
    int8_desc: {
      label: |'md
        **Discrete Output State**
        - INT8 Storage (1 byte per tensor element)
        - Memory Savings: 4x vs FP32
      '|
      width: 600
      style.fill: transparent
    }
  }
}

# --- ROW 4: FORMULA REFERENCE ---
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  formula_box: {
    label: "Affine Quantization Mathematics"
    width: 650
    details: |'md
      ### Forward Transform (Quantize)
      $q = \text{clamp}(\text{round}(\frac{r}{S} + Z), q_{min}, q_{max})$

      ### Inverse Transform (Dequantize)
      $r \approx S \times (q - Z)$
      
      *Note: Precision loss occurs during the round() operation.*
    '|
    style: {
      fill: "#EBF5FB"
      stroke: "#2980B9"
      stroke-width: 2
      border-radius: 8
    }
  }
}

# --- ROW 5: PARAMETER SPECIFICATIONS ---
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  params_table: {
    shape: sql_table
    label: "Quantization Parameters (Metadata)"
    f1: "S      | float32 | Scale (Step size between levels)"
    f2: "Z      | int32   | Zero-Point (Maps to FP32 0.0)"
    f3: "q_min  | int8    | Min valid integer (-128)"
    f4: "q_max  | int8    | Max valid integer (127)"
    total: "Storage: Parameters usually stored per-tensor or per-channel"
  }
}

# --- ROW 6: EDGE CASES ---
row6: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  overflow_box: {
    label: "clamping_logic.c"
    width: 650
    code: |'c
      // Overflow Handling Example
      float r_val = 0.85f; // Outside range [-0.5, 0.5]
      int32_t raw_q = round(r_val / 0.00392f + 0); // ~216
      int8_t q_clamped = clamp(raw_q, -128, 127);  // Result: 127
      // Clipped value results in Max Saturation Error
    '|
    style: { fill: "#FDEDEC"; stroke: "#E74C3C"; border-radius: 8 }
  }
}

# --- GLOBAL CONNECTIONS ---
row1.fp32_section -> row2.transform_section: "Quantize | FP32 -> INT8" {
  style: { stroke: "#3498DB"; stroke-width: 3; animated: true }
}
row2.transform_section -> row3.int8_section: "Store | Discrete Grid" {
  style: { stroke: "#E67E22"; stroke-width: 3 }
}

legend: {
  label: |'md
    **Affine Legend**
    - **S**: Scaling Factor
    - **Z**: Shift/Offset
    - **Clipping**: r > r_max
  '|
  near: bottom-right
  style: { fill: "#F8F9FA"; stroke: "#BDC3C7"; border-radius: 8 }
}