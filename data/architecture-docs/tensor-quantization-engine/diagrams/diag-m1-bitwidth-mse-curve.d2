direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    symmetric: "#4A90D9"
    asymmetric: "#E67E22"
    cliff: "#E74C3C"
    grid: "#CBD6E1"
    annotation: "#5D6D7E"
  }
}
title: |md
  # Bit Width vs Quantization Error Tradeoff
| {near: top-center}
subtitle: |md
  MSE (log scale) vs Bit Width — INT4 as practical lower bound
| {near: top-center}
chart_container: {
  style.fill: "#FAFBFC"
  style.stroke: ${colors.grid}
  style.stroke-width: 1
  y_axis_label: |md
    ## MSE
    *(log scale)*
  |
  x_axis_label: |md
    ## Bit Width
  |
  grid_2: {
    style.stroke: ${colors.grid}
    style.stroke-dash: 2
    style.fill: transparent
    width: 600
    height: 400
  }
  symmetric_line: {
    label: "Symmetric (zero_point=0)"
    style.stroke: ${colors.symmetric}
    style.stroke-width: 3
    style.fill: transparent
    width: 600
    height: 400
  }
  asymmetric_line: {
    label: "Asymmetric (computed zero_point)"
    style.stroke: ${colors.asymmetric}
    style.stroke-dash: 5
    style.stroke-width: 3
    style.fill: transparent
    width: 600
    height: 400
  }
}
data_points: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  col_2bit: {
    direction: down
    label: "2-bit"
    sym_point: {
      label: "MSE: 0.5+"
      style.fill: ${colors.symmetric}
      shape: circle
    }
    asym_point: {
      label: "MSE: 0.3+"
      style.fill: ${colors.asymmetric}
      shape: circle
    }
    cliff_annotation: |md
      **CLIFF**
      Only 4 values
      (-2 to 1)
      *Catastrophic for most models*
    |
  }
  col_4bit: {
    direction: down
    label: "4-bit (INT4)"
    sym_point: {
      label: "MSE: 0.01-0.1"
      style.fill: ${colors.symmetric}
      shape: circle
    }
    asym_point: {
      label: "MSE: 0.008-0.08"
      style.fill: ${colors.asymmetric}
      shape: circle
    }
    practical_bound: |md
      **PRACTICAL LOWER BOUND**
      16 values (-8 to 7)
      *Requires GPTQ for LLMs*
    |
  }
  col_8bit: {
    direction: down
    label: "8-bit (INT8)"
    sym_point: {
      label: "MSE: ~0.00001"
      style.fill: ${colors.symmetric}
      shape: circle
    }
    asym_point: {
      label: "MSE: ~0.000008"
      style.fill: ${colors.asymmetric}
      shape: circle
    }
    sweet_spot: |md
      **SWEET SPOT**
      256 values
      *Works for most layers*
    |
  }
  col_16bit: {
    direction: down
    label: "16-bit"
    sym_point: {
      label: "MSE: ~0.0000001"
      style.fill: ${colors.symmetric}
      shape: circle
    }
    asym_point: {
      label: "MSE: ~0.00000008"
      style.fill: ${colors.asymmetric}
      shape: circle
    }
    near_fp32: |md
      **NEAR FP32**
      65536 values
      *Negligible error*
    |
  }
}
legend_container: {
  style.fill: "#F8F9FA"
  style.stroke: ${colors.grid}
  style.border-radius: 4
  legend_title: |md
    ### Legend
  |
  symmetric_legend: {
    shape: rectangle
    width: 30
    height: 3
    style.fill: ${colors.symmetric}
    style.stroke: ${colors.symmetric}
  }
  symmetric_label: "Symmetric Quantization (zp=0)"
  asymmetric_legend: {
    shape: rectangle
    width: 30
    height: 3
    style.fill: transparent
    style.stroke: ${colors.asymmetric}
    style.stroke-dash: 5
  }
  asymmetric_label: "Asymmetric Quantization"
  cliff_legend: {
    shape: diamond
    style.fill: ${colors.cliff}
  }
  cliff_label: "Quantization Cliff"
}
insights_panel: {
  style.fill: "#FEF9E7"
  style.stroke: "#F7DC6F"
  style.border-radius: 4
  insights_title: |md
    ### Key Insights
  |
  insight_1: |md
    1. **Exponential relationship**: Each additional bit halves the quantization error (doubles representable values)
  |
  insight_2: |md
    2. **Asymmetric advantage**: 10-20% lower MSE for positive-only distributions (post-ReLU activations)
  |
  insight_3: |md
    3. **2-bit cliff**: Only 4 values — catastrophic for any realistic model, unusable without extreme techniques
  |
  insight_4: |md
    4. **INT4 threshold**: 16 values — requires GPTQ/AWQ for LLMs, works directly for some vision models
  |
  insight_5: |md
    5. **INT8 sweet spot**: 256 values — negligible error (<0.01%) for most weights, standard for PTQ
  |
}
math_reference: {
  shape: sql_table
  label: "Quantization Error Bounds (quant.h)"
  row_2bit: "2-bit | 4 levels | error ≤ scale/2 | scale = range/2"
  row_4bit: "4-bit | 16 levels | error ≤ scale/2 | scale = range/8"
  row_8bit: "8-bit | 256 levels | error ≤ scale/2 | scale = range/128"
  row_16bit: "16-bit | 65536 levels | error ≤ scale/2 | scale = range/32768"
  formula: "MSE ∝ scale² ∝ (range / 2^bits)²"
}
data_points.col_2bit.cliff_annotation.style.font-color: ${colors.cliff}
data_points.col_4bit.practical_bound.style.font-color: ${colors.symmetric}