direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Quantization Error Distribution
  Demonstrates uniform error within ±scale/2 bounds
'|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  int8_hist: {
    label: "INT8 Quantization (256 levels)"
    histogram: {
      shape: rectangle
      width: 280
      height: 180
      style.fill: transparent
      style.stroke: "#6B7280"
      
      bars: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        b1: { shape: rectangle; width: 40; height: 20; style.fill: "#3B82F6"; style.stroke: "#1D4ED8" }
        b2: { shape: rectangle; width: 40; height: 80; style.fill: "#3B82F6"; style.stroke: "#1D4ED8" }
        b3: { shape: rectangle; width: 40; height: 140; style.fill: "#10B981"; style.stroke: "#059669"; label: "±0.002" }
        b4: { shape: rectangle; width: 40; height: 75; style.fill: "#3B82F6"; style.stroke: "#1D4ED8" }
        b5: { shape: rectangle; width: 40; height: 18; style.fill: "#3B82F6"; style.stroke: "#1D4ED8" }
      }
    }
    stats: {
      shape: rectangle
      width: 260
      style.fill: transparent
      style.stroke: transparent
      scale_val: |'md
        **scale = 0.0039**
        Error bound: **±0.00195**
      '|
      mse_val: |'md
        MSE: **0.000001**
        Max error: 0.0019
      '|
    }
  }

  int4_hist: {
    label: "INT4 Quantization (16 levels)"
    histogram2: {
      shape: rectangle
      width: 280
      height: 180
      style.fill: transparent
      style.stroke: "#6B7280"
      
      bars2: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        b1_b: { shape: rectangle; width: 40; height: 15; style.fill: "#F59E0B"; style.stroke: "#D97706" }
        b2_b: { shape: rectangle; width: 40; height: 60; style.fill: "#F59E0B"; style.stroke: "#D97706" }
        b3_b: { shape: rectangle; width: 40; height: 100; style.fill: "#10B981"; style.stroke: "#059669"; label: "±0.031" }
        b4_b: { shape: rectangle; width: 40; height: 55; style.fill: "#F59E0B"; style.stroke: "#D97706" }
        b5_b: { shape: rectangle; width: 40; height: 12; style.fill: "#F59E0B"; style.stroke: "#D97706" }
      }
    }
    stats2: {
      shape: rectangle
      width: 260
      style.fill: transparent
      style.stroke: transparent
      scale_val2: |'md
        **scale = 0.0625**
        Error bound: **±0.03125**
      '|
      mse_val2: |'md
        MSE: **0.000327**
        Max error: 0.0313
      '|
    }
  }

  int2_hist: {
    label: "INT2 Quantization (4 levels)"
    histogram3: {
      shape: rectangle
      width: 280
      height: 180
      style.fill: transparent
      style.stroke: "#6B7280"
      
      bars3: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        b1_c: { shape: rectangle; width: 40; height: 10; style.fill: "#EF4444"; style.stroke: "#DC2626" }
        b2_c: { shape: rectangle; width: 40; height: 40; style.fill: "#EF4444"; style.stroke: "#DC2626" }
        b3_c: { shape: rectangle; width: 40; height: 70; style.fill: "#10B981"; style.stroke: "#059669"; label: "±0.125" }
        b4_c: { shape: rectangle; width: 40; height: 35; style.fill: "#EF4444"; style.stroke: "#DC2626" }
        b5_c: { shape: rectangle; width: 40; height: 8; style.fill: "#EF4444"; style.stroke: "#DC2626" }
      }
    }
    stats3: {
      shape: rectangle
      width: 260
      style.fill: transparent
      style.stroke: transparent
      scale_val3: |'md
        **scale = 0.25**
        Error bound: **±0.125**
      '|
      mse_val3: |'md
        MSE: **0.005208**
        Max error: 0.125
      '|
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  error_formula: {
    label: "Quantization Theory (quant.c)"
    width: 380
    formula: |'md
      **Error per element:**
      ε(r) = r - scale * (q - zp)
      **Error bound:**
      |ε(r)| ≤ scale / 2
      **MSE approximation:**
      MSE ≈ scale² / 12
    '|
    code: |'python
    def compute_error(tensor, scale):
        q = round(tensor / scale)
        dq = scale * q
        error = tensor - dq
        return error # Uniform in [-s/2, s/2]
    '|
  }

  comparison_table: {
    label: "Bit Width Tradeoffs"
    shape: sql_table
    header: "Bit | Levels | Scale | Max Err | MSE"
    row8: "8 | 256 | 0.0078 | 0.0039 | 5.1e-6"
    row4: "4 | 16  | 0.125  | 0.0625 | 3.3e-4"
    row3: "3 | 8   | 0.25   | 0.125  | 5.2e-3"
    row2: "2 | 4   | 0.5    | 0.25   | 2.1e-2"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  outlier_panel: {
    label: "Outlier Impact on Error"
    width: 400
    normal_dist: {
      label: "Normal Dist"
      shape: rectangle
      width: 180
      height: 100
      style.fill: "#DBEAFE"
      style.stroke: "#3B82F6"
      desc: "Optimal scale covers 99% of values"
    }
    outlier_dist: {
      label: "With Outliers"
      shape: rectangle
      width: 180
      height: 100
      style.fill: "#FEE2E2"
      style.stroke: "#EF4444"
      desc: "Scale inflated; base error increases"
    }
    normal_dist -> outlier_dist: "outlier at 10σ" {
      style.stroke: "#EF4444"
      style.stroke-dash: 3
    }
  }

  key_insight: {
    label: "Key Insight"
    width: 350
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
    insight: |'md
      **MSE ∝ (1 / 2^bits)²**
      
      Each bit removed quadruples the MSE. 
      INT8 to INT4 is a 16x error increase.
      This is why GPTQ/AWQ is essential 
      for model survival at low bits.
    '|
  }
}

legend: {
  style.fill: transparent
  style.stroke: "#6B7280"
  int8_l: "INT8 (High Fidelity)" { shape: rectangle; style.fill: "#3B82F6" }
  int4_l: "INT4 (Standard)" { shape: rectangle; style.fill: "#F59E0B" }
  int2_l: "INT2 (High Distortion)" { shape: rectangle; style.fill: "#EF4444" }
  zero_l: "Zero Point/Bound" { shape: rectangle; style.fill: "#10B981" }
}
legend.near: bottom-right

int8_hist -> int4_hist: "16x MSE" {
  style.stroke: "#F59E0B"
  style.stroke-dash: 3
}
int4_hist -> int2_hist: "16x MSE" {
  style.stroke: "#EF4444"
  style.stroke-dash: 3
}