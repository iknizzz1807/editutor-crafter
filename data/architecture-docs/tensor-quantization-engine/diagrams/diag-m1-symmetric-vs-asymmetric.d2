direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  label: "Symmetric vs Asymmetric Quantization Ranges (quantize.h)"
  style: {
    font-size: 24
    bold: true
    fill: "#F1F5F9"
    stroke-width: 0
  }
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  symmetric_section: {
    direction: down
    label: "SYMMETRIC QUANTIZATION"
    style.fill: "#F8FAFC"
    
    sym_int8_range: {
      label: "INT8 Range Mapping"
      shape: rectangle
      width: 400
      style: {
        fill: "#E8F4FD"
        stroke: "#2563EB"
        stroke-width: 2
      }
      
      sym_visual: {
        width: 380
        style.stroke: transparent
        style.fill: transparent
        
        sym_bar: {
          shape: rectangle
          width: 360
          height: 40
          label: "Quantized Domain: [-127, 127]"
          style: {
            fill: "linear-gradient(to right, #93C5FD, #DBEAFE, #93C5FD)"
            stroke: "#1E40AF"
            stroke-width: 2
          }
        }
        
        annotations: {
          direction: right
          style.stroke: transparent
          style.fill: transparent
          min: "-127" { style.font: mono }
          zero: "0 (Fixed ZP)" { 
            style.font: mono
            style.font-color: "#DC2626"
            style.bold: true 
          }
          max: "127" { style.font: mono }
        }
      }
      
      properties: {
        label: "Mapping Logic"
        content: |'md
          - **Zero-point (zp)**: Always 0
          - **Scale (s)**: max(|r_min|, |r_max|) / 127
          - **Efficiency**: Faster integer arithmetic
          - **Constraint**: Symmetry forced around zero
        '|
      }
    }
    
    sym_implementation: {
      label: "Reference Implementation (quantize.c)"
      code: |'c
        float scale = max(abs(r_min), abs(r_max)) / 127.0f;
        int8_t q = (int8_t)round(r / scale);
        // Dequantize
        float r_rec = q * scale;
      '|
    }
  }

  asymmetric_section: {
    direction: down
    label: "ASYMMETRIC QUANTIZATION"
    style.fill: "#FFFBEB"
    
    asym_uint8_range: {
      label: "UINT8 / Offset Range Mapping"
      shape: rectangle
      width: 400
      style: {
        fill: "#FEF3C7"
        stroke: "#D97706"
        stroke-width: 2
      }
      
      asym_visual: {
        width: 380
        style.stroke: transparent
        style.fill: transparent
        
        asym_bar: {
          shape: rectangle
          width: 360
          height: 40
          label: "Quantized Domain: [0, 255]"
          style: {
            fill: "linear-gradient(to right, #FCD34D, #FEF3C7, #FBBF24)"
            stroke: "#92400E"
            stroke-width: 2
          }
        }
        
        annotations: {
          direction: right
          style.stroke: transparent
          style.fill: transparent
          min: "0" { style.font: mono }
          zp: "zp (Learned)" { 
            style.font: mono
            style.font-color: "#059669"
            style.bold: true 
          }
          max: "255" { style.font: mono }
        }
      }
      
      properties: {
        label: "Mapping Logic"
        content: |'md
          - **Zero-point (zp)**: round(q_min - r_min / s)
          - **Scale (s)**: (r_max - r_min) / 255
          - **Efficiency**: Full bit-width utilization
          - **Constraint**: Requires zp subtraction in MACs
        '|
      }
    }
    
    asym_implementation: {
      label: "Reference Implementation (quantize.c)"
      code: |'c
        float scale = (r_max - r_min) / 255.0f;
        int32_t zp = (int32_t)round(0 - r_min / scale);
        uint8_t q = (uint8_t)clamp(round(r / scale) + zp, 0, 255);
        // Dequantize
        float r_rec = (q - zp) * scale;
      '|
    }
  }
}

distribution_section: {
  direction: down
  label: "Deployment Strategy: Distribution Mapping"
  
  dist_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    relu_case: {
      label: "ReLU Activations"
      width: 320
      visual: {
        shape: rectangle
        height: 60
        label: "Domain: [0, max_val]"
        style.fill: "#DCFCE7"
        style.stroke: "#16A34A"
      }
      verdict: {
        label: "VERDICT: ASYMMETRIC"
        style: {
          fill: "#BBF7D0"
          stroke: "#16A34A"
          bold: true
        }
      }
      note: "No negative values; asymmetric uses full range."
    }
    
    weight_case: {
      label: "Layer Weights (Post-BN)"
      width: 320
      visual: {
        shape: rectangle
        height: 60
        label: "Domain: ≈[-std, +std]"
        style.fill: "#DBEAFE"
        style.stroke: "#2563EB"
      }
      verdict: {
        label: "VERDICT: SYMMETRIC"
        style: {
          fill: "#BFDBFE"
          stroke: "#2563EB"
          bold: true
        }
      }
      note: "Zero-centered weights; symmetric is hardware optimal."
    }
    
    embed_case: {
      label: "Embedding Vectors"
      width: 320
      visual: {
        shape: rectangle
        height: 60
        label: "Domain: Arbitrary [a, b]"
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
      }
      verdict: {
        label: "VERDICT: ASYMMETRIC"
        style: {
          fill: "#FECACA"
          stroke: "#DC2626"
          bold: true
        }
      }
      note: "Highly skewed ranges; asymmetric reduces quantization error."
    }
  }
}

summary_table: {
  label: "Comparative Analysis Summary"
  table: |'md
    | Aspect | Symmetric Quantization | Asymmetric Quantization |
    | :--- | :--- | :--- |
    | **Zero-point** | Fixed at 0 | Computed dynamically |
    | **Quantization Type** | Uniform Symmetric | Uniform Asymmetric |
    | **Arithmetic Complexity** | Low (Scale multiplication only) | Medium (Subtract ZP, then Scale) |
    | **Effective Range** | -127 to 127 (INT8) | 0 to 255 (UINT8) |
    | **Hardware Support** | DSP/TPU Optimized | General Purpose / CPU |
  '|
  shape: rectangle
  style: {
    fill: "#F1F5F9"
    stroke: "#475569"
    border-radius: 4
  }
}

legend: {
  label: "Legend: 🔵 Symmetric Path | 🟡 Asymmetric Path | 🟢 Efficient for ReLU | 🔴 High Dynamic Range"
  shape: rectangle
  style: {
    stroke-dash: 5
    fill: transparent
  }
}

header -> row_comparison: "Architecture Decision"
row_comparison -> distribution_section: "Heuristics"
distribution_section -> summary_table: "Final Specification"

legend.near: bottom-center
header.near: top-center