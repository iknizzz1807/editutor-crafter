          │ tok[1] → [e e e ... e]  │
          │ tok[2] → [e e e ... e]  │
          │    ...                  │
          │ tok[50256] → [e e e e]  │
          └─────────────────────────┘
               ↑ dim=0 (vocab entries)
          
        |
      }
