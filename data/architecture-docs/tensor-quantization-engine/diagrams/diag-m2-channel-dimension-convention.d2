          ┌─────────────────────────────┐
          │ ch[0] → [3×3 kernel ×128]   │
          │ ch[1] → [3×3 kernel ×128]   │
          │ ch[2] → [3×3 kernel ×128]   │
          │    ...                      │
          │ ch[63] → [3×3 kernel ×128]  │
          └─────────────────────────────┘
               ↑ dim=0 (CHANNELS)
          
        |
      }
