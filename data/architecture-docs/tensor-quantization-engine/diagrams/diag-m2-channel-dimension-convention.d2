    conv_tensor: {
      shape: sql_table
      label: "Weight Tensor Shape"
      d0: "0 | dim=0 | out_channels (CHANNELS)"
      d1: "1 | dim=1 | in_channels"
      d2: "2 | dim=2 | kernel_height"
      d3: "3 | dim=3 | kernel_width"
      note: "Shape: [out_ch, in_ch, kH, kW]"
    }
    conv_visual: {
      label: "Visual: [64, 128, 3, 3]"
