  }
}
row_why: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  why_section: {
    direction: down
    label: "Why Output Dimension (dim=0)?"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    width: 400
    explanation: {
      label: |md
        **Matrix Multiplication: Y = X @ W.T**
        For output element Y[b, c]:
        
        Y[b,c] = Σ X[b,i] × W[c,i]
        
        Output Y[c] depends on **row c** of W.
        During quantized inference:
        
        Y[b,c] = Σ X[b,i] × scale_c × (Q[c,i] - zp_c)
        
        We need `scale_c` and `zp_c` per **output channel**.
      |
      shape: rectangle
      style.fill: white
    }
    formula_box: {
      label: |md
        **Per-Channel Scale Application:**
        
        scales: [C_out] → [C_out, 1] (broadcast)
        W_dequant = scales * (Q - zeros)
        
      |
      shape: rectangle
      style: {
        fill: "#FFF9C4"
        stroke: "#FBC02D"
        font: mono
      }
    }
  }
  broadcast_section: {
    direction: down
    label: "Broadcasting Trick"
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
    width: 400
    broadcast_code: {
      label: |'python
# For [C_out, C_in] weight matrix
# with per-channel scales [C_out]
# Reshape for broadcasting
scales_bc = scales.view(C_out, 1)
# Result: [C_out, 1]
# Now division works per-row
quantized = torch.round(weight / scales_bc)
# Each row divided by its own scale!
# All in one efficient tensor operation
      '|
      shape: rectangle
      style: {
        fill: "#263238"
        font-color: "#ECEFF1"
        font: mono
      }
    }
    broadcast_annot: {
      label: "Single tensor op, not a loop!"
      style: {
        fill: "#C8E6C9"
        bold: true
      }
    }
  }
}
row_warning: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  warning_section: {
    direction: down
    label: "⚠️ Common Pitfalls"
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
    }
    width: 400
    pitfall1: {
      label: |md
        **Pitfall 1: Wrong Dimension**
        Using dim=1 (input features) instead of dim=0
        → Scales don't match output channels
        → Wrong dequantization, garbage outputs
      |
      style.fill: "#FFCDD2"
    }
    pitfall2: {
      label: |md
        **Pitfall 2: Shape Mismatch**
        For Conv2d: scales must broadcast to [C_out, C_in, kH, kW]
        → Use `.view(C_out, 1, 1, 1)` not `.view(C_out, 1)`
      |
      style.fill: "#FFCDD2"
    }
    pitfall3: {
      label: |md
        **Pitfall 3: Embedding Confusion**
        Embeddings are lookups, not matmuls
        → Per-"channel" doesn't make sense
        → Usually kept in FP16 or FP32
      |
      style.fill: "#FFCDD2"
    }
  }
  summary_section: {
    direction: down
    label: "Summary: Channel Dimension Rules"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
    width: 400
    summary_table: {
      shape: sql_table
      label: "Quick Reference"
      layer: "Layer Type | Channel Dim | Scale Shape"
      linear: "Linear | dim=0 | [out_features]"
      conv1d: "Conv1d | dim=0 | [out_channels]"
      conv2d: "Conv2d | dim=0 | [out_channels]"
      conv3d: "Conv3d | dim=0 | [out_channels]"
      embed: "Embedding | N/A | (don't quantize)"
    }
    key_insight: {
      label: |md
        **Key Insight:** Output dimension = channel dimension
        Because: Y[c] = f(W[c, :], X)
        Each output channel has its own row of weights,
        so each output channel needs its own scale.
      |
      style: {
        fill: "#FFF9C4"
        stroke: "#FBC02D"
        bold: true
      }
    }
  }
}
