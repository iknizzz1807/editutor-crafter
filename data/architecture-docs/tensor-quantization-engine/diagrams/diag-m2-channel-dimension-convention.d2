    linear_tensor: {
      shape: sql_table
      label: "Weight Tensor Shape"
      d0: "0 | dim=0 | out_features (CHANNELS)"
      d1: "1 | dim=1 | in_features"
      note: "Shape: [out_features, in_features]"
    }
    linear_visual: {
      label: "Visual: [512, 768]"
      width: 280
      shape_box: {
        label: |md
          
          ┌─────────────────────────┐
          │ ch[0] → [w w w ... w]   │  ← row 0
          │ ch[1] → [w w w ... w]   │  ← row 1
          │ ch[2] → [w w w ... w]   │  ← row 2
          │    ...                  │
          │ ch[511] → [w w w ... w] │  ← row 511
          └─────────────────────────┘
               ↑ dim=0 (CHANNELS)
                    ↑ dim=1 (768 cols)
          
        |
      }
    }
    linear_annot: {
      label: "Per-Channel Scale: scales[512]"
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
