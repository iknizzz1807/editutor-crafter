direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Weight Distribution Variance Across Output Channels"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: {
  label: "16 sampled output channels from Linear(1024, 1024) layer"
  near: top-center
  style: {
    font-size: 16
    italic: true
  }
}
# Container for all violin plots - row-based layout
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  # Channel 0 - narrow distribution
  ch0: {
    label: "Ch 0"
    style.fill: transparent
    v0_high: {
      label: ""
      shape: circle
      width: 8
      height: 8
      style.fill: "#A8D5BA"
      style.stroke: "#2D6A4F"
    }
    v0_mid1: {
      label: ""
      shape: circle
      width: 24
      height: 24
      style.fill: "#A8D5BA"
      style.stroke: "#2D6A4F"
    }
    v0_center: {
      label: "0.08"
      shape: circle
      width: 36
      height: 36
      style.fill: "#A8D5BA"
      style.stroke: "#2D6A4F"
    }
    v0_mid2: {
      label: ""
      shape: circle
      width: 24
      height: 24
      style.fill: "#A8D5BA"
      style.stroke: "#2D6A4F"
    }
    v0_low: {
      label: ""
      shape: circle
      width: 8
      height: 8
      style.fill: "#A8D5BA"
      style.stroke: "#2D6A4F"
    }
    v0_top: {
      label: "0.10"
      shape: text
      style.font-size: 10
      style.font-color: "#2D6A4F"
    }
    v0_bot: {
      label: "-0.09"
      shape: text
      style.font-size: 10
      style.font-color: "#2D6A4F"
    }
    v0_top -> v0_high -> v0_mid1 -> v0_center -> v0_mid2 -> v0_low -> v0_bot
  }
  # Channel 1 - medium distribution
  ch1: {
    label: "Ch 1"
    style.fill: transparent
    v1_high: {
      label: ""
