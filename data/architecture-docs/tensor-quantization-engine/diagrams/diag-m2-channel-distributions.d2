      style.font-color: "#4A7C2E"
    }
    v14_bot: {
      label: "-0.20"
      shape: text
      style.font-size: 10
      style.font-color: "#4A7C2E"
    }
    v14_top -> v14_high -> v14_mid1 -> v14_center -> v14_mid2 -> v14_low -> v14_bot
  }
  # Channel 15 - widest (dominates per-tensor scale)
  ch15: {
    label: "Ch 15"
    style.fill: transparent
    style.stroke: "#8B0000"
    v15_high: {
      label: ""
      shape: circle
      width: 20
      height: 20
      style.fill: "#FF9999"
      style.stroke: "#8B0000"
      style.stroke-width: 3
    }
    v15_mid1: {
      label: ""
      shape: circle
      width: 72
      height: 72
      style.fill: "#FF9999"
      style.stroke: "#8B0000"
      style.stroke-width: 3
    }
    v15_center: {
      label: "1.85"
      shape: circle
      width: 90
      height: 90
      style.fill: "#FF9999"
      style.stroke: "#8B0000"
      style.stroke-width: 3
    }
    v15_mid2: {
      label: ""
      shape: circle
      width: 72
      height: 72
      style.fill: "#FF9999"
      style.stroke: "#8B0000"
      style.stroke-width: 3
    }
    v15_low: {
      label: ""
      shape: circle
      width: 20
      height: 20
      style.fill: "#FF9999"
      style.stroke: "#8B0000"
      style.stroke-width: 3
    }
    v15_top: {
      label: "2.10"
      shape: text
      style.font-size: 11
      style.font-color: "#8B0000"
      style.bold: true
    }
    v15_bot: {
      label: "-2.05"
      shape: text
      style.font-size: 11
      style.font-color: "#8B0000"
      style.bold: true
    }
    v15_top -> v15_high -> v15_mid1 -> v15_center -> v15_mid2 -> v15_low -> v15_bot
  }
}
# Summary statistics panel
stats_panel: {
  label: "Distribution Statistics (per_channel_quantization.c)"
  style: {
    fill: "#F5F5F5"
    stroke: "#333333"
    stroke-width: 2
    border-radius: 8
  }
  summary_table: {
    shape: sql_table
    label: "Channel Range Analysis"
    narrow: "Narrow channels | [-0.05, 0.11] | 4/16 (25%)"
    medium: "Medium channels | [-0.35, 0.55] | 6/16 (37.5%)"
    wide: "Wide channels | [-0.78, 0.85] | 3/16 (18.75%)"
    outlier: "Outlier channels | [-2.05, 2.10] | 3/16 (18.75%)"
    per_tensor: "Per-tensor range | [-2.05, 2.10] | scale=0.0165"
    per_channel: "Per-channel scales | [0.0004, 0.0165] | optimal"
  }
}
# Problem illustration
problem_box: {
  label: "The Per-Tensor Quantization Problem"
  style: {
    fill: "#FFF0F0"
    stroke: "#C41E3A"
    stroke-width: 2
    border-radius: 8
  }
  problem_text: |md
    **Per-tensor scale forced to cover [-2.05, 2.10]**
    - Scale: `0.0165` (INT8 range / 255)
    - Channel 2 (range ±0.05): Only **6 quantization levels** used
    - Channel 15 (range ±2.05): Uses **~248 quantization levels**
    - **Precision waste: 97.5%** for narrow channels
    **Solution: Per-channel quantization**
    - Each channel gets its own scale
    - Channel 2: scale = 0.0004 (uses all 256 levels)
    - Channel 15: scale = 0.0165 (uses all 256 levels)
    - Storage overhead: 0.26% of weight memory
  |
}
row4 -> stats_panel
stats_panel -> problem_box
# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#CCCCCC"
    border-radius: 4
  }
  legend_title: {
    label: "Legend"
    style: {
      bold: true
      font-size: 14
    }
  }
  legend_narrow: {
    label: ""
    shape: circle
    width: 20
    height: 20
    style.fill: "#A8D5BA"
    style.stroke: "#2D6A4F"
  }
  legend_narrow_text: "Narrow distribution (victim of per-tensor)"
  legend_wide: {
    label: ""
    shape: circle
    width: 30
    height: 30
    style.fill: "#B8D4E8"
    style.stroke: "#1E6091"
  }
  legend_wide_text: "Medium distribution"
  legend_outlier: {
    label: ""
    shape: circle
    width: 40
    height: 40
    style.fill: "#FF9999"
    style.stroke: "#8B0000"
    style.stroke-width: 2
  }
  legend_outlier_text: "Outlier channel (dominates per-tensor scale)"
  legend_narrow_text -> legend_narrow
  legend_wide_text -> legend_wide
  legend_outlier_text -> legend_outlier
}