direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Per-Tensor vs Per-Channel Scale Storage {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_comparison: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  per_tensor: {
    direction: down
    label: "Per-Tensor Quantization"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    pt_weight: {
      label: "Weight Matrix W\n[1024 × 4096]"
      shape: rectangle
      width: 280
      height: 160
      style: {
        fill: "#F5E6D3"
        stroke: "#D4A574"
        stroke-width: 2
      }
      pt_w_note: "INT8 Weights: 4,194,304 bytes\n≈ 4.0 MB"
      pt_w_note.style.font-size: 14
    }
    pt_params: {
      direction: right
      label: "Quantization\nParameters"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      pt_scale: {
        label: "scale\n(float32)"
        shape: rectangle
        width: 80
        height: 50
        style.fill: "#C3E6CB"
      }
      pt_zp: {
        label: "zero_point\n(int32)"
        shape: rectangle
        width: 80
        height: 50
        style.fill: "#C3E6CB"
      }
    }
    pt_storage: {
      label: "Total Parameter Storage\nscale: 4 bytes + zero_point: 4 bytes = 8 bytes"
      shape: rectangle
      width: 260
      style: {
        fill: "#FFF3CD"
        stroke: "#856404"
        stroke-dash: 3
      }
    }
  }
  per_channel: {
    direction: down
    label: "Per-Channel Quantization"
    style.fill: "#F0E6F6"
    style.stroke: "#6B4C9A"
    pc_weight: {
      label: "Weight Matrix W\n[1024 × 4096]"
      shape: rectangle
      width: 280
      height: 160
      style: {
        fill: "#F5E6D3"
        stroke: "#D4A574"
        stroke-width: 2
      }
      pc_w_note: "INT8 Weights: 4,194,304 bytes\n≈ 4.0 MB (same)"
      pc_w_note.style.font-size: 14
    }
    pc_params: {
      direction: down
      label: "Per-Channel Parameters"
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
      pc_channel_row: {
        direction: right
        ch0: {
          label: "ch0"
          shape: rectangle
          width: 45
          height: 35
          style.fill: "#C3E6CB"
          style.font-size: 10
        }
        ch1: {
          label: "ch1"
          shape: rectangle
          width: 45
          height: 35
          style.fill: "#B8D4B8"
          style.font-size: 10
        }
        ch2: {
          label: "..."
          shape: rectangle
          width: 35
          height: 35
          style.fill: "#ADD6AD"
          style.font-size: 10
        }
        ch1023: {
          label: "ch1023"
          shape: rectangle
          width: 50
          height: 35
          style.fill: "#A3C8A3"
          style.font-size: 10
        }
      }
      pc_legend: "scale[i] + zero_point[i] for each output channel i"
      pc_legend.style.font-size: 11
      pc_legend.style.italic: true
    }
    pc_storage: {
      label: "Total Parameter Storage\n1024 scales + 1024 zero_points = 8,192 bytes"
      shape: rectangle
      width: 260
      style: {
        fill: "#FFF3CD"
        stroke: "#856404"
        stroke-dash: 3
      }
    }
  }
}
overhead_comparison: {
  direction: right
  label: "Storage Overhead Analysis"
  style: {
    fill: "#F8F9FA"
    stroke: "#6C757D"
    stroke-width: 2
  }
  overhead_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    overhead_pt: {
      label: "Per-Tensor\nOverhead"
      shape: rectangle
      width: 150
      style.fill: "#E8F4FD"
      pt_val: "8 bytes total\n0.00019% of weights"
      pt_val.style.font-size: 12
      pt_val.style.bold: true
    }
    overhead_pc: {
      label: "Per-Channel\nOverhead"
      shape: rectangle
      width: 150
      style.fill: "#F0E6F6"
      pc_val: "8,192 bytes total\n0.195% of weights"
      pc_val.style.font-size: 12
      pc_val.style.bold: true
    }
    overhead_diff: {
      label: "Difference"
      shape: rectangle
      width: 150
      style.fill: "#D4EDDA"
      diff_val: "8,184 bytes\n≈ 8 KB extra"
      diff_val.style.font-size: 12
      diff_val.style.bold: true
    }
  }
  conclusion: {
    label: |md
      **Key Insight**: Per-channel adds only **8 KB** overhead to a **4 MB** weight matrix.
      That's **0.2% extra storage** for potentially **30-50% MSE reduction**.
      The overhead is **negligible** for any practical layer size.
    |
    shape: rectangle
    width: 520
    style: {
      fill: "#E2F0D9"
      stroke: "#548235"
    }
  }
}
arrow_pt_to_overhead: per_tensor -> overhead_comparison.overhead_pt: "compare" {
  style.stroke-dash: 3
  style.stroke: "#6C757D"
}
arrow_pc_to_overhead: per_channel -> overhead_comparison.overhead_pc: "compare" {
  style.stroke-dash: 3
  style.stroke: "#6C757D"
}