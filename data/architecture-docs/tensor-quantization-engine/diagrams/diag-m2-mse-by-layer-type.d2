direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # MSE Comparison: Per-Tensor vs Per-Channel by Layer Type
  |
  near: top-center
  shape: text
  style.font-size: 28
}
y_axis_label: {
  label: "MSE (Mean Squared Error)"
  near: center-left
  shape: text
  style.font-size: 18
}
chart: {
  style.fill: transparent
  style.stroke: "#E5E7EB"
  y_axis: {
    label: ""
    style.fill: transparent
    style.stroke: "#9CA3AF"
  }
  x_axis: {
    label: "Layer Type"
    style.fill: transparent
    style.stroke: "#9CA3AF"
  }
  embedding_group: {
    label: "Embedding\nLayers"
    style.fill: transparent
    style.stroke: transparent
    pt_bar: {
      label: "PT"
      shape: rectangle
      width: 60
      height: 120
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
    }
    pc_bar: {
      label: "PC"
      shape: rectangle
      width: 60
      height: 108
      style.fill: "#22C55E"
      style.stroke: "#16A34A"
    }
  }
  linear_early_group: {
    label: "Linear\n(Early)"
    style.fill: transparent
    style.stroke: transparent
    pt_bar: {
      label: "PT"
      shape: rectangle
      width: 60
      height: 180
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
    }
    pc_bar: {
      label: "PC"
      shape: rectangle
      width: 60
      height: 100
      style.fill: "#22C55E"
      style.stroke: "#16A34A"
    }
  }
  linear_late_group: {
    label: "Linear\n(Late)"
    style.fill: transparent
    style.stroke: transparent
    pt_bar: {
      label: "PT"
      shape: rectangle
      width: 60
      height: 280
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
    }
    pc_bar: {
      label: "PC"
      shape: rectangle
      width: 60
      height: 80
      style.fill: "#22C55E"
      style.stroke: "#16A34A"
    }
  }
  conv2d_group: {
    label: "Conv2d\nLayers"
    style.fill: transparent
    style.stroke: transparent
    pt_bar: {
      label: "PT"
      shape: rectangle
      width: 60
      height: 200
      style.fill: "#EF4444"
      style.stroke: "#DC2626"
    }
    pc_bar: {
      label: "PC"
      shape: rectangle
      width: 60
      height: 90
      style.fill: "#22C55E"
      style.stroke: "#16A34A"
    }
  }
}
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent
  pt_legend: {
    label: "Per-Tensor"
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#EF4444"
    style.stroke: "#DC2626"
  }
  pc_legend: {
    label: "Per-Channel"
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#22C55E"
    style.stroke: "#16A34A"
  }
}
insights: {
  near: bottom-right
  style.fill: "#FEF3C7"
  style.stroke: "#F59E0B"
  style.border-radius: 8
  insight_title: "Key Insight"
  insight_text: {
    label: |md
      **Late Linear layers** show 3.5x MSE reduction with per-channel
      quantization due to higher channel variance.
      **Embedding layers** benefit least (~10% improvement) as weight
      distributions are more uniform across dimensions.
    |
    shape: text
  }
}
data_table: {
  shape: sql_table
  label: "MSE Values (×10⁻⁶)"
  layer_type: "Layer Type | Per-Tensor | Per-Channel | Improvement"
  embedding: "Embedding | 2.4 | 2.16 | 10%"
  linear_early: "Linear (Early) | 3.8 | 1.9 | 50%"
  linear_late: "Linear (Late) | 6.2 | 1.1 | 82%"
  conv2d: "Conv2d | 4.5 | 1.8 | 60%"
  note: "Lower MSE = Better quantization quality"
}
chart.embedding_group -> chart.linear_early_group
chart.linear_early_group -> chart.linear_late_group
chart.linear_late_group -> chart.conv2d_group