direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |md
    # Activation Function Impact on Quantization Distribution
    How ReLU, GELU, and SiLU shape activation statistics and calibration strategy
  |
  style.stroke: transparent
  style.fill: transparent
}
title.near: top-center

row_distributions: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  relu_block: {
    direction: down
    label: "ReLU: f(x) = max(0, x) (activation.c)"
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    
    relu_formula: {
      shape: code
      code: |'python
        def relu(x):
            return max(0, x)
      '|
    }

    relu_dist: {
      shape: sql_table
      label: "ReLU Output Distribution"
      p1: "0x01 | Range      | [0, +inf)"
      p2: "0x02 | Mean       | > 0 (Positive shift)"
      p3: "0x03 | Mode       | 0 (Spike at zero)"
      p4: "0x04 | Skewness   | High (Right-tailed)"
      p5: "0x05 | Sparsity   | ~50% zeros"
      note: "Asymmetric: ALL POSITIVE"
    }

    relu_cal: {
      label: "Recommended Calibration"
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      content: |'md
        **ASYMMETRIC Quantization**
        - Range: [0, r_max] maps to [0, 255]
        - Zero-point: non-zero integer
        - Scale: r_max / 255
      '|
    }
  }

  gelu_block: {
    direction: down
    label: "GELU: f(x) = x * Φ(x) (activation.c)"
    style.fill: "#F0F0FF"
    style.stroke: "#0000CC"
    
    gelu_formula: {
      shape: code
      code: |'python
        def gelu(x):
            return x * 0.5 * (1 + erf(x / sqrt(2)))
      '|
    }

    gelu_dist: {
      shape: sql_table
      label: "GELU Output Distribution"
      p1: "0x01 | Range      | (-0.17, +inf)"
      p2: "0x02 | Mean       | ~0 (Near symmetric)"
      p3: "0x03 | Mode       | near 0 (Smooth)"
      p4: "0x04 | Skewness   | Low (Quasi-symmetric)"
      p5: "0x05 | Sparsity   | ~0% (No hard zeros)"
      note: "Near-Symmetric around 0"
    }

    gelu_cal: {
      label: "Recommended Calibration"
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      content: |'md
        **SYMMETRIC Quantization**
        - Range: [-max, +max] maps to [-127, 127]
        - Zero-point: exactly 0
        - Scale: max(|r_min|, |r_max|) / 127
      '|
    }
  }

  silu_block: {
    direction: down
    label: "SiLU/Swish: f(x) = x * σ(x) (activation.c)"
    style.fill: "#F0FFF0"
    style.stroke: "#006600"
    
    silu_formula: {
      shape: code
      code: |'python
        def silu(x):
            return x * sigmoid(x)
      '|
    }

    silu_dist: {
      shape: sql_table
      label: "SiLU Output Distribution"
      p1: "0x01 | Range      | (-0.28, +inf)"
      p2: "0x02 | Mean       | ~0 (Near symmetric)"
      p3: "0x03 | Mode       | near 0 (Smooth peak)"
      p4: "0x04 | Skewness   | Low (Quasi-symmetric)"
      p5: "0x05 | Sparsity   | ~0% (Soft threshold)"
      note: "Near-Symmetric around 0"
    }

    silu_cal: {
      label: "Recommended Calibration"
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      content: |'md
        **SYMMETRIC Quantization**
        - Range: [-max, +max] maps to [-127, 127]
        - Zero-point: exactly 0
        - Scale: max(|r_min|, |r_max|) / 127
      '|
    }
  }
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  comparison_matrix: {
    shape: sql_table
    label: "Quantization Decision Matrix (Calibration Plan)"
    h1: "Activation | Symmetry | Recommended Mode | Zero-Point | Correction"
    r1: "ReLU | ASYMMETRIC | Asymmetric INT8/UINT8 | zp != 0 | Required"
    r2: "GELU | SYMMETRIC | Symmetric INT8 | zp = 0 | None"
    r3: "SiLU | SYMMETRIC | Symmetric INT8 | zp = 0 | None"
    note: "Symmetric mode preferred for hardware acceleration (TensorCores/DSP)"
  }

  key_insight: {
    label: "Quantization Engineering Notes"
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    content: |'md
      **Hardware & Performance Impact:**
      1. **ReLU (Asymmetric):** Forces the use of the `(q - zp)` term in MAC operations. 
         This adds 1 extra addition per product, increasing latency.
      2. **GELU/SiLU (Symmetric):** Zero-point is 0. MAC becomes `q_w * q_x`, 
         enabling "Fast Path" SIMD kernels.
      3. **Calibration Data:** ReLU requires asymmetric min/max tracking 
         (usually [0, max]). GELU/SiLU require symmetric tracking.
    '|
  }
}

row_visual: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  relu_vis: {
    label: "ReLU Distribution (Histogram)"
    style.fill: "#FFCDD2"
    content: |'md
      Freq
      ^  ████
      |  ████
      |  ████  High Zero Spike
      | ██████
      |█████████████████
      +-------------------> Val
      0
    '|
  }

  gelu_vis: {
    label: "GELU Distribution (Histogram)"
    style.fill: "#BBDEFB"
    content: |'md
      Freq
      ^      ████
      |     ██████
      |    ████████  Bell Curve
      |   ██████████
      |  ████████████
      +-------------------> Val
         -0.2  0  +0.2
    '|
  }

  silu_vis: {
    label: "SiLU Distribution (Histogram)"
    style.fill: "#C8E6C9"
    content: |'md
      Freq
      ^      ████
      |     ██████
      |    ████████  Symmetric
      |   ██████████
      |  ████████████
      +-------------------> Val
         -0.3  0  +0.3
    '|
  }
}

summary_box: {
  label: "Calibration Strategy Summary"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  content: |'md
    ## Calibration Logic Flow
    
    1. **Identify Activation:** 
       - If ReLU: Collect `max` only -> Set `min=0` -> Map to `[0, 255]`.
       - If GELU/SiLU: Collect `abs_max` -> Set `range = [-abs_max, abs_max]`.
    
    2. **Compute Scale ($S$):**
       - Asymmetric: $S = (max - min) / (2^n - 1)$
       - Symmetric: $S = max(|min|, |max|) / (2^{n-1} - 1)$
    
    3. **Set Zero Point ($Z$):**
       - Asymmetric: $Z = round(-min/S)$
       - Symmetric: $Z = 0$
  '|
}

legend: {
  shape: rectangle
  label: |'md
    **Color Legend:**
    🔴 Red = Asymmetric / ReLU Path (Positive only)
    🔵 Blue = Symmetric / GELU Path
    🟢 Green = Symmetric / SiLU Path / Optimal Path
  '|
  style.fill: "#FFFFFF"
  style.stroke: "#CCCCCC"
}
legend.near: bottom-right

row_distributions -> row_comparison: "Statistics | generate plan"
row_comparison -> row_visual: "Plan | validate shift"
row_visual -> summary_box: "Final Params"