direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Calibration Dataset Size vs Accuracy Stability
  Line graph showing accuracy variance convergence with increasing calibration samples
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  graph_container: {
    direction: down
    label: ""
    y_axis: {
      shape: rectangle
      width: 60
      height: 280
      style.fill: transparent
      style.stroke: transparent
      y_title: |md
        **Accuracy**
        **Variance**
        **(σ²)**
      | {
        width: 50
      }
      y_high: "0.0015" {style.fill: transparent; style.stroke: transparent}
      y_mid: "0.0010" {style.fill: transparent; style.stroke: transparent}
      y_low: "0.0005" {style.fill: transparent; style.stroke: transparent}
      y_zero: "0.0000" {style.fill: transparent; style.stroke: transparent}
    }
    plot_area: {
      shape: rectangle
      width: 480
      height: 280
      style.fill: "#fafafa"
      style.stroke: "#cccccc"
      style.stroke-width: 1
      # Grid lines (horizontal)
      grid_high: {
        shape: rectangle
        width: 480
        height: 1
        style.fill: "#e0e0e0"
        style.stroke: transparent
      }
      grid_mid: {
        shape: rectangle
        width: 480
        height: 1
        style.fill: "#e0e0e0"
        style.stroke: transparent
      }
      grid_low: {
        shape: rectangle
        width: 480
        height: 1
        style.fill: "#e0e0e0"
        style.stroke: transparent
      }
      # Data points on the variance curve
      p10: {
        shape: circle
        width: 16
        style.fill: "#e74c3c"
        style.stroke: "#c0392b"
        style.stroke-width: 2
        tooltip: "10 samples: High variance (σ² = 0.00145)"
      }
      p50: {
        shape: circle
        width: 14
        style.fill: "#e67e22"
        style.stroke: "#d35400"
        style.stroke-width: 2
        tooltip: "50 samples: Medium-high variance (σ² = 0.00085)"
      }
      p100: {
        shape: circle
        width: 12
        style.fill: "#f39c12"
        style.stroke: "#d68910"
        style.stroke-width: 2
        tooltip: "100 samples: Convergence begins (σ² = 0.00035)"
      }
      p500: {
        shape: circle
        width: 12
        style.fill: "#27ae60"
        style.stroke: "#1e8449"
        style.stroke-width: 2
        tooltip: "500 samples: Stable (σ² = 0.00012)"
      }
      p1000: {
        shape: circle
        width: 12
        style.fill: "#2980b9"
        style.stroke: "#1f618d"
        style.stroke-width: 2
        tooltip: "1000 samples: Fully stable (σ² = 0.00008)"
      }
      # Variance curve (approximated as connected segments)
      curve_segment1: "Variance Curve" {
        shape: rectangle
        width: 80
        height: 2
        style.fill: "#3498db"
        style.stroke: transparent
      }
      curve_segment2: {
        shape: rectangle
        width: 80
        height: 2
        style.fill: "#3498db"
        style.stroke: transparent
      }
      curve_segment3: {
        shape: rectangle
        width: 120
        height: 2
        style.fill: "#3498db"
        style.stroke: transparent
      }
      curve_segment4: {
        shape: rectangle
        width: 120
        height: 2
        style.fill: "#3498db"
        style.stroke: transparent
      }
      curve_tail: {
        shape: rectangle
        width: 80
        height: 1
        style.fill: "#3498db"
        style.stroke: transparent
      }
      # Convergence zone highlight
      convergence_zone: {
        shape: rectangle
        width: 180
        height: 60
        style.fill: "#d5f5e3"
        style.stroke: "#27ae60"
        style.stroke-width: 2
        style.stroke-dash: 4
        style.opacity: 0.5
        label: "Convergence Zone\n(100-500 samples)"
      }
    }
    x_axis: {
      shape: rectangle
      width: 480
      height: 40
      style.fill: transparent
      style.stroke: transparent
      x_title: |md
        **Calibration Dataset Size (samples)**
      | {
        width: 200
      }
      x10: "10" {style.fill: transparent; style.stroke: transparent}
      x50: "50" {style.fill: transparent; style.stroke: transparent}
      x100: "100" {style.fill: transparent; style.stroke: transparent}
      x500: "500" {style.fill: transparent; style.stroke: transparent}
      x1000: "1000" {style.fill: transparent; style.stroke: transparent}
    }
  }
}
