direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    cool_low: "#E3F2FD"
    cool_mid: "#64B5F6"
    cool_high: "#1565C0"
    hot_low: "#FFF3E0"
    hot_mid: "#FF9800"
    hot_high: "#E65100"
    outlier: "#D32F2F"
    grid: "#E0E0E0"
  }
}

title: |md
  # Per-Layer Activation Statistics Heatmap
  **Calibration Pipeline: Layer-wise Distribution Analysis**
|
title.near: top-center

# Main visualization row
row_header: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  heatmap_container: {
    label: "Activation Distribution Heatmap"
    direction: right
    
    # Left Axis labels and scale
    y_axis_group: {
      style.stroke: transparent
      style.fill: transparent
      y_axis_label: "Value" {
        shape: text
        style.bold: true
      }
      y_scale: {
        style.fill: transparent
        style.stroke: transparent
        y_max: "+50.0" { shape: text }
        y_p99: "+5.0" { shape: text }
        y_p90: "+1.0" { shape: text }
        y_mean: "0.0" { shape: text; style.bold: true }
        y_p10: "-1.0" { shape: text }
        y_min: "-50.0" { shape: text }
      }
    }

    # Main heatmap grid
    heatmap: {
      direction: right
      style.fill: white
      style.stroke: ${colors.grid}
      
      layer_0: "L0\nEmbed" {
        style.fill: ${colors.cool_low}
        width: 60
        height: 200
      }
      layer_1: "L1\nAttn" {
        style.fill: ${colors.cool_mid}
        width: 60
        height: 200
      }
      layer_2: "L2\nFFN" {
        style.fill: ${colors.cool_high}
        width: 60
        height: 200
      }
      layer_3: "L3\nAttn" {
        style.fill: ${colors.cool_mid}
        width: 60
        height: 200
      }
      layer_4: "L4\nFFN" {
        style.fill: ${colors.hot_mid}
        width: 60
        height: 200
      }
      layer_5: "L5\nAttn" {
        style.fill: ${colors.cool_mid}
        width: 60
        height: 200
      }
      layer_6: "L6\nFFN" {
        style.fill: ${colors.hot_high}
        width: 60
        height: 200
      }
      layer_7: "L7\nOut" {
        style.fill: ${colors.outlier}
        width: 60
        height: 200
      }
    }
  }

  legend_container: {
    label: "Legend & Statistics"
    style.fill: "#F5F5F5"
    style.stroke: ${colors.grid}
    width: 280
    
    freq_legend: "Color Intensity = Frequency" {
      shape: text
      style.bold: true
    }
    freq_low: "■ Rare (outliers)" {
      shape: text
      style.font-color: ${colors.outlier}
    }
    freq_mid: "■ Moderate frequency" {
      shape: text
      style.font-color: ${colors.hot_mid}
    }
    freq_high: "■ High frequency" {
      shape: text
      style.font-color: ${colors.cool_mid}
    }
    freq_dense: "■ Dense region" {
      shape: text
      style.font-color: ${colors.cool_high}
    }

    stats: {
      style.fill: white
      style.stroke: ${colors.grid}
      stat_title: "Key Statistics:" {
        shape: text
        style.bold: true
      }
      stat_1: "• L0 (Embed): range [-2.1, +2.3]" { shape: text }
      stat_2: "• L6 (FFN): WIDE range [-45.2, +50.1]" {
        shape: text
        style.font-color: ${colors.outlier}
      }
      stat_3: "• L7 (Output): OUTLIERS detected" {
        shape: text
        style.font-color: ${colors.outlier}
      }
      stat_4: "• Most layers: well-behaved" {
        shape: text
        style.font-color: green
      }
    }

    recommendation: {
      style.fill: "#FFF3E0"
      style.stroke: ${colors.hot_mid}
      rec_title: "⚠ Calibration Recommendations:" {
        shape: text
        style.bold: true
        style.font-color: ${colors.hot_high}
      }
      rec_1: "1. Use percentile 99.9% for L6, L7" { shape: text }
      rec_2: "2. Consider keeping L7 in FP32" { shape: text }
      rec_3: "3. Monitor L6 in production" { shape: text }
    }
  }
}

# Problems & Annotations
annotation_wide: "Wide Range!\n100x typical" {
  shape: callout
  style.fill: ${colors.hot_mid}
  style.stroke: ${colors.outlier}
}
annotation_wide -> row_header.heatmap_container.heatmap.layer_6

annotation_outlier: "Outliers\nDetected" {
  shape: callout
  style.fill: ${colors.outlier}
  style.font-color: white
}
annotation_outlier -> row_header.heatmap_container.heatmap.layer_7

# Patterns summary
patterns: "Layer Pattern Analysis" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  pattern_uniform: "Uniform Distribution\n(Good for quantization)" {
    style.fill: ${colors.cool_low}
    style.stroke: ${colors.cool_mid}
    width: 200
  }
  pattern_heavy: "Heavy-Tailed\n(Needs percentile calib)" {
    style.fill: ${colors.hot_low}
    style.stroke: ${colors.hot_mid}
    width: 200
  }
  pattern_extreme: "Extreme Outliers\n(Consider FP32)" {
    style.fill: ${colors.outlier}
    style.font-color: white
    width: 200
  }
}

row_header.heatmap_container.heatmap.layer_0 -> patterns.pattern_uniform: "L0-L3" {
  style.stroke-dash: 3
  style.stroke: ${colors.cool_mid}
}
row_header.heatmap_container.heatmap.layer_6 -> patterns.pattern_heavy: "L4-L6" {
  style.stroke-dash: 3
  style.stroke: ${colors.hot_mid}
}
row_header.heatmap_container.heatmap.layer_7 -> patterns.pattern_extreme: "L7" {
  style.stroke-dash: 3
  style.stroke: ${colors.outlier}
}

footer: |md
  **Methodology**: Calibration data (N=512 samples) passed through model. Per-layer activation min/max, percentiles (P1, P50, P99, P99.9, P100) recorded. Color intensity indicates frequency of values in each bin.
|
footer.near: bottom-center