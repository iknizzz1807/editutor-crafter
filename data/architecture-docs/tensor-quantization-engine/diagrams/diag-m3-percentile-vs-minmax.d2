direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- HEADER SECTION ---
header: {
  style.stroke: transparent
  style.fill: transparent
  title: |md
    # Calibration Strategy Comparison
    ## Min/Max vs Percentile on Outlier-Heavy Distribution
  |
}
header.near: top-center

# --- ROW 1: INPUT DISTRIBUTION ---
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  histogram: {
    direction: down
    label: "Activation Value Distribution (Heavy-Tailed)"
    
    dist_desc: |'md
      **Typical LLM Activation Characteristics:**
      - 99% of values in [-2, +2] range
      - 0.1% outliers at ±50+ magnitude
      - Outlier ratio (max/p99): ~25-50x
    '|
    
    hist_visual: {
      label: "Distribution Visualization"
      style.fill: "#E8F4FD"
      
      bins_normal: {
        label: "Normal Range [-2, +2]"
        content: |md
          ███████████████
          ██████████████████
          ███████████████
        |
        style.fill: "#4A90D9"
      }
      
      bins_tail: {
        label: "Tail [+2, +50]"
        content: "░░░░░░░░"
        style.fill: "#B8D4F0"
      }
      
      outlier: {
        label: "Outlier (+50.2)"
        shape: diamond
        style.fill: "#E74C3C"
      }
    }
    
    stats: {
      shape: sql_table
      label: "Distribution Statistics"
      f1: "Mean | 0.012"
      f2: "Std | 0.89"
      f3: "Median | 0.008"
      f4: "P99 | 2.31"
      f5: "P99.9 | 48.7"
      f6: "P100 (max) | 50.2"
      f7: "Outlier ratio | 21.7x"
    }
  }
}

# --- ROW 2: CALIBRATION STRATEGIES ---
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  minmax: {
    direction: down
    label: "Min/Max Calibration (Naive)"
    style.stroke: "#C0392B"
    style.stroke-width: 3
    
    range_box: {
      label: "Calibrated Range"
      style.fill: "#FADBD8"
      
      params: {
        shape: sql_table
        label: "Quantization Parameters"
        f1: "r_min | -50.2"
        f2: "r_max | +50.2"
        f3: "scale | 0.394"
        f4: "zero_pt | 0"
      }
      
      problem: {
        label: "⚠️ UNDERFLOW ERROR"
        style.fill: "#F1948A"
        desc: |'md
          **99% of values use <5% of range!**
          Normal range [-2, 2] maps to:
          [-5, 5] (only 11 of 256 levels)
          Quantization Error is high.
        '|
      }
    }
    
    visual_rep: {
      label: "Quantization Grid"
      style.fill: "#FADBD8"
      grid: |'md
        -50  -30  -10   0   10   30   50
         |----|----|----|----|----|----|
              ↑               ↑
         Values cramped   Wasted precision
      '|
    }
  }

  percentile: {
    direction: down
    label: "99.9% Percentile Calibration (Robust)"
    style.stroke: "#27AE60"
    style.stroke-width: 3
    
    range_box: {
      label: "Calibrated Range"
      style.fill: "#D5F5E3"
      
      params: {
        shape: sql_table
        label: "Quantization Parameters"
        f1: "r_min | -48.7 (P0.1)"
        f2: "r_max | +48.7 (P99.9)"
        f3: "scale | 0.383"
        f4: "zero_pt | 0"
      }
      
      solution: {
        label: "✓ PRECISION OPTIMIZED"
        style.fill: "#82E0AA"
        desc: |'md
          **Clip 0.1% outliers, save 99.9%!**
          Dedicates the full 8-bit grid
          to the active distribution.
          Lower MSE for normal paths.
        '|
      }
    }
    
    visual_rep: {
      label: "Quantization Grid"
      style.fill: "#D5F5E3"
      grid: |'md
        -48  -28   -8    0    8   28   48
         |----|----|----|----|----|----|
              ↑                   ↑
         Well-distributed    Outliers Clipped
      '|
    }
  }
}

# --- ROW 3: COMPARISON AND INSIGHT ---
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  comparison: {
    direction: down
    label: "MSE Comparison Summary"
    
    comp_table: {
      shape: sql_table
      label: "Performance Metrics"
      h: "Metric | Min/Max | P99.9 | Result"
      r1: "Scale | 0.394 | 0.383 | 2.8% Finer"
      r2: "Normal MSE | 0.0129 | 0.0122 | 5.4% Lower"
      r3: "Outlier MSE | 0.0001 | 2.40 | Clipped"
      r4: "Clipped % | 0% | 0.1% | Negligible"
    }
  }
  
  insight_box: {
    label: "Architecture Insight"
    style.fill: "#FEF9E7"
    style.stroke: "#F4D03F"
    style.stroke-width: 2
    
    content: |'md
      ## The Outlier Paradox
      In LLMs, outliers are statistically rare but 
      magnitude-dominant. Calibrating to P100 (Max)
      wastes bits on empty space. 
      
      **Percentile wins** by treating outliers as 
      noise to be clipped, significantly boosting 
      SNR for the critical 99.9% signal.
    '|
  }
}

# --- CONNECTIONS ---
row1.histogram.hist_visual.bins_normal -> row1.histogram.hist_visual.outlier: "0.1% | rare" {
  style.stroke: "#E74C3C"
  style.stroke-dash: 3
}

row2.minmax -> row2.percentile: "Better strategy" {
  style.stroke: "#27AE60"
  style.stroke-width: 2
}

row3.comparison -> row3.insight_box: "Informs selection" {
  style.stroke: "#F4D03F"
}