direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Before/After: PTQ Model Comparison"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

comparison_row: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  before_card: {
    label: "BEFORE: FP32 Model"
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      border-radius: 8
    }
    metrics_before: {
      shape: sql_table
      label: "Model Metrics (FP32)"
      f1: "Model Size    | 1.00 GB     | baseline"
      f2: "Latency (CPU) | 45.2 ms     | baseline"
      f3: "Latency (GPU) | 12.8 ms     | baseline"
      f4: "Memory (VRAM) | 3.2 GB      | baseline"
      f5: "Accuracy      | 94.2%       | baseline"
      f6: "Perplexity    | 5.68        | baseline"
      total: "Storage: FP32 weights + FP32 activations"
    }
    storage_before: {
      label: "Storage Format"
      width: 200
      content: |'md
        **Weight Tensor** [4096, 4096]
        - Data type: `float32`
        - Bytes per weight: 4
        - Total: 67.1 MB per layer
      '|
    }
  }

  arrow_container: {
    width: 100
    style.fill: transparent
    style.stroke: transparent
    pipeline_label: {
      label: "PTQ Pipeline"
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#1565C0"
      }
    }
  }

  after_card: {
    label: "AFTER: INT8 PTQ Model"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 8
    }
    metrics_after: {
      shape: sql_table
      label: "Model Metrics (INT8 PTQ)"
      f1: "Model Size    | 0.26 GB     | -74% (3.9x smaller)"
      f2: "Latency (CPU) | 18.1 ms     | -60% (2.5x faster)"
      f3: "Latency (GPU) | 11.2 ms     | -12% (1.1x faster)"
      f4: "Memory (VRAM) | 1.1 GB      | -66% (2.9x smaller)"
      f5: "Accuracy      | 93.8%       | -0.4% (acceptable)"
      f6: "Perplexity    | 5.72        | +0.04 (minimal)"
      total: "Storage: INT8 weights + per-channel scales"
    }
    storage_after: {
      label: "Storage Format"
      width: 200
      content: |'md
        **Weight Tensor** [4096, 4096]
        - Data type: `int8` + scales
        - Bytes per weight: 1 + 0.004
        - Total: 17.0 MB per layer
      '|
    }
  }
}

hardware_row: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }

  cpu_card: {
    label: "CPU Inference (AVX2/VNNI)"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      border-radius: 8
    }
    cpu_details: {
      shape: sql_table
      label: "CPU Speedup Analysis"
      row1: "INT8 Kernels  | Available (VNNI)"
      row2: "GEMM Speedup  | 2.5 - 4.0x"
      row3: "Memory BW     | 4x less traffic"
      row4: "Overall       | 2.5x faster"
      note: "Requires: AVX2 + VNNI instructions"
    }
  }

  gpu_card: {
    label: "GPU Inference (No Tensor Cores)"
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      border-radius: 8
    }
    gpu_details: {
      shape: sql_table
      label: "GPU Speedup Analysis"
      row1: "INT8 Kernels  | Limited/Emulated"
      row2: "GEMM Speedup  | 1.0 - 1.2x"
      row3: "Memory BW     | 4x less traffic"
      row4: "Overall       | 1.1x faster"
      note: "Needs: Tensor Cores for INT8 speedup"
    }
  }

  gpu_tensor_card: {
    label: "GPU Inference (Tensor Cores)"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      border-radius: 8
    }
    gpu_tensor_details: {
      shape: sql_table
      label: "GPU + Tensor Cores Analysis"
      row1: "INT8 Kernels  | Native (TC INT8)"
      row2: "GEMM Speedup  | 2.0 - 4.0x"
      row3: "Memory BW     | 4x less traffic"
      row4: "Overall       | 2.5x faster"
      note: "Requires: RTX 20xx+ / A100 / H100"
    }
  }
}

summary_container: {
  style.stroke: transparent
  style.fill: transparent
  summary_card: {
    label: "PTQ Tradeoff Summary"
    width: 650
    style: {
      fill: "#F5F5F5"
      stroke: "#757575"
      border-radius: 8
    }
    summary_text: |'md
      | Metric | FP32 | INT8 PTQ | Change |
      | :--- | :--- | :--- | :--- |
      | **Model Size** | 1.00 GB | 0.26 GB | **-74%** |
      | **CPU Latency** | 45.2 ms | 18.1 ms | **-60%** |
      | **GPU (no TC)** | 12.8 ms | 11.2 ms | **-12%** |
      | **GPU (TC)** | 12.8 ms | 5.1 ms | **-60%** |
      | **Accuracy** | 94.2% | 93.8% | **-0.4%** |

      **Key Insight**: Memory reduction is guaranteed. Speedup requires INT8 hardware support.
    '|
  }
}

legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  item1: "TC = Tensor Cores"
  item2: "VNNI = Intel AVX-512 VNNI"
  item3: "BW = Bandwidth"
}

# Connections
comparison_row.before_card -> comparison_row.after_card: "Quantize" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
    animated: true
  }
}

comparison_row -> hardware_row: "Hardware deps"
hardware_row -> summary_container: "Aggregate"