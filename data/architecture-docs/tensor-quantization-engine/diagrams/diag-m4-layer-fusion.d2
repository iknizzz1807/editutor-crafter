direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Layer Fusion for Quantization Efficiency (fuse_layers.c)"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

row_before: {
  style.stroke: transparent
  style.fill: transparent
  
  before_section: {
    direction: down
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    style.stroke-dash: 3
    label: "BEFORE: Separate Operations (3 quant points)"
    
    input_fp32_before: "Input Tensor X" {
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    
    quant1: "Q1" {
      shape: circle
      style.fill: "#FFCDD2"
      width: 40
    }
    
    conv_before: "Conv2d (W, b)" {
      shape: rectangle
      style.fill: "#FFF9C4"
    }
    
    quant2: "Q2" {
      shape: circle
      style.fill: "#FFCDD2"
      width: 40
    }
    
    bn_before: {
      shape: sql_table
      label: "BatchNorm2d (FP32)"
      f0: "0x00 | float32 | gamma"
      f1: "0x04 | float32 | beta"
      f2: "0x08 | float32 | mean"
      f3: "0x0C | float32 | var"
      sz: "Total: 16 bytes per channel"
    }
    
    quant3: "Q3" {
      shape: circle
      style.fill: "#FFCDD2"
      width: 40
    }
    
    relu_before: "ReLU" {
      shape: diamond
      style.fill: "#C8E6C9"
    }
    
    quant4: "Q4" {
      shape: circle
      style.fill: "#FFCDD2"
      width: 40
    }
    
    output_before: "Output Y" {
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    
    input_fp32_before -> quant1: "FP32 | cast"
    quant1 -> conv_before: "INT8 | input"
    conv_before -> quant2: "INT32 | accum"
    quant2 -> bn_before: "INT8 | cast"
    bn_before -> quant3: "FP32 | normalize"
    quant3 -> relu_before: "INT8 | cast"
    relu_before -> quant4: "INT8 | activate"
    quant4 -> output_before: "INT8 | result"
  }
}

row_before -> row_after: "FOLDING | fuse layers" {
  style: {
    stroke: "#1565C0"
    stroke-width: 4
    animated: true
  }
}

row_after: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  after_section: {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    label: "AFTER: Fused Conv-BN-ReLU"
    
    input_fp32_after: "Input Tensor X" {
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    
    quant_fused: "Q" {
      shape: circle
      style.fill: "#A5D6A7"
      width: 40
    }
    
    fused_op: "FusedConvBNReLU" {
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
    }
    
    output_after: "Output Y" {
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    
    input_fp32_after -> quant_fused: "FP32 | cast"
    quant_fused -> fused_op: "INT8 | input"
    fused_op -> output_after: "INT8 | result"
  }
  
  params_section: {
    direction: down
    style.fill: "#FFF8E1"
    label: "Fused Weight Computation"
    
    fused_weight: {
      shape: sql_table
      label: "struct FusedWeight (fuse_layers.h)"
      f0: "0x00 | float32 | W_fused"
      f1: "0x04 | float32 | b_fused"
      sz: "Total: 8 bytes per weight"
    }
    
    formula_box: {
      label: "BN Folding Theory"
      width: 350
      code: |'c
        // Fold BN into Conv weights
        // factor = gamma / sqrt(var + eps)
        // W_fused = W * factor
        // b_fused = (b - mean) * factor + beta
        // Output: y = W_fused * x + b_fused
      '|
    }
    fused_weight -> formula_box: "Theory"
  }
}

comparison_row: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  benefits: {
    direction: down
    style.fill: "#E3F2FD"
    label: "Quantization Efficiency"
    
    b1: {
      label: "1. Precision"
      code: |'text
        - Only 1 quant stage
        - Minimized rounding noise
        - Better SNR for weights
      '|
    }
    b2: {
      label: "2. Throughput"
      code: |'text
        - 0 intermediate buffers
        - IO bound -> Compute bound
        - No PCIe/Bus latency
      '|
    }
  }
  
  weight_dist: {
    direction: down
    style.fill: "#FCE4EC"
    label: "Quantization Impact"
    
    dist_before: {
      label: "Native Weights"
      code: |'text
        Range: [-0.1, 0.1]
        Uniform variance
        Symmetric INT8
      '|
    }
    dist_after: {
      label: "Fused Weights"
      code: |'text
        Per-channel variance
        Requires per-channel Q
        ReLU: Use UINT8 (0-255)
      '|
    }
    dist_before -> dist_after: "Folding"
  }
}

implementation_row: {
  direction: right
  style.fill: "#F5F5F5"
  label: "Implementation Reference"
  
  code_impl: {
    label: "fold_batchnorm (fuse_layers.c)"
    width: 450
    code: |'c
      for (int c = 0; c < channels; c++) {
        float factor = gamma[c] / sqrtf(var[c] + eps);
        // Fold Conv Weights
        for (int i = 0; i < weights_per_ch; i++)
          out_w[c*n + i] = conv_w[c*n + i] * factor;
        // Fold Conv Bias
        out_b[c] = (conv_b[c] - mean[c]) * factor + beta[c];
      }
    '|
  }
  
  notes: {
    label: "Engine Specs"
    width: 280
    code: |'text
      - Stage: Pre-calibration
      - Strategy: Per-channel Q
      - Output: Asymmetric UINT8
      - Target: TensorRT / TVM
    '|
  }
}

legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  l1: "Q = Quantization Op" { shape: text }
  l2: "Red = High Noise Path" { 
    shape: text 
    style.font-color: "#C62828"
  }
  l3: "Green = Low Noise Path" { 
    shape: text 
    style.font-color: "#2E7D32"
  }
}