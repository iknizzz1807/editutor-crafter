direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Header Section
header: {
  style.stroke: transparent
  style.fill: transparent
  
  title: |'md
    # Layer Sensitivity Analysis: Which Layers to Keep FP32
  '|
  subtitle: |'md
    ### Accuracy drop (%) when quantizing each layer individually (others remain FP32)
  '|
}

# Visualization Row
visual_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  # Chart Container
  chart_area: {
    style.fill: "#fcfcfc"
    style.stroke: "#dddddd"
    style.border-radius: 4
    
    direction: right

    y_axis: {
      shape: rectangle
      width: 60
      style.fill: transparent
      style.stroke: transparent
      label: "Accuracy Drop"
      
      points: {
        shape: sql_table
        label: "Scale"
        v5: "5.0% | ---"
        v4: "4.0% | ---"
        v3: "3.0% | ---"
        v2: "2.0% | Threshold"
        v1: "1.0% | ---"
        v0: "0.0% | Baseline"
      }
    }

    bars: {
      direction: right
      style.stroke: transparent
      style.fill: transparent

      # High Sensitivity
      b1: "4.5% (FP32)" {
        shape: rectangle
        height: 360
        width: 80
        style.fill: "#DC2626"
        style.stroke: "#991B1B"
        tooltip: "Final Projection"
      }
      b2: "4.0% (FP32)" {
        shape: rectangle
        height: 320
        width: 80
        style.fill: "#DC2626"
        style.stroke: "#991B1B"
        tooltip: "Embedding"
      }
      b3: "3.5% (FP32)" {
        shape: rectangle
        height: 280
        width: 80
        style.fill: "#DC2626"
        style.stroke: "#991B1B"
        tooltip: "Attention Softmax"
      }

      # Medium Sensitivity
      b4: "1.5%" {
        shape: rectangle
        height: 120
        width: 80
        style.fill: "#F59E0B"
        style.stroke: "#B45309"
        tooltip: "Q/K/V Proj"
      }
      b5: "1.2%" {
        shape: rectangle
        height: 100
        width: 80
        style.fill: "#F59E0B"
        style.stroke: "#B45309"
        tooltip: "FFN Up"
      }
      b6: "1.0%" {
        shape: rectangle
        height: 80
        width: 80
        style.fill: "#F59E0B"
        style.stroke: "#B45309"
        tooltip: "FFN Down"
      }

      # Low Sensitivity
      b7: "0.7% (INT8)" {
        shape: rectangle
        height: 56
        width: 80
        style.fill: "#10B981"
        style.stroke: "#047857"
        tooltip: "LayerNorm"
      }
      b8: "0.6% (INT8)" {
        shape: rectangle
        height: 48
        width: 80
        style.fill: "#10B981"
        style.stroke: "#047857"
        tooltip: "Attn Output"
      }
      b9: "0.4% (INT8)" {
        shape: rectangle
        height: 32
        width: 80
        style.fill: "#10B981"
        style.stroke: "#047857"
        tooltip: "Mid Linear"
      }
    }
  }
}

# Logic & Code Reference
logic_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  recommendations: {
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
    style.stroke-width: 2
    style.border-radius: 8
    width: 500
    
    label: "🎯 Quantization Policy Engine"
    
    implementation: |'python
      def get_precision_target(layer_sensitivity):
          # Logic derived from analysis
          if layer_sensitivity > 0.02:
              return "float32"
          elif layer_sensitivity > 0.01:
              return "bfloat16"
          else:
              return "int8_per_tensor"
    '|

    policy_notes: |'md
      ### ❌ Forced FP32
      - **Embedding**: High lookup variance
      - **Softmax**: Logit scale compression issues
      - **Final Proj**: Last-mile precision loss
      
      ### ✅ Target INT8
      - **Linear Layers**: Per-channel scaling robust
      - **FFN blocks**: High noise tolerance
    '|
  }

  statistics: {
    style.fill: "#DBEAFE"
    style.stroke: "#3B82F6"
    style.stroke-width: 2
    style.border-radius: 8
    width: 400
    
    label: "📊 Summary Matrix"

    table: |'md
      | Metric | Value | Status |
      | :--- | :--- | :--- |
      | Total Layers | 9 | - |
      | FP32 Required | 3 | High |
      | Mixed Eval | 3 | Med |
      | INT8 Ready | 3 | Low |
      | Max Drift | 4.5% | Critical |
      | Min Drift | 0.4% | Minimal |
    '|
    
    note: "Method: One-at-a-time (OAT) validation"
  }
}

# Legend & Threshold Line
footer: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  legend: {
    style.fill: "#F3F4F6"
    style.stroke: "#D1D5DB"
    style.border-radius: 8
    
    direction: right
    
    h: {
      style.fill: "#DC2626"
      label: "HIGH (>2%): KEEP FP32"
    }
    m: {
      style.fill: "#F59E0B"
      label: "MED (1-2%): EVALUATE"
    }
    l: {
      style.fill: "#10B981"
      label: "LOW (<1%): QUANTIZE"
    }
  }
}

# Layout Connections
header -> visual_row
visual_row -> logic_row
logic_row -> footer

# Constraints
visual_row.chart_area.bars.b1 -> visual_row.chart_area.bars.b2 -> visual_row.chart_area.bars.b3 -> visual_row.chart_area.bars.b4 -> visual_row.chart_area.bars.b5 -> visual_row.chart_area.bars.b6 -> visual_row.chart_area.bars.b7 -> visual_row.chart_area.bars.b8 -> visual_row.chart_area.bars.b9: {style.stroke: transparent}