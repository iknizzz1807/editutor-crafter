direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Residual Connection Quantization Challenge {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_problem: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  problem_container: PROBLEM: Scale Mismatch {
    style: {
      fill: "#FFF0F0"
      stroke: "#D32F2F"
      stroke-width: 2
      border-radius: 8
    }
    input: Input x {
      shape: rectangle
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    main_path: Main Path {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
      conv1: Conv2d (INT8) {
        style: {
          fill: "#C8E6C9"
          stroke: "#388E3C"
        }
        width: 140
      }
      bn1: BN Folded {
        style: {
          fill: "#C8E6C9"
          stroke: "#388E3C"
          font-size: 12
        }
        width: 140
      }
      relu1: ReLU {
        style: {
          fill: "#FFECB3"
          stroke: "#FFA000"
        }
        width: 140
      }
      conv2: Conv2d (INT8) {
        style: {
          fill: "#C8E6C9"
          stroke: "#388E3C"
        }
        width: 140
      }
      relu2: ReLU {
        style: {
          fill: "#FFECB3"
          stroke: "#FFA000"
        }
        width: 140
      }
      conv1 -> bn1 -> relu1 -> conv2 -> relu2
    }
    skip_path: Skip Connection {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
      identity: Identity {
        style: {
          fill: "#E1BEE7"
          stroke: "#7B1FA2"
        }
        width: 140
      }
    }
    add_wrong: Add (WRONG!) {
      shape: diamond
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
        stroke-width: 3
      }
    }
    output_wrong: Output y {
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#D32F2F"
      }
    }
    input -> main_path.conv1
    input -> skip_path.identity
    main_path.relu2 -> add_wrong
    skip_path.identity -> add_wrong
    add_wrong -> output_wrong
  }
}
scale_annotation: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  scale_main: Main Path Scale {
    shape: rectangle
    width: 180
    code: |'c
      s_main = 0.015
      zp_main = 10
      range: [-2.0, 1.8]
    '|
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      font: mono
    }
  }
  scale_skip: Skip Connection Scale {
    shape: rectangle
    width: 180
    code: |'c
      s_skip = 0.008
      zp_skip = -5
      range: [-1.0, 1.0]
    '|
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      font: mono
    }
  }
  mismatch_arrow: scale_main -> scale_skip: MISMATCH! {
    style: {
      stroke: "#D32F2F"
      stroke-width: 3
      stroke-dash: 5
      animated: true
    }
  }
}
row_solution: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  solution_container: SOLUTION: Scale Alignment {
    style: {
      fill: "#F1F8E9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 8
    }
    input2: Input x (INT8) {
      shape: rectangle
      style: {
        fill: "#E3F2FD"
        stroke: "#1976D2"
      }
    }
    main2: Main Path {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
      conv2d_1: Conv2d {
        style: {
          fill: "#C8E6C9"
          stroke: "#388E3C"
        }
        width: 100
      }
      conv2d_2: Conv2d {
        style: {
          fill: "#C8E6C9"
          stroke: "#388E3C"
        }
        width: 100
      }
      conv2d_1 -> conv2d_2
    }
    skip2: Skip Path {
      style: {
        fill: "#F5F5F5"
        stroke: "#9E9E9E"
        stroke-dash: 3
      }
      identity2: Identity {
        style: {
          fill: "#E1BEE7"
          stroke: "#7B1FA2"
        }
        width: 100
      }
    }
    dequant_main: Dequantize {
      shape: parallelogram
      style: {
        fill: "#B3E5FC"
        stroke: "#0277BD"
      }
    }
    dequant_skip: Dequantize {
      shape: parallelogram
      style: {
        fill: "#B3E5FC"
        stroke: "#0277BD"
      }
    }
    add_correct: Add (FP32) {
      shape: diamond
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
      }
    }
    quant_out: Requantize {
      shape: parallelogram
      style: {
        fill: "#B3E5FC"
        stroke: "#0277BD"
      }
    }
    output_correct: Output y (INT8) {
      shape: rectangle
      style: {
        fill: "#C8E6C9"
        stroke: "#388E3C"
      }
    }
    input2 -> main2.conv2d_1
    input2 -> skip2.identity2
    main2.conv2d_2 -> dequant_main: "q / s_main + zp_main"
    skip2.identity2 -> dequant_skip: "q / s_skip + zp_skip"
    dequant_main -> add_correct: FP32
    dequant_skip -> add_correct: FP32
    add_correct -> quant_out: FP32
    quant_out -> output_correct: "round(x / s_out + zp_out)"
  }
}
legend: "" {
  direction: right
  near: bottom-center
  style: {
    stroke: transparent
    fill: transparent
  }
  legend_title: Legend {
    style: {
      bold: true
      underline: true
    }
  }
  int8_op: INT8 Operation {
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
    width: 120
  }
  fp32_op: FP32 Operation {
    style: {
      fill: "#B3E5FC"
      stroke: "#0277BD"
    }
    width: 120
  }
  quantize_op: Quantize/Dequant {
    shape: parallelogram
    style: {
      fill: "#B3E5FC"
      stroke: "#0277BD"
    }
    width: 120
  }
  error_op: Error {
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
    width: 120
  }
}
key_insight: Key Insight {
  near: bottom-center
  width: 600
  code: |'c
    // WRONG: Adding quantized tensors with different scales
    y_quant = x_quant + residual_quant;  // GARBAGE!
    // CORRECT: Dequantize -> Add in FP32 -> Requantize
    x_float     = s_x * (x_quant - zp_x);
    res_float   = s_res * (residual_quant - zp_res);
    out_float   = x_float + res_float;
    out_quant   = clamp(round(out_float / s_out + zp_out), -128, 127);
  '|
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    font: mono
  }
}