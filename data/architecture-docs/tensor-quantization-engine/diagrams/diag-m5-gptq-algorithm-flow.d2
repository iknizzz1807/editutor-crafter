direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # GPTQ Algorithm: Column-by-Column Quantization with Compensation
  *Step-by-step visualization of Hessian-aware weight quantization*
| {near: top-center}
step0: {
  label: "Initial State: Weight Matrix W"
  width: 600
  code: |'python
    # Input: Weight matrix W [d_out, d_in]
    # Hessian: H = 2 * X^T X (from calibration data)
    # Hessian inverse: H^{-1}
    W = layer.weight.data  # [4096, 4096] for typical LLM
    H_inv = compute_hessian_inverse(calibration_inputs)
  '|
}
step1: {
  label: "Step 1: Quantize Column 0"
  width: 600
  matrix_before: {
    label: "W before"
    shape: rectangle
    width: 200
    height: 150
    style.fill: "#E8F5E9"
    col0_label: "Column 0\n(to quantize)" {
      style.fill: "#81C784"
      style.stroke: "#2E7D32"
      style.stroke-width: 3
    }
    col_rest: "Columns 1..n\n(unquantized)" {
      style.fill: "#E8F5E9"
      style.stroke-dash: 3
    }
  }
  arrow1: "->" {
    style.stroke: "#1565C0"
    style.stroke-width: 2
  }
  matrix_after: {
    label: "After quantizing col 0"
    shape: rectangle
    width: 200
    height: 150
    style.fill: "#E8F5E9"
    col0_q: "Q[:,0]\n(INT4)" {
      style.fill: "#4CAF50"
      style.stroke: "#1B5E20"
      style.stroke-width: 3
      style.font-color: white
      style.bold: true
    }
    col_rest2: "Columns 1..n\n(still FP16)" {
      style.fill: "#FFF9C4"
      style.stroke-dash: 3
    }
  }
  code1: |'python
    # Quantize column 0 to INT4
    scale_0 = W[:, 0].abs().max() / 7  # INT4: -8 to 7
    Q[:, 0] = clamp(round(W[:, 0] / scale_0), -8, 7)
  '|
}
step2: {
  label: "Step 2: Compute Quantization Error"
  width: 600
  error_visual: {
    label: "Quantization Error δ₀"
    shape: rectangle
    width: 180
    height: 120
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2
    error_content: "δ₀ = W[:,0] - Q[:,0] × scale₀\n\n(Error in FP32,\nwill be compensated)"
  }
  code2: |'python
    # Compute quantization error for column 0
    delta_0 = W[:, 0] - Q[:, 0] * scale_0
    # This error propagates to output:
    # ΔY = X[:, 0] × δ₀ᵀ
  '|
}
step3: {
  label: "Step 3: Hessian-Guided Compensation"
  width: 650
  hessian_explain: {
    label: "Hessian Inverse H⁻¹"
    shape: rectangle
    width: 200
    height: 150
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    h_content: "H⁻¹ tells us:\n\n• Which columns\n  are 'important'\n• How columns\n  interact\n• Optimal update\n  direction"
  }
  arrow_h: "->" {
    label: "guides"
    style.stroke: "#1565C0"
    style.stroke-width: 2
  }
  update_visual: {
    label: "Update Remaining Columns"
    shape: rectangle
    width: 220
    height: 150
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
    style.stroke-width: 2
    update_content: "W[:, 1:] -= \nδ₀ × H⁻¹[0, 1:] / H⁻¹[0, 0]\n\n(Compensate for\nquantization error)"
  }
  code3: |'python
    # Hessian-weighted compensation update
    # Key insight: adjust remaining columns to minimize output error
    error_scaled = delta_0 / H_inv[0, 0]
    W[:, 1:] -= error_scaled.unsqueeze(1) @ H_inv[0, 1:].unsqueeze(0)
    # This "pre-compensates" for the quantization error
    # by adjusting weights that haven't been quantized yet
  '|
}
step4: {
  label: "Step 4: Recursive Update of Hessian Inverse"
  width: 600
  hessian_update: {
    label: "H⁻¹ Update (Sherman-Morrison)"
    shape: rectangle
    width: 280
    height: 100
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    h_update_content: "After quantizing column j:\nH⁻¹ is updated to remove\nrow/column j influence\n\nO(n²) per column"
  }
  code4: |'python
    # Recursive Hessian inverse update (optional optimization)
    # After processing column j, update H^{-1} for remaining columns
    # This maintains accuracy for subsequent column quantizations
    # In practice, GPTQ often skips this for speed
    # The initial H^{-1} approximation is usually sufficient
  '|
}
step5: {
  label: "Step 5: Repeat for All Columns"
  width: 650
  iteration_visual: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    iter1: "i=0\n✓" {
      shape: circle
      style.fill: "#4CAF50"
      style.font-color: white
    }
    iter2: "i=1\n✓" {
      shape: circle
      style.fill: "#4CAF50"
      style.font-color: white
    }
    iter3: "i=2\nprocessing..." {
      shape: circle
      style.fill: "#FFC107"
      style.stroke: "#F57C00"
      style.stroke-width: 3
    }
    iter4: "i=3" {
      shape: circle
      style.fill: "#E0E0E0"
    }
    iter5: "..." {
      shape: text
      style.font-size: 20
    }
    iter6: "i=n" {
      shape: circle
      style.fill: "#E0E0E0"
    }
    iter1 -> iter2 -> iter3 -> iter4 -> iter5 -> iter6
  }
  code5: |'python
    # Complete GPTQ loop
    for i in range(in_features):
        # 1. Quantize column i
        Q[:, i] = quantize_column(W[:, i], group_scale)
        # 2. Compute error
        delta = W[:, i] - dequantize(Q[:, i], group_scale)
        # 3. Update remaining columns
        error_scaled = delta / H_inv[i, i]
        W[:, i+1:] -= error_scaled.unsqueeze(1) @ H_inv[i, i+1:].unsqueeze(0)
        # 4. (Optional) Update H^{-1} for numerical stability
  '|
}
final_result: {
  label: "Final Result: INT4 Quantized Weights"
  width: 700
  comparison: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    before: {
      label: "Original W (FP16)"
      shape: rectangle
      width: 180
      height: 120
      style.fill: "#E3F2FD"
      before_stats: "4096 × 4096 × 2 bytes\n= 33.6 MB"
    }
    arrow_final: "->" {
      label: "GPTQ\n4x compression"
      style.stroke: "#4CAF50"
      style.stroke-width: 3
      style.bold: true
    }
    after: {
      label: "Quantized Q (INT4)"
      shape: rectangle
      width: 180
      height: 120
      style.fill: "#E8F5E9"
      after_stats: "4096 × 4096 / 2 bytes\n= 8.4 MB\n\n+ scales: ~0.3 MB"
    }
  }
  final_code: |'python
    # Output: Quantized weights with minimal perplexity increase
    # - Q: INT4 weights (packed, 2 per byte)
    # - scales: Per-group scales [d_out, num_groups]
    # - zeros: Per-group zero points (usually 0 for symmetric)
    # Inference: W_dequant = Q * scales[group_idx]
    # Perplexity increase: < 1.0 (vs 40+ for naive INT4)
  '|
}
key_insight: {
  label: "Key Insight: Compensation is What Makes INT4 Work"
  width: 700
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.stroke-width: 2
  insight_content: |md
    **Naive INT4**: Quantize all weights → error compounds → perplexity explodes (40+)
    **GPTQ INT4**: Quantize column → compute error → *compensate in remaining columns* → error absorbed
    The Hessian inverse tells us **which weights matter most** and **how to adjust them** to minimize output error.
    This is why GPTQ achieves perplexity increase < 1.0 while naive quantization fails catastrophically.
  |
}
step0 -> step1 -> step2 -> step3 -> step4 -> step5 -> final_result -> key_insight