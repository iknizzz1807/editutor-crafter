arrow: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  arrow_box: {
    label: "GPTQ reduces\noutput error by\n71%"
    shape: diamond
    width: 120
    height: 80
    style: {
      fill: "#4299E1"
      font-color: white
      bold: true
    }
  }
}
naive_side.naive_error -> gptq_side.gptq_error: {
  label: "Hessian-weighted\ncompensation"
  style: {
    stroke: "#4299E1"
    stroke-width: 3
    animated: true
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  algorithm_box: {
    direction: down
    label: "GPTQ Algorithm (Column-by-Column)"
    width: 600
    style: {
      fill: "#EBF8FF"
      stroke: "#3182CE"
      border-radius: 8
    }
    step1: {
      label: "Step 1: Quantize Column j"
      width: 550
      code: |'python
        Q[:, j] = round(W[:, j] / scale)
        error = W[:, j] - Q[:, j] * scale
      '|
    }
    step2: {
      label: "Step 2: Compute Hessian"
      width: 550
      code: |'python
        H = X.T @ X  # Calibration inputs
        H_inv = cholesky_inverse(H + damp)
      '|
    }
    step3: {
      label: "Step 3: Compensate Remaining Columns"
      width: 550
      code: |'python
        W[:, j+1:] -= error @ H_inv[j, j+1:] / H_inv[j, j]
      '|
    }
    step4: {
      label: "Step 4: Repeat for j+1, j+2, ..."
      style.italic: true
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  label: "Color Legend"
  pos_high: {
    label: "+3, +2"
    shape: rectangle
    width: 50
    height: 30
    style.fill: "#C53030"
    style.font-color: white
  }
  pos_med: {
    label: "+1"
    shape: rectangle
    width: 50
    height: 30
    style.fill: "#F56565"
    style.font-color: white
  }
  zero: {
    label: "0"
    shape: rectangle
    width: 50
    height: 30
    style.fill: "#FC8181"
    style.font-color: white
  }
  neg_med: {
    label: "-1, -2"
    shape: rectangle
    width: 50
    height: 30
    style.fill: "#68D391"
    style.font-color: "#276749"
  }
  neg_high: {
    label: "-3"
    shape: rectangle
    width: 50
    height: 30
    style.fill: "#38A169"
    style.font-color: white
  }
}