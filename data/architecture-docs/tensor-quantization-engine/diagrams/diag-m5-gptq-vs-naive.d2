direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  near: top-center
  shape: text
  label: "GPTQ vs Naive INT4: Weight Compensation Visualized"
  style: {
    font-size: 32
    bold: true
  }
}
