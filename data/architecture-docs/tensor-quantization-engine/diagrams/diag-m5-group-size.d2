direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    weight-blue: "#E3F2FD"
    weight-border: "#1976D2"
    group1: "#BBDEFB"
    group2: "#90CAF9"
    group3: "#64B5F6"
    group4: "#42A5F5"
    scale-green: "#C8E6C9"
    scale-border: "#388E3C"
    packed-orange: "#FFE0B2"
    packed-border: "#F57C00"
    memory-purple: "#E1BEE7"
    memory-border: "#7B1FA2"
  }
}
title: "Group Size: Multiple Scales per Weight Matrix"
section_weights: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  weight_matrix_label: "Weight Matrix W ∈ ℝ^(out_features × in_features)" {
    shape: text
    style.font-size: 18
    style.bold: true
  }
  weight_matrix: {
    direction: right
    style.fill: ${colors.weight-blue}
    style.stroke: ${colors.weight-border}
    style.stroke-width: 2
    label: ""
    row_label: "out_features\n(rows)" {
      shape: text
      style.font-size: 14
    }
    group1: "Group 0\n(columns 0-127)" {
      direction: down
      style.fill: ${colors.group1}
      style.stroke: ${colors.weight-border}
      width: 140
      height: 180
      label.near: outside-top-center
    }
    group2: "Group 1\n(columns 128-255)" {
      direction: down
      style.fill: ${colors.group2}
      style.stroke: ${colors.weight-border}
      width: 140
      height: 180
      label.near: outside-top-center
    }
    group3: "Group 2\n(columns 256-383)" {
      direction: down
      style.fill: ${colors.group3}
      style.stroke: ${colors.weight-border}
      width: 140
      height: 180
      label.near: outside-top-center
    }
    group4: "Group 3\n(columns 384-511)" {
      direction: down
      style.fill: ${colors.group4}
      style.stroke: ${colors.weight-border}
      width: 140
      height: 180
      label.near: outside-top-center
    }
    ellipsis: "..." {
      shape: text
      style.font-size: 24
    }
    col_label: "in_features = 4096\n(32 groups of 128)" {
      shape: text
      style.font-size: 12
    }
  }
  group1 -> scale1: "scale₀" {
    style.stroke: ${colors.scale-border}
    style.stroke-width: 2
  }
  group2 -> scale2: "scale₁" {
    style.stroke: ${colors.scale-border}
    style.stroke-width: 2
  }
  group3 -> scale3: "scale₂" {
    style.stroke: ${colors.scale-border}
    style.stroke-width: 2
  }
  group4 -> scale4: "scale₃" {
    style.stroke: ${colors.scale-border}
    style.stroke-width: 2
  }
  scale_row: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    scale1: "s₀" {
      shape: circle
      style.fill: ${colors.scale-green}
      style.stroke: ${colors.scale-border}
      style.stroke-width: 2
      width: 40
    }
    scale2: "s₁" {
      shape: circle
      style.fill: ${colors.scale-green}
      style.stroke: ${colors.scale-border}
      style.stroke-width: 2
      width: 40
    }
    scale3: "s₂" {
      shape: circle
      style.fill: ${colors.scale-green}
      style.stroke: ${colors.scale-border}
      style.stroke-width: 2
      width: 40
    }
    scale4: "s₃" {
      shape: circle
      style.fill: ${colors.scale-green}
      style.stroke: ${colors.scale-border}
      style.stroke-width: 2
      width: 40
    }
    ellipsis_s: "..." {
      shape: text
    }
    scale_n: "s₃₁" {
      shape: circle
      style.fill: ${colors.scale-green}
      style.stroke: ${colors.scale-border}
      style.stroke-width: 2
      width: 40
    }
  }
  scale_label: "Per-Group Scales: [out_features × num_groups] = [4096 × 32]" {
    shape: text
    style.font-size: 14
    style.italic: true
  }
}
section_memory: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  memory_title: "Memory Layout (group_size = 128)" {
    shape: text
    style.font-size: 18
    style.bold: true
  }
  memory_layout: {
    direction: right
    style.fill: ${colors.memory-purple}
    style.stroke: ${colors.memory-border}
    style.stroke-width: 2
    label: ""
    packed_weights: "Packed INT4 Weights\n(2 values per byte)" {
      direction: down
      style.fill: ${colors.packed-orange}
      style.stroke: ${colors.packed-border}
      width: 200
      label.near: outside-top-center
      byte0: "Byte 0: [w₁, w₀]"
      byte1: "Byte 1: [w₃, w₂]"
      byte2: "Byte 2: [w₅, w₄]"
      dots: "..."
      byteN: "Byte N: [w_{2N+1}, w_{2N}]"
      size_info: "Size: out × in / 2 bytes" {
        shape: text
        style.font-size: 12
        style.italic: true
      }
    }
    scale_array: "Scale Array\n(FP16 per group)" {
      direction: down
      style.fill: ${colors.scale-green}
      style.stroke: ${colors.scale-border}
      width: 160
      label.near: outside-top-center
      scale_entry0: "scale[0, 0] = 0.0234"
      scale_entry1: "scale[0, 1] = 0.0198"
      dots2: "..."
      scale_entryN: "scale[out-1, 31]"
      size_info2: "Size: out × (in/128) × 2 bytes" {
        shape: text
        style.font-size: 12
        style.italic: true
      }
    }
    zeros_array: "Zero Points\n(usually 0 for symmetric)" {
      direction: down
      style.fill: "#FFF9C4"
      style.stroke: "#F9A825"
      width: 140
      label.near: outside-top-center
      zp_entry: "zeros[0, 0] = 0"
      zp_entry2: "zeros[0, 1] = 0"
      dots3: "..."
      zp_entryN: "zeros[out-1, 31] = 0"
      size_info3: "Size: out × num_groups × 2 bytes" {
        shape: text
        style.font-size: 12
        style.italic: true
      }
    }
  }
}
section_formula: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  formula_title: "Quantization Formula (per group)" {
    shape: text
    style.font-size: 18
    style.bold: true
  }
  formula_box: {
    style.fill: "#FAFAFA"
    style.stroke: "#BDBDBD"
    style.stroke-width: 1
    width: 600
    formula: |'python
  # For weight at position [row, col]:
  group_idx = col // group_size  # Which group?
  scale = scales[row, group_idx]
  # Quantize:
  q = clamp(round(w / scale), -8, 7)
  # Dequantize:
  w_approx = q * scale
    '|
  }
}
section_tradeoff: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  tradeoff_title: "Group Size Tradeoff" {
    shape: text
    style.font-size: 18
    style.bold: true
  }
  tradeoff_table: {
    shape: sql_table
    label: "Group Size vs Accuracy vs Overhead"
    row1: "Group Size | Scale Storage | Precision | Inference Complexity"
    row2: "4096 (per-row) | Minimal (1 scale/row) | Low | Simple"
    row3: "128 (standard) | 32x more | High | Moderate"
    row4: "64 | 64x more | Higher | More complex"
    row5: "32 | 128x more | Highest | Complex"
    row6: "Total: 5 configurations compared"
  }
  insight_box: {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 500
    insight_label: "Key Insight" {
      shape: text
      style.bold: true
      style.font-size: 16
    }
    insight_text: |md
      **group_size = 128** is the sweet spot:
      - Small enough to capture local weight variance
      - Large enough to keep scale overhead minimal (~3%)
      - Standard choice for GPTQ, AWQ, and other INT4 methods
      Overhead calculation for 4096×4096 layer:
      - Weights: 4096 × 4096 / 2 = 8,388,608 bytes (INT4 packed)
      - Scales: 4096 × 32 × 2 = 262,144 bytes (FP16)
      - Overhead: 262,144 / 8,388,608 = **3.1%**
    |
  }
}
section_example: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent
  example_title: "Concrete Example: 7B LLM Layer" {
    shape: text
    style.font-size: 18
    style.bold: true
  }
  example_box: {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    width: 550
    example_code: |'python
  # Typical 7B model attention projection
  layer_shape = (4096, 4096)  # out_features, in_features
  group_size = 128
  num_groups = 4096 // 128  # = 32 groups per row
  # Memory breakdown:
  # FP16 weights:  4096 × 4096 × 2 = 33,554,432 bytes
  # INT4 packed:   4096 × 4096 / 2 = 8,388,608 bytes
  # Scales (FP16): 4096 × 32 × 2   = 262,144 bytes
  # 
  # Compression: 33.5 MB → 8.65 MB = **3.88x**
  # (4x theoretical, 3.88x with scale overhead)
    '|
  }
}