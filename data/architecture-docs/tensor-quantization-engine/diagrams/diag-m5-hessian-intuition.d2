direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: Hessian Approximation: Why It Matters for Quantization {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  landscape: Loss Landscape {
    direction: down
    width: 480
    style: {
      fill: "#f8f9fa"
      stroke: "#dee2e6"
      border-radius: 8
    }
    
    contour_note: |md
      **Loss Landscape (Contour Plot)**
      Contours show constant loss values.
      Closely spaced = steep curvature.
      Widely spaced = flat curvature.
    | {
      width: 380
    }
    
    contour_visual: Loss Landscape Visualization {
      direction: right
      width: 420
      style.fill: transparent
      ellipses: |md
        text
              ╭────────────────────────╮
         ╭────│────────────────────────│────╮
        ╱     │    ╭────────────────╮  │     ╲
       │      │   ╱ ╭──────────────╮ ╲ │      │
       │      │  │  │  ╭────────╮  │  │      │
       │      │  │  │  │   ●A   │  │  │      │
       │      │  │  │  ╰────────╯  │  │      │
       │      │  │  ╰──────────────╯  │      │
       │      │   ╲ ╰────────────────╯ ╱      │
        ╲     │    │                    │     ╱
         ╰────│────│────────────────────│────╯
              ╰────│────────────────────│───╯
                   │                    │
        ←── Steep (H large)   Flat (H small) ──→
      | {
        width: 400
        style.fill: transparent
      }
    }
    
    points: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      point_a: Current Weights (A) {
        shape: circle
        style: {
          fill: "#4dabf7"
          stroke: "#1971c2"
          stroke-width: 2
        }
      }
      
      spacer: "" {
        style.stroke: transparent
        style.fill: transparent
        width: 40
      }
      
      point_q: Quantized (Q) {
        shape: circle
        style: {
          fill: "#ff6b6b"
          stroke: "#c92a2a"
          stroke-width: 2
        }
      }
    }
    
    points.point_a -> points.point_q: "Quantization | ∆w" {
      style: {
        stroke: "#868e96"
        stroke-dash: 4
        stroke-width: 2
      }
    }
  }
}

row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  hessian_box: Hessian Matrix H {
    direction: down
    width: 340
    style: {
      fill: "#e7f5ff"
      stroke: "#339af0"
      border-radius: 8
    }
    h_def: |md
      **Hessian = Second Derivatives**
      H_ij = ∂²L / ∂w_i ∂w_j
    |
    h_diagonal: Diagonal Elements H_ii {
      direction: down
      width: 300
      style.fill: transparent
      meaning: |md
        **Curvature in each direction**
        - H_ii large: steep direction
          Small weight change = large loss increase
        - H_ii small: flat direction  
          Can move freely with low cost
      |
    }
    h_offdiag: Off-Diagonal H_ij {
      direction: down
      width: 300
      style.fill: transparent
      meaning: |md
        **Interaction between weights**
        - How changing w_i affects the
          optimal value of w_j
        - Key for error compensation!
      |
    }
  }
  
  gptq_box: GPTQ Algorithm {
    direction: down
    width: 420
    style: {
      fill: "#fff3bf"
      stroke: "#fab005"
      border-radius: 8
    }
    gptq_algo: |md
      **Layer-wise Quantization**
      1. Quantize weight column j → Q_j
      2. Compute error: δ_j = w_j - Q_j
      3. **Compensate remaining columns:**
      
      W_rem -= δ_j · H_inv_row / H_inv_diag
      
      4. Update Hessian-inverse and repeat.
    |
    insight: |md
      **Key Insight:**
      Hessian tells us *which* weights to
      adjust and *how much* to minimize
      the output error caused by quantization.
    | {
      style.fill: "#ffe066"
    }
  }
}

row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  
  diag_approx: Diagonal Approximation {
    direction: down
    width: 320
    style: {
      fill: "#f3f0ff"
      stroke: "#7950f2"
      border-radius: 8
    }
    approx_explain: |md
      **Full Hessian: O(n²) storage**
      For 4096 weights → 16M elements!
      **Diagonal Approximation: O(n)**
      H_diag = 2 · Σ(X²) per column
    |
    approx_formula: H_ii ≈ 2 · Σ_k X²_ki {
      style: {
        font: mono
        fill: "#e5dbff"
      }
    }
    approx_note: |md
      Fast to compute from calibration data.
      GPTQ reconstructs interaction info through
      column-by-column updates.
    |
  }
  
  why_matters: Why This Matters {
    direction: down
    width: 450
    style: {
      fill: "#d3f9d8"
      stroke: "#40c057"
      border-radius: 8
    }
    
    comparison: {
      direction: right
      style.fill: transparent
      style.stroke: transparent
      
      without: Without Hessian Info {
        direction: down
        style: {
          fill: "#ffe3e3"
          stroke: "#fa5252"
          border-radius: 6
        }
        w_text: |md
          - Quantize blindly
          - Error accumulates
          - Perplexity explodes
        |
      }
      
      with: With Hessian (GPTQ) {
        direction: down
        style: {
          fill: "#d3f9d8"
          stroke: "#40c057"
          border-radius: 6
        }
        w_text: |md
          - Know sensitive directions
          - Compensate intelligently  
          - Minimal accuracy loss
        |
      }
    }
    
    result: |md
      **Result:** INT4 quantization with < 1% perplexity increase
      vs. naive INT4 with 40%+ perplexity increase.
    | {
      style: {
        bold: true
        fill: "#b2f2bb"
      }
    }
  }
}

