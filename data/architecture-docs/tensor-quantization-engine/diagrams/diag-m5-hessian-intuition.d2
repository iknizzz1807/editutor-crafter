  near: bottom-center
  direction: right
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    border-radius: 6
  }
  
  item1: {
    direction: right
    style.stroke: transparent
    steep: "" {
      shape: circle
      width: 20
      height: 20
      style.fill: "#fa5252"
    }
    label: "H large = costly move"
  }
  
  item2: {
    direction: right
    style.stroke: transparent
    flat: "" {
      shape: circle
      width: 20
      height: 20
      style.fill: "#51cf66"
    }
    label: "H small = cheap move"
  }
  
  item3: {
    direction: right
