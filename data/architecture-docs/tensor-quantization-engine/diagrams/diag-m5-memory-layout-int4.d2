direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # INT4 Memory Layout: Packing Two Weights Per Byte
| {near: top-center}
row_original: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  original_weights: {
    label: "Original INT4 Weights\n[out_dim, in_dim]"
    w0: {
      shape: rectangle
      label: "W[0]\n-3"
      width: 60
      style.fill: "#E8F5E9"
    }
    w1: {
      shape: rectangle
      label: "W[1]\n7"
      width: 60
      style.fill: "#E3F2FD"
    }
    w2: {
      shape: rectangle
      label: "W[2]\n-8"
      width: 60
      style.fill: "#E8F5E9"
    }
    w3: {
      shape: rectangle
      label: "W[3]\n2"
      width: 60
      style.fill: "#E3F2FD"
    }
    ellipsis: {
      label: "..."
      shape: text
    }
    w_pair0: {
      direction: right
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      label: "Pair 0"
    }
    w_pair1: {
      direction: right
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      label: "Pair 1"
    }
  }
}
row_bitview: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  bit_representation: {
    label: "4-Bit Representation\n(signed: -8 to 7)"
    bits_header: {
      shape: text
      label: "**4-bit binary (signed two's complement)**"
    }
    bits_row: {
      direction: right
      bits_w0: {
        shape: class
        label: "W[0] = -3"
        b3: "0"
        b2: "1"
        b1: "0"
        b0: "1"
        style.fill: "#E8F5E9"
      }
      bits_w1: {
        shape: class
        label: "W[1] = 7"
        b3: "0"
        b2: "1"
        b1: "1"
        b0: "1"
        style.fill: "#E3F2FD"
      }
    }
  }
}
row_unsigned: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  unsigned_mapping: {
    label: "Signed → Unsigned Mapping\noffset = +8"
    unsigned_table: {
      shape: sql_table
      label: "Signed to Unsigned LUT"
      row1: "-8 | 0 | 0b0000"
      row2: "-3 | 5 | 0b0101"
      row3: "0  | 8 | 0b1000"
      row4: "7  | 15| 0b1111"
      note: "Range: 0-15 (16 values)"
    }
    unsigned_example: {
      direction: right
      label: "After +8 offset:"
      u0: {
        shape: rectangle
        label: "U[0]\n5"
        width: 60
        style.fill: "#E8F5E9"
      }
      u1: {
        shape: rectangle
        label: "U[1]\n15"
        width: 60
        style.fill: "#E3F2FD"
      }
      u2: {
        shape: rectangle
        label: "U[2]\n0"
        width: 60
        style.fill: "#E8F5E9"
      }
      u3: {
        shape: rectangle
        label: "U[3]\n10"
        width: 60
        style.fill: "#E3F2FD"
      }
    }
  }
}
row_packing: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  packing_logic: {
    label: "Packing: Two INT4 → One INT8"
    pack_formula: {
      label: "Pack Formula"
      code: |'c
        // Even index: lower 4 bits
        // Odd index: upper 4 bits
        packed[i/2] = unsigned[i] | (unsigned[i+1] << 4)
      '|
      width: 320
    }
    packed_byte: {
      direction: right
      label: "Packed Byte 0 (stores W[0] and W[1])"
      lower_nibble: {
        shape: rectangle
        label: "Lower\n4 bits\nU[0]=5\n0b0101"
        width: 80
        height: 100
        style.fill: "#E8F5E9"
      }
      upper_nibble: {
        shape: rectangle
        label: "Upper\n4 bits\nU[1]=15\n0b1111"
        width: 80
        height: 100
        style.fill: "#E3F2FD"
      }
      combined: {
        shape: rectangle
        label: "Packed Byte\n= 0b11110101\n= 245 (uint8)"
        width: 120
        height: 60
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
        style.stroke-width: 2
      }
    }
  }
}
row_memory: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  memory_layout: {
    label: "Memory Layout: [out_dim, ceil(in_dim/2)]"
    packed_array: {
      shape: class
      label: "Packed Weight Array"
      row0: "Byte[0]: W[0] | W[1]"
      row1: "Byte[1]: W[2] | W[3]"
      row2: "Byte[2]: W[4] | W[5]"
      row3: "..."
      row4: "Byte[N-1]: W[2N-2] | W[2N-1]"
      style.fill: "#FFF3E0"
    }
    size_comparison: {
      shape: sql_table
      label: "Memory Savings"
      original: "FP32 Weight | 4 bytes | 100%"
      int8: "INT8 Weight | 1 byte | 25%"
      int4: "Packed INT4 | 0.5 byte | 12.5%"
      ratio: "Compression: 8x vs FP32"
      style.fill: "#E8F5E9"
    }
  }
}
row_unpack: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  unpacking_logic: {
    label: "Unpacking for Inference"
    unpack_formula: {
      label: "Unpack Formula"
      code: |'c
        // Extract nibbles
        lower = packed[i] & 0x0F;       // Mask lower 4
        upper = (packed[i] >> 4) & 0x0F; // Shift & mask
        // Convert unsigned back to signed
        w_even = lower - 8;  // 0..15 -> -8..7
        w_odd  = upper - 8;
      '|
      width: 350
    }
    unpack_example: {
      direction: right
      label: "Example: Byte = 245 (0b11110101)"
      step1: {
        shape: rectangle
        label: "1. Mask\n245 & 0x0F\n= 5"
        width: 80
        style.fill: "#E8F5E9"
      }
      step2: {
        shape: rectangle
        label: "2. Shift\n245 >> 4\n= 15"
        width: 80
        style.fill: "#E3F2FD"
      }
      step3: {
        shape: rectangle
        label: "3. Offset\n5 - 8 = -3\n15 - 8 = 7"
        width: 100
        style.fill: "#FFF3E0"
      }
      step4: {
        shape: rectangle
        label: "Result\nW[0] = -3\nW[1] = 7"
        width: 100
        style.fill: "#C8E6C9"
      }
    }
  }
}
row_groupscale: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  group_scale: {
    label: "Group-Wise Scale Lookup"
    group_layout: {
      shape: class
      label: "Scale Array [out_dim, num_groups]"
      desc: "group_size = 128 weights"
      g0: "scale[0]: weights 0-127"
      g1: "scale[1]: weights 128-255"
      g2: "scale[2]: weights 256-383"
      g3: "... (in_dim / 128 groups)"
      style.fill: "#F3E5F5"
    }
    scale_lookup: {
      label: "Scale Lookup Logic"
      code: |'c
        // For weight at position j:
        group_idx = j / group_size;  // e.g., 128
        scale = scales[out_row][group_idx];
        // Dequantize
        float_weight = (unpacked_int4 - zero) * scale;
      '|
      width: 340
    }
    dequant_example: {
      shape: rectangle
      label: "Dequantization Example\n\nW[0] = -3 (INT4)\nscale[0] = 0.0234\nzero = 0\n\nfloat = -3 × 0.0234\n     = -0.0702"
      width: 200
      style.fill: "#E1F5FE"
    }
  }
}
row_kernel: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  kernel_impl: {
    label: "Inference Kernel (Pseudocode)"
    kernel_code: {
      code: |'c
        void int4_matmul(
            int8_t* packed_weights,  // [out, in/2]
            float* scales,           // [out, num_groups]
            float* input,            // [batch, in]
            float* output,           // [batch, out]
            int in_dim, int out_dim, int group_size
        ) {
          for (int o = 0; o < out_dim; o++) {
            for (int b = 0; b < batch; b++) {
              float sum = 0.0f;
              for (int i = 0; i < in_dim; i += 2) {
                // Unpack two INT4 values
                uint8_t packed = packed_weights[o * (in_dim/2) + i/2];
                int8_t w0 = (packed & 0x0F) - 8;
                int8_t w1 = (packed >> 4) - 8;
                // Lookup scale (same for both in group)
                int group = i / group_size;
                float scale = scales[o * num_groups + group];
                // Dequantize and accumulate
                sum += (w0 * scale) * input[b * in_dim + i];
                sum += (w1 * scale) * input[b * in_dim + i + 1];
              }
              output[b * out_dim + o] = sum;
            }
          }
        }
      '|
      width: 420
    }
  }
}
row_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  summary_box: {
    label: "Summary: INT4 Packing"
    key_points: {
      shape: sql_table
      label: "Key Facts"
      fact1: "Storage | 2 weights per byte"
      fact2: "Range | -8 to 7 (signed)"
      fact3: "Packing | even:lower, odd:upper"
      fact4: "Offset | +8 for unsigned"
      fact5: "Groups | 128 weights share scale"
      fact6: "Compression | 8x vs FP32"
      style.fill: "#FFF8E1"
    }
  }
}
original_weights.w0 -> bit_representation.bits_w0
bit_representation -> unsigned_mapping.unsigned_table
unsigned_mapping.unsigned_example.u0 -> packing_logic.packed_byte.lower_nibble
unsigned_mapping.unsigned_example.u1 -> packing_logic.packed_byte.upper_nibble
packing_logic.packed_byte.combined -> memory_layout.packed_array
memory_layout.packed_array -> unpacking_logic.unpack_example.step1
unpacking_logic.unpack_example.step4 -> group_scale.dequant_example