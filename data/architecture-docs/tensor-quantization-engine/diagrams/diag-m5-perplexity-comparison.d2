direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

header: {
  shape: rectangle
  label: |md
    # Perplexity Comparison: FP16 vs Naive INT4 vs GPTQ INT4
    *WikiText-2 Evaluation on 7B Parameter Model (Llama-2 architecture)*
  |
  style: {
    stroke-width: 0
    fill: transparent
  }
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  scale_axis: {
    label: |md
      **Perplexity**
      (PPL)
      *Lower is Better*
    |
    style.stroke-dash: 3
    style.fill: "#f8f9fa"
  }

  fp16: "FP16 Baseline" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    
    bar_fp16: {
      shape: rectangle
      width: 120
      height: 48
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
    }
    
    stats: {
      shape: sql_table
      label: "Metrics"
      v: "12.0 PPL"
      b: "16-bit float"
      s: "13.5 GB"
    }
    
    note: "Full Precision Reference"
  }

  naive: "Naive INT4" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    
    bar_naive: {
      shape: rectangle
      width: 120
      height: 100
      style.fill: "#F44336"
      style.stroke: "#C62828"
    }
    
    stats: {
      shape: sql_table
      label: "Metrics"
      v: "25.0+ PPL"
      b: "4-bit integer"
      s: "3.4 GB"
    }
    
    status: {
      label: "❌ Model Broken"
      style: {
        font-color: red
        bold: true
        stroke-width: 0
        fill: transparent
      }
    }
  }

  gptq: "GPTQ INT4" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    
    bar_gptq: {
      shape: rectangle
      width: 120
      height: 50
      style.fill: "#2196F3"
      style.stroke: "#1565C0"
    }
    
    stats: {
      shape: sql_table
      label: "Metrics"
      v: "12.5 PPL"
      b: "4-bit integer"
      s: "3.5 GB"
    }
    
    status: {
      label: "✅ Model Usable"
      style: {
        font-color: blue
        bold: true
        stroke-width: 0
        fill: transparent
      }
    }
  }
}

footer_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  legend: {
    shape: sql_table
    label: "Quantization Quality Scale"
    r1: "🟢 < 13.0 | Production Ready"
    r2: "🟡 13.0 - 15.0 | Noticeable Loss"
    r3: "🔴 > 20.0 | Model Failure"
  }

  insight_box: "Technical Insight: Error Compensation" {
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.stroke-width: 2
    width: 450
    content: |'md
      **GPTQ Algorithm (One-Shot Quantization):**
      GPTQ minimizes weight error $|Wx - \hat{W}x|^2$ by 
      processing weights in blocks. It uses the 
      **Inverse Hessian** ($H^{-1}$) to adjust 
      unquantized weights to compensate for 
      rounding errors in quantized ones.
      
      $w_q = \text{round}(w) + H^{-1}_{ii} \cdot \epsilon$
      
      This preserves the activation distributions 
      needed for coherent language generation.
    '|
  }
}

row_comparison -> footer_row: "Evaluation Summary" {
  style.stroke-width: 2
  style.stroke: "#9E9E9E"
}

header.near: top-center