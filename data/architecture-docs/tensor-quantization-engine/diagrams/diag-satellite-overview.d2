direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    blue: "#4A90D9"
    green: "#2E8B57"
    orange: "#E07C24"
    purple: "#8B5CF6"
    gray: "#6B7280"
  }
}
title: |md
  # Tensor Quantization Engine: System Map
  Satellite view of the complete quantization pipeline
| {near: top-center}
legend: {
  near: bottom-right
  label: "Legend"
  blue_node: "Fundamental Math"
  blue_node.style.fill: ${colors.blue}
  green_node: "Calibration"
  green_node.style.fill: ${colors.green}
  orange_node: "Systems"
  orange_node.style.fill: ${colors.orange}
  purple_node: "Advanced Algorithms"
  purple_node.style.fill: ${colors.purple}
}
flow: "Quantization Pipeline Flow" {
  style.fill: "#F8FAFC"
  style.stroke: "#CBD6E1"
  style.stroke-width: 2
  direction: down
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    m1: "M1: Quantization\nFundamentals" {
      style.fill: ${colors.blue}
      style.font-color: white
      style.stroke: "#3B7DD8"
      style.stroke-width: 2
      width: 200
      link: layers.m1_detail
      m1_core: |md
        **Core Concepts**
        - Affine transform
        - Symmetric vs Asymmetric
        - Scale & Zero-point
        - INT8/INT4/INT2 ranges
      |
    }
    m1_to_m2: {
      style.stroke: ${colors.blue}
      style.stroke-width: 3
      style.animated: true
    }
    m2: "M2: Per-Tensor vs\nPer-Channel" {
      style.fill: ${colors.blue}
      style.font-color: white
      style.stroke: "#3B7DD8"
      style.stroke-width: 2
      width: 200
      link: layers.m2_detail
      m2_core: |md
        **Granularity**
        - Channel variance analysis
        - Per-channel scales
        - Broadcast operations
        - Storage overhead
      |
    }
  }
  row2: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    m1_to_m3: {
      style.stroke: ${colors.blue}
      style.stroke-width: 3
      style.animated: true
    }
    m3: "M3: Calibration\nPipeline" {
      style.fill: ${colors.green}
      style.font-color: white
      style.stroke: "#247347"
      style.stroke-width: 2
      width: 200
      link: layers.m3_detail
      m3_core: |md
        **Activation Statistics**
        - Min/Max vs Percentile
        - Histogram collection
        - Outlier handling
        - Data drift detection
      |
    }
    m3_to_m4: {
      style.stroke: ${colors.green}
      style.stroke-width: 3
      style.animated: true
    }
  }
  row3: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    m4: "M4: Static PTQ" {
      style.fill: ${colors.orange}
      style.font-color: white
      style.stroke: "#C06A1A"
      style.stroke-width: 2
      width: 200
      link: layers.m4_detail
      m4_core: |md
        **Full System**
        - Layer sensitivity
        - Residual connections
        - Layer fusion
        - Quantized Linear
      |
    }
    m4_to_m5: {
      style.stroke: ${colors.orange}
      style.stroke-width: 3
      style.animated: true
    }
  }
  row4: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    m1_m2_to_m5: "" {
      direction: down
      style.stroke: transparent
      style.fill: transparent
      spacer1
    }
    m5: "M5: GPTQ\nQuantization" {
      style.fill: ${colors.purple}
      style.font-color: white
      style.stroke: "#7C3AED"
      style.stroke-width: 2
      width: 200
      link: layers.m5_detail
      m5_core: |md
        **Advanced INT4**
        - Hessian computation
        - Column compensation
        - Group-wise scales
        - INT4 packing
      |
    }
  }
}
m1 -> m2: "Scale computation" {
  style.stroke: ${colors.blue}
  style.stroke-width: 2
  style.stroke-dash: 4
}
m2 -> m3: "Weight granularity" {
  style.stroke: ${colors.blue}
  style.stroke-width: 2
  style.stroke-dash: 4
}
m3 -> m4: "Calibration params" {
  style.stroke: ${colors.green}
  style.stroke-width: 2
  style.stroke-dash: 4
}
m4 -> m5: "Quantized layers" {
  style.stroke: ${colors.orange}
  style.stroke-width: 2
  style.stroke-dash: 4
}
dependency_hub: "Dependency Hub" {
  style.fill: "#F1F5F9"
  style.stroke: ${colors.gray}
  direction: right
  source: "M1 + M2\n(Fundamentals)" {
    style.fill: "#E2E8F0"
    style.stroke-width: 0
  }
  source -> target: "Enables" {
    style.stroke: ${colors.purple}
    style.stroke-width: 3
    style.animated: true
    label: "Hessian-aware\ncompensation"
  }
  target: "M5: GPTQ\n(Advanced)" {
    style.fill: "#EDE9FE"
    style.stroke-width: 0
  }
}
data_flow: "Data Flow Through Pipeline" {
  style.fill: "#FAFAFA"
  style.stroke: ${colors.gray}
  direction: right
  input: "FP32 Model" {
    shape: cylinder
    style.fill: "#DBEAFE"
  }
  input -> m1_process: "Weights" {
    style.stroke: ${colors.blue}
  }
  m1_process: "Quantize\nWeights" {
    style.fill: ${colors.blue}
    style.font-color: white
    shape: hexagon
  }
  m1_process -> m2_process: "Quantized" {
    style.stroke: ${colors.blue}
  }
  m2_process: "Per-Channel\nScales" {
    style.fill: ${colors.blue}
    style.font-color: white
    shape: hexagon
  }
  m2_process -> m3_process: "Weight params" {
    style.stroke: ${colors.green}
  }
  m3_process: "Calibrate\nActivations" {
    style.fill: ${colors.green}
    style.font-color: white
    shape: hexagon
  }
  m3_process -> m4_process: "Act. scales" {
    style.stroke: ${colors.orange}
  }
  m4_process: "Build\nQuantized Model" {
    style.fill: ${colors.orange}
    style.font-color: white
    shape: hexagon
  }
  m4_process -> output: "INT8 Model" {
    style.stroke: ${colors.orange}
  }
  output: "Deploy" {
    shape: circle
    style.fill: "#DCFCE7"
  }
  gptq_branch: "" {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    m4_process -> m5_process: "For INT4" {
      style.stroke: ${colors.purple}
      style.stroke-dash: 4
    }
    m5_process: "GPTQ\nOptimize" {
      style.fill: ${colors.purple}
      style.font-color: white
      shape: hexagon
    }
    m5_process -> int4_output: "INT4 Model" {
      style.stroke: ${colors.purple}
    }
    int4_output: "Deploy 4x" {
      shape: circle
      style.fill: "#F3E8FF"
    }
  }
}
layers: {
  m1_detail: {
    title: |md
      # M1: Quantization Fundamentals
      Street-Level Detail
    | {near: top-center}
    direction: down
    affine: "Affine Transform" {
      style.fill: ${colors.blue}
      style.font-color: white
      formula: |md
        **Quantization**
        `q = round(r / scale + zero_point)`
        **Dequantization**
        `r ≈ scale × (q - zero_point)`
      |
    }
    symmetric: "Symmetric" {
      style.fill: "#BFDBFE"
      zp_zero: "zero_point = 0"
      scale_formula: "scale = max|r| / 127"
    }
    asymmetric: "Asymmetric" {
      style.fill: "#BFDBFE"
      zp_computed: "zero_point computed from data"
      scale_formula2: "scale = (r_max - r_min) / 255"
    }
    int8_range: "INT8 Range" {
      style.fill: "#E0E7FF"
      range: "[-128, 127] = 256 values"
      bytes: "1 byte per weight"
    }
    int4_range: "INT4 Range" {
      style.fill: "#E0E7FF"
      range: "[-8, 7] = 16 values"
      bytes: "0.5 bytes per weight"
    }
  }
  m2_detail: {
    title: |md
      # M2: Per-Tensor vs Per-Channel
      Street-Level Detail
    | {near: top-center}
    direction: down
    per_tensor: "Per-Tensor" {
      style.fill: ${colors.blue}
      style.font-color: white
      desc: |md
        - 1 scale for entire tensor
        - Simple implementation
        - Wastes precision for
          heterogeneous channels
      |
    }
    per_channel: "Per-Channel" {
      style.fill: ${colors.blue}
      style.font-color: white
      desc: |md
        - 1 scale per output channel
        - 30-50% MSE reduction
        - <1% storage overhead
        - Default for weights
      |
    }
    channel_dim: "Channel Convention" {
      style.fill: "#DBEAFE"
      linear: "Linear: dim 0 (out_features)"
      conv: "Conv2d: dim 0 (out_channels)"
    }
    broadcast: "Broadcast Trick" {
      style.fill: "#DBEAFE"
      code: |'python
# scales [512] -> [512, 1]
scales_bc = scales.view(512, 1)
q = round(weight / scales_bc)
      '|
    }
  }
  m3_detail: {
    title: |md
      # M3: Calibration Pipeline
      Street-Level Detail
    | {near: top-center}
    direction: down
    minmax: "Min/Max Calibration" {
      style.fill: "#FEE2E2"
      desc: |md
        - Uses observed min/max
        - **Destroyed by outliers**
        - 134x scale inflation from
          single extreme value
      |
    }
    percentile: "Percentile Calibration" {
      style.fill: ${colors.green}
      style.font-color: white
      desc: |md
        - Clips outliers intentionally
        - 99.9% coverage typical
        - 10%+ MSE improvement
        - Handles heavy tails
      |
    }
    collector: "CalibrationCollector" {
      style.fill: "#D1FAE5"
      hooks: "Forward hooks for stats"
      histogram: "Histogram-based percentiles"
      running: "Running min/max/sum"
    }
    stability: "Stability Rule" {
      style.fill: "#D1FAE5"
      rule: "100-500 samples sufficient"
      diminishing: "Diminishing returns beyond"
    }
  }
  m4_detail: {
    title: |md
      # M4: Post-Training Static Quantization
      Street-Level Detail
    | {near: top-center}
    direction: down
    sensitivity: "Layer Sensitivity" {
      style.fill: ${colors.orange}
      style.font-color: white
      keep_fp32: |md
        **Keep FP32:**
        - First embedding
        - Final projection
        - LayerNorm
        - Softmax
      |
    }
    residual: "Residual Connections" {
      style.fill: "#FED7AA"
      problem: "Scale mismatch: x + f(x)"
      solution: "Dequantize → Add → Requantize"
    }
    fusion: "Layer Fusion" {
      style.fill: "#FED7AA"
      conv_bn: "Conv-BN → Single Conv"
      bn_formula: "W_fold = W × γ/√(σ² + ε)"
    }
    qlinear: "QuantizedLinear" {
      style.fill: ${colors.orange}
      style.font-color: white
      flow: |md
        1. Input: INT8 (from prev layer)
        2. Dequantize input
        3. Dequantize weights
        4. Matmul in float
        5. Quantize output to INT8
      |
    }
    results: "PTQ Results" {
      style.fill: "#FFEDD5"
      compression: "~4x size reduction"
      speedup: "~2x faster (with INT8 kernels)"
      accuracy: "<3% accuracy drop"
    }
  }
  m5_detail: {
    title: |md
      # M5: GPTQ Weight Quantization
      Street-Level Detail
    | {near: top-center}
    direction: down
    naive_failure: "Naive INT4 Failure" {
      style.fill: "#FEE2E2"
      desc: |md
        - 64x worse output error
        - Perplexity explodes: 5.5 → 50+
        - Model becomes useless
      |
    }
    gptq_success: "GPTQ Algorithm" {
      style.fill: ${colors.purple}
      style.font-color: white
      desc: |md
        **Column-by-column with compensation:**
        1. Quantize column j
        2. Compute error δ_j
        3. Update remaining columns
        4. Use Hessian for importance
      |
    }
    hessian: "Hessian Computation" {
      style.fill: "#EDE9FE"
      formula: "H = 2 × X^T × X"
      diagonal: "Diagonal approximation for speed"
      cholesky: "Cholesky decomposition for stability"
    }
    group_size: "Group Size 128" {
      style.fill: "#EDE9FE"
      desc: |md
        - 128 weights share 1 scale
        - Handles weight variance
        - Standard configuration
      |
    }
    packing: "INT4 Packing" {
      style.fill: ${colors.purple}
      style.font-color: white
      desc: |md
        - Two INT4 per byte
        - -8..7 → 0..15 (unsigned)
        - Lower nibble + upper << 4
        - True 8x compression
      |
    }
    results: "GPTQ Results" {
      style.fill: "#F3E8FF"
      compression: "~4x size reduction (INT4)"
      perplexity: "Increase < 1.0"
      improvement: "30%+ better than naive"
    }
  }
}