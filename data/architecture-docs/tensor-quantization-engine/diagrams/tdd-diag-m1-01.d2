layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

direction: right

# -----------------------------------------------------------------------------------------
# CLASSES: Definition of technical visual standards for FP32/INT8 conversion
# -----------------------------------------------------------------------------------------
classes: {
  step: {
    shape: circle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  fp32_value: {
    shape: circle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      font-size: 11
    }
  }
  int8_value: {
    shape: circle
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      font-size: 11
    }
  }
  formula: {
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      font-size: 16
      bold: true
    }
  }
  changed: {
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
      stroke-width: 3
      bold: true
      shadow: true
    }
  }
  container_style: {
    style: {
      stroke-width: 2
      stroke-dash: 3
      border-radius: 8
    }
  }
}

# -----------------------------------------------------------------------------------------
# HEADER & CORE TRANSFORM EQUATION
# -----------------------------------------------------------------------------------------
title: "Affine Quantization Transform (FP32 -> INT8)" {
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

formula_box: "q = clamp(round(r / scale + zero_point), q_min, q_max)" {
  class: formula
  style: {
    font-size: 20
  }
}

# -----------------------------------------------------------------------------------------
# ALGORITHM EXECUTION STEPS
# -----------------------------------------------------------------------------------------
step1: "1" { class: step; tooltip: "Sample FP32 Input" }
step2: "2" { class: step; tooltip: "Calculate Parameters" }
step3: "3" { class: step; tooltip: "Execute Transform" }
step4: "4" { class: step; tooltip: "Store INT8 Result" }

# -----------------------------------------------------------------------------------------
# BEFORE STATE: FP32 Continuous Real-Value Domain
# -----------------------------------------------------------------------------------------
fp32_container: "FP32 Range (Continuous Real Values)" {
  class: container_style
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"

  fp32_label: "r ∈ [r_min, r_max]" {
    shape: text
    style.italic: true
  }

  fp32_line: "" {
    width: 400
    height: 4
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 2
    }
  }

  fp32_min: "r_min = -1.5" { class: fp32_value }
  fp32_zero: "0.0" { class: fp32_value }
  fp32_max: "r_max = 2.5" { class: fp32_value }
  
  # Tracking the transformation of value r=0.75
  fp32_example: "r = 0.75" { 
    class: [fp32_value; changed]
    style.font-size: 12
  }
}

# -----------------------------------------------------------------------------------------
# METADATA: Quantization Constants (Scale & Zero-Point)
# -----------------------------------------------------------------------------------------
params: "Quantization Parameters (Metadata)" {
  class: container_style
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"

  scale_label: "scale = (r_max - r_min) / (q_max - q_min)" {
    shape: text
    style.font-size: 13
  }
  scale_calc: "scale = (2.5 - (-1.5)) / 255 ≈ 0.015686" {
    shape: text
    style: { font-size: 13; bold: true }
  }
  
  zp_label: "zero_point = round(q_min - r_min / scale)" {
    shape: text
    style.font-size: 13
  }
  zp_calc: "zero_point = round(0 - (-1.5) / 0.015686) = 96" {
    shape: text
    style: { font-size: 13; bold: true }
  }
}

# -----------------------------------------------------------------------------------------
# EXECUTION: Quantization Pipeline Operations
# -----------------------------------------------------------------------------------------
compute: "Computation Unit (ALU)" {
  class: container_style
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"

  div_op: "1. Divide: 0.75 / 0.015686 = 47.81" {
    shape: text
    style.font-size: 13
  }
  add_op: "2. Shift: 47.81 + 96 = 143.81" {
    shape: text
    style.font-size: 13
  }
  round_op: "3. Final: round(143.81) = 144" {
    shape: text
    style: { font-size: 14; bold: true; font-color: "#D32F2F" }
  }
}

# -----------------------------------------------------------------------------------------
# INTERMEDIATE: Value-to-Grid Alignment
# -----------------------------------------------------------------------------------------
grid_marks: "INT8 Discrete Grid Points" {
  style: {
    fill: "#FFF8E1"
    stroke: "#FFB300"
    border-radius: 4
  }
  
  tick_0: "| 0 | ... | 96 | ... | 144 | ... | 255 |" {
    shape: text
    style: {
      font-size: 12
      font: mono
    }
  }
  
  tick_highlight: "Value maps to Index 144" {
    shape: text
    style: {
      font-size: 13
      bold: true
      font-color: "#D32F2F"
    }
  }
}

# -----------------------------------------------------------------------------------------
# AFTER STATE: Discretized INT8 Memory Representation
# -----------------------------------------------------------------------------------------
int8_container: "INT8 Grid (Storage Format)" {
  class: container_style
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"

  int8_label: "q ∈ [0, 255] (uint8)" {
    shape: text
    style.italic: true
  }

  int8_line: "" {
    width: 400
    height: 4
    style: {
      fill: "#FFE0B2"
      stroke: "#F57C00"
      stroke-width: 2
    }
  }

  int8_min: "q_min = 0" { class: int8_value }
  int8_zp: "ZP = 96" { class: int8_value }
  int8_max: "q_max = 255" { class: int8_value }
  
  # The final stored quantized integer result
  int8_result: "q = 144" { 
    class: [int8_value; changed]
    style.font-size: 12
  }
}

# -----------------------------------------------------------------------------------------
# DATA FLOW & RELATIONSHIP MAPPING
# -----------------------------------------------------------------------------------------

# Algorithm Execution Flow
step1 -> fp32_container.fp32_example: "Fetch Sample" { style.stroke: "#1976D2" }
step2 -> params: "Sync Params" { style.stroke: "#1976D2" }
step3 -> compute: "Execute Pipeline" { style.stroke: "#1976D2" }
step4 -> int8_container.int8_result: "Commit Write" { style.stroke: "#1976D2" }

# Dependency and Data Transfer Paths
formula_box -> step3: "Logic Basis" {
  style: {
    stroke: "#7B1FA2"
    stroke-dash: 4
  }
}

fp32_container.fp32_example -> compute: "FP32 Input" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}

params -> compute: "Scale/ZP constants" {
  style: {
    stroke: "#455A64"
    stroke-dash: 2
  }
}

compute -> grid_marks: "Calculated Index" {
  style: {
    stroke: "#F9A825"
    stroke-width: 2
  }
}

grid_marks -> int8_container.int8_result: "Aligned Integer" {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
  }
}

# Technical Specification Legend
legend: "Technical Legend" {
  near: bottom-right
  style: { fill: "#FAFAFA"; stroke: "#9E9E9E" }
  
  l1: "FP32 Continuous" { class: fp32_value }
  l2: "INT8 Discrete" { class: int8_value }
  l3: "Resultant State" { class: changed }
}