vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # Tensor Quantization: Symmetric vs Asymmetric Ranges
  *Reference for Hardware Accelerator Implementation*
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# Implementation Specification Table
spec: {
  shape: sql_table
  near: top-right
  style.fill: "#F5F5F5"
  
  "Feature": "Detail"
  "Bit-width": "8-bit (INT8/UINT8)"
  "Symmetric Range": "[-127, 127]"
  "Asymmetric Range": "[-128, 127] or [0, 255]"
  "Zero Point (Z)": "Fixed @ 0 vs. Dynamic Offset"
  "Math Logic": "q = clip(round(f/s + Z))"
}

# --- Symmetric Implementation ---
symmetric: {
  label: "Symmetric Quantization (INT8 Weights)"
  tooltip: "Preferred for weights to simplify MAC unit logic."
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 4
    double-border: true
  }

  # Layout container for internal alignment
  header: {
    grid-columns: 2
    grid-gap: 320
    style.stroke-width: 0
    style.fill: transparent

    min_val: "-127" {
      shape: text
      style: { font-color: "#1B5E20"; bold: true; font-size: 16 }
    }

    max_val: "+127" {
      shape: text
      style: { font-color: "#1B5E20"; bold: true; font-size: 16 }
    }
  }

  visual_range: {
    label: ""
    direction: right
    style: {
      fill: transparent
      stroke: "#2E7D32"
      stroke-dash: 0
    }

    start_cap: "|" {
      shape: text
      style.font-size: 20
    }
    
    line: {
      shape: rectangle
      width: 400
      height: 12
      style: {
        fill: "linear-gradient(to right, #4CAF50, #A5D6A7, #4CAF50)"
        stroke: "#1B5E20"
      }
    }
    
    end_cap: "|" {
      shape: text
      style.font-size: 20
    }

    start_cap -> line -> end_cap: {style.opacity: 0}
  }

  # Hardware component representation
  zero_point: "Zero Point (Z=0)" {
    shape: diamond
    style: {
      fill: "#FFFFFF"
      stroke: "#1B5E20"
      stroke-width: 3
    }
  }

  metadata: |md
    ### Attributes
    - **Balance**: Even distribution around zero.
    - **Optimization**: Zero-point addition is omitted in hardware.
    - **Unused Value**: -128 is typically ignored to maintain symmetry.
    - **Formula**: `q = round(f / scale)`
  | {
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#81C784"
      stroke-dash: 3
    }
  }
  
  header -> visual_range -> zero_point -> metadata: {style.opacity: 0}
}

# --- Asymmetric Implementation ---
asymmetric: {
  label: "Asymmetric Quantization (INT8 Activations)"
  tooltip: "Optimized for non-negative data like ReLU outputs."
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 4
    double-border: true
  }

  header: {
    grid-columns: 2
    grid-gap: 320
    style.stroke-width: 0
    style.fill: transparent

    min_val: "-128" {
      shape: text
      style: { font-color: "#0D47A1"; bold: true; font-size: 16 }
    }

    max_val: "+127" {
      shape: text
      style: { font-color: "#0D47A1"; bold: true; font-size: 16 }
    }
  }

  visual_range: {
    label: ""
    direction: right
    style: {
      fill: transparent
      stroke: "#1565C0"
    }

    start_cap: "|" {
      shape: text
      style.font-size: 20
    }
    
    line: {
      shape: rectangle
      width: 400
      height: 12
      style: {
        fill: "linear-gradient(to right, #2196F3, #BBDEFB, #2196F3)"
        stroke: "#0D47A1"
      }
    }
    
    end_cap: "|" {
      shape: text
      style.font-size: 20
    }

    start_cap -> line -> end_cap: {style.opacity: 0}
  }

  offset_z: "Zero Point (Z)" {
    shape: diamond
    style: {
      fill: "#FFFFFF"
      stroke: "#B71C1C" 
      stroke-width: 3
    }
  }

  metadata: |md
    ### Attributes
    - **Full Range**: Map all 256 levels of INT8/UINT8.
    - **Efficiency**: Ideal for skewed data (e.g., Sigmoid/ReLU).
    - **Overhead**: Requires ALU to add `Z` before accumulation.
    - **Formula**: `q = round(f / scale + Z)`
  | {
    shape: rectangle
    style: {
      fill: "#FFFFFF"
      stroke: "#64B5F6"
      stroke-dash: 3
    }
  }

  header -> visual_range -> offset_z -> metadata: {style.opacity: 0}
}

# Comparison and Logic Flow
logic_comparison: {
  shape: package
  label: "Hardware Logic Comparison"
  near: bottom-center
  
  direction: right
  
  sym_logic: "Symmetric Path" {
    shape: parallelogram
    label: "Accumulator += W * A"
    style.fill: "#E8F5E9"
  }
  
  asym_logic: "Asymmetric Path" {
    shape: parallelogram
    label: "Accumulator += W * (A - Z)"
    style.fill: "#E3F2FD"
  }

  sym_logic <-> asym_logic: "Complexity Gap" {
    style.stroke-dash: 5
    label: "+1 ALU Cycle"
  }
}

# Legend / Global Formulas
formulas: {
  label: "Quantization Constants"
  near: bottom-left
  
  scale: "Scale (S) = (f_max - f_min) / (q_max - q_min)" {
    shape: text
    style.font: mono
  }
  
  zp: "Zero Point (Z) = round(q_min - f_min / S)" {
    shape: text
    style.font: mono
  }
  
  scale -> zp: {style.opacity: 0}
}

# Structural Guidance Connections
symmetric -> asymmetric: "Quantization Strategy Comparison" {
  style: {
    stroke: "#BDBDBD"
    stroke-width: 2
    stroke-dash: 8
  }
}

# Root-level structural alignment (invisible)
formulas -> logic_comparison: { style.opacity: 0 }
spec -> symmetric: { style.opacity: 0 }