layout-engine: elk
theme: 4
title: {
  label: Quantization Error Distribution\nNormal vs Heavy-Tailed Inputs
  shape: text
  near: top-center
}
# Error bound reference
error_bound: {
  shape: text
  label: Error Bound: |ε(r)| ≤ scale/2
  style.font-size: 20
  style.bold: true
  style.fill: "#1f77b4"
  style.font-color: white
  style.stroke: "#1f77b4"
  style.border-radius: 4
}
# Normal Distribution Histogram
normal_dist: {
  label: Normal Distribution Inputs
  shape: rectangle
  style.fill: "#e8f4e8"
  style.stroke: "#2ca02c"
  style.stroke-width: 2
  # Histogram bars for normal distribution (centered around 0)
  bar_n1: {
    shape: rectangle
    label: "2%"
    width: 40
    height: 20
    style.fill: "#2ca02c"
  }
  bar_n2: {
    shape: rectangle
    label: "8%"
    width: 40
    height: 60
    style.fill: "#2ca02c"
  }
  bar_n3: {
    shape: rectangle
    label: "20%"
    width: 40
    height: 120
    style.fill: "#2ca02c"
  }
  bar_n4: {
    shape: rectangle
    label: "35%"
    width: 40
    height: 180
    style.fill: "#2ca02c"
  }
  bar_n5: {
    shape: rectangle
    label: "20%"
    width: 40
    height: 120
    style.fill: "#2ca02c"
  }
  bar_n6: {
    shape: rectangle
    label: "10%"
    width: 40
    height: 70
    style.fill: "#2ca02c"
  }
  bar_n7: {
    shape: rectangle
    label: "5%"
    width: 40
    height: 40
    style.fill: "#2ca02c"
  }
  axis_label: {
    shape: text
    label: Quantization Error (ε)
    style.font-size: 14
  }
}
# Heavy-Tailed Distribution Histogram
heavy_dist: {
  label: Heavy-Tailed Distribution Inputs
  shape: rectangle
  style.fill: "#fff0e0"
  style.stroke: "#ff7f0e"
  style.stroke-width: 2
  # Histogram bars for heavy-tailed (wider spread, outliers)
  bar_h1: {
    shape: rectangle
    label: "5%"
    width: 40
    height: 50
    style.fill: "#ff7f0e"
  }
  bar_h2: {
    shape: rectangle
    label: "8%"
    width: 40
    height: 70
    style.fill: "#ff7f0e"
  }
  bar_h3: {
    shape: rectangle
    label: "12%"
    width: 40
    height: 100
    style.fill: "#ff7f0e"
  }
  bar_h4: {
    shape: rectangle
    label: "15%"
    width: 40
    height: 130
    style.fill: "#ff7f0e"
  }
  bar_h5: {
    shape: rectangle
    label: "15%"
    width: 40
    height: 130
    style.fill: "#ff7f0e"
  }
  bar_h6: {
    shape: rectangle
    label: "12%"
    width: 40
    height: 100
    style.fill: "#ff7f0e"
  }
  bar_h7: {
    shape: rectangle
    label: "8%"
    width: 40
    height: 70
    style.fill: "#ff7f0e"
  }
  bar_h8: {
    shape: rectangle
    label: "10%"
    width: 40
    height: 85
    style.fill: "#ff7f0e"
  }
  bar_h9: {
    shape: rectangle
    label: "8%"
    width: 40
    height: 70
    style.fill: "#ff7f0e"
  }
  bar_h10: {
    shape: rectangle
    label: "7%"
    width: 40
    height: 60
    style.fill: "#ff7f0e"
  }
  axis_label: {
    shape: text
    label: Quantization Error (ε)
    style.font-size: 14
  }
}
# Scale comparison panel
scale_comparison: {
  label: Scale Comparison
  shape: rectangle
  style.fill: "#f0f0f0"
  style.stroke: "#666666"
  style.stroke-dash: 4
  normal_scale: {
    shape: rectangle
    label: "Normal Scale\n(Compact)"
    style.fill: "#2ca02c"
    style.font-color: white
    width: 120
    height: 40
  }
  heavy_scale: {
    shape: rectangle
    label: "Inflated Scale\n(Outlier Impact)"
    style.fill: "#ff7f0e"
    style.font-color: white
    width: 200
    height: 40
  }
  scale_arrow: {
    shape: text
    label: "→ scale increases →"
    style.font-size: 12
    style.italic: true
  }
}
# Error bound indicators
upper_bound_normal: {
  shape: text
  label: "+scale/2"
  style.font-size: 12
  style.bold: true
  style.fill: "#1f77b4"
  style.font-color: white
}
lower_bound_normal: {
  shape: text
  label: "-scale/2"
  style.font-size: 12
  style.bold: true
  style.fill: "#1f77b4"
  style.font-color: white
}
# Key insights panel
insights: {
  label: Key Insights
  shape: rectangle
  style.fill: "#e6f3ff"
  style.stroke: "#1f77b4"
  insight1: {
    shape: text
    label: • Normal inputs: Error concentrated near zero
    style.font-size: 12
  }
  insight2: {
    shape: text
    label: • Heavy-tailed: Wider error spread due to outliers
    style.font-size: 12
  }
  insight3: {
    shape: text
    label: • Outliers inflate scale → larger errors for all values
    style.font-size: 12
  }
  insight4: {
    shape: text
    label: • Solution: Percentile calibration clips outliers
    style.font-size: 12
    style.bold: true
  }
}
# Legend
legend: {
  shape: rectangle
  label: Legend
  style.fill: "#fafafa"
  style.stroke: "#cccccc"
  normal_legend: {
    shape: rectangle
    label: "Normal Distribution"
    width: 20
    height: 15
    style.fill: "#2ca02c"
  }
  heavy_legend: {
    shape: rectangle
    label: "Heavy-Tailed"
    width: 20
    height: 15
    style.fill: "#ff7f0e"
  }
  bound_legend: {
    shape: rectangle
    label: "Error Bound (±scale/2)"
    width: 20
    height: 15
    style.fill: "#1f77b4"
  }
}
# Mathematical formula box
formula_box: {
  label: Quantization Error Formula
  shape: rectangle
  style.fill: "#fff8dc"
  style.stroke: "#daa520"
  style.stroke-width: 2
  formula: {
    shape: text
    label: "ε(r) = r - Q(r) = r - round(r/scale + zp) × scale + zp×scale"
    style.font-size: 14
    style.bold: true
  }
  bound: {
    shape: text
    label: "Bound: |ε(r)| ≤ scale/2"
    style.font-size: 14
    style.fill: "#cc0000"
  }
}
# Connections
error_bound -> normal_dist: {
  label: bounds error
  style.stroke: "#1f77b4"
  style.stroke-dash: 3
}
error_bound -> heavy_dist: {
  label: bounds error
  style.stroke: "#1f77b4"
  style.stroke-dash: 3
}
normal_dist -> scale_comparison.normal_scale: {
  label: produces
  style.stroke: "#2ca02c"
}
heavy_dist -> scale_comparison.heavy_scale: {
  label: produces
  style.stroke: "#ff7f0e"
}
scale_comparison -> insights: {
  label: explains
  style.stroke: "#666666"
  style.stroke-dash: 2
}
formula_box -> error_bound: {
  label: defines
  style.stroke: "#daa520"
}