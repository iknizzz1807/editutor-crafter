direction: right
vars: {
  d2-config: {
    layout-engine: tala
    theme-id: 4
    pad: 40
  }
  colors: {
    axis: "#334155"
    grid: "#e2e8f0"
    severe: "#ef4444"
    moderate: "#eab308"
    optimal: "#22c55e"
    near_fp: "#3b82f6"
    header: "#6d28d9"
    data: "#2563eb"
    padding: "#94a3b8"
    cache_line: "#64748b"
  }
}

# --- GLOBAL STYLES ---
***.style.font: mono

# --- TITLE BLOCK ---
header: {
  title: "BIT WIDTH VS MSE TRADEOFF CURVE" {
    shape: text
    style: {
      font-size: 32
      bold: true
      underline: true
    }
  }
  subtitle: "Numerical Precision Analysis & Memory Layout for Tensor Quantization" {
    shape: text
    style.font-size: 18
  }
}

# --- MEMORY LAYOUT REPRESENTATION ---
# Intel-Manual Style Memory Maps
memory_layouts: "Physical Memory Footprint (Bit-Level Layout)" {
  style.stroke: "#475569"
  style.fill: "#f8fafc"
  style.stroke-width: 2

  fp16_layout: {
    label: "FP16 (IEEE 754 Half Precision)"
    shape: sql_table
    "0x00": "Sign [1b]" {constraint: "bit 15"}
    "0x01": "Exponent [5b]" {constraint: "bits 14:10"}
    "0x06": "Mantissa [10b]" {constraint: "bits 9:0"}
    footer: "Total Size: 16 bits | Range: ±65,504" {style.stroke-width: 0; style.italic: true}
    
    style.fill: ${colors.near_fp}
  }

  int8_layout: {
    label: "INT8 (Two's Complement)"
    shape: sql_table
    "0x00": "Integer Payload [8b]" {constraint: "bits 7:0"}
    padding: "Zero Padding" {style.fill: ${colors.padding}; style.stroke-dash: 3}
    footer: "Total Size: 8 bits | Range: -128 to 127" {style.stroke-width: 0; style.italic: true}
    
    style.fill: ${colors.optimal}
  }

  int4_layout: {
    label: "INT4 (Sub-byte Packing)"
    shape: sql_table
    "0x00": "Element Low [4b]" {constraint: "bits 3:0"}
    "0x04": "Element High [4b]" {constraint: "bits 7:4"}
    footer: "Packing Ratio: 2:1 (8-bit addressable)" {style.stroke-width: 0; style.italic: true}
    
    style.fill: ${colors.moderate}
  }
  
  # Cache line visualization
  cache_line_boundary: "64-Byte Cache Line Boundary" {
    shape: text
    style: {
      stroke-dash: 5
      font-color: ${colors.cache_line}
      font-size: 10
    }
  }
}

# --- ANALYTICAL CHART ---
tradeoff_analysis: {
  style.fill: white
  style.stroke-width: 0

  y_axis: {
    label: "MSE Error (Mean Squared Error)"
    shape: rectangle
    style: {
      stroke: ${colors.axis}
      stroke-width: 4
      fill: "#f1f5f9"
      bold: true
    }
    
    ticks: {
      grid-rows: 5
      grid-gap: 40
      style.stroke-width: 0
      t0: "1.000" { shape: text }
      t1: "0.500" { shape: text }
      t2: "0.100" { shape: text }
      t3: "0.010" { shape: text }
      t4: "0.001" { shape: text }
    }
  }

  plot_area: "Precision Decay Function: f(bits)" {
    style: {
      fill: "#ffffff"
      stroke: "#cbd5e1"
      stroke-width: 1
    }

    # Data Points
    p2: "2-bit (Binary)" {
      shape: circle
      style: { fill: ${colors.severe}; stroke: black; stroke-width: 2; bold: true }
      tooltip: "MSE: 0.521 - Accuracy Collapse"
    }

    p4: "4-bit (INT4)" {
      shape: circle
      style: { fill: ${colors.moderate}; stroke: black; stroke-width: 2; bold: true }
      tooltip: "MSE: 0.048 - Optimal for LLM weights"
    }

    p8: "8-bit (INT8)" {
      shape: circle
      style: { fill: ${colors.optimal}; stroke: black; stroke-width: 2; bold: true }
      tooltip: "MSE: 0.003 - Industry Inference Std"
    }

    p16: "16-bit (FP16)" {
      shape: circle
      style: { fill: ${colors.near_fp}; stroke: black; stroke-width: 2; bold: true }
      tooltip: "MSE: 1e-7 - Training Baseline"
    }

    # Curve mapping (State transitions)
    p2 -> p4: "Gain: 10.8x" {
      style: { stroke: "#f97316"; stroke-width: 3; stroke-dash: 3; animated: true }
    }
    p4 -> p8: "Gain: 16.0x" {
      style: { stroke: "#84cc16"; stroke-width: 3; stroke-dash: 3; animated: true }
    }
    p8 -> p16: "Convergence" {
      style: { stroke: "#06b6d4"; stroke-width: 3; stroke-dash: 3; animated: true }
    }
  }

  x_axis: {
    label: "Quantization Bit-Width (N-bits)"
    shape: rectangle
    style: {
      stroke: ${colors.axis}
      stroke-width: 4
      fill: "#f1f5f9"
      bold: true
    }
    
    ticks: {
      grid-columns: 4
      grid-gap: 80
      style.stroke-width: 0
      b2: "N=2" { shape: text }
      b4: "N=4" { shape: text }
      b8: "N=8" { shape: text }
      b16: "N=16" { shape: text }
    }
  }
}

# --- DOCUMENTATION PANELS ---
sidebar: {
  formula: |latex
    \text{MSE} \approx \frac{\Delta^2}{12} \quad \text{where} \quad \Delta = \frac{x_{max} - x_{min}}{2^n - 1}
  | {
    label: "Uniform Quantization Noise"
    shape: parallelogram
    style.fill: "#f5f3ff"
    style.stroke: "#7c3aed"
  }

  insights: {
    label: "Hardware Implementation Guide"
    content: |md
    ### Memory Bandwidth (BW)
    * **4-bit**: Reduces BW by 4x vs FP16. 
    * Ideal for I/O bound Large Language Models (LLMs).
    
    ### Compute Throughput
    * **INT8**: 2x peak TOPS vs FP16 on NVIDIA Tensor Cores.
    * Use `_mm256_adds_epi8` for SIMD saturation logic.
    |
    style.fill: "#eff6ff"
    style.stroke: "#3b82f6"
  }

  legend: {
    label: "Precision Invariants"
    grid-rows: 3
    style.stroke-width: 1
    l1: "● SEVERE: SNR < 10dB (Illegal for Prod)" { shape: text; style.font-color: ${colors.severe} }
    l2: "● MODERATE: 40dB < SNR < 50dB (GPTQ/AWQ)" { shape: text; style.font-color: ${colors.moderate} }
    l3: "● OPTIMAL: High Fidelity PTQ" { shape: text; style.font-color: ${colors.optimal} }
  }
}

# --- ANNOTATIONS ---
annotation_baseline: "FP32 Baseline (MSE → 0)" {
  near: top-right
  shape: text
  style: {
    italic: true
    font-color: "#64748b"
    font-size: 11
    bold: true
  }
}

# --- LOGICAL FLOW HINTS ---
# Layout hints for TALA engine to ensure correct grouping
memory_layouts -> tradeoff_analysis: {style.stroke-width: 0; style.opacity: 0}
tradeoff_analysis -> sidebar: {style.stroke-width: 0; style.opacity: 0}

# Invisible axes connections for spatial consistency
tradeoff_analysis.y_axis -> tradeoff_analysis.plot_area: {style.stroke: transparent}
tradeoff_analysis.plot_area -> tradeoff_analysis.x_axis: {style.stroke: transparent}