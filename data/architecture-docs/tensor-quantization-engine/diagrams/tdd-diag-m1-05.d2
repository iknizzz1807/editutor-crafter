vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 20
  }
}

"TensorQuantizer State Machine": {
  # FIX: changed 'state_diagram' (invalid) to 'package'
  shape: package
  style: {
    stroke-width: 2
    stroke-dash: 0
    fill: "#FAFAFA"
  }

  # Initial state marker
  start: {
    shape: circle
    label: ""
    style.fill: "#333"
    width: 20
    height: 20
  }

  # State Definitions with Detailed Invariants
  Uncalibrated: {
    label: "STATE: Uncalibrated\n(Initial/Reset)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.bold: true
    "Internal State": |md
      **Invariants:**
      - `is_calibrated` : **uint8(0)**
      - `scale_fp32` : **NULL** (0x00000000)
      - `zp_int32` : **NULL** (0x00000000)
      - `bit_width` : 8-bit (default)
      - `range` : [0.0, 0.0]
    |
  }

  Calibrating: {
    label: "STATE: Calibrating\n(Statistics Collection)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    "Internal State": |md
      **Active Processes:**
      - `running_min`: min(batch_min, current_min)
      - `running_max`: max(batch_max, current_max)
      - `hist_bins`: update(tensor_distribution)
      - *Action*: Partial parameter estimation
    |
  }

  Calibrated: {
    label: "STATE: Calibrated\n(Ready for Ops)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    "Internal State": |md
      **Computed Parameters:**
      - `is_calibrated` : **uint8(1)**
      - `scale` : `(max-min)/(qmax-qmin)`
      - `zero_point` : `qmin - min/scale`
      - `type` : Symmetric/Asymmetric
    |
  }

  Quantizing: {
    label: "STATE: Quantizing\n(Transform Execution)"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    "Internal State": |md
      **Operation Context:**
      - `Instruction`: VPMADDUBSW (Simulated)
      - `Formula`: $q = \text{clamp}(\lfloor f/s + z \rceil)$
      - `Saturation`: [0, 255] for UINT8
    |
  }

  ErrorState: {
    label: "RuntimeError\nInvalidStateTransition"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.font-color: "#B71C1C"
    "Reason": |md
      **Traceback:**
      Attempted to access `_quantize_impl`
      while `is_calibrated == 0`.
      Memory Access Violation at `scale` ptr.
    |
  }

  # Initial transition
  start -> Uncalibrated: "CTOR: init_quantizer()"

  # Valid Transitions with Triggers & Guards
  Uncalibrated -> Calibrating: "Trigger: calibrate(batch_data)" {
    style.stroke: "#2196F3"
    style.stroke-width: 3
  }

  Calibrating -> Calibrated: "Guard: epoch_complete\nAction: finalize_params()" {
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }

  Calibrated -> Quantizing: "Trigger: quantize(fp32_tensor)\n[Guard: is_calibrated == 1]" {
    style.stroke: "#9C27B0"
    style.stroke-width: 3
  }

  Quantizing -> Calibrated: "Return: int8_tensor" {
    style.stroke: "#9C27B0"
    style.stroke-dash: 3
    style.animated: true
  }

  Calibrated -> Calibrating: "Trigger: reset_calibration()" {
    style.stroke: "#FF9800"
    style.stroke-dash: 3
  }

  # Illegal transitions (Red dashed)
  Uncalibrated -> ErrorState: "Method Call: quantize()" {
    style.stroke: "#F44336"
    style.stroke-dash: 5
    label: "❌ ILLEGAL_OP"
  }

  Calibrating -> ErrorState: "Method Call: dequantize()" {
    style.stroke: "#F44336"
    style.stroke-dash: 5
    label: "❌ ILLEGAL_OP"
  }
}

# FIX: Moved legend to root level to allow 'near' positioning
"Quantizer Specification Legend": {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#E0E0E0"
    double-border: true
    font-size: 14
  }
  
  valid: {
    label: "→ Valid State Transition"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
  }
  illegal: {
    label: "⇢ ILLEGAL (Throws RuntimeError)"
    style.stroke: "#F44336"
    style.stroke-dash: 5
  }
  return: {
    label: "⇢ Async Return / Result"
    style.stroke: "#9C27B0"
    style.stroke-dash: 3
  }

  metadata: |md
    **Implementation Notes:**
    - Sizeof(Quantizer): 128 Bytes
    - Alignment: 64-Byte (Cache Line)
    - Thread-Safety: Atomic state flags
  |
}