direction: right
layout-engine: elk

title: {
  label: "Integer Overflow Scenario: Why INT8×INT8 Requires INT32 Accumulation"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Problem demonstration container
problem: {
  label: "THE PROBLEM: INT8 Overflow"
  header_prob: {
    shape: text
    label: "INT8 range: -128 to 127 (8 bits)"
    style: {
      font-size: 14
      italic: true
    }
  }
  step1: {
    label: "Step 1: Quantized Values"
    shape: rectangle
    style.fill: "#E3F2FD"
    val_a: {
      label: "Value A"
      shape: rectangle
      style.fill: "#BBDEFB"
      a_bits: {
        label: "01100100\n(binary)"
        shape: text
        style.font-size: 11
      }
      a_dec: {
        label: "= 100 (decimal)"
        shape: text
        style: {
          font-size: 14
          bold: true
        }
      }
    }
    val_b: {
      label: "Value B"
      shape: rectangle
      style.fill: "#BBDEFB"
      b_bits: {
        label: "01100100\n(binary)"
        shape: text
        style.font-size: 11
      }
      b_dec: {
        label: "= 100 (decimal)"
        shape: text
        style: {
          font-size: 14
          bold: true
        }
      }
    }
    val_a -> val_b: "× (multiply)"
  }
  step2: {
    label: "Step 2: Multiplication Result"
    shape: rectangle
    style.fill: "#FFEBEE"
    raw_result: {
      label: "100 × 100 = 10,000"
      shape: text
      style: {
        font-size: 18
        bold: true
      }
    }
    overflow_check: {
      label: "10,000 > 127"
      shape: text
      style: {
        font-size: 16
        bold: true
        font-color: "#B71C1C"
      }
    }
    max_int8: {
      label: "INT8_MAX = 127"
      shape: text
      style: {
        font-size: 12
        italic: true
      }
    }
  }
  step3: {
    label: "Step 3: Overflow Result"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 3
    }
    overflow_header: {
      label: "❌ OVERFLOW!"
      shape: text
      style: {
        font-size: 20
        bold: true
        font-color: "#B71C1C"
      }
    }
    truncated: {
      label: "Truncated to INT8:\n10,000 mod 256 = 16"
      shape: text
      style.font-size: 14
    }
    garbage: {
      label: "= GARBAGE VALUE"
      shape: text
      style: {
        font-size: 16
        bold: true
        font-color: "#B71C1C"
      }
    }
  }
  step1 -> step2 -> step3
}

# Visual byte representation
byte_viz: {
  label: "Byte Layout Visualization"
  int8_box: {
    label: "INT8 (1 byte)"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke-dash: 3
    }
    bits_row: {
      shape: rectangle
      label: "b7|b6|b5|b4|b3|b2|b1|b0"
      style: {
        fill: "#FFE0B2"
        font-size: 10
      }
    }
    range_label: {
      shape: text
      label: "Range: -128 to +127\nMax positive: 01111111 = +127"
      style.font-size: 11
    }
  }
  int32_box: {
    label: "INT32 (4 bytes) - Required!"
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    byte3: {
      label: "Byte 3\n(High)"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    byte2: {
      label: "Byte 2"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
    byte1: {
      label: "Byte 1"
      shape: rectangle
      style.fill: "#81C784"
    }
    byte0: {
      label: "Byte 0\n(Low)"
      shape: rectangle
      style.fill: "#66BB6A"
    }
    byte3 -> byte2 -> byte1 -> byte0
    range_label32: {
      shape: text
      label: "Range: -2,147,483,648 to +2,147,483,647\nCan hold 127² × K safely!"
      style: {
        font-size: 11
        font-color: "#1B5E20"
      }
    }
  }
}

# Solution container
solution: {
  label: "THE SOLUTION: INT32 Accumulation"
  correct_flow: {
    label: "Correct Quantized Inference Flow"
    shape: rectangle
    style.fill: "#E8F5E9"
    cstep1: {
      label: "1. Load INT8 Weights"
      shape: rectangle
      style.fill: "#C8E6C9"
      w_bits: {
        label: "int8_t weight = 100"
        shape: text
        style: {
          font-size: 12
          font: mono
        }
      }
    }
    cstep2: {
      label: "2. Load INT8 Activations"
      shape: rectangle
      style.fill: "#C8E6C9"
      a_bits: {
        label: "int8_t activation = 100"
        shape: text
        style: {
          font-size: 12
          font: mono
        }
      }
    }
    cstep3: {
      label: "3. Widen & Multiply"
      shape: rectangle
      style.fill: "#A5D6A7"
      widen: {
        label: "int32_t temp = (int32_t)weight\n             × (int32_t)activation"
        shape: text
        style: {
          font-size: 12
          font: mono
        }
      }
      result: {
        label: "temp = 10,000 ✓"
        shape: text
        style: {
          font-size: 14
          bold: true
          font-color: "#1B5E20"
        }
      }
    }
    cstep4: {
      label: "4. Accumulate in INT32"
      shape: rectangle
      style: {
        fill: "#81C784"
        stroke: "#2E7D32"
        stroke-width: 2
      }
      accum: {
        label: "int32_t accumulator = 0\nfor (i = 0; i < K; i++) {\n  accumulator += temp[i]\n}"
        shape: text
        style: {
          font-size: 11
          font: mono
        }
      }
      max_accum: {
        label: "Max sum: 127² × K\nFor K=1024: 16,641,024\nStill fits in INT32!"
        shape: text
        style: {
          font-size: 10
          font-color: "#1B5E20"
        }
      }
    }
    cstep5: {
      label: "5. Requantize to INT8"
      shape: rectangle
      style.fill: "#66BB6A"
      requant: {
        label: "int8_t output = (int8_t)(\n  accumulator × scale + zero_point\n)"
        shape: text
        style: {
          font-size: 11
          font: mono
        }
      }
      out_val: {
        label: "Properly scaled result"
        shape: text
        style: {
          font-size: 12
          font-color: "#1B5E20"
        }
      }
    }
    cstep1 -> cstep2 -> cstep3 -> cstep4 -> cstep5
  }
}

# Mathematical proof
math_box: {
  label: "Mathematical Proof"
  shape: rectangle
  style.fill: "#F3E5F5"
  formula: {
    label: "INT8 × INT8 Range Analysis:\n\nMin: (-128) × (-128) = 16,384\nMax: (127) × (127) = 16,129\n\nWith K elements accumulated:\nMax accumulator = 16,129 × K\n\nFor typical K=4096:\nMax = 66,088,964\n\nINT32_MAX = 2,147,483,647 ✓"
    shape: text
    style.font-size: 13
  }
}

# Comparison table
comparison: {
  label: "Comparison: Naive vs Correct"
  shape: rectangle
  table: {
    shape: sql_table
    "Naive Approach": "int8_t Accumulator" {constraint: "❌ OVERFLOW"}
    "Correct Approach": "int32_t Accumulator" {constraint: "✓ Valid Accumulation"}
  }
}

# Key insight callout
insight: {
  label: "💡 KEY INSIGHT"
  shape: rectangle
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
  }
  insight_text: {
    label: "Quantized inference MUST use INT32 as the accumulation\ndatatype because the product of two INT8 values requires\nup to 16 bits, and summing K such products requires even more.\n\nThis is why frameworks like TensorFlow Lite and ONNX Runtime\nuse int32_t for their quantized GEMM kernels."
    shape: text
    style.font-size: 13
  }
}

# Code example
code_example: {
  label: "Pseudo-code: Correct Pattern"
  shape: rectangle
  style.fill: "#263238"
  code: {
    label: "// Quantized Matrix Multiply Kernel\nvoid qgemm(int8_t* A, int8_t* B, int8_t* C,\n           int M, int N, int K,\n           float scale_a, int zp_a,\n           float scale_b, int zp_b,\n           float scale_c, int zp_c) {\n  for (int m = 0; m < M; m++) {\n    for (int n = 0; n < N; n++) {\n      int32_t accumulator = 0;  // ← INT32!\n      for (int k = 0; k < K; k++) {\n        int32_t a_val = (int32_t)A[m*K + k] - zp_a;\n        int32_t b_val = (int32_t)B[k*N + n] - zp_b;\n        accumulator += a_val * b_val;\n      }\n      // Requantize: scale down to INT8 range\n      float float_result = accumulator * scale_a * scale_b;\n      C[m*N + n] = (int8_t)(float_result / scale_c + zp_c);\n    }\n  }\n}"
    shape: text
    style: {
      font-size: 10
      font-color: "#ECEFF1"
      font: mono
    }
  }
}

# Connections
problem -> solution: "SOLVED BY" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    bold: true
  }
}
byte_viz -> math_box
solution -> insight
comparison -> code_example