direction: right
layout-engine: elk
theme-id: 4
title: {
  label: Weight Distribution Variance Across Channels\nPer-Channel Quantization Justification
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Legend
legend: {
  label: Magnitude Legend
  shape: rectangle
  style.fill: "#f8f9fa"
  low: {
    label: "0.0 - 0.3 (Low)"
    shape: rectangle
    style.fill: "#a8d5ba"
  }
  medium: {
    label: "0.3 - 0.6 (Medium)"
    shape: rectangle
    style.fill: "#ffd93d"
  }
  high: {
    label: "0.6 - 1.0 (High)"
    shape: rectangle
    style.fill: "#ff6b6b"
  }
  critical: {
    label: "≥10x Variance (Critical)"
    shape: rectangle
    style.fill: "#c92a2a"
    style.font-color: white
    style.stroke: "#ff0000"
    style.stroke-width: 3
  }
  low -> medium -> high -> critical
}
# Stats Panel
stats_panel: {
  label: Channel Statistics
  shape: rectangle
  style.fill: "#e9ecef"
  stat1: {
    label: "Channel Range Ratio: 8.47x"
    shape: text
  }
  stat2: {
    label: "Smallest Channel Range: 0.1123"
    shape: text
  }
  stat3: {
    label: "Largest Channel Range: 0.9501"
    shape: text
  }
  stat4: {
    label: "Quantization MSE (Per-Tensor): 0.0847"
    shape: text
    style.bold: true
    style.underline: true
  }
  stat5: {
    label: "Quantization MSE (Per-Channel): 0.0023"
    shape: text
    style.bold: true
    style.font-color: "#2f9e44"
  }
  stat1 -> stat2 -> stat3 -> stat4 -> stat5
}
# Main Heatmap Grid - Output Channels (rows) x Weight Ranges (columns)
heatmap_container: {
  label: Weight Magnitude Heatmap\n(Output Channels 0-15)
  # Row labels
  row_header: {
    label: "Output\nChannel"
    shape: text
    style.bold: true
  }
  # Column headers
  col_0: {label: "Ch 0"; shape: text; style.bold: true}
  col_1: {label: "Ch 1"; shape: text; style.bold: true}
  col_2: {label: "Ch 2"; shape: text; style.bold: true}
  col_3: {label: "Ch 3"; shape: text; style.bold: true}
  col_4: {label: "Ch 4"; shape: text; style.bold: true}
  col_5: {label: "Ch 5"; shape: text; style.bold: true}
  col_6: {label: "Ch 6"; shape: text; style.bold: true}
  col_7: {label: "Ch 7"; shape: text; style.bold: true}
  # Row 0 - Low variance channel
  r0_label: {label: "OC 0"; shape: text; style.bold: true}
  r0_c0: {label: "0.12"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c1: {label: "0.15"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c2: {label: "0.11"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c3: {label: "0.14"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c4: {label: "0.13"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c5: {label: "0.16"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c6: {label: "0.10"; shape: rectangle; style.fill: "#a8d5ba"}
  r0_c7: {label: "0.12"; shape: rectangle; style.fill: "#a8d5ba"}
  # Row 1 - Medium variance
  r1_label: {label: "OC 1"; shape: text; style.bold: true}
  r1_c0: {label: "0.35"; shape: rectangle; style.fill: "#ffd93d"}
  r1_c1: {label: "0.42"; shape: rectangle; style.fill: "#ffd93d"}
  r1_c2: {label: "0.38"; shape: rectangle; style.fill: "#ffd93d"}
  r1_c3: {label: "0.45"; shape: rectangle; style.fill: "#ffd93d"}
  r1_c4: {label: "0.40"; shape: rectangle; style.fill: "#ffd93d"}
  r1_c5: {label: "0.36"; shape: rectangle; style.fill: "#ffd93d"}
