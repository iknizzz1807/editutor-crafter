  r6_c1: {label: "0.11"; shape: rectangle; style.fill: "#a8d5ba"}
  r6_c2: {label: "0.08"; shape: rectangle; style.fill: "#a8d5ba"}
  r6_c3: {label: "0.10"; shape: rectangle; style.fill: "#a8d5ba"}
  r6_c4: {label: "0.12"; shape: rectangle; style.fill: "#a8d5ba"}
  r6_c5: {label: "0.09"; shape: rectangle; style.fill: "#a8d5ba"}
  r6_c6: {label: "0.11"; shape: rectangle; style.fill: "#a8d5ba"}
  r6_c7: {label: "0.10"; shape: rectangle; style.fill: "#a8d5ba"}
  # Row 7 - Medium variance
  r7_label: {label: "OC 7"; shape: text; style.bold: true}
  r7_c0: {label: "0.32"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c1: {label: "0.38"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c2: {label: "0.35"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c3: {label: "0.40"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c4: {label: "0.36"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c5: {label: "0.33"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c6: {label: "0.39"; shape: rectangle; style.fill: "#ffd93d"}
  r7_c7: {label: "0.37"; shape: rectangle; style.fill: "#ffd93d"}
  # Grid connections for visual layout
  col_0 -> col_1 -> col_2 -> col_3 -> col_4 -> col_5 -> col_6 -> col_7
  row_header -> r0_label -> r0_c0 -> r0_c1 -> r0_c2 -> r0_c3 -> r0_c4 -> r0_c5 -> r0_c6 -> r0_c7
  r0_c7 -> r1_label -> r1_c0 -> r1_c1 -> r1_c2 -> r1_c3 -> r1_c4 -> r1_c5 -> r1_c6 -> r1_c7
  r1_c7 -> r2_label -> r2_c0 -> r2_c1 -> r2_c2 -> r2_c3 -> r2_c4 -> r2_c5 -> r2_c6 -> r2_c7
  r2_c7 -> r3_label -> r3_c0 -> r3_c1 -> r3_c2 -> r3_c3 -> r3_c4 -> r3_c5 -> r3_c6 -> r3_c7
  r3_c7 -> r4_label -> r4_c0 -> r4_c1 -> r4_c2 -> r4_c3 -> r4_c4 -> r4_c5 -> r4_c6 -> r4_c7
  r4_c7 -> r5_label -> r5_c0 -> r5_c1 -> r5_c2 -> r5_c3 -> r5_c4 -> r5_c5 -> r5_c6 -> r5_c7
  r5_c7 -> r6_label -> r6_c0 -> r6_c1 -> r6_c2 -> r6_c3 -> r6_c4 -> r6_c5 -> r6_c6 -> r6_c7
  r6_c7 -> r7_label -> r7_c0 -> r7_c1 -> r7_c2 -> r7_c3 -> r7_c4 -> r7_c5 -> r7_c6 -> r7_c7
}
# Quantization Comparison Flow
comparison_flow: {
  label: Quantization Strategy Comparison
  direction: right
  per_tensor: {
    label: Per-Tensor Quantization
    style.fill: "#ffe3e3"
    style.stroke: "#c92a2a"
    scale_single: {
      label: "Single Scale (s)\nfor ALL channels"
      shape: rectangle
    }
    formula_single: {
      label: "s = max(|W|) / 127\n      = 0.95 / 127 = 0.00748"
      shape: text
      style.font-size: 11
    }
    problem: {
      label: "PROBLEM\nSmall weights get\nquantized to ZERO"
      shape: rectangle
      style.fill: "#c92a2a"
      style.font-color: white
      style.bold: true
    }
    mse_tensor: {
      label: "MSE = 0.0847"
      shape: rectangle
      style.fill: "#c92a2a"
      style.font-color: white
      style.bold: true
    }
    scale_single -> formula_single -> problem -> mse_tensor
  }
  per_channel: {
    label: Per-Channel Quantization
    style.fill: "#d3f9d8"
    style.stroke: "#2f9e44"
    scale_multi: {
      label: "Individual Scale (s_i)\nper output channel"
      shape: rectangle
    }
    formula_multi: {
      label: "s_i = max(|W_i|) / 127\ns_0 = 0.16/127 = 0.00126\ns_2 = 0.95/127 = 0.00748"
      shape: text
      style.font-size: 11
    }
    solution: {
      label: "SOLUTION\nAll weights preserved\nwith optimal precision"
      shape: rectangle
      style.fill: "#2f9e44"
      style.font-color: white
      style.bold: true
    }
    mse_channel: {
      label: "MSE = 0.0023\n(37x better)"
      shape: rectangle
      style.fill: "#2f9e44"
      style.font-color: white
      style.bold: true
    }
    scale_multi -> formula_multi -> solution -> mse_channel
  }
  arrow: {
    label: "10x magnitude\ndifference"
    shape: text
    style.bold: true
    style.font-color: "#c92a2a"
  }
  per_tensor -> arrow -> per_channel
}
# Annotation for critical insight
insight: {
  label: Key Insight
  shape: rectangle
  style.fill: "#fff3bf"
  style.stroke: "#fab005"
  style.stroke-width: 2
  text: {
    label: "When output channels have 10x+ magnitude variance,\nper-tensor quantization forces a single scale that:\n• Clips high-magnitude channels (precision loss)\n• Zeros low-magnitude channels (information loss)\n\nPer-channel quantization provides 37x lower MSE\nby adapting scales to each channel's range."
    shape: text
  }
}
# Data flow connections
heatmap_container -> comparison_flow: {
  label: "Reveals variance"
  style.stroke-dash: 3
}
comparison_flow -> insight: {
  label: "Drives strategy"
  style.stroke-dash: 3
}
legend -> heatmap_container: {
  label: "Color mapping"
  style.stroke-dash: 3
  style.opacity: 0.5
}
stats_panel -> heatmap_container: {
  label: "Computed from"
  style.stroke-dash: 3
  style.opacity: 0.5
}