  # Row 2 - High variance (CRITICAL - 10x difference from row 0)
  r2_label: {label: "OC 2"; shape: text; style.bold: true; style.fill: "#ffe3e3"}
  r2_c0: {label: "0.85"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c1: {label: "0.92"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c2: {label: "0.88"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c3: {label: "0.95"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c4: {label: "0.87"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c5: {label: "0.91"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c6: {label: "0.89"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r2_c7: {label: "0.93"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  # Row 3 - Low variance
  r3_label: {label: "OC 3"; shape: text; style.bold: true}
  r3_c0: {label: "0.18"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c1: {label: "0.21"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c2: {label: "0.17"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c3: {label: "0.19"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c4: {label: "0.20"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c5: {label: "0.22"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c6: {label: "0.16"; shape: rectangle; style.fill: "#a8d5ba"}
  r3_c7: {label: "0.18"; shape: rectangle; style.fill: "#a8d5ba"}
  # Row 4 - Medium variance
  r4_label: {label: "OC 4"; shape: text; style.bold: true}
  r4_c0: {label: "0.48"; shape: rectangle; style.fill: "#ffd93d"}
  r4_c1: {label: "0.52"; shape: rectangle; style.fill: "#ffd93d"}
  r4_c2: {label: "0.49"; shape: rectangle; style.fill: "#ffd93d"}
  r4_c3: {label: "0.55"; shape: rectangle; style.fill: "#ff6b6b"}
  r4_c4: {label: "0.51"; shape: rectangle; style.fill: "#ffd93d"}
  r4_c5: {label: "0.47"; shape: rectangle; style.fill: "#ffd93d"}
  r4_c6: {label: "0.53"; shape: rectangle; style.fill: "#ffd93d"}
  r4_c7: {label: "0.50"; shape: rectangle; style.fill: "#ffd93d"}
  # Row 5 - High variance (CRITICAL)
  r5_label: {label: "OC 5"; shape: text; style.bold: true; style.fill: "#ffe3e3"}
  r5_c0: {label: "0.78"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c1: {label: "0.82"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c2: {label: "0.79"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c3: {label: "0.85"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c4: {label: "0.80"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c5: {label: "0.83"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c6: {label: "0.77"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  r5_c7: {label: "0.81"; shape: rectangle; style.fill: "#c92a2a"; style.font-color: white; style.stroke: "#ff0000"; style.stroke-width: 2}
  # Row 6 - Low variance
  r6_label: {label: "OC 6"; shape: text; style.bold: true}
