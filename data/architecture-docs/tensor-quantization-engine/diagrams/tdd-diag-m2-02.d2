vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Memory Layout Comparison
  ## Per-Tensor vs. Per-Channel Quantization Storage
| {
  near: top-center
  shape: text
}

# Left side: Per-Tensor Quantization
per_tensor_group: {
  label: "Per-Tensor Quantization"
  shape: rectangle
  style: {
    stroke: "#6366f1"
    fill: "#fafafa"
    stroke-width: 2
  }

  pt_header: {
    label: "Scale Metadata (8 bytes total)"
    shape: rectangle
    style: {
      fill: "#a855f7"
      font-color: white
      stroke: "#7c3aed"
    }
    width: 400

    pt_scale: {
      label: "scale (FP32)\n4 bytes\nOffset: 0x0000"
      shape: rectangle
      style: {
        fill: "#3b82f6"
        font-color: white
      }
      width: 196
    }
    pt_zp: {
      label: "zero_point (INT32)\n4 bytes\nOffset: 0x0004"
      shape: rectangle
      style: {
        fill: "#3b82f6"
        font-color: white
      }
      width: 196
    }
    pt_scale -> pt_zp: {
      style: {
        stroke-width: 0
      }
    }
  }

  pt_weight: {
    label: "Weight Matrix W[4096, 4096] INT8\n16,777,216 bytes (16 MB)\nOffset: 0x0008 - 0x1000007"
    shape: rectangle
    style: {
      fill: "#3b82f6"
      font-color: white
    }
    width: 400
    height: 200
  }

  pt_header -> pt_weight: {
    style: {
      stroke-width: 0
    }
  }
}

# Right side: Per-Channel Quantization
per_channel_group: {
  label: "Per-Channel Quantization"
  shape: rectangle
  style: {
    stroke: "#6366f1"
    fill: "#fafafa"
    stroke-width: 2
  }

  pc_header: {
    label: "Scale Metadata (32,768 bytes for C_out=4096)"
    shape: rectangle
    style: {
      fill: "#a855f7"
      font-color: white
      stroke: "#7c3aed"
    }
    width: 400

    pc_scales_header: {
      label: "Scales Array (C_out * 4B)"
      shape: rectangle
      style: {
        fill: "#8b5cf6"
        font-color: white
      }
      width: 196

      pc_scale_0: "scale[0]\nFP32\n0x0000" {
        style: {
          fill: "#3b82f6"
          font-color: white
        }
      }
      pc_scale_1: "scale[1]\nFP32\n0x0004" {
        style: {
          fill: "#3b82f6"
          font-color: white
        }
      }
      pc_scale_dots: "..." {
        style: {
          fill: "#64748b"
          font-color: white
        }
      }
      pc_scale_n: "scale[4095]\nFP32\n0x3FFC" {
        style: {
          fill: "#3b82f6"
          font-color: white
        }
      }

      pc_scale_0 -> pc_scale_1 -> pc_scale_dots -> pc_scale_n: {
        style.stroke-width: 0
      }
    }

    pc_zp_header: {
      label: "Zero-Points Array (C_out * 4B)"
      shape: rectangle
      style: {
        fill: "#8b5cf6"
        font-color: white
      }
      width: 196

      pc_zp_0: "zp[0]\nINT32\n0x4000" {
        style: {
          fill: "#3b82f6"
          font-color: white
        }
      }
      pc_zp_1: "zp[1]\nINT32\n0x4004" {
        style: {
          fill: "#3b82f6"
          font-color: white
        }
      }
      pc_zp_dots: "..." {
        style: {
          fill: "#64748b"
          font-color: white
        }
      }
      pc_zp_n: "zp[4095]\nINT32\n0x7FFC" {
        style: {
          fill: "#3b82f6"
          font-color: white
        }
      }

      pc_zp_0 -> pc_zp_1 -> pc_zp_dots -> pc_zp_n: {
        style.stroke-width: 0
      }
    }

    pc_scales_header -> pc_zp_header: {
      style.stroke-width: 0
    }
  }

  pc_weight: {
    label: "Weight Matrix W[4096, 4096] INT8\n16,777,216 bytes (16 MB)\nOffset: 0x8000 - 0x1008000"
    shape: rectangle
    style: {
      fill: "#3b82f6"
      font-color: white
    }
    width: 400
    height: 200
  }

  pc_header -> pc_weight: {
    style.stroke-width: 0
  }
}

# Comparison summary
comparison: {
  label: "Storage Overhead Analysis"
  shape: rectangle
  style: {
    fill: "#f0fdf4"
    stroke: "#22c55e"
    stroke-width: 2
  }
  width: 400

  c_title: "For W[4096, 4096] Weight Matrix" {
    shape: text
    style: {
      font-color: "#1e293b"
      bold: true
    }
  }
  c_per_tensor: "Per-Tensor:\n  • Metadata: 8 bytes\n  • Overhead: 0.000048%" {
    shape: text
    style.font-color: "#1e293b"
  }
  c_per_channel: "Per-Channel:\n  • Metadata: 32,768 bytes (32 KB)\n  • Overhead: 0.195%" {
    shape: text
    style.font-color: "#1e293b"
  }
  c_conclusion: "✓ Per-channel overhead is NEGLIGIBLE\n  (<0.2% of 16 MB weight storage)" {
    shape: text
    style: {
      font-color: "#16a34a"
      bold: true
    }
  }

  c_title -> c_per_tensor -> c_per_channel -> c_conclusion: {
    style.stroke-width: 0
  }
}

# Indicators
indicators: {
  grid-columns: 1
  cache_line: "Cache Line: 64 bytes" {
    style: {
      fill: "#fef3c7"
      stroke: "#f59e0b"
      stroke-dash: 5
    }
  }
  page_boundary: "Page Boundary: 4KB (4096 bytes)" {
    style: {
      fill: "#fce7f3"
      stroke: "#ec4899"
      stroke-dash: 0
      stroke-width: 3
    }
  }
}

# Legend
legend: {
  label: "Memory Map Legend"
  shape: rectangle
  style: {
    fill: "#f8fafc"
    stroke: "#e2e8f0"
  }
  
  l_header: "Header/Metadata" {
    shape: rectangle
    style: {
      fill: "#a855f7"
      font-color: white
    }
  }
  l_data: "Primary Data/Weights" {
    shape: rectangle
    style: {
      fill: "#3b82f6"
      font-color: white
    }
  }
  l_padding: "Continuation/Ellipsis" {
    shape: rectangle
    style: {
      fill: "#64748b"
      font-color: white
    }
  }
  
  l_header -> l_data -> l_padding: {
    style.stroke-width: 0
  }
}

# Logical Connections
per_tensor_group -> per_channel_group: "VS" {
  style: {
    stroke: "#e2e8f0"
    stroke-dash: 3
    font-size: 24
    bold: true
  }
}

per_channel_group -> comparison: "Results" {
  style: {
    stroke: "#22c55e"
    stroke-dash: 2
    animated: true
  }
}

indicators -> per_tensor_group: {
  style.opacity: 0
}

legend -> comparison: {
  style.opacity: 0
}