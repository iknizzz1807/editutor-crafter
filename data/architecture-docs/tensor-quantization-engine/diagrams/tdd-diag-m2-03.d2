vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

# --- Global Style Definitions ---
classes: {
  tensor_container: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: "#F8F9FA"
    }
  }
  mem_header: {
    style: {
      fill: "#673AB7"
      font-color: white
      bold: true
    }
  }
  scale_element: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      font-size: 14
    }
  }
  weight_element: {
    style: {
      fill: "#EEEEEE"
      stroke: "#757575"
      font-size: 12
    }
  }
  quant_element: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      bold: true
      font-color: "#1B5E20"
    }
  }
  logic_op: {
    shape: diamond
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      bold: true
    }
  }
}

# --- Diagram Header ---
title: {
  label: ||md
    # Broadcast Trick for Per-Channel Quantization
    **Engine Component:** `QuantizationEngine::ApplyPerChannelScale`
    **TDD Spec:** Module M2-03 | Hardware Accelerated Tensor Ops
  ||
  near: top-center
}

# --- 1. PHYSICAL MEMORY LAYOUT (1D) ---
mem_layout_1d: {
  "label": "Physical Memory: Input Scales (1D Vector) | Type: FP32 | Size: C_out * 4B"
  class: tensor_container
  
  grid-columns: 4
  grid-gap: 0

  h_off: { label: "Offset"; class: mem_header }
  h_val: { label: "Value"; class: mem_header }
  h_ptr: { label: "Pointer"; class: mem_header }
  h_meta: { label: "Metadata"; class: mem_header }

  o0: { label: "0x00"; style.font: mono }
  v0: { label: "s₀"; class: scale_element }
  p0: { label: "ptr[0]"; style.font-color: orange }
  m0: { label: "Channel 0 Scale (4 Bytes)" }

  o1: { label: "0x04"; style.font: mono }
  v1: { label: "s₁"; class: scale_element }
  p1: { label: "ptr[1]"; style.font-color: orange }
  m1: { label: "Channel 1 Scale (4 Bytes)" }

  o2: { label: "0x08"; style.font: mono }
  v2: { label: "s₂"; class: scale_element }
  p2: { label: "ptr[2]"; style.font-color: orange }
  m2: { label: "Channel 2 Scale (4 Bytes)" }

  dots: { label: "..."; grid-colspan: 4; style.stroke-dash: 2 }
}

# --- 2. TRANSFORMATION BLOCK ---
reshape_op: {
  label: "view(C_out, 1)"
  shape: rectangle
  style: {
    stroke: "#1976D2"
    stroke-width: 2
    stroke-dash: 5
    fill: "#E3F2FD"
    border-radius: 10
  }
  tooltip: "Logical reshape to allow row-wise broadcasting across weight matrix"
}

# --- 3. LOGICAL BROADCAST VIEW (COLUMN VECTOR) ---
scales_2d: {
  label: "Broadcast View [C_out, 1]"
  class: tensor_container
  grid-columns: 1
  grid-gap: 2
  
  r0: { label: "s₀"; class: scale_element; width: 60 }
  r1: { label: "s₁"; class: scale_element; width: 60 }
  r2: { label: "s₂"; class: scale_element; width: 60 }
  r_dots: { label: "⋮"; style.stroke-width: 0; style.fill: transparent }
  rn: { label: "sₙ"; class: scale_element; width: 60 }
}

# --- 4. WEIGHT MATRIX (W) ---
weight_matrix: {
  label: "Input Weights (W) [C_out, C_in]"
  class: tensor_container
  grid-columns: 5
  
  # Row 0
  w00: { label: "w₀₀"; class: weight_element }
  w01: { label: "w₀₁"; class: weight_element }
  w02: { label: "w₀₂"; class: weight_element }
  w0_d: { label: "⋯"; style.stroke-width: 0 }
  w0m: { label: "w₀ₘ"; class: weight_element }
  
  # Row 1
  w10: { label: "w₁₀"; class: weight_element }
  w11: { label: "w₁₁"; class: weight_element }
  w12: { label: "w₁₂"; class: weight_element }
  w1_d: { label: "⋯"; style.stroke-width: 0 }
  w1m: { label: "w₁ₘ"; class: weight_element }
  
  # Divider
  dots_row: { label: "⋮"; grid-colspan: 5; style.stroke-width: 0 }

  # Row N
  wn0: { label: "wₙ₀"; class: weight_element }
  wn1: { label: "wₙ₁"; class: weight_element }
  wn2: { label: "wₙ₂"; class: weight_element }
  wn_d: { label: "⋯"; style.stroke-width: 0 }
  wnm: { label: "wₙₘ"; class: weight_element }
}

# --- 5. BROADCAST ENGINE ---
div_op: {
  label: "W / s_bc"
  class: logic_op
  tooltip: "W[i, j] / s[i]"
}

# --- 6. INTERMEDIATE STATE ---
intermediate_matrix: {
  label: "FP32 Scaled Values"
  class: tensor_container
  grid-columns: 2
  
  i00: { label: "w₀₀/s₀"; style.fill: "#FFF3E0" }
  i01: { label: "w₀₁/s₀"; style.fill: "#FFF3E0" }
  i10: { label: "w₁₀/s₁"; style.fill: "#FFF3E0" }
  i11: { label: "w₁₁/s₁"; style.fill: "#FFF3E0" }
}

round_cast: {
  label: "round() & cast<int8>"
  class: logic_op
}

# --- 7. FINAL OUTPUT ---
output_tensor: {
  label: "Quantized Tensor (Q) INT8 [C_out, C_in]"
  class: tensor_container
  grid-columns: 4
  
  q00: { label: "q₀₀"; class: quant_element }
  q01: { label: "q₀₁"; class: quant_element }
  q0_d: { label: "⋯"; style.stroke-width: 0 }
  q0m: { label: "q₀ₘ"; class: quant_element }

  q10: { label: "q₁₀"; class: quant_element }
  q11: { label: "q₁₁"; class: quant_element }
  q1_d: { label: "⋯"; style.stroke-width: 0 }
  q1m: { label: "q₁ₘ"; class: quant_element }
  
  q_dots: { label: "⋮"; grid-colspan: 4; style.stroke-width: 0 }
}

# --- CONNECTIONS ---

mem_layout_1d -> reshape_op: "Load Pointer" {
  style: {
    stroke: orange
    stroke-width: 2
  }
}

reshape_op -> scales_2d: "Set [C, 1] View"

scales_2d -> div_op: "Broadcast Divisor" {
  source-arrowhead: triangle
}

weight_matrix -> div_op: "Dividend Buffer"

div_op -> intermediate_matrix

intermediate_matrix -> round_cast

round_cast -> output_tensor: "SIMD Store" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    animated: true
  }
}

# --- FOOTER & EXPLANATION ---
explanation_footer: {
  near: bottom-center
  grid-columns: 2
  grid-gap: 20
  
  logic_text: {
    label: |md
      ### Logic: Per-Channel Scaling
      Per-channel quantization requires applying a unique scale factor $s_i$ to every row $i$ of the weight matrix.
      
      **The Trick:** 
      By reshaping the 1D scales vector to $(C_{out}, 1)$, we allow the hardware matrix engine to 
      "broadcast" the single value $s_i$ across all $C_{in}$ columns of row $i$ in a single SIMD cycle.
    |
    shape: rectangle
    style: {
      fill: "#FFFDE7"
      stroke: "#FBC02D"
      border-radius: 8
    }
  }
  
  math_block: {
    label: |md
      ### Quantization Formula
      $$Q_{i,j} = \text{clamp}\left(\left\lfloor \frac{W_{i,j}}{s_i} + 0.5 \right\rfloor, -128, 127\right)$$
      Where:
      - $W$: FP32 Input Weight
      - $s_i$: FP32 Scale for channel $i$
      - $Q$: INT8 Output Weight
    |
    shape: rectangle
    style: {
      fill: "#E1F5FE"
      stroke: "#0288D1"
      border-radius: 8
    }
  }
}