layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

direction: right

# ─────────────────────────────────────────────────────────────────────────────
# TITLE & SUBTITLE
# ─────────────────────────────────────────────────────────────────────────────
title: "Channel Dimension Convention" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: {
  near: top-center
  shape: text
  style: {
    font-size: 14
    italic: true
  }
  label: "Per-channel quantization uses dim=0 (output channel dimension) for all layer types"
}

# ─────────────────────────────────────────────────────────────────────────────
# CONTAINER: Key Principle Box
# ─────────────────────────────────────────────────────────────────────────────
key_principle: {
  label: "CORE PRINCIPLE"
  shape: rectangle
  style.fill: "#1a1a2e"
  style.stroke: "#00d4ff"
  style.stroke-width: 3
  style.font-color: "#ffffff"
  
  principle_text: {
    shape: text
    label: "channel_dim = 0 (always the OUTPUT dimension)"
    style.font-size: 18
    style.bold: true
    style.font-color: "#00ff88"
  }
  reason: {
    shape: text
    label: "Each output channel produces one element of the output → quantized independently"
    style.font-size: 12
    style.font-color: "#aaaaaa"
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# LINEAR LAYER SECTION
# ─────────────────────────────────────────────────────────────────────────────
linear_section: {
  label: "LINEAR LAYER"
  shape: rectangle
  style.fill: "#0d1117"
  style.stroke: "#58a6ff"
  style.stroke-width: 2
  
  header: {
    shape: text
    label: "nn.Linear(in_features, out_features)"
    style.font-size: 16
    style.bold: true
    style.font-color: "#58a6ff"
  }

  weight_shape: {
    label: "Weight Tensor Shape"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    shape_visual: {
      label: "[out_features, in_features]"
      shape: text
      style.font-size: 20
      style.bold: true
      style.font-color: "#ffffff"
    }
  }

  dim_indices: {
    label: "Dimension Indices"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    dim0: "dim=0 → out_features (OUTPUT CHANNELS)" {
      style.font-color: "#00ff88"
      style.bold: true
    }
    dim1: "dim=1 → in_features" {
      style.font-color: "#8b949e"
    }
  }

  matrix_viz: {
    label: "Visual: Weight Matrix"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    
    matrix_container: {
      shape: rectangle
      style.fill: "#0d1117"
      style.stroke: "#00ff88"
      style.stroke-dash: 4
      
      row_label: "Row i = weights for output channel i" {
        shape: text
        style.font-color: "#00ff88"
        style.italic: true
      }
      
      col_header: "← in_features (dim=1) →" {
        shape: text
        style.font-color: "#8b949e"
        style.font-size: 10
      }

      rows: {
        grid-rows: 4
        grid-columns: 5
        grid-gap: 10
        style.stroke-width: 0
        
        "ch 0"; "w00"; "w01"; "..."; "w0n"
        "ch 1"; "w10"; "w11"; "..."; "w1n"
        "... "; " ..."; "  ..."; "   ..."; "    ..."
        "ch C"; "wC0"; "wC1"; "... "; "wCn"
      }

      row_dim_label: "↑\nout_features\n(dim=0)" {
        shape: text
        style.font-color: "#00ff88"
        style.font-size: 10
      }
    }
  }

  scale_broadcast: {
    label: "Per-Channel Scale Shape"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#f0883e"
    scale_shape: {
      shape: text
      label: "scale.shape = [out_features, 1]"
      style.font-color: "#f0883e"
      style.bold: true
    }
    broadcast_note: {
      shape: text
      label: "Broadcasts across in_features (dim=1)"
      style.font-color: "#8b949e"
      style.italic: true
    }
  }

  example: {
    label: "Example: Linear(512, 1024)"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    ex_weight: "weight.shape = [1024, 512]" {
      shape: text
      style.font-color: "#ffffff"
    }
    ex_scale: "scale.shape = [1024, 1] (one scale per output neuron)" {
      shape: text
      style.font-color: "#f0883e"
    }
    ex_chan: "1024 output channels → 1024 quantization parameters" {
      shape: text
      style.font-color: "#00ff88"
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# CONV2D LAYER SECTION
# ─────────────────────────────────────────────────────────────────────────────
conv_section: {
  label: "CONV2D LAYER"
  shape: rectangle
  style.fill: "#0d1117"
  style.stroke: "#a371f7"
  style.stroke-width: 2
  
  header: {
    shape: text
    label: "nn.Conv2d(in_channels, out_channels, kernel_size)"
    style.font-size: 16
    style.bold: true
    style.font-color: "#a371f7"
  }

  weight_shape: {
    label: "Weight Tensor Shape"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    shape_visual: {
      label: "[out_channels, in_channels, H, W]"
      shape: text
      style.font-size: 20
      style.bold: true
      style.font-color: "#ffffff"
    }
  }

  dim_indices: {
    label: "Dimension Indices"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    dim0: "dim=0 → out_channels (OUTPUT CHANNELS)" {
      style.font-color: "#00ff88"
      style.bold: true
    }
    dim1: "dim=1 → in_channels" {
      style.font-color: "#8b949e"
    }
    dim2: "dim=2 → kernel height (H)" {
      style.font-color: "#8b949e"
    }
    dim3: "dim=3 → kernel width (W)" {
      style.font-color: "#8b949e"
    }
  }

  tensor_viz: {
    label: "Visual: 4D Weight Tensor"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    
    tensor_container: {
      shape: rectangle
      style.fill: "#0d1117"
      style.stroke: "#00ff88"
      style.stroke-dash: 4
      slice_label: "Slice [i, :, :, :] = kernel for output channel i" {
        shape: text
        style.font-color: "#00ff88"
        style.italic: true
      }
      
      slices: {
        slice0: "out_ch 0\n[in_ch, H, W]" {
          shape: rectangle
          style.fill: "#238636"
          style.stroke: "#2ea043"
        }
        slice1: "out_ch 1\n[in_ch, H, W]" {
          shape: rectangle
          style.fill: "#238636"
          style.stroke: "#2ea043"
        }
        ellipsis: "..." {
          shape: text
          style.font-color: "#8b949e"
        }
        sliceC: "out_ch C\n[in_ch, H, W]" {
          shape: rectangle
          style.fill: "#238636"
          style.stroke: "#2ea043"
        }
        slice0 -> slice1 -> ellipsis -> sliceC
      }
      
      dim0_arrow: "↑ dim=0 (out_channels) ↑" {
        shape: text
        style.font-color: "#00ff88"
        style.bold: true
      }
    }
  }

  scale_broadcast: {
    label: "Per-Channel Scale Shape"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#f0883e"
    scale_shape: {
      shape: text
      label: "scale.shape = [out_channels, 1, 1, 1]"
      style.font-color: "#f0883e"
      style.bold: true
    }
    broadcast_note: {
      shape: text
      label: "Broadcasts across in_channels, H, W (dims 1, 2, 3)"
      style.font-color: "#8b949e"
      style.italic: true
    }
  }

  example: {
    label: "Example: Conv2d(64, 128, kernel_size=3)"
    shape: rectangle
    style.fill: "#161b22"
    style.stroke: "#30363d"
    ex_weight: "weight.shape = [128, 64, 3, 3]" {
      shape: text
      style.font-color: "#ffffff"
    }
    ex_scale: "scale.shape = [128, 1, 1, 1] (one scale per output filter)" {
      shape: text
      style.font-color: "#f0883e"
    }
    ex_chan: "128 output channels → 128 quantization parameters" {
      shape: text
      style.font-color: "#00ff88"
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# UNIFIED BROADCAST SHAPE SUMMARY
# ─────────────────────────────────────────────────────────────────────────────
broadcast_table: {
  label: "Scale Broadcast Shape Summary"
  shape: rectangle
  style.fill: "#0d1117"
  style.stroke: "#00d4ff"
  style.stroke-width: 2
  
  content: |||md
    | Layer Type | Weight Shape | Scale Shape | Broadcast Dimensions |
    | :--- | :--- | :--- | :--- |
    | **Linear** | `[C_out, C_in]` | `[C_out, 1]` | `dim=1` |
    | **Conv2d** | `[C_out, C_in, H, W]` | `[C_out, 1, 1, 1]` | `dims 1, 2, 3` |
  |||

  note: {
    shape: text
    label: "Note: C_out = number of output channels (always at dim=0)"
    style.font-color: "#8b949e"
    style.italic: true
  }
}

# ─────────────────────────────────────────────────────────────────────────────
# IMPLEMENTATION CODE SNIPPET
# ─────────────────────────────────────────────────────────────────────────────
code_snippet: {
  label: "Implementation Reference"
  shape: rectangle
  style.fill: "#0d1117"
  style.stroke: "#30363d"
  
  code: |||python
    # Channel dimension is ALWAYS 0 for per-channel quantization
    CHANNEL_DIM = 0

    def get_per_channel_scale_shape(weight_shape):
        # weight_shape[0] = number of output channels
        scale_shape = [1] * len(weight_shape)
        scale_shape[CHANNEL_DIM] = weight_shape[CHANNEL_DIM]
        return scale_shape

    # Results:
    # Linear: weight [1024, 512]      -> scale [1024, 1]
    # Conv2d: weight [128, 64, 3, 3] -> scale [128, 1, 1, 1]
  |||
  code.style.font-size: 14
}

# ─────────────────────────────────────────────────────────────────────────────
# CONNECTIONS / LAYOUT
# ─────────────────────────────────────────────────────────────────────────────
key_principle -> linear_section: {
  style.stroke: "#00d4ff"
  style.stroke-dash: 3
}
key_principle -> conv_section: {
  style.stroke: "#00d4ff"
  style.stroke-dash: 3
}
linear_section -> broadcast_table: {
  style.stroke: "#58a6ff"
  style.stroke-dash: 2
}
conv_section -> broadcast_table: {
  style.stroke: "#a371f7"
  style.stroke-dash: 2
}
broadcast_table -> code_snippet: {
  style.stroke: "#30363d"
}