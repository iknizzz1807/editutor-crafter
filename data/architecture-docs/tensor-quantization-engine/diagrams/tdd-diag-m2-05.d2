direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# CLASSES FOR CONSISTENCY
classes: {
  per_tensor_bar: {
    shape: rectangle
    width: 40
    style: {
      fill: "#4A90D9"
      stroke: "#2E5A8A"
      stroke-width: 2
      shadow: true
    }
    label.near: outside-top-center
    style.font-size: 10
  }
  per_channel_bar: {
    shape: rectangle
    width: 40
    style: {
      fill: "#D94A4A"
      stroke: "#8A2E2E"
      stroke-width: 2
      shadow: true
    }
    label.near: outside-top-center
    style.font-size: 10
  }
  category_container: {
    style: {
      stroke: "#CCCCCC"
      stroke-dash: 2
      border-radius: 10
      fill: "#F9F9F9"
    }
  }
}

# TITLE & METADATA
title: "MSE Comparison by Layer Type" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
    font-color: "#222222"
  }
}

subtitle: "Per-Tensor vs Per-Channel Quantization Quality Analysis" {
  near: top-center
  shape: text
  style: {
    font-size: 16
    italic: true
    font-color: "#666666"
  }
}

# LEGEND (Root Level)
legend: {
  shape: rectangle
  near: bottom-right
  style: {
    stroke-dash: 4
    fill: "#FFFFFF"
    stroke: "#999999"
  }
  per_tensor: "■ Per-Tensor (PT)" {
    style: {
      font-color: "#4A90D9"
      bold: true
    }
  }
  per_channel: "■ Per-Channel (PC)" {
    style: {
      font-color: "#D94A4A"
      bold: true
    }
  }
  improvement: "↓ 30-50% MSE Reduction" {
    style: {
      font-color: "#4A9D4A"
      italic: true
    }
  }
}

# Y-AXIS SCALE
metrics: {
  shape: rectangle
  style.stroke-width: 0
  style.fill: transparent
  
  y_axis: "MSE Value" {
    shape: text
    style: {
      font-size: 12
      bold: true
    }
  }

  y_scale: "0.03 ┐\n0.02 ┼\n0.01 ┼\n0.00 ┴" {
    shape: text
    style: {
      font-size: 11
      font: mono
    }
  }
}

# LAYER TYPE CATEGORIES
linear_layers: {
  class: category_container
  label: "Linear Layers"
  
  linear_small: {
    label: "Small\n(128x64)"
    pt_small: "0.0124" {
      class: per_tensor_bar
      height: 120
    }
    pc_small: "0.0078" {
      class: per_channel_bar
      height: 72
    }
  }
  
  linear_medium: {
    label: "Medium\n(512x256)"
    pt_med: "0.0187" {
      class: per_tensor_bar
      height: 160
    }
    pc_med: "0.0102" {
      class: per_channel_bar
      height: 96
    }
  }
  
  linear_large: {
    label: "Large\n(2048x1024)"
    pt_large: "0.0243" {
      class: per_tensor_bar
      height: 200
    }
    pc_large: "0.0134" {
      class: per_channel_bar
      height: 110
    }
  }
}

conv_layers: {
  class: category_container
  label: "Conv2d Layers"
  
  conv_3x3: {
    label: "3x3 Kernel\n(64ch)"
    pt_3x3: "0.0156" {
      class: per_tensor_bar
      height: 140
    }
    pc_3x3: "0.0089" {
      class: per_channel_bar
      height: 70
    }
  }
  
  conv_5x5: {
    label: "5x5 Kernel\n(128ch)"
    pt_5x5: "0.0212" {
      class: per_tensor_bar
      height: 180
    }
    pc_5x5: "0.0106" {
      class: per_channel_bar
      height: 90
    }
  }
  
  conv_depth: {
    label: "Depthwise\n(256ch)"
    pt_dw: "0.0298" {
      class: per_tensor_bar
      height: 220
    }
    pc_dw: "0.0119" {
      class: per_channel_bar
      height: 88
    }
  }
}

# SUMMARY ANALYSIS
improvement_summary: {
  label: |md
    ### Per-Channel Improvement Summary
    ---
    - **Linear Layers**: 35-45% MSE reduction
    - **Conv2d 3x3**: 43% MSE reduction
    - **Conv2d 5x5**: 50% MSE reduction
    - **Depthwise**: 60% MSE reduction (**Maximum Benefit**)
    ---
    *Heterogeneous weights benefit significantly more from per-channel granularity.*
  |
  shape: rectangle
  style: {
    fill: "#E8F5E8"
    stroke: "#4A9D4A"
    stroke-width: 2
    border-radius: 8
  }
}

# FLOW CONNECTIONS
metrics -> linear_layers: "Baseline"
linear_layers -> conv_layers: "Increased Complexity" {
  style: {
    stroke-dash: 3
    animated: true
  }
}

conv_layers -> improvement_summary: "Quantization Stats" {
  style: {
    stroke-dash: 3
  }
}

# Layout Constraints
linear_layers.linear_small -> linear_layers.linear_medium -> linear_layers.linear_large
conv_layers.conv_3x3 -> conv_layers.conv_5x5 -> conv_layers.conv_depth