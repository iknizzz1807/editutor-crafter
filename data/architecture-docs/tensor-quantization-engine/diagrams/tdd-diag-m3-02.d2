vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |md
  # Min/Max vs Percentile Calibration on Outlier Distribution
  *Calibration Analysis for 8-bit Integer Quantization (INT8)*
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# 1. HEAVY-TAILED DISTRIBUTION VISUALIZATION
# Represents a typical activation tensor from a LLM or Transformer layer
distribution_group: {
  label: "Heavy-Tailed Activation Distribution"
  style.fill: "#F5F5F5"
  
  main_mass: {
    label: ""
    shape: rectangle
    width: 200
    height: 80
    style.fill: "#E8F5E9"
    style.stroke-dash: 2
  }
  
  typical_region: {
    label: "Typical Values\n(99.9% of data)"
    shape: rectangle
    width: 180
    height: 60
    style: {
      fill: "#81C784"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  
  outlier_spike: {
    label: "Outliers\n(0.1%)"
    shape: rectangle
    width: 40
    height: 100
    style: {
      fill: "#FF5722"
      stroke: "#BF360C"
      stroke-width: 2
    }
  }
  
  typical_region -> outlier_spike: {
    label: "10x-1000x\nlarger"
    style: {
      stroke-dash: 3
      stroke: "#D84315"
      font-size: 10
    }
  }
}

# 2. MIN/MAX CALIBRATION PANEL
# Demonstrates "Range Inflation" error
minmax_group: {
  label: "Min/Max Calibration (Naive)"
  style.fill: "#FFF0F0"
  
  full_range: {
    label: "Full Range (min→max)"
    shape: rectangle
    width: 300
    height: 30
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 3
    }
  }
  
  precision_zone_minmax: {
    label: "Usable Precision\n(spread thin)"
    shape: rectangle
    width: 180
    height: 20
    style: {
      fill: "#EF9A9A"
      stroke: "#B71C1C"
    }
  }
  
  wasted_quant: {
    label: "Wasted\nQuantization\nBins"
    shape: rectangle
    width: 100
    height: 30
    style.fill: "#FFEBEE"
  }
  
  scale_metric: {
    label: "Scale = (max - min) / 255\n= inflated by outliers"
    shape: text
    style: {
      font-color: "#C62828"
      bold: true
      font-size: 11
    }
  }
  
  mse_metric: {
    label: "MSE: ↑4324x\n(single outlier)"
    shape: text
    style: {
      font-color: "#B71C1C"
      bold: true
      font-size: 11
    }
  }
  
  full_range -> wasted_quant
  precision_zone_minmax -> scale_metric
  scale_metric -> mse_metric
}

# 3. PERCENTILE CALIBRATION PANEL
# Demonstrates "Clipping" strategy to maintain resolution
percentile_group: {
  label: "Percentile Calibration (99.9%)"
  style.fill: "#F0FFF0"
  
  clipped_range: {
    label: "Clipped Range (p0.05→p99.95)"
    shape: rectangle
    width: 200
    height: 30
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 3
    }
  }
  
  precision_zone_pct: {
    label: "Dense Precision\n(concentrated)"
    shape: rectangle
    width: 180
    height: 25
    style: {
      fill: "#66BB6A"
      stroke: "#1B5E20"
    }
  }
  
  clipped_outliers: {
    label: "Clipped\nOutliers"
    shape: rectangle
    width: 40
    height: 30
    style: {
      fill: "#FFCC80"
      stroke: "#E65100"
      stroke-dash: 4
    }
  }
  
  pct_scale_metric: {
    label: "Scale = (p99.95 - p0.05) / 255\n= optimized for 99.9% of data"
    shape: text
    style: {
      font-color: "#2E7D32"
      bold: true
      font-size: 11
    }
  }
  
  pct_mse_metric: {
    label: "MSE: Minimal\n(0.1% clipped)"
    shape: text
    style: {
      font-color: "#1B5E20"
      bold: true
      font-size: 11
    }
  }
  
  clipped_range -> clipped_outliers: "clips"
  precision_zone_pct -> pct_scale_metric
  pct_scale_metric -> pct_mse_metric
}

# 4. COMPARISON OVERLAY
# Visualizes the overlap and efficiency gap
comparison_group: {
  label: "Scale Comparison Overlay"
  style.fill: "#F9F9F9"
  
  hist_bar: {
    label: "Distribution Baseline"
    shape: rectangle
    width: 400
    height: 8
    style.fill: "#E0E0E0"
  }
  
  minmax_indicator: {
    label: "Min/Max Range"
    shape: rectangle
    width: 400
    height: 12
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 2
      opacity: 0.7
    }
  }
  
  pct_indicator: {
    label: "Percentile Range"
    shape: rectangle
    width: 280
    height: 12
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      opacity: 0.7
    }
  }
  
  inflation_note: {
    label: "30% scale inflation\nfrom 0.1% outliers"
    shape: text
    style: {
      font-color: "#C62828"
      italic: true
      font-size: 11
    }
  }
  
  hist_bar -> minmax_indicator: {
    style.stroke: "transparent"
  }
  minmax_indicator -> pct_indicator: {
    label: "outliers\nexcluded"
    style: {
      stroke: "#2E7D32"
      stroke-dash: 3
    }
  }
  pct_indicator -> inflation_note
}

# 5. DATA FLOW CONNECTIONS
distribution_group -> minmax_group: {
  label: "captures all\nincluding outliers"
  style: {
    stroke: "#C62828"
    stroke-width: 2
  }
}
distribution_group -> percentile_group: {
  label: "clips to\n99.9% range"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
minmax_group -> comparison_group: {
  label: "inflated scale"
  style: {
    stroke: "#EF9A9A"
    stroke-width: 2
    stroke-dash: 5
  }
}
percentile_group -> comparison_group: {
  label: "optimal scale"
  style: {
    stroke: "#81C784"
    stroke-width: 2
  }
}

# 6. KEY INSIGHT BOX
insight_box: {
  label: "KEY ARCHITECTURAL INSIGHT"
  shape: rectangle
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
    shadow: true
  }
  
  insight_content: {
    label: "Outlier Ratio (max/p99) > 10× indicates\npercentile calibration will significantly\nreduce quantization error"
    shape: text
    style: {
      font-size: 14
      bold: true
    }
  }
  
  formula: {
    label: "q = round(r / scale + zero_point)\nscale↓ → precision↑ for typical values"
    shape: text
    style: {
      font: mono
      font-size: 12
    }
  }
  insight_content -> formula
}

comparison_group -> insight_box: {
  label: "sensitivity\npredictor"
  style: {
    stroke: "#FF8F00"
    stroke-dash: 4
  }
}

# 7. QUANTIZATION LEVELS VISUALIZATION
# Direct visualization of bit-width utilization
quant_levels: {
  label: "Quantization Level Distribution"
  style.fill: "#FAFAFA"
  
  mm_levels: {
    label: "Min/Max: ████████░░░░░░░░░░░░ (levels spread thin)"
    shape: text
    style: {
      font: mono
      font-color: "#C62828"
      font-size: 12
    }
  }
  
  pct_levels: {
    label: "Pct 99.9: ████████████████████ (levels concentrated)"
    shape: text
    style: {
      font: mono
      font-color: "#2E7D32"
      font-size: 12
    }
  }
  
  mm_levels -> pct_levels: {
    label: "same 256 levels\nbetter utilization"
    style: {
      stroke: "#757575"
      stroke-dash: 3
    }
  }
}

comparison_group -> quant_levels