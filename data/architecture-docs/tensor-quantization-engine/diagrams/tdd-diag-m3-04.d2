    stroke-width: 3
  }
}
curve_99_9.point_99_9_mid3 -> curve_99_9.point_99_9_right: {
  style: {
    stroke: "#10B981"
    stroke-width: 3
  }
}
curve_99_9.point_99_9_right -> curve_99_9.point_99_9_farend: {
  style: {
    stroke: "#10B981"
    stroke-width: 3
  }
}
# ===========================================
# CURVE 3: 99% Percentile (Orange)
# Covers 99% of values, clips 1%
# ===========================================
curve_99: {
  label: ""
  shape: rectangle
  style: {
    fill: transparent
    stroke: "#F59E0B"
    stroke-width: 3
  }
  # Point at 0.01% clip - HIGH MSE (very inflated scale)
  point_99_left: {
    label: ""
    shape: circle
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
    }
    pos: {
      x: 100
      y: 450
    }
  }
  # Point at 0.1% clip - still descending
  point_99_mid1: {
    label: ""
    shape: circle
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
    }
    pos: {
      x: 175
      y: 350
    }
  }
  # Point at 0.5% clip - near optimal for this curve
  point_99_mid2: {
    label: ""
    shape: circle
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
    }
    pos: {
      x: 250
      y: 280
    }
  }
  # Point at 1% clip - local minimum but higher than 99.9%
  point_99_optimal: {
    label: ""
    shape: circle
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
    }
    pos: {
      x: 400
      y: 200
    }
  }
  # Point at 2% clip
  point_99_right: {
    label: ""
    shape: circle
