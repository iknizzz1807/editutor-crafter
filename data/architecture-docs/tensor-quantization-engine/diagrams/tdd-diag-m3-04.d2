direction: right
layout-engine: elk
theme-id: 4
title: {
  label: "Percentile Calibration Tradeoff Curve\nMSE vs Clip Percentage for Quantization Scale Selection"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Main graph container representing the plot
plot_area: {
  label: ""
  shape: rectangle
  style: {
    fill: "#FAFBFC"
    stroke: "#1B1F23"
    stroke-width: 2
  }
  # Y-Axis (MSE)
  y_axis: {
    label: "MSE (Mean Squared Error)"
    shape: rectangle
    style: {
      stroke: "#586069"
      stroke-dash: 3
      fill: transparent
    }
    pos: {
      x: 0
      y: 0
    }
  }
  y_axis_label_low: {
    label: "0.001"
    shape: text
    pos: {
      x: -20
      y: 0
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  y_axis_label_mid: {
    label: "0.005"
    shape: text
    pos: {
      x: -20
      y: 150
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  y_axis_label_high: {
    label: "0.010"
    shape: text
    pos: {
      x: -20
      y: 300
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  y_axis_label_peak: {
    label: "0.020"
    shape: text
    pos: {
      x: -20
      y: 450
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  # X-Axis (Clip Percentage)
  x_axis: {
    label: "Clip Percentage (% of values clipped as outliers)"
    shape: rectangle
    style: {
      stroke: "#586069"
      stroke-dash: 3
      fill: transparent
    }
    pos: {
      x: 0
      y: 500
    }
  }
  x_axis_label_0: {
    label: "0%"
    shape: text
    pos: {
      x: 0
      y: 520
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  x_axis_label_01: {
    label: "0.01%"
    shape: text
    pos: {
      x: 100
      y: 520
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  x_axis_label_02: {
    label: "0.1%"
    shape: text
    pos: {
      x: 250
      y: 520
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  x_axis_label_1: {
    label: "1%"
    shape: text
    pos: {
      x: 400
      y: 520
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  x_axis_label_5: {
    label: "5%"
    shape: text
    pos: {
      x: 600
      y: 520
    }
    style: {
      font-size: 10
      font-color: "#586069"
    }
  }
  # Grid lines
  grid_line_1: {
    label: ""
    shape: rectangle
    style: {
      stroke: "#E1E4E8"
      stroke-dash: 2
      fill: transparent
    }
    pos: {
      x: 0
      y: 100
    }
  }
  grid_line_2: {
    label: ""
    shape: rectangle
    style: {
      stroke: "#E1E4E8"
      stroke-dash: 2
      fill: transparent
    }
    pos: {
      x: 0
      y: 200
    }
  }
  grid_line_3: {
    label: ""
    shape: rectangle
    style: {
      stroke: "#E1E4E8"
      stroke-dash: 2
      fill: transparent
    }
    pos: {
      x: 0
      y: 300
    }
  }
  grid_line_4: {
    label: ""
    shape: rectangle
    style: {
      stroke: "#E1E4E8"
      stroke-dash: 2
      fill: transparent
    }
    pos: {
      x: 0
      y: 400
    }
  }
}
# ===========================================
# CURVE 1: 99.99% Percentile (Purple)
# Covers 99.99% of values, clips 0.01%
# ===========================================
