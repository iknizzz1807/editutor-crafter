  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
  }
}
curve_99_99.point_99_99_mid1 -> curve_99_99.point_99_99_mid2: {
  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
  }
}
curve_99_99.point_99_99_mid2 -> curve_99_99.point_99_99_mid3: {
  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
  }
}
curve_99_99.point_99_99_mid3 -> curve_99_99.point_99_99_right: {
  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
  }
}
curve_99_99.point_99_99_right -> curve_99_99.point_99_99_farend: {
  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
  }
}
# ===========================================
# CURVE 2: 99.9% Percentile (Green) - OPTIMAL
# Covers 99.9% of values, clips 0.1%
# Sweet spot: lowest MSE while clipping only 0.1%
# ===========================================
curve_99_9: {
  label: ""
  shape: rectangle
  style: {
    fill: transparent
    stroke: "#10B981"
    stroke-width: 3
  }
  # Point at 0.01% clip - HIGH MSE (outliers inflate scale)
  point_99_9_left: {
    label: ""
    shape: circle
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
    }
    pos: {
      x: 100
      y: 380
    }
  }
  # Point at 0.05% clip - descending
  point_99_9_mid1: {
    label: ""
    shape: circle
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
    }
    pos: {
      x: 175
      y: 280
    }
  }
  # OPTIMAL POINT at 0.1% clip - LOWEST MSE
  point_99_9_optimal: {
    label: ""
    shape: diamond
    style: {
      fill: "#10B981"
      stroke: "#047857"
      stroke-width: 3
      shadow: true
    }
    pos: {
      x: 250
      y: 120
    }
  }
  # Point at 0.5% clip - rising again
  point_99_9_mid3: {
    label: ""
    shape: circle
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
    }
    pos: {
      x: 350
      y: 200
    }
  }
  # Point at 1% clip - higher (too much clipping)
  point_99_9_right: {
    label: ""
    shape: circle
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
    }
    pos: {
      x: 400
      y: 280
    }
  }
  point_99_9_farend: {
    label: ""
    shape: circle
    style: {
      fill: "#10B981"
      stroke: "#059669"
      stroke-width: 2
    }
    pos: {
      x: 550
      y: 380
    }
  }
}
# 99.9% curve connections
curve_99_9.point_99_9_left -> curve_99_9.point_99_9_mid1: {
  style: {
    stroke: "#10B981"
    stroke-width: 3
  }
}
curve_99_9.point_99_9_mid1 -> curve_99_9.point_99_9_optimal: {
  style: {
    stroke: "#10B981"
    stroke-width: 3
  }
}
curve_99_9.point_99_9_optimal -> curve_99_9.point_99_9_mid3: {
  style: {
