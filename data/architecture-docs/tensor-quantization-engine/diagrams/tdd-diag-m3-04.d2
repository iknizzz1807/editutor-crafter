}
# ===========================================
# ANNOTATIONS AND CALLOUTS
# ===========================================
annotation_outlier_inflation: {
  label: "|'md\n  **Left Side: Outlier Inflation Zone**\n\n  - 100th percentile (min/max) doubles MSE\n  - Outliers inflate scale factor\n  - Large quantization steps for most values\n  '|"
  shape: text
  style: {
    font-size: 11
    font-color: "#DC2626"
    bold: false
  }
}
annotation_optimal: {
  label: "|'md\n  **★ Optimal Point**\n\n  **99.9% Percentile**\n  - Lowest MSE achieved\n  - Only 0.1% of values clipped\n  - Best balance between coverage and precision\n  '|"
  shape: text
  style: {
    font-size: 11
    font-color: "#047857"
    bold: true
  }
}
annotation_over_clipping: {
  label: "|'md\n  **Right Side: Over-Clipping Zone**\n\n  - 99% clips too many values\n  - Information loss in clipped range\n  - Accuracy degradation\n  '|"
  shape: text
  style: {
    font-size: 11
    font-color: "#D97706"
    bold: false
  }
}
# Connect annotations to relevant areas
annotation_outlier_inflation -> curve_99_9.point_99_9_left: {
  label: "High MSE from\noutlier inflation"
  style: {
    stroke: "#DC2626"
    stroke-dash: 4
    stroke-width: 2
    font-color: "#DC2626"
    font-size: 10
  }
}
annotation_optimal -> curve_99_9.point_99_9_optimal: {
  label: ""
  style: {
    stroke: "#047857"
    stroke-width: 2
    animated: true
  }
}
annotation_over_clipping -> curve_99.point_99_farend: {
  label: "Accuracy loss\nfrom clipping"
  style: {
    stroke: "#D97706"
    stroke-dash: 4
    stroke-width: 2
    font-color: "#D97706"
    font-size: 10
  }
}
# ===========================================
# DATA FLOW: Calibration Pipeline
# ===========================================
pipeline_section: {
  label: "Calibration Data Flow"
  input_activations: {
    label: "Input Activations\n(FP32 Tensor)"
    shape: hexagon
    style: {
      fill: "#DBEAFE"
      stroke: "#2563EB"
      stroke-width: 2
    }
  }
  histogram_builder: {
    label: "Histogram Builder\n\n|'md\n  - Collect value frequencies\n  - 4096 bins for precision\n  - O(n) single pass\n  '|"
    shape: rectangle
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  percentile_calculator: {
    label: "Percentile Calculator\n\n|'md\n  - Accumulate from lowest bin\n  - Find threshold at:\n    - 99.00% → 1% clipped\n    - 99.90% → 0.1% clipped  ★\n    - 99.99% → 0.01% clipped\n  '|"
    shape: rectangle
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 2
    }
  }
  scale_computer: {
    label: "Scale Computation\n\n|'md\n  scale = percentile_value / 127\n  \n  For INT8: [-127, 127]\n  Symmetric quantization\n  '|"
    shape: rectangle
    style: {
      fill: "#EDE9FE"
      stroke: "#7C3AED"
      stroke-width: 2
    }
  }
  mse_evaluator: {
    label: "MSE Evaluation\n\n|'md\n  MSE = mean((x - dequant(quant(x)))²)\n  \n  Lower MSE = Better\n  quantization quality\n  '|"
    shape: rectangle
    style: {
      fill: "#FCE7F3"
      stroke: "#DB2777"
      stroke-width: 2
    }
  }
  output_scale: {
    label: "Optimal Scale\n(99.9% percentile)"
    shape: hexagon
    style: {
      fill: "#D1FAE5"
      stroke: "#047857"
      stroke-width: 3
      bold: true
    }
  }
  input_activations -> histogram_builder: {
    label: "Collect statistics"
    style: {
      stroke: "#2563EB"
      stroke-width: 2
    }
  }
  histogram_builder -> percentile_calculator: {
    label: "Bin frequencies"
    style: {
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  percentile_calculator -> scale_computer: {
    label: "Threshold value"
    style: {
      stroke: "#059669"
      stroke-width: 2
    }
  }
  scale_computer -> mse_evaluator: {
    label: "Candidate scale"
    style: {
      stroke: "#7C3AED"
      stroke-width: 2
    }
  }
  mse_evaluator -> output_scale: {
    label: "Select optimal\n(min MSE)"
    style: {
      stroke: "#DB2777"
      stroke-width: 2
      animated: true
    }
  }
}
# ===========================================
# TECHNICAL NOTES
# ===========================================
technical_notes: {
  label: "|'md\n  ## Technical Implementation Notes\n\n  ### Histogram-Based Percentile (O(n) algorithm)\n  python\n  def percentile_from_histogram(hist, bins, percentile):\n      total = sum(hist)\n      target = total * percentile / 100\n      cumulative = 0\n      for i, count in enumerate(hist):\n          cumulative += count\n          if cumulative >= target:\n              return bins[i]\n      return bins[-1]\n  \n\n  ### Tradeoff Analysis\n  | Percentile | Clip % | MSE Impact | Recommendation |\n  |------------|--------|------------|----------------|\n  | 99.00%     | 1.0%   | High       | Too aggressive |\n  | 99.90%     | 0.1%   | **Lowest** | **Optimal**    |\n  | 99.99%     | 0.01%  | Medium     | Conservative   |\n  | 100.00%    | 0.0%   | 2x Higher  | Outlier issue  |\n\n  ### Key Insight\n  Heavy-tailed activation distributions have extreme outliers that\n  disproportionately inflate the scale factor. The 99.9% percentile\n  provides the optimal balance by excluding these outliers while\n  preserving 99.9% of the value range.\n  '|"
  shape: rectangle
  style: {
    fill: "#F8FAFC"
    stroke: "#64748B"
    stroke-width: 1
    font-size: 10
  }
}
# ===========================================
