      stroke: "#7C3AED"
      stroke-width: 2
    }
    pos: {
      x: 175
      y: 160
    }
  }
  # Point at 0.1% clip
  point_99_99_mid2: {
    label: ""
    shape: circle
    style: {
      fill: "#8B5CF6"
      stroke: "#7C3AED"
      stroke-width: 2
    }
    pos: {
      x: 250
      y: 150
    }
  }
  # Point at 0.5% clip
  point_99_99_mid3: {
    label: ""
    shape: circle
    style: {
      fill: "#8B5CF6"
      stroke: "#7C3AED"
      stroke-width: 2
    }
    pos: {
      x: 350
      y: 145
    }
  }
  # Point at 1% clip (right side)
  point_99_99_right: {
    label: ""
    shape: circle
    style: {
      fill: "#8B5CF6"
      stroke: "#7C3AED"
      stroke-width: 2
    }
    pos: {
      x: 400
      y: 155
    }
  }
  point_99_99_farend: {
    label: ""
    shape: circle
