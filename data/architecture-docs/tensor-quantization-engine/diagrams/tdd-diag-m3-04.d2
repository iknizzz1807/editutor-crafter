  point_99_farend: {
    label: ""
    shape: circle
    style: {
      fill: "#F59E0B"
      stroke: "#D97706"
      stroke-width: 2
    }
    pos: {
      x: 600
      y: 320
    }
  }
}
# 99% curve connections
curve_99.point_99_left -> curve_99.point_99_mid1: {
  style: {
    stroke: "#F59E0B"
    stroke-width: 3
  }
