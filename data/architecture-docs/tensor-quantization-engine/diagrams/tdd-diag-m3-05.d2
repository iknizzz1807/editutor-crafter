direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    dark-theme-id: 200
  }
}

# Title and description
title: {
  label: "Calibration Dataset Size vs Stability"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

subtitle: {
  label: "Variance of Computed Quantization Scales vs Number of Calibration Samples"
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# Stability zones (horizontal bands)
zones: {
  unstable_zone: {
    label: "UNSTABLE\nVariance > 1e-6"
    style: {
      fill: "#ff6b6b"
      opacity: 0.2
      stroke: "#ff6b6b"
    }
    shape: rectangle
    width: 800
    height: 120
  }
  good_zone: {
    label: "GOOD\n1e-8 < Variance < 1e-6"
    style: {
      fill: "#ffd93d"
      opacity: 0.2
      stroke: "#ffd93d"
    }
    shape: rectangle
    width: 800
    height: 100
  }
  stable_zone: {
    label: "STABLE\nVariance < 1e-8"
    style: {
      fill: "#6bcb77"
      opacity: 0.2
      stroke: "#6bcb77"
    }
    shape: rectangle
    width: 800
    height: 80
  }
}

# Invisible connections for layout grouping
zones.unstable_zone -> zones.good_zone: {
  style.stroke: transparent
}
zones.good_zone -> zones.stable_zone: {
  style.stroke: transparent
}

# Axis labels
x_axis_label: {
  label: "Number of Calibration Samples →"
  shape: text
  near: bottom-center
}

y_axis_label: {
  label: "← Variance of Computed Scales"
  shape: text
  near: center-left
}

# Data points showing convergence trajectory
data_points: {
  n10: {
    label: "N=10\nσ² = 1e-4"
    shape: circle
    style: {
      fill: "#ff6b6b"
      stroke: "#ff6b6b"
    }
    width: 60
  }
  n50: {
    label: "N=50\nσ² = 5e-6"
    shape: circle
    style: {
      fill: "#ffd93d"
      stroke: "#ffd93d"
    }
    width: 50
  }
  n100: {
    label: "N=100\nσ² = 8e-8"
    shape: circle
    style: {
      fill: "#6bcb77"
      stroke: "#6bcb77"
    }
    width: 45
  }
  n500: {
    label: "N=500\nσ² = 1e-9"
    shape: circle
    style: {
      fill: "#4d96ff"
      stroke: "#4d96ff"
    }
    width: 40
  }
  n1000: {
    label: "N=1000\nσ² = 5e-10"
    shape: circle
    style: {
      fill: "#4d96ff"
      stroke: "#4d96ff"
    }
    width: 38
  }
}

# Convergence curve
data_points.n10 -> data_points.n50: "Rapid\nImprovement" {
  style: {
    stroke-dash: 3
    stroke: "#ff6b6b"
  }
}
data_points.n50 -> data_points.n100: "Crossing\nThreshold" {
  style: {
    stroke-dash: 3
    stroke: "#ffd93d"
  }
}
data_points.n100 -> data_points.n500: "Diminishing\nReturns" {
  style: {
    stroke-dash: 3
    stroke: "#6bcb77"
  }
}
data_points.n500 -> data_points.n1000: "Converged" {
  style: {
    stroke-dash: 3
    stroke: "#4d96ff"
  }
}

# Threshold lines
threshold_1e6: {
  label: "GOOD Threshold (1e-6)"
  shape: rectangle
  style: {
    fill: "#ffd93d"
    opacity: 0.4
    stroke: "#ffd93d"
  }
  width: 800
  height: 2
}
threshold_1e8: {
  label: "STABLE Threshold (1e-8)"
  shape: rectangle
  style: {
    fill: "#6bcb77"
    opacity: 0.4
    stroke: "#6bcb77"
  }
  width: 800
  height: 2
}

# Recommendations panel
recommendations: {
  label: "Recommendations"
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#6bcb77"
    font-color: white
  }
  width: 300
  rec1: "✓ Minimum: 100 samples\n  (variance < 1e-8)" { shape: text }
  rec2: "✓ Recommended: 100-500 samples\n  (optimal stability/efficiency)" { shape: text }
  rec3: "✓ Large models: 500-1000 samples\n  (handles parameter variance)" { shape: text }
  rec4: "✗ Avoid: < 50 samples\n  (high variance, unstable quantization)" { 
    shape: text 
    style.font-color: "#ff6b6b"
  }
}

# Factors affecting stability
factors: {
  label: "Factors Affecting Stability"
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#4d96ff"
    font-color: white
  }
  width: 300
  factor1: "• Model size (parameters)" { shape: text }
  factor2: "• Data diversity in calibration set" { shape: text }
  factor3: "• Outlier frequency in activations" { shape: text }
  factor4: "• Quantization strategy\n  (per-tensor vs per-channel)" { shape: text }
  factor5: "• Calibration method\n  (min/max vs percentile)" { shape: text }
}

# Key insight box
insight: {
  label: "Key Insight: Calibration variance decreases exponentially with sample count, following σ² ∝ 1/N. Beyond 500 samples, improvements become negligible."
  shape: rectangle
  style: {
    fill: "#4d96ff"
    opacity: 0.15
    stroke: "#4d96ff"
  }
  width: 600
}

# Quantization strategy comparison
strategies: {
  label: "Quantization Strategy Impact"
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#9d4edd"
    font-color: white
  }
  width: 300
  per_tensor: "Per-Tensor: Faster convergence\nRequires ~100 samples" {
    shape: text
    style.font-color: "#6bcb77"
  }
  per_channel: "Per-Channel: Slower convergence\nRequires ~300-500 samples" {
    shape: text
    style.font-color: "#ffd93d"
  }
}

# Calibration methods
methods: {
  label: "Calibration Methods"
  shape: rectangle
  style: {
    fill: "#1e1e2e"
    stroke: "#f72585"
    font-color: white
  }
  width: 300
  minmax: "Min/Max: Sensitive to outliers\nNeeds more samples (500+)" { shape: text }
  percentile: "Percentile (99.9%): Robust\nStable with 100-200 samples" { shape: text }
  histogram: "Histogram: Best accuracy\nRequires 200-500 samples" { shape: text }
}

# Flow arrows showing data flow
pipeline: {
  calibration_input: {
    label: "Calibration\nData Loader"
    shape: hexagon
    style: {
      fill: "#4d96ff"
      opacity: 0.2
      stroke: "#4d96ff"
    }
  }
  scale_computation: {
    label: "Scale\nComputation"
    shape: diamond
    style: {
      fill: "#6bcb77"
      opacity: 0.2
      stroke: "#6bcb77"
    }
  }
  variance_tracker: {
    label: "Variance\nTracker"
    shape: circle
    style: {
      fill: "#ffd93d"
      opacity: 0.2
      stroke: "#ffd93d"
    }
  }

  calibration_input -> scale_computation: "batch activations" {
    style: {
      stroke: "#4d96ff"
      stroke-dash: 2
    }
  }
  scale_computation -> variance_tracker: "computed scales" {
    style: {
      stroke: "#6bcb77"
      stroke-dash: 2
    }
  }
  variance_tracker -> data_points.n10: "log variance" {
    style: {
      stroke: "#ffd93d"
      stroke-dash: 1
    }
  }
}

# Layout constraints
recommendations -> factors -> strategies -> methods: {
  style.stroke: transparent
}

pipeline -> zones: {
  style.stroke: transparent
}

insight.near: bottom-center