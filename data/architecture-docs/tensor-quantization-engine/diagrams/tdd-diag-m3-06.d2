direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    blue_fill: "#E8F4FD"
    blue_stroke: "#2196F3"
    orange_fill: "#FFF3E0"
    orange_stroke: "#FF9800"
    green_fill: "#E8F5E9"
    green_stroke: "#4CAF50"
    red_fill: "#FFEBEE"
    red_stroke: "#F44336"
    gray_text: "#616161"
  }
}

title: {
  label: "Activation Function Impact on Tensor Distribution\nCalibration Pipeline Specification v3.0"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

input_distribution: {
  label: "Input Distribution\n(Normal, μ=0, σ=1)"
  shape: rectangle
  style: {
    fill: ${colors.blue_fill}
    stroke: ${colors.blue_stroke}
    stroke-width: 2
  }
  hist_input: {
    shape: rectangle
    width: 200
    height: 100
    style: {
      stroke-dash: 3
      fill: transparent
    }
    # Simulated Gaussian histogram bars
    bar_i1: { shape: rectangle; width: 15; height: 20; style.fill: "#90CAF9" }
    bar_i2: { shape: rectangle; width: 15; height: 35; style.fill: "#90CAF9" }
    bar_i3: { shape: rectangle; width: 15; height: 55; style.fill: "#90CAF9" }
    bar_i4: { shape: rectangle; width: 15; height: 75; style.fill: "#64B5F6" }
    bar_i5: { shape: rectangle; width: 15; height: 90; style.fill: "#42A5F5" }
    bar_i6: { shape: rectangle; width: 15; height: 75; style.fill: "#64B5F6" }
    bar_i7: { shape: rectangle; width: 15; height: 55; style.fill: "#90CAF9" }
    bar_i8: { shape: rectangle; width: 15; height: 35; style.fill: "#90CAF9" }
    bar_i9: { shape: rectangle; width: 15; height: 20; style.fill: "#90CAF9" }
  }
  axis_i: {
    label: "-2.0  -1.0   0.0   +1.0  +2.0"
    shape: text
    style: { font-size: 10 }
  }
}

relu_container: {
  label: "ReLU Activation Unit\nf(x) = max(0, x)"
  shape: rectangle
  style: {
    fill: ${colors.orange_fill}
    stroke: ${colors.orange_stroke}
    stroke-width: 3
  }
  relu_histogram: {
    label: "Output Distribution (Half-Normal)"
    shape: rectangle
    width: 220
    height: 140
    bar_r0: {
      label: "Negative Clipping\nMass Spike at 0"
      shape: rectangle
      width: 50
      height: 95
      style: {
        fill: "#FF5722"
        stroke: "#E64A19"
        stroke-width: 2
      }
    }
    bar_r1: { shape: rectangle; width: 20; height: 60; style.fill: "#FFB74D" }
    bar_r2: { shape: rectangle; width: 20; height: 45; style.fill: "#FFCC80" }
    bar_r3: { shape: rectangle; width: 20; height: 30; style.fill: "#FFE0B2" }
    bar_r4: { shape: rectangle; width: 20; height: 18; style.fill: "#FFF3E0" }
  }
  relu_axis: {
    label: "0.0    +0.5   +1.0   +1.5  +2.0"
    shape: text
    style: { font-size: 10 }
  }
}

gelu_container: {
  label: "GELU Activation Unit\nf(x) = x · Φ(x)"
  shape: rectangle
  style: {
    fill: ${colors.green_fill}
    stroke: ${colors.green_stroke}
    stroke-width: 3
  }
  gelu_histogram: {
    label: "Output Distribution (Smooth)"
    shape: rectangle
    width: 220
    height: 140
    bar_g1: { shape: rectangle; width: 18; height: 15; style.fill: "#C8E6C9" }
    bar_g2: { shape: rectangle; width: 18; height: 30; style.fill: "#A5D6A7" }
    bar_g3: { shape: rectangle; width: 18; height: 50; style.fill: "#81C784" }
    bar_g4: { shape: rectangle; width: 18; height: 70; style.fill: "#66BB6A" }
    bar_g5: { shape: rectangle; width: 18; height: 85; style.fill: "#4CAF50" }
    bar_g6: { shape: rectangle; width: 18; height: 70; style.fill: "#66BB6A" }
    bar_g7: { shape: rectangle; width: 18; height: 50; style.fill: "#81C784" }
    bar_g8: { shape: rectangle; width: 18; height: 30; style.fill: "#A5D6A7" }
    bar_g9: { shape: rectangle; width: 18; height: 15; style.fill: "#C8E6C9" }
  }
  gelu_axis: {
    label: "-0.5   0.0   +0.5  +1.0  +1.5"
    shape: text
    style: { font-size: 10 }
  }
}

quant_impact_relu: {
  label: "Quantization Calibration: ReLU"
  shape: rectangle
  style: {
    fill: ${colors.red_fill}
    stroke: ${colors.red_stroke}
    stroke-width: 2
    stroke-dash: 4
  }
  impact_text: |md
    ### ⚠️ Asymmetric Profile Required
    - **Wasted Precision:** Symmetric quantization would waste ~50% of the range (no negatives).
    - **Zero-Point:** Offset from zero required to map `0.0` to `q_min`.
    - **Bimodal Stress:** The spike at zero makes entropy-based calibration (KL) more volatile.
  |
  formula_relu: |python
    # Calculate Asymmetric Parameters
    scale = (max_val - 0) / (qmax - qmin)
    zp = qmin - round(0 / scale)
  | { shape: code }
}

quant_impact_gelu: {
  label: "Quantization Calibration: GELU"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
    stroke-dash: 4
  }
  impact_text: |md
    ### ✓ Symmetric Profile Optimal
    - **Range Utilization:** Gaussian-like tail maps cleanly to signed INT8 range.
    - **Zero-Point:** Natural zero-point at 0 (Symmetric).
    - **Hardware Efficiency:** No zero-point subtraction logic needed in fused kernels.
  |
  formula_gelu: |python
    # Calculate Symmetric Parameters
    max_abs = max(abs(min_val), abs(max_val))
    scale = max_abs / 127
    zp = 0
  | { shape: code }
}

legend: {
  label: "Visual Legend"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  l1: "■ Output Mass (ReLU)" { style.font-color: "#FF5722" }
  l2: "■ Probability Mass (GELU)" { style.font-color: "#4CAF50" }
  l3: "• Input: Normal N(0,1)" { style: { font-size: 10; italic: true } }
}

# Data Flow Connections
input_distribution -> relu_container: "Non-Linear Map" {
  style: {
    stroke: ${colors.orange_stroke}
    stroke-width: 2
    animated: true
  }
}
input_distribution -> gelu_container: "Non-Linear Map" {
  style: {
    stroke: ${colors.green_stroke}
    stroke-width: 2
    animated: true
  }
}

relu_container -> quant_impact_relu: "Collect Stats" {
  style: { stroke: ${colors.red_stroke}; stroke-dash: 3 }
}
gelu_container -> quant_impact_gelu: "Collect Stats" {
  style: { stroke: ${colors.blue_stroke}; stroke-dash: 3 }
}

annotation: {
  label: |md
    ## Calibration Pipeline Policy (quant-m3)
    *   **Asymmetric Policy:** Mandatory for ReLU to prevent precision loss.
    *   **Symmetric Policy:** Preferred for GELU/Tanh/SiLU to simplify integer arithmetic.
    *   **Clipping Threshold:** Use 99.99th percentile for ReLU to mitigate the 0-spike bias.
  |
  shape: rectangle
  style: {
    font-size: 12
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    border-radius: 8
  }
}