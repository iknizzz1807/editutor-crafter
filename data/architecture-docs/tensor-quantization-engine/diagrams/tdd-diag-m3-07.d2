vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

direction: right

title: "CalibrationMonitor Drift Detection State Machine" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# State Definitions
initial: {
  shape: circle
  style: {
    fill: "#1E3A5F"
    stroke: "#4A90D9"
    stroke-width: 2
  }
}

normal: {
  shape: rectangle
  label: "Normal\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nInvariant:\nclip_pct в‰¤ 1.0%"
  style: {
    fill: "#0D3B1E"
    stroke: "#2ECC71"
    stroke-width: 3
    font-color: "#FFFFFF"
    shadow: true
    border-radius: 10
  }
}

warning: {
  shape: rectangle
  label: "Warning\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nInvariant:\n1.0% < clip_pct в‰¤ 5.0%\n\nentry / log_warning()\nexit / clear_warning_timer()"
  style: {
    fill: "#5D4E0D"
    stroke: "#F1C40F"
    stroke-width: 3
    font-color: "#FFFFFF"
    shadow: true
    border-radius: 10
  }
}

alert: {
  shape: rectangle
  label: "Alert\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nInvariant:\nclip_pct > 5.0%\n\nentry / trigger_alert()\n       notify_ops_team()\nexit / reset_alert_flags()"
  style: {
    fill: "#5D1A0D"
    stroke: "#E74C3C"
    stroke-width: 3
    font-color: "#FFFFFF"
    shadow: true
    multiple: true
    border-radius: 10
  }
}

# Compartmentalized State Details
normal.monitoring: {
  label: "Monitoring Active"
  style: {
    fill: "#0A2E17"
  }
}
normal.calibration: {
  label: "Calibration Stable"
  style: {
    fill: "#0A2E17"
  }
}

warning.investigation: {
  label: "Investigation Mode"
  style: {
    fill: "#4A3D0A"
  }
}
warning.degraded: {
  label: "Degraded Service"
  style: {
    fill: "#4A3D0A"
  }
}

alert.critical: {
  label: "Critical Failure"
  style: {
    fill: "#4A150A"
  }
}
alert.fallback: {
  label: "Fallback Model Active"
  style: {
    fill: "#4A150A"
  }
}

# Transitions
initial -> normal: {
  label: "initialize()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[system_ready]\n/start_monitoring()"
  style: {
    stroke: "#4A90D9"
    stroke-width: 2
    animated: true
  }
}

normal -> warning: {
  label: "check_activation()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[clip_pct > 1.0%]\n/elevate_priority()"
  style: {
    stroke: "#F1C40F"
    stroke-width: 2
  }
}

warning -> normal: {
  label: "check_activation()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[clip_pct в‰¤ 1.0%]\n/resume_normal_ops()"
  style: {
    stroke: "#2ECC71"
    stroke-width: 2
  }
}

warning -> alert: {
  label: "check_activation()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[clip_pct > 5.0%]\n/escalate_to_alert()"
  style: {
    stroke: "#E74C3C"
    stroke-width: 2
    animated: true
  }
}

alert -> warning: {
  label: "manual_reset()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[clip_pct в‰¤ 5.0%]\n/de_escalate()"
  style: {
    stroke: "#F39C12"
    stroke-width: 2
    stroke-dash: 4
  }
}

alert -> normal: {
  label: "recalibrate()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[clip_pct в‰¤ 1.0%]\n/restart_calibration()"
  style: {
    stroke: "#2ECC71"
    stroke-width: 2
    stroke-dash: 4
  }
}

# Self-transitions
normal -> normal: {
  label: "periodic_check()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[clip_pct в‰¤ 1.0%]\n/update_metrics()"
  style: {
    stroke: "#2ECC71"
    stroke-width: 1
    stroke-dash: 2
  }
}

warning -> warning: {
  label: "monitor_drift()\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[1.0% < clip_pct в‰¤ 5.0%]\n/log_drift_trend()"
  style: {
    stroke: "#F1C40F"
    stroke-width: 1
    stroke-dash: 2
  }
}

# Documentation Overlay
metadata: {
  near: bottom-left
  
  legend: {
    shape: rectangle
    label: "State Legend\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nв—Џ Initial State\nв–  Normal (Green)\nв–І Warning (Yellow)\nв—† Alert (Red - Error State)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nTrigger[Guard]/Action\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nAnimated = Auto Transition\nDashed = Manual/Recovery"
    style: {
      fill: "#1A1A2E"
      stroke: "#4A4A6A"
      font-color: "#CCCCCC"
      font-size: 11
    }
  }
  
  thresholds: {
    shape: rectangle
    label: "Drift Thresholds\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nNormal:   clip_pct в‰¤ 1.0%\nWarning:  1.0% < clip_pct в‰¤ 5.0%\nAlert:    clip_pct > 5.0%\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nDefault alert_threshold: 0.01\n(1% of activations clipped)"
    style: {
      fill: "#1A1A2E"
      stroke: "#4A4A6A"
      font-color: "#CCCCCC"
      font-size: 11
    }
  }
}

# Positioning hint for layout engine
metadata.legend -- metadata.thresholds: {
  style: {
    stroke: transparent
  }
}