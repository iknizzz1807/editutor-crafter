direction: right
layout-engine: elk
title: QuantizedLinear Internal Structure
vars: {
    color-module: "#1a1a2e"
    color-buffer: "#16213e"
    color-scalar: "#0f3460"
    color-op: "#e94560"
    color-flow: "#00fff5"
    color-input: "#4ecca3"
    color-output: "#ffc93c"
}
QuantizedLinear: {
    label: "QuantizedLinear\n[out_features × in_features]"
    style.fill: "${color-module}"
    style.stroke: "#4a4a6a"
    style.font-color: "#ffffff"
    style.border-radius: 8
    buffers: {
        label: "Quantized Buffers"
        style.fill: "${color-buffer}"
        style.stroke: "#3a3a5a"
        style.border-radius: 4
        weight_quantized: {
            label: "weight_quantized\n[int8] [out × in]"
            shape: stored_data
            style.fill: "${color-buffer}"
            style.font-color: "#ffffff"
            style.stroke: "${color-op}"
        }
        weight_scale: {
            label: "weight_scale\n[float32] [out]"
            shape: stored_data
            style.fill: "${color-buffer}"
            style.font-color: "#ffffff"
            style.stroke: "${color-flow}"
        }
        weight_zero_point: {
            label: "weight_zero_point\n[int32] [out]"
            shape: stored_data
            style.fill: "${color-buffer}"
            style.font-color: "#ffffff"
            style.stroke: "#8a8aaa"
        }
    }
    activation_params: {
        label: "Activation Parameters"
        style.fill: "${color-scalar}"
        style.stroke: "#2a5a8a"
        style.border-radius: 4
        input_scale: {
            label: "input_scale\nfloat32"
            shape: oval
            style.fill: "${color-scalar}"
            style.font-color: "${color-input}"
        }
        input_zero_point: {
            label: "input_zero_point\nint32"
            shape: oval
            style.fill: "${color-scalar}"
            style.font-color: "${color-input}"
        }
        output_scale: {
            label: "output_scale\nfloat32"
            shape: oval
            style.fill: "${color-scalar}"
            style.font-color: "${color-output}"
        }
        output_zero_point: {
            label: "output_zero_point\nint32"
            shape: oval
            style.fill: "${color-scalar}"
            style.font-color: "${color-output}"
        }
    }
    forward_ops: {
        label: "Forward Operations"
        style.fill: "#1e1e3e"
        style.stroke: "#4a4a6a"
        style.border-radius: 4
        dequant_input: {
            label: "Dequantize\nInput\nx_float = (x_q - zp) × scale"
            shape: diamond
            style.fill: "${color-op}"
            style.font-color: "#ffffff"
        }
        dequant_weight: {
            label: "Dequantize\nWeights\nW_float = (W_q - zp) × scale"
            shape: diamond
            style.fill: "${color-op}"
            style.font-color: "#ffffff"
        }
        matmul: {
            label: "MatMul\ny = x @ W^T + bias"
            shape: circle
            style.fill: "${color-op}"
            style.font-color: "#ffffff"
        }
        quant_output: {
            label: "Quantize\nOutput\ny_q = round(y/scale) + zp"
            shape: diamond
            style.fill: "${color-op}"
            style.font-color: "#ffffff"
        }
    }
}
input: {
    label: "Input\nx_quantized\n[batch × in_features]\nINT8"
    shape: hexagon
    style.fill: "${color-input}"
    style.font-color: "#000000"
    style.stroke: "#2a8a6a"
}
output: {
    label: "Output\ny_quantized\n[batch × out_features]\nINT8"
    shape: hexagon
    style.fill: "${color-output}"
    style.font-color: "#000000"
    style.stroke: "#cc9a2c"
}
input -> QuantizedLinear.forward_ops.dequant_input: {
    label: "INT8"
    style.stroke: "${color-input}"
    style.stroke-width: 3
}
QuantizedLinear.activation_params.input_scale -> QuantizedLinear.forward_ops.dequant_input: {
    style.stroke: "${color-input}"
    style.stroke-dash: 3
}
QuantizedLinear.activation_params.input_zero_point -> QuantizedLinear.forward_ops.dequant_input: {
    style.stroke: "${color-input}"
    style.stroke-dash: 3
}
QuantizedLinear.forward_ops.dequant_input -> QuantizedLinear.forward_ops.matmul: {
    label: "FP32"
    style.stroke: "${color-flow}"
    style.stroke-width: 3
}
QuantizedLinear.buffers.weight_quantized -> QuantizedLinear.forward_ops.dequant_weight: {
    style.stroke: "${color-op}"
    style.stroke-dash: 3
}
QuantizedLinear.buffers.weight_scale -> QuantizedLinear.forward_ops.dequant_weight: {
    style.stroke: "${color-flow}"
    style.stroke-dash: 3
}
QuantizedLinear.buffers.weight_zero_point -> QuantizedLinear.forward_ops.dequant_weight: {
    style.stroke: "#8a8aaa"
    style.stroke-dash: 3
}
QuantizedLinear.forward_ops.dequant_weight -> QuantizedLinear.forward_ops.matmul: {
    label: "FP32 weights"
    style.stroke: "${color-flow}"
    style.stroke-width: 2
}
QuantizedLinear.forward_ops.matmul -> QuantizedLinear.forward_ops.quant_output: {
    label: "FP32"
    style.stroke: "${color-flow}"
    style.stroke-width: 3
}
QuantizedLinear.activation_params.output_scale -> QuantizedLinear.forward_ops.quant_output: {
    style.stroke: "${color-output}"
    style.stroke-dash: 3
}
QuantizedLinear.activation_params.output_zero_point -> QuantizedLinear.forward_ops.quant_output: {
    style.stroke: "${color-output}"
    style.stroke-dash: 3
}
QuantizedLinear.forward_ops.quant_output -> output: {
    label: "INT8"
    style.stroke: "${color-output}"
    style.stroke-width: 3
}
legend: {
    label: "Legend"
    style.fill: "#0a0a1a"
    style.stroke: "#3a3a5a"
    style.font-color: "#ffffff"
    buffer_legend: {
        label: "■ Stored Buffers"
        shape: text
        style.font-color: "${color-buffer}"
    }
    scalar_legend: {
        label: "● Scalar Parameters"
        shape: text
        style.font-color: "${color-scalar}"
    }
    op_legend: {
        label: "◆ Operations"
        shape: text
        style.font-color: "${color-op}"
    }
    flow_legend: {
        label: "→ Data Flow (solid)\n   Parameter Flow (dashed)"
        shape: text
        style.font-color: "${color-flow}"
    }
}