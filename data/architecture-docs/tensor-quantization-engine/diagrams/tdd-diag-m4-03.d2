vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: "Residual Connection Scale Alignment: INT8 Quantization Strategy"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}

# -----------------------------------------------------------------------------
# Section 1: The Problem - Direct INT8 Addition Failure
# -----------------------------------------------------------------------------
problem_container: {
  label: "вќЊ FAILURE CASE: Direct Quantized Addition"
  style: {
    fill: "#2d1b1b"
    stroke: "#ff6b6b"
    stroke-width: 4
    double-border: true
  }

  problem_intro: {
    label: "Critical Error: Logic Mismatch in Scale Domains"
    shape: text
    style: {
      font-size: 16
      italic: true
      font-color: "#ff6b6b"
    }
  }

  # Input tensors with different scales
  x_quant: {
    label: "x_quant (Input)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nType: INT8 Tensor\nScale (Sв‚Ѓ): 0.01\nStored: [50, 60, 70]\nReal: [0.5, 0.6, 0.7]"
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#4a9eff"
      stroke-width: 2
    }
  }

  f_x_quant: {
    label: "f(x)_quant (Residual)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nType: INT8 Tensor\nScale (Sв‚‚): 0.02\nStored: [30, 40, 50]\nReal: [0.6, 0.8, 1.0]"
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#4a9eff"
      stroke-width: 2
    }
  }

  # Direct addition node
  direct_add: {
    label: "ALU: Raw INT8 Add\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n[50+30, 60+40, 70+50]\nResult: [80, 100, 120]"
    shape: rectangle
    style: {
      fill: "#3d2b2b"
      stroke: "#ff6b6b"
    }
  }

  # Garbage output
  garbage_out: {
    label: "вљ пёЏ CORRUPTED OUTPUT\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nExpected Real: 1.10\nActual interpretation:\n80 * 0.01 = 0.80 (WRONG)\n80 * 0.02 = 1.60 (WRONG)"
    shape: rectangle
    style: {
      fill: "#4a1c1c"
      stroke: "#ff4444"
      stroke-width: 3
      shadow: true
    }
  }

  # Connections in failure path
  x_quant -> direct_add: "Raw bits"
  f_x_quant -> direct_add: "Raw bits"
  direct_add -> garbage_out: "вќЊ Arithmetic Noise"

  # Explanation of the physics/math problem
  scale_mismatch: {
    label: "рџ“Љ Scale Mismatch Analysis\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвЂў Domain A: s=0.01\nвЂў Domain B: s=0.02\nвЂў Violation: Adding values with\n  different basis vectors.\nвЂў Result: Unrecoverable precision loss."
    shape: rectangle
    style: {
      fill: "#2a2a3e"
      stroke: "#888"
      stroke-dash: 3
      font-size: 12
    }
  }
}

# -----------------------------------------------------------------------------
# Section 2: Mathematical Theory
# -----------------------------------------------------------------------------
math_section: {
  label: "Formal Logic & Proof"
  style: {
    fill: "#1a1a2e"
    stroke: "#6c63ff"
    stroke-width: 2
  }

  quant_formula: {
    label: "Standard Quantization Model\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nq = clamp(round(r / s + zp))\nr = s Г— (q - zp)\n\nVariables:\n  q: Integer code\n  r: Continuous value\n  s: Resolution quanta"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
    }
  }

  problem_proof: {
    label: "Proof of Incompatibility\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nAdd(x, y) = (sв‚Ѓx_q) + (sв‚‚y_q)\nIf sв‚Ѓ в‰  sв‚‚:\n  ОЈ в‰  s_out Г— (x_q + y_q)\n\nCorrect result requires:\n  ОЈ = s_out Г— [ (sв‚Ѓ/s_out)x_q + (sв‚‚/s_out)y_q ]"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#f85149"
    }
  }

  quant_formula -> problem_proof: "defines"
}

# -----------------------------------------------------------------------------
# Section 3: The Solution - Rescale & Requant
# -----------------------------------------------------------------------------
solution_container: {
  label: "вњ… OPTIMIZED SOLUTION: Rescaling Pipeline"
  style: {
    fill: "#1b2d1b"
    stroke: "#51cf66"
    stroke-width: 4
    double-border: true
  }

  solution_intro: {
    label: "Operation: Re-projection to Common Floating Point Domain"
    shape: text
    style: {
      font-size: 16
      italic: true
      font-color: "#51cf66"
    }
  }

  dequant_x: {
    label: "Stage 1a: Proj(x) в†’ FP32\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nx_fp = 50 * 0.01\n     = 0.50"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#51cf66"
    }
  }

  dequant_fx: {
    label: "Stage 1b: Proj(f(x)) в†’ FP32\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nfx_fp = 30 * 0.02\n      = 0.60"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#51cf66"
    }
  }

  float_add: {
    label: "Stage 2: Linear FP Addition\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nОЈ_fp = 0.50 + 0.60\n     = 1.10"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#58a6ff"
      stroke-width: 3
    }
  }

  requant: {
    label: "Stage 3: Quantize(ОЈ_fp, s_out)\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\ns_out = 0.007\nq_out = round(1.10 / 0.007)\n      = 157"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#51cf66"
    }
  }

  valid_output: {
    label: "вњ… VERIFIED INT8 RESULT\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nValue: 157\nScale: 0.007\nCalculated: 1.099 (Error < 0.1%)"
    shape: rectangle
    style: {
      fill: "#1a3d1a"
      stroke: "#51cf66"
      stroke-width: 3
      shadow: true
    }
  }

  dequant_x -> float_add: "FP32"
  dequant_fx -> float_add: "FP32"
  float_add -> requant: "High Precision"
  requant -> valid_output: "INT8 Mapping"
}

# -----------------------------------------------------------------------------
# Section 4: Implementation Blueprint
# -----------------------------------------------------------------------------
module_container: {
  label: "Hardware/Software Module: QuantizedResidualAdd"
  style: {
    fill: "#1a1a2e"
    stroke: "#a855f7"
    stroke-width: 2
  }

  module_sig: {
    label: "API Definition\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nInput A: (data: INT8, scale: FP32)\nInput B: (data: INT8, scale: FP32)\nOutput:  (data: INT8, scale: FP32)\n\nLogic: Rescale(A, B) -> Add -> Requant"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#a855f7"
    }
  }

  module_flow: {
    label: "Implementation Steps\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n1. Load S_input, S_residual\n2. Compute FP32 result\n3. Dynamic range check\n4. Cast back to quantized"
    shape: rectangle
    style: {
      fill: "#0d1117"
      stroke: "#a855f7"
    }
  }

  module_sig -> module_flow
}

# -----------------------------------------------------------------------------
# Meta Sections: Insight & Legend
# -----------------------------------------------------------------------------
insight: {
  label: "рџ’Ў ENGINEERING INSIGHT\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n\nScale alignment is the most common bug in Quantization-Aware Training (QAT).\nWithout explicit alignment, residual connections effectively inject random noise\ninto the forward pass. \n\nPerformance Note: In high-performance kernels, we often perform 'Fixed-Point Rescaling'\nusing bit-shifts and multipliers to avoid expensive FP32 hardware cycles."
  shape: rectangle
  style: {
    fill: "#2a2a3e"
    stroke: "#ffd43b"
    stroke-width: 2
    font-size: 14
  }
}

legend: {
  label: "Diagram Legend\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nрџ”ґ Red: Mismatched Domains\nрџџў Green: Aligned Domains\nрџ”µ Blue: Precision Accumulator\nрџџЈ Purple: System Module"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#666"
    font-size: 12
  }
}

# Top-level sequence connections
problem_container -> math_section: "Why?" {
  style.stroke-dash: 5
}
math_section -> solution_container: "Resolution" {
  style: {
    stroke: "#51cf66"
    stroke-width: 3
  }
}
