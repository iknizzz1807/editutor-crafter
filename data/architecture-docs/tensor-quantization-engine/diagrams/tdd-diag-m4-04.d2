layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
    dark-theme-id: 200
  }
}

direction: right

title: |md
  # Layer Fusion: Conv-BN-ReLU
  ## Tensor Quantization Engine Optimization Pipeline
| {
  near: top-center
  shape: text
}

# BEFORE: Separate Operations (High Memory Overhead)
before: {
  label: "Before Fusion (High Latency)"
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }

  input: {
    label: "Input Tensor\nX ∈ ℝᶜˣᴴˣᵂ"
    shape: rectangle
    style: {
      fill: "#16213e"
      stroke: "#0f4c75"
    }
  }

  conv: {
    label: "Conv2d\n──────────\nW ∈ ℝᴼˣᶜˣᴷˣᴷ\nb ∈ ℝᴼ"
    shape: rectangle
    style: {
      fill: "#1f4068"
      stroke: "#42a5f5"
    }
  }

  bn: {
    label: "BatchNorm2d\n──────────────\nγ (scale) ∈ ℝᴼ\nβ (shift) ∈ ℝᴼ\nμ (mean)\nσ² (var)"
    shape: rectangle
    style: {
      fill: "#4a1942"
      stroke: "#e94560"
    }
  }

  relu: {
    label: "ReLU\n──────────\nf(x) = max(0, x)\nRange: [0, +∞)"
    shape: rectangle
    style: {
      fill: "#2d4a22"
      stroke: "#6aaa64"
    }
  }

  output_before: {
    label: "Output Tensor\nY ∈ ℝᴼˣᴴ'ˣᵂ'"
    shape: rectangle
    style: {
      fill: "#16213e"
      stroke: "#0f4c75"
    }
  }

  input -> conv: "C channels" {
    style.stroke: "#42a5f5"
  }
  conv -> bn: "O feature maps" {
    style.stroke: "#e94560"
  }
  bn -> relu: "normalized" {
    style.stroke: "#6aaa64"
  }
  relu -> output_before: "activated" {
    style.stroke: "#6aaa64"
  }
}

# Fusion Transformation Arrow
transform: {
  label: "┌─────────────────────────────────────────┐\n│         FUSION TRANSFORMATION            │\n├─────────────────────────────────────────┤\n│  W_folded = W × (γ / √(σ² + ε))          │\n│  b_folded = (b - μ) × γ/√(σ² + ε) + β    │\n│                                          │\n│  • BN params absorbed into conv weights  │\n│  • ReLU bounds → asymmetric quant scale  │\n│  • 3 kernel launches → 1 fused kernel    │\n└─────────────────────────────────────────┘"
  shape: rectangle
  style: {
    fill: "#0d0d1a"
    stroke: "#ffd700"
    stroke-width: 2
  }
}

# AFTER: Fused Operation (Zero Intermediate Memory R/W)
after: {
  label: "After Fusion (Optimized)"
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }

  input_fused: {
    label: "Input Tensor\nX ∈ ℝᶜˣᴴˣᵂ"
    shape: rectangle
    style: {
      fill: "#16213e"
      stroke: "#0f4c75"
    }
  }

  fused_conv_relu: {
    label: "FusedConvReLU2d\n─────────────────────\nW_folded = W × γ/√(σ²+ε)\nb_folded = (b-μ)×γ/√(σ²+ε)+β\n─────────────────────\nImplicit ReLU via\nasymmetric quant [0, max]"
    shape: rectangle
    style: {
      fill: "#0f4c75"
      stroke: "#00ff88"
      stroke-width: 3
      shadow: true
    }
  }

  output_fused: {
    label: "Output Tensor\nY ∈ ℝᴼˣᴴ'ˣᵂ'  [0, max]"
    shape: rectangle
    style: {
      fill: "#16213e"
      stroke: "#00ff88"
    }
  }

  input_fused -> fused_conv_relu: "C channels\nINT8 quantized" {
    style.stroke: "#00ff88"
  }
  fused_conv_relu -> output_fused: "O feature maps\nINT8 asymmetric" {
    style.stroke: "#00ff88"
  }
}

# Quantization Scale Info
scale_info: {
  label: "Combined Quantization Scale\n────────────────────────────\nS_fused = S_conv × γ / √(σ² + ε)\nZ_output = 0  (ReLU clipped)\n────────────────────────────\nPer-channel granularity for\nweight, per-tensor for activation"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#ff6b6b"
  }
}

# Memory Layout Comparison
memory_comparison: {
  label: "Memory & Compute Savings Analysis"
  shape: rectangle
  style: {
    fill: "#0d0d0d"
    stroke: "#4a4a6a"
  }
  
  before_mem: {
    label: "Before:\n• 3 kernel launches\n• BN: O(H×W×C) memory r/w\n• ReLU: O(H×W×C) memory r/w\n• Intermediate buffers required"
    shape: text
    style.font-color: "#ff6b6b"
  }
  
  after_mem: {
    label: "After:\n• 1 fused kernel launch\n• Zero intermediate buffers\n• BN folded into weights (offline)\n• ReLU via output quant bounds"
    shape: text
    style.font-color: "#00ff88"
  }
  
  before_mem -> after_mem: "→" {
    style: {
      stroke: "#ffd700"
      stroke-width: 2
    }
  }
}

# Top Level Connections
before -> transform: {
  style: {
    stroke: "#ffd700"
    stroke-width: 3
    stroke-dash: 4
  }
}

transform -> after: {
  style: {
    stroke: "#ffd700"
    stroke-width: 3
    stroke-dash: 4
  }
}

after.fused_conv_relu -> scale_info: "produces" {
  style: {
    stroke: "#ff6b6b"
    stroke-dash: 3
  }
}

after -> memory_comparison: {
  style: {
    stroke: "#4a4a6a"
    stroke-dash: 3
  }
}

# Legend for Engineering Clarity
legend: {
  label: "Kernel Legend"
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#0a0a0a"
    stroke: "#333333"
  }
  
  conv_color: {
    label: "■ Convolution Layer"
    shape: text
    style.font-color: "#42a5f5"
  }
  bn_color: {
    label: "■ BatchNorm Layer"
    shape: text
    style.font-color: "#e94560"
  }
  relu_color: {
    label: "■ Activation Layer"
    shape: text
    style.font-color: "#6aaa64"
  }
  fused_color: {
    label: "■ Fused / Folded Op"
    shape: text
    style.font-color: "#00ff88"
  }
}

# IDs for Atlas Reference
# FUSE_CONV_BN_RELU: Optimization transform
# OP_CONV2D: Initial op
# OP_FUSED_CONCISE: Resultant op
# MEM_MAP: Analysis container