direction: right
layout-engine: elk
title: {
  label: Layer Sensitivity Analysis Heatmap\nAccuracy Drop When Quantizing Each Layer Individually
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Legend for sensitivity levels
legend: {
  label: Sensitivity Levels
  shape: rectangle
  style.fill: "#f8f9fa"
  high: {
    label: HIGH (>2% drop)\nKeep FP32
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
    style.stroke: "#b02a37"
  }
  medium: {
    label: MEDIUM (0.5-2%)\nQuantize Carefully
    shape: rectangle
    style.fill: "#ffc107"
    style.stroke: "#cc9a06"
  }
  low: {
    label: LOW (<0.5%)\nSafe to Quantize
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
    style.stroke: "#1e7e34"
  }
}
# Model Architecture Column
model_arch: {
  label: Model Architecture
  shape: rectangle
  style.fill: "#e9ecef"
  style.stroke: "#6c757d"
  embed_layer: {
    label: Embedding\n768-dim
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  ln1_layer: {
    label: LayerNorm 1
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
  }
  attn_qkv: {
    label: Attention QKV\nLinear 768x2304
    shape: rectangle
    style.fill: "#ffc107"
  }
  attn_proj: {
    label: Attention Proj\nLinear 768x768
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  ln2_layer: {
    label: LayerNorm 2
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
  }
  mlp_fc1: {
    label: MLP FC1\nLinear 768x3072
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  mlp_fc2: {
    label: MLP FC2\nLinear 3072x768
    shape: rectangle
    style.fill: "#ffc107"
  }
}
# Accuracy Drop Column
accuracy_drop: {
  label: Accuracy Drop (%)
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#6c757d"
  drop_embed: {
    label: "0.12%"
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  drop_ln1: {
    label: "3.45%"
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
  }
  drop_qkv: {
    label: "1.23%"
    shape: rectangle
    style.fill: "#ffc107"
  }
  drop_proj: {
    label: "0.34%"
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  drop_ln2: {
    label: "2.89%"
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
  }
  drop_fc1: {
    label: "0.28%"
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  drop_fc2: {
    label: "0.67%"
    shape: rectangle
    style.fill: "#ffc107"
  }
}
# Sensitivity Score Column
sensitivity: {
  label: Sensitivity Score
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#6c757d"
  score_embed: {
    label: "0.24"
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  score_ln1: {
    label: "6.90"
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
  }
  score_qkv: {
    label: "2.46"
    shape: rectangle
    style.fill: "#ffc107"
  }
  score_proj: {
    label: "0.68"
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  score_ln2: {
    label: "5.78"
    shape: rectangle
    style.fill: "#dc3545"
    style.font-color: white
  }
  score_fc1: {
    label: "0.56"
    shape: rectangle
    style.fill: "#28a745"
    style.font-color: white
  }
  score_fc2: {
    label: "1.34"
    shape: rectangle
    style.fill: "#ffc107"
  }
}
# Quantization Decision Column
decision: {
  label: Quantization Decision
  shape: rectangle
  style.fill: "#f8f9fa"
  style.stroke: "#6c757d"
  dec_embed: {
    label: INT8
    shape: rectangle
    style.fill: "#17a2b8"
    style.font-color: white
  }
  dec_ln1: {
    label: KEEP_FP32
    shape: rectangle
    style.fill: "#6c757d"
    style.font-color: white
  }
  dec_qkv: {
    label: INT8\n(per-channel)
    shape: rectangle
    style.fill: "#17a2b8"
    style.font-color: white
  }
  dec_proj: {
    label: INT8
    shape: rectangle
    style.fill: "#17a2b8"
    style.font-color: white
  }
  dec_ln2: {
    label: KEEP_FP32
    shape: rectangle
    style.fill: "#6c757d"
    style.font-color: white
  }
  dec_fc1: {
    label: INT8
    shape: rectangle
    style.fill: "#17a2b8"
    style.font-color: white
  }
  dec_fc2: {
    label: INT8\n(per-channel)
    shape: rectangle
    style.fill: "#17a2b8"
    style.font-color: white
  }
}
# Connections - horizontal flow
model_arch.embed_layer -> accuracy_drop.drop_embed: {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
model_arch.ln1_layer -> accuracy_drop.drop_ln1: {
  style.stroke: "#dc3545"
  style.stroke-dash: 3
}
model_arch.attn_qkv -> accuracy_drop.drop_qkv: {
  style.stroke: "#ffc107"
  style.stroke-dash: 3
}
model_arch.attn_proj -> accuracy_drop.drop_proj: {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
model_arch.ln2_layer -> accuracy_drop.drop_ln2: {
  style.stroke: "#dc3545"
  style.stroke-dash: 3
}
model_arch.mlp_fc1 -> accuracy_drop.drop_fc1: {
  style.stroke: "#28a745"
  style.stroke-dash: 3
}
model_arch.mlp_fc2 -> accuracy_drop.drop_fc2: {
  style.stroke: "#ffc107"
  style.stroke-dash: 3
}
accuracy_drop.drop_embed -> sensitivity.score_embed
accuracy_drop.drop_ln1 -> sensitivity.score_ln1
accuracy_drop.drop_qkv -> sensitivity.score_qkv
accuracy_drop.drop_proj -> sensitivity.score_proj
accuracy_drop.drop_ln2 -> sensitivity.score_ln2
accuracy_drop.drop_fc1 -> sensitivity.score_fc1
accuracy_drop.drop_fc2 -> sensitivity.score_fc2
sensitivity.score_embed -> decision.dec_embed
sensitivity.score_ln1 -> decision.dec_ln1
sensitivity.score_qkv -> decision.dec_qkv
sensitivity.score_proj -> decision.dec_proj
sensitivity.score_ln2 -> decision.dec_ln2
sensitivity.score_fc1 -> decision.dec_fc1
sensitivity.score_fc2 -> decision.dec_fc2
# Summary statistics
summary: {
  label: Summary Statistics
  shape: rectangle
  style.fill: "#e9ecef"
  style.stroke: "#6c757d"
  total_layers: {
    label: "Total Layers: 7"
    shape: text
  }
  safe_layers: {
    label: "Safe to Quantize: 3 (43%)"
    shape: text
    style.font-color: "#28a745"
  }
  caution_layers: {
    label: "Quantize Carefully: 2 (29%)"
    shape: text
    style.font-color: "#cc9a06"
  }
  keep_fp32: {
    label: "Keep FP32: 2 (29%)"
    shape: text
    style.font-color: "#dc3545"
  }
  baseline_acc: {
    label: "Baseline FP32 Accuracy: 94.2%"
    shape: text
  }
  projected_acc: {
    label: "Projected INT8 Accuracy: 93.5%"
    shape: text
    style.bold: true
  }
  compression: {
    label: "Expected Compression: ~3.7x"
    shape: text
  }
}
# Connect summary
decision -> summary: {
  label: Analysis Result
  style.stroke: "#6c757d"
  style.stroke-width: 2
}
# Input/Output nodes
input: {
  label: Calibration\nDataset
  shape: oval
  style.fill: "#007bff"
  style.font-color: white
}
output: {
  label: Quantization\nPlan
  shape: oval
  style.fill: "#6610f2"
  style.font-color: white
}
input -> model_arch: {
  label: layer-by-layer\nanalysis
  style.stroke-width: 2
}
summary -> output: {
  label: optimized\nconfig
  style.stroke-width: 2
  style.stroke: "#6610f2"
}
# Layer group labels
layer_groups: {
  label: ""
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
  embed_group: {
    label: Embedding
    shape: rectangle
    style.stroke-dash: 5
  }
  attn_group: {
    label: Attention Block
    shape: rectangle
    style.stroke-dash: 5
  }
  mlp_group: {
    label: MLP Block
    shape: rectangle
    style.stroke-dash: 5
  }
}