direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: "Perplexity Comparison: FP16 vs Naive INT4 vs GPTQ INT4" {
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

chart_area: {
  # Y-Axis Assembly
  y_axis_container: {
    y_axis: {
      shape: rectangle
      width: 4
      height: 500
      style.fill: "#333333"
    }
    y_label_0: "0" {
      shape: text
      style.font-size: 12
    }
    y_label_25: "25" {
      shape: text
      style.font-size: 12
    }
    y_label_50: "50+" {
      shape: text
      style.font-size: 12
    }
    axis_label: "Perplexity (PPL) ↓" {
      shape: text
      style: {
        font-size: 16
        bold: true
      }
    }
  }

  # Data Groups
  group_fp16: {
    label: "Lower is Better (Target)"
    shape: rectangle
    style: {
      fill: "#f8f9fa"
      stroke-dash: 2
    }
    fp16_bar: {
      shape: rectangle
      width: 100
      height: 55
      style: {
        fill: "#4CAF50"
        stroke: "#388E3C"
        stroke-width: 2
      }
    }
    fp16_label: "FP16 Baseline" {
      shape: text
      style: {
        font-size: 14
        bold: true
      }
    }
    fp16_value: "PPL: 5.5" {
      shape: text
      style: {
        font-size: 20
        bold: true
        font-color: "#2E7D32"
      }
    }
  }

  group_naive: {
    label: "Catastrophic Degradation"
    shape: rectangle
    style: {
      fill: "#ffebee"
      stroke-dash: 2
    }
    naive_bar: {
      shape: rectangle
      width: 100
      height: 500
      style: {
        fill: "#f44336"
        stroke: "#c62828"
        stroke-width: 2
      }
    }
    naive_label: "Naive INT4" {
      shape: text
      style: {
        font-size: 14
        bold: true
      }
    }
    naive_value: "PPL: 50+" {
      shape: text
      style: {
        font-size: 22
        bold: true
        font-color: "#c62828"
      }
    }
    warning: "⚠️ 9x worse!" {
      shape: text
      style: {
        font-size: 14
        font-color: "#c62828"
        italic: true
        bold: true
      }
    }
  }

  group_gptq: {
    label: "Minimal Degradation"
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke-dash: 2
    }
    gptq_bar: {
      shape: rectangle
      width: 100
      height: 58
      style: {
        fill: "#2196F3"
        stroke: "#1565C0"
        stroke-width: 2
      }
    }
    gptq_label: "GPTQ INT4" {
      shape: text
      style: {
        font-size: 14
        bold: true
      }
    }
    gptq_value: "PPL: 5.85" {
      shape: text
      style: {
        font-size: 20
        bold: true
        font-color: "#1565C0"
      }
    }
    delta: "+6% only" {
      shape: text
      style: {
        font-size: 14
        font-color: "#1565C0"
        italic: true
        bold: true
      }
    }
  }
}

legend: {
  shape: rectangle
  near: bottom-right
  style: {
    fill: "#ffffff"
    stroke: "#cccccc"
    stroke-width: 1
    shadow: true
  }
  legend_title: "Key Insight" {
    shape: text
    style: {
      bold: true
      font-size: 14
      underline: true
    }
  }
  legend_text: |md
    **GPTQ's Hessian-aware compensation**
    preserves model quality at INT4,
    while naive quantization destroys
    the weight distribution.
  | {
    shape: text
    style.font-size: 12
  }
}

# Connections representing the transformation logic
chart_area.group_fp16.fp16_bar -> chart_area.group_naive.naive_bar: "Round-to-nearest\n(Standard Cast)" {
  style: {
    stroke-dash: 4
    font-size: 11
    stroke: "#c62828"
  }
}

chart_area.group_naive.naive_bar -> chart_area.group_gptq.gptq_bar: "Hessian-based\nQuantization Offset" {
  style: {
    stroke-dash: 4
    font-size: 11
    stroke: "#1565C0"
    animated: true
  }
}