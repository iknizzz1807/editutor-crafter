direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 200
  }
  dark-bg: "#1a1a2e"
  surface-high: "#ff6b6b"
  surface-mid: "#4ecdc4"
  surface-low: "#45b7d1"
  accent-gold: "#ffd93d"
  text-light: "#e8e8e8"
  grid-line: "#3d3d5c"
}

title: {
  label: "Hessian Intuition: Curvature Matters"
  shape: text
  style: {
    font-size: 28
    bold: true
    font-color: "${text-light}"
  }
}

# Main concept flow
context_label: {
  label: "Why does Hessian tell us which weights matter?"
  shape: text
  style: {
    font-size: 16
    font-color: "${text-light}"
    italic: true
  }
}

# Loss Landscape Container
loss_landscape: {
  label: "Loss Landscape L(W)"
  style: {
    fill: "${dark-bg}"
    stroke: "${grid-line}"
    stroke-width: 2
    border-radius: 8
  }

  # 3D Surface representation using layered shapes
  surface_back: {
    label: ""
    shape: hexagon
    style: {
      fill: "${surface-low}"
      opacity: 0.4
      stroke: "${grid-line}"
    }
    width: 400
    height: 120
  }

  surface_mid: {
    label: ""
    shape: hexagon
    style: {
      fill: "${surface-mid}"
      opacity: 0.6
      stroke: "${grid-line}"
    }
    width: 350
    height: 100
  }

  surface_front: {
    label: ""
    shape: hexagon
    style: {
      fill: "${surface-high}"
      opacity: 0.8
      stroke: "${surface-high}"
    }
    width: 280
    height: 80
  }

  # Curvature indicators
  steep_region: {
    label: "High Curvature\n(Steep Valley)"
    shape: text
    style: {
      font-color: "${surface-high}"
      font-size: 12
      bold: true
    }
  }

  flat_region: {
    label: "Low Curvature\n(Flat Plateau)"
    shape: text
    style: {
      font-color: "${surface-low}"
      font-size: 12
    }
  }

  # Weight axis
  w1_axis: {
    label: "W₁ (Weight 1)"
    shape: text
    style: {
      font-color: "${text-light}"
      font-size: 11
    }
  }
}

# Hessian Matrix Panel
hessian_panel: {
  label: "Hessian Matrix H = 2XᵀX"
  style: {
    fill: "#0f0f1a"
    stroke: "${accent-gold}"
    stroke-width: 2
    border-radius: 8
  }

  hessian_visual: {
    label: "[H₁₁  H₁₂]\n[H₂₁  H₂₂]"
    shape: rectangle
    style: {
      fill: "${dark-bg}"
      stroke: "${accent-gold}"
      font: mono
      font-size: 18
      font-color: "${text-light}"
    }
    width: 140
    height: 80
  }

  diagonal_high: {
    label: "Hᵢᵢ = HIGH\n→ Weight matters!"
    shape: rectangle
    style: {
      fill: "${surface-high}"
      opacity: 0.3
      stroke: "${surface-high}"
      font-size: 11
      font-color: "${text-light}"
    }
  }

  diagonal_low: {
    label: "Hⱼⱼ = LOW\n→ Weight less critical"
    shape: rectangle
    style: {
      fill: "${surface-low}"
      opacity: 0.3
      stroke: "${surface-low}"
      font-size: 11
      font-color: "${text-light}"
    }
  }

  formula: {
    label: "∂²L/∂W² = Curvature"
    shape: text
    style: {
      font-color: "${accent-gold}"
      font-size: 14
      italic: true
    }
  }
}

# Intuition explanation
intuition: {
  label: "Key Insight"
  style: {
    fill: "${dark-bg}"
    stroke: "${accent-gold}"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 8
  }

  insight_text: {
    label: |md
      **Quantization error δ in high-curvature direction**
      → Large increase in loss

      **Quantization error δ in low-curvature direction**
      → Small increase in loss
    |
    shape: text
    style: {
      font-color: "${text-light}"
      font-size: 12
    }
  }

  conclusion: {
    label: "∴ Use Hessian to prioritize which weights\nneed higher precision during quantization"
    shape: text
    style: {
      font-color: "${accent-gold}"
      font-size: 13
      bold: true
    }
  }
}

# Weight importance scale
importance_scale: {
  label: "Weight Importance"
  style: {
    fill: "${dark-bg}"
    stroke: "${grid-line}"
    border-radius: 8
  }

  scale_high: {
    label: "CRITICAL"
    shape: rectangle
    style: {
      fill: "${surface-high}"
      bold: true
    }
    width: 100
    height: 30
  }

  scale_mid: {
    label: "MODERATE"
    shape: rectangle
    style: {
      fill: "${surface-mid}"
    }
    width: 100
    height: 30
  }

  scale_low: {
    label: "LESS"
    shape: rectangle
    style: {
      fill: "${surface-low}"
    }
    width: 100
    height: 30
  }

  scale_label: {
    label: "Hessian Diagonal Value →"
    shape: text
    style: {
      font-color: "${text-light}"
      font-size: 10
    }
  }
}

# GPTQ Application
gptq_box: {
  label: "GPTQ Strategy"
  style: {
    fill: "#1e3a5f"
    stroke: "${accent-gold}"
    stroke-width: 2
    border-radius: 8
  }

  gptq_steps: {
    label: |md
      1. Compute **H⁻¹** from activations
      2. Quantize column by column
      3. Apply Hessian-weighted compensation:
         **δ = -wᵠ / (H⁻¹)ᵢᵢ**
    |
    shape: text
    style: {
      font-color: "${text-light}"
      font-size: 11
    }
  }
}

# Connections
loss_landscape -> hessian_panel: {
  label: "Second derivative\nmeasures curvature"
  style: {
    stroke: "${accent-gold}"
    stroke-width: 2
    animated: true
    font-color: "${accent-gold}"
  }
}

hessian_panel -> intuition: {
  label: "Diagonal values\nindicate sensitivity"
  style: {
    stroke: "${text-light}"
    stroke-dash: 3
    font-color: "${text-light}"
  }
}

intuition -> importance_scale: {
  label: "Determines Priority"
  style: {
    stroke: "${grid-line}"
    font-color: "${text-light}"
  }
}

importance_scale -> gptq_box: {
  label: "Informs\nquantization"
  style: {
    stroke: "${accent-gold}"
    stroke-width: 2
    font-color: "${accent-gold}"
  }
}

# Legend
legend: {
  label: "Legend"
  style: {
    fill: "${dark-bg}"
    stroke: "${grid-line}"
    border-radius: 8
  }

  leg_high: {
    label: "■ High curvature = Sensitive weight"
    shape: text
    style: {
      font-color: "${surface-high}"
      font-size: 10
    }
  }

  leg_low: {
    label: "■ Low curvature = Tolerant weight"
    shape: text
    style: {
      font-color: "${surface-low}"
      font-size: 10
    }
  }

  leg_gold: {
    label: "■ Mathematical relationship"
    shape: text
    style: {
      font-color: "${accent-gold}"
      font-size: 10
    }
  }
}