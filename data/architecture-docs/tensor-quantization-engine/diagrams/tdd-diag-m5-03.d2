direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- GLOBAL STYLES & CLASSES ---
# Intel Manual Quality styling
*.style.font: mono
*.style.border-radius: 4

classes: {
  matrix_box: {
    style: {
      fill: "#0d0d1a"
      stroke: "#333"
      stroke-width: 2
    }
  }
  keep_style: {
    style: {
      fill: "#0d3320"
      stroke: "#4ade80"
      stroke-width: 2
    }
  }
  discard_style: {
    style: {
      fill: "#3d1a1a"
      stroke: "#f87171"
      stroke-width: 2
    }
  }
  annotation: {
    shape: sticky_note
    style.font-size: 12
  }
}

# --- MAIN COMPONENTS ---

full_hessian: "FULL HESSIAN MATRIX [H = 2XᵀX]" {
  tooltip: "Second-order derivative of the loss function representing parameter curvature"
  style.fill: "#1a1a2e"
  style.stroke: "#4a9eff"
  style.stroke-width: 3

  matrix_viz: "Memory Layout: float64[N, N]" {
    class: matrix_box
    width: 280
    height: 280
    
    diag_strip: "Main Diagonal (Hᵢᵢ)" {
      # Corrected shape: line -> rectangle
      shape: rectangle
      style.fill: "#4ade80"
      style.stroke-width: 0
      style.opacity: 0.8
      width: 20
      height: 240
    }
    
    off_diag_area: "Off-Diagonal Interactions (Hᵢⱼ)" {
      style.fill-pattern: dots
      style.fill: "#f87171"
      style.opacity: 0.15
    }

    footer: "Total Bytes: N² * 8" {
      style.font-size: 10
    }
  }

  diagonal_elements: "Hᵢᵢ: Per-Weight Curvature" {
    shape: rectangle
    width: 320
    height: 70
    style.fill: "#2d5a3d"
    style.stroke: "#4ade80"
    style.bold: true
    label: |md
      **Diagonal Terms**
      `Hᵢᵢ = 2 · Σⱼ(Xⱼᵢ)²`
      *Size: N * 8 Bytes*
    |
  }

  offdiag_elements: "Hᵢⱼ: Interaction Terms" {
    shape: rectangle
    width: 320
    height: 70
    style.fill: "#5a2d2d"
    style.stroke: "#f87171"
    label: |md
      **Off-Diagonal Terms**
      `Hᵢⱼ = 2 · XᵢᵀXⱼ`
      *Size: (N²-N) * 8 Bytes*
    |
  }
}

preserved: "RETAINED STATE (PTQ SPARSE)" {
  class: keep_style
  
  diag_value: {
    label: |||md
      ### Sparse Curvature Vector
      - $H_{11} = 2 \cdot ||X_{:,1}||^2$
      - $H_{22} = 2 \cdot ||X_{:,2}||^2$
      - $H_{nn} = 2 \cdot ||X_{:,n}||^2$
      ---
      **Usage**: Denominator in OBS error update
    |||
    width: 320
  }

  interpretation: {
    label: |md
      ### Theoretical Mapping
      - **Curvature**: Local Sensitivity to $\Delta W$
      - **Fisher Info**: Parameter Importance Rank
      - **Quantization**: Optimal Bit Allocation
    |
    width: 320
  }

  complexity: "Complexity: O(N) Space" {
    style.fill: "#1a4d2e"
    style.bold: true
    style.font-color: "#4ade80"
    style.double-border: true
  }
}

lost: "INFORMATION PRUNING (ZEROED)" {
  class: discard_style

  offdiag_value: {
    label: |md
      ### Discarded Interactions
      - $H_{ij}$ where $i \neq j$
      - Input Feature Cross-Correlation
      - Parameter Coupling Terms
      - Multi-variate Redundancy
    |
    width: 320
  }

  interpretation_lost: {
    label: |md
      ### Approximation Impact
      - **Assumption**: Parameters are independent
      - **Risk**: Greedy rounding local drift
      - **Result**: Potential Signal Degradation
    |
    width: 320
  }

  complexity_lost: "Complexity: O(N²) Pruned" {
    style.fill: "#5a2020"
    style.bold: true
    style.font-color: "#f87171"
  }
}

diagonal_approx: "DIAGONAL APPROXIMATION ENGINE" {
  style.fill: "#1a2a1a"
  style.stroke: "#4ade80"
  style.stroke-width: 4

  approx_matrix: "H ≈ diag(H₁₁, ..., Hₙₙ)" {
    class: matrix_box
    width: 280
    height: 280
    style.fill: "#0d1a0d"
    style.stroke: "#4ade80"
    
    diagonal: "Extracted Diagonal" {
      # Corrected shape: line -> rectangle
      shape: rectangle
      style.fill: "#4ade80"
      style.stroke-width: 0
      width: 30
      height: 240
    }
  }

  benefit: {
    label: |md
      ### Runtime Efficiency
      - **O(1) Inversion**: $H^{-1} = 1/H_{ii}$
      - **Memory**: Resident in L3 Cache
      - **Ops**: Element-wise Vector Multiply
    |
    width: 320
  }
}

tradeoff: "GPTQ / OPTIMAL BRAIN SURGEON" {
  style.fill: "#2a2a1a"
  style.stroke: "#fbbf24"
  style.stroke-width: 3

  problem: {
    label: |md
      ### Hardware Bound: Llama-3-70B
      - Hidden Dimension: 8192
      - Matrix N: 67,108,864
      - Full Matrix: **4.5 PB** (Storage Impossible)
      - Diag Approx: **536 MB** (Fit in VRAM)
    |
    width: 380
  }

  solution: {
    label: |md
      ### OBS Compensation Logic
      1. Rank weights by Diag Hessian $H_{ii}$
      2. Quantize single column $i$
      3. Compute Residual Error: $\epsilon_i$
      4. Compensate neighbors using $\epsilon_i / H_{ii}$
    |
    width: 380
  }

  algo_steps: {
    label: |md
      ### Mathematical Correction
      - $\epsilon_i = \text{quant}(W_i) - W_i$
      - $\Delta W_{>i} = - \epsilon_i \cdot \frac{H_{i, >i}}{H_{ii}}$
    |
    style.fill: "#3a3a2a"
    width: 380
  }
}

comparison: "STORAGE FOOTPRINT (N=1,000,000)" {
  style.fill: "#111"
  style.stroke: "#666"
  style.stroke-dash: 5

  full_scale: {
    label: |md
      ### Dense Hessian (N²)
      - 10¹² Elements
      - **8,000 GB (8 TB)**
    |
    width: 380
    style.fill: "#3d1a1a"
  }

  diag_scale: {
    label: |md
      ### Sparse Diagonal (N)
      - 10⁶ Elements
      - **8 MB**
    |
    width: 380
    style.fill: "#0d3320"
  }
}

# --- CONNECTIONS ---

full_hessian.diagonal_elements -> preserved: "EXTRACT (Row IDs [i,i])" {
  style.stroke: "#4ade80"
  style.stroke-dash: 3
  style.stroke-width: 2
}

full_hessian.offdiag_elements -> lost: "DROP (Row IDs [i,j] where i≠j)" {
  style.stroke: "#f87171"
  style.stroke-dash: 3
  style.stroke-width: 2
}

preserved -> diagonal_approx: "Initialize Sparse Tensor" {
  style.stroke: "#4ade80"
  style.stroke-width: 4
}

lost -> tradeoff: "Heuristic Penalty (Assumption Error)" {
  style.stroke: "#fbbf24"
  style.stroke-dash: 5
  style.stroke-width: 2
}

diagonal_approx -> tradeoff: "Inverse Hessian Scale" {
  style.stroke: "#fbbf24"
  style.stroke-width: 2
}

comparison.full_scale -> comparison.diag_scale: "Compression Factor: 10⁶x" {
  style.stroke: "#4ade80"
  style.stroke-width: 2
  target-arrowhead: triangle
}

# --- FOOTER ---
footer: "Hessian Diagonal Approximation Strategy for Post-Training Quantization (PTQ) Engines" {
  shape: text
  style.font-size: 24
  style.bold: true
  style.font-color: "#4a9eff"
}