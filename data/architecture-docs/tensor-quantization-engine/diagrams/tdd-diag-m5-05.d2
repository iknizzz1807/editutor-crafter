direction: right
layout-engine: elk
title: {
  label: Group Size Concept: Per-Group Quantization for Precision Recovery
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
  style.underline: true
}
# Original weight row (FP16)
original_weights: {
  label: "Original Weight Row (FP16)\n4096 consecutive weights"
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 2
  w1: {
    label: "w₁"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    width: 40
  }
  w2: {
    label: "w₂"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    width: 40
  }
  w3: {
    label: "w₃"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    width: 40
  }
  dots1: {
    label: "···"
    shape: text
  }
  w128: {
    label: "w₁₂₈"
    shape: rectangle
    style.fill: "#90CAF9"
    style.stroke: "#1976D2"
    width: 40
  }
  w129: {
    label: "w₁₂₉"
    shape: rectangle
    style.fill: "#64B5F6"
    style.stroke: "#1976D2"
    width: 40
  }
  dots2: {
    label: "···"
    shape: text
  }
  w4096: {
    label: "w₄₀₉₆"
    shape: rectangle
    style.fill: "#42A5F5"
    style.stroke: "#1976D2"
    width: 40
  }
  w1 -> w2 -> w3 -> dots1 -> w128 -> w129 -> dots2 -> w4096
}
# Division into groups
group_division: {
  label: "Group Division (g = 128)"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#F57C00"
  style.stroke-width: 2
  style.stroke-dash: 4
  group1: {
    label: "Group 1\n(128 weights)"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
    width: 120
  }
  group2: {
    label: "Group 2\n(128 weights)"
    shape: rectangle
    style.fill: "#FFCC80"
    style.stroke: "#F57C00"
    width: 120
  }
  dots: {
    label: "···"
    shape: text
  }
  group32: {
    label: "Group 32\n(128 weights)"
    shape: rectangle
    style.fill: "#FFB74D"
    style.stroke: "#F57C00"
    width: 120
  }
  group1 -> group2 -> dots -> group32
}
# Per-group scales
per_group_scales: {
  label: "Per-Group Scale Factors"
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
  scale1: {
    label: "s₁ = max(|G₁|) / 7\n= 0.0847"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    width: 130
  }
  scale2: {
    label: "s₂ = max(|G₂|) / 7\n= 0.0312"
    shape: rectangle
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
    width: 130
  }
  dots: {
    label: "···"
    shape: text
  }
  scale32: {
    label: "s₃₂ = max(|G₃₂|) / 7\n= 0.0621"
    shape: rectangle
    style.fill: "#81C784"
    style.stroke: "#388E3C"
    width: 130
  }
  scale1 -> scale2 -> dots -> scale32
}
# Quantized output
quantized_output: {
  label: "INT4 Quantized Weights + Scales"
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  qg1: {
    label: "Q₁\nINT4\n[−7, +7]"
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    width: 70
  }
  sg1: {
    label: "s₁"
    shape: circle
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
    width: 40
  }
  qg2: {
    label: "Q₂\nINT4\n[−7, +7]"
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    width: 70
  }
  sg2: {
    label: "s₂"
    shape: circle
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
    width: 40
  }
  dots: {
    label: "···"
    shape: text
  }
  qg32: {
    label: "Q₃₂\nINT4\n[−7, +7]"
    shape: rectangle
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
    width: 70
  }
  sg32: {
    label: "s₃₂"
    shape: circle
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
    width: 40
  }
  qg1 -> sg1 -> qg2 -> sg2 -> dots -> qg32 -> sg32
}
# Connections
original_weights -> group_division: {
  label: "Divide into\ngroups of 128"
  style.stroke: "#1976D2"
  style.stroke-width: 2
}
group_division -> per_group_scales: {
  label: "Compute\nper-group scale"
  style.stroke: "#F57C00"
  style.stroke-width: 2
}
per_group_scales -> quantized_output: {
  label: "Quantize each\ngroup separately"
  style.stroke: "#388E3C"
  style.stroke-width: 2
}
# Comparison panel
comparison: {
  label: "Precision Recovery Comparison"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  style.stroke-width: 2
  # Per-tensor (bad)
  per_tensor: {
    label: "❌ Single Per-Tensor Scale"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2
    pt_explain: {
      label: "One scale for entire row\ns = max(|all weights|) / 7"
      shape: text
    }
    pt_problem: {
      label: "Problem:\nSmall weights lose precision\n→ quantization error accumulates"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }
    pt_explain -> pt_problem
  }
  # Per-group (good)
  per_group: {
    label: "✓ Per-Group Scale (g=128)"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    pg_explain: {
      label: "Scale adapts to local weight range\nsᵢ = max(|group i|) / 7"
      shape: text
    }
    pg_benefit: {
      label: "Benefit:\n32× finer granularity\n→ Precision recovered in each group"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    pg_explain -> pg_benefit
  }
  per_tensor <-> per_group: {
    label: "vs"
    style.stroke: "#424242"
    style.stroke-dash: 3
  }
}
# Example calculation
example_calc: {
  label: "Example: Weight Value Reconstruction"
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  style.stroke-width: 2
  ex_original: {
    label: "Original: w = 0.0312"
    shape: text
    style.font-size: 14
  }
  ex_tensor: {
    label: "Per-Tensor (s=0.0847):\nq = round(0.0312/0.0847) = 0\nŵ = 0 × 0.0847 = 0\nError = 100%"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    width: 200
  }
  ex_group: {
    label: "Per-Group (s=0.0312):\nq = round(0.0312/0.0312) = 1\nŵ = 1 × 0.0312 = 0.0312\nError = 0%"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    width: 200
  }
  ex_original -> ex_tensor -> ex_group
}
# Memory overhead note
memory_note: {
  label: "Memory Overhead: 32 scales × FP16 = 64 bytes per weight row\n(Only 1.56% overhead for 4096 weights)"
  shape: rectangle
  style.fill: "#FFFDE7"
  style.stroke: "#F9A825"
  style.stroke-width: 2
  style.italic: true
}
# Layout connections
quantized_output -> comparison: {
  style.stroke: "#7B1FA2"
  style.stroke-width: 1
  style.stroke-dash: 3
}
comparison -> example_calc: {
  style.stroke: "#424242"
  style.stroke-width: 1
  style.stroke-dash: 3
}
example_calc -> memory_note: {
  style.stroke: "#F9A825"
  style.stroke-width: 1
}