layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: "INT4 Memory Layout: Packing Two Weights Per Byte" {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# 1. PHYSICAL BYTE STRUCTURE (Bit Level)
# Demonstrates how a single 8-bit byte is partitioned into two 4-bit nibbles.
byte_structure: {
  label: "Physical Byte Representation (8-bit)"
  
  bits: {
    grid-columns: 8
    grid-gap: 0
    
    # Upper Nibble (Bits 7-4) - Blue
    b7: "7" { style: { fill: "#E3F2FD"; stroke: "#1976D2"; font-size: 10 } }
    b6: "6" { style: { fill: "#E3F2FD"; stroke: "#1976D2"; font-size: 10 } }
    b5: "5" { style: { fill: "#E3F2FD"; stroke: "#1976D2"; font-size: 10 } }
    b4: "4" { style: { fill: "#E3F2FD"; stroke: "#1976D2"; font-size: 10 } }
    
    # Lower Nibble (Bits 3-0) - Purple
    b3: "3" { style: { fill: "#F3E5F5"; stroke: "#7B1FA2"; font-size: 10 } }
    b2: "2" { style: { fill: "#F3E5F5"; stroke: "#7B1FA2"; font-size: 10 } }
    b1: "1" { style: { fill: "#F3E5F5"; stroke: "#7B1FA2"; font-size: 10 } }
    b0: "0" { style: { fill: "#F3E5F5"; stroke: "#7B1FA2"; font-size: 10 } }
  }

  nibble_labels: {
    grid-columns: 2
    grid-gap: 20
    upper: "Weight[2N+1] (MSB Nibble)" {
      style: { fill: "#E3F2FD"; stroke: "#1976D2"; stroke-dash: 3; bold: true }
    }
    lower: "Weight[2N] (LSB Nibble)" {
      style: { fill: "#F3E5F5"; stroke: "#7B1FA2"; stroke-dash: 3; bold: true }
    }
  }
}

# 2. LOGICAL MAPPING TABLE
# Defines the transformation from Signed Integer domain to Unsigned Nibble domain.
mapping_table: {
  label: "Quantization Mapping: Signed INT4 -> Unsigned Storage"
  content: |'md
| Signed Value (w) | Offset (w+8) | Binary (Unsigned) | Hex |
| :--- | :--- | :--- | :--- |
| **-8** | 0 | `0000` | 0x0 |
| **-1** | 7 | `0111` | 0x7 |
| **0**  | 8 | `1000` | 0x8 |
| **+7** | 15 | `1111` | 0xF |
  '|
  style: {
    fill: "#FAFAFA"
    stroke: "#424242"
    stroke-width: 1
    double-border: true
  }
}

# 3. PACKING ALGORITHM
# Technical implementation detail for engineer reference.
packing_logic: {
  label: "Bitwise Packing Implementation (C/Python)"
  formula: |'python
# w_even: Weight at index 2n
# w_odd:  Weight at index 2n+1
def pack_byte(w_even, w_odd):
    # 1. Zero-point offset (bias +8) to unsigned
    u_even = (w_even + 8) & 0x0F
    u_odd  = (w_odd + 8) & 0x0F
    
    # 2. Left-shift odd index to MSB nibble
    # 3. Logical OR to combine into 8-bit byte
    return (u_odd << 4) | u_even
  '|
  style: {
    fill: "#E1F5FE"
    stroke: "#0288D1"
    stroke-width: 2
  }
}

# 4. MEMORY LAYOUT DIAGRAM
# High-fidelity layout showing offsets and field sizes.
memory_layout: {
  label: "Physical Memory Buffer Layout (Weight Tensor Data)"
  
  # Offsets Left Margin
  offsets: {
    style.stroke-width: 0
    style.fill: transparent
    o0: "0x00"
    o1: "0x01"
    o2: "0x02"
    o3: "0x03"
  }

  # Data Field Blue
  data_bytes: {
    grid-columns: 1
    grid-gap: 2
    b0: "Byte 0 (W1[7:4] : W0[3:0])" { style.fill: "#BBDEFB"; style.stroke: "#1976D2" }
    b1: "Byte 1 (W3[7:4] : W2[3:0])" { style.fill: "#BBDEFB"; style.stroke: "#1976D2" }
    b2: "Byte 2 (W5[7:4] : W4[3:0])" { style.fill: "#BBDEFB"; style.stroke: "#1976D2" }
    b3: "Byte 3 (W7[7:4] : W6[3:0])" { style.fill: "#BBDEFB"; style.stroke: "#1976D2" }
  }

  # Field Sizes Right Margin
  sizes: {
    style.stroke-width: 0
    style.fill: transparent
    s0: "8 bits"
    s1: "8 bits"
    s2: "8 bits"
    s3: "8 bits"
  }

  # Layout associations (Logical mapping, not visual connections)
  offsets.o0 -> data_bytes.b0
  data_bytes.b0 -> sizes.s0
  
  offsets.o1 -> data_bytes.b1
  data_bytes.b1 -> sizes.s1
  
  offsets.o2 -> data_bytes.b2
  data_bytes.b2 -> sizes.s2
  
  offsets.o3 -> data_bytes.b3
  data_bytes.b3 -> sizes.s3
}

# 5. STEP-BY-STEP CALCULATION (Algorithm State)
# Trace of a specific operation to verify logic.
example_trace: {
  label: "Example Execution Trace"
  
  quantize: "1. Apply Offset (Input: W0=3, W1=-5)" {
    detail: |'md
- Weight[0]: 3 + 8 = **11** (`1011` / 0xB)
- Weight[1]: -5 + 8 = **3** (`0011` / 0x3)
    '|
  }
  
  shift_or: "2. Bitwise Assembly" {
    detail: |'md
- Lower (W0): `0x0B`
- Upper (W1): `0x03 << 4` = `0x30`
- Final: `0x30 | 0x0B` = **0x3B**
    '|
  }
  
  result: "Storage Byte: 0x3B" {
    style: {
      fill: "#FFF9C4"
      bold: true
      stroke: "#FBC02D"
      double-border: true
    }
  }

  quantize -> shift_or -> result
}

# Structural Connections
byte_structure.nibble_labels.upper -> example_trace.shift_or: "MSB Mapping" {
  style.stroke-dash: 5
}

packing_logic -> example_trace: "Verification" {
  style.stroke: "#0288D1"
}

# Footer Documentation
implementation_notes: |'md
### Engineering Specifications
- **Format:** INT4 Quantized (Asymmetric with zero-point offset 8).
- **Packing:** 2 elements per uint8 container.
- **Ordering:** Little-endian nibble order (W_even=Low, W_odd=High).
- **Alignment:** 64-byte aligned (Cache Line) for AVX-512/AMX compatibility.
'| {
  near: bottom-center
  style: {
    font-size: 14
    stroke: "#424242"
    fill: "#F5F5F5"
  }
}

# Global Styling
memory_layout.data_bytes.*.style.stroke-width: 2
memory_layout.offsets.*.style.font-color: gray
memory_layout.sizes.*.style.font-color: gray
example_trace.** { style.font: mono }