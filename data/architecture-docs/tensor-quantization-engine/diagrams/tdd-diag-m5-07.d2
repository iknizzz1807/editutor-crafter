vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: "GPTQ vs Naive: Weight Compensation Visualized"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# ========== STYLE DEFINITIONS ==========
classes: {
  error_high: {
    style: {
      fill: "#ff6b6b"
      stroke: "#c92a2a"
      font-color: "#ffffff"
    }
  }
  error_low: {
    style: {
      fill: "#51cf66"
      stroke: "#2f9e44"
      font-color: "#ffffff"
    }
  }
  process: {
    style: {
      fill: "#339af0"
      stroke: "#1971c2"
      font-color: "#ffffff"
      border-radius: 8
    }
  }
  matrix: {
    shape: square
    style: {
      fill: "#e9ecef"
      stroke: "#adb5bd"
      multiple: true
    }
  }
  weight_block: {
    style: {
      fill: "#748ffc"
      stroke: "#4c6ef5"
      font-color: "#ffffff"
    }
  }
  hessian_block: {
    style: {
      fill: "#da77f2"
      stroke: "#be4bdb"
      font-color: "#ffffff"
    }
  }
  compensation_arrow: {
    style: {
      stroke: "#be4bdb"
      stroke-width: 3
      stroke-dash: 3
    }
  }
}

# ========== NAIVE QUANTIZATION PATH (TOP) ==========
naive_container: "Naive INT4 Quantization Pipeline" {
  style: {
    fill: "#ffe3e3"
    stroke: "#fa5252"
    stroke-width: 2
  }
  
  naive_input: "Calibration Activations X" {
    shape: parallelogram
    style: {
      fill: "#fcc419"
      stroke: "#e67700"
    }
  }
  
  naive_fp16_weights: "W_fp16 [4096x4096]" {
    shape: sql_table
    class: matrix
  }
  
  naive_quant: "Round(W / S) * S" {
    shape: diamond
    class: process
  }
  
  naive_int4: "W_int4 (Packed)" {
    shape: cylinder
    style: {
      fill: "#ff922b"
      stroke: "#e8590c"
      font-color: "#ffffff"
    }
  }
  
  naive_dequant: "Dequantize: W_int4 * S" {
    shape: diamond
    class: process
  }
  
  naive_output: "Output Y_naive" {
    shape: parallelogram
    style: {
      fill: "#fcc419"
      stroke: "#e67700"
    }
  }
  
  naive_error: "Quantization Error δ" {
    shape: circle
    class: error_high
  }
  
  naive_propagated: "Output Error ||Y_fp16 - Y_naive||" {
    shape: circle
    class: error_high
    width: 140
  }
  
  naive_input -> naive_fp16_weights: "Forward Pass" {
    style.stroke: "#868e96"
  }
  naive_fp16_weights -> naive_quant
  naive_quant -> naive_int4
  naive_int4 -> naive_dequant
  naive_dequant -> naive_output
  
  naive_quant -> naive_error: {
    style: {
      stroke: "#fa5252"
      stroke-width: 2
    }
  }
  
  naive_error -> naive_propagated: "Error Accumulates" {
    style: {
      stroke: "#fa5252"
      stroke-width: 3
    }
  }
  
  naive_metrics: "MSE: 2.3e-3 | PPL Δ: +15% | Quality: DEGRADED" {
    shape: text
    style: {
      font-color: "#c92a2a"
      italic: true
      bold: true
    }
  }
  
  naive_propagated -> naive_metrics: { style.opacity: 0 }
}

# ========== GPTQ COMPENSATION PATH (BOTTOM) ==========
gptq_container: "GPTQ INT4 Quantization (Hessian-Based Compensation)" {
  style: {
    fill: "#d3f9d8"
    stroke: "#40c057"
    stroke-width: 2
  }
  
  gptq_input: "Calibration Activations X" {
    shape: parallelogram
    style: {
      fill: "#fcc419"
      stroke: "#e67700"
    }
  }
  
  gptq_fp16_weights: "W_fp16 [4096x4096]" {
    shape: sql_table
    class: matrix
  }
  
  # Hessian computation block
  hessian_block: "Hessian Engine" {
    style: {
      fill: "#f3d9fa"
      stroke: "#be4bdb"
    }
    hessian_input: "X^T * X" {
      shape: hexagon
      class: hessian_block
    }
    hessian_inv: "H^-1 (Cholesky)" {
      shape: stored_data
      class: hessian_block
    }
    hessian_input -> hessian_inv: "Invert"
  }
  
  # Column-by-column processing
  column_process: "Column-wise Quantization Loop" {
    style: {
      fill: "#e7f5ff"
      stroke: "#339af0"
    }
    col_j: "Column j" {
      shape: rectangle
      class: weight_block
    }
    quant_col: "quant(W[:,j])" {
      shape: diamond
      class: process
      style.fill: "#4dabf7"
    }
    error_col: "e_j = W[:,j] - Q(W[:,j])" {
      shape: circle
      style: {
        fill: "#ffd43b"
        stroke: "#fab005"
      }
    }
    col_j -> quant_col -> error_col
  }
  
  # Compensation mechanism
  compensation: "Weight Compensation Step" {
    style: {
      fill: "#fff3bf"
      stroke: "#fab005"
    }
    comp_formula: "W[:, j+1:] -= e_j * H^-1[j,j+1:]" {
      shape: code
      language: python
      style.fill: "#fff9db"
    }
    remaining_cols: "Remaining Columns j+1 -> N" {
      shape: square
      class: matrix
      style.fill: "#b197fc"
    }
    comp_formula -> remaining_cols: "Adjust Weights" {
      style: {
        stroke: "#be4bdb"
        stroke-width: 3
        stroke-dash: 3
      }
    }
  }
  
  gptq_int4: "W_int4 (Optimized)" {
    shape: cylinder
    style: {
      fill: "#51cf66"
      stroke: "#2f9e44"
      font-color: "#ffffff"
    }
  }
  
  gptq_output: "Output Y_gptq" {
    shape: parallelogram
    style: {
      fill: "#fcc419"
      stroke: "#e67700"
    }
  }
  
  gptq_error: "Compensated Error" {
    shape: circle
    class: error_low
  }
  
  gptq_propagated: "Output Error ||Y_fp16 - Y_gptq||" {
    shape: circle
    class: error_low
    width: 140
  }
  
  # Flow connections
  gptq_input -> gptq_fp16_weights: "Forward Pass"
  gptq_fp16_weights -> column_process
  gptq_input -> hessian_block: "Compute Hessian H"
  
  column_process -> compensation: "Residual Error e_j" {
    style: {
      stroke: "#fab005"
      stroke-width: 2
    }
  }
  
  hessian_block -> compensation: "H^-1 Pre-computed" {
    class: compensation_arrow
  }
  
  compensation -> gptq_int4
  column_process -> gptq_int4: "Final Quantized Stream"
  gptq_int4 -> gptq_output: "Dequantize & Inference"
  
  column_process -> gptq_error: {
    style.stroke: "#40c057"
  }
  
  compensation -> gptq_error: "Error Absorbed" {
    style: {
      stroke: "#be4bdb"
      stroke-dash: 3
    }
  }
  
  gptq_error -> gptq_propagated: "Error Minimized" {
    style: {
      stroke: "#40c057"
      stroke-width: 3
    }
  }
  
  gptq_metrics: "MSE: 3.6e-5 (64x Improvement) | PPL Δ: +2% | Quality: PRESERVED" {
    shape: text
    style: {
      font-color: "#2f9e44"
      italic: true
      bold: true
    }
  }
  
  gptq_propagated -> gptq_metrics: { style.opacity: 0 }
}

# ========== COMPARISON LOGIC ==========
comparison: "64x MSE Reduction via Hessian-Inverse" {
  shape: text
  style: {
    font-size: 20
    bold: true
    font-color: "#2f9e44"
  }
}

(naive_container.naive_propagated -> comparison -> gptq_container.gptq_propagated)[*]: {
  style: {
    stroke: "#40c057"
    stroke-width: 4
    stroke-dash: 5
  }
}

# ========== FORMULA EXPLANATION ==========
formula_box: "Technical Algorithm Details" {
  near: bottom-center
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    border-radius: 4
  }
  
  algo: |md
  python
  # GPTQ Main Compensation Loop
  # W: Weight matrix, H_inv: Inverse Hessian
  for j in range(num_columns):
      # 1. Quantize column j using standard scale
      w_j = W[:, j]
      q_j = quantize(w_j, bitwidth=4)
      
      # 2. Compute quantization error for this column
      error_j = w_j - dequantize(q_j)
      
      # 3. Use Hessian inverse to update future columns
      # This compensates for error_j in the remaining weights
      W[:, j+1:] -= error_j.outer(H_inv[j, j+1:]) / H_inv[j, j]
  
  | {
    shape: code
  }
  
  insight: "Key Principle: Hessian-based compensation redistributes quantization error from column 'j' into the remaining columns 'j+1...N' such that the total output reconstruction error is mathematically minimized." {
    shape: text
    style: {
      font-color: "#495057"
      italic: true
      bold: true
    }
  }
  
  algo -> insight
}