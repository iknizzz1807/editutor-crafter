direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header_purple: "#6a0dad"
    data_blue: "#007acc"
    free_green: "#28a745"
    padding_gray: "#808080"
    pointer_orange: "#ff8c00"
    error_red: "#dc3545"
  }
}

title: |md
  # GPTQModelQuantizer Pipeline Architecture
  ## Technical Implementation Specification v1.0.4
| {
  near: top-center
  style: {
    font-size: 32
    bold: true
  }
}

# Core System Container
system: {
  label: "Quantization System Runtime"
  style: {
    stroke: "#333333"
    stroke-width: 4
    fill: "#f8f9fa"
  }

  # M1: Quantization Fundamentals
  m1_fundamentals: {
    label: "M1: Quantization Fundamentals\n(Core Math Engine)"
    style.fill: "#f3e5f5"
    
    quantize_dequantize: {
      label: "Quantize-Dequantize (QDQ)"
      shape: class
      style.stroke: "${colors.header_purple}"
      "+scale": "Tensor (FP16/FP32)"
      "+zero_point": "Tensor (INT)"
      "+bit_width": "int (2-16)"
      "+signed": "bool"
      
      "+quantize(x: Tensor)": "Tensor"
      "+dequantize(x_q: Tensor)": "Tensor"
      "+forward(x: Tensor)": "Tensor"
      
      tooltip: "Base class for simulated quantization (FakeQuant)"
    }

    symmetric_quant: {
      label: "Symmetric Quantizer"
      shape: class
      "+scale": "Tensor"
      "+bit_width": "int"
      "+qmin": "int"
      "+qmax": "int"
      
      "+compute_scale(min: float, max: float)": "Tensor"
      "+quantize(x: Tensor)": "Tensor"
      "+dequantize(x_q: Tensor)": "Tensor"
    }

    asymmetric_quant: {
      label: "Asymmetric Quantizer"
      shape: class
      "+scale": "Tensor"
      "+zero_point": "int"
      "+bit_width": "int"
      "+qmin": "int"
      "+qmax": "int"
      
      "+compute_params(min: float, max: float)": "tuple"
      "+quantize(x: Tensor)": "Tensor"
      "+dequantize(x_q: Tensor)": "Tensor"
    }

    bit_width_config: {
      label: "Bit Width Config"
      shape: class
      # Fixed array syntax from [4, 8, 16] to [4; 8; 16]
      "+supported_widths": "[4; 8; 16]"
      "+default_width": "8"
      "+get_qrange(bit_width: int, signed: bool)": "tuple"
      "+validate_config(config: dict)": "bool"
    }

    error_measurement: {
      label: "Error Measurement"
      shape: class
      "+mse(orig: Tensor, quant: Tensor)": "float"
      "+mae(orig: Tensor, quant: Tensor)": "float"
      "+snr(orig: Tensor, quant: Tensor)": "float"
      "+cosine_sim(a: Tensor, b: Tensor)": "float"
    }

    quantize_dequantize -> symmetric_quant: "implements"
    quantize_dequantize -> asymmetric_quant: "implements"
    symmetric_quant -> bit_width_config: "references"
    asymmetric_quant -> bit_width_config: "references"
    quantize_dequantize -> error_measurement: "validated by"
  }

  # M2: Per-Tensor vs Per-Channel
  m2_granularity: {
    label: "M2: Quantization Granularity"
    style.fill: "#e3f2fd"

    per_tensor: {
      label: "Per-Tensor Quantizer"
      shape: class
      "+scale": "Tensor [1]"
      "+zero_point": "Tensor [1]"
      "+compute_params(tensor: Tensor)": "tuple"
      "+quantize(x: Tensor)": "Tensor"
    }

    per_channel: {
      label: "Per-Channel Quantizer"
      shape: class
      "+scale": "Tensor [C, 1, 1, 1]"
      "+zero_point": "Tensor [C, 1, 1, 1]"
      "+axis": "int"
      "+compute_params(tensor: Tensor, axis: int)": "tuple"
    }

    granularity_strategy: {
      label: "Granularity Router"
      shape: diamond
      "+select_strategy(layer_type: str)": "Quantizer"
    }

    weight_analyzer: {
      label: "Weight Distribution Analyzer"
      shape: class
      "+compute_stats(weights: Tensor)": "dict"
      "+detect_outliers(weights: Tensor)": "bool"
    }

    granularity_strategy -> per_tensor: "Low variance"
    granularity_strategy -> per_channel: "High variance / Conv"
    weight_analyzer -> granularity_strategy: "feeds metrics"
  }

  # M3: Calibration Pipeline
  m3_calibration: {
    label: "M3: Calibration Pipeline"
    style.fill: "#e8f5e9"

    calibration_manager: {
      label: "Calibration Manager"
      shape: class
      "+model": "nn.Module"
      "+dataloader": "DataLoader"
      "+register_hooks()": "void"
      "+run_calibration()": "void"
    }

    activation_collector: {
      label: "Activation Collector"
      shape: class
      "+stats_registry": "dict"
      "+hook_fn(m: Module, i: Tensor, o: Tensor)": "void"
    }

    calibration_strategies: {
      minmax: {
        label: "MinMax"
        shape: class
        "+compute_scale(stats: Stats)": "Tensor"
      }
      percentile: {
        label: "Percentile (99.9%)"
        shape: class
        "+percentile": "float"
        "+compute_scale(stats: Stats)": "Tensor"
      }
      entropy: {
        label: "Entropy (KL-Div)"
        shape: class
        "+num_bins": "int"
        "+compute_optimal_threshold()": "float"
      }
    }

    tensor_stats: {
      label: "Tensor Statistics"
      shape: class
      "+min_val": "float"
      "+max_val": "float"
      "+histogram": "Tensor"
    }

    calibration_manager -> activation_collector: "manages"
    activation_collector -> tensor_stats: "populates"
    calibration_manager -> calibration_strategies: "executes"
  }

  # M4: Post-Training Static Quantization
  m4_ptq: {
    label: "M4: Post-Training Static Quantization"
    style.fill: "#fff3e0"

    ptq_pipeline: {
      label: "PTQ Pipeline"
      shape: class
      "+prepare()": "Module"
      "+calibrate()": "void"
      "+convert()": "Module"
    }

    layer_fusion: {
      label: "Layer Fusion Engine"
      conv_bn: {
        label: "Conv-BN Fusion"
        shape: class
        "+fuse(conv: Conv2d, bn: BN)": "Conv2d"
      }
      linear_relu: {
        label: "Linear-ReLU Fusion"
        shape: class
        "+fuse(lin: Linear, relu: ReLU)": "Linear"
      }
    }

    quantized_layers: {
      q_conv2d: { label: "QuantizedConv2d"; shape: class }
      q_linear: { label: "QuantizedLinear"; shape: class }
    }

    ptq_pipeline -> layer_fusion: "optimizes"
    layer_fusion -> quantized_layers: "lowers to"
  }

  # M5: GPTQ Weight Quantization
  m5_gptq: {
    label: "M5: GPTQ Weight Quantization (LLM Optimized)"
    style.fill: "#fce4ec"

    gptq_quantizer: {
      label: "GPTQ Core Quantizer"
      shape: class
      "+bits": "int"
      "+groupsize": "int"
      "+actorder": "bool"
      "+quantize()": "Module"
      "+compute_hessian(layer: Layer, inputs: Tensor)": "Tensor"
    }

    hessian_computer: {
      label: "Hessian Computer"
      shape: class
      "+hessian": "Tensor"
      "+dampening": "float"
      "+accumulate(input: Tensor)": "void"
      "+get_inverse()": "Tensor"
    }

    weight_updater: {
      label: "Weight Updater"
      shape: class
      "+update_weights(layer: Layer, H_inv: Tensor)": "void"
      "+compensate_error(err: Tensor, H_inv: Tensor)": "void"
    }

    gptq_config: {
      label: "GPTQ Configuration"
      shape: class
      "+bits": "int (4)"
      "+groupsize": "int (128)"
      "+damp_percent": "float (0.01)"
    }

    gptq_quantizer -> hessian_computer: "requires"
    hessian_computer -> weight_updater: "provides inverse"
    gptq_quantizer -> gptq_config: "configured by"
  }

  # Connections between Modules
  m1_fundamentals -> m2_granularity: "defines logic"
  m2_granularity -> m3_calibration: "instantiated in"
  m3_calibration -> m4_ptq: "provides parameters"
  m4_ptq -> m5_gptq: "fallback for activations"
}

# IO Nodes
inputs: {
  label: "Inputs: FP32 Model + Dataset"
  shape: parallelogram
  style.fill: "#e1f5fe"
}

outputs: {
  label: "Outputs"
  shape: parallelogram
  quantized_model: {
    label: "INT4/INT8 Weights"
    shape: cylinder
    style.fill: "${colors.data_blue}"
  }
  metrics: {
    label: "Quantization Report"
    shape: document
  }
}

inputs -> system.m3_calibration: "calibration samples"
inputs -> system.m4_ptq: "FP32 weights"
system.m5_gptq -> outputs.quantized_model: "serialized model"
system.m1_fundamentals -> outputs.metrics: "error logs"

# Legend
legend: {
  near: bottom-right
  label: "Manual Reference"
  l1: "Purple = Core Interfaces"
  l2: "Blue = Weights/Data"
  l3: "Green = Success State"
  l1.style.font-color: "${colors.header_purple}"
  l2.style.font-color: "${colors.data_blue}"
  l3.style.font-color: "${colors.free_green}"
}