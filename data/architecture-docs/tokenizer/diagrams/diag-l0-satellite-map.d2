direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Tokenizer Pipeline — Satellite Map (L0)
  Raw source → structured token stream across 4 milestones
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_node: "Source Input" {
    shape: parallelogram
    label: "source: str\n(raw text)"
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
    style.font-color: "#1e3a5f"
    style.bold: true
  }
  scanner_core: "Scanner (scanner.py)" {
    direction: down
    style.fill: "#f0fdf4"
    style.stroke: "#16a34a"
    style.stroke-width: 3
    style.shadow: true
    scanner_class: {
      shape: class
      label: "Scanner (scanner.py)"
      style.fill: "#dcfce7"
      -source: "str"
      -start: "int"
      -current: "int"
      -line: "int"
      -column: "int"
      -token_start_line: "int"
      -token_start_column: "int"
      -tokens: "list[Token]"
      +scan_tokens(): "list[Token]"
      +advance(): "str"
      +peek(): "str"
      -_match(expected): "bool"
      -_peek_next(): "str"
      -_begin_token(): "void"
      -_make_token(type): "Token"
      -_scan_token(): "void"
      -_scan_number(): "void"
      -_scan_identifier(): "void"
      -_scan_string(): "void"
      -_scan_line_comment(): "void"
      -_scan_block_comment(): "void"
    }
    token_struct: {
      shape: sql_table
      label: "Token (dataclass)"
      style.fill: "#dcfce7"
      f0: "type      | TokenType | category"
      f1: "lexeme    | str       | raw source text"
      f2: "line      | int       | 1-based line"
      f3: "column    | int       | 1-based column"
    }
    token_enum: {
      shape: sql_table
      label: "TokenType (enum) — 26 variants"
      style.fill: "#dcfce7"
      r0: "LITERALS  | NUMBER, STRING"
      r1: "NAMES     | IDENTIFIER, KEYWORD"
      r2: "OPERATORS | PLUS, MINUS, STAR, SLASH, ASSIGN"
      r3: "COMPARE   | EQUAL_EQUAL, BANG_EQUAL, LESS, LESS_EQUAL"
      r4: "COMPARE2  | GREATER, GREATER_EQUAL"
      r5: "PUNCT     | LPAREN, RPAREN, LBRACE, RBRACE"
      r6: "PUNCT2    | LBRACKET, RBRACKET, SEMICOLON, COMMA"
      r7: "SENTINEL  | EOF, ERROR"
    }
    scanner_class -> token_struct: "creates"
    scanner_class -> token_enum: "uses"
  }
  output_node: "Token Stream Output" {
    shape: parallelogram
    label: "list[Token]\n→ Parser"
    style.fill: "#fef3c7"
    style.stroke: "#d97706"
    style.font-color: "#78350f"
    style.bold: true
  }
  input_node -> scanner_core: "str | feed"
  scanner_core -> output_node: "list[Token] | emit"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m1: "M1 — Token Types & Scanner Foundation" {
    direction: down
    style.fill: "#eff6ff"
    style.stroke: "#3b82f6"
    style.stroke-width: 2
    m1_label: {
      shape: sql_table
      label: "M1: Foundation"
      style.fill: "#dbeafe"
      a0: "Deliverable | TokenType enum (26 variants)"
      a1: "Deliverable | Token @dataclass"
      a2: "Deliverable | Scanner.__init__ + state fields"
      a3: "Deliverable | advance() — consume + track pos"
      a4: "Deliverable | peek() — lookahead, no consume"
      a5: "Deliverable | scan_tokens() main loop"
      a6: "Deliverable | Single-char tokens + whitespace skip"
      a7: "Deliverable | ERROR token for unknown chars"
      a8: "Input       | raw source str"
      a9: "Output      | +, -, *, /, (, ), {, }, [, ], ;, ,"
    }
  }
  m2: "M2 — Multi-Char Tokens & Maximal Munch" {
    direction: down
    style.fill: "#faf5ff"
    style.stroke: "#7c3aed"
    style.stroke-width: 2
    m2_label: {
      shape: sql_table
      label: "M2: Maximal Munch"
      style.fill: "#ede9fe"
      b0: "Deliverable | _match(expected) conditional consume"
      b1: "Deliverable | _peek_next() 2-char lookahead"
      b2: "Deliverable | == != <= >= two-char operators"
      b3: "Deliverable | _scan_number() integer + float"
      b4: "Deliverable | _scan_identifier() + KEYWORDS dict"
      b5: "Deliverable | Keyword lookup: if else while return"
      b6: "Key Rule    | Always prefer longest valid token"
      b7: "Input       | =, !, <, >, digits, letters, _"
      b8: "Output      | EQUAL_EQUAL, NUMBER, IDENTIFIER, KEYWORD"
    }
  }
  m3: "M3 — Strings & Comments" {
    direction: down
    style.fill: "#fff7ed"
    style.stroke: "#ea580c"
    style.stroke-width: 2
    m3_label: {
      shape: sql_table
      label: "M3: Strings and Comments"
      style.fill: "#ffedd5"
      c0: "Deliverable | _scan_string() with escape handling"
      c1: "Deliverable | _scan_line_comment() via //"
      c2: "Deliverable | _scan_block_comment() via /* */"
      c3: "Escape seqs | \\n \\t \\r \\\" \\\\"
      c4: "Error cases | unterminated string, block comment"
      c5: "Modes       | NORMAL, IN_STRING, IN_LINE_CMT, IN_BLOCK_CMT"
      c6: "Key Rule    | // inside string is NOT a comment"
      c7: "Input       | \", /, /* sequences"
      c8: "Output      | STRING, SLASH, or no token (comments)"
    }
  }
  m4: "M4 — Integration Testing & Error Recovery" {
    direction: down
    style.fill: "#f0fdf4"
    style.stroke: "#16a34a"
    style.stroke-width: 2
    m4_label: {
      shape: sql_table
      label: "M4: Integration and Error Recovery"
      style.fill: "#dcfce7"
      d0: "Deliverable | Canonical token stream assertion tests"
      d1: "Deliverable | Multi-line position accuracy tests"
      d2: "Deliverable | Error recovery: collect all errors"
      d3: "Deliverable | Edge cases: empty, long, Windows CRLF"
      d4: "Deliverable | Performance: 10k lines under 1 second"
      d5: "Strategy    | Emit ERROR token, continue scanning"
      d6: "Contract    | scan_tokens() always ends with EOF"
      d7: "Input       | Complete programs with mixed errors"
      d8: "Output      | Verified list[Token] spec"
    }
  }
}
row0 -> row1: "milestones build on Scanner core"
row1.m1 -> row1.m2: "adds to Scanner"
row1.m2 -> row1.m3: "extends _scan_token"
row1.m3 -> row1.m4: "full system verified"
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formal_rl: "Regular Language" {
    shape: hexagon
    style.fill: "#fce7f3"
    style.stroke: "#db2777"
    style.font-color: "#831843"
    style.bold: true
    label: "Regular Language\n─────────────────\nAll token patterns are regular.\nNo recursion needed.\nFinite automata suffice.\nBoundary: nesting needs parser."
  }
  formal_fsm: "Finite State Machine" {
    shape: hexagon
    style.fill: "#e0f2fe"
    style.stroke: "#0284c7"
    style.font-color: "#0c4a6e"
    style.bold: true
    label: "FSM (DFA)\n─────────────────\nStates: NORMAL, IN_STRING,\n  IN_LINE_CMT, IN_BLOCK_CMT\nTransitions: per character class\nAccept: token emitted"
  }
  formal_mm: "Maximal Munch" {
    shape: hexagon
    style.fill: "#fefce8"
    style.stroke: "#ca8a04"
    style.font-color: "#713f12"
    style.bold: true
    label: "Maximal Munch\n─────────────────\nAlways prefer longest token.\n>== → GREATER_EQUAL + ASSIGN\n=== → EQUAL_EQUAL + ASSIGN\nEnabled by: peek() lookahead"
  }
}
row1 -> row2: "governed by"
row2.formal_fsm -> row0.scanner_core: "implements"
row2.formal_mm -> row1.m2: "principle"
row2.formal_rl -> row0.output_node: "guarantees O(n)"
legend: {
  near: bottom-right
  shape: sql_table
  label: "Legend"
  style.fill: "#f8fafc"
  l0: "Green border  | Scanner core component"
  l1: "Blue border   | M1 Foundation"
  l2: "Purple border | M2 Maximal Munch"
  l3: "Orange border | M3 Strings and Comments"
  l4: "Hexagon       | Formal concept anchor"
  l5: "Parallelogram | Data flow boundary"
}