advance_impl: "advance() — the ONLY place line/column update (scanner.py)" {
  style.fill: "#212121"
  style.font-color: "#B0BEC5"
  style.border-radius: 4
  code: |'python
    def advance(self) -> str:
        ch = self.source[self.current]
        self.current += 1
        if ch == '\n':
            self.line   += 1   # ← newline: bump line
            self.column  = 1   # ← newline: RESET column to 1
        else:
            self.column += 1   # ← any other char: bump column only
        return ch
  '|
  width: 540
}
tab_note: "Tab ('\\t') rule" {
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.border-radius: 4
  body: |md
    `\t` hits the **else** branch — treated identically to any
    non-newline character: `column += 1`.
    **'\t' does NOT advance by tab-stop width (4 or 8).**
    Column advances by exactly **1**.
    Input: `x\tb`
    - step 1: consume `x` → col 2
    - step 2: consume `\t` → col **3**  (not 5 or 9)
    - step 3: consume `b` → col **4**
    Token `b` is reported at column **3**, not column 5.
  |
  width: 460
}
pitfall_note: "Common Pitfall: forgetting column reset on newline" {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.border-radius: 4
  body: |md
    **WRONG** — bypassing `advance()`:
    python
    self.current += 1   # skips line/column tracking!
    
    After `\n` on line 1 col 5, column stays at 6 instead of
    resetting to 1.  Every token on line 2 gets a wrong column.
    Drift compounds — line 50 tokens show col ~250 instead of ~1.
    **CORRECT** — always call `advance()` to consume characters.
    Position tracking is centralised: one function, one truth.
  |
  width: 460
}
token_summary: "Resulting tokens (snapshot positions use token_start_* fields)" {
  shape: sql_table
  label: "Token | line | column | note"
  t1: "IDENTIFIER 'a' | 1 | 1 | _begin_token() before 'a' consumed"
  t2: "IDENTIFIER 'b' | 2 | 3 | _begin_token() after 2 spaces consumed"
  t3: "IDENTIFIER 'c' | 3 | 1 | _begin_token() at start of line 3"
  note: "Token position = position of FIRST character (snapshotted at _begin_token)"
}
bottom_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tab_note
  pitfall_note
}
title_box -> header_row: "" { style.stroke: transparent }
header_row -> row_init: "" { style.stroke: transparent }
row_init -> row1: "" { style.stroke: transparent }
row1 -> row2: "" { style.stroke: transparent }
row2 -> row3: "newline consumed" {
  style.stroke: "#FF8F00"
  style.stroke-width: 2
  style.bold: true
}
row3 -> row4: "" { style.stroke: transparent }
row4 -> row5: "" { style.stroke: transparent }
row5 -> row6: "" { style.stroke: transparent }
row6 -> row7: "newline consumed" {
  style.stroke: "#FF8F00"
  style.stroke-width: 2
  style.bold: true
}
row7 -> advance_impl: "all transitions go through here" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.bold: true
}
advance_impl -> token_summary: "token_start_* captured before first char" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
token_summary -> bottom_row: "" { style.stroke: transparent }