direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Token Type Enumeration & Data Structure Layout (scanner.py)" {
  shape: rectangle
  style: {
    font-size: 20
    bold: true
    fill: "#1e293b"
    font-color: "#f8fafc"
    stroke: "#1e293b"
    border-radius: 4
  }
}
title -> row_top: "" {
  style.opacity: 0
}
row_top: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  token_type_enum: {
    label: "TokenType (enum.Enum) — scanner.py"
    shape: sql_table
    style.fill: "#1e3a5f"
    style.font-color: "#e2e8f0"
    cat_lit: "── LITERALS ───────────────────────────"
    number_row: "NUMBER      = auto()   # 42, 3.14, 0"
    string_row: "STRING      = auto()   # \"hello world\""
    cat_name: "── NAMES ──────────────────────────────"
    ident_row: "IDENTIFIER  = auto()   # x, my_var, _count"
    kw_row:    "KEYWORD     = auto()   # if, else, while, return, true, false, null"
    cat_arith: "── ARITHMETIC OPS ─────────────────────"
    plus_row:  "PLUS        = auto()   # +"
    minus_row: "MINUS       = auto()   # -"
    star_row:  "STAR        = auto()   # *"
    slash_row: "SLASH       = auto()   # /"
    cat_cmp: "── COMPARISON OPS ─────────────────────"
    assign_row:  "ASSIGN        = auto()   # ="
    eqeq_row:   "EQUAL_EQUAL   = auto()   # =="
    bangeq_row: "BANG_EQUAL    = auto()   # !="
    lt_row:     "LESS          = auto()   # <"
    lte_row:    "LESS_EQUAL    = auto()   # <="
    gt_row:     "GREATER       = auto()   # >"
    gte_row:    "GREATER_EQUAL = auto()   # >="
    cat_punct: "── PUNCTUATION ────────────────────────"
    lp_row:  "LPAREN    = auto()   # ("
    rp_row:  "RPAREN    = auto()   # )"
    lb_row:  "LBRACE    = auto()   # {"
    rb_row:  "RBRACE    = auto()   # }"
    lbk_row: "LBRACKET  = auto()   # ["
    rbk_row: "RBRACKET  = auto()   # ]"
    semi_row: "SEMICOLON = auto()   # ;"
    com_row:  "COMMA     = auto()   # ,"
    cat_sent: "── SENTINELS ──────────────────────────"
    eof_row:   "EOF   = auto()   # end of input — parser terminator"
    error_row: "ERROR = auto()   # unrecognized char — recoverable"
  }
  token_struct: {
    label: "@dataclass Token — scanner.py"
    shape: sql_table
    style.fill: "#1a3a2a"
    style.font-color: "#e2e8f0"
    f_type:   "type   | TokenType | category (enum variant above)"
    f_lexeme: "lexeme | str       | raw source text — NOT interpreted value"
    f_line:   "line   | int       | source line (1-based)"
    f_col:    "column | int       | source column (1-based, first char of token)"
    note_sz:  "repr: Token(KEYWORD, 'if', 1:1)"
    design1: "KEY DESIGN: lexeme of NUMBER('42') is the string '42'"
    design2: "   value conversion (int/float) is a LATER stage's job"
    design3: "KEY DESIGN: ERROR tokens carry position of bad char"
    design4: "   scanning continues — all errors collected, not halted"
  }
}
row_top -> row_example: "source str | scan_tokens()"
row_example: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  source_box: {
    label: "Source Text — if (x >= 42)"
    shape: rectangle
    style.fill: "#312e2e"
    style.font-color: "#f1f5f9"
    style.border-radius: 6
    chars: |'md
      Byte offsets (0-indexed):
      
      0123456789...
      if (x >= 42)
      ^  ^ ^  ^  ^
      │  │ │  │  └─ col 12  ')'
      │  │ │  └──── col 9   '4'
      │  │ └─────── col 7   '>'
      │  └───────── col 4   'x'
      └─────────────col 1   'i'
      
      Scanner reads L→R, one char at a time.
      advance() consumes + updates line/column.
      peek() inspects without consuming.
    '|
  }
  stream_table: {
    label: "Token Stream — scan_tokens() output"
    shape: sql_table
    style.fill: "#1e2640"
    style.font-color: "#e2e8f0"
    hdr: "# | type          | lexeme | line | col | note"
    t0: "0 | KEYWORD       | 'if'   |  1   |  1  | keyword table lookup: 'if' → KEYWORD"
    t1: "1 | LPAREN        | '('    |  1   |  4  | single-char dispatch"
    t2: "2 | IDENTIFIER    | 'x'    |  1   |  5  | not in keyword table → IDENTIFIER"
    t3: "3 | GREATER_EQUAL | '>='   |  1   |  7  | maximal munch: '>' peek '=' → GTE"
    t4: "4 | NUMBER        | '42'   |  1   | 10  | lexeme='42' (str) NOT value=42 (int)"
    t5: "5 | RPAREN        | ')'    |  1   | 12  | single-char dispatch"
    t6: "6 | EOF           | ''     |  1   | 13  | sentinel — parser terminator"
  }
}
row_example -> row_anatomy: "Token[4] | annotated"
row_anatomy: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  token_anatomy: {
    label: "Anatomy of Token[4] — NUMBER '42'"
    shape: sql_table
    style.fill: "#2d1f3d"
    style.font-color: "#e2e8f0"
    style.stroke: "#7c3aed"
    a0: "field  | value    | meaning"
    a1: "type   | NUMBER   | category: this is a numeric literal"
    a2: "lexeme | '42'     | RAW source text — two chars '4','2'"
    a3: "line   | 1        | snapshotted at _begin_token() call"
    a4: "column | 10       | position of '4', NOT of '2' (first char)"
    a5: "─────────────────────────────────────────────────────────"
    a6: "int('42') happens LATER in the eval/parse stage"
    a7: "float('3.14') — same rule — scanner stores raw lexeme only"
  }
  keyword_anatomy: {
    label: "Anatomy of Token[0] — KEYWORD 'if'"
    shape: sql_table
    style.fill: "#1f3020"
    style.font-color: "#e2e8f0"
    style.stroke: "#16a34a"
    b0: "field  | value   | meaning"
    b1: "type   | KEYWORD | found in KEYWORDS dict after full word scan"
    b2: "lexeme | 'if'    | exact source text"
    b3: "line   | 1       | first char 'i' position"
    b4: "column | 1       | column of 'i'"
    b5: "─────────────────────────────────────────────────────────"
    b6: "WHY NOT prefix-match? 'iffy' → scan ALL chars → 'iffy'"
    b7: "  KEYWORDS.get('iffy', IDENTIFIER) → IDENTIFIER (correct)"
    b8: "  KEYWORDS.get('if',   IDENTIFIER) → KEYWORD   (correct)"
  }
  eof_anatomy: {
    label: "Anatomy of Token[6] — EOF sentinel"
    shape: sql_table
    style.fill: "#3a1f1f"
    style.font-color: "#e2e8f0"
    style.stroke: "#dc2626"
    c0: "field  | value | meaning"
    c1: "type   | EOF   | end-of-stream sentinel"
    c2: "lexeme | ''    | no source text"
    c3: "line   | 1     | position after last char consumed"
    c4: "column | 13    | one past the ')'"
    c5: "────────────────────────────────────────────────"
    c6: "Parser calls advance() until it sees EOF — then stops."
    c7: "Without EOF: parser hangs or reads past end of list."
    c8: "Same pattern as: TCP FIN, Unix pipe close, HTTP Content-Length"
  }
}
row_anatomy -> row_error: "ERROR path | illustrate"
row_error: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  error_example: {
    label: "ERROR Recovery — source: 'x@y#z'"
    shape: sql_table
    style.fill: "#3a1a0a"
    style.font-color: "#fde8d8"
    style.stroke: "#ea580c"
    e0: "# | type       | lexeme | line | col | action"
    e1: "0 | IDENTIFIER | 'x'    |  1   |  1  | normal scan"
    e2: "1 | ERROR      | '@'    |  1   |  2  | unrecognized → emit ERROR, continue"
    e3: "2 | IDENTIFIER | 'y'    |  1   |  3  | recovery: scanner resumes"
    e4: "3 | ERROR      | '#'    |  1   |  4  | second error collected"
    e5: "4 | IDENTIFIER | 'z'    |  1   |  5  | valid token after two errors"
    e6: "5 | EOF        | ''     |  1   |  6  | stream terminates normally"
    e7: "ALL errors collected — not stop-at-first. O(1) recovery cost."
  }
  positions_note: {
    label: "Position Tracking Rules (advance.py invariant)"
    shape: sql_table
    style.fill: "#0f1f3a"
    style.font-color: "#bfdbfe"
    style.stroke: "#3b82f6"
    p0: "rule                  | detail"
    p1: "line starts at 1      | 1-based, per POSIX convention"
    p2: "column starts at 1    | 1-based"
    p3: "newline (0x0A)        | line += 1, column = 1"
    p4: "carriage return (0x0D)| column += 1, NOT line (avoids CRLF double-count)"
    p5: "tab (0x09)            | column += 1 (not tab-stop width)"
    p6: "snapshot at _begin_token() | token.line/col = first char, not last"
    p7: "ALL updates inside advance() ONLY — single source of truth"
    p8: "peek() never changes line/col — inspect only, no side effects"
  }
}