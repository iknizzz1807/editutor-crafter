direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: "Extended FSM: Two-Character Operator Scanning" {
  near: top-center
  style: {
    font-size: 20
    bold: true
    stroke: transparent
    fill: transparent
  }
}
legend: "Color Key" {
  near: bottom-right
  style: {
    fill: "#f0f0f0"
    stroke: "#888888"
    border-radius: 6
    font-size: 12
  }
  k1: "Green border = accepting / emit state"
  k2: "Blue = START (initial state)"
  k3: "Orange = intermediate 'SEEN' states"
  k4: "Dashed arrow = non-consuming branch (char re-processed)"
}
START: "START" {
  shape: circle
  style: {
    fill: "#C7E9FF"
    stroke: "#1565C0"
    stroke-width: 3
    bold: true
    font-size: 16
  }
}
row_seen: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  SEEN_EQUALS: "SEEN_EQUALS" {
    shape: circle
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      stroke-width: 2
      bold: true
    }
  }
  SEEN_LESS: "SEEN_LESS" {
    shape: circle
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      stroke-width: 2
      bold: true
    }
  }
  SEEN_GREATER: "SEEN_GREATER" {
    shape: circle
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      stroke-width: 2
      bold: true
    }
  }
  SEEN_BANG: "SEEN_BANG" {
    shape: circle
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
      stroke-width: 2
      bold: true
    }
  }
}
row_emit: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  EMIT_EQ: "emit EQUAL_EQUAL" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_ASSIGN: "emit ASSIGN" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_LE: "emit LESS_EQUAL" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_LT: "emit LESS" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_GE: "emit GREATER_EQUAL" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_GT: "emit GREATER" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_NE: "emit BANG_EQUAL" {
    shape: oval
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
  EMIT_ERR: "emit ERROR" {
    shape: oval
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      stroke-width: 2
      bold: true
      font-size: 12
    }
  }
}
note_nonconsuming: "NON-CONSUMING BRANCH" {
  shape: callout
  style: {
    fill: "#FFF9C4"
    stroke: "#F9A825"
    stroke-width: 2
    font-size: 12
    italic: true
  }
  detail: "peek() inspects without advance()."
  detail2: "Current char is NOT consumed."
  detail3: "Re-processed at START next iteration."
}
START -> row_seen.SEEN_EQUALS: "read '=' (advance)" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
START -> row_seen.SEEN_LESS: "read '<' (advance)" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
START -> row_seen.SEEN_GREATER: "read '>' (advance)" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
START -> row_seen.SEEN_BANG: "read '!' (advance)" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
row_seen.SEEN_EQUALS -> row_emit.EMIT_EQ: "peek '=' → advance()" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
row_seen.SEEN_EQUALS -> row_emit.EMIT_ASSIGN: "peek other → NO advance" {
  style.stroke-dash: 5
  style.stroke: "#E65100"
  style.stroke-width: 2
}
row_seen.SEEN_LESS -> row_emit.EMIT_LE: "peek '=' → advance()" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
row_seen.SEEN_LESS -> row_emit.EMIT_LT: "peek other → NO advance" {
  style.stroke-dash: 5
  style.stroke: "#E65100"
  style.stroke-width: 2
}
row_seen.SEEN_GREATER -> row_emit.EMIT_GE: "peek '=' → advance()" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
row_seen.SEEN_GREATER -> row_emit.EMIT_GT: "peek other → NO advance" {
  style.stroke-dash: 5
  style.stroke: "#E65100"
  style.stroke-width: 2
}
row_seen.SEEN_BANG -> row_emit.EMIT_NE: "peek '=' → advance()" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
row_seen.SEEN_BANG -> row_emit.EMIT_ERR: "peek other → NO advance" {
  style.stroke-dash: 5
  style.stroke: "#B71C1C"
  style.stroke-width: 2
}
row_emit.EMIT_EQ -> START: "→ START" {
  style.stroke: "#888888"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_ASSIGN -> START: "→ START (re-process)" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_LE -> START: "→ START" {
  style.stroke: "#888888"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_LT -> START: "→ START (re-process)" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_GE -> START: "→ START" {
  style.stroke: "#888888"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_GT -> START: "→ START (re-process)" {
  style.stroke: "#E65100"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_NE -> START: "→ START" {
  style.stroke: "#888888"
  style.stroke-dash: 3
  style.font-size: 11
}
row_emit.EMIT_ERR -> START: "→ START (re-process)" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 3
  style.font-size: 11
}
example: "Trace: '>=='" {
  style: {
    fill: "#EDE7F6"
    stroke: "#4527A0"
    border-radius: 8
    font-size: 13
    bold: true
  }
  s1: "1. START: read '>' → SEEN_GREATER"
  s2: "2. SEEN_GREATER: peek '=' → advance → emit GREATER_EQUAL → START"
  s3: "3. START: read '=' → SEEN_EQUALS"
  s4: "4. SEEN_EQUALS: peek EOF → NO advance → emit ASSIGN → START"
  s5: "Result: [GREATER_EQUAL, ASSIGN]  (maximal munch applied)"
}