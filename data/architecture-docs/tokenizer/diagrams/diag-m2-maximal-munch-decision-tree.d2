direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title_box: "Maximal Munch Decision Tree (scanner.py)" {
  style.font-size: 18
  style.bold: true
  style.fill: "#E8EEF7"
  style.stroke: "#3A5BA0"
  style.border-radius: 6
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tree_eq: "TREE A: Input char '='" {
    direction: down
    style.fill: "#F0F4FF"
    style.stroke: "#4A6BBF"
    style.border-radius: 6
    entry_eq: "advance() consumed '='" {
      shape: rectangle
      style.fill: "#C7D4F0"
      style.stroke: "#3A5BA0"
      style.bold: true
    }
    decision_eq: "peek() == '='?" {
      shape: diamond
      style.fill: "#FFF9C2"
      style.stroke: "#B8960C"
      style.bold: true
    }
    yes_eq: "advance() — consume second '='" {
      shape: rectangle
      style.fill: "#C8F0C8"
      style.stroke: "#2E7D32"
    }
    emit_eq_eq: "emit EQUAL_EQUAL\nlexeme: '=='" {
      shape: rectangle
      style.fill: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
    no_eq: "peek stays — do NOT consume" {
      shape: rectangle
      style.fill: "#F0E0C8"
      style.stroke: "#8B4513"
    }
    emit_assign: "emit ASSIGN\nlexeme: '='" {
      shape: rectangle
      style.fill: "#8B4513"
      style.font-color: white
      style.bold: true
    }
    entry_eq -> decision_eq
    decision_eq -> yes_eq: "YES"
    yes_eq -> emit_eq_eq
    decision_eq -> no_eq: "NO"
    no_eq -> emit_assign
  }
  tree_lt: "TREE B: Input char '<'" {
    direction: down
    style.fill: "#F0F4FF"
    style.stroke: "#4A6BBF"
    style.border-radius: 6
    entry_lt: "advance() consumed '<'" {
      shape: rectangle
      style.fill: "#C7D4F0"
      style.stroke: "#3A5BA0"
      style.bold: true
    }
    decision_lt: "peek() == '='?" {
      shape: diamond
      style.fill: "#FFF9C2"
      style.stroke: "#B8960C"
      style.bold: true
    }
    yes_lt: "advance() — consume '='" {
      shape: rectangle
      style.fill: "#C8F0C8"
      style.stroke: "#2E7D32"
    }
    emit_leq: "emit LESS_EQUAL\nlexeme: '<='" {
      shape: rectangle
      style.fill: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
    no_lt: "peek stays — do NOT consume" {
      shape: rectangle
      style.fill: "#F0E0C8"
      style.stroke: "#8B4513"
    }
    emit_less: "emit LESS\nlexeme: '<'" {
      shape: rectangle
      style.fill: "#8B4513"
      style.font-color: white
      style.bold: true
    }
    entry_lt -> decision_lt
    decision_lt -> yes_lt: "YES"
    yes_lt -> emit_leq
    decision_lt -> no_lt: "NO"
    no_lt -> emit_less
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  invariant: "INVARIANT: Maximal Munch (scanner.py:_scan_token)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.border-radius: 6
    rule1: {
      shape: sql_table
      label: "Maximal Munch Rules"
      r1: "Rule 1 | Always consume the longest possible valid token"
      r2: "Rule 2 | Never emit a shorter token when a longer one is possible"
      r3: "Rule 3 | Lookahead via peek() — inspect without consuming"
      r4: "Rule 4 | Consume second char via advance() ONLY if it extends the token"
      r5: "Rule 5 | Two-char checks MUST precede single-char fallback table"
    }
  }
  failure: "FAILURE CASE: No Lookahead (WRONG)" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.border-radius: 6
    failure_input: "Input: '=='" {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      style.bold: true
    }
    failure_step1: "Iteration 1: advance() sees '='" {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }
    failure_emit1: "emit ASSIGN ('=')" {
      shape: rectangle
      style.fill: "#C62828"
      style.font-color: white
      style.bold: true
    }
    failure_step2: "Iteration 2: advance() sees '='" {
      shape: rectangle
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }
    failure_emit2: "emit ASSIGN ('=')" {
      shape: rectangle
      style.fill: "#C62828"
      style.font-color: white
      style.bold: true
    }
    failure_result: {
      shape: sql_table
      label: "WRONG Result: Two ASSIGN tokens"
      r1: "Got    | ASSIGN + ASSIGN"
      r2: "Wanted | EQUAL_EQUAL"
      r3: "Effect | Parser sees 'x = = 42' — syntax error"
    }
    failure_input -> failure_step1
    failure_step1 -> failure_emit1
    failure_emit1 -> failure_step2
    failure_step2 -> failure_emit2
    failure_emit2 -> failure_result
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  impl: "Implementation: _match() Helper (scanner.py)" {
    direction: down
    style.fill: "#EDE7F6"
    style.stroke: "#4527A0"
    style.border-radius: 6
    match_sig: {
      shape: class
      label: "Scanner._match()"
      +_match(expected): "bool"
      +advance(): "str"
      +peek(): "str"
      +is_at_end(): "bool"
    }
    match_contract: {
      shape: sql_table
      label: "_match(expected: str) -> bool contract"
      r1: "if is_at_end()          | return False — nothing to consume"
      r2: "if source[current] != x | return False — no consume"
      r3: "else                    | call advance(), return True"
      r4: "advance() updates       | line, column, current atomically"
      r5: "DO NOT                  | use current += 1 directly (breaks tracking)"
    }
    dispatch: {
      shape: sql_table
      label: "_scan_token() dispatch order (correctness-critical)"
      r1: "1st | Two-char operators  | '=', '!', '<', '>'  via _match()"
      r2: "2nd | Division / comments | '/'                 via _match()"
      r3: "3rd | String literals     | '\"'                via _scan_string()"
      r4: "4th | Single-char table   | SINGLE_CHAR_TOKENS  dict lookup"
      r5: "5th | Numbers             | isdigit()           via _scan_number()"
      r6: "6th | Identifiers         | isalpha() or _      via _scan_identifier()"
      r7: "7th | Fallthrough         | ERROR token         + continue scanning"
    }
  }
}
title_box -> row1: "" {
  style.stroke-dash: 4
  style.stroke: "#3A5BA0"
}
row1 -> row2
row2 -> row3
row1.tree_eq.emit_eq_eq -> row2.invariant: "correct path" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}
row1.tree_eq.emit_assign -> row2.failure: "without lookahead" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
row2.invariant -> row3.impl: "enforced by"
row2.failure -> row3.impl: "prevented by"