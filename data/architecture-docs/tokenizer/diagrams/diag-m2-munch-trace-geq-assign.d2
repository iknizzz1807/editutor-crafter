direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Trace: Tokenizing '>=='' with Maximal Munch"
  shape: rectangle
  style: {
    font-size: 20
    bold: true
    fill: "#E8F4FD"
    stroke: "#2980B9"
    border-radius: 6
  }
}
input_display: {
  label: "Input Buffer (scanner.py)"
  style: {
    fill: "#F0F0F0"
    stroke: "#888888"
    border-radius: 4
  }
  buf: {
    shape: sql_table
    label: "source: str  (len=3)"
    idx0: "index 0 | char '>' | CURRENT start"
    idx1: "index 1 | char '=' | peek() target"
    idx2: "index 2 | char '=' | peek_next() target"
    idx3: "index 3 | '\\0'    | is_at_end() sentinel"
  }
}
title -> input_display: "begin scan"
row_steps: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "STEP 1 — Dispatch on '>'"
    style: {
      fill: "#FFF9E6"
      stroke: "#F39C12"
      border-radius: 6
    }
    state1: {
      shape: sql_table
      label: "Scanner State (before)"
      s1a: "start   | int | 0"
      s1b: "current | int | 0"
      s1c: "line    | int | 1"
      s1d: "column  | int | 1"
    }
    action1: {
      label: "_scan_token() (scanner.py)"
      width: 340
      code: |'py
        ch = self.advance()   # ch='>', current→1
        # ch == '>' branch:
        if self._match('='):  # peek idx1='=' → True
            self.advance()    # current→2, col→3
            tok = GREATER_EQUAL
        else:
            tok = GREATER
      '|
    }
    decision1: {
      shape: diamond
      label: "peek(idx=1) == '='?"
      style: {
        fill: "#FFF9E6"
        stroke: "#F39C12"
      }
    }
    yes1: {
      label: "YES — _match('=') consumes idx=1"
      style: {
        fill: "#E8F8E8"
        stroke: "#27AE60"
        border-radius: 4
      }
    }
    emit1: {
      shape: sql_table
      label: "Token Emitted"
      e1a: "type   | TokenType | GREATER_EQUAL"
      e1b: "lexeme | str       | '>=' (idx 0..2)"
      e1c: "line   | int       | 1"
      e1d: "column | int       | 1"
    }
    state1_after: {
      shape: sql_table
      label: "Scanner State (after emit)"
      s1e: "start   | int | 2  (next _begin_token)"
      s1f: "current | int | 2"
      s1g: "line    | int | 1"
      s1h: "column  | int | 3"
    }
    state1 -> action1
    action1 -> decision1
    decision1 -> yes1: "YES"
    yes1 -> emit1
    emit1 -> state1_after
  }
  step2: {
    direction: down
    label: "STEP 2 — Dispatch on '='"
    style: {
      fill: "#EAF4FF"
      stroke: "#2980B9"
      border-radius: 6
    }
    state2: {
      shape: sql_table
      label: "Scanner State (before)"
      s2a: "start   | int | 2"
      s2b: "current | int | 2"
      s2c: "line    | int | 1"
      s2d: "column  | int | 3"
    }
    action2: {
      label: "_scan_token() (scanner.py)"
      width: 340
      code: |'py
        ch = self.advance()   # ch='=', current→3
        # ch == '=' branch:
        if self._match('='):  # peek idx3='\0' → False
            tok = EQUAL_EQUAL
        else:
            tok = ASSIGN      # ← taken
      '|
    }
    decision2: {
      shape: diamond
      label: "peek(idx=3) == '='?"
      style: {
        fill: "#EAF4FF"
        stroke: "#2980B9"
      }
    }
    no2: {
      label: "NO — peek()='\\0' (EOF sentinel)"
      style: {
        fill: "#FDE8E8"
        stroke: "#E74C3C"
        border-radius: 4
      }
    }
    emit2: {
      shape: sql_table
      label: "Token Emitted"
      e2a: "type   | TokenType | ASSIGN"
      e2b: "lexeme | str       | '=' (idx 2..3)"
      e2c: "line   | int       | 1"
      e2d: "column | int       | 3"
    }
    state2_after: {
      shape: sql_table
      label: "Scanner State (after emit)"
      s2e: "start   | int | 3"
      s2f: "current | int | 3"
      s2g: "is_at_end() | bool | True"
    }
    state2 -> action2
    action2 -> decision2
    decision2 -> no2: "NO"
    no2 -> emit2
    emit2 -> state2_after
  }
  step3: {
    direction: down
    label: "STEP 3 — EOF"
    style: {
      fill: "#F5F0FF"
      stroke: "#8E44AD"
      border-radius: 6
    }
    eof_check: {
      shape: diamond
      label: "is_at_end()?"
      style: {
        fill: "#F5F0FF"
        stroke: "#8E44AD"
      }
    }
    eof_emit: {
      shape: sql_table
      label: "EOF Token Appended"
      ef1: "type   | TokenType | EOF"
      ef2: "lexeme | str       | '' (empty)"
      ef3: "line   | int       | 1"
      ef4: "column | int       | 4"
    }
    eof_check -> eof_emit: "True → scan_tokens() appends EOF"
  }
}
input_display -> row_steps.step1: "advance() → ch='>'"
row_steps.step1 -> row_steps.step2: "loop: _begin_token(); _scan_token()"
row_steps.step2 -> row_steps.step3: "loop: _begin_token(); is_at_end()=True"
final_stream: {
  label: "Final Token Stream (scanner.tokens)"
  style: {
    fill: "#E8F8E8"
    stroke: "#27AE60"
    border-radius: 6
    bold: true
  }
  stream: {
    shape: sql_table
    label: "list[Token]  — 3 tokens"
    t0: "tokens[0] | GREATER_EQUAL | '>='  | 1:1"
    t1: "tokens[1] | ASSIGN        | '='   | 1:3"
    t2: "tokens[2] | EOF           | ''    | 1:4"
  }
}
row_steps.step3 -> final_stream: "return tokens"
annotation: {
  label: "Maximal Munch Invariant (scanner.py)"
  style: {
    fill: "#FFF3CD"
    stroke: "#F39C12"
    border-radius: 6
  }
  note: {
    shape: sql_table
    label: "Why '>=' wins over '>' + '='"
    r1: "Rule      | Always consume the LONGEST valid token first"
    r2: "Decision  | '>' seen → peek next → '=' found → consume both → GREATER_EQUAL"
    r3: "Remaining | '=' at idx=2 stands alone → peek next → '\\0' → ASSIGN"
    r4: "Guarantee | No backtracking; at most 1 char lookahead via peek()"
    r5: "Alt wrong | GREATER + EQUAL_EQUAL would need parser-level fixup (C++ >> bug)"
  }
}
final_stream -> annotation: "maximal munch consumed >= first"