direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Before/After: Comment-Inside-String Ambiguity"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    font-color: "#e0e0ff"
    font-size: 18
    bold: true
    border-radius: 6
    stroke: "#3a3a6e"
  }
}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_box: {
    label: "Input Source Text"
    shape: rectangle
    style: {
      fill: "#2d2d44"
      font-color: "#c0c0ff"
      font-size: 14
      bold: true
      border-radius: 4
      stroke: "#5050aa"
    }
    char_seq: {
      shape: sql_table
      label: "Character Stream"
      c0:  "idx=00 | char=' \" ' | U+0022 | token boundary candidate"
      c1:  "idx=01 | char='h'   | U+0068 | string content"
      c2:  "idx=02 | char='e'   | U+0065 | string content"
      c3:  "idx=03 | char='l'   | U+006C | string content"
      c4:  "idx=04 | char='l'   | U+006C | string content"
      c5:  "idx=05 | char='o'   | U+006F | string content"
      c6:  "idx=06 | char=' '   | U+0020 | string content"
      c7:  "idx=07 | char='/'   | U+002F | AMBIGUOUS — depends on mode"
      c8:  "idx=08 | char='/'   | U+002F | AMBIGUOUS — depends on mode"
      c9:  "idx=09 | char=' '   | U+0020 | ?"
      c10: "idx=10 | char='w'   | U+0077 | ?"
      c11: "idx=11 | char='o'   | U+006F | ?"
      c12: "idx=12 | char='r'   | U+0072 | ?"
      c13: "idx=13 | char='l'   | U+006C | ?"
      c14: "idx=14 | char='d'   | U+0064 | ?"
      c15: "idx=15 | char=' \" ' | U+0022 | ?"
    }
  }
}
row_main: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  before_col: "BEFORE: Naive Preprocessor Approach" {
    direction: down
    style: {
      fill: "#2d1515"
      stroke: "#aa3333"
      font-color: "#ff8080"
      font-size: 14
      bold: true
      border-radius: 6
    }
    step1_before: {
      label: "Step 1: Preprocessor Scans for Comment"
      shape: rectangle
      style: {
        fill: "#3d1a1a"
        stroke: "#cc4444"
        font-color: "#ffaaaa"
        border-radius: 4
      }
      code: |'python
        # Naive: strip everything after '//'
        def strip_comments(src):
            for i in range(len(src)-1):
                if src[i] == '/' and src[i+1] == '/':
                    return src[:i]  # BUG: ignores mode
            return src
      '|
      width: 420
    }
    step2_before: {
      label: "Step 2: Preprocessor Finds '//' at idx=7"
      shape: rectangle
      style: {
        fill: "#3d1a1a"
        stroke: "#cc4444"
        font-color: "#ffaaaa"
        border-radius: 4
      }
      code: |'python
        # Input:   '"hello // world"'
        # idx 7-8: '//' found!
        # Truncate: src = '"hello '
        # Result:  '"hello '   (7 chars)
      '|
      width: 420
    }
    step3_before: {
      shape: sql_table
      label: "Step 3: Truncated Input to Lexer"
      r1: "char | ' \" '  | OPEN QUOTE  | starts string"
      r2: "char | 'h'    | content"
      r3: "char | 'e'    | content"
      r4: "char | 'l'    | content"
      r5: "char | 'l'    | content"
      r6: "char | 'o'    | content"
      r7: "char | ' '    | content"
      r8: "EOF  | ---    | NO CLOSING QUOTE FOUND"
    }
    step4_before: {
      label: "Step 4: Lexer Result — WRONG"
      shape: rectangle
      style: {
        fill: "#5a0000"
        stroke: "#ff2222"
        font-color: "#ff6666"
        bold: true
        border-radius: 4
      }
      err_table: {
        shape: sql_table
        label: "Token Stream (INCORRECT)"
        t1: "type=ERROR   | lexeme='\"hello ' | line=1 | col=1"
        t2: "msg=Unterminated string literal reached EOF"
        t3: "type=EOF     | lexeme=''        | line=1 | col=8"
      }
    }
    before_annotation: {
      label: "ROOT CAUSE"
      shape: rectangle
      style: {
        fill: "#4a1010"
        stroke: "#ff4444"
        font-color: "#ffcccc"
        border-radius: 4
        stroke-dash: 4
      }
      note: {
        shape: sql_table
        label: "Why Preprocessing Fails"
        r1: "Preprocessing has NO state: it cannot know"
        r2: "whether '//' appears inside a string or not."
        r3: "'http://x.com' — the '//' is inside a string"
        r4: "'val // note'  — the '//' is a real comment"
        r5: "Both look identical to a context-free stripper."
      }
    }
  }
  after_col: "AFTER: Correct Scanner-Mode Approach" {
    direction: down
    style: {
      fill: "#0d2d0d"
      stroke: "#33aa33"
      font-color: "#80ff80"
      font-size: 14
      bold: true
      border-radius: 6
    }
    fsm_states: {
      shape: sql_table
      label: "Scanner FSM States (scanner.py)"
      s1: "NORMAL        | default mode — full token dispatch active"
      s2: "IN_STRING     | inside string literal — most chars are content"
      s3: "IN_LINE_CMT   | inside // comment  — discard until newline"
      s4: "IN_BLOCK_CMT  | inside /* comment  — discard until */"
      s5: "KEY RULE: mode is determined by scanner, not by character alone"
    }
    step1_after: {
      label: "Step 1: Scanner Sees '\"' in NORMAL Mode → Enter IN_STRING"
      shape: rectangle
      style: {
        fill: "#0d3d0d"
        stroke: "#44cc44"
        font-color: "#aaffaa"
        border-radius: 4
      }
      code: |'python
        # _scan_token() in NORMAL mode:
        ch = self.advance()   # ch = '"'
        if ch == '"':
            self._scan_string()  # ENTER IN_STRING MODE
            return
      '|
      width: 420
    }
    step2_after: {
      label: "Step 2: IN_STRING Mode — Characters Are Content, Not Operators"
      shape: rectangle
      style: {
        fill: "#0d3d0d"
        stroke: "#44cc44"
        font-color: "#aaffaa"
        border-radius: 4
      }
      code: |'python
        def _scan_string(self) -> None:
            while not self.is_at_end():
                ch = self.advance()
                if ch == '"':      # ONLY this closes the string
                    self.tokens.append(
                        self._make_token(TokenType.STRING))
                    return
                if ch == '\n':     # newline = error (unterminated)
                    ...error...
                if ch == '\\':    # backslash = escape sequence
                    ...escape...
                # ALL OTHER CHARS (including '/', '/') = literal content
                # '//' at idx 7-8: just two content chars, ignored
      '|
      width: 420
    }
    step3_after: {
      shape: sql_table
      label: "Step 3: Trace Through '\"hello // world\"'"
      r1:  "idx=00 | '\"' | NORMAL mode → enter _scan_string()"
      r2:  "idx=01 | 'h'  | IN_STRING → content, accumulate"
      r3:  "idx=02 | 'e'  | IN_STRING → content, accumulate"
      r4:  "idx=03 | 'l'  | IN_STRING → content, accumulate"
      r5:  "idx=04 | 'l'  | IN_STRING → content, accumulate"
      r6:  "idx=05 | 'o'  | IN_STRING → content, accumulate"
      r7:  "idx=06 | ' '  | IN_STRING → content, accumulate"
      r8:  "idx=07 | '/'  | IN_STRING → content (NOT comment!)"
      r9:  "idx=08 | '/'  | IN_STRING → content (NOT comment!)"
      r10: "idx=09 | ' '  | IN_STRING → content, accumulate"
      r11: "idx=10 | 'w'  | IN_STRING → content, accumulate"
      r12: "idx=14 | 'd'  | IN_STRING → content, accumulate"
      r13: "idx=15 | '\"' | IN_STRING → CLOSING QUOTE → emit STRING"
    }
    step4_after: {
      label: "Step 4: Lexer Result — CORRECT"
      shape: rectangle
      style: {
        fill: "#005500"
        stroke: "#22ff22"
        font-color: "#aaffaa"
        bold: true
        border-radius: 4
      }
      tok_table: {
        shape: sql_table
        label: "Token Stream (CORRECT)"
        t1: "type=STRING | lexeme='\"hello // world\"' | line=1 | col=1"
        t2: "lexeme includes both quote chars and all 16 content chars"
        t3: "type=EOF    | lexeme=''                  | line=1 | col=17"
      }
    }
    after_annotation: {
      label: "KEY INSIGHT"
      shape: rectangle
      style: {
        fill: "#0a3d0a"
        stroke: "#44ff44"
        font-color: "#ccffcc"
        border-radius: 4
        stroke-dash: 4
      }
      note: {
        shape: sql_table
        label: "Why Scanner Modes Are Required"
        r1: "The scanner is a DFA. Each mode = a DFA state."
        r2: "In NORMAL mode:    '/' can start a comment"
        r3: "In IN_STRING mode: '/' is always literal content"
        r4: "Same byte (0x2F), different state → different action"
        r5: "This context-sensitivity is impossible in preprocessing"
      }
    }
  }
}
row_insight: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  insight_box: {
    label: "The Fundamental Principle"
    shape: rectangle
    style: {
      fill: "#1a1a3e"
      stroke: "#7070dd"
      font-color: "#c0c0ff"
      font-size: 14
      bold: true
      border-radius: 6
    }
    principle: {
      shape: sql_table
      label: "Mode-Dependent Character Semantics (scanner.py)"
      p1: "Character | NORMAL mode meaning      | IN_STRING mode meaning"
      p2: "  '/'     | division OR comment start | literal content char"
      p3: "  '\"'    | start string literal      | END string literal"
      p4: "  '\\'    | ERROR (unrecognized)       | escape sequence prefix"
      p5: "  ' '     | whitespace, discard        | literal content char"
      p6: "  'n'     | start identifier           | literal content char"
      p7: "RULE: advance() + peek() determine char meaning, NOT char value alone"
    }
  }
}
title -> row_input: ""
row_input -> row_main: "str | dispatch"
row_main -> row_insight: "Token[] | emit"
before_col.step1_before -> before_col.step2_before: "src | scan"
before_col.step2_before -> before_col.step3_before: "str | truncate"
before_col.step3_before -> before_col.step4_before: "str | lex"
before_col.step4_before -> before_col.before_annotation: "error | diagnose"
after_col.fsm_states -> after_col.step1_after: "state | NORMAL"
after_col.step1_after -> after_col.step2_after: "state | IN_STRING"
after_col.step2_after -> after_col.step3_after: "char | accumulate"
after_col.step3_after -> after_col.step4_after: "Token | emit"
after_col.step4_after -> after_col.after_annotation: "correct | verify"
before_col.step4_before -> after_col.step4_after: "vs" {
  style: {
    stroke: "#ffaa00"
    stroke-dash: 5
    font-color: "#ffaa00"
  }
}