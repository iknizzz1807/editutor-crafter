direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Decision Tree: '/' Character Dispatch (scanner.py)
| {near: top-center}
entry: {
  label: "advance() consumed '/'"
  shape: rectangle
  style.fill: "#E8F4FD"
  style.stroke: "#2980B9"
  style.stroke-width: 2
  style.bold: true
}
peek_check: {
  label: "peek() == '/'"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
  style.stroke-width: 2
}
peek_check2: {
  label: "peek() == '*'"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
  style.stroke-width: 2
}
peek_else: {
  label: "peek() == anything else\n(including '\\0' at EOF)"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
  style.stroke-width: 2
}
entry -> peek_check: "char='/' in hand"
consume_second_slash: {
  label: "advance() — consume second '/'"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#5DADE2"
}
line_comment_mode: {
  label: "IN_LINE_COMMENT mode\n_scan_line_comment()"
  shape: rectangle
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
  style.stroke-width: 2
}
line_comment_loop: {
  label: "while peek() != '\\n' and not is_at_end()"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
}
line_advance: {
  label: "advance() — discard char"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#5DADE2"
}
line_stop: {
  label: "Stop — leave '\\n' for main loop\n(main loop handles \\n as whitespace)"
  shape: rectangle
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
}
emit_nothing_line: {
  label: "Emit: NOTHING\n(no token appended)"
  shape: oval
  style.fill: "#EAECEE"
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.font-color: "#555555"
}
consume_star: {
  label: "advance() — consume '*'"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#5DADE2"
}
block_comment_mode: {
  label: "IN_BLOCK_COMMENT mode\n_scan_block_comment()"
  shape: rectangle
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
  style.stroke-width: 2
}
block_loop: {
  label: "while not is_at_end()"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
}
block_peek_star: {
  label: "peek() == '*'"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
}
block_consume_star: {
  label: "advance() — consume '*'"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#5DADE2"
}
block_peek_slash: {
  label: "peek() == '/'"
  shape: diamond
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
}
block_consume_slash: {
  label: "advance() — consume '/'"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#5DADE2"
}
emit_nothing_block: {
  label: "Emit: NOTHING\n(comment closed)"
  shape: oval
  style.fill: "#EAECEE"
  style.stroke: "#7F8C8D"
  style.stroke-width: 2
  style.font-color: "#555555"
}
block_discard: {
  label: "advance() — discard char\n(advance() tracks '\\n' → line++)"
  shape: rectangle
  style.fill: "#EBF5FB"
  style.stroke: "#5DADE2"
}
block_eof_error: {
  label: "Emit: ERROR token\nlexeme=source[start:current]\nline=token_start_line\ncol=token_start_column"
  shape: oval
  style.fill: "#FADBD8"
  style.stroke: "#C0392B"
  style.stroke-width: 2
  style.font-color: "#922B21"
}
emit_slash: {
  label: "Emit: SLASH token\n_make_token(TokenType.SLASH)\nposition = token_start_line/col"
  shape: oval
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
  style.stroke-width: 2
  style.font-color: "#1D6A3B"
}
eof_annotation: {
  label: "CRITICAL EDGE CASE\npeek() at EOF returns '\\0'\n'\\0' != '/' and '\\0' != '*'\n→ falls through to SLASH emit\n→ valid Division token, NOT an error"
  shape: callout
  style.fill: "#FDF2E9"
  style.stroke: "#E67E22"
  style.stroke-width: 2
  style.font-color: "#784212"
}
peek_check -> consume_second_slash: "YES"
peek_check -> peek_check2: "NO"
peek_check2 -> consume_star: "YES"
peek_check2 -> peek_else: "NO"
peek_else -> emit_slash: "any char\nor EOF (\\0)"
consume_second_slash -> line_comment_mode
line_comment_mode -> line_comment_loop
line_comment_loop -> line_advance: "char not '\\n' and not EOF"
line_advance -> line_comment_loop: "loop back"
line_comment_loop -> line_stop: "peek()=='\\n' or EOF"
line_stop -> emit_nothing_line
consume_star -> block_comment_mode
block_comment_mode -> block_loop
block_loop -> block_peek_star: "not EOF"
block_peek_star -> block_consume_star: "YES — saw '*'"
block_consume_star -> block_peek_slash
block_peek_slash -> block_consume_slash: "YES — saw '*/'"
block_consume_slash -> emit_nothing_block
block_peek_slash -> block_loop: "NO — '*' not followed by '/'\nloop continues"
block_peek_star -> block_discard: "NO — not '*'"
block_discard -> block_loop: "loop back"
block_loop -> block_eof_error: "is_at_end() — unterminated"
emit_slash -> eof_annotation: "EOF case"
eof_annotation.near: bottom-right
peek_check -> peek_check2 -> peek_else: {
  style.opacity: 0
}