direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Trace: Scanning `"hello\nworld"` — Character-by-Character
| {near: top-center}
legend: {
  near: bottom-right
  style.stroke: "#888888"
  style.fill: "#f5f5f5"
  style.border-radius: 6
  l1: "Green border = IN_STRING_NORMAL"
  l2: "Yellow border = IN_STRING_ESCAPE"
  l3: "Red = closing quote / token emit"
  l4: "Arrow label = action taken"
}
states: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  S_NORMAL: "IN_STRING_NORMAL" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
    style.stroke-width: 3
    style.border-radius: 8
    style.font-size: 14
    style.bold: true
  }
  S_ESCAPE: "IN_STRING_ESCAPE" {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.stroke-width: 3
    style.border-radius: 8
    style.font-size: 14
    style.bold: true
  }
  S_NORMAL -> S_ESCAPE: "see '\\'"
  S_ESCAPE -> S_NORMAL: "consume escape char"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c0: {
    label: "Step 0"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=0: '\"'"
      ch: "char | '\"'"
      st: "state | START"
      act: "action | advance(), enter IN_STRING_NORMAL"
      lex: "lexeme so far | '\"'"
      pos: "line=1, col=1"
    }
  }
  c1: {
    label: "Step 1"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=1: 'h'"
      ch: "char | 'h'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"h'"
      pos: "line=1, col=2"
    }
  }
  c2: {
    label: "Step 2"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=2: 'e'"
      ch: "char | 'e'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"he'"
      pos: "line=1, col=3"
    }
  }
  c3: {
    label: "Step 3"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=3: 'l'"
      ch: "char | 'l'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hel'"
      pos: "line=1, col=4"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c4: {
    label: "Step 4"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=4: 'l'"
      ch: "char | 'l'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hell'"
      pos: "line=1, col=5"
    }
  }
  c5: {
    label: "Step 5"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=5: 'o'"
      ch: "char | 'o'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hello'"
      pos: "line=1, col=6"
    }
  }
  c6: {
    label: "Step 6 — TRANSITION"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.stroke-width: 3
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=6: '\\' (backslash)"
      ch: "char | '\\'"
      st: "state | IN_STRING_NORMAL → IN_STRING_ESCAPE"
      act: "action | advance(), set escape mode ON"
      lex: "lexeme so far | '\"hello\\'"
      pos: "line=1, col=7"
    }
  }
  c7: {
    label: "Step 7 — ESCAPE RESOLVED"
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
    style.stroke-width: 3
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=7: 'n' (escape payload)"
      ch: "char | 'n'"
      st: "state | IN_STRING_ESCAPE → IN_STRING_NORMAL"
      act: "action | '\\n' is valid escape; advance()"
      lex: "lexeme so far | '\"hello\\n' (raw)"
      pos: "line=1, col=8"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c8: {
    label: "Step 8"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=8: 'w'"
      ch: "char | 'w'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hello\\nw'"
      pos: "line=1, col=9"
    }
  }
  c9: {
    label: "Step 9"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=9: 'o'"
      ch: "char | 'o'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hello\\nwo'"
      pos: "line=1, col=10"
    }
  }
  c10: {
    label: "Step 10"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=10: 'r'"
      ch: "char | 'r'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hello\\nwor'"
      pos: "line=1, col=11"
    }
  }
  c11: {
    label: "Step 11"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=11: 'l'"
      ch: "char | 'l'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hello\\nworl'"
      pos: "line=1, col=12"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c12: {
    label: "Step 12"
    style.fill: "#e8f4fd"
    style.stroke: "#28a745"
    style.stroke-width: 2
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=12: 'd'"
      ch: "char | 'd'"
      st: "state | IN_STRING_NORMAL"
      act: "action | advance(), append to lexeme"
      lex: "lexeme so far | '\"hello\\nworld'"
      pos: "line=1, col=13"
    }
  }
  c13: {
    label: "Step 13 — EMIT TOKEN"
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
    style.stroke-width: 3
    style.border-radius: 6
    char: {
      shape: sql_table
      label: "Cursor=13: '\"' (closing quote)"
      ch: "char | '\"'"
      st: "state | IN_STRING_NORMAL → DONE"
      act: "action | advance(), emit STRING token"
      lex: "lexeme final | '\"hello\\nworld\"'"
      pos: "line=1, col=14"
    }
  }
}
escape_detail: "Escape Sequence Protocol (Step 6→7)" {
  style.fill: "#fff8e1"
  style.stroke: "#ffc107"
  style.stroke-width: 2
  style.border-radius: 8
  direction: right
  trigger: {
    shape: sql_table
    label: "Trigger char: '\\'"
    r1: "Consumed by | advance() in _scan_string()"
    r2: "Effect | escape_mode = True"
    r3: "State | IN_STRING_NORMAL → IN_STRING_ESCAPE"
    r4: "Lexeme | '\\' appended raw to source slice"
  }
  payload: {
    shape: sql_table
    label: "Payload char: 'n'"
    r1: "Consumed by | escape_char = self.advance()"
    r2: "Validation | 'n' in valid_escapes: True"
    r3: "State | IN_STRING_ESCAPE → IN_STRING_NORMAL"
    r4: "Stored value | raw '\\n' (2 bytes in source)"
  }
  trigger -> payload: "advance()"
}
final_token: {
  shape: sql_table
  label: "Final Token Emitted"
  f1: "type | TokenType.STRING"
  f2: "lexeme | '\"hello\\nworld\"'  (14 chars raw)"
  f3: "line | 1"
  f4: "column | 1  (position of opening '\"')"
  f5: "interpreted value | hello + newline + world"
  f6: "note | lexeme is RAW source; interpreter converts \\n → 0x0A"
}
valid_escapes: "Valid Escape Sequences (scanner.py)" {
  shape: sql_table
  label: "VALID_ESCAPES dict"
  e1: "\\n | newline (0x0A)"
  e2: "\\t | horizontal tab (0x09)"
  e3: "\\r | carriage return (0x0D)"
  e4: "\\\" | literal double-quote"
  e5: "\\\\ | literal backslash"
  e6: "other | ERROR token emitted, scan continues"
}
states -> row1: "cursor advances →"
row1 -> row2: "cursor advances →"
row2 -> row3: "cursor advances →"
row3 -> row4: "cursor advances →"
row4 -> escape_detail: "detail"
row4 -> final_token: "STRING emit"
escape_detail -> valid_escapes: "lookup"
c6.char -> c7.char: "IN_STRING_ESCAPE" {
  style.stroke: "#ffc107"
  style.stroke-width: 2
  style.stroke-dash: 4
}