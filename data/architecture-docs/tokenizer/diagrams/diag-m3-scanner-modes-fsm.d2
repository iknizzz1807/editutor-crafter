direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: "Scanner Mode FSM — The current mode determines which transition rules apply to each character" {
  near: top-center
  style: {
    font-size: 18
    bold: true
    italic: true
    fill: transparent
    stroke: transparent
  }
}
normal_mode: "NORMAL MODE (default)" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    border-radius: 8
    bold: true
    font-size: 16
  }
  direction: down
  dispatch: {
    shape: sql_table
    label: "Dispatch Table (scanner.py:_scan_token)"
    row_ws:  "' ' \\t \\r \\n | whitespace   | consume, no token"
    row_eq:  "'='           | ASSIGN        | or peek '=' → EQUAL_EQUAL"
    row_lt:  "'<'           | LESS          | or peek '=' → LESS_EQUAL"
    row_gt:  "'>'           | GREATER       | or peek '=' → GREATER_EQUAL"
    row_bang:"'!'           | peek '='      | → BANG_EQUAL else ERROR"
    row_sl:  "'/'           | SLASH         | or peek '/' → LINE_CMT mode"
    row_sl2: "'/'           | peek '*'      | → BLOCK_CMT mode"
    row_dq:  "'\"'          | STRING mode   | enter _scan_string()"
    row_dig: "[0-9]         | NUMBER        | → _scan_number()"
    row_alp: "[a-zA-Z_]     | IDENTIFIER    | → _scan_identifier() + kw lookup"
    row_sc:  "'+' '-' etc.  | single-char   | emit from SINGLE_CHAR_TOKENS dict"
    row_bad: "other         | ERROR token   | emit ERROR, continue"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  string_mode: "IN_STRING MODE" {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
      border-radius: 8
      bold: true
      font-size: 16
    }
    direction: down
    str_table: {
      shape: sql_table
      label: "String Transitions (_scan_string)"
      s1: "'\"'      | closing quote | emit STRING → back to NORMAL"
      s2: "'\\n'     | newline       | emit ERROR(unterminated) → NORMAL"
      s3: "'\\\\'    | backslash     | enter escape sub-state"
      s4: "esc: n/t/r/\"/\\\\ | valid esc | consume 2 chars, stay IN_STRING"
      s5: "esc: other | invalid esc  | emit ERROR(bad esc), stay IN_STRING"
      s6: "EOF       | EOF in string | emit ERROR(unterminated) → NORMAL"
      s7: "other     | any char      | accumulate, stay IN_STRING"
    }
  }
  block_comment_mode: "IN_BLOCK_COMMENT MODE" {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 3
      border-radius: 8
      bold: true
      font-size: 16
    }
    direction: down
    bc_table: {
      shape: sql_table
      label: "Block Comment Transitions (_scan_block_comment)"
      b1: "'*' then '/' | close seq    | emit nothing → back to NORMAL"
      b2: "'*' then X   | lone asterisk | discard, stay IN_BLOCK_COMMENT"
      b3: "'\\n'        | newline       | advance() → line++, col=1, discard"
      b4: "other        | any char      | advance() discards, stay mode"
      b5: "EOF          | unterminated  | emit ERROR(unterminated) → NORMAL"
      b6: "NOTE: comments do NOT nest  | first */ always closes"
    }
  }
}
line_comment_mode: "IN_LINE_COMMENT MODE" {
  style: {
    fill: "#F3E5F5"
    stroke: "#6A1B9A"
    stroke-width: 3
    border-radius: 8
    bold: true
    font-size: 16
  }
  direction: down
  lc_table: {
    shape: sql_table
    label: "Line Comment Transitions (_scan_line_comment)"
    l1: "'\\n'  | end of line | stop loop, leave \\n for main loop → NORMAL"
    l2: "EOF   | end of file | stop loop → NORMAL (no token emitted)"
    l3: "other | any char    | advance() discards, stay IN_LINE_COMMENT"
    l4: "NOTE: newline is NOT consumed here — main loop handles it as whitespace"
  }
}
error_accepting: "ERROR / ACCEPTING" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    border-radius: 8
    bold: true
    font-size: 16
  }
  direction: down
  err_table: {
    shape: sql_table
    label: "Error Token Contract"
    e1: "type     | TokenType.ERROR"
    e2: "lexeme   | exact source chars that caused the error"
    e3: "line     | token_start_line (opening char, NOT current pos)"
    e4: "column   | token_start_column (opening char, NOT current pos)"
    e5: "recovery | scanner continues — ALL errors collected, no halt"
  }
}
normal_mode -> row1.string_mode: "'\"'" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.bold: true
}
normal_mode -> row1.block_comment_mode: "'/' + '*'" {
  style.stroke: "#E65100"
  style.stroke-width: 2
  style.bold: true
}
normal_mode -> line_comment_mode: "'/' + '/'" {
  style.stroke: "#6A1B9A"
  style.stroke-width: 2
  style.bold: true
}
row1.string_mode -> normal_mode: "closing '\"'" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row1.block_comment_mode -> normal_mode: "'*/'" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 4
}
line_comment_mode -> normal_mode: "'\\n' or EOF" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 4
}
row1.string_mode -> error_accepting: "EOF or '\\n'" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 5
}
row1.block_comment_mode -> error_accepting: "EOF" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 5
}
normal_mode -> error_accepting: "unrecognized char" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 5
}
error_accepting -> normal_mode: "emit ERROR, continue scanning" {
  style.stroke: "#FF6F00"
  style.stroke-width: 2
  style.animated: true
}