direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}
title: |md
  ## String Literal FSM — IN\_STRING Mode
  States, transitions, and error paths for `_scan_string()`
| {near: top-center}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entry: ENTRY {
    label: "scan_token() sees '\"'"
    shape: oval
    style.fill: "#4a4a6a"
    style.font-color: white
    style.bold: true
  }
  normal: IN_STRING_NORMAL {
    label: "IN_STRING_NORMAL\n(scanner.py:_scan_string)"
    shape: circle
    width: 220
    style.fill: "#2a5f8f"
    style.font-color: white
    style.bold: true
    style.double-border: true
  }
  escape: IN_STRING_ESCAPE {
    label: "IN_STRING_ESCAPE\n(saw backslash)"
    shape: circle
    width: 220
    style.fill: "#6a2a8f"
    style.font-color: white
    style.bold: true
    style.double-border: true
  }
}
row0.entry -> row0.normal: "advance('\"') consumed"
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  ok_exit: DONE {
    label: "DONE\nemit STRING token"
    shape: oval
    width: 200
    style.fill: "#2a7a3a"
    style.font-color: white
    style.bold: true
    style.double-border: true
  }
  err_unterm: ERR_UNTERMINATED {
    label: "ERROR\n(unterminated string)\nposition = token_start"
    shape: oval
    width: 220
    style.fill: "#8f2a2a"
    style.font-color: white
    style.bold: true
  }
  err_escape: ERR_BAD_ESCAPE {
    label: "ERROR\n(invalid escape seq)\ncontinue scanning"
    shape: oval
    width: 220
    style.fill: "#8f5a2a"
    style.font-color: white
    style.bold: true
  }
}
row0.normal -> row1.ok_exit: "'\"' | advance, close"
row0.normal -> row1.err_unterm: "'\\n' or EOF | emit error"
row0.normal -> row0.escape: "'\\\\' | advance()" {
  style.stroke: "#b060f0"
  style.bold: true
}
row0.escape -> row0.normal: "valid payload | accumulate, loop" {
  style.stroke: "#60b0f0"
  style.bold: true
}
row0.escape -> row1.err_escape: "other char | emit error, loop" {
  style.stroke: "#f09030"
  style.stroke-dash: 4
  style.bold: true
}
row0.escape -> row1.err_unterm: "EOF | emit error, halt" {
  style.stroke: "#cc3333"
  style.stroke-dash: 4
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  normal_detail: NORMAL_mode_transitions {
    shape: sql_table
    label: "IN_STRING_NORMAL — Transition Table"
    r0: "INPUT CHAR      | ACTION                     | NEXT STATE"
    r1: "not '\"'\\\\\\n, not EOF | accumulate via advance()   | IN_STRING_NORMAL"
    r2: "'\\\\' (backslash) | advance(), note position   | IN_STRING_ESCAPE"
    r3: "'\"' (dbl-quote)  | advance(), emit STRING      | DONE (return)"
    r4: "'\\n' (newline)   | emit Error(unterminated)   | halt (return)"
    r5: "EOF (\\0 sentinel) | emit Error(unterminated)  | halt (return)"
  }
  escape_detail: ESCAPE_mode_transitions {
    shape: sql_table
    label: "IN_STRING_ESCAPE — Valid Payload Table"
    r0: "ESCAPE CHAR | INTERPRETED VALUE | NEXT STATE"
    r1: "'n'         | newline  0x0A    | IN_STRING_NORMAL"
    r2: "'t'         | tab      0x09    | IN_STRING_NORMAL"
    r3: "'r'         | CR       0x0D    | IN_STRING_NORMAL"
    r4: "'\"'         | dbl-quot 0x22    | IN_STRING_NORMAL"
    r5: "'\\\\'        | backslash 0x5C  | IN_STRING_NORMAL"
    r6: "any other   | emit Error(bad)  | IN_STRING_NORMAL (recover)"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  invariants: Design_Invariants {
    shape: sql_table
    label: "Implementation Invariants (_scan_string)"
    i1: "RULE 1  | advance() is ONLY place position updates — never self.current++"
    i2: "RULE 2  | Error position = token_start_line/col (opening quote), not current"
    i3: "RULE 3  | Lexeme stored RAW: '\"hello\\\\nworld\"' kept as 14 chars in source"
    i4: "RULE 4  | Bad escape emits ERROR then CONTINUES scanning for closing '\"'"
    i5: "RULE 5  | Newline inside string → ERROR + return (no multi-line literals)"
    i6: "RULE 6  | peek() returns '\\0' at EOF — never matches any valid escape char"
  }
  code_ref: Code_Reference {
    shape: sql_table
    label: "Code Reference (scanner.py)"
    c1: "METHOD  | _scan_string(self) -> None"
    c2: "CALLED  | from _scan_token() when ch == '\"'"
    c3: "EMITS   | Token(STRING, lexeme, token_start_line, token_start_col)"
    c4: "EMITS   | Token(ERROR, ...) on unterminated OR unknown escape"
    c5: "HELPER  | _make_token(TokenType.STRING) — uses self.start:self.current slice"
    c6: "HELPER  | advance() — consumes char, updates self.line / self.column"
  }
}
row1.err_escape -> row0.normal: "continue scanning\n(error recovery)" {
  style.stroke: "#f09030"
  style.stroke-dash: 4
  style.animated: true
}
row1.ok_exit -> row3.code_ref: "token appended" {
  style.stroke: "#2a7a3a"
  style.stroke-dash: 3
}
row0 -> row2
row2 -> row3