direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: 'Error Recovery: Halt-on-First vs Skip-and-Continue\nInput: x @ y $ z  —  two invalid characters @ and $'
  shape: rectangle
  style: {
    stroke: transparent
    fill: transparent
    font-size: 20
    bold: true
  }
}
title_node.near: top-center

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  left_col: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    
    halt_header: "HALT-ON-FIRST" {
      style.fill: "#FF4444"
      style.font-color: white
      style.bold: true
      style.border-radius: 6
    }
    
    halt_input: {
      shape: sql_table
      label: 'Input: x @ y $ z'
      c0: "0x00 | char 'x'  | IDENTIFIER  → emitted"
      c1: "0x01 | char '@'  | UNRECOGNIZED → ERROR emitted"
      c2: "0x02 | char 'y'  | NEVER REACHED (halted)"
      c3: '0x03 | char "$"  | NEVER REACHED (halted)'
      c4: "0x04 | char 'z'  | NEVER REACHED (halted)"
      c5: "0x05 | EOF       | NEVER REACHED (halted)"
    }
    
    halt_tokens: {
      shape: sql_table
      label: "Emitted Tokens — HALT strategy"
      t0: "1  |  IDENTIFIER  |  'x'  |  1:1"
      t1: "2  |  ERROR       |  '@'  |  1:3  ← scanner stops here"
      t2: "—  |  (no more tokens emitted)"
      sz: "Total: 2 tokens  |  1 error reported  |  INCOMPLETE"
    }
    
    halt_consequence: {
      shape: sql_table
      label: "What the IDE / user sees"
      e0: 'Errors reported    |  1 of 2  ($ never seen)'
      e1: "Valid tokens lost  |  y, z, EOF  — parser never receives them"
      e2: "Fix cycles needed  |  2 minimum  (one error per compile)"
      e3: 'IDE squiggles      |  Only on @  ($ appears clean)'
      e4: "Developer time     |  HIGH — iterative single-error workflow"
    }
  }

  right_col: {
    direction: down
    style.stroke: transparent
    style.fill: transparent
    
    cont_header: "SKIP-AND-CONTINUE (your scanner)" {
      style.fill: "#22AA55"
      style.font-color: white
      style.bold: true
      style.border-radius: 6
    }
    
    cont_input: {
      shape: sql_table
      label: 'Input: x @ y $ z'
      c0: "0x00 | char 'x'  | IDENTIFIER  → emitted"
      c1: "0x01 | char '@'  | UNRECOGNIZED → ERROR, advance"
      c2: "0x02 | char 'y'  | IDENTIFIER  → emitted"
      c3: '0x03 | char "$"  | UNRECOGNIZED → ERROR, advance'
      c4: "0x04 | char 'z'  | IDENTIFIER  → emitted"
      c5: "0x05 | EOF       | EOF sentinel → emitted"
    }
    
    cont_tokens: {
      shape: sql_table
      label: "Emitted Tokens — skip-and-continue strategy"
      t0: "1  |  IDENTIFIER  |  'x'  |  1:1"
      t1: "2  |  ERROR       |  '@'  |  1:3"
      t2: "3  |  IDENTIFIER  |  'y'  |  1:5"
      t3: '4  |  ERROR       |  "$"  |  1:7'
      t4: "5  |  IDENTIFIER  |  'z'  |  1:9"
      t5: "6  |  EOF         |  ''   |  1:11"
      sz: "Total: 6 tokens  |  2 errors reported  |  COMPLETE"
    }
    
    cont_consequence: {
      shape: sql_table
      label: "What the IDE / user sees"
      e0: "Errors reported    |  2 of 2  (all invalid chars found)"
      e1: "Valid tokens lost  |  none — full stream delivered to parser"
      e2: "Fix cycles needed  |  1  (all errors shown at once)"
      e3: 'IDE squiggles      |  On @ AND $  (both highlighted)'
      e4: "Developer time     |  LOW — batch-fix workflow"
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  why_box: {
    shape: sql_table
    label: "Key Insight — scanner.py:_scan_token()"
    r0: "Lexer state after error  |  CLEAN — no recursive frames"
    r1: "Re-sync mechanism        |  trivial — advance() moves next"
    r2: "Parser impact            |  zero — ERROR token is just a type"
    r3: "Memory overhead          |  zero — error IS the token"
    r4: "Implementation delta     |  zero — fallthrough appends+returns"
    r5: "Theoretical basis        |  lexer is flat FSM; no stack"
  }
  
  contrast_box: {
    shape: sql_table
    label: "Why Parsers Find Recovery Hard"
    r0: "Lexer on bad char   |  consume 1, emit ERROR, next is clean"
    r1: "Parser on bad token |  partial AST node? active grammar rule?"
    r2: "Parser recovery     |  panic mode, sync sets, productions"
    r3: "Lexer recovery      |  none — main loop IS the recovery"
    r4: "Stack depth on err  |  lexer: 1 frame  |  parser: N frames"
    r5: "Clang Strategy      |  Skip-and-continue: ships faster wins"
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  ide_box: {
    shape: sql_table
    label: "LSP Diagnostic Flow"
    r0: 'scanner.py emits  |  ERROR("@", 1:3), ERROR("$", 1:7)'
    r1: "Language server   |  collects all ERROR tokens from scan()"
    r2: "LSP response      |  publishDiagnostics with 2 entries"
    r3: "VS Code renderer  |  red squiggle at 1:3 AND 1:7"
    r4: "Halt strategy     |  only 1:3 squiggled — 1:7 hidden"
    r5: "User experience   |  Truthful diagnostics vs misleading"
  }
  
  code_box: {
    label: "Error Recovery Code (scanner.py)"
    width: 450
    code: |'python
      # _scan_token() fallthrough — this IS the recovery:
      self.tokens.append(
          self._error_token(f"Unexpected: {ch!r}")
      )
      # No early return. Next iteration:
      # _begin_token() resets start = current.
      # Scanner is in a clean state at pos+1.
    '|
  }
}

row1.left_col.halt_header -> row1.left_col.halt_input
row1.left_col.halt_input -> row1.left_col.halt_tokens
row1.left_col.halt_tokens -> row1.left_col.halt_consequence

row1.right_col.cont_header -> row1.right_col.cont_input
row1.right_col.cont_input -> row1.right_col.cont_tokens
row1.right_col.cont_tokens -> row1.right_col.cont_consequence

row1 -> row2: "Architectural Analysis"
row2 -> row3: "Production Impact"

row1.left_col.halt_consequence -> row1.right_col.cont_consequence: "vs" {
  style.stroke: "#FF4444"
  style.stroke-dash: 4
}