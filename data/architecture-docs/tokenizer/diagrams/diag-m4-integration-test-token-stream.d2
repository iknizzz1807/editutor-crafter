direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
source_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  src: "Source: 'if (x >= 42) { return true; }'" {
    style.fill: "#1a1a2e"
    style.font-color: "#e0e0ff"
    style.bold: true
    style.border-radius: 6
    style.font-size: 14
    width: 620
  }
}
tokens_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t1: {
    shape: sql_table
    label: "Token[0] — KEYWORD"
    style.fill: "#3d2b6b"
    style.font-color: "#d0b8ff"
    lex:  "lexeme  | 'if'"
    ln:   "line    | 1"
    col:  "column  | 1"
    note: "keyword table hit"
  }
  t2: {
    shape: sql_table
    label: "Token[1] — LPAREN"
    style.fill: "#1a3a5c"
    style.font-color: "#a8d8ff"
    lex:  "lexeme  | '('"
    ln:   "line    | 1"
    col:  "column  | 4"
    note: "single-char dispatch"
  }
  t3: {
    shape: sql_table
    label: "Token[2] — IDENTIFIER"
    style.fill: "#1a3a1a"
    style.font-color: "#a8ffa8"
    lex:  "lexeme  | 'x'"
    ln:   "line    | 1"
    col:  "column  | 5"
    note: "keyword.get miss"
  }
  t4: {
    shape: sql_table
    label: "Token[3] — GREATER_EQUAL"
    style.fill: "#5c3a00"
    style.font-color: "#ffd080"
    lex:  "lexeme  | '>='"
    ln:   "line    | 1"
    col:  "column  | 7"
    note: "maximal munch: peek('=')"
  }
}
tokens_row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t5: {
    shape: sql_table
    label: "Token[4] — NUMBER"
    style.fill: "#1a3a5c"
    style.font-color: "#a8d8ff"
    lex:  "lexeme  | '42'"
    ln:   "line    | 1"
    col:  "column  | 10"
    note: "digit loop: 2 chars"
  }
  t6: {
    shape: sql_table
    label: "Token[5] — RPAREN"
    style.fill: "#1a3a5c"
    style.font-color: "#a8d8ff"
    lex:  "lexeme  | ')'"
    ln:   "line    | 1"
    col:  "column  | 12"
    note: "single-char dispatch"
  }
  t7: {
    shape: sql_table
    label: "Token[6] — LBRACE"
    style.fill: "#1a3a5c"
    style.font-color: "#a8d8ff"
    lex:  "lexeme  | '{'"
    ln:   "line    | 1"
    col:  "column  | 14"
    note: "single-char dispatch"
  }
  t8: {
    shape: sql_table
    label: "Token[7] — KEYWORD"
    style.fill: "#3d2b6b"
    style.font-color: "#d0b8ff"
    lex:  "lexeme  | 'return'"
    ln:   "line    | 1"
    col:  "column  | 16"
    note: "6-char ident + kw hit"
  }
}
tokens_row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t9: {
    shape: sql_table
    label: "Token[8] — KEYWORD"
    style.fill: "#3d2b6b"
    style.font-color: "#d0b8ff"
    lex:  "lexeme  | 'true'"
    ln:   "line    | 1"
    col:  "column  | 23"
    note: "4-char ident + kw hit"
  }
  t10: {
    shape: sql_table
    label: "Token[9] — SEMICOLON"
    style.fill: "#1a3a5c"
    style.font-color: "#a8d8ff"
    lex:  "lexeme  | ';'"
    ln:   "line    | 1"
    col:  "column  | 27"
    note: "single-char dispatch"
  }
  t11: {
    shape: sql_table
    label: "Token[10] — RBRACE"
    style.fill: "#1a3a5c"
    style.font-color: "#a8d8ff"
    lex:  "lexeme  | '}'"
    ln:   "line    | 1"
    col:  "column  | 29"
    note: "single-char dispatch"
  }
  t12: {
    shape: sql_table
    label: "Token[11] — EOF"
    style.fill: "#3a1a1a"
    style.font-color: "#ff9090"
    lex:  "lexeme  | ''"
    ln:   "line    | 1"
    col:  "column  | 30"
    note: "sentinel: no more input"
  }
}
legend: {
  style.fill: "#111122"
  style.stroke: "#444466"
  style.border-radius: 6
  label: "Color Legend"
  k:  "Purple  = KEYWORD (keyword table hit)"
  i:  "Green   = IDENTIFIER (keyword table miss)"
  o:  "Orange  = Operator via maximal munch"
  b:  "Blue    = Literal / Punctuation"
  e:  "Red     = EOF sentinel"
}
legend.near: bottom-right
source_row -> tokens_row: "Scanner._scan_token() × 8 chars"
tokens_row -> tokens_row2: "Scanner._scan_token() × 9 chars"
tokens_row2 -> tokens_row3: "Scanner._scan_token() × 13 chars"
source_row.src -> tokens_row.t1: "advance 'i','f' → peek ' '" {
  style.stroke: "#a080ff"
  style.stroke-dash: 3
}
source_row.src -> tokens_row.t4: "advance '>' → _match('=')" {
  style.stroke: "#ffaa40"
  style.stroke-dash: 3
}
source_row.src -> tokens_row2.t8: "advance×6 → KEYWORDS.get" {
  style.stroke: "#a080ff"
  style.stroke-dash: 3
}
source_row.src -> tokens_row3.t12: "is_at_end() → append EOF" {
  style.stroke: "#ff6060"
  style.stroke-dash: 3
}