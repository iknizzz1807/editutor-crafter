direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
# ─── PRODUCER SIDE ───────────────────────────────────────────────────────────
producer: "PRODUCER: Tokenizer (scanner.py)" {
  style.fill: "#e8f4fd"
  style.stroke: "#2980b9"
  style.stroke-width: 2
  style.border-radius: 8
  direction: down
  source_str: {
    shape: sql_table
    label: "Source Input"
    r0: "type | str"
    r1: "example | \"if (x >= 42) { return true; }\""
    r2: "access | scanner.source[i]  -- character-level"
  }
  scanner_cls: {
    shape: class
    label: "Scanner (scanner.py)"
    -source: "str"
    -start: "int"
    -current: "int"
    -line: "int"
    -column: "int"
    -token_start_line: "int"
    -token_start_column: "int"
    -tokens: "list[Token]"
    +scan_tokens(): "list[Token]"
    -advance(): "str"
    -peek(): "str"
    -peek_next(): "str"
    -match(expected): "bool"
    -scan_token(): "None"
    -scan_number(): "None"
    -scan_identifier(): "None"
    -scan_string(): "None"
    -scan_line_comment(): "None"
    -scan_block_comment(): "None"
    -make_token(tt): "Token"
    -begin_token(): "None"
  }
  source_str -> scanner_cls: "str | read-only"
}
# ─── CONTRACT / INTERFACE ────────────────────────────────────────────────────
interface_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  token_struct: {
    shape: sql_table
    label: "struct Token  (the wire type)"
    f0: "field | type      | note"
    f1: "type  | TokenType | KEYWORD / NUMBER / EOF / ERROR ..."
    f2: "lexeme| str       | exact source text  e.g. \">=\" "
    f3: "line  | int       | 1-based  (for LSP diagnostics)"
    f4: "col   | int       | 1-based  (for LSP diagnostics)"
    f5: "Total | 4 fields  | ~64 bytes per token (CPython)"
  }
  stream_rules: {
    shape: sql_table
    label: "Token Stream Contract"
    r0: "rule | description"
    r1: "ORDER   | tokens emitted left-to-right, line order"
    r2: "EOF     | last token is ALWAYS TokenType.EOF"
    r3: "ONE EOF | exactly one EOF sentinel per scan"
    r4: "IMMUT   | list is complete before parser starts"
    r5: "NO SRC  | parser never touches source string"
    r6: "ERRORS  | ERROR tokens IN stream (pass-through)"
  }
  token_enum: {
    shape: sql_table
    label: "TokenType (enum)"
    k0: "category | members"
    k1: "Literals | NUMBER  STRING"
    k2: "Names    | IDENTIFIER  KEYWORD"
    k3: "ArithOp  | PLUS  MINUS  STAR  SLASH"
    k4: "CmpOp    | EQUAL_EQUAL  BANG_EQUAL"
    k5: "CmpOp2   | LESS  LESS_EQUAL  GREATER  GREATER_EQUAL"
    k6: "Assign   | ASSIGN"
    k7: "Punct    | LPAREN RPAREN LBRACE RBRACE"
    k8: "Punct2   | LBRACKET RBRACKET SEMICOLON COMMA"
    k9: "Sentinel | EOF   ERROR"
  }
}
# ─── STREAM CHANNEL ──────────────────────────────────────────────────────────
channel: "TOKEN STREAM  list[Token]  (the typed channel)" {
  style.fill: "#fefce8"
  style.stroke: "#d97706"
  style.stroke-width: 3
  style.border-radius: 6
  direction: right
  ex_stream: {
    shape: sql_table
    label: "Example: \"if (x >= 42)\""
    t0: "idx | type          | lexeme | line | col"
    t1: " 0  | KEYWORD       | if     |  1   |  1"
    t2: " 1  | LPAREN        | (      |  1   |  4"
    t3: " 2  | IDENTIFIER    | x      |  1   |  5"
    t4: " 3  | GREATER_EQUAL | >=     |  1   |  7"
    t5: " 4  | NUMBER        | 42     |  1   | 10"
    t6: " 5  | RPAREN        | )      |  1   | 12"
    t7: " 6  | EOF           |        |  1   | 13"
  }
  annotations: {
    shape: sql_table
    label: "Stream Annotations"
    a1: "annotation-1 | EOF is stream terminator -- parser loops until EOF"
    a2: "annotation-2 | ERROR tokens flow through -- parser handles or skips"
    a3: "annotation-3 | positions are SNAPSHOT at token START (not end)"
    a4: "annotation-4 | whitespace + comments ABSENT -- consumed silently"
    a5: "annotation-5 | keyword vs identifier resolved HERE -- parser sees KEYWORD"
  }
}
# ─── ERROR TOKEN POLICY ──────────────────────────────────────────────────────
error_policy_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  policy_a: "Option A: Pass-through (current impl)" {
    style.fill: "#fef2f2"
    style.stroke: "#dc2626"
    style.stroke-width: 2
    style.border-radius: 6
    direction: down
    pa_flow: {
      shape: sql_table
      label: "ERROR flows into parser stream"
      p1: "Scanner emits ERROR token into list[Token]"
      p2: "Parser receives ERROR -- treats as unknown"
      p3: "Parser may emit additional parse errors"
      p4: "Pro: parser gets location of bad char"
      p5: "Con: parser must guard every rule for ERROR"
    }
  }
  policy_b: "Option B: Separate error list (future)" {
    style.fill: "#f0fdf4"
    style.stroke: "#16a34a"
    style.stroke-width: 2
    style.border-radius: 6
    direction: down
    pb_flow: {
      shape: sql_table
      label: "ERROR collected separately"
      p1: "Scanner splits output: tokens + errors"
      p2: "tokens: list[Token]  -- only VALID tokens"
      p3: "errors: list[ScanError]  -- structured"
      p4: "Parser never sees ERROR tokens"
      p5: "Pro: parser stays clean"
      p6: "Con: two output channels to thread through"
    }
  }
}
# ─── CONSUMER SIDE ───────────────────────────────────────────────────────────
consumer: "CONSUMER: Future Parser (parser.py  -- NOT YET BUILT)" {
  style.fill: "#f3f4f6"
  style.stroke: "#6b7280"
  style.stroke-width: 2
  style.stroke-dash: 6
  style.border-radius: 8
  direction: right
  parser_api: {
    shape: class
    label: "Parser (parser.py) -- skeleton"
    -tokens: "list[Token]"
    -current: "int"
    +parse(): "ASTNode"
    +peek(): "Token"
    +advance(): "Token"
    +match(tt): "bool"
    +check(tt): "bool"
    +consume(tt, msg): "Token"
    +is_at_end(): "bool"
  }
  parser_loop: {
    label: "Parser main loop"
    width: 380
    code: |'py
      def advance(self) -> Token:
          # moves cursor over self.tokens[]
          # NEVER touches self.source
          tok = self.tokens[self.current]
          self.current += 1
          return tok
      def is_at_end(self) -> bool:
          return self.peek().type == TokenType.EOF
      def parse(self) -> ASTNode:
          nodes = []
          while not self.is_at_end():   # EOF is terminator
              nodes.append(self.statement())
          return Program(nodes)
    '|
  }
  hard_boundary: {
    shape: sql_table
    label: "THE BOUNDARY  (enforcement)"
    b1: "RULE | parser.source  -- does NOT exist"
    b2: "RULE | parser.advance() consumes Token not char"
    b3: "RULE | scanner.advance() consumes char not Token"
    b4: "RULE | scanner is DONE before parser starts"
    b5: "RULE | token.lexeme is the only src text visible"
    b6: "RULE | token.line+col used for all diagnostics"
  }
}
# ─── LEGEND ──────────────────────────────────────────────────────────────────
legend: {
  shape: sql_table
  label: "Legend"
  l1: "color | meaning"
  l2: "BLUE border  | producer / scanner"
  l3: "ORANGE border| token stream channel (the contract)"
  l4: "GRAY dashed  | future parser (not yet built)"
  l5: "RED dashed   | error / danger zone"
  l6: "GREEN dashed | safe / recommended path"
}
legend.near: bottom-right
# ─── CONNECTIONS ─────────────────────────────────────────────────────────────
producer.scanner_cls -> interface_row.token_struct: "Token | emit"
interface_row.token_struct -> channel: "list[Token] | sealed"
interface_row.stream_rules -> channel: "contract"
interface_row.token_enum -> interface_row.token_struct: "TokenType | type field"
channel -> error_policy_row.policy_a: "ERROR token | pass-through"
channel -> error_policy_row.policy_b: "split | future"
error_policy_row.policy_a -> consumer: "list[Token] | with ERROR"
error_policy_row.policy_b -> consumer: "list[Token] | clean only"
consumer.parser_api -> consumer.parser_loop: "impl"
consumer.parser_api -> consumer.hard_boundary: "enforces"