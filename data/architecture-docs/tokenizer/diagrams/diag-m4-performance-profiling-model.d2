direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Performance Model: Lexer Throughput — 10,000-Line Input" {
  near: top-center
  style: {
    font-size: 20
    bold: true
    stroke: transparent
    fill: transparent
  }
}
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_box: {
    label: "INPUT (scanner.py)"
    shape: sql_table
    r1: "source: str       | 10,000 lines"
    r2: "chars             | ~300,000 chars"
    r3: "avg line length   | ~30 chars"
    r4: "token density     | ~6 tokens/line"
    r5: "expected tokens   | ~60,000 tokens"
    r6: "complexity        | O(n) — single pass"
    style.fill: "#dbeafe"
    style.stroke: "#3b82f6"
  }
  arrow0a: "" {
    shape: rectangle
    style.stroke: transparent
    style.fill: transparent
    width: 40
  }
  complexity_box: {
    label: "ALGORITHMIC COMPLEXITY"
    shape: sql_table
    r1: "advance() calls   | 300,000 total"
    r2: "per call ops      | O(1) — index + branch"
    r3: "peek() calls      | ~300,000 total"
    r4: "per call ops      | O(1) — index only"
    r5: "emit token        | O(1) — slice + append"
    r6: "total             | O(n) — no backtracking"
    style.fill: "#dcfce7"
    style.stroke: "#16a34a"
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pipeline: "SCANNING PIPELINE (scanner.py)" {
    direction: right
    style.fill: "#f8fafc"
    style.stroke: "#64748b"
    phase_read: {
      label: "Phase 1: Load Source"
      shape: sql_table
      r1: "op       | source = open(f).read()"
      r2: "cost     | O(n) disk I/O"
      r3: "result   | str object in heap"
      r4: "bytes    | ~300 KB in CPython"
      r5: "time est | ~1 ms (SSD)"
      style.fill: "#fef9c3"
      style.stroke: "#ca8a04"
    }
    arrow_p1: "" {
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      width: 30
    }
    phase_scan: {
      label: "Phase 2: scan_tokens() Loop"
      shape: sql_table
      r1: "loop iters    | 300,000"
      r2: "_begin_token  | 3 assignments"
      r3: "_scan_token   | 1 advance() + dispatch"
      r4: "advance()     | index + inc + branch"
      r5: "peek()        | index only (no consume)"
      r6: "hot path      | whitespace discard"
      r7: "time est      | 100-400 ms (CPython)"
      style.fill: "#fee2e2"
      style.stroke: "#dc2626"
      style.font-color: "#111"
    }
    arrow_p2: "" {
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      width: 30
    }
    phase_emit: {
      label: "Phase 3: Return List"
      shape: sql_table
      r1: "tokens list   | ~60,001 Token objects"
      r2: "slice per tok | source[start:current]"
      r3: "slice cost    | O(k), k=token length"
      r4: "append cost   | O(1) amortized"
      r5: "EOF sentinel  | always last"
      r6: "time est      | ~5 ms (allocation)"
      style.fill: "#dcfce7"
      style.stroke: "#16a34a"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  advance_detail: {
    label: "advance() — O(1) Breakdown (scanner.py:advance)"
    shape: sql_table
    r1: "ch = source[current]   | CPython str index: O(1)"
    r2: "current += 1           | int increment: O(1)"
    r3: "if ch == newline       | byte compare: O(1)"
    r4: "  line += 1            | int increment: O(1)"
    r5: "  column = 1           | int assign: O(1)"
    r6: "else: column += 1      | int increment: O(1)"
    r7: "return ch              | ref return: O(1)"
    r8: "Total bytecodes        | ~12 per call"
    r9: "At 300K calls          | ~3.6M bytecodes"
    style.fill: "#fce7f3"
    style.stroke: "#db2777"
  }
  arrow_r2a: "" {
    shape: rectangle
    style.stroke: transparent
    style.fill: transparent
    width: 40
  }
  dispatch_detail: {
    label: "_scan_token() Dispatch Cost (scanner.py:_scan_token)"
    shape: sql_table
    r1: "whitespace (hot path)  | 2-op set lookup"
    r2: "single-char op         | dict lookup O(1)"
    r3: "two-char op (=,!,<,>)  | branch + peek"
    r4: "slash (/ comment)      | branch + _match"
    r5: "digit (number)         | isdigit() call"
    r6: "alpha (ident/keyword)  | isalpha() call"
    r7: "keyword lookup         | dict.get() O(1)"
    r8: "string literal         | sub-loop entry"
    r9: "comment                | sub-loop entry"
    style.fill: "#ede9fe"
    style.stroke: "#7c3aed"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hand_written: {
    label: "Hand-Written Scanner (THIS IMPL)"
    shape: sql_table
    r1: "algorithm       | single-pass DFA"
    r2: "lookahead       | 1 char (peek)"
    r3: "backtracking    | NONE"
    r4: "inner loops     | per-token only"
    r5: "string ops      | slice at emit O(k)"
    r6: "complexity      | O(n) time, O(n) space"
    r7: "CPython est     | 100-400 ms / 300K chars"
    r8: "PyPy est        | 10-40 ms / 300K chars"
    r9: "Rust port est   | 2-5 ms / 300K chars"
    style.fill: "#dcfce7"
    style.stroke: "#15803d"
  }
  arrow_vs: "" {
    shape: rectangle
    style.stroke: transparent
    style.fill: transparent
    width: 30
  }
  regex_based: {
    label: "re.findall() Regex Lexer (COMPARISON)"
    shape: sql_table
    r1: "algorithm       | NFA-to-DFA compiled"
    r2: "compile step    | re.compile() one-time"
    r3: "compile cost    | NFA-to-DFA: O(2^k) worst"
    r4: "match cost      | O(n) after compile"
    r5: "overhead        | Python-C boundary per tok"
    r6: "complexity      | O(n) same asymptotic"
    r7: "CPython est     | 150-600 ms / 300K chars"
    r8: "advantage       | fewer Python bytecodes"
    r9: "disadvantage    | NFA overhead, less control"
    style.fill: "#fef9c3"
    style.stroke: "#b45309"
  }
  arrow_vs2: "" {
    shape: rectangle
    style.stroke: transparent
    style.fill: transparent
    width: 30
  }
  quadratic_risk: {
    label: "PATHOLOGICAL CASE — O(n²) Risk"
    shape: sql_table
    r1: "cause           | lexeme += ch in loop"
    r2: "why             | str is immutable in Python"
    r3: "each +=         | allocates new str object"
    r4: "k-char token    | k allocations = O(k²)"
    r5: "1000-char ident | ~1M extra allocations"
    r6: "FIX             | source[start:current]"
    r7: "slice is O(k)   | one allocation per token"
    r8: "THIS IMPL       | uses slice — safe"
    r9: "verify          | test_maximum_length_ident"
    style.fill: "#fee2e2"
    style.stroke: "#991b1b"
    style.font-color: "#111"
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  benchmark_target: {
    label: "BENCHMARK TARGET (test_scanner.py:TestPerformance)"
    shape: sql_table
    r1: "input size      | 10,000 lines, ~300K chars"
    r2: "wall-clock goal | < 1.0 second (CPython)"
    r3: "throughput goal | > 100,000 chars/sec"
    r4: "measured at     | best of 3 runs (warm)"
    r5: "typical result  | 300K-1M chars/sec"
    r6: "pass threshold  | < 1s AND > 100K chars/s"
    r7: "failure signal  | O(n^2) bug or huge const"
    style.fill: "#dbeafe"
    style.stroke: "#1d4ed8"
  }
  arrow_r4a: "" {
    shape: rectangle
    style.stroke: transparent
    style.fill: transparent
    width: 40
  }
  runtime_tiers: {
    label: "RUNTIME TIER COMPARISON (same O(n) algorithm)"
    shape: sql_table
    r1: "CPython 3.11    | 100-400 ms  | baseline"
    r2: "PyPy 3.10       | 10-40 ms    | JIT 10x"
    r3: "Cython (typed)  | 20-80 ms    | 5x"
    r4: "ctypes/cffi     | 5-20 ms     | 20x"
    r5: "Rust (pyo3)     | 2-8 ms      | 50x"
    r6: "Pure Rust       | 1-4 ms      | 100x"
    r7: "LLVM clang C    | 0.3-1 ms    | 300x"
    r8: "note: all O(n)  | const factor differs"
    style.fill: "#f0fdf4"
    style.stroke: "#15803d"
  }
}
row0 -> row1: "source str | pass"
row1 -> row2: "per-char ops | detail"
row2 -> row3: "impl compare | throughput"
row3 -> row4: "benchmark | target"
row1.pipeline.phase_read -> row1.pipeline.phase_scan: "str | O(n)"
row1.pipeline.phase_scan -> row1.pipeline.phase_emit: "Token[] | O(1) amort"