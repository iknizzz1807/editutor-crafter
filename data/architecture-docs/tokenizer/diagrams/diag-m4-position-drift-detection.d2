direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Position Tracking Drift: How Off-by-One Accumulates" {
  near: top-center
  style: {
    font-size: 18
    bold: true
    font-color: "#1a1a2e"
  }
}
input_block: "Input: 'ab\\ncd\\nef' (7 chars)" {
  style: {
    fill: "#e8f4f8"
    stroke: "#2196F3"
    stroke-width: 2
    border-radius: 6
    bold: true
  }
  direction: right
  c0: {
    shape: sql_table
    label: "Source Characters"
    ch0: "idx=0 | 'a' | letter"
    ch1: "idx=1 | 'b' | letter"
    ch2: "idx=2 | '\\n' | NEWLINE"
    ch3: "idx=3 | 'c' | letter"
    ch4: "idx=4 | 'd' | letter"
    ch5: "idx=5 | '\\n' | NEWLINE"
    ch6: "idx=6 | 'e' | letter"
    ch7: "idx=7 | 'f' | letter"
  }
}
row_line1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  correct_line1: "LINE 1 — Correct Scanner" {
    style: {
      fill: "#e8f5e9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 6
      bold: true
    }
    c_l1: {
      shape: sql_table
      label: "advance() per char"
      r0: "consume 'a' | line=1 | col=1 → col=2"
      r1: "consume 'b' | line=1 | col=2 → col=3"
      r2: "consume '\\n' | line=1→2 | col=RESET→1"
    }
  }
  buggy_line1: "LINE 1 — Buggy Scanner (col never resets)" {
    style: {
      fill: "#fff3e0"
      stroke: "#FF9800"
      stroke-width: 2
      border-radius: 6
      bold: true
    }
    b_l1: {
      shape: sql_table
      label: "broken advance() — no reset on \\n"
      r0: "consume 'a' | line=1 | col=1 → col=2"
      r1: "consume 'b' | line=1 | col=2 → col=3"
      r2: "consume '\\n' | line=1→2 | col=3 → col=4  BUG"
    }
  }
}
diverge1: "DIVERGENCE POINT 1 — After first \\n" {
  direction: right
  style: {
    fill: "#fff8e1"
    stroke: "#FFC107"
    stroke-width: 2
    border-radius: 6
  }
  correct_state1: {
    shape: sql_table
    label: "Correct State"
    s1: "line = 2"
    s2: "col  = 1"
    s3: "next token col → 1"
  }
  buggy_state1: {
    shape: sql_table
    label: "Buggy State"
    s1: "line = 2"
    s2: "col  = 4  (WRONG)"
    s3: "next token col → 4"
    style.fill: "#FFCCBC"
  }
  correct_state1 -> buggy_state1: "col off by +3" {
    style.stroke: "#FF9800"
    style.stroke-dash: 4
    style.bold: true
  }
}
row_line2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  correct_line2: "LINE 2 — Correct Scanner" {
    style: {
      fill: "#e8f5e9"
      stroke: "#4CAF50"
      stroke-width: 2
      border-radius: 6
      bold: true
    }
    c_l2: {
      shape: sql_table
      label: "Token 'c' at correct position"
      r0: "consume 'c' | line=2 | col=1 → col=2"
      r1: "consume 'd' | line=2 | col=2 → col=3"
      r2: "consume '\\n' | line=2→3 | col=RESET→1"
      r3: "Token(IDENTIFIER,'c', line=2, col=1)"
    }
  }
  buggy_line2: "LINE 2 — Buggy Scanner" {
    style: {
      fill: "#ffccbc"
      stroke: "#F44336"
      stroke-width: 2
      border-radius: 6
      bold: true
    }
    b_l2: {
      shape: sql_table
      label: "Token 'c' at WRONG position"
      r0: "consume 'c' | line=2 | col=4 → col=5"
      r1: "consume 'd' | line=2 | col=5 → col=6"
      r2: "consume '\\n' | line=2→3 | col=6 → col=7  BUG"
      r3: "Token(IDENTIFIER,'c', line=2, col=4)  WRONG"
      style.fill: "#FFCCBC"
    }
  }
}
diverge2: "DIVERGENCE POINT 2 — After second \\n" {
  direction: right
  style: {
    fill: "#fce4ec"
    stroke: "#F44336"
    stroke-width: 2
    border-radius: 6
  }
  correct_state2: {
    shape: sql_table
    label: "Correct State"
    s1: "line = 3"
    s2: "col  = 1"
    s3: "next token col → 1"
  }
  buggy_state2: {
    shape: sql_table
    label: "Buggy State — SEVERE DRIFT"
    s1: "line = 3"
    s2: "col  = 7  (WRONG: +6 off)"
    s3: "next token col → 7"
    style.fill: "#FFCCBC"
  }
  correct_state2 -> buggy_state2: "col off by +6" {
    style.stroke: "#F44336"
    style.stroke-width: 3
    style.bold: true
  }
}
row_line3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  correct_line3: "LINE 3 — Correct Scanner" {
    style: {
      fill: "#e8f5e9"
      stroke: "#4CAF50"
      stroke-width: 3
      border-radius: 6
      bold: true
    }
    c_l3: {
      shape: sql_table
      label: "Token 'e' — CORRECT"
      r0: "consume 'e' | line=3 | col=1 → col=2"
      r1: "consume 'f' | line=3 | col=2 → col=3"
      r2: "Token(IDENTIFIER,'e', line=3, col=1)"
      r3: "assert tok.line==3, tok.col==1  PASS"
    }
  }
  buggy_line3: "LINE 3 — Buggy Scanner" {
    style: {
      fill: "#b71c1c"
      stroke: "#F44336"
      stroke-width: 3
      border-radius: 6
      bold: true
      font-color: white
    }
    b_l3: {
      shape: sql_table
      label: "Token 'e' — WRONG POSITION"
      r0: "consume 'e' | line=3 | col=7 → col=8"
      r1: "consume 'f' | line=3 | col=8 → col=9"
      r2: "Token(IDENTIFIER,'e', line=3, col=7)  WRONG"
      r3: "assert tok.col==1  FAIL: got 7"
    }
  }
}
fix_block: "Root Cause & Fix" {
  style: {
    fill: "#f3e5f5"
    stroke: "#9C27B0"
    stroke-width: 2
    border-radius: 8
    bold: true
  }
  direction: right
  broken_code: {
    label: "BROKEN advance() — bug"
    width: 380
    code: |'python
      def advance(self) -> str:
          ch = self.source[self.current]
          self.current += 1
          # BUG: increments line but NEVER resets column
          if ch == '\n':
              self.line += 1
          self.column += 1   # col keeps growing forever
          return ch
    '|
  }
  correct_code: {
    label: "CORRECT advance() — fix"
    width: 380
    code: |'python
      def advance(self) -> str:
          ch = self.source[self.current]
          self.current += 1
          if ch == '\n':
              self.line += 1
              self.column = 1   # RESET on newline
          else:
              self.column += 1  # only increment on non-newline
          return ch
    '|
  }
}
annotation: "Position tracking errors are invisible in unit tests of single tokens but compound across multi-line inputs. Integration tests with exact position assertions are the only defense." {
  style: {
    fill: "#1a237e"
    stroke: "#3F51B5"
    stroke-width: 2
    border-radius: 8
    font-color: white
    bold: true
  }
  width: 860
}
input_block -> row_line1: "scan char by char"
row_line1 -> diverge1: "after consuming '\\n'"
diverge1 -> row_line2: "continue scanning"
row_line2 -> diverge2: "after second '\\n'"
diverge2 -> row_line3: "continue scanning"
row_line3 -> fix_block: "diagnose"
fix_block -> annotation: "lesson"