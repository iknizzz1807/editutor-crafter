direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Formal Language Hierarchy: Where the Lexer Ends and the Parser Begins"
  style: {
    font-size: 18
    bold: true
    fill: transparent
    stroke: transparent
  }
}
title.near: top-center
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hierarchy: "Chomsky Hierarchy (Expressive Power)" {
    direction: down
    style.fill: "#f0f4ff"
    style.stroke: "#3a4db8"
    style.stroke-width: 2
    style.border-radius: 12
    cs_layer: "Context-Sensitive & Unrestricted Languages" {
      direction: down
      style.fill: "#ffeaea"
      style.stroke: "#cc0000"
      style.stroke-width: 2
      style.border-radius: 8
      cs_annot: {
        shape: sql_table
        label: "Context-Sensitive Examples (beyond parsers)"
        r1: "Type checking: variable declared before use"
        r2: "Overload resolution: which f() to call"
        r3: "Lifetime analysis (Rust borrow checker)"
        r4: "Cross-module name resolution"
      }
      cf_layer: "Context-Free Languages — PARSER territory" {
        direction: down
        style.fill: "#fff8e6"
        style.stroke: "#e67e00"
        style.stroke-width: 2
        style.border-radius: 8
        cf_annot: {
          shape: sql_table
          label: "Context-Free Constructs (need a stack / recursion)"
          r1: "( expr )  ← balanced parentheses — requires counter"
          r2: "{ stmt* } ← brace blocks — arbitrary nesting depth"
          r3: "if cond { A } else { B } ← nested if/else matching"
          r4: "f(g(h(x))) ← nested function calls"
          r5: "expr := term ((+ | -) term)* ← recursive grammar rules"
          r6: "/* */ nesting (D-lang) ← depth counter required"
          r7: "Why CF? Matching brackets needs unbounded stack memory"
        }
        reg_layer: "Regular Languages — LEXER territory" {
          direction: down
          style.fill: "#e8f8e8"
          style.stroke: "#1a7a1a"
          style.stroke-width: 3
          style.border-radius: 8
          reg_annot: {
            shape: sql_table
            label: "Regular Constructs (DFA / finite state — no stack needed)"
            r1: "IDENTIFIER   [a-zA-Z_][a-zA-Z0-9_]*   e.g. my_var, _count"
            r2: "NUMBER       [0-9]+(.[0-9]+)?          e.g. 42, 3.14"
            r3: "STRING       \"(escape | [^\"\n])*\"   e.g. \"hello\\nworld\""
            r4: "KEYWORD      fixed set lookup in dict  e.g. if, while, return"
            r5: "OPERATOR     = == != < <= > >= + - * /  maximal munch"
            r6: "PUNCTUATION  ( ) { } [ ] ; ,           single-char dispatch"
            r7: "LINE COMMENT // [^\n]*                  discard till newline"
            r8: "BLOCK COMMENT /* [^*/]* */              non-nesting only"
            r9: "Why Regular? DFA has FINITE states — no counter, no stack"
            r10: "Complexity: O(n) time, O(1) extra memory — linear scan"
          }
        }
      }
    }
  }
  insight: "Key Design Principle" {
    direction: down
    style.fill: "#1a1a2e"
    style.stroke: "#6c63ff"
    style.stroke-width: 3
    style.border-radius: 12
    width: 360
    ins1: {
      shape: sql_table
      label: "Why the Lexer Stops at Regular Languages"
      r1: "Regular = DFA recognizable = O(n) guaranteed"
      r2: "DFA: finite states, no stack, no backtracking"
      r3: "Each char visited EXACTLY ONCE by advance()"
      r4: "peek() = 1-char lookahead = still O(1) memory"
      r5: "This is NOT a limitation — it is a guarantee"
      style.stroke: "#6c63ff"
      style.fill: "#2d2d4e"
      style.font-color: "#e0e0ff"
    }
    boundary_rule: {
      shape: sql_table
      label: "The Boundary Rule (memorize this)"
      r1: "Lexer handles: flat patterns, no counting, no nesting"
      r2: "Parser handles: matching, nesting, recursion"
      r3: "Signal: if you need a counter -> parser territory"
      r4: "Signal: if you need a stack  -> parser territory"
      r5: "Signal: if a loop suffices   -> lexer territory"
      style.stroke: "#6c63ff"
      style.fill: "#2d2d4e"
      style.font-color: "#e0e0ff"
    }
    pumping: {
      shape: sql_table
      label: "Pumping Lemma (Formal Proof Sketch)"
      r1: "Balanced parens NOT regular — proved by Pumping Lemma"
      r2: "Assume DFA with k states recognizes balanced parens"
      r3: "Feed (^(k+1) )^(k+1) — by pigeonhole, a state repeats"
      r4: "Pump the repeated segment -> unbalanced string accepted"
      r5: "Contradiction. Balanced parens is context-free, not regular"
      style.stroke: "#cc0000"
      style.fill: "#2d1a1a"
      style.font-color: "#ffe0e0"
    }
  }
}
concrete: "Concrete Examples: Same Token, Different Territory" {
  direction: right
  style.fill: "#f8f8f8"
  style.stroke: "#888888"
  style.border-radius: 8
  reg_ex: "LEXER handles (Regular)" {
    direction: down
    style.fill: "#e8f8e8"
    style.stroke: "#1a7a1a"
    style.border-radius: 6
    ex1: {
      shape: sql_table
      label: "Input: if (x >= 42) { return true; }"
      r1: "KEYWORD('if')      line=1 col=1   — dict lookup"
      r2: "LPAREN('(')        line=1 col=4   — single char"
      r3: "IDENTIFIER('x')    line=1 col=5   — letter loop"
      r4: "GREATER_EQUAL('>=')line=1 col=7   — maximal munch"
      r5: "NUMBER('42')       line=1 col=10  — digit loop"
      r6: "RPAREN(')')        line=1 col=12  — single char"
      r7: "LBRACE('{')        line=1 col=14  — single char"
      r8: "KEYWORD('return')  line=1 col=16  — dict lookup"
      r9: "KEYWORD('true')    line=1 col=23  — dict lookup"
      r10: "SEMICOLON(';')    line=1 col=27  — single char"
      r11: "RBRACE('}')       line=1 col=29  — single char"
      r12: "Each token: one forward pass, no backtracking"
    }
  }
  cf_ex: "PARSER handles (Context-Free)" {
    direction: down
    style.fill: "#fff8e6"
    style.stroke: "#e67e00"
    style.border-radius: 6
    ex2: {
      shape: sql_table
      label: "Parser receives token stream, builds AST"
      r1: "IfStmt → KEYWORD('if') LPAREN Expr RPAREN Block"
      r2: "Block  → LBRACE Stmt* RBRACE  ← recursive rule"
      r3: "Expr   → Expr GREATER_EQUAL Expr ← left-recursive"
      r4: "Parser CHECKS: does LPAREN match RPAREN?"
      r5: "Parser CHECKS: does LBRACE match RBRACE?"
      r6: "Parser uses call STACK for recursive rules"
      r7: "Unbalanced { } → parser error, NOT lexer error"
      r8: "Lexer emits all tokens even if unbalanced"
    }
  }
}
impossible_ex: "What the Lexer CANNOT Do (by mathematical necessity)" {
  direction: right
  style.fill: "#ffeaea"
  style.stroke: "#cc0000"
  style.border-radius: 8
  cant1: {
    shape: sql_table
    label: "Cannot: Detect unbalanced parentheses"
    r1: "((( — lexer emits 3 LPAREN tokens, no error"
    r2: "Detecting imbalance needs a counter (unbounded)"
    r3: "Unbounded counter = not a DFA = not regular"
    r4: "Fix: parser checks balance using call stack"
  }
  cant2: {
    shape: sql_table
    label: "Cannot: Detect keyword used as variable"
    r1: "if = 42; — lexer emits KEYWORD ASSIGN NUMBER"
    r2: "Legality of assignment to keyword is semantic"
    r3: "Fix: semantic analysis checks symbol table"
  }
  cant3: {
    shape: sql_table
    label: "Cannot: Match closing */ to opening /*"
    r1: "/* a /* b */ — lexer closes at FIRST */"
    r2: "Nesting would need depth counter (not regular)"
    r3: "Design choice: non-nesting keeps comments regular"
    r4: "/* */ non-nesting = O(n) scan guaranteed"
  }
}
row1.hierarchy -> insight: "Lexer lives here" {
  style.stroke: "#1a7a1a"
  style.stroke-width: 2
}
reg_ex -> cf_ex: "Token stream" {
  style.stroke: "#3a4db8"
  style.stroke-width: 2
  style.animated: true
}
row1 -> concrete: "applied to real code"
concrete -> impossible_ex: "boundary violations"