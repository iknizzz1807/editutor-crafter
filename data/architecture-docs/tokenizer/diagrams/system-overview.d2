direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# ROW 0 — Data Model Layer
# ─────────────────────────────────────────────────────────────────────────────
row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  token_type: {
    shape: sql_table
    label: "enum TokenType  (scanner.py)  [M1]"
    NUMBER: "auto()  | integer or float literal"
    STRING: "auto()  | double-quoted string"
    IDENTIFIER: "auto()  | user-defined name"
    KEYWORD: "auto()  | reserved word"
    PLUS: "auto()  | +"
    MINUS: "auto()  | -"
    STAR: "auto()  | *"
    SLASH: "auto()  | /"
    ASSIGN: "auto()  | ="
    EQUAL_EQUAL: "auto()  | =="
    BANG_EQUAL: "auto()  | !="
    LESS: "auto()  | <"
    LESS_EQUAL: "auto()  | <="
    GREATER: "auto()  | >"
    GREATER_EQUAL: "auto()  | >="
    LPAREN: "auto()  | ("
    RPAREN: "auto()  | )"
    LBRACE: "auto()  | {"
    RBRACE: "auto()  | }"
    LBRACKET: "auto()  | ["
    RBRACKET: "auto()  | ]"
    SEMICOLON: "auto()  | ;"
    COMMA: "auto()  | ,"
    EOF: "auto()  | end-of-stream sentinel"
    ERROR: "auto()  | unrecognized / lexical error"
    total: "26 variants — Enum(int)"
  }
  token_struct: {
    shape: sql_table
    label: "dataclass Token  (scanner.py)  [M1]"
    type: "TokenType  | category"
    lexeme: "str        | raw source slice"
    line: "int        | 1-based line of first char"
    column: "int        | 1-based col of first char"
    repr: "__repr__() | Token(NAME,'lex',L:C)"
    eq: "__eq__()   | @dataclass auto-generated"
    note: "~56 bytes CPython; immutable after init"
  }
  constants: {
    shape: sql_table
    label: "Module Constants  (scanner.py)  [M1-M3]"
    SINGLE_CHAR_TOKENS: "dict[str,TokenType] | 12 entries M3"
    WHITESPACE: "frozenset[str]      | space tab CR LF"
    KEYWORDS: "dict[str,TokenType] | 7 reserved words [M2]"
    VALID_ESCAPE_CHARS: "frozenset[str]      | n t r double-quote backslash [M3]"
    note: "All O(1) lookup via Python hash"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# ROW 1 — Scanner Core Primitives
# ─────────────────────────────────────────────────────────────────────────────
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scanner_state: {
    shape: sql_table
    label: "class Scanner — State Fields  (scanner.py)  [M1]"
    source: "str          | full source text (immutable)"
    start: "int          | index of first char of current token"
    current: "int          | index of next char to read"
    line: "int          | current line 1-based"
    column: "int          | current column 1-based"
    token_start_line: "int          | snapshot at _begin_token()"
    token_start_column: "int          | snapshot at _begin_token()"
    tokens: "list[Token]  | grows monotonically"
    note: "Single-use per instance; O(n) total"
  }
  scanner_primitives: {
    shape: class
    label: "Scanner — Primitives  (scanner.py)  [M1]"
    +is_at_end(): "bool"
    +advance(): "str"
    +peek(): "str"
    +_peek_next(): "str"
    +_match(expected): "bool"
    +_begin_token(): "None"
    +_current_lexeme(): "str"
    +_make_token(token_type): "Token"
    +_error_token(message): "Token"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# ROW 2 — Scanner Scanning Methods
# ─────────────────────────────────────────────────────────────────────────────
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scanner_dispatch: {
    shape: class
    label: "Scanner — Dispatch  (scanner.py)  [M1-M3]"
    +scan_tokens(): "list[Token]"
    -_scan_token(): "None"
  }
  scanner_m2: {
    shape: class
    label: "Scanner — M2 Scanners  (scanner.py)  [M2]"
    -_scan_number(): "None"
    -_scan_identifier(): "None"
  }
  scanner_m3: {
    shape: class
    label: "Scanner — M3 Scanners  (scanner.py)  [M3]"
    -_scan_string(): "None"
    -_scan_line_comment(): "None"
    -_scan_block_comment(): "None"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# ROW 3 — FSM / Algorithm Detail
# ─────────────────────────────────────────────────────────────────────────────
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fsm_dispatch: {
    shape: sql_table
    label: "_scan_token() Dispatch Order  [M1-M3]"
    p1: "1 | WHITESPACE — consume discard"
    p2: "2 | ch==  equals two-char ops M2"
    p3: "3 | ch == slash  div or comment M3"
    p4: "4 | ch == quote  string literal M3"
    p5: "5 | SINGLE_CHAR_TOKENS dict lookup"
    p6: "6 | ch.isdigit()  number scan M2"
    p7: "7 | ch.isalpha() or _  identifier M2"
    p8: "8 | fallthrough  ERROR token"
    note: "Order is correctness invariant — not style"
  }
  fsm_number: {
    shape: sql_table
    label: "_scan_number() FSM  [M2]"
    s1: "INTEGER | consume digits via peek loop"
    s2: "GUARD   | peek=='.' AND _peek_next().isdigit()"
    s3: "FLOAT   | consume '.' then more digits"
    s4: "EMIT    | NUMBER token via _make_token()"
    policy1: "3.  -> NUMBER(3) + ERROR('.')  no trailing dot"
    policy2: ".5  -> ERROR('.') + NUMBER(5)  no leading dot"
    policy3: "42abc -> NUMBER(42)+IDENTIFIER(abc)"
    note: "2-char lookahead only for decimal guard"
  }
  fsm_identifier: {
    shape: sql_table
    label: "_scan_identifier() + Keyword Lookup  [M2]"
    s1: "SCAN  | while isalpha or isdigit or _"
    s2: "SLICE | text = source[start:current]"
    s3: "LOOK  | KEYWORDS.get(text, IDENTIFIER)"
    s4: "EMIT  | KEYWORD or IDENTIFIER token"
    inv: "Invariant: lookup AFTER full word scanned"
    ex1: "iffy  -> IDENTIFIER not KEYWORD(if)+err"
    ex2: "returning -> IDENTIFIER not KEYWORD(return)"
    note: "O(k) scan + O(1) dict hash lookup"
  }
  fsm_string: {
    shape: sql_table
    label: "_scan_string() FSM  [M3]"
    s1: "IN_STRING  | normal char — continue"
    s2: "ON_QUOTE   | closing quote — emit STRING"
    s3: "ON_NEWLINE | unterminated — emit ERROR return"
    s4: "ON_ESCAPE  | consume next as escape code"
    s5: "BAD_ESCAPE | unknown escape — ERROR continue"
    s6: "ON_EOF     | unterminated — emit ERROR"
    pos: "Error position = opening quote token_start_*"
    note: "Lexeme is raw source incl quotes"
  }
  fsm_comment: {
    shape: sql_table
    label: "_scan_line_comment + _scan_block_comment  [M3]"
    lc1: "LINE  | advance while peek != newline"
    lc2: "LINE  | newline NOT consumed — left for loop"
    bc1: "BLOCK | peek=='*' consume then peek==slash"
    bc2: "BLOCK | if slash consume return success"
    bc3: "BLOCK | else continue outer loop"
    bc4: "BLOCK | is_at_end — emit ERROR at open slash"
    iso: "Mode isolation: slash-slash inside string = content"
    note: "Non-nesting: first star-slash closes comment"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# ROW 4 — Test Files
# ─────────────────────────────────────────────────────────────────────────────
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tests_m1: {
    shape: sql_table
    label: "M1 Test Files  [M1]"
    f1: "test_m1_types.py      | TokenType + Token dataclass"
    f2: "test_m1_scanner.py    | is_at_end advance peek"
    f3: "test_m1_integration.py | scan_tokens full stream"
    tc1: "empty input -> [EOF(1:1)]"
    tc2: "+ - * / ( ) -> correct types + positions"
    tc3: "ERROR on @ continues scanning"
    tc4: "windows CRLF counted as one newline"
  }
  tests_m2: {
    shape: sql_table
    label: "M2 Test Files  [M2]"
    f1: "test_m2_operators.py   | == != <= >= maximal munch"
    f2: "test_m2_numbers.py     | int float edge cases"
    f3: "test_m2_identifiers.py | keyword prefix collision"
    f4: "test_m2_integration.py | if (x >= 42) exact stream"
    tc1: "geq_assign: ">=="  -> GREATER_EQUAL + ASSIGN"
    tc2: "iffy -> IDENTIFIER not KEYWORD+error"
    tc3: "3. -> NUMBER(3) + ERROR(.)"
  }
  tests_m3: {
    shape: sql_table
    label: "M3 Test Files  [M3]"
    f1: "test_m3_strings.py    | valid escapes unterminated"
    f2: "test_m3_comments.py   | line block non-nesting"
    f3: "test_m3_integration.py | comments inside strings"
    tc1: '"hello // world"  -> 1 STRING token'
    tc2: "unterminated at newline -> ERROR at open quote"
    tc3: "block comment EOF -> ERROR at open slash"
  }
  tests_m4: {
    shape: sql_table
    label: "M4 Test Files  [M4]"
    f1: "test_m4_canonical.py        | exact 11-token stream"
    f2: "test_m4_integration.py      | 13-line Fibonacci"
    f3: "test_m4_error_recovery.py   | all errors collected"
    f4: "test_m4_edge_cases.py       | empty 1000-char id"
    f5: "test_m4_position_accuracy.py | 50-line drift test"
    f6: "test_m4_performance.py       | 10K lines under 1s"
    tc1: "O(n) ratio check 1K->10K->100K < 15x"
    tc2: "scan_tokens always ends with exactly one EOF"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# ROW 5 — Pipeline and Position Tracking Invariants
# ─────────────────────────────────────────────────────────────────────────────
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  position_rules: {
    shape: sql_table
    label: "Position Tracking Invariants  [M1-M3]"
    r1: "advance() is SOLE updater of line and column"
    r2: "newline -> line+=1; column=1"
    r3: "carriage return -> column+=1; line unchanged"
    r4: "tab -> column+=1 (1 column not tab-stop width)"
    r5: "token_start_* frozen at _begin_token() call"
    r6: "ERROR position = token_start_* not current"
    r7: "EOF position = self.line self.column post-consume"
    note: "Drift detected by 50-line semicolon column test"
  }
  maximal_munch: {
    shape: sql_table
    label: "Maximal Munch Rules  [M2]"
    rule: "Always prefer longest valid token at position"
    eq: "= -> ASSIGN; == -> EQUAL_EQUAL via _match"
    bang: "! alone -> ERROR; != -> BANG_EQUAL"
    lt: "< -> LESS; <= -> LESS_EQUAL"
    gt: "> -> GREATER; >= -> GREATER_EQUAL"
    slash: "/ -> SLASH; // -> line comment; /* -> block"
    order: "Two-char checks BEFORE SINGLE_CHAR_TOKENS dict"
    note: "No backtracking; max 2-char lookahead"
  }
  error_recovery: {
    shape: sql_table
    label: "Error Recovery Contract  [M1-M4]"
    r1: "Never raise exception for lexical error"
    r2: "Emit ERROR token then continue main loop"
    r3: "Multiple errors collected in one pass"
    r4: "Unterminated string: ERROR at opening quote"
    r5: "Unterminated block: ERROR at opening slash"
    r6: "Bad escape: ERROR + continue to closing quote"
    r7: "scan_tokens always ends with exactly one EOF"
    note: "Enables all-errors-in-one-pass developer UX"
  }
  pipeline: {
    shape: sql_table
    label: "Lexer Pipeline Position  [M1-M4]"
    input: "str  | raw source text (Python str)"
    output: "list[Token] | structured categorized stream"
    guarantee: "Every char visited exactly once O(n)"
    eof_role: "Sentinel for downstream parser termination"
    no_recursion: "Regular language — while loop not recursive"
    boundary: "Stops at balanced delimiter counting -> parser"
    note: "100K+ chars/sec CPython; algorithmic O(n)"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# Milestone Index
# ─────────────────────────────────────────────────────────────────────────────
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | tokenizer-m1 | TokenType Token Scanner primitives scan_tokens"
  m2: "M2 | tokenizer-m2 | _match _peek_next _scan_number _scan_identifier KEYWORDS"
  m3: "M3 | tokenizer-m3 | _scan_string _scan_line_comment _scan_block_comment"
  m4: "M4 | tokenizer-m4 | Integration tests error recovery position accuracy perf"
}
# ─────────────────────────────────────────────────────────────────────────────
# Edges — Data Model
# ─────────────────────────────────────────────────────────────────────────────
row0.token_type -> row0.token_struct: "TokenType | field type"
row0.token_struct -> row0.constants: "references"
row0.token_type -> row0.constants: "dict values"
# Scanner state uses Token
row0.token_struct -> row1.scanner_state: "list[Token] | tokens field"
row0.token_type -> row1.scanner_state: "TokenType | _make_token arg"
# Primitives operate on state
row1.scanner_state -> row1.scanner_primitives: "reads/writes"
# Dispatch uses primitives
row1.scanner_primitives -> row2.scanner_dispatch: "advance peek match"
row0.constants -> row2.scanner_dispatch: "SINGLE_CHAR_TOKENS | WHITESPACE"
# M2 scanners use primitives
row1.scanner_primitives -> row2.scanner_m2: "peek _peek_next advance"
row0.constants -> row2.scanner_m2: "KEYWORDS | lookup"
# M3 scanners use primitives + constants
row1.scanner_primitives -> row2.scanner_m3: "advance peek is_at_end"
row0.constants -> row2.scanner_m3: "VALID_ESCAPE_CHARS"
# Dispatch calls sub-scanners
row2.scanner_dispatch -> row2.scanner_m2: "calls"
row2.scanner_dispatch -> row2.scanner_m3: "calls"
# FSM detail nodes
row2.scanner_dispatch -> row3.fsm_dispatch: "implements"
row2.scanner_m2 -> row3.fsm_number: "implements"
row2.scanner_m2 -> row3.fsm_identifier: "implements"
row2.scanner_m3 -> row3.fsm_string: "implements"
row2.scanner_m3 -> row3.fsm_comment: "implements"
# Tests validate implementation
row2.scanner_dispatch -> row4.tests_m1: "tested by"
row2.scanner_m2 -> row4.tests_m2: "tested by"
row2.scanner_m3 -> row4.tests_m3: "tested by"
row4.tests_m1 -> row4.tests_m4: "regression"
row4.tests_m2 -> row4.tests_m4: "regression"
row4.tests_m3 -> row4.tests_m4: "regression"
# Invariants cross-cut
row1.scanner_primitives -> row5.position_rules: "advance() rule"
row3.fsm_dispatch -> row5.maximal_munch: "dispatch order"
row2.scanner_dispatch -> row5.error_recovery: "scan_tokens contract"
row2.scanner_dispatch -> row5.pipeline: "public API"
# Token struct flows to pipeline
row0.token_struct -> row5.pipeline: "Token | output element"