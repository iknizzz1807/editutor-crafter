vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # TokenType Enumeration — All 26 Variants
  **Architecture: Complete Enum with Milestone Production Map**
| {near: top-center}
legend: |md
  🟢 Produced in M1  🔵 Produced in M2  🟣 Produced in M3  ⬜ Declared M1, emitted later
| {near: bottom-center}
TokenType: {
  style.fill: "#1a1a2e"
  style.stroke: "#7c3aed"
  style.stroke-width: 2
  style.font-color: white
  style.bold: true
  literals: "LITERALS" {
    style.fill: "#1e3a5f"
    style.stroke: "#3b82f6"
    style.stroke-width: 2
    style.font-color: "#93c5fd"
    style.bold: true
    NUMBER: |md
      **NUMBER** = auto()
      `42` `0` `3.14`
      ⬜ declared M1 → 🔵 emitted M2
    | {
      style.fill: "#1e40af"
      style.stroke: "#3b82f6"
      style.font-color: white
    }
    STRING: |md
      **STRING** = auto()
      `"hello world"`
      ⬜ declared M1 → 🟣 emitted M3
    | {
      style.fill: "#1e40af"
      style.stroke: "#3b82f6"
      style.font-color: white
    }
  }
  names: "NAMES" {
    style.fill: "#1e3a5f"
    style.stroke: "#3b82f6"
    style.stroke-width: 2
    style.font-color: "#93c5fd"
    style.bold: true
    IDENTIFIER: |md
      **IDENTIFIER** = auto()
      `x` `my_var` `_count`
      ⬜ declared M1 → 🔵 emitted M2
    | {
      style.fill: "#1e40af"
      style.stroke: "#3b82f6"
      style.font-color: white
    }
    KEYWORD: |md
      **KEYWORD** = auto()
      `if` `else` `while`
      `return` `true` `false` `null`
      ⬜ declared M1 → 🔵 emitted M2
    | {
      style.fill: "#1e40af"
      style.stroke: "#3b82f6"
      style.font-color: white
    }
  }
  arithmetic: "ARITHMETIC OPERATORS" {
    style.fill: "#1a2e1e"
    style.stroke: "#22c55e"
    style.stroke-width: 2
    style.font-color: "#86efac"
    style.bold: true
    PLUS: |md
      **PLUS** = auto()
      `+`
      🟢 M1
    | {
      style.fill: "#14532d"
      style.stroke: "#22c55e"
      style.font-color: white
    }
    MINUS: |md
      **MINUS** = auto()
      `-`
      🟢 M1
    | {
      style.fill: "#14532d"
      style.stroke: "#22c55e"
      style.font-color: white
    }
    STAR: |md
      **STAR** = auto()
      `*`
      🟢 M1
    | {
      style.fill: "#14532d"
      style.stroke: "#22c55e"
      style.font-color: white
    }
    SLASH: |md
      **SLASH** = auto()
      `/`
      🟢 M1 → removed M3
    | {
      style.fill: "#14532d"
      style.stroke: "#22c55e"
      style.font-color: white
    }
  }
  comparison: "COMPARISON / ASSIGNMENT" {
    style.fill: "#2e1a1e"
    style.stroke: "#f59e0b"
    style.stroke-width: 2
    style.font-color: "#fcd34d"
    style.bold: true
    ASSIGN: |md
      **ASSIGN** = auto()
      `=`
      🟢 M1 (single-char)
      🔵 M2 (lookahead)
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
    EQUAL_EQUAL: |md
      **EQUAL_EQUAL** = auto()
      `==`
      🔵 M2 — maximal munch
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
    BANG_EQUAL: |md
      **BANG_EQUAL** = auto()
      `!=`
      🔵 M2 — maximal munch
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
    LESS: |md
      **LESS** = auto()
      `<`
      🔵 M2 — lookahead
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
    LESS_EQUAL: |md
      **LESS_EQUAL** = auto()
      `<=`
      🔵 M2 — maximal munch
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
    GREATER: |md
      **GREATER** = auto()
      `>`
      🔵 M2 — lookahead
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
    GREATER_EQUAL: |md
      **GREATER_EQUAL** = auto()
      `>=`
      🔵 M2 — maximal munch
    | {
      style.fill: "#78350f"
      style.stroke: "#f59e0b"
      style.font-color: white
    }
  }
  punctuation: "PUNCTUATION / GROUPING" {
    style.fill: "#1e1e3a"
    style.stroke: "#8b5cf6"
    style.stroke-width: 2
    style.font-color: "#c4b5fd"
    style.bold: true
    LPAREN: |md
      **LPAREN** = auto()
      `(`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    RPAREN: |md
      **RPAREN** = auto()
      `)`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    LBRACE: |md
      **LBRACE** = auto()
      `{`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    RBRACE: |md
      **RBRACE** = auto()
      `}`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    LBRACKET: |md
      **LBRACKET** = auto()
      `[`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    RBRACKET: |md
      **RBRACKET** = auto()
      `]`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    SEMICOLON: |md
      **SEMICOLON** = auto()
      `;`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
    COMMA: |md
      **COMMA** = auto()
      `,`  🟢 M1
    | {
      style.fill: "#4c1d95"
      style.stroke: "#8b5cf6"
      style.font-color: white
    }
  }
  sentinels: "SENTINELS" {
    style.fill: "#2e1e1e"
    style.stroke: "#ef4444"
    style.stroke-width: 2
    style.font-color: "#fca5a5"
    style.bold: true
    EOF: |md
      **EOF** = auto()
      `lexeme=""` always last token
      Parser end-of-stream signal
      🟢 M1
    | {
      style.fill: "#7f1d1d"
      style.stroke: "#ef4444"
      style.font-color: white
    }
    ERROR: |md
      **ERROR** = auto()
      Unrecognized char / lexical error
      Enables error recovery — scan continues
      🟢 M1
    | {
      style.fill: "#7f1d1d"
      style.stroke: "#ef4444"
      style.font-color: white
    }
  }
}
milestone_map: "MILESTONE PRODUCTION SUMMARY" {
  style.fill: "#0f172a"
  style.stroke: "#475569"
  style.stroke-width: 1
  style.font-color: "#94a3b8"
  m1: |md
    **M1 — Foundation (13 types produced)**
    PLUS MINUS STAR SLASH ASSIGN
    LPAREN RPAREN LBRACE RBRACE
    LBRACKET RBRACKET SEMICOLON COMMA
    EOF ERROR
    *All 26 types declared in M1 enum*
  | {
    style.fill: "#14532d"
    style.stroke: "#22c55e"
    style.font-color: white
  }
  m2: |md
    **M2 — Multi-char & Identifiers (adds 9)**
    EQUAL_EQUAL BANG_EQUAL LESS LESS_EQUAL
    GREATER GREATER_EQUAL
    NUMBER IDENTIFIER KEYWORD
    *ASSIGN now via lookahead; = removed from SINGLE_CHAR_TOKENS*
  | {
    style.fill: "#1e3a5f"
    style.stroke: "#3b82f6"
    style.font-color: white
  }
  m3: |md
    **M3 — Strings & Comments (adds 1)**
    STRING
    */ removed from SINGLE_CHAR_TOKENS*
    *Comments produce 0 tokens*
  | {
    style.fill: "#4c1d95"
    style.stroke: "#8b5cf6"
    style.font-color: white
  }
  m1 -> m2: "extends" { style.stroke: "#64748b"; style.stroke-dash: 3 }
  m2 -> m3: "extends" { style.stroke: "#64748b"; style.stroke-dash: 3 }
}
sizing_note: |md
  **sizeof(Token) = 4 fields**
  `type: TokenType` — enum member
  `lexeme: str` — raw source slice O(k)
  `line: int` — 1-based, ≥ 1
  `column: int` — 1-based, ≥ 1, resets after \n
| {
  near: bottom-right
  style.fill: "#0f172a"
  style.stroke: "#334155"
  style.font-color: "#94a3b8"
}