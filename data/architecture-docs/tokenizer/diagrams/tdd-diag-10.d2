vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `_match(expected)` — Conditional Consume Data Flow
  Invariant: `advance()` is the **only** path that mutates `current`, `line`, `column`
| {near: top-center}
# ─────────────────────────────────────────────────────────────────────────────
# CALLER CONTEXT
# ─────────────────────────────────────────────────────────────────────────────
caller: "_scan_token() calls _match('=')" {
  style.fill: "#E8EAF6"
  style.stroke: "#5C6BC0"
  style.border-radius: 8
  state_before: |md
    **Scanner state BEFORE call**
    `source  = ">=42"`
    `start   = 0`  → points to `>`
    `current = 1`  → points to `=`  ← next char
    `line    = 1`
    `column  = 2`  (after consuming `>`)
  | {
    style.fill: "#C5CAE9"
    style.stroke: "#5C6BC0"
    shape: rectangle
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# _match() INTERNALS — main flow
# ─────────────────────────────────────────────────────────────────────────────
match_fn: "_match(expected='=')" {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.border-radius: 8
  step1: "Step 1\nis_at_end()?" {
    shape: diamond
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
  }
  step2: "Step 2\nsource[current] != expected?" {
    shape: diamond
    style.fill: "#CE93D8"
    style.stroke: "#7B1FA2"
  }
  step3: "Step 3\ncall advance()" {
    style.fill: "#AB47BC"
    style.stroke: "#6A1B9A"
    style.font-color: white
    style.bold: true
  }
  step4: "Step 4\nreturn True" {
    style.fill: "#4CAF50"
    style.stroke: "#1B5E20"
    style.font-color: white
    style.bold: true
  }
  ret_false_eof: "return False\n(at end)" {
    style.fill: "#EF9A9A"
    style.stroke: "#B71C1C"
    style.bold: true
  }
  ret_false_mismatch: "return False\n(mismatch)" {
    style.fill: "#EF9A9A"
    style.stroke: "#B71C1C"
    style.bold: true
  }
  step1 -> ret_false_eof: "True (at end)" {
    style.stroke: "#B71C1C"
    style.font-color: "#B71C1C"
  }
  step1 -> step2: "False (not at end)" {
    style.stroke: "#388E3C"
    style.font-color: "#388E3C"
  }
  step2 -> ret_false_mismatch: "True (char ≠ expected)" {
    style.stroke: "#B71C1C"
    style.font-color: "#B71C1C"
  }
  step2 -> step3: "False (char == expected)" {
    style.stroke: "#388E3C"
    style.font-color: "#388E3C"
  }
  step3 -> step4
}
# ─────────────────────────────────────────────────────────────────────────────
# advance() INTERNALS (called from Step 3)
# ─────────────────────────────────────────────────────────────────────────────
advance_fn: "advance()  ← sole mutator of cursor + position" {
  style.fill: "#FFF8E1"
  style.stroke: "#F57F17"
  style.border-radius: 8
  read: "ch = source[current]\n(reads '=' here)" {
    style.fill: "#FFE082"
    style.stroke: "#F9A825"
  }
  inc_cur: "current += 1\n→ current becomes 2" {
    style.fill: "#FFB300"
    style.stroke: "#E65100"
    style.font-color: white
    style.bold: true
  }
  nl_check: "ch == '\\n'?" {
    shape: diamond
    style.fill: "#FFE082"
    style.stroke: "#F9A825"
  }
  inc_line: "line += 1\ncolumn = 1" {
    style.fill: "#FF8F00"
    style.stroke: "#E65100"
    style.font-color: white
  }
  inc_col: "column += 1\n→ column becomes 3" {
    style.fill: "#FF8F00"
    style.stroke: "#E65100"
    style.font-color: white
  }
  ret_ch: "return '='" {
    style.fill: "#FFE082"
    style.stroke: "#F9A825"
  }
  read -> inc_cur
  inc_cur -> nl_check
  nl_check -> inc_line: "yes" {style.stroke: "#B71C1C"}
  nl_check -> inc_col: "no" {style.stroke: "#388E3C"}
  inc_line -> ret_ch
  inc_col -> ret_ch
}
# ─────────────────────────────────────────────────────────────────────────────
# STATE AFTER
# ─────────────────────────────────────────────────────────────────────────────
state_after: |md
  **Scanner state AFTER _match('=') → True**
  `source  = ">=42"`
  `start   = 0`  unchanged
  `current = 2`  → now points to `4`
  `line    = 1`  unchanged
  `column  = 3`  (advanced past `=`)
  `_current_lexeme() = ">="  ✓`
| {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.border-radius: 8
}
# ─────────────────────────────────────────────────────────────────────────────
# ANTI-PATTERN PANEL (raw current increment)
# ─────────────────────────────────────────────────────────────────────────────
antipattern: "❌  ANTI-PATTERN: raw current increment" {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.border-radius: 8
  bad_code: |go
    // WRONG — bypasses position tracking
    if source[current] == expected {
        current += 1   // column NOT updated!
        return true
    }
  | {style.fill: "#FFCDD2"}
  bad_consequence: |md
    **Consequence:**
    `column` stays at **2** instead of **3**
    After 5 such calls → column off by **5**
    Error messages point to **wrong location**
    IDE highlights **wrong token**
  | {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  bad_code -> bad_consequence: "leads to"  {
    style.stroke: "#C62828"
    style.font-color: "#C62828"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# EQUIVALENT PATTERN (peek + advance separately)
# ─────────────────────────────────────────────────────────────────────────────
equiv: "✓  Equivalent (but verbose) — peek() then advance()" {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.border-radius: 8
  equiv_code: |go
    // CORRECT but verbose — _match() wraps this atomically
    if peek() == expected {
        advance()      // position tracking preserved ✓
        return true
    }
    return false
  | {style.fill: "#C8E6C9"}
  equiv_note: |md
    `_match()` makes this **atomic** and **names the intent**:
    *"try to consume exactly this character"*
    Callers cannot forget the `advance()` call.
  | {
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  equiv_code -> equiv_note: "documents intent" {
    style.stroke: "#2E7D32"
    style.font-color: "#2E7D32"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# USAGE EXAMPLES IN _scan_token()
# ─────────────────────────────────────────────────────────────────────────────
usage: "Usage in _scan_token() — all two-char operators" {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.border-radius: 8
  eq: "ch == '='\n_match('=') → EQUAL_EQUAL\nelse → ASSIGN" {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  bang: "ch == '!'\n_match('=') → BANG_EQUAL\nelse → ERROR" {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  lt: "ch == '<'\n_match('=') → LESS_EQUAL\nelse → LESS" {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
  gt: "ch == '>'\n_match('=') → GREATER_EQUAL\nelse → GREATER" {
    style.fill: "#BBDEFB"
    style.stroke: "#1565C0"
  }
}
# ─────────────────────────────────────────────────────────────────────────────
# INVARIANT BOX
# ─────────────────────────────────────────────────────────────────────────────
invariant: |md
  **Core Invariant**
  `advance()` is the **sole and exclusive** updater of
  `self.current`, `self.line`, `self.column`.
  No code path may do `self.current += 1` directly.
  `_match()` enforces this by always delegating to `advance()`.
| {
  near: bottom-center
  style.fill: "#37474F"
  style.font-color: white
  style.border-radius: 8
  style.bold: true
}
# ─────────────────────────────────────────────────────────────────────────────
# CONNECTIONS
# ─────────────────────────────────────────────────────────────────────────────
caller.state_before -> match_fn.step1: "calls _match('=')" {
  style.stroke: "#5C6BC0"
  style.bold: true
}
match_fn.step3 -> advance_fn.read: "delegates to advance()\n— never raw current++" {
  style.stroke: "#7B1FA2"
  style.bold: true
  style.stroke-width: 3
}
advance_fn.ret_ch -> match_fn.step4: "ch consumed\nstate updated" {
  style.stroke: "#F57F17"
}
match_fn.step4 -> state_after: "_match returns True\ncaller emits GREATER_EQUAL" {
  style.stroke: "#4CAF50"
  style.bold: true
}
match_fn.ret_false_mismatch -> state_after: "_match returns False\ncurrent unchanged\ncaller emits GREATER" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
antipattern -> advance_fn: "vs correct path →" {
  style.stroke: "#C62828"
  style.stroke-dash: 5
  style.font-color: "#C62828"
}
equiv -> match_fn: "wrapped by" {
  style.stroke: "#2E7D32"
  style.stroke-dash: 3
}