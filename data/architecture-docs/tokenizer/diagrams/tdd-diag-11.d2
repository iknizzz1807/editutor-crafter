vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Trace: Tokenizing `>==` with Maximal Munch
  Input string (3 chars): `>` `=` `=`
| {near: top-center}
direction: down
input_strip: {
  label: "Input Buffer"
  style.fill: "#1a1a2e"
  style.font-color: white
  style.bold: true
  grid-rows: 1
  grid-gap: 0
  c0: "> [0]" {
    style.fill: "#e94560"
    style.font-color: white
    style.bold: true
    width: 120
    height: 60
  }
  c1: "= [1]" {
    style.fill: "#f5a623"
    style.font-color: white
    style.bold: true
    width: 120
    height: 60
  }
  c2: "= [2]" {
    style.fill: "#4ecdc4"
    style.font-color: white
    style.bold: true
    width: 120
    height: 60
  }
  c3: "\\0 [EOF]" {
    style.fill: "#555577"
    style.font-color: "#aaaaaa"
    style.italic: true
    width: 120
    height: 60
  }
}
phase1: "PHASE 1 — Token 1: GREATER_EQUAL" {
  style.fill: "#16213e"
  style.stroke: "#e94560"
  style.stroke-width: 3
  style.font-color: "#e94560"
  style.bold: true
  step1: |md
    **Step 1 — _begin_token()**
    `start = 0`
    `token_start_line = 1`
    `token_start_column = 1`
    Cursor: `current = 0`
  | {
    style.fill: "#0f3460"
    style.font-color: white
  }
  step2: |md
    **Step 2 — advance() called in _scan_token()**
    Reads `source[0]` → `'>'`
    `current` → `1`
    `column` → `2`
    `ch = '>'` dispatched to `ch == '>'` branch
  | {
    style.fill: "#0f3460"
    style.font-color: white
  }
  step3: |md
    **Step 3 — _match('=') called**
    `peek()` → `source[1]` = `'='`
    `'=' == '='` → **TRUE**
    `advance()` called: `current` → `2`, `column` → `3`
    `_match` returns `True`
  | {
    style.fill: "#1a4a1a"
    style.font-color: "#90ee90"
    style.bold: true
  }
  step4: |md
    **Step 4 — emit GREATER_EQUAL**
    `_current_lexeme()` = `source[0:2]` = `">="` ✓
    Token: `GREATER_EQUAL(">="`, line=1, col=1`)`
    Appended to `self.tokens`
  | {
    style.fill: "#2d1b4e"
    style.font-color: "#d4a8ff"
    style.bold: true
  }
  step1 -> step2: "begin token"
  step2 -> step3: "ch=='>' branch"
  step3 -> step4: "_match returns True"
}
phase2: "PHASE 2 — Token 2: ASSIGN" {
  style.fill: "#16213e"
  style.stroke: "#4ecdc4"
  style.stroke-width: 3
  style.font-color: "#4ecdc4"
  style.bold: true
  step5: |md
    **Step 5 — _begin_token()**
    `start = 2`
    `token_start_line = 1`
    `token_start_column = 3`
    Cursor: `current = 2`
  | {
    style.fill: "#0f3460"
    style.font-color: white
  }
  step6: |md
    **Step 6 — advance() called in _scan_token()**
    Reads `source[2]` → `'='`
    `current` → `3`
    `column` → `4`
    `ch = '='` dispatched to `ch == '='` branch
  | {
    style.fill: "#0f3460"
    style.font-color: white
  }
  step7: |md
    **Step 7 — _match('=') called**
    `peek()` → `is_at_end()` = True → returns `'\0'`
    `'\0' != '='` → **FALSE**
    `_match` returns `False`
    cursor stays at `current = 3`
  | {
    style.fill: "#4a1a1a"
    style.font-color: "#ff9999"
    style.bold: true
  }
  step8: |md
    **Step 8 — emit ASSIGN**
    `_current_lexeme()` = `source[2:3]` = `"="` ✓
    Token: `ASSIGN("="`, line=1, col=3`)`
    Appended to `self.tokens`
  | {
    style.fill: "#2d1b4e"
    style.font-color: "#d4a8ff"
    style.bold: true
  }
  step5 -> step6: "begin token"
  step6 -> step7: "ch=='=' branch"
  step7 -> step8: "_match returns False"
}
eof_step: "Step 9 — EOF Emission" {
  style.fill: "#222233"
  style.stroke: "#888888"
  style.stroke-width: 2
  body: |md
    `is_at_end()` = True → exit main loop
    Append `Token(EOF, "", line=1, col=4)`
  | {
    style.fill: "#333344"
    style.font-color: "#aaaaaa"
  }
}
result_box: "Final Token Stream" {
  style.fill: "#0d1117"
  style.stroke: "#30a46c"
  style.stroke-width: 3
  style.font-color: "#30a46c"
  style.bold: true
  grid-rows: 1
  grid-gap: 8
  t1: |md
    `GREATER_EQUAL`
    lexeme: `">="`
    line=1, col=**1**
  | {
    style.fill: "#1a3a2a"
    style.font-color: "#90ee90"
    style.bold: true
  }
  t2: |md
    `ASSIGN`
    lexeme: `"="`
    line=1, col=**3**
  | {
    style.fill: "#1a2a3a"
    style.font-color: "#87ceeb"
    style.bold: true
  }
  t3: |md
    `EOF`
    lexeme: `""`
    line=1, col=**4**
  | {
    style.fill: "#222233"
    style.font-color: "#888888"
    style.italic: true
  }
}
naive_antipattern: "⚠ Naive Approach — WRONG Result" {
  style.fill: "#2d0a0a"
  style.stroke: "#cc0000"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.font-color: "#ff4444"
  style.bold: true
  wrong_explain: |md
    **If `'>'` stayed in SINGLE_CHAR_TOKENS:**
    Iteration 1: `ch='>'` → dict lookup → emit `GREATER(">")`  ← no lookahead!
    Iteration 2: `ch='='` → `_match('=')` → TRUE → emit `EQUAL_EQUAL("==")`
    Iteration 3: (nothing left)
    Result: `[GREATER, EQUAL_EQUAL]`  ✗ WRONG
    **Root cause:** Single-char dispatch fires before
    two-char lookahead has a chance to run.
    Fix: remove `'>'`, `'<'`, `'='`, `'!'` from
    `SINGLE_CHAR_TOKENS` and handle explicitly first.
  | {
    style.fill: "#1a0505"
    style.font-color: "#ff8888"
  }
}
cursor_states: "Cursor Position Timeline" {
  style.fill: "#111122"
  style.stroke: "#4444aa"
  style.stroke-width: 2
  grid-rows: 1
  grid-gap: 0
  cs0: |md
    **before step1**
    `current=0`
    `start=?`
  | { style.fill: "#1a1a33"; style.font-color: "#aaaaff"; width: 160 }
  cs1: |md
    **after step2**
    `current=1`
    `start=0`
    consumed `'>'`
  | { style.fill: "#1a1a33"; style.font-color: "#ffaa44"; width: 160 }
  cs2: |md
    **after step3**
    `current=2`
    `start=0`
    consumed `'='`
    lexeme=`">="`
  | { style.fill: "#1a3320"; style.font-color: "#90ee90"; width: 160 }
  cs3: |md
    **after step6**
    `current=3`
    `start=2`
    consumed `'='`
  | { style.fill: "#1a1a33"; style.font-color: "#87ceeb"; width: 160 }
  cs4: |md
    **after step7**
    `current=3`
    `start=2`
    peek=`'\0'`
    lexeme=`"="`
  | { style.fill: "#331a1a"; style.font-color: "#ff9999"; width: 160 }
}
input_strip -> phase1: "scan loop iteration 1" {
  style.stroke: "#e94560"
  style.bold: true
}
phase1 -> phase2: "scan loop iteration 2\n_begin_token() resets start=2" {
  style.stroke: "#ffffff"
  style.bold: true
}
phase2 -> eof_step: "scan loop exits\nis_at_end()=True" {
  style.stroke: "#888888"
}
eof_step -> result_box: "complete token stream" {
  style.stroke: "#30a46c"
  style.bold: true
}
result_box -> naive_antipattern: "compare: maximal munch vs naive" {
  style.stroke: "#cc0000"
  style.stroke-dash: 5
  style.bold: true
}