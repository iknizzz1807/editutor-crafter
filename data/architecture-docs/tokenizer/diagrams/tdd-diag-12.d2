layout-engine: elk
theme-id: 6

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: {
  label: |'md
  # FSM: Number Literal Scanning (Integer & Float)
  **Entry Invariant:** First digit already consumed by `advance()` in `_scan_token()`
  '|
  near: top-center
}

classes: {
  state: {
    shape: rectangle
    style: {
      border-radius: 8
      font-size: 14
      font: mono
      bold: true
    }
  }
  accepting: {
    shape: rectangle
    style: {
      border-radius: 8
      font-size: 14
      font: mono
      bold: true
      double-border: true
      fill: "#d4edda"
      stroke: "#28a745"
      font-color: "#155724"
    }
  }
  initial_point: {
    shape: circle
    style: {
      fill: "#212529"
    }
  }
  decision: {
    shape: diamond
    style: {
      border-radius: 4
      font-size: 13
      fill: "#fff3cd"
      stroke: "#ffc107"
      font-color: "#856404"
    }
  }
  trace_note: {
    shape: rectangle
    style: {
      border-radius: 6
      font-size: 12
      fill: "#f8f9fa"
      stroke: "#6c757d"
    }
  }
}

# ── States ────────────────────────────────────────────────────────────────────

●: "" {
  class: initial_point
  width: 20
  height: 20
}

SCANNING_INT: {
  class: state
  label: |'md
  **SCANNING_INT**
  ---
  **Invariant:** `lexeme` contains $D^+$
  **Action:** `advance()` on digits
  '|
  style.fill: "#cfe2ff"
  style.stroke: "#0d6efd"
}

CHECK_DOT: {
  class: decision
  label: "Lookahead\n(peek_next)"
}

SCANNING_FRAC: {
  class: state
  label: |'md
  **SCANNING_FRAC**
  ---
  **Invariant:** `lexeme` contains $D+\.D+$
  **Action:** `advance()` on digits
  '|
  style.fill: "#d1ecf1"
  style.stroke: "#17a2b8"
}

EMIT_NUMBER: {
  class: accepting
  label: |'md
  **EMIT_NUMBER**
  ---
  **Type:** `NUMBER`
  **Final Lexeme:** `source[start:current]`
  '|
}

# ── Transitions ───────────────────────────────────────────────────────────────

● -> SCANNING_INT: "digit / advance()" {
  style.stroke: "#212529"
  style.font-size: 12
}

SCANNING_INT -> SCANNING_INT: "digit / advance()" {
  style.stroke: "#0d6efd"
  style.font-size: 11
  style.animated: true
}

SCANNING_INT -> CHECK_DOT: "peek() == '.'" {
  style.stroke: "#ffc107"
  style.font-size: 12
  style.bold: true
}

SCANNING_INT -> EMIT_NUMBER: "[else] / emit()" {
  style.stroke: "#28a745"
  style.font-size: 12
}

CHECK_DOT -> SCANNING_FRAC: "[next is digit] / advance('.')" {
  style.stroke: "#17a2b8"
  style.font-size: 12
  style.bold: true
}

CHECK_DOT -> EMIT_NUMBER: "[next not digit] / return" {
  style.stroke: "#dc3545"
  style.font-size: 11
  style.stroke-dash: 5
}

SCANNING_FRAC -> SCANNING_FRAC: "digit / advance()" {
  style.stroke: "#17a2b8"
  style.font-size: 11
  style.animated: true
}

SCANNING_FRAC -> EMIT_NUMBER: "[else] / emit()" {
  style.stroke: "#28a745"
  style.font-size: 12
}

# ── Annotations ───────────────────────────────────────────────────────────────

lookahead_logic: {
  label: |'md
  ### Fractional Lookahead Strategy
  Lexing `3.foo` vs `3.14`:
  1. At `CHECK_DOT`, `peek()` is `'.'`.
  2. `_peek_next()` checks character *after* the dot.
  3. If digit: consume `'.'`, transition to `SCANNING_FRAC`.
  4. If not: leave `'.'` for next scan loop (will emit `3` as `NUMBER`).
  '|
  near: bottom-center
  style.fill: "#fff3cd"
  style.stroke: "#ffc107"
}

trace_int: {
  class: trace_note
  label: |'md
  **Trace: `42`**
  1. `4` -> `SCANNING_INT`
  2. `peek()` is `2` -> `advance()`
  3. `peek()` is `EOF` -> `EMIT_NUMBER`
  Result: `NUMBER("42")`
  '|
  near: top-left
}

trace_float: {
  class: trace_note
  label: |'md
  **Trace: `3.14`**
  1. `3` -> `SCANNING_INT`
  2. `peek()` is `.` -> `CHECK_DOT`
  3. `peek_next()` is `1` -> `SCANNING_FRAC`
  4. consume `1`, `4` -> `EMIT_NUMBER`
  Result: `NUMBER("3.14")`
  '|
  near: top-right
}

trace_invalid: {
  class: trace_note
  label: |'md
  **Trace: `3.f`**
  1. `3` -> `SCANNING_INT`
  2. `peek()` is `.` -> `CHECK_DOT`
  3. `peek_next()` is `f` -> `EMIT_NUMBER`
  Result: `NUMBER("3")`
  *(Note: `.` remains in source)*
  '|
  near: center-left
  style.fill: "#f8d7da"
  style.stroke: "#dc3545"
}