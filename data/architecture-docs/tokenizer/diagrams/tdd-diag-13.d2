vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  ## `peek()` vs `_peek_next()` — Lookahead Depth Comparison
  Neither method advances the cursor. Both are O(1) reads.
| {near: top-center}
# ─── Source Buffer ───────────────────────────────────────────────────────────
buffer: "Source Buffer  (e.g. '3.14foo')" {
  style.fill: "#E8F4FD"
  style.stroke: "#2980B9"
  style.stroke-width: 2
  style.border-radius: 8
  grid-columns: 8
  grid-gap: 0
  c0: "3" {
    width: 56
    height: 56
    style.fill: "#AED6F1"
    style.stroke: "#2980B9"
    style.font-size: 20
    style.bold: true
  }
  c1: "." {
    width: 56
    height: 56
    style.fill: "#FADBD8"
    style.stroke: "#E74C3C"
    style.stroke-width: 2
    style.font-size: 20
    style.bold: true
  }
  c2: "1" {
    width: 56
    height: 56
    style.fill: "#D5F5E3"
    style.stroke: "#27AE60"
    style.stroke-width: 2
    style.font-size: 20
    style.bold: true
  }
  c3: "4" {
    width: 56
    height: 56
    style.fill: "#F9F9F9"
    style.stroke: "#BDC3C7"
    style.font-size: 20
  }
  c4: "f" {
    width: 56
    height: 56
    style.fill: "#F9F9F9"
    style.stroke: "#BDC3C7"
    style.font-size: 20
  }
  c5: "o" {
    width: 56
    height: 56
    style.fill: "#F9F9F9"
    style.stroke: "#BDC3C7"
    style.font-size: 20
  }
  c6: "o" {
    width: 56
    height: 56
    style.fill: "#F9F9F9"
    style.stroke: "#BDC3C7"
    style.font-size: 20
  }
  c7: "\\0" {
    width: 56
    height: 56
    style.fill: "#F4ECF7"
    style.stroke: "#8E44AD"
    style.font-size: 16
    style.italic: true
  }
  idx0: "i-1" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#7F8C8D"
  }
  idx1: "i  ← current" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#E74C3C"
    style.bold: true
  }
  idx2: "i+1" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#27AE60"
    style.bold: true
  }
  idx3: "i+2" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#7F8C8D"
  }
  idx4: "i+3" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#7F8C8D"
  }
  idx5: "i+4" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#7F8C8D"
  }
  idx6: "i+5" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#7F8C8D"
  }
  idx7: "EOF" {
    width: 56
    height: 24
    style.fill: transparent
    style.stroke: transparent
    style.font-size: 11
    style.font-color: "#8E44AD"
  }
}
# ─── Method Boxes ─────────────────────────────────────────────────────────────
peek_box: "peek()\nreads source[current]\nreturns source[i]" {
  style.fill: "#FADBD8"
  style.stroke: "#E74C3C"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 13
  style.bold: true
  width: 220
}
peek_next_box: "_peek_next()\nreads source[current + 1]\nreturns source[i+1]" {
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 13
  style.bold: true
  width: 240
}
cursor_note: |md
  **Cursor invariant:**
  Neither `peek()` nor `_peek_next()` calls `advance()`.
  `self.current` is **unchanged** after both calls.
  Only `advance()` moves the cursor.
| {
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"
  style.stroke-width: 2
  style.border-radius: 6
}
# ─── Arrows from buffer cells to method boxes ────────────────────────────────
buffer.c1 -> peek_box: "1-ahead\n(source[i])" {
  style.stroke: "#E74C3C"
  style.stroke-width: 2
  style.bold: true
  style.font-size: 12
  style.font-color: "#E74C3C"
}
buffer.c2 -> peek_next_box: "2-ahead\n(source[i+1])" {
  style.stroke: "#27AE60"
  style.stroke-width: 2
  style.bold: true
  style.font-size: 12
  style.font-color: "#27AE60"
}
# ─── Decision Engine ─────────────────────────────────────────────────────────
decision: "Float-Mode Entry Guard\nin _scan_number()" {
  shape: diamond
  style.fill: "#EBF5FB"
  style.stroke: "#2980B9"
  style.stroke-width: 2
  style.font-size: 13
  style.bold: true
  width: 280
  height: 100
}
peek_box -> decision: "peek() == '.' ?" {
  style.stroke: "#E74C3C"
  style.stroke-width: 1
  style.stroke-dash: 4
  style.font-size: 11
}
peek_next_box -> decision: "_peek_next().isdigit() ?" {
  style.stroke: "#27AE60"
  style.stroke-width: 1
  style.stroke-dash: 4
  style.font-size: 11
}
enter_float: "consume '.'\nenter FRACTIONAL mode\nadvance() → i moves to i+1" {
  style.fill: "#D5F5E3"
  style.stroke: "#27AE60"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 12
}
no_float: "emit NUMBER(integer)\nleave '.' for next token\n(member access / ERROR)" {
  style.fill: "#FADBD8"
  style.stroke: "#E74C3C"
  style.stroke-width: 2
  style.border-radius: 6
  style.font-size: 12
}
decision -> enter_float: "BOTH true" {
  style.stroke: "#27AE60"
  style.stroke-width: 2
  style.bold: true
  style.font-size: 12
  style.font-color: "#27AE60"
}
decision -> no_float: "EITHER false" {
  style.stroke: "#E74C3C"
  style.stroke-width: 2
  style.bold: true
  style.font-size: 12
  style.font-color: "#E74C3C"
}
# ─── Three-Case Lookup Table ─────────────────────────────────────────────────
table: "Three-Input Proof Table" {
  style.fill: "#F8F9FA"
  style.stroke: "#5D6D7E"
  style.stroke-width: 2
  style.border-radius: 8
  grid-columns: 4
  grid-gap: 0
  hdr_input: "Input at cursor" {
    height: 36
    style.fill: "#2C3E50"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  hdr_peek: "peek()\nsource[i]" {
    height: 36
    style.fill: "#E74C3C"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  hdr_pnext: "_peek_next()\nsource[i+1]" {
    height: 36
    style.fill: "#27AE60"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  hdr_result: "Float mode?" {
    height: 36
    style.fill: "#2980B9"
    style.font-color: white
    style.bold: true
    style.font-size: 13
  }
  r1_input: "'3.1…'  (cursor at '.')" {
    height: 44
    style.fill: "#EBF5FB"
    style.font-size: 12
  }
  r1_peek: "'.'  ✓" {
    height: 44
    style.fill: "#FADBD8"
    style.font-size: 13
    style.bold: true
  }
  r1_pnext: "'1'  ✓ isdigit" {
    height: 44
    style.fill: "#D5F5E3"
    style.font-size: 13
    style.bold: true
  }
  r1_result: "YES  →  consume '.'" {
    height: 44
    style.fill: "#D5F5E3"
    style.font-size: 12
    style.bold: true
    style.font-color: "#1A5276"
  }
  r2_input: "'3.f…'  (cursor at '.')" {
    height: 44
    style.fill: "#EBF5FB"
    style.font-size: 12
  }
  r2_peek: "'.'  ✓" {
    height: 44
    style.fill: "#FADBD8"
    style.font-size: 13
    style.bold: true
  }
  r2_pnext: "'f'  ✗ not digit" {
    height: 44
    style.fill: "#FADBD8"
    style.font-size: 13
    style.bold: true
    style.font-color: "#C0392B"
  }
  r2_result: "NO  →  leave '.'" {
    height: 44
    style.fill: "#FADBD8"
    style.font-size: 12
    style.bold: true
    style.font-color: "#922B21"
  }
  r3_input: "'3.'  (cursor at '.', EOF next)" {
    height: 44
    style.fill: "#EBF5FB"
    style.font-size: 12
  }
  r3_peek: "'.'  ✓" {
    height: 44
    style.fill: "#FADBD8"
    style.font-size: 13
    style.bold: true
  }
  r3_pnext: "'\\0'  ✗ sentinel" {
    height: 44
    style.fill: "#F4ECF7"
    style.font-size: 13
    style.bold: true
    style.font-color: "#6C3483"
  }
  r3_result: "NO  →  leave '.'" {
    height: 44
    style.fill: "#FADBD8"
    style.font-size: 12
    style.bold: true
    style.font-color: "#922B21"
  }
}
# ─── Key insight callout ──────────────────────────────────────────────────────
insight: |md
  **Why `peek()` alone is insufficient:**
  Row 2 (`3.foo`) shows that `peek() == '.'` is **TRUE**
  yet we must NOT enter float mode.
  Only `_peek_next()` reveals the following char is `'f'` (not a digit).
  Without the second lookahead, the scanner would consume `'.'` and emit
  `NUMBER("3.")` — an invalid token requiring backtracking to fix.
  **Two-character lookahead eliminates backtracking entirely.**
| {
  style.fill: "#FDFEFE"
  style.stroke: "#F39C12"
  style.stroke-width: 2
  style.border-radius: 8
  near: bottom-center
}
table -> decision: "drives" {
  style.stroke: "#5D6D7E"
  style.stroke-dash: 3
  style.font-size: 11
}
cursor_note -> peek_box: "" {
  style.stroke: "#BDC3C7"
  style.stroke-dash: 5
}
cursor_note -> peek_next_box: "" {
  style.stroke: "#BDC3C7"
  style.stroke-dash: 5
}