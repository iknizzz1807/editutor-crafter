vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: "## Identifier Scanning Pipeline: Characters → FSM → Keyword Lookup → Token" {
  shape: text
  near: top-center
}

# ── INVARIANT BANNER ──────────────────────────────────────────────────────────
invariant: ||md
  **Critical Invariant:** `KEYWORDS.get()` is called **only after** the `while` loop exits.
  The complete lexeme string is the lookup key — never a prefix.
|| {
  near: top-center
  style: {
    fill: "#FFF9C9"
    stroke: "#E6B800"
    stroke-width: 2
    font-size: 13
    bold: true
  }
}

# ══════════════════════════════════════════════════════════════════════════════
# STAGE 1 — FSM LOOP
# ══════════════════════════════════════════════════════════════════════════════
stage1: "Stage 1 — FSM: Consume Identifier Characters" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    border-radius: 8
  }

  entry: "_scan_token() dispatches here\nwhen ch.isalpha() or ch == '_'" {
    style: {
      fill: "#BBDEFB"
      stroke: "#1565C0"
      font-size: 12
      border-radius: 4
    }
  }

  first_char: "First char already consumed\nby advance() in _scan_token()\nself.start ← index of first char" {
    style: {
      fill: "#90CAF9"
      stroke: "#1565C0"
      font-size: 12
      border-radius: 4
    }
  }

  loop_check: "peek() condition check" {
    shape: diamond
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      font-size: 12
    }
  }

  condition: ||md
    `peek().isalpha()`
    `or peek().isdigit()`
    `or peek() == '_'`
  || {
    style: {
      fill: "#DCEEFB"
      stroke: "#1565C0"
      font-size: 12
      border-radius: 4
    }
  }

  consume: "self.advance()\n(updates line/column;\ncursor moves +1)" {
    style: {
      fill: "#42A5F5"
      stroke: "#0D47A1"
      font-color: white
      font-size: 12
      border-radius: 4
    }
  }

  loop_exit: "Loop exits\n(peek() is non-identifier char\nor peek() == '\\0' at EOF)" {
    style: {
      fill: "#BBDEFB"
      stroke: "#1565C0"
      font-size: 12
      border-radius: 4
    }
  }

  lexeme_slice: "text = self.source[self.start : self.current]\n→ complete identifier string (O(k) slice, no concatenation)" {
    style: {
      fill: "#1565C0"
      font-color: white
      font-size: 12
      stroke: "#0D47A1"
      border-radius: 4
    }
  }

  entry -> first_char
  first_char -> loop_check
  loop_check -> condition: "evaluate"
  condition -> consume: "True\n(isalpha/isdigit/_)"
  consume -> loop_check: "back to top\n(cursor advanced)"
  condition -> loop_exit: "False\n(boundary reached)"
  loop_check -> loop_exit: "False\n(is_at_end → '\\0')"
  loop_exit -> lexeme_slice
}

# ══════════════════════════════════════════════════════════════════════════════
# STAGE 2 — KEYWORD LOOKUP
# ══════════════════════════════════════════════════════════════════════════════
stage2: "Stage 2 — Keyword Table Lookup" {
  style: {
    fill: "#F3E5F5"
    stroke: "#6A1B9A"
    stroke-width: 2
    border-radius: 8
  }

  lookup_call: "KEYWORDS.get(text, TokenType.IDENTIFIER)\n(O(1) Python dict hash lookup)" {
    style: {
      fill: "#CE93D8"
      stroke: "#6A1B9A"
      font-size: 12
      border-radius: 4
    }
  }

  keywords_dict: ||md
    **KEYWORDS dict — 7 entries**
    | Key | Value |
    |-----|-------|
    | `'if'` | `KEYWORD` |
    | `'else'` | `KEYWORD` |
    | `'while'` | `KEYWORD` |
    | `'return'` | `KEYWORD` |
    | `'true'` | `KEYWORD` |
    | `'false'` | `KEYWORD` |
    | `'null'` | `KEYWORD` |
    default → `IDENTIFIER`
  || {
    style: {
      fill: "#EDE7F6"
      stroke: "#6A1B9A"
      font-size: 12
      border-radius: 4
    }
  }

  hit: "Key found\n→ return TokenType.KEYWORD" {
    shape: diamond
    style: {
      fill: "#AB47BC"
      font-color: white
      stroke: "#6A1B9A"
      font-size: 12
    }
  }

  miss: "Key not found\n→ return default:\nTokenType.IDENTIFIER" {
    shape: diamond
    style: {
      fill: "#9C27B0"
      font-color: white
      stroke: "#4A148C"
      font-size: 12
    }
  }

  result_kw: "token_type = KEYWORD" {
    style: {
      fill: "#6A1B9A"
      font-color: white
      font-size: 12
      border-radius: 4
    }
  }

  result_id: "token_type = IDENTIFIER" {
    style: {
      fill: "#8E24AA"
      font-color: white
      font-size: 12
      border-radius: 4
    }
  }

  lookup_call -> keywords_dict: "look up\nfull text"
  keywords_dict -> hit: "text in dict"
  keywords_dict -> miss: "text not in dict"
  hit -> result_kw
  miss -> result_id
}

# ══════════════════════════════════════════════════════════════════════════════
# STAGE 3 — EMIT TOKEN
# ══════════════════════════════════════════════════════════════════════════════
stage3: "Stage 3 — Emit Token via _make_token()" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }

  make_token: "_make_token(token_type)" {
    style: {
      fill: "#81C784"
      stroke: "#2E7D32"
      font-size: 12
      border-radius: 4
    }
  }

  token_struct: ||md
    **Token constructed:**
    
    Token(
      type   = token_type,        ← KEYWORD or IDENTIFIER
      lexeme = source[start:current],  ← full word
      line   = token_start_line,  ← first char's line
      column = token_start_column ← first char's col
    )
  || {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      font-size: 12
      border-radius: 4
    }
  }

  append: "self.tokens.append(token)\n→ emitted to token stream" {
    style: {
      fill: "#2E7D32"
      font-color: white
      font-size: 12
      border-radius: 4
    }
  }

  make_token -> token_struct
  token_struct -> append
}

# ══════════════════════════════════════════════════════════════════════════════
# PIPELINE CONNECTIONS
# ══════════════════════════════════════════════════════════════════════════════
stage1.lexeme_slice -> stage2.lookup_call: "text = complete lexeme\n(full word, not prefix)" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    font-size: 11
    bold: true
  }
}
stage2.result_kw -> stage3.make_token: "KEYWORD" {
  style: {
    stroke: "#6A1B9A"
    stroke-width: 2
    font-size: 11
  }
}
stage2.result_id -> stage3.make_token: "IDENTIFIER" {
  style: {
    stroke: "#8E24AA"
    stroke-width: 2
    stroke-dash: 3
    font-size: 11
  }
}

# ══════════════════════════════════════════════════════════════════════════════
# WORKED EXAMPLES
# ══════════════════════════════════════════════════════════════════════════════
examples: "Worked Examples" {
  style: {
    fill: "#FFF8E1"
    stroke: "#F57F17"
    stroke-width: 2
    border-radius: 8
  }

  ex_if: ||md
    **Input: `if`**
    FSM consumes: `i`, `f`
    peek() → `'\0'` or non-identifier → loop exits
    text = `"if"`
    KEYWORDS.get(`"if"`) → **found** → `KEYWORD`
    → `Token(KEYWORD, "if", …)`
  || {
    style: {
      fill: "#FFF9C2"
      stroke: "#F57F17"
      font-size: 12
      border-radius: 4
    }
  }

  ex_iffy: ||md
    **Input: `iffy`**
    FSM consumes: `i`, `f`, `f`, `y`
    peek() → non-identifier → loop exits
    text = `"iffy"`  ← **full word, not `"if"`**
    KEYWORDS.get(`"iffy"`) → **miss** → default `IDENTIFIER`
    → `Token(IDENTIFIER, "iffy", …)`
  || {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      font-size: 12
      border-radius: 4
    }
  }

  ex_returning: ||md
    **Input: `returning`**
    FSM consumes: `r`,`e`,`t`,`u`,`r`,`n`,`i`,`n`,`g`
    peek() → non-identifier → loop exits
    text = `"returning"`  ← **not `"return"`**
    KEYWORDS.get(`"returning"`) → **miss** → default `IDENTIFIER`
    → `Token(IDENTIFIER, "returning", …)`
  || {
    style: {
      fill: "#FBE9E7"
      stroke: "#BF360C"
      font-size: 12
      border-radius: 4
    }
  }

  key_invariant: ||md
    **Why prefix matching is WRONG:**
    Checking `KEYWORDS` inside the loop at each character
    would match `"if"` inside `"iffy"` and emit
    `KEYWORD("if")` + `IDENTIFIER("fy")` — **incorrect**.
    The `while` loop MUST complete before any lookup.
    This is enforced by calling `KEYWORDS.get()` only
    after the loop exits, using the complete `text` slice.
  || {
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      font-size: 12
      border-radius: 4
      bold: false
    }
  }

  ex_if -> ex_iffy -> ex_returning -> key_invariant
}

examples -> stage1.entry: "feeds into pipeline" {
  style: {
    stroke: "#F57F17"
    stroke-dash: 4
    font-size: 10
  }
}