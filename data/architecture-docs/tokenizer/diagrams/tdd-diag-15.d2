vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## `_scan_token()` Dispatch Order — Correctness Constraints
  **Order is a correctness invariant, not style. Reordering (2)↔(4) breaks `==` → `ASSIGN+ASSIGN`.**
| {near: top-center}
# ─── ENTRY ───────────────────────────────────────────────────────────────────
entry: "ch = advance()" {
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke: "#555555"
  style.stroke-width: 2
  style.bold: true
}
# ─── STEP 1: WHITESPACE ───────────────────────────────────────────────────────
s1: "① WHITESPACE CHECK\nch in {' ', '\\t', '\\r', '\\n'}" {
  shape: diamond
  style.fill: "#E8E8E8"
  style.stroke: "#555555"
  style.stroke-width: 2
  style.font-size: 14
}
s1_yes: "return\n(no token emitted)" {
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.font-size: 13
}
# ─── STEP 2: TWO-CHAR OPERATORS ──────────────────────────────────────────────
s2_box: "② TWO-CHARACTER OPERATORS\n⚠ MUST appear BEFORE SINGLE_CHAR_TOKENS lookup" {
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 3
  style.bold: true
  style.font-size: 13
}
s2a: "ch == '='" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2a_t: "_match('=') ?" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2a_tt: "emit EQUAL_EQUAL\nlexeme '=='" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
s2a_tf: "emit ASSIGN\nlexeme '='" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
s2b: "ch == '!'" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2b_t: "_match('=') ?" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2b_tt: "emit BANG_EQUAL\nlexeme '!='" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
s2b_tf: "emit ERROR\n'!' alone invalid" {shape: rectangle; style.fill: "#FFCDD2"; style.stroke: "#C62828"; style.font-size: 13}
s2c: "ch == '<'" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2c_t: "_match('=') ?" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2c_tt: "emit LESS_EQUAL\nlexeme '<='" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
s2c_tf: "emit LESS\nlexeme '<'" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
s2d: "ch == '>'" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2d_t: "_match('=') ?" {shape: diamond; style.fill: "#FFF9C4"; style.stroke: "#F9A825"; style.font-size: 13}
s2d_tt: "emit GREATER_EQUAL\nlexeme '>='" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
s2d_tf: "emit GREATER\nlexeme '>'" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
# ─── STEP 3: SLASH / COMMENT ─────────────────────────────────────────────────
s3_box: "③ SLASH / COMMENT DISPATCH\n'/' removed from SINGLE_CHAR_TOKENS (M3 extension point)" {
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.stroke-width: 2
  style.font-size: 13
  style.bold: true
}
s3: "ch == '/'" {shape: diamond; style.fill: "#E8F5E9"; style.stroke: "#388E3C"; style.font-size: 13}
s3_a: "_match('/') ?" {shape: diamond; style.fill: "#E8F5E9"; style.stroke: "#388E3C"; style.font-size: 13}
s3_b: "_match('*') ?" {shape: diamond; style.fill: "#E8F5E9"; style.stroke: "#388E3C"; style.font-size: 13}
s3_lc: "_scan_line_comment()\nno token (M3)" {shape: rectangle; style.fill: "#C8E6C9"; style.stroke: "#388E3C"; style.font-size: 13}
s3_bc: "_scan_block_comment()\nno token or ERROR (M3)" {shape: rectangle; style.fill: "#C8E6C9"; style.stroke: "#388E3C"; style.font-size: 13}
s3_sl: "emit SLASH\nlexeme '/'" {shape: rectangle; style.fill: "#B3E5FC"; style.stroke: "#0288D1"; style.font-size: 13}
# ─── STEP 4: SINGLE_CHAR_TOKENS ──────────────────────────────────────────────
s4: "④ ch in SINGLE_CHAR_TOKENS?\n{+, -, *, (, ), {, }, [, ], ;, ,}\n'=' REMOVED in M2  '/' REMOVED in M3" {
  shape: diamond
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  style.font-size: 13
}
s4_yes: "emit SINGLE_CHAR_TOKENS[ch]\n(PLUS, MINUS, STAR, LPAREN…)" {
  shape: rectangle
  style.fill: "#B3E5FC"
  style.stroke: "#0288D1"
  style.font-size: 13
}
# ─── STEP 5: DIGITS ──────────────────────────────────────────────────────────
s5: "⑤ ch.isdigit() ?" {
  shape: diamond
  style.fill: "#EDE7F6"
  style.stroke: "#4527A0"
  style.font-size: 14
}
s5_yes: "_scan_number()\nemit NUMBER" {
  shape: rectangle
  style.fill: "#D1C4E9"
  style.stroke: "#4527A0"
  style.font-size: 13
}
# ─── STEP 6: ALPHA / UNDERSCORE ──────────────────────────────────────────────
s6: "⑥ ch.isalpha() or ch == '_' ?" {
  shape: diamond
  style.fill: "#FCE4EC"
  style.stroke: "#880E4F"
  style.font-size: 14
}
s6_yes: "_scan_identifier()\nFull word scanned → KEYWORDS.get()\nemit KEYWORD or IDENTIFIER" {
  shape: rectangle
  style.fill: "#F8BBD9"
  style.stroke: "#880E4F"
  style.font-size: 13
}
# ─── STEP 7: FALLTHROUGH ERROR ───────────────────────────────────────────────
s7: "⑦ FALLTHROUGH\nunrecognized character" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#B71C1C"
  style.stroke-width: 3
  style.font-size: 14
  style.bold: true
}
s7_err: "emit ERROR(ch)\nscan continues (error recovery)" {
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.font-size: 13
}
# ─── CORRECTNESS VIOLATION ANNOTATION ────────────────────────────────────────
violation: |md
  **🔴 IF ② and ④ ARE SWAPPED:**
  Input `==`:
  - `=` found in `SINGLE_CHAR_TOKENS` → emit `ASSIGN`
  - `=` found in `SINGLE_CHAR_TOKENS` → emit `ASSIGN`
  - Result: **`ASSIGN + ASSIGN`** ❌
  Correct order produces:
  - ch=`=`, `_match('=')` → emit **`EQUAL_EQUAL`** ✓
  Same breakage for `!=` → `ERROR + ASSIGN`,
  `<=` → `LESS + ASSIGN`, `>=` → `GREATER + ASSIGN`
| {
  near: bottom-right
  style.font-size: 13
}
munch_note: |md
  **Maximal Munch Rule:**
  Always prefer the longest valid token.
  `_match()` peeks+consumes 2nd char only if valid.
  `>==` → `GREATER_EQUAL` + `ASSIGN` (not `GREATER` + `EQUAL_EQUAL`)
| {
  near: bottom-left
  style.font-size: 13
}
# ─── CONNECTIONS: MAIN FLOW ──────────────────────────────────────────────────
entry -> s1: "ch consumed\nby advance()"
s1 -> s1_yes: "yes" {style.stroke: "#388E3C"; style.bold: true}
s1 -> s2_box: "no"
s2_box -> s2a
s2a -> s2a_t: "yes"
s2a -> s2b: "no"
s2a_t -> s2a_tt: "yes" {style.stroke: "#0288D1"}
s2a_t -> s2a_tf: "no" {style.stroke: "#0288D1"}
s2b -> s2b_t: "yes"
s2b -> s2c: "no"
s2b_t -> s2b_tt: "yes" {style.stroke: "#0288D1"}
s2b_t -> s2b_tf: "no" {style.stroke: "#C62828"; style.stroke-dash: 3}
s2c -> s2c_t: "yes"
s2c -> s2d: "no"
s2c_t -> s2c_tt: "yes" {style.stroke: "#0288D1"}
s2c_t -> s2c_tf: "no" {style.stroke: "#0288D1"}
s2d -> s2d_t: "yes"
s2d -> s3_box: "no"
s2d_t -> s2d_tt: "yes" {style.stroke: "#0288D1"}
s2d_t -> s2d_tf: "no" {style.stroke: "#0288D1"}
s3_box -> s3
s3 -> s3_a: "yes"
s3 -> s4: "no"
s3_a -> s3_lc: "yes"
s3_a -> s3_b: "no"
s3_b -> s3_bc: "yes"
s3_b -> s3_sl: "no"
s4 -> s4_yes: "yes" {style.stroke: "#0288D1"; style.bold: true}
s4 -> s5: "no"
s5 -> s5_yes: "yes" {style.stroke: "#4527A0"; style.bold: true}
s5 -> s6: "no"
s6 -> s6_yes: "yes" {style.stroke: "#880E4F"; style.bold: true}
s6 -> s7: "no"
s7 -> s7_err
# ─── VIOLATION ARROW (RED DASHED) ────────────────────────────────────────────
s4 -> s2_box: "🔴 ILLEGAL: if ④ precedes ②\n== becomes ASSIGN+ASSIGN" {
  style.stroke: "#B71C1C"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.bold: true
  style.font-color: "#B71C1C"
}