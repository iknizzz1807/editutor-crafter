layout-engine: elk
theme-id: 4

# DIAGRAM: Canonical M2 Token Stream Implementation
# SPEC: 'if (x >= 42) { return true; }'

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ### Token Stream Byte Layout & State Mapping
  `if (x >= 42) { return true; }`
| {near: top-center}

# GLOBAL STYLES
***.style.font: mono

# TOKEN STREAM DATA STRUCTURES (Contiguous Struct Array)
# sizeof(Token) = 16 bytes
stream: {
  r0: "0x00 [16B]" {
    label: "0: KEYWORD\n'if' [1,1]"
    style.fill: "#C8B6E2" # Purple: Header/Keyword
    style.border-radius: 4
  }
  r1: "0x10 [16B]" {
    label: "1: LPAREN\n'(' [1,4]"
    style.fill: "#D6EAF8" # Blue: Data/Punc
    style.border-radius: 4
  }
  r2: "0x20 [16B]" {
    label: "2: IDENTIFIER\n'x' [1,5]"
    style.fill: "#D6EAF8"
    style.border-radius: 4
  }
  r3: "0x30 [16B]" {
    label: "3: GREATER_EQUAL\n'>=' [1,7]"
    style.fill: "#FDEBD0" # Orange: Pointers/Operators
    style.border-radius: 4
  }
  r4: "0x40 [16B]" {
    label: "4: NUMBER\n'42' [1,10]"
    style.fill: "#D5F5E3" # Green: Literals
    style.border-radius: 4
  }
  r5: "0x50 [16B]" {
    label: "5: RPAREN\n')' [1,12]"
    style.fill: "#D6EAF8"
    style.border-radius: 4
  }
  r6: "0x60 [16B]" {
    label: "6: LBRACE\n'{' [1,14]"
    style.fill: "#D6EAF8"
    style.border-radius: 4
  }
  r7: "0x70 [16B]" {
    label: "7: KEYWORD\n'return' [1,16]"
    style.fill: "#C8B6E2"
    style.border-radius: 4
  }
  r8: "0x80 [16B]" {
    label: "8: KEYWORD\n'true' [1,23]"
    style.fill: "#C8B6E2"
    style.border-radius: 4
  }
  r9: "0x90 [16B]" {
    label: "9: SEMICOLON\n';' [1,27]"
    style.fill: "#D6EAF8"
    style.border-radius: 4
  }
  r10: "0xA0 [16B]" {
    label: "10: RBRACE\n'}' [1,29]"
    style.fill: "#D6EAF8"
    style.border-radius: 4
  }
  r_eof: "0xB0 [16B]" {
    label: "EOF\n'' [1,31]"
    style.fill: "#EAECEE" # Gray: Padding/EOF
    style.stroke-dash: 4
    style.border-radius: 4
  }

  r0 -> r1 -> r2 -> r3 -> r4 -> r5 -> r6 -> r7 -> r8 -> r9 -> r10 -> r_eof: {
    style.stroke: "#AAAAAA"
    style.stroke-width: 1
  }
}

# ANNOTATIONS (Logic & Analysis)
analysis: {
  ann_kw: |md
    **Keyword Validation**
    `KEYWORDS.get('if')`
    Pre-calculated Hash: `0xDEADBEEF`
  | {
    style.fill: "#F9F0FF"
    style.stroke: "#C8B6E2"
    style.font-size: 11
  }

  ann_munch: |md
    **Maximal Munch**
    Lookahead(1)='=' 
    Match `GREATER_EQUAL`
  | {
    style.fill: "#FEF9EC"
    style.stroke: "#FDEBD0"
    style.font-size: 11
  }

  ann_eof: |md
    **Sentinel EOF**
    Column: 31 (Len+1)
    State: HALT
  | {
    style.fill: "#F4F6F7"
    style.stroke: "#AAAAAA"
    style.font-size: 11
  }
}

# CONNECTIONS (Group labels with targets)
analysis.ann_kw -> stream.r0
analysis.ann_munch -> stream.r3
analysis.ann_eof -> stream.r_eof

# LEGEND
legend: {
  near: bottom-center
  style.stroke: "#AAAAAA"
  style.border-radius: 4
  grid-columns: 5
  
  l1: "KEYWORD" { style.fill: "#C8B6E2"; style.font-size: 10 }
  l2: "PUNCTUATION" { style.fill: "#D6EAF8"; style.font-size: 10 }
  l3: "OPERATOR" { style.fill: "#FDEBD0"; style.font-size: 10 }
  l4: "LITERAL" { style.fill: "#D5F5E3"; style.font-size: 10 }
  l5: "SENTINEL" { style.fill: "#EAECEE"; style.font-size: 10 }
}