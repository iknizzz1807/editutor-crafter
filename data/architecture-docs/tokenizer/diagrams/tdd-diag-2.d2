direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# CLASSES FOR MEMORY TYPES
classes: {
  header: {
    style: {
      fill: "#f3e8ff"
      stroke: "#7c3aed"
      stroke-width: 2
    }
  }
  data: {
    style: {
      fill: "#dbeafe"
      stroke: "#1d4ed8"
      stroke-width: 2
    }
  }
  padding: {
    style: {
      fill: "#f3f4f6"
      stroke: "#6b7280"
      stroke-width: 1
    }
  }
  pointer: {
    style: {
      fill: "#ffedd5"
      stroke: "#d97706"
      stroke-width: 2
    }
  }
  label_note: {
    style: {
      stroke-dash: 3
      border-radius: 5
      font-size: 12
    }
  }
}

title: {
  shape: text
  label: |'md
    # Token Struct Memory Layout
    ### Python Dataclass (Heap Indirection) vs. C/Rust (Packed Contiguous)
  '|
}

# --- PYTHON IMPLEMENTATION ---
python_layout: "Python Token Instance (CPython Heap)" {
  tooltip: "sizeof=48 bytes"
  style: {
    stroke: "#7c3aed"
    stroke-width: 4
  }

  h1: "0x00 | ob_refcnt" {
    class: header
    tooltip: "8 Bytes (Standard CPython Header)"
  }
  h2: "0x08 | ob_type" {
    class: header
    tooltip: "8 Bytes (Pointer to Class Object)"
  }
  f_type: "0x10 | *type_ptr" {
    class: pointer
    tooltip: "8 Bytes (Pointer to Enum)"
  }
  f_lexeme: "0x18 | *lexeme_ptr" {
    class: pointer
    tooltip: "8 Bytes (Pointer to String)"
  }
  f_line: "0x20 | *line_ptr" {
    class: pointer
    tooltip: "8 Bytes (Pointer to Int Object)"
  }
  f_column: "0x28 | *col_ptr" {
    class: pointer
    tooltip: "8 Bytes (Pointer to Int Object)"
  }

  python_size_note: "Total Size: 48 Bytes" {
    class: label_note
    style.fill: "#faf5ff"
  }
}

# --- C/RUST IMPLEMENTATION ---
c_layout: "C / Rust Packed Struct (Contiguous)" {
  tooltip: "sizeof=16 bytes"
  style: {
    stroke: "#059669"
    stroke-width: 4
  }

  b00: "0x00 | type (u8)" {
    class: data
    tooltip: "1 Byte"
  }
  b01: "0x01 | [padding]" {
    class: padding
    tooltip: "1 Byte Alignment Padding"
  }
  b02: "0x02 | column (u16)" {
    class: data
    tooltip: "2 Bytes"
  }
  b04: "0x04 | line (u32)" {
    class: data
    tooltip: "4 Bytes"
  }
  b08: "0x08 | lexeme (ptr)" {
    class: pointer
    tooltip: "8 Bytes (Machine Word)"
  }

  boundary: "--- 16B Boundary ---" {
    style: {
      stroke: "#dc2626"
      stroke-dash: 5
      fill: "#fee2e2"
    }
  }

  c_size_note: "Total Size: 16 Bytes" {
    class: label_note
    style.fill: "#f0fdf4"
  }
}

# --- EXTERNAL HEAP OBJECTS ---
heap_objects: "External Python Heap Objects" {
  style: {
    fill: "#f8fafc"
    stroke: "#64748b"
    stroke-dash: 3
  }
  
  tok_enum: "TokenType.PLUS (Enum)" { class: header }
  tok_str: "str '+' (PyUnicode)" { class: data }
  tok_line: "int 123 (PyLong)" { class: data }
  tok_col: "int 1 (PyLong)" { class: data }
}

# --- COMPARISON TABLE ---
comparison_metrics: {
  label: |'md
    ### Architectural Comparison
    | Metric | Python (Heap) | C / Rust (Packed) |
    | :--- | :--- | :--- |
    | **Instance Size** | 48 B (Pointers) | **16 B** (Inlined Data) |
    | **Indirection** | 4 Pointer derefs | **0** (Numeric local) |
    | **Locality** | Scattered (Heap) | **Contiguous** |
    | **64B Cache Line**| 1.3 Tokens | **4.0 Tokens** |
  '|
  style: {
    fill: "#f1f5f9"
    stroke: "#475569"
  }
}

# --- LEGEND ---
legend: {
  near: bottom-right
  h: "Header (Purple)" { class: header }
  d: "Data (Blue)" { class: data }
  p: "Pointer (Orange)" { class: pointer }
  pd: "Padding (Gray)" { class: padding }
}

# --- CONNECTIONS ---
python_layout.f_type -> heap_objects.tok_enum: "deref" {
  style: { stroke: "#d97706"; animated: true }
}
python_layout.f_lexeme -> heap_objects.tok_str: "deref" {
  style: { stroke: "#d97706"; animated: true }
}
python_layout.f_line -> heap_objects.tok_line: "deref" {
  style: { stroke: "#d97706"; animated: true }
}
python_layout.f_column -> heap_objects.tok_col: "deref" {
  style: { stroke: "#d97706"; animated: true }
}

# Layout constraints
python_layout -> c_layout: "Comparison" { style.stroke-opacity: 0 }
c_layout -> comparison_metrics: "" { style.stroke-opacity: 0 }

# Global Annotations
growth_direction: "Growth Direction: Low to High Address (Downward)" {
  shape: text
  style.font-size: 14
  style.bold: true
}