vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: |'md'
  ## Unterminated Construct Error Position: Opening Delimiter vs Current Position
  Error token position = snapshot at `_begin_token()`, NOT position at detection
'|
title.near: top-center

panel_a: "Panel A — Unterminated String" {
  style: {
    fill: "#EEF2FF"
    stroke: "#6366F1"
    stroke-width: 2
    border-radius: 8
  }

  source_a: |'md'
    **Source:** `"unterminated`
    Length: 14 chars, no closing `"`
  '|
  source_a.style: {
    fill: "#E0E7FF"
    stroke: "#6366F1"
  }

  snapshot_a: "SNAPSHOT at _begin_token()" {
    style: {
      fill: "#7C3AED"
      font-color: white
      stroke-width: 0
      border-radius: 6
    }
    detail_a: |'md'
      `self.start = 0`
      `token_start_line   = 1`
      `token_start_column = 1`
      ← **frozen here**, never updated
    '|
    detail_a.style: {
      fill: "#7C3AED"
      font-color: white
      stroke: "#5B21B6"
    }
  }

  scan_loop_a: "Scan Loop — _scan_string()" {
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
      border-radius: 6
    }
    step1_a: "Step 1" {
      style.fill: "#BFDBFE"
      label: |'md'
        `ch = advance()` → `"`
        enters string mode
        current=1, line=1, col=2
      '|
    }
    step2_a: "Step 2-13" {
      style.fill: "#BFDBFE"
      label: |'md'
        advance() × 13 chars
        `u n t e r m i n a t e d`
        current=14, line=1, col=15
      '|
    }
    step3_a: "Step 14" {
      style.fill: "#FEF3C7"
      style.stroke: "#D97706"
      label: |'md'
        `is_at_end()` → **True**
        EOF reached, no `"` found
        current=14, line=1, **col=15**
      '|
    }
    step1_a -> step2_a -> step3_a
  }

  error_emit_a: "ERROR Token Constructed" {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 2
      border-radius: 6
    }
    fields_a: |'md'
      `type    = TokenType.ERROR`
      `lexeme  = '"unterminated'`
      `line    =` **token_start_line = 1**
      `column  =` **token_start_column = 1**
    '|
    fields_a.style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
    }
  }

  wrong_a: "If we used current position instead" {
    style: {
      fill: "#FFF1F2"
      stroke: "#FB7185"
      stroke-dash: 5
      border-radius: 6
    }
    wrong_detail_a: |'md'
      `line=1, column=15` ← **WRONG**
      Points past the last char
      "Error at end of file" — useless!
    '|
    wrong_detail_a.style: {
      fill: "#FFE4E6"
      stroke: "#FB7185"
    }
  }

  annotation_a: |'md'
    **Error points to column 1** — the opening `"`
    That is WHERE THE PROBLEM IS
  '|
  annotation_a.style: {
    fill: "#F5F3FF"
    stroke: "#8B5CF6"
    italic: true
  }

  source_a -> snapshot_a -> scan_loop_a -> error_emit_a
  error_emit_a -> wrong_a: "vs incorrect approach" {
    style.stroke-dash: 4
    style.stroke: "#FB7185"
  }
  error_emit_a -> annotation_a
}

panel_b: "Panel B — Unterminated Block Comment" {
  style: {
    fill: "#F0FDF4"
    stroke: "#16A34A"
    stroke-width: 2
    border-radius: 8
  }

  source_b: |'md'
    **Source:** `x`
    `/* open`
    `no close`
    `x` on line 1 | `/*` opens on line 2 | content on line 3
  '|
  source_b.style: {
    fill: "#DCFCE7"
    stroke: "#16A34A"
  }

  tokens_before_b: "Tokens from line 1" {
    style: {
      fill: "#BBF7D0"
      stroke: "#22C55E"
      border-radius: 6
    }
    label: |'md'
      `IDENTIFIER('x', line=1, col=1)`
      scan loop continues to `\n` (whitespace)
      line becomes **2**, column resets to **1**
    '|
  }

  snapshot_b: "SNAPSHOT at _begin_token() for /*" {
    style: {
      fill: "#166534"
      font-color: white
      stroke-width: 0
      border-radius: 6
    }
    detail_b: |'md'
      cursor at `/` of `/*` — line 2, col 1
      `self.start = index_of_/`
      `token_start_line   = 2`
      `token_start_column = 1`
      ← **frozen here**
    '|
    detail_b.style: {
      fill: "#166534"
      font-color: white
      stroke: "#14532D"
    }
  }

  scan_loop_b: "Scan Loop — _scan_block_comment()" {
    style: {
      fill: "#D1FAE5"
      stroke: "#10B981"
      border-radius: 6
    }
    match_b: |'md'
      `_match('/')` → True (advances past `/`)
      `_match('*')` → True (advances past `*`)
      `_scan_block_comment()` called
      current at first char after `/*`
    '|
    consume_b: |'md'
      advance() × chars of ` open\nno close`
      `\n` encountered → line becomes **3**, col **1**
      Continues advancing…
    '|
    eof_b: |'md'
      `is_at_end()` → **True**
      EOF at line=3, col=9
      No `*/` was found
    '|
    eof_b.style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
    }
    match_b -> consume_b -> eof_b
  }

  error_emit_b: "ERROR Token Constructed" {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 2
      border-radius: 6
    }
    fields_b: |'md'
      `type    = TokenType.ERROR`
      `lexeme  = '/* open\nno close'`
      `line    =` **token_start_line = 2**
      `column  =` **token_start_column = 1**
    '|
    fields_b.style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
    }
  }

  wrong_b: "If we used current position instead" {
    style: {
      fill: "#FFF1F2"
      stroke: "#FB7185"
      stroke-dash: 5
      border-radius: 6
    }
    wrong_detail_b: |'md'
      `line=3, column=9` ← **WRONG**
      Points to end of last consumed char
      "Error at 'close'" — misleading!
    '|
    wrong_detail_b.style: {
      fill: "#FFE4E6"
      stroke: "#FB7185"
    }
  }

  annotation_b: |'md'
    **Error points to line 2, col 1** — the opening `/`
    That is WHERE THE PROBLEM IS
  '|
  annotation_b.style: {
    fill: "#F0FDF4"
    stroke: "#16A34A"
    italic: true
  }

  source_b -> tokens_before_b -> snapshot_b -> scan_loop_b -> error_emit_b
  error_emit_b -> wrong_b: "vs incorrect approach" {
    style.stroke-dash: 4
    style.stroke: "#FB7185"
  }
  error_emit_b -> annotation_b
}

principle: |'md'
  ## The Universal Rule
  **`token_start_line` / `token_start_column`** are snapshotted by `_begin_token()`
  **before** any character of the token is consumed.
  They remain **frozen** for the entire duration of scanning that token.

  `self.line` / `self.column` advance with every `advance()` call
  and describe "where the cursor is NOW" — not "where the token started."

  For unterminated constructs the detection point is always **after** the
  opening delimiter — sometimes many lines later. The error MUST reference
  the opening delimiter position. Only `token_start_*` preserves that.

  **Rule:** All `Token(ERROR, ...)` constructions for unterminated constructs
  use `token_start_line` and `token_start_column`, never `self.line` / `self.column`.
'|
principle.near: bottom-center
principle.style: {
  fill: "#FFFBEB"
  stroke: "#D97706"
  stroke-width: 2
  border-radius: 8
}