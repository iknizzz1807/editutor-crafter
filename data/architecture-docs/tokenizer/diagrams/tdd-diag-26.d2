vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Error Recovery Strategy: Skip-One-and-Continue vs Halt-on-First
| {near: top-center}
direction: right
# ─── LEFT COLUMN: HALT STRATEGY ──────────────────────────────────────────────
halt_col: "HALT STRATEGY\n(early GCC style)" {
  style: {
    fill: "#FFF0F0"
    stroke: "#CC3333"
    stroke-width: 2
    border-radius: 8
  }
  h_input: "Input: x @ y # z" {
    style.fill: "#FFDCDC"
    style.border-radius: 4
  }
  h_step1: "Step 1  →  consume 'x'" {
    style.fill: "#E8F5E9"
    style.border-radius: 4
  }
  h_tok1: "emit  IDENTIFIER('x', 1:1)" {
    style.fill: "#C8E6C9"
    style.border-radius: 4
  }
  h_step2: "Step 2  →  consume '@'" {
    style.fill: "#FFCDD2"
    style.border-radius: 4
  }
  h_decision: "Unrecognized character!" {
    style: {
      fill: "#FF5252"
      font-color: white
      bold: true
      border-radius: 4
    }
  }
  h_halt: "⛔  RAISE EXCEPTION\nor return immediately" {
    style: {
      fill: "#B71C1C"
      font-color: white
      bold: true
      border-radius: 6
      stroke: "#FF1744"
      stroke-width: 2
    }
  }
  h_lost: "Steps 3–5 NEVER EXECUTE\n'y' '#' 'z' never scanned" {
    style: {
      fill: "#EF9A9A"
      stroke-dash: 5
      border-radius: 4
    }
  }
  h_output_label: "Output token stream:" {
    style.fill: "#FFCDD2"
    style.border-radius: 4
  }
  h_output: "[ IDENTIFIER('x') ]\n— only 1 token —\nScanning stopped" {
    style: {
      fill: "#FF8A80"
      stroke: "#CC3333"
      stroke-width: 2
      border-radius: 6
      bold: true
    }
  }
  h_input -> h_step1
  h_step1 -> h_tok1
  h_tok1 -> h_step2
  h_step2 -> h_decision
  h_decision -> h_halt
  h_halt -> h_lost: "y, #, z unseen"
  h_lost -> h_output_label
  h_output_label -> h_output
}
# ─── RIGHT COLUMN: CONTINUE STRATEGY ─────────────────────────────────────────
cont_col: "CONTINUE STRATEGY\n(Clang / your scanner)" {
  style: {
    fill: "#F0FFF4"
    stroke: "#2E7D32"
    stroke-width: 2
    border-radius: 8
  }
  c_input: "Input: x @ y # z" {
    style.fill: "#DCEDC8"
    style.border-radius: 4
  }
  c_step1: "Step 1  →  consume 'x'" {
    style.fill: "#C8E6C9"
    style.border-radius: 4
  }
  c_tok1: "emit  IDENTIFIER('x', 1:1)" {
    style.fill: "#A5D6A7"
    style.border-radius: 4
  }
  c_step2: "Step 2  →  consume '@'" {
    style.fill: "#FFF9C4"
    style.border-radius: 4
  }
  c_err1: "emit  ERROR('@', 1:2)\n→ _begin_token() → continue" {
    style: {
      fill: "#F57F17"
      font-color: white
      border-radius: 4
    }
  }
  c_step3: "Step 3  →  consume 'y'" {
    style.fill: "#C8E6C9"
    style.border-radius: 4
  }
  c_tok3: "emit  IDENTIFIER('y', 1:3)" {
    style.fill: "#A5D6A7"
    style.border-radius: 4
  }
  c_step4: "Step 4  →  consume '#'" {
    style.fill: "#FFF9C4"
    style.border-radius: 4
  }
  c_err2: "emit  ERROR('#', 1:4)\n→ _begin_token() → continue" {
    style: {
      fill: "#F57F17"
      font-color: white
      border-radius: 4
    }
  }
  c_step5: "Step 5  →  consume 'z'" {
    style.fill: "#C8E6C9"
    style.border-radius: 4
  }
  c_tok5: "emit  IDENTIFIER('z', 1:5)" {
    style.fill: "#A5D6A7"
    style.border-radius: 4
  }
  c_step6: "is_at_end() == True" {
    style.fill: "#E8F5E9"
    style.border-radius: 4
  }
  c_eof: "emit  EOF('', 1:6)" {
    style.fill: "#81C784"
    style.border-radius: 4
  }
  c_output_label: "Output token stream:" {
    style.fill: "#C8E6C9"
    style.border-radius: 4
  }
  c_output: "[ IDENTIFIER('x'),\n  ERROR('@'),\n  IDENTIFIER('y'),\n  ERROR('#'),\n  IDENTIFIER('z'),\n  EOF ]\n— 6 tokens, ALL errors visible —" {
    style: {
      fill: "#388E3C"
      font-color: white
      stroke: "#1B5E20"
      stroke-width: 2
      border-radius: 6
      bold: true
    }
  }
  c_input -> c_step1
  c_step1 -> c_tok1
  c_tok1 -> c_step2
  c_step2 -> c_err1
  c_err1 -> c_step3: "resume"
  c_step3 -> c_tok3
  c_tok3 -> c_step4
  c_step4 -> c_err2
  c_err2 -> c_step5: "resume"
  c_step5 -> c_tok5
  c_tok5 -> c_step6
  c_step6 -> c_eof
  c_eof -> c_output_label
  c_output_label -> c_output
}
# ─── WHY IT MATTERS PANEL ─────────────────────────────────────────────────────
why: "WHY IT MATTERS — A File with 5 Bugs" {
  style: {
    fill: "#F3E5F5"
    stroke: "#6A1B9A"
    stroke-width: 2
    border-radius: 8
  }
  tbl: ||md
    | Strategy | Bugs in file | Errors per compile | Cycles to fix all 5 |
    |---|---|---|---|
    | **HALT (early GCC)** | 5 | 1 (stops at first) | **5 compile-fix cycles** |
    | **CONTINUE (Clang / your scanner)** | 5 | up to 5 (all collected) | **1 compile-fix cycle** |
  ||
  note: |md
    **Historical context:**
    Early GCC halted on the first fatal error — developers discovered bugs one at a time.
    Clang was designed from day one to recover and collect all diagnostics in one pass.
    Rust's `rustc` follows Clang's philosophy and adds suggested fixes per error.
    Your scanner implements the Clang model: `_scan_token()` appends `ERROR` and returns
    normally to `scan_tokens()`, which calls `_begin_token()` and continues.
    **Zero state to unwind** — lexer recovery is free; parser recovery is hard.
  |
}
halt_col -> why: "Halt model"
cont_col -> why: "Continue model"