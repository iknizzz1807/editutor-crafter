vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}
title: |md
  ## Position Drift Detection: Off-by-One Accumulates Over 50 Lines
| {near: top-center}
# ── Two Tracking Lines ──────────────────────────────────────────────────────
correct: "CORRECT TRACKING\n(advance() is sole updater)" {
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
    stroke-width: 2
    border-radius: 8
  }
  grid-rows: 1
  grid-gap: 0
  l1c: "Line 1\ncol=1" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  l5c: "Line 5\ncol=1" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  l10c: "Line 10\ncol=1" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  l25c: "Line 25\ncol=1" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
  }
  l50c: "Line 50\ncol=1 ✓" {
    style.fill: "#4CAF50"
    style.stroke: "#1B5E20"
    style.font-color: white
    style.bold: true
  }
}
drifting: "DRIFTING TRACKER\n(tab counted twice, or column += 2 per \\n)" {
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 2
    border-radius: 8
  }
  grid-rows: 1
  grid-gap: 0
  l1d: "Line 1\ncol=1" {
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
  }
  l5d: "Line 5\ncol=5" {
    style.fill: "#EF9A9A"
    style.stroke: "#C62828"
  }
  l10d: "Line 10\ncol=10" {
    style.fill: "#E57373"
    style.stroke: "#C62828"
    style.font-color: white
  }
  l25d: "Line 25\ncol=25" {
    style.fill: "#EF5350"
    style.stroke: "#C62828"
    style.font-color: white
  }
  l50d: "Line 50\ncol=51 ✗" {
    style.fill: "#B71C1C"
    style.stroke: "#7F0000"
    style.font-color: white
    style.bold: true
  }
}
# ── Drift Delta Annotation ────────────────────────────────────────────────────
delta: |md
  **Δ error at line 50 = +50 columns**
  Started with: off-by-1 per line (e.g. `column += 2` on `\n`, or tab = 2 col-units)
  After 1 line  → off by  1
  After 5 lines → off by  5
  After 25 lines → off by 25
  After 50 lines → off by **50**
  What should be `column=1` reports `column=51`
| {
  near: bottom-center
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    stroke-width: 2
    border-radius: 8
  }
}
# ── The Test That Catches It ──────────────────────────────────────────────────
catching_test: "THE CATCHING TEST (50-line drift detector)" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    border-radius: 8
    bold: true
  }
  code: |python
    line_content = 'x = 1;'
    source = '\n'.join([line_content] * 50)
    tokens = Scanner(source).scan_tokens()
    line_50_tokens = [t for t in tokens if t.line == 50]
    first = line_50_tokens[0]
    assert first.lexeme  == 'x'
    assert first.column  == 1    # FAILS if drift: reports 51
    assert first.line    == 50
    semicolons = [t for t in line_50_tokens
                  if t.type == TokenType.SEMICOLON]
    assert semicolons[0].column == 6  # x=1 space=2 ==3 space=4 1=5 ;=6
  | {
    style: {
      fill: "#BBDEFB"
      stroke: "#1565C0"
    }
  }
}
# ── Why Single-Token Tests Are Blind ─────────────────────────────────────────
blind_zone: "WHY SINGLE-TOKEN TESTS NEVER CATCH DRIFT" {
  style: {
    fill: "#F3E5F5"
    stroke: "#6A1B9A"
    stroke-width: 2
    border-radius: 8
  }
  grid-columns: 2
  grid-gap: 12
  single_test: |md
    **Single-line test (BLIND)**
    python
    tokens = Scanner('+').scan_tokens()
    assert tokens[0].column == 1  # ✓
    
    Off-by-one per line never triggers
    because there is only 1 line.
    Drift = 0 × 1 = **0** — test passes!
  | {
    style.fill: "#CE93D8"
  }
  multi_test: |md
    **50-line test (CATCHES IT)**
    python
    # After 50 lines with +1 drift per line:
    # Expected: column = 1
    # Actual:   column = 51
    # Difference: 50 — obviously wrong
    assert first.column == 1  # ✗ FAILS
    
    Amplification makes the bug visible.
  | {
    style.fill: "#9C27B0"
    style.font-color: white
  }
}
# ── Root Causes ───────────────────────────────────────────────────────────────
root_causes: "COMMON ROOT CAUSES OF COLUMN DRIFT" {
  style: {
    fill: "#FBE9E7"
    stroke: "#BF360C"
    stroke-width: 2
    border-radius: 8
  }
  grid-columns: 3
  grid-gap: 8
  rc1: "Tab counts as 2\ncol-units instead of 1\n\ncol += tab_width (4 or 8)\ninstead of col += 1" {
    style.fill: "#FFCCBC"
    style.stroke: "#BF360C"
  }
  rc2: "\\r\\n increments\nline TWICE\n\nadvance('\\r') → line++\nadvance('\\n') → line++\n= double-count" {
    style.fill: "#FFCCBC"
    style.stroke: "#BF360C"
  }
  rc3: "Bypassing advance()\nwith self.current += 1\n\nskips column update\ninside comments/strings\n→ drift after comments" {
    style.fill: "#FFCCBC"
    style.stroke: "#BF360C"
  }
}
# ── The Fix ────────────────────────────────────────────────────────────────────
the_fix: "THE FIX: advance() is the SOLE updater of line and column" {
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    border-radius: 8
    bold: true
  }
  fix_code: |python
    def advance(self) -> str:
        ch = self.source[self.current]
        self.current += 1
        if ch == '\n':
            self.line += 1
            self.column = 1   # reset — not increment
        else:
            self.column += 1  # always +1, never +tab_width
        return ch
    # Rule: NEVER do self.current += 1 outside advance()
    # Rule: NEVER do self.column += tab_width
    # Rule: ONLY '\n' increments line (not '\r')
  | {
    style: {
      fill: "#A5D6A7"
      stroke: "#2E7D32"
    }
  }
}
# ── Connections ───────────────────────────────────────────────────────────────
correct -> drifting: "same source\ndifferent impl" {
  style.stroke-dash: 4
  style.stroke: "#555555"
}
drifting.l50d -> catching_test: "column=51 detected\nby assertion" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
correct.l50c -> catching_test: "column=1 passes\nassertion" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
catching_test -> blind_zone: "why single-token\ntests miss this" {
  style.stroke-dash: 4
  style.stroke: "#6A1B9A"
}
root_causes -> the_fix: "prevented by" {
  style.stroke: "#BF360C"
  style.stroke-width: 2
  target-arrowhead.shape: arrow
}
blind_zone -> delta: "amplification\nexplains the gap" {
  style.stroke-dash: 4
  style.stroke: "#F9A825"
}