vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Performance Model: Lexer Throughput & O(n) Complexity
| {near: top-center}

PanelA: "Panel A — Operation Count & Throughput Estimate" {
  style: {
    stroke: "#6a1b9a"
    stroke-width: 4
    fill: "#f3e5f5" # Purple Header base
  }

  ops_table: {
    label: ||md
      | Method | Operations | Cost |
      |--------|-----------|------|
      | `advance()` | index source[current] | 1 op |
      | `advance()` | current += 1 | 1 op |
      | `advance()` | if ch == '\n' branch | 1 op |
      | `advance()` | column += 1 | 1 op |
      | `peek()` | is_at_end() check | 1 op |
      | `peek()` | index source[current] | 1 op |
      | `_scan_token()` | dispatch chain | ~4 ops |
      | **Total** | **Per character** | **~10 ops** |
    ||
    style: {
      fill: "#e3f2fd" # Blue (Data)
      stroke: "#1565c0"
      border-radius: 4
    }
  }

  math: {
    label: ||md
      ### Throughput Calculation
      - CPython throughput: ~10M ops/sec
      - 10,000 lines × 40 chars/line = **400,000 chars**
      - 400,000 chars × 10 ops/char = **4,000,000 ops**
      - 4,000,000 ops ÷ 10,000,000 ops/sec = **0.40 seconds**
      - ✅ **Performance Target: < 1.0s**
    ||
    style: {
      fill: "#e3f2fd" # Blue (Data)
      stroke: "#1565c0"
      border-radius: 6
    }
  }

  token_mem: "Token Object Layout (64-bit)" {
    style.fill: "#f3e5f5"
    0x00: "Type (int)" {
      style.fill: "#bbdefb" # Blue (Data)
      grid-columns: 1
      label: "0x00: Type (enum) [8B]"
    }
    0x08: "Lexeme Pointer (ptr)" {
      style.fill: "#ffe0b2" # Orange (Pointer)
      label: "0x08: Lexeme String Ptr [8B]"
    }
    0x10: "Line (int)" {
      style.fill: "#bbdefb"
      label: "0x10: Line Number [8B]"
    }
    0x18: "Column (int)" {
      style.fill: "#bbdefb"
      label: "0x18: Column Number [8B]"
    }
    0x20: "Padding" {
      style.fill: "#eeeeee" # Gray (Padding)
      label: "0x20: Reserved [32B]"
    }
    "sizeof=64 bytes (one cache line)"
  }
}

PanelB: "Panel B — O(n) Proof & Anti-Pattern" {
  style: {
    stroke: "#6a1b9a"
    stroke-width: 4
    fill: "#f3e5f5"
  }

  proof: "O(n) Invariants" {
    label: ||md
      **Proof:**
      1. `advance()` moves `current` by exactly 1.
         Total `advance()` calls across life of Scanner = n.
      2. `peek()` / `_peek_next()` are O(1) read-only lookups.
      3. Sum of all token lengths emitted = n.
      4. `s.source[start:current]` is a slice, O(k).
      **Result:** Σ O(kᵢ) = O(Σ kᵢ) = **O(n)**. ∎
    ||
    style: {
      fill: "#e3f2fd" # Blue (Data)
      stroke: "#1565c0"
    }
  }

  correct: "✅ CORRECT PATTERN — O(n)" {
    label: ||go
      func (s *Scanner) makeToken(t TokenType) Token {
          // O(k) per token via slicing
          return Token{
              Type:   t,
              Lexeme: s.source[s.start:s.current],
              Line:   s.line,
          }
      }
    ||
    style: {
      fill: "#e8f5e9" # Green (Free/Good)
      stroke: "#2e7d32"
      stroke-width: 2
    }
  }

  antipattern: "❌ ANTI-PATTERN — O(n²)" {
    label: ||go
      // DANGER: String concatenation in loop
      lexeme := ""
      for isIdent(s.peek()) {
          ch := s.advance()
          lexeme += string(ch) // O(k²)
      }
    ||
    style: {
      fill: "#f5f5f5" # Gray (Padding/Bad)
      stroke: "#c62828"
      stroke-width: 3
    }
  }

  ratio_check: "Complexity Ratio Check" {
    label: ||md
      | Input Size (n) | Time (O(n)) | Ratio |
      |----------------|-------------|-------|
      | 1,000 lines    | t₁          | 1.0   |
      | 10,000 lines   | 10.2s       | ~10x ✅|
      | 100,000 lines  | 105.0s      | ~10x ✅|
    ||
    style: {
      fill: "#e3f2fd" # Blue (Data)
      stroke: "#1565c0"
    }
  }
}

# Connections (Pointers/Flow = Orange)
PanelA -> PanelB: "Constraint verification" {
  style: {
    stroke: "#ef6c00" # Orange (Pointers)
    stroke-width: 2
  }
}

PanelA.ops_table -> PanelA.math: "Input" {
  style.stroke: "#ef6c00"
}

PanelB.proof -> PanelB.ratio_check: "Operationalized" {
  style: {
    stroke: "#ef6c00"
    stroke-dash: 3
  }
}

PanelB.correct -> PanelB.antipattern: "VS" {
  style: {
    stroke: "#c62828"
    stroke-width: 2
  }
}