vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

title: |md
  # FSM: Single-Character Token Recognition State Machine
  **M1 Scanner Architecture:** `advance()` consumes one character; dispatch is irrevocable.
  *Invariants: Monotonic `current` pointer; `start` snapshots `current` at entry.*
| {near: top-center}

START: {
  label: "START\n─────\nInvariants:\n- entry: _begin_token()\n- cursor: self.current\n- tokens_emitted: N"
  shape: circle
  style: {
    fill: "#2d1b69"
    font-color: white
    stroke: "#9b59b6"
    stroke-width: 3
    bold: true
  }
}

initial: "" {
  shape: circle
  style: {
    fill: black
    stroke: black
  }
  width: 24
  height: 24
}

EMIT_WHITESPACE: {
  label: "WHITESPACE_SKIP\n───────────────\nAction: discard\nEffect: current updated\nInvariants:\n- tokens_emitted: N"
  shape: rectangle
  style: {
    fill: "#1a3a2a"
    font-color: "#2ecc71"
    stroke: "#2ecc71"
    stroke-width: 2
    border-radius: 8
  }
}

EMIT_SINGLE: {
  label: "ACCEPT: SINGLE_CHAR\n───────────────────\nAction: tokens.append()\nEffect: token_count++\nInvariants:\n- tokens_emitted: N+1"
  shape: rectangle
  style: {
    double-border: true
    fill: "#1a2a3a"
    font-color: "#3498db"
    stroke: "#3498db"
    stroke-width: 2
    border-radius: 8
  }
}

EMIT_EOF: {
  label: "ACCEPT: EOF\n───────────\nAction: tokens.append(EOF)\nEffect: terminate loop\nInvariants:\n- EOF sentinel unique"
  shape: rectangle
  style: {
    double-border: true
    fill: "#2a1a3a"
    font-color: "#9b59b6"
    stroke: "#9b59b6"
    stroke-width: 2
    border-radius: 8
  }
}

EMIT_ERROR: {
  label: "ERROR_STATE\n───────────\nAction: tokens.append(ERR)\nRecovery: next iteration\nInvariants:\n- token_count: N+1"
  shape: rectangle
  style: {
    double-border: true
    fill: "#3a1a1a"
    font-color: "#e74c3c"
    stroke: "#e74c3c"
    stroke-width: 2
    border-radius: 8
  }
}

ILLEGAL_BACKTRACK: {
  label: "ILLEGAL: BACKTRACK\n──────────────────\nGuard: current < start\nEffect: Fatal Architecture Error"
  shape: rectangle
  style: {
    fill: "#1a0a0a"
    font-color: "#c0392b"
    stroke: "#c0392b"
    stroke-width: 1
    stroke-dash: 5
    border-radius: 4
    italic: true
  }
}

initial -> START: "init()" {
  style.stroke: black
  style.stroke-width: 2
}

START -> EMIT_WHITESPACE: "Trigger: [ ' ', \\t, \\r, \\n ]\nGuard: ch in WHITESPACE\nAction: advance()" {
  style.stroke: "#2ecc71"
  style.stroke-width: 2
}

START -> EMIT_SINGLE: "Trigger: [ +, -, *, /, (, ), ... ]\nGuard: ch in SINGLE_MAP\nAction: advance()" {
  style.stroke: "#3498db"
  style.stroke-width: 2
}

START -> EMIT_EOF: "Trigger: \\0 (Null Byte)\nGuard: is_at_end()" {
  style.stroke: "#9b59b6"
  style.stroke-width: 2
}

# FIXED: Escaped the $ character using backslash to prevent substitution error
START -> EMIT_ERROR: "Trigger: [ @, #, \$, ! ... ]\nGuard: fallthrough (no match)\nAction: advance()" {
  style.stroke: "#e74c3c"
  style.stroke-width: 2
}

EMIT_WHITESPACE -> START: "loop: _begin_token()" {
  style.stroke: "#2ecc71"
  style.stroke-dash: 4
  style.stroke-width: 1
}

EMIT_SINGLE -> START: "loop: _begin_token()" {
  style.stroke: "#3498db"
  style.stroke-dash: 4
  style.stroke-width: 1
}

EMIT_ERROR -> START: "loop: _begin_token()" {
  style.stroke: "#e74c3c"
  style.stroke-dash: 4
  style.stroke-width: 1
}

EMIT_WHITESPACE -> ILLEGAL_BACKTRACK: "ILLEGAL" {
  style.stroke: "#c0392b"
  style.stroke-dash: 6
  style.stroke-width: 2
}

legend: {
  label: |md
    **Single-Character State Machine Legend**
    - **●**: Initializer Entry Point
    - **══**: Double Border = Accepting State (Token Emitted)
    - **- - →**: Next Iteration Loop-back
    - **Red Dashed**: ILLEGAL Transition (Never Occurs)
    - **advance()**: The strictly monotonic cursor mutator
    - **_begin_token()**: State reset (start = current)
  |
  near: bottom-right
  style: {
    fill: "#1a1a2e"
    font-color: "#cccccc"
    stroke: "#444466"
    border-radius: 6
  }
}