vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

scan_tokens_sequence: {
  shape: sequence_diagram

  scan_tokens: "scan_tokens()"
  begin_token: "_begin_token()"
  scan_token: "_scan_token()"
  advance_fn: "advance()"
  dispatch: "dispatch logic"
  tokens_list: "self.tokens: list[Token]"

  loop_start: {
    label: "while not is_at_end()"
    shape: text
  }

  scan_tokens -> begin_token: "① snapshot start position" {
    style.stroke: blue
  }
  begin_token -> begin_token: "self.start = self.current\nself.token_start_line = self.line\nself.token_start_column = self.column" {
    style.stroke: "#888888"
    style.font-size: 12
  }
  begin_token -> scan_tokens: "return  [start/line/col frozen]" {
    style.stroke: blue
    style.stroke-dash: 4
  }
  scan_tokens -> scan_token: "② _scan_token()" {
    style.stroke: blue
  }
  scan_token -> advance_fn: "ch = advance()" {
    style.stroke: blue
  }
  advance_fn -> advance_fn: "self.current += 1\nif ch == '\\n': line+=1; col=1\nelse: col+=1" {
    style.stroke: "#888888"
    style.font-size: 12
  }
  advance_fn -> scan_token: "return ch" {
    style.stroke: blue
    style.stroke-dash: 4
  }
  scan_token -> dispatch: "③ dispatch on ch" {
    style.stroke: blue
  }

  whitespace_path: "whitespace branch" {
    shape: text
  }
  dispatch -> whitespace_path: "ch in WHITESPACE → return (no token)" {
    style.stroke: "#888888"
    style.stroke-dash: 3
  }

  single_path: "single-char branch" {
    shape: text
  }
  dispatch -> single_path: "ch in SINGLE_CHAR_TOKENS\n→ _make_token(type)" {
    style.stroke: blue
    style.stroke-dash: 3
  }
  single_path -> tokens_list: "append Token(type, lexeme,\n  token_start_line,\n  token_start_column)" {
    style.stroke: blue
  }

  error_path: "error branch" {
    shape: text
  }
  dispatch -> error_path: "unrecognized ch\n→ _error_token(msg)" {
    style.stroke: red
    style.stroke-dash: 3
  }
  error_path -> tokens_list: "append Token(ERROR, ch,\n  token_start_line,\n  token_start_column)" {
    style.stroke: red
  }
  scan_token -> scan_tokens: "return" {
    style.stroke: blue
    style.stroke-dash: 4
  }

  scan_tokens.repeat_note: "↺  loop repeats: _begin_token() → _scan_token()\n   until is_at_end() == True" {
    style: {
      font-size: 13
      italic: true
    }
  }

  scan_tokens -> tokens_list: "④ after loop:\nappend Token(EOF, '',\n  self.line, self.column)" {
    style.stroke: "#7B2FBE"
    style.stroke-width: 2
  }
  scan_tokens -> scan_tokens: "return self.tokens" {
    style.stroke: blue
    style.stroke-dash: 4
  }
}

invariant_box: |md
  **Invariant: start is always set before advance() in _scan_token()**
  Call order per iteration:
  1. `_begin_token()` → freezes `start`, `token_start_line`, `token_start_column`
  2. `_scan_token()` → calls `advance()` which mutates `self.current`, `self.line`, `self.column`
  3. `_make_token()` uses **frozen** `token_start_*` → position is the first character, not the character after
  Violation: calling `advance()` before `_begin_token()` → token reports wrong position
| {
  near: bottom-center
  style.font-size: 13
}