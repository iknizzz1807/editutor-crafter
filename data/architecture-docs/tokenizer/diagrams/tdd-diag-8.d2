vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Test Matrix — M1 Expected Input → Token Stream
  TDD Red-Green Reference: `scan_tokens()` exact output for three canonical inputs
| {near: top-center}
# ─── Scenario A ───────────────────────────────────────────────────────────────
scenA: "Scenario A" {
  style.fill: "#E8EAF6"
  style.stroke: "#5C6BC0"
  style.border-radius: 6
  input_a: Input {
    shape: rectangle
    style.fill: "#C5CAE9"
    style.stroke: "#3949AB"
    style.font: mono
    label: |md
      `"+ - * /"`
      14 chars, 1 line
    |
  }
  tokens_a: Expected Token Stream {
    shape: rectangle
    style.fill: "#E8EAF6"
    style.stroke: "#5C6BC0"
    t0a: "tokens[0]" {
      shape: rectangle
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.font: mono
      label: |md
        **PLUS**
        lexeme: `'+'`
        line: 1 · col: **1**
      |
    }
    t1a: "tokens[1]" {
      shape: rectangle
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.font: mono
      label: |md
        **MINUS**
        lexeme: `'-'`
        line: 1 · col: **3**
      |
    }
    t2a: "tokens[2]" {
      shape: rectangle
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.font: mono
      label: |md
        **STAR**
        lexeme: `'*'`
        line: 1 · col: **5**
      |
    }
    t3a: "tokens[3]" {
      shape: rectangle
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      style.font: mono
      label: |md
        **SLASH**
        lexeme: `'/'`
        line: 1 · col: **7**
      |
    }
    eofa: "tokens[4]" {
      shape: rectangle
      style.fill: "#E0E0E0"
      style.stroke: "#616161"
      style.font: mono
      label: |md
        **EOF**
        lexeme: `''`
        line: 1 · col: **9**
      |
    }
    t0a -> t1a
    t1a -> t2a
    t2a -> t3a
    t3a -> eofa
  }
  criteria_a: "Acceptance Criteria" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    label: |md
      ✅ Single-char dispatch via `SINGLE_CHAR_TOKENS`
      ✅ Whitespace consumed silently (spaces at cols 2,4,6)
      ✅ 4 real tokens + 1 EOF = **5 total**
      ✅ `len(tokens) == 5`
      ✅ `tokens[-1].type == EOF`
      ✅ Column tracks: each token 2 apart (char + space)
    |
  }
  input_a -> tokens_a
  tokens_a -> criteria_a
}
# ─── Scenario B ───────────────────────────────────────────────────────────────
scenB: "Scenario B" {
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  style.border-radius: 6
  input_b: Input {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.font: mono
    label: |md
      `"+\n-"`
      3 chars, 2 lines
      newline at index 1
    |
  }
  tokens_b: Expected Token Stream {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    t0b: "tokens[0]" {
      shape: rectangle
      style.fill: "#A5D6A7"
      style.stroke: "#1B5E20"
      style.font: mono
      label: |md
        **PLUS**
        lexeme: `'+'`
        line: **1** · col: **1**
      |
    }
    t1b: "tokens[1]" {
      shape: rectangle
      style.fill: "#A5D6A7"
      style.stroke: "#1B5E20"
      style.font: mono
      label: |md
        **MINUS**
        lexeme: `'-'`
        line: **2** · col: **1**
      |
    }
    eofb: "tokens[2]" {
      shape: rectangle
      style.fill: "#E0E0E0"
      style.stroke: "#616161"
      style.font: mono
      label: |md
        **EOF**
        lexeme: `''`
        line: **2** · col: **2**
      |
    }
    t0b -> t1b
    t1b -> eofb
  }
  nl_note: "advance('\\n') trace" {
    shape: rectangle
    style.fill: "#DCEDC8"
    style.stroke: "#558B2F"
    style.font: mono
    label: |md
      `advance('+')` → col=2
      `advance('\n')` → **line=2, col=1**
      `advance('-')` → col=2
      EOF appended: line=2, col=2
    |
  }
  criteria_b: "Acceptance Criteria" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    label: |md
      ✅ `\n` increments `self.line`, resets `self.column`
      ✅ MINUS reports **line=2**, not line=1
      ✅ EOF.column = 2 (one past the `-`)
      ✅ `len(tokens) == 3`
      ✅ `tokens[-1].type == EOF`
      ✅ No token emitted for `\n` (whitespace)
    |
  }
  input_b -> tokens_b
  tokens_b -> nl_note
  tokens_b -> criteria_b
}
# ─── Scenario C ───────────────────────────────────────────────────────────────
scenC: "Scenario C" {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  style.border-radius: 6
  input_c: Input {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#BF360C"
    style.font: mono
    label: |md
      `"@"`
      1 char, unrecognized
      not in any token class
    |
  }
  tokens_c: Expected Token Stream {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    t0c: "tokens[0]" {
      shape: rectangle
      style.fill: "#FFCCBC"
      style.stroke: "#BF360C"
      style.font: mono
      label: |md
        **ERROR**
        lexeme: `'@'`
        line: **1** · col: **1**
      |
    }
    eofc: "tokens[1]" {
      shape: rectangle
      style.fill: "#E0E0E0"
      style.stroke: "#616161"
      style.font: mono
      label: |md
        **EOF**
        lexeme: `''`
        line: **1** · col: **2**
      |
    }
    t0c -> eofc
  }
  err_note: "Error recovery trace" {
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
    style.font: mono
    label: |md
      `_scan_token()` fallthrough hit
      `_error_token()` called
      ERROR appended — **no exception raised**
      `scan_tokens()` loop continues
      `is_at_end()` → True → append EOF
    |
  }
  criteria_c: "Acceptance Criteria" {
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    label: |md
      ✅ Unrecognized char → ERROR token (not exception)
      ✅ `ERROR.lexeme == '@'`
      ✅ `ERROR.line == 1`, `ERROR.column == 1`
      ✅ Scanning **continues** after error
      ✅ `len(tokens) == 2` (ERROR + EOF)
      ✅ `tokens[-1].type == EOF`
      ✅ `EOF.column == 2` (cursor past `@`)
    |
  }
  input_c -> tokens_c
  tokens_c -> err_note
  tokens_c -> criteria_c
}
# ─── Column Layout Legend ──────────────────────────────────────────────────────
legend: "Column Arithmetic Reference" {
  near: bottom-center
  style.fill: "#ECEFF1"
  style.stroke: "#546E7A"
  style.border-radius: 4
  col_rule: {
    shape: rectangle
    style.fill: "#CFD8DC"
    style.stroke: "#455A64"
    style.font: mono
    label: |md
      **Rule:** `token.column` = value of `self.column` at `_begin_token()` call
      `advance(ch)` → if `ch=='\n'`: line++, col=1  else: col++
      Position snapshot frozen at `_begin_token()` — not at `_make_token()`
      **Scenario A column derivation:**
      `'+ - * /'` → indices 0–7
      `+`=idx0 → col **1** │ (space idx1 → col 2, discarded)
      `-`=idx2 → col **3** │ (space idx3 → col 4, discarded)
      `*`=idx4 → col **5** │ (space idx5 → col 6, discarded)
      `/`=idx6 → col **7** │ EOF → col **9** (after `/`, col=8; then `scan_tokens` appends EOF with col=8... wait: after consuming `/`, col becomes 8; EOF.col=8)
    |
  }
}
# ─── Flow connections between scenarios ───────────────────────────────────────
scenA -> scenB: "newline handling →" {
  style.stroke-dash: 4
  style.stroke: "#5C6BC0"
  style.font-size: 12
}
scenB -> scenC: "error recovery →" {
  style.stroke-dash: 4
  style.stroke: "#388E3C"
  style.font-size: 12
}