vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Maximal Munch Decision Trees
  ### Characters: `=`  `!`  `<`  `>`
  **Rule:** After `advance()` consumes first char, call `peek()` — consume second only if match
| {near: top-center}
# ─── TREE A: '=' ─────────────────────────────────────────────────────────────
tree_eq: "advance() → '='" {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  style.border-radius: 8
  root_eq: "advance() consumed '='" {
    style.fill: "#1565C0"
    style.font-color: white
    style.bold: true
  }
  peek_eq: "peek() == '='?" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
  yes_eq: "_match('=') → true\nadvance() consumes '='" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  emit_eqeq: "emit EQUAL_EQUAL\nlexeme: '=='" {
    style.fill: "#2E7D32"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  no_eq: "next char ≠ '='\n_match() returns false\ncursor unchanged" {
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    style.stroke-width: 2
  }
  emit_assign: "emit ASSIGN\nlexeme: '='" {
    style.fill: "#BF360C"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  illegal_eq: "⚠ ILLEGAL PATH\nemit ASSIGN before\nchecking peek()" {
    style.fill: "#B71C1C"
    style.font-color: white
    style.stroke-dash: 5
    style.stroke: "#FF1744"
    style.stroke-width: 3
    style.bold: true
  }
  root_eq -> peek_eq: "lookahead"
  peek_eq -> yes_eq: "YES" { style.stroke: "#388E3C"; style.bold: true }
  peek_eq -> no_eq: "NO" { style.stroke: "#E64A19"; style.bold: true }
  yes_eq -> emit_eqeq
  no_eq -> emit_assign
  peek_eq -> illegal_eq: "SKIP peek() ← NEVER DO THIS" {
    style.stroke: "#FF1744"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.font-color: "#B71C1C"
    style.bold: true
  }
}
# ─── TREE B: '!' ─────────────────────────────────────────────────────────────
tree_bang: "advance() → '!'" {
  style.fill: "#FDE8E8"
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.border-radius: 8
  root_bang: "advance() consumed '!'" {
    style.fill: "#B71C1C"
    style.font-color: white
    style.bold: true
  }
  peek_bang: "peek() == '='?" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
  yes_bang: "_match('=') → true\nadvance() consumes '='" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  emit_neq: "emit BANG_EQUAL\nlexeme: '!='" {
    style.fill: "#2E7D32"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  no_bang: "next char ≠ '='\n_match() returns false\ncursor unchanged" {
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    style.stroke-width: 2
  }
  emit_bang_err: "emit ERROR\nlexeme: '!'\n'!' alone is INVALID\nin this language" {
    style.fill: "#880E4F"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
    style.multiple: true
  }
  illegal_bang: "⚠ ILLEGAL PATH\nemit BANG_ALONE token\n(no such token exists)" {
    style.fill: "#B71C1C"
    style.font-color: white
    style.stroke-dash: 5
    style.stroke: "#FF1744"
    style.stroke-width: 3
    style.bold: true
  }
  root_bang -> peek_bang: "lookahead"
  peek_bang -> yes_bang: "YES" { style.stroke: "#388E3C"; style.bold: true }
  peek_bang -> no_bang: "NO" { style.stroke: "#E64A19"; style.bold: true }
  yes_bang -> emit_neq
  no_bang -> emit_bang_err
  peek_bang -> illegal_bang: "SKIP peek() ← NEVER DO THIS" {
    style.stroke: "#FF1744"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.font-color: "#B71C1C"
    style.bold: true
  }
}
# ─── TREE C: '<' ─────────────────────────────────────────────────────────────
tree_lt: "advance() → '<'" {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  style.border-radius: 8
  root_lt: "advance() consumed '<'" {
    style.fill: "#4A148C"
    style.font-color: white
    style.bold: true
  }
  peek_lt: "peek() == '='?" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
  yes_lt: "_match('=') → true\nadvance() consumes '='" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  emit_leq: "emit LESS_EQUAL\nlexeme: '<='" {
    style.fill: "#2E7D32"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  no_lt: "next char ≠ '='\n_match() returns false\ncursor unchanged" {
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    style.stroke-width: 2
  }
  emit_less: "emit LESS\nlexeme: '<'" {
    style.fill: "#BF360C"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  illegal_lt: "⚠ ILLEGAL PATH\nemit LESS before\nchecking peek()" {
    style.fill: "#B71C1C"
    style.font-color: white
    style.stroke-dash: 5
    style.stroke: "#FF1744"
    style.stroke-width: 3
    style.bold: true
  }
  root_lt -> peek_lt: "lookahead"
  peek_lt -> yes_lt: "YES" { style.stroke: "#388E3C"; style.bold: true }
  peek_lt -> no_lt: "NO" { style.stroke: "#E64A19"; style.bold: true }
  yes_lt -> emit_leq
  no_lt -> emit_less
  peek_lt -> illegal_lt: "SKIP peek() ← NEVER DO THIS" {
    style.stroke: "#FF1744"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.font-color: "#B71C1C"
    style.bold: true
  }
}
# ─── TREE D: '>' ─────────────────────────────────────────────────────────────
tree_gt: "advance() → '>'" {
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
  style.stroke-width: 2
  style.border-radius: 8
  root_gt: "advance() consumed '>'" {
    style.fill: "#1A237E"
    style.font-color: white
    style.bold: true
  }
  peek_gt: "peek() == '='?" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-width: 2
  }
  yes_gt: "_match('=') → true\nadvance() consumes '='" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  emit_geq: "emit GREATER_EQUAL\nlexeme: '>='" {
    style.fill: "#2E7D32"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  no_gt: "next char ≠ '='\n_match() returns false\ncursor unchanged" {
    style.fill: "#FFCCBC"
    style.stroke: "#E64A19"
    style.stroke-width: 2
  }
  emit_greater: "emit GREATER\nlexeme: '>'" {
    style.fill: "#BF360C"
    style.font-color: white
    style.bold: true
    style.border-radius: 6
  }
  illegal_gt: "⚠ ILLEGAL PATH\nemit GREATER before\nchecking peek()\ne.g. '>=' → GREATER+ASSIGN" {
    style.fill: "#B71C1C"
    style.font-color: white
    style.stroke-dash: 5
    style.stroke: "#FF1744"
    style.stroke-width: 3
    style.bold: true
  }
  root_gt -> peek_gt: "lookahead"
  peek_gt -> yes_gt: "YES" { style.stroke: "#388E3C"; style.bold: true }
  peek_gt -> no_gt: "NO" { style.stroke: "#E64A19"; style.bold: true }
  yes_gt -> emit_geq
  no_gt -> emit_greater
  peek_gt -> illegal_gt: "SKIP peek() ← NEVER DO THIS" {
    style.stroke: "#FF1744"
    style.stroke-dash: 5
    style.stroke-width: 2
    style.font-color: "#B71C1C"
    style.bold: true
  }
}
# ─── LEGEND ──────────────────────────────────────────────────────────────────
legend: {
  near: bottom-center
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.border-radius: 6
  content: |md
    **Legend**
    🟦 Root node — character just consumed by `advance()`
    🟨 Decision diamond — `peek()` inspects next char WITHOUT consuming
    🟩 YES branch — `_match(ch)` consumes char, updates position, returns `true`
    🟥 NO branch — `_match(ch)` returns `false`, cursor UNCHANGED
    🟫 Emit node — `_make_token()` called; lexeme = `source[start:current]`
    🔴 ILLEGAL path (dashed red) — emitting token BEFORE `peek()` check
       violates maximal munch; only for `!`: standalone is an ERROR token
  |
}