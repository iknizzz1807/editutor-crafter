direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# Header Section
header: {
  style: {
    stroke: transparent
    fill: transparent
  }
  title: "Attention Complexity Analysis" {
    shape: rectangle
    style: {
      font-size: 28
      bold: true
      underline: true
      stroke: transparent
      fill: transparent
    }
  }
  subtitle: "O(n²) Memory and Compute for Score Matrix" {
    shape: rectangle
    style: {
      font-size: 18
      stroke: transparent
      fill: transparent
    }
  }
}

# ROW 1: Matrix Scaling Comparison
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  seq_64: {
    direction: down
    label: "Sequence Length n = 64"
    matrix_64: {
      shape: sql_table
      label: "Scores [Batch, Head, 64, 64]"
      r0: "Q0 | K0 | K1 | K... | K63"
      r1: "Q1 | K0 | K1 | K... | K63"
      r2: "... | ... | ... | ... | ..."
      r63: "Q63 | K0 | K1 | K... | K63"
      total: "Total: 4,096 scores per head"
    }
    mem_64: {
      label: "Memory Analysis (FP32)"
      style.fill: "#d4edda"
      usage: |'md
        - Elements: 4,096
        - Size: 4,096 * 4 bytes
        - **Total: 16 KB**
        (Fits in L1 Cache)
      '|
    }
    matrix_64 -> mem_64: "calculate"
  }

  seq_256: {
    direction: down
    label: "Sequence Length n = 256"
    matrix_256: {
      shape: sql_table
      label: "Scores [Batch, Head, 256, 256]"
      note: "16x larger than n=64"
      r0: "Rows: 256"
      r1: "Cols: 256"
      total: "Total: 65,536 scores"
    }
    mem_256: {
      label: "Memory Analysis (FP32)"
      style.fill: "#fff3cd"
      usage: |'md
        - Elements: 65,536
        - Size: 65,536 * 4 bytes
        - **Total: 256 KB**
        (Fits in L2 Cache)
      '|
    }
    matrix_256 -> mem_256: "calculate"
  }

  seq_1024: {
    direction: down
    label: "Sequence Length n = 1,024"
    matrix_1024: {
      shape: sql_table
      label: "Scores [Batch, Head, 1k, 1k]"
      r0: "Rows: 1,024"
      r1: "Cols: 1,024"
      total: "Total: 1,048,576 scores"
    }
    mem_1024: {
      label: "Memory Analysis (FP32)"
      style.fill: "#f8d7da"
      usage: |'md
        - Elements: ~1 Million
        - Size: 1M * 4 bytes
        - **Total: 4 MB**
        (Exceeds standard L2)
      '|
    }
    matrix_1024 -> mem_1024: "calculate"
  }

  seq_4096: {
    direction: down
    label: "Sequence Length n = 4,096"
    matrix_4096: {
      shape: sql_table
      label: "Scores [Batch, Head, 4k, 4k]"
      r0: "Rows: 4,096"
      r1: "Cols: 4,096"
      total: "Total: 16.8 Million scores"
    }
    mem_4096: {
      label: "Memory Analysis (FP32)"
      style.fill: "#f5c6cb"
      usage: |'md
        - Elements: 16,777,216
        - Size: 16.8M * 4 bytes
        - **Total: 64 MB**
        (Significant VRAM pressure)
      '|
    }
    matrix_4096 -> mem_4096: "calculate"
  }
}

# ROW 2: Theoretical & Impact Analysis
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  formula: {
    label: "Complexity Theory"
    style: {
      fill: "#e2e3e5"
      stroke: "#6c757d"
    }
    content: |'md
      **Attention Mechanism:**
      `Attention(Q, K, V) = softmax(QKᵀ / √dₖ)V`

      **Complexity Metrics:**
      - Space: `O(n²)` per head
      - Time: `O(n² * d)`
      - MatMul: `[n, d] @ [d, n] = [n, n]`
    '|
  }

  scaling: {
    label: "Scaling Table"
    style: {
      fill: "#cce5ff"
      stroke: "#004085"
    }
    # Using |'md to handle the pipe characters in the table
    table: |'md
      | n (Seq) | n² (Entries) | Mem (FP32) |
      | :--- | :--- | :--- |
      | 512 | 262,144 | 1.0 MB |
      | 1,024 | 1,048,576 | 4.0 MB |
      | 2,048 | 4,194,304 | 16.0 MB |
      | 4,096 | 16,777,216 | 64.0 MB |
      | 8,192 | 67,108,864 | 256.0 MB |
    '|
  }

  real_impact: {
    label: "Real-World Context"
    style: {
      fill: "#fff3cd"
      stroke: "#856404"
    }
    context: |'md
      **Multi-Head Batch Setup:**
      - Batch Size: 32
      - Num Heads: 8
      - Precision: FP32

      **At n = 8,192:**
      `32 * 8 * 256 MB = 64 GB VRAM`
      *Exceeds single A100 (40GB/80GB) capacity*
    '|
  }
}

# ROW 3: Optimization Strategies
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  mitigation: {
    label: "Mitigation & Modern Architectures"
    width: 800
    style: {
      fill: "#d1ecf1"
      stroke: "#0c5460"
    }
    strategies: |'md
      1. **Flash Attention:** Fused kernels, online softmax; reduces memory to **O(n)** by not materializing `QKᵀ`.
      2. **Sparse Attention:** Global + Local + Random sliding windows (e.g., BigBird); reduces to **O(n)** or **O(n log n)**.
      3. **Linear Attention:** Uses kernel trick `(φ(Q)φ(K)ᵀ)V` to change order of ops; reduces to **O(n)**.
      4. **Multi-Query Attention (MQA):** Shared K/V across all heads; reduces KV cache size during inference.
      5. **Sliding Window Attention:** Fixed-size local context; common in Longformer/Mistral.
    '|
  }
}

# Global Legend
legend: {
  near: bottom-right
  label: "Memory Legend (Per Head)"
  low: "Low (< 1MB)" {
    style.fill: "#d4edda"
  }
  med: "Moderate (1-10MB)" {
    style.fill: "#fff3cd"
  }
  high: "Critical (> 10MB)" {
    style.fill: "#f8d7da"
  }
  low -> med -> high: "n increasing"
}