direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Query-Key-Value Decomposition (attention.h)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  x_container: {
    direction: down
    label: "Input Embedding"
    x: {
      shape: sql_table
      label: "X [batch, seq, d_model]"
      f0: "batch × seq"
      f1: "d_model = 512"
      dim: "Shape: [B, L, 512]"
    }
    x.style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
    }
  }
  arrow1: {
    shape: text
    label: "→"
    style: {
      font-size: 40
      font-color: "#6B7280"
    }
  }
  projections: {
    direction: down
    label: "Learned Projections"
    wq: {
      shape: sql_table
      label: "W_Q [d_model, d_k]"
      w0: "512 × 64"
      note: "Query weights"
    }
    wk: {
      shape: sql_table
      label: "W_K [d_model, d_k]"
      w0: "512 × 64"
      note: "Key weights"
    }
    wv: {
      shape: sql_table
      label: "W_V [d_model, d_v]"
      w0: "512 × 64"
      note: "Value weights"
    }
    wq.style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
    }
    wk.style: {
      fill: "#D1FAE5"
      stroke: "#059669"
    }
    wv.style: {
      fill: "#EDE9FE"
      stroke: "#7C3AED"
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  q_container: {
    direction: down
    label: "Query Projection"
    q_math: {
      label: "Q = X @ W_Q"
      code: |'python
        Q = self.W_Q(x)
        # [B, L, 512] @ [512, 64]
        # → [B, L, 64]
      '|
      width: 280
    }
    q: {
      shape: sql_table
      label: "Q [batch, seq, d_k]"
      f0: "batch × seq"
      f1: "d_k = 64"
      dim: "Shape: [B, L, 64]"
    }
    q.style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
    }
    q_math.style: {
      fill: "#FFFBEB"
      stroke: "#D97706"
      font: mono
    }
  }
  k_container: {
    direction: down
    label: "Key Projection"
    k_math: {
      label: "K = X @ W_K"
      code: |'python
        K = self.W_K(x)
        # [B, L, 512] @ [512, 64]
        # → [B, L, 64]
      '|
      width: 280
    }
    k: {
      shape: sql_table
      label: "K [batch, seq, d_k]"
      f0: "batch × seq"
      f1: "d_k = 64"
      dim: "Shape: [B, L, 64]"
    }
    k.style: {
      fill: "#D1FAE5"
      stroke: "#059669"
    }
    k_math.style: {
      fill: "#ECFDF5"
      stroke: "#059669"
      font: mono
    }
  }
  v_container: {
    direction: down
    label: "Value Projection"
    v_math: {
      label: "V = X @ W_V"
      code: |'python
        V = self.W_V(x)
        # [B, L, 512] @ [512, 64]
        # → [B, L, 64]
      '|
      width: 280
    }
    v: {
      shape: sql_table
      label: "V [batch, seq, d_v]"
      f0: "batch × seq"
      f1: "d_v = 64"
      dim: "Shape: [B, L, 64]"
    }
    v.style: {
      fill: "#EDE9FE"
      stroke: "#7C3AED"
    }
    v_math.style: {
      fill: "#F5F3FF"
      stroke: "#7C3AED"
      font: mono
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  metaphor: {
    label: "Library Analogy"
    width: 700
    code: |'text
      ┌─────────────────────────────────────────────────────────────────┐
      │  Query (Q)    │  "I need books about neural networks"           │
      │  Key (K)      │  Book spine: title, author, subject             │
      │  Value (V)    │  Book contents: actual information              │
      │  Match        │  Q · K^T = similarity score between query & key │
      └─────────────────────────────────────────────────────────────────┘
    '|
  }
  metaphor.style: {
    fill: "#F9FAFB"
    stroke: "#9CA3AF"
    font: mono
  }
}
x_container.x -> projections: "Linear projections" {
  style: {
    stroke: "#6B7280"
    stroke-width: 2
  }
}
projections.wq -> q_container: " " {
  style: {
    stroke: "#D97706"
    stroke-width: 3
  }
}
projections.wk -> k_container: " " {
  style: {
    stroke: "#059669"
    stroke-width: 3
  }
}
projections.wv -> v_container: " " {
  style: {
    stroke: "#7C3AED"
    stroke-width: 3
  }
}
legend: {
  near: bottom-right
  label: "Dimension Key"
  dims: {
    shape: sql_table
    label: "Notation"
    b: "B = batch size"
    l: "L = sequence length"
    d: "d_model = 512"
    dk: "d_k = d_v = 64"
  }
  dims.style: {
    fill: "#F3F4F6"
    stroke: "#6B7280"
  }
}