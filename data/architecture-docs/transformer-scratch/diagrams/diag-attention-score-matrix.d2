direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Attention Score Matrix Construction (attention.py)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  q_tensor: {
    label: "Q (Query)"
    shape: class
    label: "Q: [batch, seq_len, d_k]"
    batch_dim: "batch"
    seq_dim: "seq_len"
    feat_dim: "d_k (64)"
    shape_info: "e.g., [32, 20, 64]"
  }
  k_tensor: {
    label: "K (Key)"
    shape: class
    label: "K: [batch, seq_len, d_k]"
    batch_dim: "batch"
    seq_dim: "seq_len"
    feat_dim: "d_k (64)"
    shape_info: "e.g., [32, 20, 64]"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  k_transpose: {
    label: "K^T (Transpose)"
    shape: class
    label: "K^T: [batch, d_k, seq_len]"
    batch_dim: "batch"
    feat_dim: "d_k (64)"
    seq_dim: "seq_len"
    shape_info: "e.g., [32, 64, 20]"
    note: "swap last two dims"
  }
  matmul_op: {
    label: "@"
    shape: circle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 3
      font-size: 24
      bold: true
    }
  }
  scores_raw: {
    shape: sql_table
    label: "Raw Scores: [batch, seq_len, seq_len]"
    r0: "batch=0, Q[0]·K^T | scores[0,0,:] | shape: [seq_len]"
    r1: "batch=0, Q[1]·K^T | scores[0,1,:] | shape: [seq_len]"
    r2: "... | ... | ..."
    r3: "batch=0, Q[n]·K^T | scores[0,n,:] | shape: [seq_len]"
    info: "Each row i = Q[i]'s attention to all K positions"
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  scale_op: {
    label: "/ √d_k"
    shape: circle
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 3
      font-size: 20
      bold: true
    }
  }
  scaled_scores: {
    shape: sql_table
    label: "Scaled Scores"
    formula: "scores / sqrt(d_k)"
    d_k_val: "d_k = 64, sqrt(64) = 8"
    before: "Before: values like [18, 20, 15, 19]"
    after: "After:  values like [2.25, 2.5, 1.875, 2.375]"
    why: "Prevents softmax saturation"
    size: "Shape: [batch, seq_len, seq_len]"
  }
}
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  softmax_op: {
    label: "softmax"
    shape: hexagon
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 3
      font-size: 18
      bold: true
    }
  }
  weights: {
    shape: sql_table
    label: "Attention Weights: [batch, seq_len, seq_len]"
    w0: "0 | 0.10 | 0.25 | 0.15 | ... | Σ=1.0"
    w1: "1 | 0.08 | 0.30 | 0.12 | ... | Σ=1.0"
    w2: "2 | 0.05 | 0.20 | 0.35 | ... | Σ=1.0"
    w3: "... | ... | ... | ... | ... | ..."
    constraint: "Each row sums to 1.0 (probability dist)"
    semantic: "Row i = how much position i attends to each position"
  }
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  v_tensor: {
    label: "V (Value)"
    shape: class
    label: "V: [batch, seq_len, d_v]"
    batch_dim: "batch"
    seq_dim: "seq_len"
    feat_dim: "d_v (64)"
    shape_info: "e.g., [32, 20, 64]"
  }
  apply_op: {
    label: "@"
    shape: circle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 3
      font-size: 24
      bold: true
    }
  }
  output: {
    label: "Output"
    shape: class
    label: "Output: [batch, seq_len, d_v]"
    batch_dim: "batch"
    seq_dim: "seq_len"
    feat_dim: "d_v (64)"
    semantic: "Weighted sum of value vectors"
    shape_info: "e.g., [32, 20, 64]"
  }
}
q_tensor -> matmul_op: "Q"
k_transpose -> matmul_op: "K^T"
matmul_op -> scores_raw: "matmul"
scores_raw -> scale_op: "raw"
scale_op -> scaled_scores: "scaled"
scaled_scores -> softmax_op: "scaled"
softmax_op -> weights: "normalized"
weights -> apply_op: "weights"
v_tensor -> apply_op: "V"
apply_op -> output: "output"
legend: {
  near: bottom-center
  label: "Key Operations"
  style.fill: "#F5F5F5"
  style.stroke: "#BDBDBD"
  style.border-radius: 8
  op1: "Q @ K^T  →  Compute similarity scores (dot product)"
  op2: "/ √d_k  →  Scale for numerical stability"
  op3: "softmax →  Convert to probabilities (row-wise)"
  op4: "weights @ V  →  Weighted sum of values"
  op1.style.font: mono
  op2.style.font: mono
  op3.style.font: mono
  op4.style.font: mono
}