direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Attention as Weighted Sum
  ## Weighted combination of value vectors
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  weights_matrix: {
    direction: down
    label: "Attention Weights"
    shape: sql_table
    label: "α [seq_len × seq_len]"
    row0: "i=0 | α₀₀ | α₀₁ | α₀₂ | α₀₃"
    row1: "i=1 | α₁₀ | α₁₁ | α₁₂ | α₁₃"
    row2: "i=2 | α₂₀ | α₂₁ | α₂₂ | α₂₃"
    row3: "i=3 | α₃₀ | α₃₁ | α₃₂ | α₃₃"
    note: "Each row sums to 1.0"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
  op: {
    label: "×"
    shape: text
    style.font-size: 48
    style.font-color: "#666"
  }
  values_matrix: {
    direction: down
    label: "Value Vectors"
    shape: sql_table
    label: "V [seq_len × d_v]"
    v0: "j=0 | V₀ | [d_v = 64]"
    v1: "j=1 | V₁ | [d_v = 64]"
    v2: "j=2 | V₂ | [d_v = 64]"
    v3: "j=3 | V₃ | [d_v = 64]"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  output_matrix: {
    direction: down
    label: "Output"
    shape: sql_table
    label: "Output [seq_len × d_v]"
    out0: "i=0 | Σⱼ α₀ⱼ · Vⱼ | weighted sum"
    out1: "i=1 | Σⱼ α₁ⱼ · Vⱼ | weighted sum"
    out2: "i=2 | Σⱼ α₂ⱼ · Vⱼ | weighted sum"
    out3: "i=3 | Σⱼ α₃ⱼ · Vⱼ | weighted sum"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
weights_matrix -> op
op -> values_matrix
values_matrix -> output_matrix: "matmul"
example: {
  label: "Example: Position 2 Output"
  width: 400
  code: |'python
    # Output[2] = weighted combination of ALL value vectors
    # Using attention weights from row 2
    output[2] = (α₂₀ * V₀) + (α₂₁ * V₁) + (α₂₂ * V₂) + (α₂₃ * V₃)
    # If α₂ = [0.1, 0.2, 0.5, 0.2]
    # output[2] heavily attends to V₂ (50% weight)
    # with contributions from V₁ and V₃ (20% each) and V₀ (10%)
  '|
  style.fill: "#FAFAFA"
  style.stroke: "#DDD"
}
row1 -> example: "computation"
example -> output_matrix: "produces"
legend: {
  near: bottom-right
  direction: right
  style.fill: transparent
  style.stroke: transparent
  key: {
    shape: sql_table
    label: "Key"
    k1: "αᵢⱼ | attention weight from pos i to pos j"
    k2: "Vⱼ | value vector at position j"
    k3: "Σⱼ | sum over all key positions j"
  }
}
footer: |md
  **Shape trace:** `α[seq, seq] @ V[seq, d_v] → Output[seq, d_v]`
  Each output position is a **convex combination** of all value vectors.
| {near: bottom-center}