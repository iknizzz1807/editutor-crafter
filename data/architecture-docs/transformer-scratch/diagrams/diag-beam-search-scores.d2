direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "Beam Search: Score Accumulation & Length Penalty"
  content: |md
    ### Implementation Blueprint
    How log probabilities accumulate and why length penalty is essential for NMT systems.
  |
}
title_node.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: {
    label: "Step 1: Token Selection"
    direction: down
    
    hypotheses_before: {
      shape: sql_table
      label: "Hypotheses (t-1)"
      h1: "0x01 | [The] | -0.51"
      h2: "0x02 | [A]   | -0.69"
      sz: "Log Probability Scores"
    }
    
    expansions: {
      shape: sql_table
      label: "Candidate Expansions (t)"
      e1: "Hyp 1 + cat   | log P=-0.92 | total=-1.43"
      e2: "Hyp 1 + dog   | log P=-1.20 | total=-1.71"
      e3: "Hyp 2 + cat   | log P=-0.92 | total=-1.61"
      e4: "Hyp 2 + mouse | log P=-1.50 | total=-2.19"
    }
    
    hypotheses_before -> expansions: "Prob | expand"
  }

  formula_box: {
    label: "Accumulation Formula"
    width: 350
    note: |'md
      $$score(y_{1...n}) = \sum_{t=1}^{n} \log P(y_t | y_{<t})$$
      
      **Key Constraints:**
      - Log probs are negative
      - Sum is strictly decreasing
      - Favoring short sequences
    '|
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  problem_demo: {
    label: "The Problem: Length Bias"
    direction: down
    style.fill: "#ffebee"
    style.stroke: "#ef5350"

    seq_comparison: {
      shape: sql_table
      label: "Sequence Score (Bias)"
      short: "The cat | len=2 | -1.43"
      long: "The cat sat on mat | len=5 | -4.21"
      note: "Higher score (closer to 0) wins"
    }
    
    bias_note: {
      label: "Mechanism of Bias"
      content: |md
        - Early EOS is "rewarded"
        - Each token adds penalty
        - Model cuts outputs short
      |
    }
    seq_comparison -> bias_note: "bias"
  }

  solution_box: {
    label: "The Solution: Length Penalty"
    direction: down
    style.fill: "#e8f5e9"
    style.stroke: "#66bb6a"

    penalty_formula: {
      shape: class
      label: "LP Formula (lp.py)"
      +adjusted_score: "score / ((5 + length) / 6)^alpha"
      -alpha_val: "Commonly 0.6 to 0.7"
      +get_penalty(len, alpha): "float"
    }

    penalty_table: {
      shape: sql_table
      label: "Penalty Factors (alpha=0.6)"
      len2: "len=2 | Factor=1.17 | LP=1.10"
      len5: "len=5 | Factor=1.67 | LP=1.35"
      len10: "len=10 | Factor=2.50 | LP=1.87"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  corrected_example: {
    label: "Corrected Scores (alpha=0.6)"
    width: 800
    direction: right

    corrected_table: {
      shape: sql_table
      label: "Adjusted Comparison"
      short: "Short | raw=-1.43 | adj=-1.30"
      long: "Long | raw=-4.21 | adj=-2.25"
      res: "Penalty scales by length"
    }
    
    logic_note: {
      label: "Post-Processing Note"
      content: |md
        The penalty reduces the gap but 
        preserves relative model confidence.
        EOS must be reached to apply LP.
      |
    }
    corrected_table -> logic_note
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  algorithm: {
    label: "Implementation (beam.py)"
    style.fill: "#e3f2fd"
    style.stroke: "#42a5f5"
    code: |'python
    def get_score(hyp, lp_alpha):
      raw = sum(hyp.log_probs)
      if not hyp.is_finished:
        return raw
      # Length Penalty (Google NMT)
      lp = ((5 + len(hyp)) / 6) ** lp_alpha
      return raw / lp
    '|
  }

  tradeoffs: {
    label: "Alpha Tuning"
    alpha_table: {
      shape: sql_table
      label: "Alpha Impact"
      low: "alpha < 0.5 | Brief outputs"
      med: "alpha 0.6 | Balanced (GNMT)"
      high: "alpha > 0.8 | Verbose outputs"
    }
  }
}

row1 -> row2: "Bias | trigger"
row2 -> row3: "Logic | fix"
row3 -> row4: "Code | apply"

legend: {
  label: "Legend"
  problem: "🔴 Bias / Error" { style.font-color: "#ef5350" }
  solution: "🟢 Correction" { style.font-color: "#66bb6a" }
  impl: "🔵 Implementation" { style.font-color: "#42a5f5" }
}
legend.near: bottom-right
legend.style.fill: "#f8f9fa"