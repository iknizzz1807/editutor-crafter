direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # Beam Search Exploration (Beam Width = 3)
  Each step expands top-k hypotheses, prunes low-scoring paths, and tracks until EOS
'|
title.near: top-center

classes: {
  node_active: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  node_pruned: {
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-dash: 3
      opacity: 0.5
    }
  }
  node_eos: {
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 3
    }
  }
  node_final: {
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 4
      shadow: true
    }
  }
}

beam_tree: {
  direction: down
  
  step0: {
    label: "Step 0: Start"
    style.fill: "#F5F5F5"
    start: "<sos>" {
      class: node_active
      width: 80
    }
  }

  step1: {
    label: "Step 1: Expand Top-3"
    style.fill: "#FAFAFA"
    direction: right
    h1_1: "The\nscore: -0.2" {
      class: node_active
    }
    h1_2: "A\nscore: -0.4" {
      class: node_active
    }
    h1_3: "In\nscore: -0.5" {
      class: node_active
    }
    h1_4: "Once\nscore: -0.9\n❌ PRUNED" {
      class: node_pruned
    }
  }

  step2: {
    label: "Step 2: Expand Each Hypothesis"
    style.fill: "#FAFAFA"
    direction: right
    col1: {
      direction: down
      style.stroke: transparent
      h2_1a: "The cat\nscore: -0.5" {
        class: node_active
      }
      h2_1b: "The dog\nscore: -0.7" {
        class: node_active
      }
      h2_1c: "The\nscore: -1.2\n❌ PRUNED" {
        class: node_pruned
      }
    }
    col2: {
      direction: down
      style.stroke: transparent
      h2_2a: "A cat\nscore: -0.8" {
        class: node_active
      }
      h2_2b: "A dog\nscore: -1.0\n❌ PRUNED" {
        class: node_pruned
      }
    }
    col3: {
      direction: down
      style.stroke: transparent
      h2_3a: "In the\nscore: -0.9\n❌ PRUNED" {
        class: node_pruned
      }
    }
  }

  step3: {
    label: "Step 3: EOS Reached"
    style.fill: "#FAFAFA"
    direction: right
    col1_final: {
      direction: down
      style.stroke: transparent
      h3_1a: "The cat sat\nscore: -0.8" {
        class: node_active
      }
      h3_1b: "The cat <eos>\nscore: -1.1\n✓ COMPLETE" {
        class: node_eos
      }
    }
    col2_final: {
      direction: down
      style.stroke: transparent
      h3_2: "A cat <eos>\nscore: -1.3\n✓ COMPLETE" {
        class: node_eos
      }
    }
    col3_final: {
      direction: down
      style.stroke: transparent
      h3_3: "The dog <eos>\nscore: -1.2\n✓ COMPLETE" {
        class: node_eos
      }
    }
  }

  final: {
    label: "Final Result"
    style.fill: "#E8F5E9"
    winner: "Best: 'The cat sat'\nLength-penalized score: -0.26" {
      class: node_final
      width: 200
    }
  }
}

beam_tree.step0.start -> beam_tree.step1.h1_1: "P=0.82"
beam_tree.step0.start -> beam_tree.step1.h1_2: "P=0.67"
beam_tree.step0.start -> beam_tree.step1.h1_3: "P=0.61"
beam_tree.step0.start -> beam_tree.step1.h1_4: "P=0.41" {
  style.stroke-dash: 3
  style.stroke: "#F44336"
}

beam_tree.step1.h1_1 -> beam_tree.step2.col1.h2_1a: "P=0.74"
beam_tree.step1.h1_1 -> beam_tree.step2.col1.h2_1b: "P=0.63"
beam_tree.step1.h1_1 -> beam_tree.step2.col1.h2_1c: "P=0.30" {
  style.stroke-dash: 3
  style.stroke: "#F44336"
}

beam_tree.step1.h1_2 -> beam_tree.step2.col2.h2_2a: "P=0.57"
beam_tree.step1.h1_2 -> beam_tree.step2.col2.h2_2b: "P=0.45" {
  style.stroke-dash: 3
  style.stroke: "#F44336"
}

beam_tree.step1.h1_3 -> beam_tree.step2.col3.h2_3a: "P=0.41" {
  style.stroke-dash: 3
  style.stroke: "#F44336"
}

beam_tree.step2.col1.h2_1a -> beam_tree.step3.col1_final.h3_1a: "P=0.74"
beam_tree.step2.col1.h2_1a -> beam_tree.step3.col1_final.h3_1b: "P=0.50 <eos>" {
  style.stroke: "#2196F3"
}
beam_tree.step2.col1.h2_1b -> beam_tree.step3.col3_final.h3_3: "P=0.63 <eos>" {
  style.stroke: "#2196F3"
}
beam_tree.step2.col2.h2_2a -> beam_tree.step3.col2_final.h3_2: "P=0.55 <eos>" {
  style.stroke: "#2196F3"
}

beam_tree.step3.col1_final.h3_1a -> beam_tree.final.winner: "BEST" {
  style.stroke-width: 4
  style.stroke: "#2E7D32"
}
beam_tree.step3.col1_final.h3_1b -> beam_tree.final.winner: "complete" {
  style.stroke-dash: 3
}
beam_tree.step3.col2_final.h3_2 -> beam_tree.final.winner: "complete" {
  style.stroke-dash: 3
}
beam_tree.step3.col3_final.h3_3 -> beam_tree.final.winner: "complete" {
  style.stroke-dash: 3
}

legend: {
  near: bottom-center
  direction: right
  active: "Active Hypothesis" {
    class: node_active
    width: 100
  }
  pruned: "Pruned (outside top-3)" {
    class: node_pruned
    width: 140
  }
  eos_node: "EOS (Complete)" {
    class: node_eos
    width: 120
  }
  final_node: "Best Result" {
    class: node_final
    width: 100
  }
}

notes: {
  near: bottom-right
  style.fill: "#FFF8E1"
  width: 280
  scoring: |'md
    **Scoring Rules:**
    - Score = Σ log P(token | context)
    - Log probs are negative (probabilities < 1)
    - Longer sequences → lower scores

    **Length Penalty:**
    adjusted = score / ((5+len)/6)^α
    α=0.6 counteracts length bias
  '|
}