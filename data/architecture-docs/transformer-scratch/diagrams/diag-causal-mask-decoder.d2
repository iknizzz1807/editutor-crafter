    grid-columns: 7
    grid-rows: 7
    grid-gap: 0
    # Header row
    h0: "" {style: {fill: transparent; stroke: transparent}}
    h1: "K0" {style: {font: mono; bold: true; font-size: 14}}
    h2: "K1" {style: {font: mono; bold: true; font-size: 14}}
    h3: "K2" {style: {font: mono; bold: true; font-size: 14}}
    h4: "K3" {style: {font: mono; bold: true; font-size: 14}}
    h5: "K4" {style: {font: mono; bold: true; font-size: 14}}
    h6: "K5" {style: {font: mono; bold: true; font-size: 14}}
    # Row 0: Q0
    r0h: "Q0" {style: {font: mono; bold: true; font-size: 14}}
    r0c0: "0" {style: {fill: "#90EE90"; font: mono}}
    r0c1: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r0c2: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r0c3: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r0c4: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r0c5: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
