# Row 5: Implementation
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  impl_box: {
    label: "Implementation (PyTorch)"
    width: 720
    impl_code: {
      label: "create_causal_mask() (attention.py)"
      code: |'python
        def create_causal_mask(seq_len: int, device='cuda') -> torch.Tensor:
            """
            Create causal mask for decoder self-attention.
            Positions can only attend to themselves and earlier positions.
            Args:
                seq_len: Sequence length
                device: Device to create tensor on
            Returns:
                mask: [1, 1, seq_len, seq_len] where True = masked (ignore)
            Example for seq_len=4:
                [[0, 1, 1, 1],     Q0 sees only K0
                 [0, 0, 1, 1],     Q1 sees K0, K1
                 [0, 0, 0, 1],     Q2 sees K0, K1, K2
                 [0, 0, 0, 0]]     Q3 sees all
            """
            # Upper triangular matrix (diagonal=1 excludes diagonal)
            mask = torch.triu(
                torch.ones(seq_len, seq_len, device=device), 
                diagonal=1
            ).bool()
            # Add batch and head dimensions: [1, 1, seq, seq]
            return mask.unsqueeze(0).unsqueeze(0)
        # Usage in attention:
        # scores = scores.masked_fill(causal_mask, float('-inf'))
        # attention_weights = F.softmax(scores, dim=-1)
        # exp(-inf) = 0, so masked positions contribute nothing
      '|
      width: 700
    }
  }
}
# Row 6: Key Takeaway
row6: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  takeaway: {
    label: "Key Takeaway"
    width: 720
    takeaway_content: {
      shape: class
      label: "The Causal Constraint"
      +definition: "Position i can only attend to positions 0..i (itself and earlier)"
      +mechanism: "Upper-triangular mask with -inf → softmax produces 0.0 for masked positions"
      +purpose: "Ensures model learns to generate without cheating by looking at future tokens"
      +consistency: "Same mask at training and inference = no distribution shift"
    }
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      stroke-width: 2
    }
  }
}