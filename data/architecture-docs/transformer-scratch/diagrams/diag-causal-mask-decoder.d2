    r1c0: "0" {style: {fill: "#90EE90"; font: mono}}
    r1c1: "0" {style: {fill: "#90EE90"; font: mono}}
    r1c2: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r1c3: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r1c4: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
    r1c5: "-∞" {style: {fill: "#FF6B6B"; font: mono}}
