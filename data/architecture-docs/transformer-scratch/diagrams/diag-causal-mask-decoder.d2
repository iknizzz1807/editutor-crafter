direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Causal Mask in Decoder Self-Attention"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
# Row 1: Mask Matrix and Explanation
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  # Left: The actual mask matrix
