    width: 420
  }
  # Right: Legend and explanation
  explanation: {
    label: "Mask Semantics"
    legend: {
      shape: class
      label: "Legend"
      allowed: "0 = attend (not masked)"
      blocked: "-∞ = blocked (masked)"
    }
    shape_note: {
      label: "Upper-Triangular Pattern"
      code: |'python
        # torch.triu with diagonal=1
        mask = torch.triu(
            torch.ones(seq, seq), 
            diagonal=1
        ).bool()
        # True in upper triangle
        # → set to -inf before softmax
      '|
      width: 320
    }
    width: 350
  }
}
# Row 2: Why This Matters
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  training_box: {
    label: "Training Time"
    width: 350
    t_step1: {
      label: "1. Full target visible"
      code: |'python
        # Teacher forcing gives all tokens
        tgt = [sos, The, cat, sat, eos]
        # But mask prevents cheating
      '|
    }
    t_step2: {
      label: "2. Mask enforces causality"
      code: |'python
        # Position 2 attends to 0,1,2
        # NOT to 3,4 (future tokens)
        Q2 @ [K0, K1, K2, K3, K4]
        # K3, K4 masked with -inf
      '|
    }
  }
  inference_box: {
    label: "Inference Time"
    width: 350
    i_step1: {
      label: "1. Generate autoregressively"
      code: |'python
        # Token i only sees 0..i
        # Same constraint as training
        for i in range(max_len):
            out = decode(generated[:i+1])
            next = argmax(out[-1])
            generated.append(next)
      '|
    }
    i_step2: {
      label: "2. No information leakage"
      code: |'python
        # Model cannot "cheat" by
        # looking at tokens it hasn't
        # generated yet
        # This matches training!
      '|
    }
  }
}
# Row 3: The Key Insight
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  insight_box: {
    label: "Why Causal Masking Enables Autoregressive Generation"
    width: 720
    insight_content: {
      shape: class
      label: "Critical Insight"
      +principle: "Same constraint at train and inference"
      +training: "During training, mask prevents model from seeing future tokens even though they're in the batch"
      +inference: "During inference, future tokens don't exist yet—mask ensures model never needed them"
      +consistency: "This train/test consistency is why autoregressive generation works"
    }
  }
}
