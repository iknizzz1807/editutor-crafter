direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Cross-Attention Information Flow {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  encoder_stack: {
    direction: down
    label: "Encoder Stack"
    style.fill: "#E8F4E8"
    enc_layer1: {
      label: "Encoder Layer 1"
      shape: rectangle
      style.fill: "#C8E6C8"
    }
    enc_layer2: {
      label: "Encoder Layer 2"
      shape: rectangle
      style.fill: "#C8E6C8"
    }
    enc_layerN: {
      label: "Encoder Layer N"
      shape: rectangle
      style.fill: "#C8E6C8"
      style.stroke-dash: 3
    }
    enc_layer1 -> enc_layer2
    enc_layer2 -> enc_layerN
  }
  decoder_stack: {
    direction: down
    label: "Decoder Stack"
    style.fill: "#E8E8F4"
    dec_layer1: {
      label: "Decoder Layer 1"
      shape: rectangle
      style.fill: "#C8C8E6"
    }
    dec_layer2: {
      label: "Decoder Layer 2"
      shape: rectangle
      style.fill: "#C8C8E6"
    }
    dec_layerN: {
      label: "Decoder Layer N"
      shape: rectangle
      style.fill: "#C8C8E6"
      style.stroke-dash: 3
    }
    dec_layer1 -> dec_layer2
    dec_layer2 -> dec_layerN
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  encoder_output: {
    label: "Encoder Output\nK, V [batch, src_len, d_model]"
    shape: cylinder
    style: {
      fill: "#4CAF50"
      stroke: "#2E7D32"
      font-color: white
      bold: true
    }
  }
  cross_attn_detail: {
    label: "Cross-Attention Detail"
    style.fill: "#FFF3E0"
    q_source: {
      label: "Query (Q)\nfrom Decoder"
      shape: rectangle
      style: {
        fill: "#2196F3"
        font-color: white
      }
    }
    kv_source: {
      label: "Key (K), Value (V)\nfrom Encoder Output"
      shape: rectangle
      style: {
        fill: "#4CAF50"
        font-color: white
      }
    }
    attention_op: {
      label: "Attention\nQ × Kᵀ → Weights\nWeights × V → Output"
      shape: diamond
      style.fill: "#FF9800"
    }
    q_source -> attention_op: "Q"
    kv_source -> attention_op: "K, V"
  }
}
encoder_stack.enc_layerN -> encoder_output: "Final Output" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    bold: true
  }
}
encoder_output -> decoder_stack.dec_layer1: "K, V" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
encoder_output -> decoder_stack.dec_layer2: "K, V" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
encoder_output -> decoder_stack.dec_layerN: "K, V" {
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  l1: "Query (Q): Decoder hidden states - 'what am I looking for?'"
  l2: "Key (K): Encoder representations - 'what content is available?'"
  l3: "Value (V): Encoder representations - 'what content to retrieve?'"
  l4: "Encoder output passed to EVERY decoder layer (not just last)"
  l1.style.font-color: "#1565C0"
  l2.style.font-color: "#2E7D32"
  l3.style.font-color: "#2E7D32"
  l4.style: {
    font-color: "#E65100"
    bold: true
  }
}
flow_annotation: |md
  **Cross-Attention Semantics:**
  Each decoder position queries the encoder:
  - Decoder generates query based on target prefix
  - Encoder provides keys/values from source understanding
  - Attention weights = relevance of each source position
  - Output = weighted blend of encoder representations
  **Critical:** Same encoder output used by ALL decoder layers
| {
  near: center-right
  style.fill: "#FFF8E1"
}