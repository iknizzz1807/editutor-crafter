direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  input_block: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
    }
  }
  attention_block: {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
  residual_block: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  cross_attn_block: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  ffn_block: {
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
    }
  }
  output_block: {
    style: {
      fill: "#E0F2F1"
      stroke: "#00695C"
      stroke-width: 2
    }
  }
  encoder_ref: {
    style: {
      fill: "#ECEFF1"
      stroke: "#546E7A"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  flow_arrow: {
    style: {
      stroke: "#37474F"
      stroke-width: 2
    }
  }
  residual_arrow: {
    style: {
      stroke: "#2E7D32"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  data_arrow: {
    style: {
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
}
title: |md
  ## Decoder Layer Structure
  Three-sublayer architecture with residual connections
| {near: top-center}
# Input
decoder_input: {
  class: input_block
  label: "Decoder Input"
  shape: rectangle
  width: 200
  desc: |md
    **Shape:** `[batch, tgt_len, d_model]`
    Target sequence embeddings with positional encoding
  |
}
# Sublayer 1: Masked Self-Attention
sublayer1_container: {
  label: "Sublayer 1: Masked Self-Attention"
  style.stroke: "#E65100"
  masked_self_attn: {
    class: attention_block
    label: "Masked Self-Attention\n(decoder/layer.py)"
    shape: rectangle
    width: 200
    qkv_info: |md
      **Q, K, V from decoder input**
      Causal mask prevents attending to future positions
      Mask: `[1, 1, tgt_len, tgt_len]`
    |
  }
  add_norm_1: {
    class: residual_block
    label: "Add & LayerNorm"
    shape: rectangle
    width: 200
  }
}
# Sublayer 2: Cross-Attention
sublayer2_container: {
  label: "Sublayer 2: Cross-Attention"
  style.stroke: "#7B1FA2"
  cross_attn: {
    class: cross_attn_block
    label: "Cross-Attention\n(decoder/layer.py)"
    shape: rectangle
    width: 200
    qkv_info: |md
      **Q from decoder, K/V from encoder**
      Decoder queries encoder representation
      Shape: `[batch, tgt_len, d_model]`
    |
  }
  add_norm_2: {
    class: residual_block
    label: "Add & LayerNorm"
    shape: rectangle
    width: 200
  }
}
# Sublayer 3: Feed-Forward Network
sublayer3_container: {
  label: "Sublayer 3: Feed-Forward"
  style.stroke: "#C2185B"
  ffn: {
    class: ffn_block
    label: "FFN\n(layers/ffn.py)"
    shape: rectangle
    width: 200
    ffn_info: |md
      **Position-wise transformation**
      `W2(GELU(W1(x) + b1)) + b2`
      Expansion: `d_model → 4*d_model → d_model`
    |
  }
  add_norm_3: {
    class: residual_block
    label: "Add & LayerNorm"
    shape: rectangle
    width: 200
  }
}
# Output
decoder_output: {
  class: output_block
  label: "Decoder Output"
  shape: rectangle
  width: 200
  desc: |md
    **Shape:** `[batch, tgt_len, d_model]`
    To next decoder layer or output projection
  |
}
# Encoder Reference (for cross-attention)
encoder_output: {
  class: encoder_ref
  label: "Encoder Output\n[batch, src_len, d_model]"
  shape: cylinder
  width: 180
}
# Main flow connections
decoder_input -> sublayer1_container.masked_self_attn: "x [batch, tgt_len, d_model]" {
  class: flow_arrow
}
sublayer1_container.masked_self_attn -> sublayer1_container.add_norm_1: "attn_out" {
  class: flow_arrow
}
sublayer1_container.add_norm_1 -> sublayer2_container.cross_attn: "x + attn(x)" {
  class: flow_arrow
}
sublayer2_container.cross_attn -> sublayer2_container.add_norm_2: "cross_out" {
  class: flow_arrow
}
sublayer2_container.add_norm_2 -> sublayer3_container.ffn: "x + cross(x)" {
  class: flow_arrow
}
sublayer3_container.ffn -> sublayer3_container.add_norm_3: "ffn_out" {
  class: flow_arrow
}
sublayer3_container.add_norm_3 -> decoder_output: "x + ffn(x)" {
  class: flow_arrow
}
# Residual connections (skip connections)
residual_1: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  width: 1
  height: 1
}
residual_2: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  width: 1
  height: 1
}
residual_3: {
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
  width: 1
  height: 1
}
# Cross-attention data flow
encoder_output -> sublayer2_container.cross_attn: "K, V (encoder states)" {
  class: data_arrow
  style: {
    stroke-dash: 4
  }
}
# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-width: 1
  }
  title: "Legend"
  residual: "→ Residual Connection (+x)" {
    style: {
      stroke: "#2E7D32"
      stroke-dash: 4
    }
  }
  data_flow: "→ Data Flow" {
    style: {
      stroke: "#37474F"
    }
  }
  encoder_flow: "→ Encoder → Decoder" {
    style: {
      stroke: "#7B1FA2"
      stroke-dash: 4
    }
  }
}
# Pre-LN vs Post-LN note
norm_note: {
  near: bottom-left
  style: {
    fill: "#FFFDE7"
    stroke: "#F9A825"
    stroke-width: 1
  }
  content: |md
    **Pre-LN vs Post-LN:**
    - **Pre-LN:** `x + sublayer(LayerNorm(x))`
    - **Post-LN:** `LayerNorm(x + sublayer(x))`
    Modern models use Pre-LN for training stability.
  |
}