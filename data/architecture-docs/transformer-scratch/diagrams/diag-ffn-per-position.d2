direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Position-Wise Feed-Forward Network Architecture
  **FFN(x) = W₂ · ReLU(W₁ · x + b₁) + b₂**
  Per-token non-linear transformation with 4× expansion
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_container: {
    direction: down
    label: "Input Sequence"
    input_tensor: {
      shape: sql_table
      label: "Tensor Shape"
      dim0: "0x00 | int    | batch_size"
      dim1: "0x04 | int    | seq_len"
      dim2: "0x08 | int    | d_model (512)"
      note: "Each position: 512-dim vector"
    }
  }
  position_tokens: {
    direction: right
    label: "Token Positions (processed independently)"
    tok0: {
      label: "Token 0"
      shape: rectangle
      width: 80
      style.fill: "#E8F4FD"
    }
    tok1: {
      label: "Token 1"
      shape: rectangle
      width: 80
      style.fill: "#E8F4FD"
    }
    tok2: {
      label: "Token 2"
      shape: rectangle
      width: 80
      style.fill: "#E8F4FD"
    }
    tokN: {
      label: "Token N"
      shape: rectangle
      width: 80
      style.fill: "#E8F4FD"
      style.stroke-dash: 3
    }
  }
}
row_input.position_tokens.tok0 -> row_w1.expansion_box: "x[0]\n[512]"
row_input.position_tokens.tok1 -> row_w1.expansion_box: "x[1]\n[512]"
row_input.position_tokens.tok2 -> row_w1.expansion_box: "x[2]\n[512]"
row_w1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  expansion_box: {
    direction: down
    label: "Layer 1: Expansion (W₁)"
    w1_struct: {
      shape: sql_table
      label: "W₁: nn.Linear (d_model → d_ff)"
      w1_weight: "0x00 | Tensor | weight [d_ff, d_model]"
      w1_bias: "0x04 | Tensor | bias [d_ff]"
      w1_shape: "       | Shape  | [2048, 512]"
      w1_params: "       | Params | 1,048,576 + 2048"
    }
    w1_op: {
      label: "W₁ · x + b₁"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
  }
  expansion_result: {
    direction: down
    label: "Expanded Representation"
    expanded_tensor: {
      shape: sql_table
      label: "After W₁: [batch, seq, d_ff]"
      exp0: "0x00 | int  | batch_size"
      exp1: "0x04 | int  | seq_len"
      exp2: "0x08 | int  | d_ff (2048)"
      note2: "4× expansion: 512 → 2048"
    }
    expansion_viz: {
      direction: right
      label: "Dimension Visualization"
      before: {
        label: "d_model=512"
        shape: rectangle
        width: 60
        height: 120
        style.fill: "#E8F4FD"
      }
      arrow: {
        label: "×4"
        shape: text
      }
      after: {
        label: "d_ff=2048"
        shape: rectangle
        width: 180
        height: 120
        style.fill: "#FFE0B2"
      }
    }
  }
}
row_w1.expansion_box.w1_op -> row_activation.activation_box: "h = W₁·x + b₁\n[2048]"
row_activation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  activation_box: {
    direction: down
    label: "Non-Linearity"
    activation_select: {
      shape: class
      label: "Activation Functions"
      relu: "+ReLU(x): 'max(0, x)'"
      gelu: "+GELU(x): 'x·Φ(x)'"
      note: "// GELU preferred in modern transformers"
    }
    activation_viz: {
      direction: right
      label: "ReLU Effect"
      before_relu: {
        label: "Before ReLU\n(mixed values)"
        shape: rectangle
        style.fill: "#FFCDD2"
        width: 100
      }
      after_relu: {
        label: "After ReLU\n(negatives → 0)"
        shape: rectangle
        style.fill: "#C8E6C9"
        width: 100
      }
    }
  }
  activation_code: {
    label: "Activation Code"
    width: 320
    code: |'python
      # ReLU: simple but can have "dying neurons"
      hidden = F.relu(self.W1(x))
      # GELU: smooth gradient everywhere
      hidden = F.gelu(self.W1(x))
    '|
  }
}
row_activation.activation_box -> row_w2.compression_box: "h = ReLU(W₁·x + b₁)\n[2048]"
row_w2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  compression_box: {
    direction: down
    label: "Layer 2: Compression (W₂)"
    w2_struct: {
      shape: sql_table
      label: "W₂: nn.Linear (d_ff → d_model)"
      w2_weight: "0x00 | Tensor | weight [d_model, d_ff]"
      w2_bias: "0x04 | Tensor | bias [d_model]"
      w2_shape: "       | Shape  | [512, 2048]"
      w2_params: "       | Params | 1,048,576 + 512"
    }
    w2_op: {
      label: "W₂ · h + b₂"
      shape: rectangle
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
  }
  dropout_box: {
    direction: down
    label: "Regularization"
    dropout_info: {
      shape: class
      label: "Dropout (p=0.1)"
      train: "+training: 'randomly zero 10%'"
      eval: "+eval: 'pass through unchanged'"
    }
    dropout_viz: {
      direction: right
      label: "Dropout Effect"
      before_drop: {
        label: "Full activations"
        shape: rectangle
        style.fill: "#E1BEE7"
        width: 100
      }
      after_drop: {
        label: "Some zeroed\n(scaled by 1/0.9)"
        shape: rectangle
        style.fill: "#F3E5F5"
        style.stroke-dash: 3
        width: 100
      }
    }
  }
}
row_w2.compression_box.w2_op -> row_output.output_container: "FFN(x)\n[512]"
row_output: "" {
  direction: right
