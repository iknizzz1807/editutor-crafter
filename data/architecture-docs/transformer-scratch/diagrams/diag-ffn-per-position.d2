      style.stroke-dash: 3
    }
  }
}
row_independence: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  independence_box: {
    direction: down
    label: "Key Insight: Position-Wise Independence"
    independence_code: {
      label: "Implementation"
      width: 400
      code: |'python
        class PositionWiseFFN(nn.Module):
            def __init__(self, d_model, d_ff=None, dropout=0.1):
                super().__init__()
                d_ff = d_ff or 4 * d_model  # Default: 4× expansion
                self.W1 = nn.Linear(d_model, d_ff)    # 512 → 2048
                self.W2 = nn.Linear(d_ff, d_model)    # 2048 → 512
                self.dropout = nn.Dropout(dropout)
            def forward(self, x):
                # x: [batch, seq_len, d_model]
                # Each position processed independently!
                hidden = F.gelu(self.W1(x))           # [batch, seq, 2048]
                hidden = self.dropout(hidden)
                output = self.W2(hidden)              # [batch, seq, 512]
                return output
      '|
    }
    independence_note: {
      shape: rectangle
      label: "⚠️ No interaction between positions\nAttention handles inter-position communication\nFFN handles intra-position transformation"
      style.fill: "#FFF9C4"
      style.stroke: "#FBC02D"
    }
  }
}
row_params: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  params_box: {
    direction: down
    label: "Parameter Summary (d_model=512, d_ff=2048)"
    params_table: {
      shape: sql_table
      label: "FFN Parameters per Layer"
      p1: "W₁.weight | [2048, 512] | 1,048,576"
      p2: "W₁.bias   | [2048]      | 2,048"
      p3: "W₂.weight | [512, 2048] | 1,048,576"
      p4: "W₂.bias   | [512]       | 512"
      total: "Total     |             | 2,099,712"
    }
    ratio_note: {
      label: "FFN accounts for ~2/3 of parameters\nper transformer layer"
      shape: text
      style.fill: "#E3F2FD"
    }
  }
  why_4x: {
    direction: down
    label: "Why 4× Expansion?"
    why_table: {
      shape: sql_table
      label: "Expansion Ratio Trade-offs"
      r2: "2×  | 2× d_model² | Lower capacity"
      r4: "4×  | 4× d_model² | Standard (good balance)"
      r8: "8×  | 8× d_model² | Higher, diminishing returns"
    }
    why_note: {
      label: "4× is empirically optimal\nLarger ratios add computation without\nproportional quality gains"
      shape: text
    }
  }
}
row_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  flow_summary: {
    direction: down
    label: "Complete Data Flow"
    flow_trace: {
      shape: sql_table
      label: "Shape Trace Through FFN"
      s1: "Input     | [batch, seq, 512]  | From attention/residual"
      s2: "W₁·x + b₁ | [batch, seq, 2048] | Linear expansion"
      s3: "ReLU/GELU | [batch, seq, 2048] | Non-linearity"
      s4: "Dropout   | [batch, seq, 2048] | Regularization"
      s5: "W₂·h + b₂ | [batch, seq, 512]  | Linear compression"
      s6: "Output    | [batch, seq, 512]  | To next residual"
    }
  }
  nonlinearity_box: {
    direction: down
    label: "Why Non-Linearity is Critical"
    nonlinear_explain: {
      width: 350
      code: |'python
        # Without non-linearity, FFN collapses to single linear transform:
        # FFN(x) = W2 · (W1 · x) = (W2 · W1) · x = W_combined · x
        # This is just one matrix multiplication!
        # The model loses ALL expressive power.
        # With ReLU/GELU:
        # FFN(x) = W2 · ReLU(W1 · x)
        # Cannot be simplified - true non-linear transform
      '|
    }
    nonlinear_note: {
      label: "Non-linearity enables the model to learn\ncomplex functions that cannot be expressed\nas a single linear transformation"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#E53935"
    }
  }
}
