direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Generation Strategies Comparison
  Quality vs Diversity Trade-offs in LLM Decoders
| {near: top-center}

# Input prompt shared across all strategies
input: {
  label: "Input Prompt (context.py)"
  prompt: |md
    **"The cat sat on the"**
    Token IDs: `[1, 5, 3, 7, 2]`
  |
  width: 300
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}

# Three strategy containers side by side
strategies: {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  # GREEDY DECODING
  greedy: {
    direction: down
    label: "Greedy Decoding (greedy.py)"
    width: 280
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2

    algorithm: {
      label: "Algorithm"
      width: 250
      code: |'python
        # Select argmax at each step
        for t in range(max_len):
            logits = model(context)
            next = logits[-1].argmax()
            context.append(next)
      '|
      style.fill: "#FFECB3"
    }

    step1: {
      label: "Step 1: Compute Logits"
      width: 250
      logits: |'md
        **Logits (last position):**
        - "mat": 8.2
        - "floor": 6.1
        - "couch": 5.8
        - "bed": 4.2
      '|
      style.fill: white
    }

    step2: {
      label: "Step 2: Argmax Selection"
      width: 250
      selection: |md
        **Selected: "mat"** (highest)
        New context: "The cat sat on the mat"
      |
      style.fill: "#C8E6C9"
    }

    output_greedy: {
      label: "Output Result"
      width: 250
      result: |md
        **"The cat sat on the mat."**
        Deterministic, safe, common
      |
      style.fill: "#A5D6A7"
      style.stroke: "#4CAF50"
    }

    algorithm -> step1 -> step2 -> output_greedy
  }

  # BEAM SEARCH
  beam: {
    direction: down
    label: "Beam Search (k=3) (beam.py)"
    width: 280
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    beam_algo: {
      label: "Algorithm"
      width: 250
      code: |'python
        # Keep top-k hypotheses
        beams = [start_node]
        for t in range(max_len):
            all_next = []
            for b in beams:
                all_next.extend(top_k(model(b)))
            beams = top_k(all_next, k)
      '|
      style.fill: "#BBDEFB"
    }

    beam_step1: {
      label: "Step 1: Expand Beams"
      width: 250
      # Using |'md ... '| because the content contains | pipes for the table
      hypotheses: |'md
        **Top-3 continuations:**
        | Beam | Token | Score |
        |------|-------|-------|
        | 1 | "mat" | -0.12 |
        | 2 | "floor" | -0.38 |
        | 3 | "couch" | -0.42 |
      '|
      style.fill: white
    }

    beam_step2: {
      label: "Step 2: Prune & Expand"
      width: 250
      expansion: |'md
        **Expand each beam:**
        - B1 → "mat." (-0.15)
        - B1 → "mat and" (-0.31)
        - B2 → "floor." (-0.41)
        
        **Keep top 3 after merge**
      '|
      style.fill: white
    }

    beam_output: {
      label: "Output Result"
      width: 250
      result: |md
        **"The cat sat on the mat."**
        Explored 9 paths, chose global best
      |
      style.fill: "#90CAF9"
      style.stroke: "#1976D2"
    }

    beam_algo -> beam_step1 -> beam_step2 -> beam_output
  }

  # SAMPLING
  sampling: {
    direction: down
    label: "Sampling (T=0.8) (sample.py)"
    width: 280
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2

    sample_algo: {
      label: "Algorithm"
      width: 250
      code: |'python
        # Sample from distribution
        for t in range(max_len):
            logits = model(context) / T
            probs = softmax(logits[-1])
            next = sample(probs)
            context.append(next)
      '|
      style.fill: "#E1BEE7"
    }

    sample_step1: {
      label: "Step 1: Softmax / T"
      width: 250
      probs: |'md
        **Probabilities (T=0.8):**
        - "mat": 0.45
        - "floor": 0.28
        - "couch": 0.18
        - "bed": 0.09
        
        **Sampled: "couch"** (18% chance)
      '|
      style.fill: white
    }

    sample_step2: {
      label: "Step 2: Multi-path"
      width: 250
      continuation: |md
        **New context:**
        "The cat sat on the couch"
        Next: stochastic roll-out
      |
      style.fill: white
    }

    sample_output: {
      label: "Output (Stochastic)"
      width: 250
      result: |md
        **"The cat sat on the couch quietly."**
        Diverse, creative, non-deterministic
      |
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
    }

    sample_algo -> sample_step1 -> sample_step2 -> sample_output
  }
}

# Trade-off comparison table
comparison: {
  label: "Trade-off Analysis"
  width: 900
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"

  metrics: {
    width: 880
    direction: right
    style.fill: transparent
    style.stroke: transparent

    quality_col: {
      width: 200
      label: "Quality"
      content: |md
        **Logic Consistency**
        🥇 Beam Search
        🥈 Greedy  
        🥉 Sampling
      |
      style.fill: "#E8F5E9"
    }

    diversity_col: {
      width: 200
      label: "Diversity"
      content: |md
        **Novelty / Surprise**
        🥇 Sampling
        🥈 Beam Search
        🥉 Greedy
      |
      style.fill: "#FCE4EC"
    }

    speed_col: {
      width: 200
      label: "Speed"
      content: |md
        **Computational Cost**
        🥇 Greedy
        🥈 Sampling
        🥉 Beam Search
      |
      style.fill: "#E3F2FD"
    }

    usecase_col: {
      width: 260
      label: "Best Use Case"
      content: |md
        **Application Type:**
        Greedy → Prod, Summary
        Beam → Translation
        Sampling → Creative Chat
      |
      style.fill: "#FFF8E1"
    }
  }
}

# Key insight box
insight: {
  width: 900
  label: "Key Implementation Insights"
  content: |'md
    **The Trade-off Triangle:**
    - **Greedy**: Fast but myopic — commits to local maxima, no error recovery.
    - **Beam Search**: Balanced — explores k paths, finds better sequences but O(k*n) cost.
    - **Sampling**: Creative but unpredictable — explores full distribution, may produce nonsense.

    **Temperature (T) control logic:**
    - T → 0: Distribution sharpens; approaches Greedy behavior.
    - T = 1.0: Original model probabilities.
    - T → ∞: Distribution flattens; approaches Uniform Random (Max Entropy).
  '|
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  style.stroke-width: 2
}

# Connections
input -> strategies.greedy.algorithm: "logits"
input -> strategies.beam.beam_algo: "logits"
input -> strategies.sampling.sample_algo: "logits"

strategies -> comparison: "Strategy Metrics"
comparison -> insight: "Trade-off Summary"