direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Gradient Clipping Mechanism
  `clip_grad_norm_(params, max_norm=1.0)`
| {
  near: top-center
}

row_before: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  grad_state: {
    direction: down
    label: "Before Clipping"
    norm_box: {
      label: "||g|| = 3.7"
      style.fill: "#FFB4AB"
      style.stroke: "#B3261E"
      style.stroke-width: 2
      width: 120
    }
    vector_before: {
      label: "Gradient Vector"
      shape: sql_table
      v1: "∂L/∂W1 | 2.1"
      v2: "∂L/∂W2 | -1.8"
      v3: "∂L/∂W3 | 2.4"
      v4: "∂L/∂W4 | -0.9"
      v5: "etc | etc"
      sz: "Total Norm: 3.7"
    }
    vector_before.style.fill: "#FCE8E6"
  }
}

row_operation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  clip_op: {
    direction: down
    label: "Clipping Operation"
    step1: {
      label: "1. Compute Global Norm"
      code: |'python
        total_norm = sqrt(sum(||g_i||²))
        # total_norm = 3.7
      '|
      width: 280
    }
    step2: {
      label: "2. Compare to max_norm"
      code: |'python
        clip_coef = max_norm / total_norm
        # clip_coef = 1.0 / 3.7 = 0.27
      '|
      width: 280
    }
    step3: {
      label: "3. Rescale All Gradients"
      code: |'python
        g_clipped = g * clip_coef
        # Direction preserved, magnitude capped
      '|
      width: 280
    }
    step1 -> step2 -> step3
  }
}

row_after: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  result_state: {
    direction: down
    label: "After Clipping"
    norm_box_after: {
      label: "||g'|| = 1.0"
      style.fill: "#BCEABB"
      style.stroke: "#256D38"
      style.stroke-width: 2
      width: 120
    }
    vector_after: {
      label: "Clipped Gradient"
      shape: sql_table
      v1: "∂L/∂W1 | 0.57"
      v2: "∂L/∂W2 | -0.49"
      v3: "∂L/∂W3 | 0.65"
      v4: "∂L/∂W4 | -0.24"
      v5: "etc | etc"
      sz: "Total Norm: 1.0"
    }
    vector_after.style.fill: "#E8F5E9"
  }
}

row_visual: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  visual_before: {
    direction: down
    label: "Vector Visualization (Before)"
    coord_before: {
      shape: rectangle
      width: 200
      height: 200
      style.fill: "#FAFAFA"
      style.stroke: "#E0E0E0"
      axis_x_before: {
        label: "x-axis"
        width: 180
        height: 2
        style.fill: "#9E9E9E"
      }
      axis_y_before: {
        label: "y-axis"
        width: 2
        height: 180
        style.fill: "#9E9E9E"
      }
      vec_before: {
        label: "g"
        width: 140
        height: 8
        style.fill: "#B3261E"
        style.stroke: "#B3261E"
      }
      threshold_circle: {
        label: "max_norm=1.0"
        shape: circle
        width: 80
        height: 80
        style.stroke: "#B3261E"
        style.stroke-dash: 4
        style.fill: transparent
      }
    }
  }
  visual_after: {
    direction: down
    label: "Vector Visualization (After)"
    coord_after: {
      shape: rectangle
      width: 200
      height: 200
      style.fill: "#FAFAFA"
      style.stroke: "#E0E0E0"
      axis_x_after: {
        label: "x-axis"
        width: 180
        height: 2
        style.fill: "#9E9E9E"
      }
      axis_y_after: {
        label: "y-axis"
        width: 2
        height: 180
        style.fill: "#9E9E9E"
      }
      vec_after: {
        label: "g_clipped"
        width: 38
        height: 8
        style.fill: "#256D38"
        style.stroke: "#256D38"
      }
      clipped_circle: {
        label: "norm=1.0"
        shape: circle
        width: 80
        height: 80
        style.stroke: "#256D38"
        style.stroke-dash: 4
        style.fill: transparent
      }
    }
  }
}

row_formula: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  formula_box: {
    label: "Key Formula"
    formula: |'latex
      \vec{g}_{clipped} = \vec{g} \cdot \min\left(1, \frac{\text{max\_norm}}{||\vec{g}||}\right)
    '|
    width: 400
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
  }
}

row_properties: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  properties: {
    direction: down
    label: "Properties Preserved"
    prop1: {
      label: "✓ Direction Preserved"
      style.fill: "#E8F5E9"
      width: 160
    }
    prop2: {
      label: "✓ Relative Magnitudes"
      style.fill: "#E8F5E9"
      width: 160
    }
    prop3: {
      label: "✓ Sign of Components"
      style.fill: "#E8F5E9"
      width: 160
    }
  }
  changed: {
    direction: down
    label: "Properties Changed"
    ch1: {
      label: "X Global Norm Capped"
      style.fill: "#FCE8E6"
      width: 160
    }
    ch2: {
      label: "X Update Magnitude"
      style.fill: "#FCE8E6"
      width: 160
    }
    ch3: {
      label: "X Step Size Reduced"
      style.fill: "#FCE8E6"
      width: 160
    }
  }
}

row_usage: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  usage_box: {
    label: "PyTorch Usage"
    code: |'python
      # After loss.backward(), before optimizer.step()
      loss.backward()
      # Clip gradients to max norm 1.0
      grad_norm = torch.nn.utils.clip_grad_norm_(
          model.parameters(), 
          max_norm=1.0
      )
      optimizer.step()
    '|
    width: 420
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
  }
}

grad_state.norm_box -> clip_op.step1: "||g|| > max"
clip_op.step3 -> result_state.norm_box_after: "rescale"
grad_state.vector_before -> clip_op: "g"
clip_op -> result_state.vector_after: "g_clipped"
usage_box -> grad_state: "Input"
result_state -> usage_box: "Output" {
  style.stroke-dash: 3
}