direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Greedy Decoding Process (greedy.py)"
  near: top-center
  shape: rectangle
  style: {
    font-size: 24
    bold: true
    fill: "#F0F0F0"
  }
}

decoding_process: {
  label: "Inference Engine Loop"
  direction: down

  # Initial Setup Row
  row0: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step1: {
      label: "Phase 0: Initialization"
      direction: right
      style.fill: "#E8F4FD"
      
      init_box: {
        label: "KV Cache / Buffer"
        style.fill: white
        style.stroke: "#2196F3"
        content: "[SOS] token"
        width: 150
      }

      encoder_box: {
        label: "Encoder Context"
        style.fill: "#FFF3E0"
        style.stroke: "#FF9800"
        status: "Computed Once"
        data: "MemoryKeys + Values"
        width: 180
      }
      
      init_box -> encoder_box: "Context | Load"
    }
  }

  # Forward Pass Row
  row1: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step2: {
      label: "Phase 1: Forward Pass"
      direction: down
      style.fill: "#F3E5F5"
      
      decoder_logic: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        
        decoder_box: {
          label: "Transformer Decoder"
          style.fill: white
          style.stroke: "#9C27B0"
          input: "tokens[:t]"
          output: "logits [1, V]"
          width: 200
        }
        
        attn_box: {
          label: "Attention Head"
          style.fill: "#E1BEE7"
          style.stroke: "#9C27B0"
          mask: "Causal (Look-ahead)"
          dim: "seq_len x seq_len"
          width: 180
        }
        
        decoder_box -> attn_box: "Scores"
      }
    }
  }

  # Logits and Selection Row
  row2: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step3: {
      label: "Phase 2: Token Selection"
      direction: right
      style.fill: "#E8F5E9"

      logits_table: {
        shape: sql_table
        label: "Vocabulary Logits"
        tok_0: "4821 | cat | 2.31"
        tok_1: "1203 | the | 1.85"
        tok_2: "0014 | a   | 1.42"
        tok_3: "9822 | dog | 0.97"
        sz: "Dim: [1, 50257]"
      }

      argmax_proc: {
        label: "Argmax"
        shape: diamond
        style.fill: "#4CAF50"
        style.font-color: white
      }

      selection: {
        label: "Winner"
        style.fill: "#81C784"
        style.stroke: "#388E3C"
        id: "4821"
        token: "'cat'"
        width: 120
      }

      logits_table -> argmax_proc: "vector"
      argmax_proc -> selection: "max_idx"
    }
  }

  # Append and Check Row
  row3: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent

    step4: {
      label: "Phase 3: Update State"
      direction: right
      style.fill: "#FFF8E1"
      
      state_before: {
        label: "Input t"
        style.fill: white
        content: "[SOS]"
      }
      
      state_after: {
        label: "Input t+1"
        style.fill: "#FFECB3"
        style.stroke: "#FF8F00"
        content: "[SOS, cat]"
      }
      
      state_before -> state_after: "Append Token"
    }

    step5: {
      label: "Phase 4: Exit Condition"
      direction: down
      style.fill: "#FFEBEE"
      
      checker: {
        label: "Is Finished?"
        shape: diamond
        style.fill: "#EF5350"
        style.font-color: white
      }
      
      exit_logic: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        
        stop: "STOP" {
          style.fill: "#FFCDD2"
          shape: circle
        }
        
        loop: "CONTINUE" {
          style.fill: "#C8E6C9"
          shape: circle
        }
      }
      
      checker -> exit_logic.stop: "EOS / MaxLen"
      checker -> exit_logic.loop: "Next Iter"
    }
  }
}

# Cross-Phase Logic Flow
decoding_process.row0.step1 -> decoding_process.row1.step2: "context_vectors"
decoding_process.row1.step2 -> decoding_process.row2.step3: "raw_logits"
decoding_process.row2.step3 -> decoding_process.row3.step4: "selected_id"
decoding_process.row3.step4 -> decoding_process.row3.step5: "new_seq"

# Global Feedback Loop
loop_path: {
  style.stroke: transparent
  style.fill: transparent
  decoding_process.row3.step5.exit_logic.loop -> decoding_process.row1.step2: "Repeat Loop" {
    style.stroke: "#2196F3"
    style.stroke-width: 3
    style.stroke-dash: 5
    style.animated: true
  }
}

# Implementation Logic
implementation: {
  label: "Implementation (greedy.py)"
  code: |'python
    while len(tokens) < max_len:
        logits = model(tokens, enc_out)
        next_id = torch.argmax(logits[:, -1, :])
        tokens = torch.cat([tokens, next_id])
        if next_id == eos_id:
            break
  '|
  width: 400
}

# Complexity Analysis Row
perf_row: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  complexity: {
    label: "Efficiency Metrics"
    direction: right
    style.fill: "#FFFDE7"
    style.stroke: "#FBC02D"
    
    naive: {
      label: "Static"
      style.fill: "#FFECB3"
      cost: "O(N^2) Recompute"
    }
    
    optimized: {
      label: "Cached"
      style.fill: "#C8E6C9"
      cost: "O(N) KV-Cache"
    }
    
    naive -> optimized: "Speedup"
  }
}

legend: {
  near: bottom-right
  direction: right
  style.fill: "#F5F5F5"
  
  l1: "Encoder" { style.fill: "#FFF3E0" }
  l2: "Decoder" { style.fill: "#F3E5F5" }
  l3: "Selection" { style.fill: "#E8F5E9" }
  l4: "Termination" { style.fill: "#FFEBEE" }
}