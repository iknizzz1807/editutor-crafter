code_example: {
  label: "Cache Update Per Step"
  width: 580
  code: |'python
    # Step i: Only compute K,V for new token
    new_K, new_V = compute_kv(token_i)      # O(1) computation
    cached_K = concat(cached_K, new_K)      # Append to cache
    cached_V = concat(cached_V, new_V)
    # Attention uses full cached sequence
    scores = Q_i @ cached_K.T / sqrt(d_k)   # O(i) for position i
    output = softmax(scores) @ cached_V
  '|
}
footer: {
  label: "Speedup increases with sequence length — KV cache essential for production inference"
  style.fill: "#E8F5E9"
  style.stroke: "#27AE60"
