direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Label Smoothing Effect {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  onehot: {
    label: "One-Hot Target (Hard)"
    shape: rectangle
    style.fill: "#FFE4E1"
    class0: {
      label: "Class 0"
      shape: rectangle
      style.fill: white
    }
    class1: {
      label: "Class 1"
      shape: rectangle
      style.fill: white
    }
    class2: {
      label: "Class 2 (True)"
      shape: rectangle
      style.fill: "#90EE90"
    }
    class3: {
      label: "Class 3"
      shape: rectangle
      style.fill: white
    }
  }
  onehot_values: {
    label: |md
      
      [0.00, 0.00, 1.00, 0.00]
      
    |
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  smoothed: {
    label: "Smoothed Target (Soft)"
    shape: rectangle
    style.fill: "#E6E6FA"
    sm0: {
      label: "Class 0"
      shape: rectangle
      style.fill: "#FFFACD"
    }
    sm1: {
      label: "Class 1"
      shape: rectangle
      style.fill: "#FFFACD"
    }
    sm2: {
      label: "Class 2 (True)"
      shape: rectangle
      style.fill: "#98FB98"
    }
    sm3: {
      label: "Class 3"
      shape: rectangle
      style.fill: "#FFFACD"
    }
  }
  smoothed_values: {
    label: |md
      
      [0.025, 0.025, 0.925, 0.025]
      
    |
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
  }
}
arrow: {
  label: "Label Smoothing\nε = 0.1, K = 4"
  shape: rectangle
  style: {
    fill: transparent
    stroke: transparent
  }
}
onehot -> arrow -> smoothed: "Apply\nsmoothing" {
  style: {
    stroke: "#4169E1"
    stroke-width: 2
  }
}
formula_box: {
  label: "Smoothing Formula"
  shape: rectangle
  width: 400
  formula: |md
    **For true class k:**
    `y'_k = (1 - ε) + ε/K = 0.9 + 0.025 = 0.925`
    **For other classes:**
    `y'_i = ε/K = 0.1/4 = 0.025`
  |
}
benefits: {
  label: "Benefits"
  shape: rectangle
  width: 350
  benefit_list: |md
    - Prevents overconfident predictions
    - Improves model calibration
    - Acts as regularization
    - Better generalization on uncertain data
  |
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  formula_box
  benefits
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#F5F5F5"
  leg: |md
    **Legend:** 🟩 True class receives most probability mass  
    🟨 Other classes receive small ε/K probability mass
  |
}