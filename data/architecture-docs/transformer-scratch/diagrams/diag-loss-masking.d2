direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Loss Computation with Padding Mask"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_before: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  before: {
    direction: down
    label: "BEFORE: Without Padding Mask"
    style: {
      stroke: "#DC3545"
      fill: "#FFF5F5"
      stroke-width: 2
    }
    tokens_before: {
      shape: sql_table
      label: "Target Tokens (tgt_len=8)"
      t0: "0 | <sos>"
      t1: "1 | The"
      t2: "2 | cat"
      t3: "3 | sat"
      t4: "4 | <PAD>"
      t5: "5 | <PAD>"
      t6: "6 | <PAD>"
      t7: "7 | <PAD>"
      pad_note: "4 padding tokens = 50%"
    }
    logits_before: {
      shape: sql_table
      label: "Model Logits [batch, 8, vocab]"
      l0: "Position 0 | [...]"
      l1: "Position 1 | [...]"
      l2: "Position 2 | [...]"
      l3: "Position 3 | [...]"
      l4: "Position 4 | [...]"
      l5: "Position 5 | [...]"
      l6: "Position 6 | [...]"
      l7: "Position 7 | [...]"
    }
    loss_before: {
      shape: sql_table
      label: "Per-Token Loss (WRONG)"
      note: "CrossEntropyLoss computes ALL"
      p0: "Loss[0] | 2.31"
      p1: "Loss[1] | 1.85"
      p2: "Loss[2] | 0.92"
      p3: "Loss[3] | 1.12"
      p4: "Loss[4] | 0.45"
      p5: "Loss[5] | 0.38"
      p6: "Loss[6] | 0.51"
      p7: "Loss[7] | 0.42"
      total: "Total Loss | 7.96"
    }
    tokens_before -> logits_before: "forward"
    logits_before -> loss_before: "loss"
  }
}
row_after: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  after: {
    direction: down
    label: "AFTER: With Padding Mask"
    style: {
      stroke: "#28A745"
      fill: "#F5FFF5"
      stroke-width: 2
    }
    tokens_after: {
      shape: sql_table
      label: "Target Tokens (tgt_len=8)"
      t0: "0 | <sos>"
      t1: "1 | The"
      t2: "2 | cat"
      t3: "3 | sat"
      t4: "4 | <PAD>"
      t5: "5 | <PAD>"
      t6: "6 | <PAD>"
      t7: "7 | <PAD>"
    }
    mask: {
      shape: sql_table
      label: "Padding Mask"
      m0: "Position 0 | False"
      m1: "Position 1 | False"
      m2: "Position 2 | False"
      m3: "Position 3 | False"
      m4: "Position 4 | True"
      m5: "Position 5 | True"
      m6: "Position 6 | True"
      m7: "Position 7 | True"
      note: "True = IGNORE in loss"
    }
    loss_after: {
      shape: sql_table
      label: "Masked Loss (CORRECT)"
      note: "ignore_index=pad_token_id"
      p0: "Loss[0] | 2.31"
      p1: "Loss[1] | 1.85"
      p2: "Loss[2] | 0.92"
      p3: "Loss[3] | 1.12"
      p4: "Loss[4] | IGNORED"
      p5: "Loss[5] | IGNORED"
      p6: "Loss[6] | IGNORED"
      p7: "Loss[7] | IGNORED"
      total: "Total Loss | 6.20 / 4"
      avg: "Avg Loss | 1.55"
    }
    tokens_after -> mask: "create mask"
    mask -> loss_after: "apply"
  }
}
row_code: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  code_container: {
    label: "Implementation"
    width: 600
    style: {
      fill: "#F8F9FA"
      stroke: "#DEE2E6"
    }
    code: |'python
# PyTorch CrossEntropyLoss with ignore_index
criterion = nn.CrossEntropyLoss(
    ignore_index=pad_token_id,  # Set to 0 for <PAD>
    label_smoothing=0.1,
    reduction='none'  # Per-token losses for masking
)
# Forward pass
logits = model(src, decoder_input)  # [batch, seq_len, vocab]
targets = tgt[:, 1:]                # [batch, seq_len]
# Compute loss (padding automatically ignored)
loss_per_token = criterion(
    logits.reshape(-1, vocab_size),
    targets.reshape(-1)
)
# Mean over non-padding tokens only
non_pad_mask = (targets != pad_token_id)
loss = loss_per_token[non_pad_mask].mean()
'|
  }
}
arrow: {
  direction: right
  style: {
    stroke: "#28A745"
    stroke-width: 3
  }
}
row_before.before -> row_after.after: {
  label: "Add ignore_index"
  style: {
    stroke: "#28A745"
    stroke-width: 2
    stroke-dash: 5
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  red_box: {
    label: "Without mask: Model learns to predict <PAD>"
    style: {
      fill: "#FFF5F5"
      stroke: "#DC3545"
    }
  }
  green_box: {
    label: "With mask: Model ignores padding positions"
    style: {
      fill: "#F5FFF5"
      stroke: "#28A745"
    }
  }
}
problem_note: {
  label: "Problem: Without masking, loss includes 4 padding tokens"
  near: bottom-center
  shape: text
  style: {
    font-color: "#DC3545"
    font-size: 16
  }
}
solution_note: {
  label: "Solution: ignore_index tells CrossEntropyLoss to skip these positions"
  near: bottom-center
  shape: text
  style: {
    font-color: "#28A745"
    font-size: 16
  }
}