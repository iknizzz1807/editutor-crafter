direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Multi-Head Parallel Attention Computation
  All heads compute simultaneously on d_k-dimensional slices
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_container: {
    direction: down
    label: "Input Projection"
    style.fill: "#E8F4FD"
    input: {
      shape: sql_table
      label: "X [batch, seq, d_model]"
      r1: "0x00 | float[512] | token embeddings"
      sz: "512 dims (d_model)"
    }
    proj_WQ: {
      shape: class
      label: "W_Q (Linear)"
      weight: "Tensor [d_model, d_model]"
      +forward(x): "Tensor [batch, seq, d_model]"
    }
    proj_WK: {
      shape: class
      label: "W_K (Linear)"
      weight: "Tensor [d_model, d_model]"
      +forward(x): "Tensor [batch, seq, d_model]"
    }
    proj_WV: {
      shape: class
      label: "W_V (Linear)"
      weight: "Tensor [d_model, d_model]"
      +forward(x): "Tensor [batch, seq, d_model]"
    }
  }
}
row_heads: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  reshape: {
    direction: down
    label: "Head Splitting"
    style.fill: "#FFF3E0"
    reshape_op: {
      shape: class
      label: "Reshape + Transpose"
      op1: ".view(batch, seq, 8, 64)"
      op2: ".transpose(1, 2)"
      +output: "[batch, heads, seq, d_k]"
    }
    note: {
      label: "d_k = d_model / num_heads\n= 512 / 8 = 64"
      style.fill: "#FFE0B2"
    }
  }
  heads_container: {
    direction: down
    label: "Parallel Head Computation (8 heads)"
    style.fill: "#F3E5F5"
    head0: {
      shape: class
      label: "Head 0"
      slice: "dims [0:64]"
      attn: "softmax(Q₀K₀ᵀ/√64)V₀"
      out: "[batch, seq, 64]"
      style.fill: "#E1BEE7"
    }
    head1: {
      shape: class
      label: "Head 1"
      slice: "dims [64:128]"
      attn: "softmax(Q₁K₁ᵀ/√64)V₁"
      out: "[batch, seq, 64]"
      style.fill: "#CE93D8"
    }
    head2: {
      shape: class
      label: "Head 2"
      slice: "dims [128:192]"
      attn: "softmax(Q₂K₂ᵀ/√64)V₂"
      out: "[batch, seq, 64]"
      style.fill: "#BA68C8"
    }
    head_ellipsis: {
      label: "..."
      shape: text
      style.font-size: 24
    }
    head7: {
      shape: class
      label: "Head 7"
      slice: "dims [448:512]"
      attn: "softmax(Q₇K₇ᵀ/√64)V₇"
      out: "[batch, seq, 64]"
      style.fill: "#7B1FA2"
      style.font-color: white
    }
  }
}
row_concat: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  concat_container: {
    direction: down
    label: "Head Concatenation"
    style.fill: "#E8F5E9"
    concat_op: {
      shape: class
      label: "Concat + Reshape"
      op1: ".transpose(1, 2)"
      op2: ".contiguous()"
      op3: ".view(batch, seq, 512)"
      +output: "[batch, seq, d_model]"
    }
    concat_vis: {
      shape: sql_table
      label: "Concatenated Output"
      h0: "0x00-0x3F | float[64] | Head 0 output"
      h1: "0x40-0x7F | float[64] | Head 1 output"
      h2: "0x80-0xBF | float[64] | Head 2 output"
      ellipsis: "... | ... | ..."
      h7: "0x1C0-0x1FF | float[64] | Head 7 output"
      sz: "Total: 512 dims (d_model)"
    }
  }
  output_proj: {
    direction: down
    label: "Output Projection"
    style.fill: "#FFEBEE"
    W_O: {
      shape: class
      label: "W_O (Linear)"
      weight: "Tensor [d_model, d_model]"
      purpose: "Mix information across heads"
      +forward(x): "Tensor [batch, seq, d_model]"
    }
    final: {
      shape: sql_table
      label: "Final Output"
      r1: "[batch, seq_len, d_model]"
      r2: "Mixed head information"
      r3: "Ready for next layer"
    }
  }
}
legend: {
  near: bottom-right
  label: "Key Insight"
  content: {
    shape: text
    label: |md
      **Parallel Execution**
      - All 8 heads compute simultaneously
      - Single batched matmul operation
      - No Python loops over heads
      - GPU achieves >90% utilization
    |
  }
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
}
shape_trace: {
  near: bottom-left
  label: "Shape Trace"
  content: {
    shape: text
    label: |md
      
      X:        [batch, seq, 512]
      Q,K,V:    [batch, seq, 512]
      Reshape:  [batch, 8, seq, 64]
      Attn:     [batch, 8, seq, 64] (per head)
      Concat:   [batch, seq, 512]
      W_O:      [batch, seq, 512]
      
    |
  }
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
}
row_input.input_container.input -> row_input.input_container.proj_WQ: "project"
row_input.input_container.proj_WQ -> row_heads.reshape.reshape_op: "Q [batch, seq, 512]"
row_heads.reshape.reshape_op -> row_heads.heads_container.head0: "slice"
row_heads.reshape.reshape_op -> row_heads.heads_container.head7: "slice"
row_heads.heads_container.head0 -> row_concat.concat_container.concat_op: "head₀"
row_heads.heads_container.head7 -> row_concat.concat_container.concat_op: "head₇"
row_concat.concat_container.concat_op -> row_concat.output_proj.W_O: "[batch, seq, 512]"
row_concat.output_proj.W_O -> row_concat.output_proj.final: "mixed"