direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Multi-Head Specialization Patterns
  How different attention heads learn different relationship types
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input_token: {
    label: "Input Sequence"
    width: 280
    code: |'txt
    "The bank approved the loan
     because financial records
     were solid"
    '|
  }
  arrow_split: {
    shape: text
    label: "→ Split into 8 heads →"
  }
}
row_heads: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  head_positional: {
    label: "Head 1: Positional\nProximity"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    width: 200
    attention: |md
      **Attention Pattern:**
      - Strong: adjacent tokens
      - Weak: distant tokens
      "bank" ↔ "approved" (0.89)
      "loan" ↔ "because" (0.76)
    |
  }
  head_syntactic: {
    label: "Head 3: Syntactic\nDependencies"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    width: 200
    attention: |md
      **Attention Pattern:**
      - Subject-verb pairs
      - Modifier-noun pairs
      "bank" → "approved" (0.92)
      "records" → "solid" (0.87)
    |
  }
  head_semantic: {
    label: "Head 5: Semantic\nCo-reference"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    width: 200
    attention: |md
      **Attention Pattern:**
      - Related concepts
      - Domain words
      "bank" ↔ "loan" (0.94)
      "financial" ↔ "records" (0.91)
    |
  }
  head_causal: {
    label: "Head 7: Causal\nReasoning"
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    width: 200
    attention: |md
      **Attention Pattern:**
      - Cause-effect pairs
      - "because" trigger words
      "approved" ← "because" (0.88)
      "solid" → "approved" (0.82)
    |
  }
}
row_heads2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  head_punctuation: {
    label: "Head 2: Punctuation\nBoundaries"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    width: 155
    attention_punc: |md
      Attends to sentence
      boundaries and commas
    |
  }
  head_rare: {
    label: "Head 4: Rare Word\nFocus"
    shape: rectangle
    style.fill: "#E0F7FA"
    style.stroke: "#00BCD4"
    width: 155
    attention_rare: |md
      Highlights uncommon
      vocabulary for context
    |
  }
  head_duplicate: {
    label: "Head 6: Duplicate\nDetection"
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    width: 155
    attention_dup: |md
      Identifies repeated
      tokens and patterns
    |
  }
  head_general: {
    label: "Head 8: General\nMix"
    shape: rectangle
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 3
    width: 155
    attention_gen: |md
      Diffuse attention,
      no clear specialization
    |
  }
}
row_input -> row_heads: "Q, K, V projection\nsplit across heads" {
  style.stroke: "#666"
}
# Connections between heads to show parallelism
row_heads.head_positional -> row_heads.head_syntactic: {
  style.stroke: transparent
}
row_heads.head_syntactic -> row_heads.head_semantic: {
  style.stroke: transparent
}
row_heads.head_semantic -> row_heads.head_causal: {
  style.stroke: transparent
}
row_heads -> row_heads2: {
  style.stroke: transparent
}
# Aggregation
row_aggregate: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  concat: {
    label: "Concatenate\nAll Heads"
    shape: parallelogram
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    width: 180
  }
  wo_proj: {
    label: "W_O Projection\n(Head Mixing)"
    shape: rectangle
    style.fill: "#C5CAE9"
    style.stroke: "#3F51B5"
    width: 180
    mixing: |md
      Learns which heads
      to trust for each
      context
    |
  }
  output: {
    label: "Final\nRepresentation"
    shape: cylinder
    style.fill: "#9FA8DA"
    style.stroke: "#1A237E"
    width: 160
  }
}
row_heads2 -> row_aggregate.concat: "Concat\n[dim=-1]" {
  style.stroke: "#3F51B5"
}
row_aggregate.concat -> row_aggregate.wo_proj: "[batch, seq, d_model]" {
  style.stroke: "#3F51B5"
}
row_aggregate.wo_proj -> row_aggregate.output: "[batch, seq, d_model]" {
  style.stroke: "#3F51B5"
}
# Key insight box
insight: {
  label: "Key Insight: Emergent Specialization"
  shape: rectangle
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
  width: 650
  content: |md
    **These specializations are NOT programmed explicitly.**
    During training, different heads naturally converge to different relationship types because:
    1. **Different input slices**: Each head sees different dimensions of the embedding (head 1: dims 0-63, head 2: dims 64-127, etc.)
    2. **Gradient pressure**: When one head captures a useful pattern, it receives stronger gradients for that pattern, reinforcing specialization
    3. **Regularization effect**: Splitting dimensions forces heads to specialize rather than all learning the same thing
    **Empirical findings** (from attention head analysis papers):
    - ~30% of heads show clear syntactic patterns
    - ~20% show positional patterns
    - ~15% show semantic clustering
    - ~35% are "general purpose" or redundant
  |
}
row_aggregate -> insight: {
  style.stroke: "#FBC02D"
  style.stroke-dash: 4
}
# Legend
legend: {
  near: bottom-right
  label: "Specialization Types"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#E0E0E0"
  pos: {
    shape: rectangle
    style.fill: "#E8F5E9"
    label: "Positional"
  }
  syn: {
    shape: rectangle
    style.fill: "#E3F2FD"
    label: "Syntactic"
  }
  sem: {
    shape: rectangle
    style.fill: "#FFF3E0"
    label: "Semantic"
  }
  cau: {
    shape: rectangle
    style.fill: "#F3E5F5"
    label: "Causal"
  }
}