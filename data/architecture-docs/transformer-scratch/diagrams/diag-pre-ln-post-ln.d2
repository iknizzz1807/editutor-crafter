direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Pre-LN vs Post-LN: Gradient Highway Comparison
  *Why normalization placement determines training stability in deep transformers*
| {near: top-center}
row_comparison: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  post_ln: {
    direction: down
    label: "Post-LN (Original Transformer)"
    post_input: {
      label: "Input x"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2563EB"
    }
    post_sublayer: {
      label: "Sublayer(x)\n(Attention/FFN)"
      shape: rectangle
      style.fill: "#FEF3C7"
      style.stroke: "#D97706"
    }
    post_add: {
      label: "Add\nx + Sublayer(x)"
      shape: circle
      style.fill: "#D1FAE5"
      style.stroke: "#059669"
    }
    post_norm: {
      label: "LayerNorm"
      shape: rectangle
      style.fill: "#FCE7F3"
      style.stroke: "#DB2777"
    }
    post_output: {
      label: "Output"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2563EB"
    }
    post_input -> post_sublayer: "x"
    post_sublayer -> post_add: "sublayer(x)"
    post_input -> post_add: "residual" {
      style.stroke: "#059669"
      style.stroke-width: 2
    }
    post_add -> post_norm: "unnorm"
    post_norm -> post_output: "norm"
  }
  pre_ln: {
    direction: down
    label: "Pre-LN (Modern Standard: GPT-2/3, LLaMA)"
    pre_input: {
      label: "Input x"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2563EB"
    }
    pre_norm: {
      label: "LayerNorm"
      shape: rectangle
      style.fill: "#FCE7F3"
      style.stroke: "#DB2777"
    }
    pre_sublayer: {
      label: "Sublayer(Norm(x))\n(Attention/FFN)"
      shape: rectangle
      style.fill: "#FEF3C7"
      style.stroke: "#D97706"
    }
    pre_add: {
      label: "Add\nx + Sublayer(Norm(x))"
      shape: circle
      style.fill: "#D1FAE5"
      style.stroke: "#059669"
    }
    pre_output: {
      label: "Output"
      shape: rectangle
      style.fill: "#E8F4FD"
      style.stroke: "#2563EB"
    }
    pre_input -> pre_norm: "x"
    pre_norm -> pre_sublayer: "norm(x)"
    pre_sublayer -> pre_add: "sublayer"
    pre_input -> pre_add: "residual\n(GRADIENT HIGHWAY)" {
      style.stroke: "#DC2626"
      style.stroke-width: 3
      style.bold: true
    }
    pre_add -> pre_output: "output"
  }
}
gradient_section: {
  label: "Gradient Flow Analysis (Backpropagation)"
  grad_comparison: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    post_grad: {
      label: "Post-LN Gradient Path"
      direction: down
      pg_out: {
        label: "∂L/∂output"
        shape: rectangle
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
      }
      pg_norm: {
        label: "→ LayerNorm\n(gradient may be\namplified/attenuated)"
        shape: rectangle
        style.fill: "#FEF3C7"
        style.stroke: "#D97706"
      }
      pg_split: {
        label: "→ Split at Add"
        shape: diamond
        style.fill: "#E0E7FF"
        style.stroke: "#4F46E5"
      }
      pg_sub: {
        label: "→ Sublayer\n(vanishing risk)"
        shape: rectangle
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
      }
      pg_res: {
        label: "→ Residual\n(must pass through\nLayerNorm first!)"
        shape: rectangle
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
      }
      pg_in: {
        label: "∂L/∂input\n(noise + potential\nvanishing)"
        shape: rectangle
        style.fill: "#FEE2E2"
        style.stroke: "#DC2626"
      }
      pg_out -> pg_norm
      pg_norm -> pg_split
      pg_split -> pg_sub
      pg_split -> pg_res
      pg_sub -> pg_in
      pg_res -> pg_in
    }
    pre_grad: {
      label: "Pre-LN Gradient Path"
      direction: down
      pre_g_out: {
        label: "∂L/∂output"
        shape: rectangle
        style.fill: "#DCFCE7"
        style.stroke: "#16A34A"
      }
      pre_g_split: {
        label: "→ Split at Add\n(identity path!)"
        shape: diamond
        style.fill: "#D1FAE5"
        style.stroke: "#059669"
      }
      pre_g_highway: {
        label: "→ RESIDUAL\nHIGHWAY\n∂L/∂x += ∂L/∂output\n(DIRECT, UNMODIFIED)"
        shape: rectangle
        style.fill: "#BBF7D0"
        style.stroke: "#16A34A"
        style.bold: true
        style.stroke-width: 3
      }
      pre_g_sub: {
        label: "→ Sublayer path\n(LayerNorm gradient\nonly affects this branch)"
        shape: rectangle
        style.fill: "#FEF3C7"
        style.stroke: "#D97706"
      }
      pre_g_in: {
        label: "∂L/∂input\n(stable, bounded\nby identity)"
        shape: rectangle
        style.fill: "#DCFCE7"
        style.stroke: "#16A34A"
      }
      pre_g_out -> pre_g_split
      pre_g_split -> pre_g_highway
      pre_g_split -> pre_g_sub
      pre_g_highway -> pre_g_in
      pre_g_sub -> pre_g_in
    }
  }
}
math_section: {
  label: "Mathematical Foundation"
  math_content: {
    direction: right
    post_math: {
      label: |md
        **Post-LN Forward:**
        
        output = LayerNorm(x + Sublayer(x))
        
        **Post-LN Gradient:**
        
        ∂output/∂x = ∂LN/∂x · (I + ∂Sub/∂x)
        
        *Gradient MUST pass through LayerNorm*
        *Can explode or vanish unpredictably*
      |
      shape: rectangle
      style.fill: "#FEF3C7"
      style.stroke: "#D97706"
    }
    pre_math: {
      label: |md
        **Pre-LN Forward:**
        
        output = x + Sublayer(LayerNorm(x))
        
        **Pre-LN Gradient:**
        
        ∂output/∂x = I + ∂Sub/∂x · ∂LN/∂x
        
        *Identity term `I` provides GRADIENT HIGHWAY*
        *Even if Sublayer gradient vanishes, `I` remains*
      |
      shape: rectangle
      style.fill: "#DCFCE7"
      style.stroke: "#16A34A"
    }
  }
}
comparison_table: {
  label: "Practical Comparison"
  table_content: {
    direction: right
    post_props: {
      label: |md
        **Post-LN Properties:**
        - Requires learning rate warmup
        - Fragile training in early steps
        - Can achieve slightly better final performance
        - Gradients can explode/vanish
        - Used in: Original Transformer
      |
      shape: rectangle
      style.fill: "#FEF3C7"
      style.stroke: "#D97706"
    }
    pre_props: {
      label: |md
        **Pre-LN Properties:**
        - Stable from training step 1
        - No warmup strictly required
        - Slightly lower final performance possible
        - Bounded, stable gradients
        - Used in: GPT-2, GPT-3, LLaMA, BERT-large
      |
      shape: rectangle
      style.fill: "#DCFCE7"
      style.stroke: "#16A34A"
    }
  }
}
final_norm_note: {
  label: |md
    **Important:** Pre-LN requires a final LayerNorm after the last layer,
    since the output hasn't been normalized. Post-LN's last sublayer
    already includes normalization.
  |
  shape: callout
  style.fill: "#E0E7FF"
  style.stroke: "#4F46E5"
}
legend: {
  near: bottom-right
  label: "Legend"
  leg_res: {
    label: "Residual Connection"
    shape: rectangle
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
  }
  leg_norm: {
    label: "Layer Normalization"
    shape: rectangle
    style.fill: "#FCE7F3"
    style.stroke: "#DB2777"
  }
  leg_sub: {
    label: "Sublayer (Attn/FFN)"
    shape: rectangle
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
  }
  leg_highway: {
    label: "Gradient Highway"
    shape: rectangle
    style.fill: "#BBF7D0"
    style.stroke: "#16A34A"
    style.bold: true
  }
  leg_danger: {
    label: "Gradient Risk"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#DC2626"
  }
}