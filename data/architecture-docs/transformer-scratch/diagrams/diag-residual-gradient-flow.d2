direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Residual Connection Gradient Flow
  **Backward pass: How skip connections create a gradient highway**
| {near: top-center}
legend: {
  near: bottom-center
  label: ""
  style.stroke: transparent
  style.fill: transparent
  forward: "Forward: x → Layer → output"
  residual: "Residual: x → + → output"
  grad_direct: "Direct gradient path (identity)"
  grad_layer: "Gradient through layer"
  forward.style.fill: "#E8F4FD"
  forward.style.stroke: "#2196F3"
  residual.style.fill: "#E8F4FD"
  residual.style.stroke: "#2196F3"
  grad_direct.style.fill: "#C8E6C9"
  grad_direct.style.stroke: "#4CAF50"
  grad_layer.style.fill: "#FFCDD2"
  grad_layer.style.stroke: "#F44336"
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  comparison: {
    direction: down
    label: ""
    without_residual: {
      label: "WITHOUT Residual (Vanishing Gradient)"
      style.stroke: "#F44336"
      style.fill: "#FFEBEE"
      w_input: {
        label: "Input x"
        shape: rectangle
        style.fill: "#E3F2FD"
      }
      w_l1: {
        label: "Layer 1\n∂f₁/∂x"
        shape: rectangle
        style.fill: "#FFCDD2"
      }
      w_l2: {
        label: "Layer 2\n∂f₂/∂x"
        shape: rectangle
        style.fill: "#FFCDD2"
      }
      w_ln: {
        label: "Layer N\n∂fₙ/∂x"
        shape: rectangle
        style.fill: "#FFCDD2"
      }
      w_loss: {
        label: "Loss L"
        shape: rectangle
        style.fill: "#FFCDD2"
      }
      w_input -> w_l1: "forward"
      w_l1 -> w_l2: "forward"
      w_l2 -> w_ln: "..."
      w_ln -> w_loss: "forward"
      w_loss -> w_ln: "∂L/∂fₙ" {style.stroke: "#F44336"; style.stroke-dash: 3}
      w_ln -> w_l2: "× ∂fₙ/∂fₙ₋₁" {style.stroke: "#F44336"; style.stroke-dash: 3}
      w_l2 -> w_l1: "× ∂f₂/∂f₁" {style.stroke: "#F44336"; style.stroke-dash: 3}
      w_l1 -> w_input: "× ∂f₁/∂x\n≈ 0.5ⁿ" {style.stroke: "#F44336"; style.stroke-dash: 3}
    }
    with_residual: {
      label: "WITH Residual (Gradient Highway)"
      style.stroke: "#4CAF50"
      style.fill: "#E8F5E9"
      r_input: {
        label: "Input x"
        shape: rectangle
        style.fill: "#E3F2FD"
      }
      r_add1: {
        label: "+"
        shape: circle
        style.fill: "#C8E6C9"
      }
      r_layer1: {
        label: "Layer 1\nf₁(x)"
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      r_add2: {
        label: "+"
        shape: circle
        style.fill: "#C8E6C9"
      }
      r_layer2: {
        label: "Layer 2\nf₂(x)"
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      r_addn: {
        label: "+"
        shape: circle
        style.fill: "#C8E6C9"
      }
      r_layern: {
        label: "Layer N\nfₙ(x)"
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      r_loss: {
        label: "Loss L"
        shape: rectangle
        style.fill: "#E3F2FD"
      }
      r_input -> r_add1: "x"
      r_add1 -> r_layer1: "x"
      r_layer1 -> r_add2: "f₁(x)"
      r_input -> r_add1: "skip" {style.stroke: "#4CAF50"; style.stroke-dash: 3}
      r_add2 -> r_layer2: "x + f₁(x)"
      r_layer2 -> r_addn: "f₂(x)"
      r_addn -> r_layern: "x + Σfᵢ(x)"
      r_layern -> r_loss: "output"
      r_loss -> r_layern: "∂L/∂out" {style.stroke: "#4CAF50"}
      r_layern -> r_addn: "∂L/∂(x+f)" {style.stroke: "#4CAF50"}
      r_addn -> r_layer2: "through f" {style.stroke: "#F44336"; style.stroke-dash: 3}
      r_addn -> r_add2: "× 1 (identity)" {style.stroke: "#4CAF50"}
      r_add2 -> r_layer1: "through f" {style.stroke: "#F44336"; style.stroke-dash: 3}
      r_add2 -> r_add1: "× 1 (identity)" {style.stroke: "#4CAF50"}
      r_add1 -> r_input: "∂L/∂x = ∂L/∂out × (1 + Σ ∂fᵢ/∂x)" {style.stroke: "#4CAF50"}
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  math_box: {
    label: "The Gradient Math"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    math_content: |md
      **Without Residual:**
      
      ∂L/∂x = ∂L/∂y × ∏ᵢ ∂fᵢ/∂hᵢ
      
      If each ∂fᵢ/∂hᵢ ≈ 0.5, after 12 layers:
      `0.5¹² ≈ 0.00024` (vanished!)
      **With Residual:**
      
      ∂L/∂x = ∂L/∂y × (1 + Σᵢ ∂fᵢ/∂hᵢ)
      
      The **1** is the identity term from the skip connection.
      Even if all ∂fᵢ ≈ 0, gradient ≥ ∂L/∂y (preserved!)
    |
  }
  transformer_box: {
    label: "Transformer Layer Pattern"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    t_input: {
      label: "x [batch, seq, d_model]"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    t_norm: {
      label: "LayerNorm"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    t_attn: {
      label: "Multi-Head\nAttention"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    t_add1: {
      label: "+"
      shape: circle
      style.fill: "#C8E6C9"
    }
    t_ffn: {
      label: "FFN"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    t_add2: {
      label: "+"
      shape: circle
      style.fill: "#C8E6C9"
    }
    t_output: {
      label: "output"
      shape: rectangle
      style.fill: "#E3F2FD"
    }
    t_input -> t_norm: ""
    t_norm -> t_attn: ""
    t_attn -> t_add1: ""
    t_input -> t_add1: "residual" {style.stroke: "#4CAF50"; style.stroke-dash: 3}
    t_add1 -> t_ffn: ""
    t_ffn -> t_add2: ""
    t_add1 -> t_add2: "residual" {style.stroke: "#4CAF50"; style.stroke-dash: 3}
    t_add2 -> t_output: ""
    t_note: |md
      **Pre-LN variant shown**
      Each sublayer has a skip connection
      Gradients flow through **both** paths
    |
  }
}