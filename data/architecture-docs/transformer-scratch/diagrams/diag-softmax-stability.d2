direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Softmax Numerical Stability {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_comparison: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  naive: {
    direction: down
    label: "Naive Softmax (Overflow Risk)"
    style: {
      fill: "#FFF0F0"
      stroke: "#CC0000"
      stroke-width: 2
    }
    input_naive: {
      label: "Input Logits"
      shape: sql_table
      label_row: "i | value"
      row0: "0 | 50.0"
      row1: "1 | 60.0"
      row2: "2 | 40.0"
      row3: "3 | 55.0"
    }
    exp_naive: {
      label: "exp(x) - OVERFLOW!"
      shape: sql_table
      label_row: "i | exp(value)"
      row0: "0 | 5.18e+21"
      row1: "1 | 1.14e+26 ← INF!"
      row2: "2 | 2.35e+17"
      row3: "3 | 7.69e+23"
      note: "e^60 exceeds float32 max"
    }
    sum_naive: {
      label: "Sum"
      shape: rectangle
      width: 180
      sum_val: "Σ exp(x) = INF"
      style: {
        fill: "#FFE0E0"
        stroke: "#CC0000"
        bold: true
      }
    }
    output_naive: {
      label: "Result - BROKEN"
      shape: sql_table
      label_row: "i | softmax(x)"
      row0: "0 | 0.0 / INF = 0.0"
      row1: "1 | INF / INF = NaN"
      row2: "2 | 0.0 / INF = 0.0"
      row3: "3 | 0.0 / INF = 0.0"
      style: {
        fill: "#FFE0E0"
        stroke: "#CC0000"
      }
    }
    input_naive -> exp_naive: "exp()"
    exp_naive -> sum_naive: "sum"
    sum_naive -> output_naive: "normalize"
  }
  stable: {
    direction: down
    label: "Stable Softmax (Max Subtraction)"
    style: {
      fill: "#F0FFF0"
      stroke: "#00AA00"
      stroke-width: 2
    }
    input_stable: {
      label: "Input Logits"
      shape: sql_table
      label_row: "i | value"
      row0: "0 | 50.0"
      row1: "1 | 60.0"
      row2: "2 | 40.0"
      row3: "3 | 55.0"
    }
    max_sub: {
      label: "Subtract Max (60.0)"
      shape: sql_table
      label_row: "i | x - max"
      row0: "0 | -10.0"
      row1: "1 | 0.0"
      row2: "2 | -20.0"
      row3: "3 | -5.0"
      note: "All values ≤ 0"
    }
    exp_stable: {
      label: "exp(x - max)"
      shape: sql_table
      label_row: "i | exp(shifted)"
      row0: "0 | 4.54e-05"
      row1: "1 | 1.0"
      row2: "2 | 2.06e-09"
      row3: "3 | 6.74e-03"
      note: "All values ≤ 1.0"
    }
    sum_stable: {
      label: "Sum"
      shape: rectangle
      width: 180
      sum_val: "Σ = 1.0068"
      style: {
        fill: "#E0FFE0"
        stroke: "#00AA00"
        bold: true
      }
    }
    output_stable: {
      label: "Result - CORRECT"
      shape: sql_table
      label_row: "i | softmax(x)"
      row0: "0 | 0.0045 (0.45%)"
      row1: "1 | 0.9932 (99.32%)"
      row2: "2 | 0.0000 (0.00%)"
      row3: "3 | 0.0067 (0.67%)"
      style: {
        fill: "#E0FFE0"
        stroke: "#00AA00"
      }
    }
    input_stable -> max_sub: "x - max(x)"
    max_sub -> exp_stable: "exp()"
    exp_stable -> sum_stable: "sum"
    sum_stable -> output_stable: "normalize"
  }
}
formula_box: {
  label: "Mathematical Equivalence"
  width: 600
  style: {
    fill: "#F5F5F5"
    stroke: "#666666"
    stroke-dash: 3
  }
  formula_content: |md
    **Key Insight**: Subtracting the max does not change the output!
    $$\text{softmax}(x_i) = \frac{e^{x_i}}{\sum_j e^{x_j}} = \frac{e^{x_i - m}}{\sum_j e^{x_j - m}}$$
    where $m = \max(x)$
    **Proof**: Factor out $e^m$ from numerator and denominator:
    $$\frac{e^{x_i}}{\sum_j e^{x_j}} = \frac{e^{m} \cdot e^{x_i - m}}{e^{m} \cdot \sum_j e^{x_j - m}} = \frac{e^{x_i - m}}{\sum_j e^{x_j - m}}$$
    The $e^m$ factors cancel out!
  |
}
overflow_range: {
  label: "Overflow Thresholds"
  shape: sql_table
  label: "Numerical Limits"
  f32: "float32 max | ~3.4e+38 | exp(88.7)"
  f64: "float64 max | ~1.8e+308 | exp(709.8)"
  attention: "Attention scores | can reach 50-100 | without scaling!"
  note: "Scaling by sqrt(d_k) keeps scores in safe range"
  style: {
    fill: "#FFF8E0"
    stroke: "#CC9900"
  }
}
implementation: {
  label: "PyTorch Implementation"
  width: 500
  code: |'python
    def stable_softmax(x, dim=-1):
        """
        Numerically stable softmax.
        PyTorch's F.softmax() does this internally!
        """
        # Subtract max for numerical stability
        x_max = x.max(dim=dim, keepdim=True).values
        x_shifted = x - x_max
        # Compute exp (now safe from overflow)
        exp_x = torch.exp(x_shifted)
        # Normalize
        return exp_x / exp_x.sum(dim=dim, keepdim=True)
  '|
}
row_comparison -> formula_box
formula_box -> overflow_range
overflow_range -> implementation
legend: {
  near: bottom-right
  style: {
    fill: white
    stroke: "#999999"
    border-radius: 4
  }
  red: {
    label: "Red = Overflow/NaN risk"
    shape: rectangle
    width: 150
    style.fill: "#FFE0E0"
  }
  green: {
    label: "Green = Numerically stable"
    shape: rectangle
    width: 150
    style.fill: "#E0FFE0"
  }
  red -> green: {
    style: {
      stroke: transparent
    }
  }
}