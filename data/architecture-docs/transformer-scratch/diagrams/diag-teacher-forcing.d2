direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Teacher Forcing Data Flow
  **One-Position Offset for Next-Token Prediction**
| {near: top-center}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  target_seq: {
    direction: down
    label: "Target Sequence"
    tok_y0: "y₀"
    tok_y1: "y₁"
    tok_y2: "y₂"
    tok_y3: "y₃"
    tok_y4: "y₄"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
}
row_shift: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  dec_input: {
    direction: down
    label: "Decoder Input\n(shifted right)"
    tok_sos: "<SOS>"
    tok_d0: "y₀"
    tok_d1: "y₁"
    tok_d2: "y₂"
    tok_d3: "y₃"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  arrow_block: {
    label: ""
    width: 80
    style.fill: transparent
    style.stroke: transparent
  }
  dec_target: {
    direction: down
    label: "Target for Loss\n(shifted left)"
    tok_t0: "y₁"
    tok_t1: "y₂"
    tok_t2: "y₃"
    tok_t3: "y₄"
    tok_eos: "<EOS>"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
row_annotation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  explanation: {
    width: 600
    code: |'python
# Teacher Forcing: One-Position Shift
# 
# Decoder Input:  <SOS>  y₀    y₁    y₂    y₃
# Position:        0     1     2     3     4
# Predicts:        y₀    y₁    y₂    y₃   <EOS>
#
# Target for Loss: y₀    y₁    y₂    y₃   <EOS>
#
# Key Insight: Position i predicts token at position i+1
# decoder_input = tgt[:, :-1]   # Drop last token
# target        = tgt[:, 1:]    # Drop first token (<SOS>)
'|
  }
}
row_mapping: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mapping_table: {
    shape: sql_table
    label: "Position-to-Prediction Mapping"
    pos0: "Pos 0 | <SOS> | → | y₀"
    pos1: "Pos 1 | y₀    | → | y₁"
    pos2: "Pos 2 | y₁    | → | y₂"
    pos3: "Pos 3 | y₂    | → | y₃"
    pos4: "Pos 4 | y₃    | → | <EOS>"
    note: "Each position predicts the NEXT token"
  }
}
row_decoder: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  decoder_box: {
    label: "Decoder (with Causal Mask)"
    width: 400
    self_attn: "Masked Self-Attention\n(can only see current + past)"
    cross_attn: "Cross-Attention\n(Q from decoder, K/V from encoder)"
    ffn: "Feed-Forward Network"
    self_attn.style.fill: "#E1BEE7"
    cross_attn.style.fill: "#B2DFDB"
    ffn.style.fill: "#FFECB3"
    self_attn -> cross_attn -> ffn: "→"
  }
  output_proj: {
    label: "Output Projection"
    width: 150
    style.fill: "#FFCDD2"
    desc: "Linear → Logits\n[batch, seq, vocab_size]"
  }
}
row_loss: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  loss_box: {
    label: "Cross-Entropy Loss"
    width: 500
    formula: |'python
# Masked Cross-Entropy Loss
loss = CrossEntropyLoss(
    logits.reshape(-1, vocab_size),   # [batch*seq, vocab]
    target.reshape(-1),               # [batch*seq]
    ignore_index=PAD_TOKEN            # Skip padding
)
'|
  }
}
# Arrows showing data flow
row_input.target_seq -> row_shift.dec_input: "Shift Right\nPrepend <SOS>" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
row_input.target_seq -> row_shift.dec_target: "Shift Left\nDrop <SOS>" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
}
row_shift.dec_input -> row_decoder.decoder_box: "Feed to Decoder" {
  style.stroke: "#4CAF50"
  style.stroke-dash: 3
}
row_decoder.decoder_box -> row_decoder.output_proj: "Hidden States" {
  style.stroke: "#9C27B0"
}
row_decoder.output_proj -> row_loss.loss_box: "Logits" {
  style.stroke: "#F44336"
}
row_shift.dec_target -> row_loss.loss_box: "Target Indices" {
  style.stroke: "#FF9800"
  style.stroke-dash: 3
}
# Legend
legend: {
  near: bottom-right
  label: "Key Concepts"
  concept1: "SOS = Start of Sequence token"
  concept2: "EOS = End of Sequence token"
  concept3: "Position i predicts token at position i+1"
  concept4: "Causal mask prevents seeing future tokens"
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
}