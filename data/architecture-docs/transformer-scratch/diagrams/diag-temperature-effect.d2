direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Temperature Effect on LLM Sampling"
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  t_low: "T = 0.5 (Low)" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    label_node: "Low Temperature | Deterministic" {
      style.bold: true
      style.font-size: 16
    }

    dist_low: {
      shape: class
      label: "Probability Distribution"
      Token_A: "0.92 (High Peak)"
      Token_B: "0.05"
      Token_C: "0.02"
      Token_D: "0.01"
    }

    behavior_low: {
      desc: "Peaked distribution"
      selection: "Nearly greedy selection"
      output: "Low entropy / Focused"
    }
  }

  t_mid: "T = 1.0 (Original)" {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    label_node: "Normal Temperature | Standard" {
      style.bold: true
      style.font-size: 16
    }

    dist_mid: {
      shape: class
      label: "Probability Distribution"
      Token_A: "0.62 (Natural)"
      Token_B: "0.23"
      Token_C: "0.10"
      Token_D: "0.05"
    }

    behavior_mid: {
      desc: "Original distribution"
      selection: "Balanced exploration"
      output: "Moderate entropy"
    }
  }

  t_high: "T = 2.0 (High)" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2

    label_node: "High Temperature | Random" {
      style.bold: true
      style.font-size: 16
    }

    dist_high: {
      shape: class
      label: "Probability Distribution"
      Token_A: "0.41 (Flattened)"
      Token_B: "0.28"
      Token_C: "0.18"
      Token_D: "0.13"
    }

    behavior_high: {
      desc: "Flattened distribution"
      selection: "High exploration"
      output: "High entropy / Creative"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  formula_box: "Temperature Scaling Formula" {
    direction: down
    width: 500
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"

    # FIXED: Using |'md ... '| to allow pipe character | inside the LaTeX formula
    formula: |'latex
      P(y_t | y_{<t}) = \frac{\exp(z_t / T)}{\sum_k \exp(z_k / T)}
    '|

    explanation: {
      z_t: "Logit score for token t"
      T: "Temperature parameter"
      limit_low: "T -> 0: approaches argmax (Greedy)"
      limit_high: "T -> inf: approaches uniform (Random)"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  use_cases: "Recommended Temperature by Task" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    width: 500

    tasks: {
      shape: class
      label: "Task Selection Guide"
      Code_Gen: "0.0 - 0.2"
      Fact_Retrieval: "0.1 - 0.4"
      Summarization: "0.5 - 0.7"
      Creative_Writing: "0.7 - 1.2"
      Brainstorming: "1.0 - 1.5"
    }
  }
}

# Connections for flow
row1.t_low -> row1.t_mid: "Increase T | More Variance" {
  style.stroke-dash: 3
}
row1.t_mid -> row1.t_high: "Increase T | More Entropy" {
  style.stroke-dash: 3
}

row1 -> row2: "Softmax Transformation"
row2 -> row3: "Operational Settings"

legend: "Key Visual Identifiers" {
  near: bottom-right
  style.fill: white
  style.stroke: "#666"
  
  l1: "Green: Deterministic" {
    style.font-color: "#4CAF50"
    style.bold: true
  }
  l2: "Blue: Balanced" {
    style.font-color: "#2196F3"
    style.bold: true
  }
  l3: "Red: Creative" {
    style.font-color: "#F44336"
    style.bold: true
  }
}