direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Training Loop Data Flow {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
step1: {
  label: "Step 1: Forward Pass"
  width: 450
  code: |'python
    # Teacher forcing: shift target by 1 position
    decoder_input = tgt_tokens[:, :-1]   # <sos> + tgt[:-1]
    target_for_loss = tgt_tokens[:, 1:]  # tgt[1:] + <eos>
    # Forward through model
    logits = model(src_tokens, decoder_input, 
                   src_mask=src_mask, 
                   tgt_mask=causal_mask)
    # logits shape: [batch, tgt_len-1, vocab_size]
  '|
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
step2: {
  label: "Step 2: Loss Computation"
  width: 450
  code: |'python
    # Flatten for cross-entropy
    logits_flat = logits.reshape(-1, vocab_size)
    targets_flat = target_for_loss.reshape(-1)
    # Masked cross-entropy (ignore padding)
    loss = F.cross_entropy(
        logits_flat, targets_flat,
        ignore_index=pad_token_id,
        label_smoothing=0.1,
        reduction='mean'
    )
    # loss: scalar tensor
  '|
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
}
step3: {
  label: "Step 3: Backward Pass"
  width: 450
  code: |'python
    # Clear previous gradients
    optimizer.zero_grad()
    # Compute gradients via backpropagation
    loss.backward()
    # Gradients now stored in param.grad for all params
    # Gradient flow: loss -> logits -> decoder -> encoder
  '|
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
}
step4: {
  label: "Step 4: Gradient Clipping"
  width: 450
  code: |'python
    # Clip gradients to prevent explosion
    total_norm = torch.nn.utils.clip_grad_norm_(
        model.parameters(),
        max_norm=1.0
    )
    # If ||grads|| > 1.0, scale all grads by 1.0/||grads||
    # Preserves direction, limits magnitude
  '|
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}
step5: {
  label: "Step 5: Optimizer Step"
  width: 450
  code: |'python
    # Update parameters using gradients
    optimizer.step()
    # Adam update for each parameter:
    # m = beta1 * m + (1 - beta1) * grad
    # v = beta2 * v + (1 - beta2) * grad^2
    # param -= lr * m / (sqrt(v) + eps)
  '|
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
}
step6: {
  label: "Step 6: Scheduler Step"
  width: 450
  code: |'python
    # Get new learning rate with warmup + decay
    lr = scheduler.step()
    # Update optimizer learning rate
    for param_group in optimizer.param_groups:
        param_group['lr'] = lr
    # lr = d_model^-0.5 * min(step^-0.5, step*warmup^-1.5)
  '|
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
}
step1 -> step2: "logits [B,T,V]" {
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
step2 -> step3: "loss (scalar)" {
  style.stroke: "#E65100"
  style.stroke-width: 2
}
step3 -> step4: ".grad tensors" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
step4 -> step5: "clipped grads" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
step5 -> step6: "updated params" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
legend: {
  near: bottom-center
  label: "Training Loop Components"
  style.fill: transparent
  style.stroke: "#9E9E9E"
  item1: "Forward: model(src, tgt) → logits" {
    style.fill: "#E3F2FD"
  }
  item2: "Loss: CrossEntropy with masking" {
    style.fill: "#FFF3E0"
  }
  item3: "Backward: loss.backward() → grads" {
    style.fill: "#F3E5F5"
  }
  item4: "Clip: clip_grad_norm_ ≤ 1.0" {
    style.fill: "#FFEBEE"
  }
  item5: "Optimize: Adam β=(0.9,0.98)" {
    style.fill: "#E8F5E9"
  }
  item6: "Schedule: warmup + decay" {
    style.fill: "#E0F7FA"
  }
}
iteration_note: {
  label: "Repeat for N training steps"
  near: center-right
  shape: text
  style: {
    font-size: 18
    italic: true
    font-color: "#616161"
  }
}
step6 -> step1: "next batch" {
  style.stroke-dash: 4
  style.stroke: "#616161"
  style.animated: true
}