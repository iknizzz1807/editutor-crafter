direction: right
layout-engine: elk
title: {
  label: "Q/K/V Projection Architecture"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Style definitions
classes: {
  projection_layer: {
    style: {
      fill: "#E8E4F0"
      stroke: "#7B68EE"
      stroke-width: 2
      border-radius: 8
      font-size: 14
    }
  }
  tensor_input: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      border-radius: 4
      font-size: 12
    }
  }
  tensor_output: {
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
      border-radius: 4
      font-size: 12
    }
  }
  dim_label: {
    style: {
      font-size: 11
      italic: true
      fill: "#666666"
    }
  }
}
# Input tensor
input_embeddings: {
  label: "Input Embeddings\nX"
  class: tensor_input
}
input_shape: {
  label: "[batch, seq_len, d_model]"
  class: dim_label
  shape: text
}
input_embeddings -> input_shape: {
  style.stroke: transparent
}
# Parallel projection layers container
projections: {
  label: "Parallel Linear Projections"
  W_Q: {
    label: "W_Q\nnn.Linear"
    class: projection_layer
  }
  W_K: {
    label: "W_K\nnn.Linear"
    class: projection_layer
  }
  W_V: {
    label: "W_V\nnn.Linear"
    class: projection_layer
  }
}
# Output tensors
query: {
  label: "Query (Q)"
  class: tensor_output
}
key: {
  label: "Key (K)"
  class: tensor_output
}
value: {
  label: "Value (V)"
  class: tensor_output
}
# Output dimension labels
query_shape: {
  label: "[batch, seq_len, d_k]"
  class: dim_label
  shape: text
}
key_shape: {
  label: "[batch, seq_len, d_k]"
  class: dim_label
  shape: text
}
value_shape: {
  label: "[batch, seq_len, d_v]"
  class: dim_label
  shape: text
}
# Connections from input to projections
input_embeddings -> projections.W_Q: {
  label: "d_model"
  style: {
    stroke: "#7B68EE"
    stroke-width: 2
  }
}
input_embeddings -> projections.W_K: {
  label: "d_model"
  style: {
    stroke: "#7B68EE"
    stroke-width: 2
  }
}
input_embeddings -> projections.W_V: {
  label: "d_model"
  style: {
    stroke: "#7B68EE"
    stroke-width: 2
  }
}
# Connections from projections to outputs
projections.W_Q -> query: {
  label: "d_k"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
projections.W_K -> key: {
  label: "d_k"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
projections.W_V -> value: {
  label: "d_v"
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
# Dimension annotation connections
query -> query_shape: {
  style.stroke: transparent
}
key -> key_shape: {
  style.stroke: transparent
}
value -> value_shape: {
  style.stroke: transparent
}
# Initialization note
init_note: {
  label: "Xavier Uniform Initialization\nbias=False"
  shape: text
  style: {
    font-size: 10
    italic: true
    fill: "#9E9E9E"
  }
}
# Legend
legend: {
  label: "Legend"
  input_legend: {
    label: "Input Tensor"
    class: tensor_input
  }
  proj_legend: {
    label: "Linear Layer"
    class: projection_layer
  }
  output_legend: {
    label: "Output Tensor"
    class: tensor_output
  }
}