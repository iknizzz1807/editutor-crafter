    dim1: "dim_1: [k₀₁, k₁₁, k₂₁, k₃₁]"
    ell: "...: ..."
    dim63: "dim_63: [k₀₆₃, k₁₆₃, k₂₆₃, k₃₆₃]"
  }
  transpose_note: {
    label: "K^T[j,i] = K[i,j] | Rows become columns"
    shape: text
    style.font-size: 14
    style.italic: true
  }
}

# Matrix Multiplication Detail
multiplication_section: "Matrix Multiplication (Q @ K^T)" {
  mult_explanation: {
    label: |md
      ### Dot Product Computation
      For each position pair (i, j):
      
      **score[i,j] = Σ(Q[i,:] · K^T[:,j])**
                 = Σ(Q[i,k] · K[j,k])  for k=0 to d_k-1
                 = **Q[i] · K[j]**
      
      This computes the semantic compatibility
      between position *i* and position *j*.
    |
    shape: text
  }
  example_compute: {
    label: "Example: score[2,1]"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    formula: {
      label: |md
        **Position Pair [2,1] Calculation:**
        `score[2,1] = Q[2] · K[1]`
        
        = q₂₀·k₁₀ + q₂₁·k₁₁ + ... + q₂₆₃·k₁₆₃
        = **Σₖ q₂ₖ · k₁ₖ**  (k=0..63)
      |
      shape: text
    }
  }
}

# Resulting Attention Scores
result_section: "Raw Attention Scores [seq_len × seq_len]" {
  score_matrix: "Q @ K^T (Raw Energy)" {
    shape: sql_table
    style.fill: "#FCE4EC"
    header: {
      label: "Energy Scores"
      style.fill: "#C2185B"
      style.font-color: white
    }
    row0: "pos_0: [s₀₀, s₀₁, s₀₂, s₀₃]"
    row1: "pos_1: [s₁₀, s₁₁, s₁₂, s₁₃]"
    row2: "pos_2: [s₂₀, s₂₁, s₂₂, s₂₃]"
    row3: "pos_3: [s₃₀, s₃₁, s₃₂, s₃₃]"
  }
  score_legend: {
    label: |md
      **Score Interpretation:**
      - `s_ij` = energy from query *i* to key *j*
      - Higher energy → stronger correlation
    |
    shape: text
    style.font-size: 12
  }
}

# Scaling Operation
scale_section: "Scaling Operation" {
  scale_operation: {
    label: |md
      ### Scale by √d_k
      `scaled_scores = scores / √d_k`
      `scaled_scores = scores / √64 = 8.0`
      
      **Rationale:**
      Prevents dot products from growing large, 
      keeping Softmax gradients stable.
    |
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
  scaled_matrix: "Scaled Scores (seq_len × seq_len)" {
    shape: sql_table
    style.fill: "#EDE7F6"
    header: {
      label: "(Q @ K^T) / √d_k"
      style.fill: "#512DA8"
      style.font-color: white
    }
    row0: "pos_0: [s'₀₀, s'₀₁, s'₀₂, s'₀₃]"
    row1: "pos_1: [s'₁₀, s'₁₁, s'₁₂, s'₁₃]"
    row2: "pos_2: [s'₂₀, s'₂₁, s'₂₂, s'₂₃]"
    row3: "pos_3: [s'₃₀, s'₃₁, s'₃₂, s'₃₃]"
  }
}

