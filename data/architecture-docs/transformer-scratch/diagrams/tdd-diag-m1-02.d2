# Code Implementation Reference
pytorch_section: "PyTorch Implementation Reference" {
  code: |python
  def scaled_dot_product_attention(Q, K, d_k=64):
      # Q: [batch, heads, seq_len, d_k]
      # K: [batch, heads, seq_len, d_k]
      
      K_t = K.transpose(-2, -1)
      attn_energy = torch.matmul(Q, K_t)
      
      scale = math.sqrt(d_k)
      scaled_energy = attn_energy / scale
      
      return scaled_energy
  |
  style.fill: "#263238"
  style.font-color: "#ECEFF1"
}

