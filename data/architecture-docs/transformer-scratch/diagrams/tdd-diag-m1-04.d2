vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: "Padding Mask Application | Algorithm Steps" {
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# ============================================
# INPUT SECTION
# ============================================
input_section: "Input Tensors" {
  style.stroke-dash: 3
  
  seq_lengths: "Sequence Lengths\n(batch_size)" {
    shape: rectangle
    tooltip: "Actual number of non-padding tokens per sequence"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
  }
  
  attention_scores: "Raw Attention Scores\n[B, H, Sq, Sk]" {
    shape: rectangle
    tooltip: "Unnormalized dot-product attention values"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
    }
  }
}

# ============================================
# ALGORITHM STEPS
# ============================================

step1_position: "Step 1: Generate Position Indices" {
  position_tensor: "torch.arange(max_seq_len)\n[0, 1, 2, 3, 4, ...]" {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
    }
  }
  reshape_pos: "Reshape for broadcast\n[1, 1, 1, max_seq_len]" {
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
    }
  }
}

step2_reshape: "Step 2: Reshape Lengths" {
  lengths_reshape: "Reshape lengths\n[batch] → [batch, 1, 1, 1]" {
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }
}

step3_mask: "Step 3: Create Boolean Mask" {
  comparison: "Comparison\npositions >= lengths" {
    shape: diamond
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
    }
  }
  mask_result: "Boolean Mask\n[B, 1, 1, Sk]\nTrue = Padding" {
    shape: rectangle
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
    }
  }
}

step4_expand: "Step 4: Broadcast to Score Shape" {
  expanded_mask: "Expanded Mask\n[B, H, Sq, Sk]\n(Implicit Broadcast)" {
    shape: rectangle
    style: {
      fill: "#E0F7FA"
      stroke: "#00838F"
    }
  }
}

step5_infinity: "Step 5: Apply Masked Fill" {
  masked_fill_op: "masked_fill(mask, -1e9)\nTrue → -∞\nFalse → unchanged" {
    shape: rectangle
    style: {
      fill: "#FCE4EC"
      stroke: "#AD1457"
    }
  }
  masked_scores: "Masked Scores\n[B, H, Sq, Sk]\nPadding positions = -∞" {
    shape: rectangle
    style: {
      fill: "#FCE4EC"
      stroke: "#AD1457"
    }
  }
}

step6_softmax: "Step 6: Softmax" {
  softmax_op: "softmax(masked_scores)\nexp(-∞) = 0\nexp(valid)/sum(exp)" {
    shape: rectangle
    style: {
      fill: "#E8EAF6"
      stroke: "#3949AB"
    }
  }
}

# ============================================
# OUTPUT SECTION
# ============================================
output_section: "Output" {
  attention_weights: "Attention Weights\n[B, H, Sq, Sk]\nPadding = 0.0" {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      bold: true
      stroke-width: 4
    }
  }
}

# ============================================
# CONNECTIONS
# ============================================
input_section.seq_lengths -> step2_reshape.lengths_reshape: "batch lengths"
input_section.attention_scores -> step5_infinity.masked_fill_op: "raw scores"
step1_position.position_tensor -> step1_position.reshape_pos
step1_position.reshape_pos -> step3_mask.comparison: "positions"
step2_reshape.lengths_reshape -> step3_mask.comparison: "lengths"
step3_mask.comparison -> step3_mask.mask_result: "bool"
step3_mask.mask_result -> step4_expand.expanded_mask
step4_expand.expanded_mask -> step5_infinity.masked_fill_op: "mask"
step5_infinity.masked_fill_op -> step5_infinity.masked_scores
step5_infinity.masked_scores -> step6_softmax.softmax_op
step6_softmax.softmax_op -> output_section.attention_weights

# ============================================
# EXAMPLE DATA TRACE
# ============================================
example_box: "Concrete Example (B=2, Sk=5)" {
  near: bottom-center
  
  example_input: "lengths = [3, 4]" { shape: text }
  example_positions: "positions = [0, 1, 2, 3, 4]" { shape: text }
  
  example_mask: |md
    **Batch 0 (len=3):**
    `[F, F, F, T, T]`
    **Batch 1 (len=4):**
    `[F, F, F, F, T]`
  | {
    style: {
      fill: "#FFF8E1"
      stroke: "#F9A825"
    }
  }
  
  example_scores_before: |md
    **Scores (Before Mask):**
    [ 0.5, 0.3, 0.2, 0.1, 0.0 ]
    [ 0.4, 0.4, 0.1, 0.05, 0.05 ]
  | {
    style: {
      fill: "#ECEFF1"
      stroke: "#546E7A"
    }
  }
  
  example_scores_after: |md
    **Scores (After Mask):**
    [ 0.5, 0.3, 0.2, -inf, -inf ]
    [ 0.4, 0.4, 0.1, 0.05, -inf ]
  | {
    style: {
      fill: "#FFECB3"
      stroke: "#FF8F00"
    }
  }
  
  example_weights: |md
    **Weights (Softmax):**
    [ 0.42, 0.29, 0.29, 0.0, 0.0 ]
    [ 0.39, 0.39, 0.12, 0.10, 0.0 ]
  | {
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      bold: true
    }
  }
}

# ============================================
# LOGIC & BROADCASTING
# ============================================
formula_box: "Logic Reference" {
  near: center-right
  
  mask_formula: |md
    **Mask Condition:**
    `mask = (arange(seq_len) >= lengths.unsqueeze(-1))`
  | {
    style: { fill: "#E1F5FE"; stroke: "#0288D1" }
  }
  
  fill_formula: |md
    **Masked Fill:**
    `scores.masked_fill_(mask, float('-inf'))`
  | {
    style: { fill: "#E1F5FE"; stroke: "#0288D1" }
  }
  
  shape_logic: |md
    **Broadcasting Matrix:**
    
    Mask:   [B, 1, 1,  Sk]
    Scores: [B, H, Sq, Sk]
    ---------------------
    Result: [B, H, Sq, Sk]
    
    *Mask is repeated across Heads and Query dimensions.*
  | {
    style: {
      fill: "#F1F8E9"
      stroke: "#689F38"
    }
  }
}