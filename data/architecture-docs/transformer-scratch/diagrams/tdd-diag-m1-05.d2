direction: right
layout-engine: elk
title: {
  label: Causal Mask Structure\nUpper-Triangular Pattern for Transformer Decoder Self-Attention
  shape: text
  near: top-center
  style.font-size: 24
  style.bold: true
}
# Legend
legend: {
  shape: rectangle
  style.stroke: "#666666"
  style.stroke-dash: 4
  label: ""
  legend_title: {
    label: "Legend"
    shape: text
    style.bold: true
    style.font-size: 14
  }
  true_cell: {
    shape: rectangle
    label: "TRUE (Masked)"
    style.fill: "#ff6b6b"
    style.stroke: "#c92a2a"
  }
  false_cell: {
    shape: rectangle
    label: "FALSE (Visible)"
    style.fill: "#51cf66"
    style.stroke: "#2f9e44"
  }
  true_cell -> false_cell: {
    style.opacity: 0
  }
}
# Step 1: Concept
step1_container: {
  label: "Step 1: Mask Concept"
  shape: rectangle
  style.stroke: "#4263eb"
  style.stroke-width: 2
  concept_box: {
    shape: rectangle
    style.fill: "#e7f5ff"
    label: ""
    c1: {
      label: "Causal masking prevents tokens\nfrom attending to future positions"
      shape: text
      style.font-size: 12
    }
    c2: {
      label: "TRUE = mask with -∞ before softmax"
      shape: text
      style.font-size: 12
    }
    c3: {
      label: "FALSE = allow attention"
      shape: text
      style.font-size: 12
    }
    c1 -> c2 -> c3: {style.opacity: 0}
  }
}
# Step 2: Code
step2_container: {
  label: "Step 2: PyTorch Implementation"
  shape: rectangle
  style.stroke: "#4263eb"
  style.stroke-width: 2
  code_block: {
    label: "mask = torch.triu(\n    torch.ones(seq_len, seq_len),\n    diagonal=1\n).bool()\n\n# Shape: [1, 1, seq_len, seq_len]\n# For broadcasting across batch & heads"
    shape: code
    language: python
    style.font-size: 11
  }
}
# Step 3: Matrix Visualization
step3_container: {
  label: "Step 3: 6×6 Mask Matrix (seq_len=6)"
  shape: rectangle
  style.stroke: "#4263eb"
  style.stroke-width: 2
  # Row labels
  r0: {label: "Q₀"; shape: text; style.font-size: 10}
  r1: {label: "Q₁"; shape: text; style.font-size: 10}
  r2: {label: "Q₂"; shape: text; style.font-size: 10}
  r3: {label: "Q₃"; shape: text; style.font-size: 10}
  r4: {label: "Q₄"; shape: text; style.font-size: 10}
  r5: {label: "Q₅"; shape: text; style.font-size: 10}
  r0 -> r1 -> r2 -> r3 -> r4 -> r5: {style.opacity: 0}
  # Column labels
  c0: {label: "K₀"; shape: text; style.font-size: 10}
  c1: {label: "K₁"; shape: text; style.font-size: 10}
  c2: {label: "K₂"; shape: text; style.font-size: 10}
  c3: {label: "K₃"; shape: text; style.font-size: 10}
  c4: {label: "K₄"; shape: text; style.font-size: 10}
  c5: {label: "K₅"; shape: text; style.font-size: 10}
  c0 -> c1 -> c2 -> c3 -> c4 -> c5: {style.opacity: 0}
  # Matrix grid - Row 0
  m00: {label: "F"; shape: rectangle; style.fill: "#51cf66"; style.stroke: "#2f9e44"; width: 32; height: 32}
  m01: {label: "T"; shape: rectangle; style.fill: "#ff6b6b"; style.stroke: "#c92a2a"; width: 32; height: 32}
