}
# Step 4: Application
step4_container: {
  label: "Step 4: Mask Application in Attention"
  shape: rectangle
  style.stroke: "#4263eb"
  style.stroke-width: 2
  flow: {
    shape: rectangle
    style.fill: "#fff9db"
    label: ""
    scores: {
      label: "Attention Scores\nQ @ Kᵀ / √dₖ"
      shape: rectangle
      style.fill: "#ffe066"
    }
    masked: {
      label: "Masked Scores\nscores.masked_fill(mask, -inf)"
      shape: rectangle
      style.fill: "#ffa94d"
    }
    weights: {
      label: "Attention Weights\nsoftmax(masked_scores)"
      shape: rectangle
      style.fill: "#69db7c"
    }
    output: {
      label: "Output\nweights @ V"
      shape: rectangle
      style.fill: "#74c0fc"
    }
    scores -> masked -> weights -> output: {
      label: ""
      style.stroke: "#1971c2"
      style.stroke-width: 2
    }
  }
}
# Semantic annotations
annotations: {
  label: "Semantic Meaning"
  shape: rectangle
  style.stroke: "#862e9c"
  style.stroke-dash: 3
  ann1: {
    label: "• Diagonal: token attends to itself"
    shape: text
    style.font-size: 11
  }
  ann2: {
    label: "• Lower triangle: token attends to past"
    shape: text
    style.font-size: 11
  }
  ann3: {
    label: "• Upper triangle: FUTURE (blocked)"
    shape: text
    style.font-size: 11
    style.bold: true
  }
  ann4: {
    label: "• Each row i: what position i can see"
    shape: text
    style.font-size: 11
  }
  ann1 -> ann2 -> ann3 -> ann4: {style.opacity: 0}
}
# Flow connections
step1_container -> step2_container -> step3_container: {
  label: ""
  style.stroke: "#1971c2"
  style.stroke-width: 2
}
step3_container -> step4_container: {
  label: ""
  style.stroke: "#1971c2"
  style.stroke-width: 2
}
step4_container -> annotations: {
  label: ""
  style.stroke: "#862e9c"
  style.stroke-dash: 3
}