  m22: {label: "F"; shape: rectangle; style.fill: "#51cf66"; style.stroke: "#2f9e44"; width: 32; height: 32}
  m23: {label: "T"; shape: rectangle; style.fill: "#ff6b6b"; style.stroke: "#c92a2a"; width: 32; height: 32}
  m24: {label: "T"; shape: rectangle; style.fill: "#ff6b6b"; style.stroke: "#c92a2a"; width: 32; height: 32}
  m25: {label: "T"; shape: rectangle; style.fill: "#ff6b6b"; style.stroke: "#c92a2a"; width: 32; height: 32}
  # Row 3
  m30: {label: "F"; shape: rectangle; style.fill: "#51cf66"; style.stroke: "#2f9e44"; width: 32; height: 32}
