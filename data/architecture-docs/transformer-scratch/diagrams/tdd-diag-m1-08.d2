direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 200
    sketch: false
  }
}

title: |md
  # Scaled Dot-Product Attention
  **Module Interface & Tensor Flow Specification**
| {
  near: top-center
  shape: text
}

# --- Module Definition ---
ScaledDotProductAttention: {
  shape: class
  tooltip: "Implementation of Attention(Q, K, V) = softmax(QKᵀ / √d_k)V"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    font: "mono"
  }

  # Fields (Attributes)
  scale: "float64 (1 / sqrt(d_k))"
  dropout_layer: "nn.Dropout"

  # Methods (Interface)
  "__init__(d_k: int, dropout: float = 0.1)": "None"
  "forward(Q, K, V, mask=None)": "(Tensor, Tensor)"
  
  # Internal Details as Nested Metadata
  spec: {
    shape: text
    label: |md
      **Computation Steps:**
      1. MatMul(Q, K.T)
      2. Scale by 1/√d_k
      3. Apply Mask (if provided)
      4. Softmax
      5. Dropout
      6. MatMul(Weights, V)
    |
    style.font-size: 10
  }
}

# --- Input Space ---
inputs: {
  label: "Input Tensors (Rank 3/4)"
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    stroke-width: 2
    bold: true
  }

  Q_input: {
    label: "Query (Q)\nShape: (B, S, d_k)"
    shape: rectangle
    style: {
      font: "mono"
      fill: "#FFE0B2"
    }
  }

  K_input: {
    label: "Key (K)\nShape: (B, S, d_k)"
    shape: rectangle
    style: {
      font: "mono"
      fill: "#FFE0B2"
    }
  }

  V_input: {
    label: "Value (V)\nShape: (B, S, d_v)"
    shape: rectangle
    style: {
      font: "mono"
      fill: "#FFE0B2"
    }
  }

  mask_input: {
    label: "Mask (Optional)\nShape: (B, 1, S) or (B, S, S)"
    shape: rectangle
    style: {
      font: "mono"
      stroke-dash: 4
      fill: "#FFF8E1"
    }
  }
}

# --- Output Space ---
outputs: {
  label: "Output Tensors"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    bold: true
  }

  attention_output: {
    label: "Context Vector (O)\nShape: (B, S, d_v)"
    shape: rectangle
    style: {
      font: "mono"
      fill: "#C8E6C9"
    }
  }

  attention_weights: {
    label: "Attention Matrix (A)\nShape: (B, S, S)"
    shape: rectangle
    style: {
      font: "mono"
      fill: "#C8E6C9"
    }
  }
}

# --- Data Flow Connections ---
inputs.Q_input -> ScaledDotProductAttention: {
  label: "batch_matmul"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

inputs.K_input -> ScaledDotProductAttention: {
  label: "transpose_matmul"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

inputs.V_input -> ScaledDotProductAttention: {
  label: "weighted_sum"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}

inputs.mask_input -> ScaledDotProductAttention: {
  label: "additive_mask"
  style: {
    stroke: "#1565C0"
    stroke-width: 1
    stroke-dash: 3
  }
}

ScaledDotProductAttention -> outputs.attention_output: {
  label: "V_prime"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

ScaledDotProductAttention -> outputs.attention_weights: {
  label: "softmax_scores"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

# --- Legend & Metadata ---
legend: {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-width: 1
    shadow: true
  }

  header: "Implementation Legend" {
    shape: text
    style.bold: true
  }

  rows: {
    grid-rows: 4
    grid-gap: 5
    
    r1: "B: Batch Size" { shape: text }
    r2: "S: Sequence Length" { shape: text }
    r3: "d_k: Key Dimension" { shape: text }
    r4: "d_v: Value Dimension" { shape: text }
  }
}

# Fix: Apply property directly to shape instead of using reserved keyword 'style' in an edge path
# This removes the problematic connection that caused the compiler error.
inputs.style.opacity: 0.9
outputs.style.opacity: 0.9