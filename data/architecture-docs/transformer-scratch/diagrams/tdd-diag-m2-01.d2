direction: right
layout-engine: elk
theme-id: 4
title: Multi-Head Attention Architecture {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
# Input tensor specification
Input: {
  shape: rectangle
  label: "Input Tensor\n[batch, seq_len, d_model]"
  style.fill: "#E3F2FD"
}
# Projection layers container
Projections: {
  label: "Linear Projections"
  style.fill: "#FFF3E0"
  W_Q: {
    label: "W_Q\n(d_model → d_model)"
    shape: rectangle
    style.fill: "#FFCCBC"
  }
  W_K: {
    label: "W_K\n(d_model → d_model)"
    shape: rectangle
    style.fill: "#FFCCBC"
  }
  W_V: {
    label: "W_V\n(d_model → d_model)"
    shape: rectangle
    style.fill: "#FFCCBC"
  }
}
# Split and reshape operations
HeadSplitting: {
  label: "Head Splitting & Reshape"
  style.fill: "#E8F5E9"
  Q_split: {
    label: "Q: view(batch, seq, heads, d_k)\n     .transpose(1,2)\n     → [batch, heads, seq, d_k]"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  K_split: {
    label: "K: view(batch, seq, heads, d_k)\n     .transpose(1,2)\n     → [batch, heads, seq, d_k]"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  V_split: {
    label: "V: view(batch, seq, heads, d_k)\n     .transpose(1,2)\n     → [batch, heads, seq, d_k]"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
}
# Parallel attention heads
AttentionHeads: {
  label: "Parallel Attention Heads"
  style.fill: "#F3E5F5"
  Head_0: {
    label: "Head 0\nScaled Dot-Product\nAttention"
    shape: rectangle
    style.fill: "#E1BEE7"
    Head0_ops: {
      label: "scores = Q₀·K₀ᵀ / √d_k\nattn = softmax(scores)\noutput = attn·V₀"
      shape: code
      language: python
    }
    Head_0 -> Head0_ops
  }
  Head_1: {
    label: "Head 1\nScaled Dot-Product\nAttention"
    shape: rectangle
    style.fill: "#E1BEE7"
    Head1_ops: {
      label: "scores = Q₁·K₁ᵀ / √d_k\nattn = softmax(scores)\noutput = attn·V₁"
      shape: code
      language: python
    }
    Head_1 -> Head1_ops
  }
  Head_h: {
    label: "Head h\nScaled Dot-Product\nAttention"
    shape: rectangle
    style.fill: "#E1BEE7"
    Headh_ops: {
      label: "scores = Qₕ·Kₕᵀ / √d_k\nattn = softmax(scores)\noutput = attn·Vₕ"
      shape: code
      language: python
    }
    Head_h -> Headh_ops
  }
  ellipsis: {
    label: "···"
    shape: text
    style.font-size: 24
  }
}
# Concatenation step
Concatenation: {
  label: "Head Concatenation"
  style.fill: "#E0F7FA"
  Concat_op: {
    label: ".transpose(1, 2)\n.contiguous()\n.view(batch, seq, d_model)\n\n→ [batch, seq_len, d_model]"
    shape: rectangle
    style.fill: "#B2EBF2"
  }
}
# Output projection
OutputProjection: {
  label: "Output Projection"
  style.fill: "#FCE4EC"
  W_O: {
    label: "W_O\n(d_model → d_model)"
    shape: rectangle
    style.fill: "#F8BBD9"
  }
}
# Final output
Output: {
  shape: rectangle
  label: "Output Tensor\n[batch, seq_len, d_model]"
  style.fill: "#E3F2FD"
}
# Main data flow connections (solid arrows = owns)
Input -> Projections.W_Q: {
  label: "X"
}
Input -> Projections.W_K: {
  label: "X"
}
Input -> Projections.W_V: {
  label: "X"
}
Projections.W_Q -> HeadSplitting.Q_split: {
  label: "Q\n[batch,seq,d_model]"
}
Projections.W_K -> HeadSplitting.K_split: {
  label: "K\n[batch,seq,d_model]"
}
Projections.W_V -> HeadSplitting.V_split: {
  label: "V\n[batch,seq,d_model]"
}
HeadSplitting.Q_split -> AttentionHeads.Head_0: { label: "Q₀" }
HeadSplitting.K_split -> AttentionHeads.Head_0: { label: "K₀" }
HeadSplitting.V_split -> AttentionHeads.Head_0: { label: "V₀" }
HeadSplitting.Q_split -> AttentionHeads.Head_1: { label: "Q₁" }
HeadSplitting.K_split -> AttentionHeads.Head_1: { label: "K₁" }
HeadSplitting.V_split -> AttentionHeads.Head_1: { label: "V₁" }
HeadSplitting.Q_split -> AttentionHeads.Head_h: { label: "Qₕ" }
HeadSplitting.K_split -> AttentionHeads.Head_h: { label: "Kₕ" }
HeadSplitting.V_split -> AttentionHeads.Head_h: { label: "Vₕ" }
AttentionHeads.Head_0 -> Concatenation.Concat_op: { label: "[batch,1,seq,d_k]" }
AttentionHeads.Head_1 -> Concatenation.Concat_op: { label: "[batch,1,seq,d_k]" }
AttentionHeads.Head_h -> Concatenation.Concat_op: { label: "[batch,1,seq,d_k]" }
Concatenation.Concat_op -> OutputProjection.W_O: {
  label: "concat\n[batch,seq,d_model]"
}
OutputProjection.W_O -> Output: {
  label: "MHA(x)"
}
# Shape transformation legend
Legend: {
  label: "Tensor Shape Notation"
  style.fill: "#FAFAFA"
  batch: {
    label: "batch    = batch size"
    shape: text
  }
  seq: {
    label: "seq_len  = sequence length"
    shape: text
  }
  d_model: {
    label: "d_model  = model dimension (e.g., 512)"
    shape: text
  }
  heads: {
    label: "heads    = number of attention heads (e.g., 8)"
    shape: text
  }
  d_k: {
    label: "d_k      = d_model / heads (e.g., 64)"
    shape: text
  }
}
# Attention formula box
AttentionFormula: {
  label: "Scaled Dot-Product Attention"
  shape: rectangle
  style.fill: "#FFFDE7"
  formula: {
    label: "Attention(Q,K,V) = softmax(QKᵀ / √dₖ) V"
    shape: text
    style: {
      font-size: 18
      bold: true
    }
  }
}
# Multi-head attention formula
MHAFormula: {
  label: "Multi-Head Attention"
  shape: rectangle
  style.fill: "#FFFDE7"
  formula: {
    label: "MHA(Q,K,V) = Concat(head₁,...,headₕ) W_O\nwhere headᵢ = Attention(QWᵢQ, KWᵢK, VWᵢV)"
    shape: text
    style: {
      font-size: 16
      bold: true
    }
  }
}
# Parameter count specification
Parameters: {
  label: "Parameter Count"
  shape: rectangle
  style.fill: "#ECEFF1"
  params: {
    label: "W_Q: d_model × d_model\nW_K: d_model × d_model\nW_V: d_model × d_model\nW_O: d_model × d_model\n─────────────────────\nTotal: 4 × d_model²"
    shape: code
    language: text
  }
  Parameters -> params
}
# Connection type legend
ConnectionLegend: {
  label: "Connection Types"
  style.fill: "#FAFAFA"
  solid: {
    label: "─────► Data flow (owns)"
    shape: text
  }
  dashed: {
    label: "- - - ► Reference (uses)"
    shape: text
  }
}