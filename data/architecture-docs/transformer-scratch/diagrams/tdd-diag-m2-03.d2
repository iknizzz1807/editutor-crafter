layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

title: {
  label: "Parallel Head Computation\nMulti-Head Attention: Batched vs Sequential"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# ============================================================================
# INCORRECT APPROACH: Sequential Loop (Misconception)
# ============================================================================
incorrect_approach: {
  label: "❌ INCORRECT: Sequential Loop Approach"
  style: {
    fill: "#2d1b1b"
    stroke: "#ff6b6b"
    stroke-width: 3
  }

  header: {
    label: "Misconception: Iterating over heads one at a time"
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#ff6b6b"
    }
  }

  input_seq: {
    label: "Input X\n[batch, seq, d_model]"
    shape: rectangle
    style.fill: "#1a1a2e"
    style.stroke: "#4a4a6a"
  }

  loop_container: {
    label: "for head in range(num_heads):\n    (Repeat 8 times for 8 heads)"
    style: {
      stroke-dash: 4
      fill: "#1a1a1a"
    }
    
    loop_input: {
      label: "X"
      shape: circle
      style.fill: "#2a2a3e"
    }
    
    wq_h: {
      label: "W_Q[head]\n(Unique weights\nper head)"
      shape: diamond
      style.fill: "#3d2b2b"
    }
    wk_h: {
      label: "W_K[head]"
      shape: diamond
      style.fill: "#3d2b2b"
    }
    wv_h: {
      label: "W_V[head]"
      shape: diamond
      style.fill: "#3d2b2b"
    }
    
    q_h: {
      label: "Q_h\n[batch, seq, d_k]"
      shape: rectangle
      style.fill: "#2a2a3e"
    }
    k_h: {
      label: "K_h\n[batch, seq, d_k]"
      shape: rectangle
      style.fill: "#2a2a3e"
    }
    v_h: {
      label: "V_h\n[batch, seq, d_k]"
      shape: rectangle
      style.fill: "#2a2a3e"
    }
    
    attention_h: {
      label: "Attention(Q_h, K_h, V_h)\nsoftmax(QK^T/√d_k)V"
      shape: rectangle
      style: {
        fill: "#4a2b2b"
        stroke: "#ff6b6b"
      }
    }
    
    head_out: {
      label: "head_output\n[batch, seq, d_k]"
      shape: rectangle
      style.fill: "#2a2a3e"
    }
    
    loop_input -> wq_h -> q_h
    loop_input -> wk_h -> k_h
    loop_input -> wv_h -> v_h
    q_h -> attention_h
    k_h -> attention_h
    v_h -> attention_h
    attention_h -> head_out
  }

  accumulator: {
    label: "output += head_output\n(Accumulate results)"
    shape: rectangle
    style.fill: "#3d2b2b"
  }

  seq_output: {
    label: "Final Output\n[batch, seq, d_model]"
    shape: rectangle
    style: {
      fill: "#2a2a3e"
      stroke: "#ff6b6b"
    }
  }

  input_seq -> loop_container.loop_input
  loop_container.head_out -> accumulator
  accumulator -> seq_output

  time_cost: {
    label: "⏱️ Time Complexity: O(num_heads × seq² × d_k)\n⚠️ 8 sequential matmul operations\n⚠️ No GPU parallelization benefit"
    shape: rectangle
    style: {
      fill: "#3d1b1b"
      stroke: "#ff6b6b"
      font-size: 11
    }
  }
}

# ============================================================================
# CORRECT APPROACH: Parallel Batched Computation
# ============================================================================
correct_approach: {
  label: "✅ CORRECT: Parallel Batched Computation"
  style: {
    fill: "#1b2d1b"
    stroke: "#6bff6b"
    stroke-width: 3
  }

  header: {
    label: "Reality: All heads compute in ONE batched operation"
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#6bff6b"
    }
  }

  par_input: {
    label: "Input X\n[batch, seq, d_model]"
    shape: rectangle
    style: {
      fill: "#1a2e1a"
      stroke: "#4a6a4a"
    }
  }

  proj_weights: {
    label: "Combined Projections\nW_Q, W_K, W_V\n[d_model, d_model] each"
    shape: rectangle
    style: {
      fill: "#1a2e1a"
      stroke: "#6bff6b"
    }
  }

  single_proj: {
    label: "Single Linear Projection\nQ = W_Q(X)"
    shape: rectangle
    style: {
      fill: "#2b3d2b"
      stroke: "#6bff6b"
    }
  }

  q_full: "Q\n[batch, seq, d_model]" { shape: rectangle; style.fill: "#1a2e1a" }
  k_full: "K\n[batch, seq, d_model]" { shape: rectangle; style.fill: "#1a2e1a" }
  v_full: "V\n[batch, seq, d_model]" { shape: rectangle; style.fill: "#1a2e1a" }

  par_input -> single_proj
  proj_weights -> single_proj
  single_proj -> q_full
  single_proj -> k_full
  single_proj -> v_full

  reshape_op: {
    label: "🔑 KEY: Reshape for Parallel Heads"
    style: {
      fill: "#1a3a1a"
      stroke: "#6bff6b"
      stroke-width: 2
    }
    
    reshape_label: {
      label: ".view(batch, seq, num_heads, d_k)\n.transpose(1, 2)"
      shape: rectangle
      style: {
        fill: "#0d2d0d"
        font: mono
        stroke: "#6bff6b"
      }
    }
    
    before_shape: {
      label: "Before:\n[batch, seq, d_model]\nd_model = num_heads × d_k"
      shape: rectangle
      style.fill: "#1a2a1a"
    }
    
    arrow: "→" {
      shape: text
      style.font-size: 24
    }
    
    after_shape: {
      label: "After:\n[batch, heads, seq, d_k]\nAll 8 heads visible!"
      shape: rectangle
      style: {
        fill: "#0d3d0d"
        stroke: "#6bff6b"
        bold: true
      }
    }
    before_shape -> arrow -> after_shape
  }

  q_full -> reshape_op
  k_full -> reshape_op
  v_full -> reshape_op

  q_reshaped: {
    label: "Q\n[batch, 8, seq, d_k]\n┌─────────────────┐\n│ Head 0 │ Head 1 │ ...│ Head 7│\n└─────────────────┘"
    shape: rectangle
    style: {
      fill: "#0d3d0d"
      stroke: "#6bff6b"
      font: mono
    }
  }
  k_reshaped: "K\n[batch, 8, seq, d_k]" { shape: rectangle; style: { fill: "#0d3d0d"; stroke: "#6bff6b" } }
  v_reshaped: "V\n[batch, 8, seq, d_k]" { shape: rectangle; style: { fill: "#0d3d0d"; stroke: "#6bff6b" } }

  reshape_op -> q_reshaped
  reshape_op -> k_reshaped
  reshape_op -> v_reshaped

  single_batched: {
    label: "⚡ SINGLE BATCHED OPERATION ⚡\n\nscores = Q @ K.transpose(-2, -1)\n       / sqrt(d_k)\n\nattention = softmax(scores) @ V\n\nComputes ALL 8 heads simultaneously!"
    shape: rectangle
    style: {
      fill: "#0d4d0d"
      stroke: "#6bff6b"
      stroke-width: 4
      bold: true
      font-size: 13
    }
  }

  q_reshaped -> single_batched
  k_reshaped -> single_batched
  v_reshaped -> single_batched

  parallel_out: {
    label: "Multi-Head Output\n[batch, heads, seq, d_k]"
    shape: rectangle
    style: {
      fill: "#0d3d0d"
      stroke: "#6bff6b"
    }
  }

  single_batched -> parallel_out

  concat_op: {
    label: "Concatenate Heads\n.transpose(1, 2)\n.contiguous()\n.view(batch, seq, d_model)"
    shape: rectangle
    style: {
      fill: "#1a3a1a"
      font: mono
    }
  }

  parallel_out -> concat_op

  wo_proj: {
    label: "W_O Projection\n[d_model, d_model]\nMix head information"
    shape: rectangle
    style: {
      fill: "#1a3a1a"
      stroke: "#6bff6b"
    }
  }

  final_output: {
    label: "Final Output\n[batch, seq, d_model]"
    shape: rectangle
    style: {
      fill: "#0d4d0d"
      stroke: "#6bff6b"
      stroke-width: 2
      bold: true
    }
  }

  concat_op -> wo_proj -> final_output

  par_time_cost: {
    label: "⏱️ Time Complexity: O(seq² × d_k)\n✅ Single batched matmul for ALL heads\n✅ Maximum GPU parallelization\n✅ ~8x faster than sequential"
    shape: rectangle
    style: {
      fill: "#1a3d1a"
      stroke: "#6bff6b"
      font-size: 11
    }
  }
}

# ============================================================================
# TENSOR SHAPE FLOW DIAGRAM
# ============================================================================
shape_flow: {
  label: "Tensor Shape Transformation Flow"
  stage1: {
    label: "Stage 1: Input"
    shape: rectangle
    style.fill: "#1a1a2e"
    s1_tensor: "[batch, seq, 512]" { shape: text; style: { font: mono; font-color: "#6b9fff" } }
  }
  stage2: {
    label: "Stage 2: After W_Q/W_K/W_V"
    shape: rectangle
    style.fill: "#1a1a2e"
    s2_tensor: "[batch, seq, 512]" { shape: text; style.font: mono }
  }
  stage3: {
    label: "Stage 3: After .view()"
    shape: rectangle
    style.fill: "#2a1a2e"
    s3_tensor: "[batch, seq, 8, 64]" { shape: text; style.font: mono }
  }
  stage4: {
    label: "Stage 4: After .transpose(1,2)"
    shape: rectangle
    style.fill: "#3a1a2e"
    s4_tensor: "[batch, 8, seq, 64]" { shape: text; style: { font: mono; bold: true } }
  }
  stage5: {
    label: "Stage 5: Attention Output"
    shape: rectangle
    style.fill: "#3a1a2e"
    s5_tensor: "[batch, 8, seq, 64]" { shape: text; style.font: mono }
  }
  stage6: {
    label: "Stage 6: After concat + W_O"
    shape: rectangle
    style.fill: "#1a1a2e"
    s6_tensor: "[batch, seq, 512]" { shape: text; style.font: mono }
  }

  stage1 -> stage2: "Linear\nProjection"
  stage2 -> stage3: ".view()"
  stage3 -> stage4: ".transpose()"
  stage4 -> stage5: "Batched\nAttention"
  stage5 -> stage6: "concat +\nW_O"
}

# ============================================================================
# CODE COMPARISON
# ============================================================================
code_comparison: {
  label: "Implementation Comparison"
  wrong_code: {
    label: "❌ Wrong (Sequential)"
    shape: rectangle
    style: { fill: "#2d1b1b"; font: mono; font-size: 10 }
    code_block: {
      label: "output = 0\nfor h in range(num_heads):\n    Q_h = W_Q[h](x)  # Separate weights!\n    K_h = W_K[h](x)\n    V_h = W_V[h](x)\n    scores = Q_h @ K_h.T / sqrt(d_k)\n    attn = softmax(scores) @ V_h\n    output += attn\n# 8 sequential passes 😢"
      shape: text
      style.font: mono
    }
  }
  correct_code: {
    label: "✅ Correct (Parallel)"
    shape: rectangle
    style: { fill: "#1b2d1b"; font: mono; font-size: 10 }
    code_block: {
      label: "# Single projection for all heads\nQ = W_Q(x).view(b, s, n_h, d_k)\nQ = Q.transpose(1, 2)  # [b, 8, s, 64]\n# Same for K, V...\n\n# ONE operation for ALL heads! 🚀\nscores = Q @ K.transpose(-2, -1) / sqrt(d_k)\nattn = softmax(scores) @ V\n# All 8 heads in parallel!"
      shape: text
      style.font: mono
    }
  }
}

# ============================================================================
# KEY INSIGHT BOX
# ============================================================================
key_insight: {
  label: "💡 KEY INSIGHT: The Magic of Tensor Reshaping"
  shape: rectangle
  style: { fill: "#1a1a3e"; stroke: "#6b9fff"; stroke-width: 2 }
  insight_content: {
    label: "The 'heads' dimension becomes part of the batch dimension through reshaping.\nThis allows a SINGLE matrix multiplication to compute attention for ALL heads.\n\nGPU sees: [batch × heads, seq, d_k] → processes all heads in parallel\n\nThe model 'thinks' it has 8 separate attention heads.\nThe implementation computes them as one big batched operation.\nThis is why transformers are so efficient on GPUs!"
    shape: text
    style.font-size: 12
  }
}

# ============================================================================
# MEMORY LAYOUT VISUALIZATION
# ============================================================================
memory_layout: {
  label: "Memory Layout: Why contiguous() is Required"
  
  before_transpose: {
    label: "Before .transpose(1, 2)"
    style.fill: "#1a1a2e"
    layout1: {
      label: "Memory: [b0_s0_d0, b0_s0_d1, ..., b0_s1_d0, ...]\nStride: [512, 1] - Sequential"
      shape: text
      style: { font: mono; font-size: 10 }
    }
  }
  
  after_transpose: {
    label: "After .transpose(1, 2)"
    style.fill: "#2a1a3e"
    layout2: {
      label: "Memory: [b0_h0_s0_d0, b0_h1_s0_d0, ...]\nStride: [64, 512, 1] - NON-contiguous!"
      shape: text
      style: { font: mono; font-size: 10 }
    }
  }
  
  after_contiguous: {
    label: "After .contiguous()"
    style.fill: "#1a2a1a"
    layout3: {
      label: "Memory: [b0_h0_s0_d0, b0_h0_s0_d1, ...]\nStride: [512, 64, 1] - Re-ordered"
      shape: text
      style: { font: mono; font-size: 10 }
    }
  }

  before_transpose -> after_transpose: "transpose\n(swaps dims)"
  after_transpose -> after_contiguous: "contiguous()\n(copies memory)"

  note: {
    label: "⚠️ .view() requires contiguous memory. After transpose, must call\n.contiguous() before .view() to avoid runtime errors."
    shape: text
    style: { font-size: 10; italic: true }
  }
}

# Global Positioning Connections
incorrect_approach -> correct_approach: {
  label: "                Instead of this...\n                ...do this!\n                "
  style: { stroke: "#ffffff"; stroke-width: 2; stroke-dash: 4 }
}

correct_approach -> shape_flow
shape_flow -> code_comparison
code_comparison -> key_insight
key_insight -> memory_layout