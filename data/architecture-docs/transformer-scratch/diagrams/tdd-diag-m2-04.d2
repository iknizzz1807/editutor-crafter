direction: right
layout-engine: elk
theme-id: 4

title: Head Concatenation Flow {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: Multi-Head Attention Output Merge {
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# Step containers
step1: {
  label: "Step 1: Transpose"
  style.fill: "#E8F5E9"
  op: {
    shape: code
    label: "x.transpose(1, 2)"
  }
  before: {
    label: "Before"
    shape: rectangle
    style.fill: "#FFF3E0"
    shape_before: {
      label: "[batch, heads, seq, d_k]"
      shape: rectangle
      style: {
        fill: "#FFCCBC"
        bold: true
        stroke: "#E64A19"
        stroke-width: 2
      }
    }
    dim_before: {
      shape: rectangle
      style.fill: "#FAFAFA"
      label: |
        batch = B
        heads = H
        seq = S
        d_k = D/H
      |
    }
  }
  after: {
    label: "After"
    shape: rectangle
    style.fill: "#E3F2FD"
    shape_after: {
      label: "[batch, seq, heads, d_k]"
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        bold: true
        stroke: "#1976D2"
        stroke-width: 2
      }
    }
    dim_after: {
      shape: rectangle
      style.fill: "#FAFAFA"
      label: |
        batch = B
        seq = S
        heads = H
        d_k = D/H
      |
    }
  }
  before -> after: {
    label: "swap dims 1вҶ”2"
    style.stroke: "#1976D2"
    style.stroke-dash: 4
  }
}

step2: {
  label: "Step 2: Contiguous"
  style.fill: "#FFF8E1"
  op: {
    shape: code
    label: "x.contiguous()"
  }
  before: {
    label: "Before"
    shape: rectangle
    style.fill: "#FFECB3"
    mem_before: {
      shape: rectangle
      style: {
        fill: "#FFE082"
        italic: true
      }
      label: |
        Non-contiguous Memory
        Strides: [S*H*d_k, d_k, H*d_k, 1]
        Memory scattered across
        transposed layout
      |
    }
  }
  after: {
    label: "After"
    shape: rectangle
    style.fill: "#DCEDC8"
    mem_after: {
      shape: rectangle
      style: {
        fill: "#C5E1A5"
        bold: true
      }
      label: |
        Contiguous Memory
        Strides: [H*S*d_k, H*d_k, d_k, 1]
        Memory laid out sequentially
        for view() operation
      |
    }
  }
  before -> after: {
    label: "reorder memory"
    style.stroke: "#689F38"
    style.stroke-dash: 4
  }
}

step3: {
  label: "Step 3: View (Reshape)"
  style.fill: "#F3E5F5"
  op: {
    shape: code
    label: "x.view(batch, seq, d_model)"
  }
  before: {
    label: "Before"
    shape: rectangle
    style.fill: "#E1BEE7"
    shape_before: {
      label: "[batch, seq, heads, d_k]"
      shape: rectangle
      style.fill: "#CE93D8"
    }
    breakdown: {
      shape: rectangle
      style.fill: "#FAFAFA"
      label: |
        heads Г— d_k = H Г— (D/H)
        = D = d_model
      |
    }
  }
  after: {
    label: "After"
    shape: rectangle
    style.fill: "#C8E6C9"
    shape_after: {
      label: "[batch, seq, d_model]"
      shape: rectangle
      style: {
        fill: "#4CAF50"
        font-color: white
        bold: true
        stroke: "#2E7D32"
        stroke-width: 3
      }
    }
    dim_final: {
      shape: rectangle
      style.fill: "#FAFAFA"
      label: |
        batch = B
        seq = S
        d_model = D (merged)
      |
    }
  }
  before -> after: {
    label: "merge last 2 dims"
    style.stroke: "#2E7D32"
    style.stroke-dash: 4
  }
}

# Flow connections
step1 -> step2 -> step3: {
  style.stroke: "#424242"
  style.stroke-width: 3
}

# Example values box
example: {
  label: "Example Dimensions"
  shape: rectangle
  style.fill: "#ECEFF1"
  values: {
    shape: code
    label: |
      batch = 4
      seq = 128
      heads = 8
      d_k = 64
      d_model = 512 (8 Г— 64)
      Input:  [4, 8, 128, 64]
      Output: [4, 128, 512]
    |
  }
}

# Memory layout visualization
memory_layout: {
  label: "Memory Layout Transformation"
  shape: rectangle
  style.fill: "#FAFAFA"
  before_layout: {
    label: "Before contiguous()"
    shape: rectangle
    style.fill: "#FFCDD2"
    cells: {
      shape: rectangle
      style.fill: "#EF9A9A"
      label: |
        в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ
        в”Ӯh0 в”Ӯh1 в”Ӯh2 в”Ӯh3 в”Ӯ (scattered)
        в”Ӯd0 в”Ӯd0 в”Ӯd0 в”Ӯd0 в”Ӯ
        в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
      |
    }
  }
  after_layout: {
    label: "After contiguous()"
    shape: rectangle
    style.fill: "#C8E6C9"
    cells: {
      shape: rectangle
      style.fill: "#81C784"
      label: |
        в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
        в”Ӯ h0 h1 h2 h3 ... в”Ӯ (sequential)
        в”Ӯ d0 d0 d0 d0     в”Ӯ
        в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
      |
    }
  }
  before_layout -> after_layout: "reorder"
}

# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke-dash: 3
  changed: {
    label: "Changed dimension"
    shape: rectangle
    style: {
      fill: "#FFCCBC"
      bold: true
    }
  }
  final: {
    label: "Final output"
    shape: rectangle
    style: {
      fill: "#4CAF50"
      font-color: white
    }
  }
}

# Positioning
example -> memory_layout
legend -> step1