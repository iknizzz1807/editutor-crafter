direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Contiguous Memory Layout Issue: Why contiguous() is Required After transpose() Before view()"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Original Tensor
original: {
  label: "Original Tensor x"
  shape: rectangle
  style.fill: "#E8F5E9"
  
  header: {
    label: "x.shape = [2, 4, 8, 16]\n[batch, heads, seq, d_k]"
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  
  strides_label: {
    label: "Strides: [512, 128, 16, 1]"
    shape: text
    style.font-size: 14
    style.bold: true
  }
  
  contiguous_badge: {
    label: "is_contiguous() = TRUE"
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: white
    style.bold: true
  }
  
  memory_layout: {
    label: "Physical Memory Layout (Row-Major Order)"
    shape: rectangle
    style.fill: "#FAFAFA"
    row0: { label: "[0,0,0,0] → [0,0,0,15] (offsets 0-15)"; shape: text; style.font: mono }
    row1: { label: "[0,0,1,0] → [0,0,1,15] (offsets 16-31)"; shape: text; style.font: mono }
    dots1: { label: "..."; shape: text }
    row7: { label: "[0,0,7,0] → [0,0,7,15] (offsets 112-127)"; shape: text; style.font: mono }
    div1: { label: "━━━ head 0 complete (128 units) ━━━"; shape: text; style.font-color: "#666" }
    row8: { label: "[0,1,0,0] → [0,1,0,15] (offsets 128-143)"; shape: text; style.font: mono }
    dots2: { label: "..."; shape: text }
    row15: { label: "[0,1,7,0] → [0,1,7,15] (offsets 240-255)"; shape: text; style.font: mono }
    div2: { label: "━━━ head 1 complete ━━━"; shape: text; style.font-color: "#666" }
    dots3: { label: "... (heads 2, 3) ..."; shape: text }
    row_end: { label: "[0,3,7,0] → [0,3,7,15] (offset 511)"; shape: text; style.font: mono }
    div3: { label: "━━━ batch 0 complete (512 units) ━━━"; shape: text; style.font-color: "#666" }
  }
  
  stride_visual: {
    label: "Stride Calculation\n──────────────────\nstride[0] = 4 × 8 × 16 = 512\nstride[1] = 8 × 16 = 128\nstride[2] = 16\nstride[3] = 1"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.font: mono
  }
}

# Middle transformation
arrow_transpose: {
  label: "x.transpose(1, 2)\nSwap dim 1 ↔ dim 2"
  shape: text
  style.font-size: 16
  style.bold: true
}

original -> arrow_transpose
arrow_transpose -> transposed

# Transposed Tensor (Non-contiguous)
transposed: {
  label: "Transposed Tensor y"
  shape: rectangle
  style.fill: "#FFEBEE"
  
  header: {
    label: "y.shape = [2, 8, 4, 16]\n[batch, seq, heads, d_k]"
    shape: rectangle
    style.fill: "#FFCDD2"
  }
  
  strides_label: {
    label: "Strides: [512, 16, 128, 1]\n⚠️ STRIDES NOT DESCENDING!"
    shape: text
    style.font-size: 14
    style.bold: true
    style.font-color: "#C62828"
  }
  
  contiguous_badge: {
    label: "is_contiguous() = FALSE"
    shape: rectangle
    style.fill: "#F44336"
    style.font-color: white
    style.bold: true
  }
  
  memory_layout: {
    label: "Zero-Copy View: Scattered Logical Access"
    shape: rectangle
    style.fill: "#FAFAFA"
    note: {
      label: "Metadata update only!\nPhysical layout is still the original order."
      shape: rectangle
      style.fill: "#FFECB3"
      style.font-size: 12
    }
    elem0: { label: "Logical [0,0,0,0] @ physical offset 0"; shape: text; style.font: mono }
    elem1: { label: "Logical [0,0,1,0] @ physical offset 128"; shape: text; style.font: mono; style.font-color: "#C62828"; style.bold: true }
    elem2: { label: "Logical [0,0,2,0] @ physical offset 256"; shape: text; style.font: mono; style.font-color: "#C62828"; style.bold: true }
    elem3: { label: "Logical [0,0,3,0] @ physical offset 384"; shape: text; style.font: mono; style.font-color: "#C62828"; style.bold: true }
    div: { label: "━━━ seq position 0 done ━━━"; shape: text; style.font-color: "#666" }
    elem4: { label: "Logical [0,1,0,0] @ physical offset 16"; shape: text; style.font: mono; style.font-color: "#1565C0"; style.bold: true }
    dots: { label: "... non-linear jumps in memory ..."; shape: text; style.italic: true }
  }
  
  stride_visual: {
    label: "Logical Stride Violation\n──────────────────\nstride[0] = 512\nstride[1] = 16  (was 128)\nstride[2] = 128 (was 16)\nstride[3] = 1\n\nValidation: 512 > 16 < 128 ❌"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.font: mono
    style.stroke: "#C62828"
  }
}

# Why view() fails
view_fails: {
  label: "Runtime Error: Why view() FAILS"
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-width: 3
  
  explanation: {
    label: "y.view(2, 4, 128)  # RuntimeError\n\nview() assumes the underlying memory\nis contiguous so it can simply\nre-divide the flat buffer.\n\nSince strides are not monotonic,\ncontiguous pointers can't be calculated."
    shape: text
    style.font: mono
    style.font-size: 12
  }
  
  memory_attempt: {
    label: "Memory Logic Conflict"
    shape: rectangle
    style.fill: "#FAFAFA"
    expected: {
      label: "view() expects offsets:\n[0, 1, 2, 3, 4, 5...]"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.font: mono
    }
    actual: {
      label: "y has offsets:\n[0, 128, 256, 384, 16...]"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.font: mono
    }
    expected -> actual: "MISMATCH" {
      style.stroke: "#C62828"
      style.stroke-width: 2
      style.stroke-dash: 4
    }
  }
}

transposed -> view_fails: "Attempt view()" {
  style.stroke: "#C62828"
  style.stroke-width: 2
  style.stroke-dash: 4
}

# The Fix with contiguous()
fix_section: {
  label: "The Resolution: contiguous()"
  shape: rectangle
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.stroke-width: 3
  
  code: {
    label: "y_contig = y.contiguous()\ny_contig.view(2, 4, 128)  ✅"
    shape: rectangle
    style.fill: "#BBDEFB"
    style.font: mono
    style.bold: true
  }
  
  explanation: {
    label: "contiguous() allocates a NEW memory buffer\nand COPIES elements so they appear\nsequentially in the new logical order."
    shape: text
    style.font-size: 13
  }
  
  new_strides: {
    label: "New Valid Strides: [1024, 128, 32, 1]\n(Depends on new logical shape)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font: mono
  }
  
  memory_copy: {
    label: "Memory Defragmentation / Rearrangement"
    shape: rectangle
    style.fill: "#FAFAFA"
    before: {
      label: "Scattered in y:\noffsets: 0, 128, 256, 384, 16"
      shape: rectangle
      style.fill: "#FFCDD2"
      style.font: mono
    }
    after: {
      label: "Sequenced in y_contig:\noffsets: 0, 1, 2, 3, 4"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.font: mono
    }
    before -> after: "reallocate & copy" {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
  }
}

transposed -> fix_section: "Invoke .contiguous()" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}

# Key insight box
key_insight: {
  label: "💡 System Designer Insight"
  shape: rectangle
  style.fill: "#FFF9C4"
  style.stroke: "#F9A825"
  style.stroke-width: 2
  
  content: {
    label: "transpose() is O(1) time/space (Zero-Copy).\ncontiguous() is O(N) time/space (Physical Copy).\n\nview() is O(1) and requires the physical buffer\nto match the logical dimension jumps.\n\nUse reshape() to automatically handle\ncontiguous() if needed, but it may hide\nunintentional memory copies."
    shape: text
    style.font-size: 14
  }
}

# Visual stride comparison
stride_comparison: {
  label: "Stride State Transitions"
  shape: rectangle
  style.fill: "#FAFAFA"
  
  original_strides: {
    label: "Initial (Contiguous)\n──────────────────\nShape: [2, 4, 8, 16]\nStrides: [512, 128, 16, 1]\nOrder: Monotonic ✅"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font: mono
  }
  
  transposed_strides: {
    label: "Post-Transpose (Fragmented)\n──────────────────\nShape: [2, 8, 4, 16]\nStrides: [512, 16, 128, 1]\nOrder: 16 < 128 ❌"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.font: mono
  }
  
  contiguous_strides: {
    label: "Post-Contiguous (Restored)\n──────────────────\nShape: [2, 8, 4, 16]\nStrides: [512, 64, 16, 1]\nOrder: Monotonic ✅"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.font: mono
  }
  
  original_strides -> transposed_strides: "Swap Metadata" {
    style.stroke: "#F44336"
  }
  transposed_strides -> contiguous_strides: "Physical Re-layout" {
    style.stroke: "#4CAF50"
  }
}

# Explicit Layout Helpers
original.stride_visual -> stride_comparison.original_strides: { style.stroke: transparent }
key_insight -> fix_section: { style.stroke: transparent }