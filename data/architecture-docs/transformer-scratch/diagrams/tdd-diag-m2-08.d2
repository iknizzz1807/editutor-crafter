vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 200
  }
}

direction: right

# MultiHeadAttention Module Logic Container
# Encapsulates logic, state, and interfaces for the MHA block
# sizeof = 4,194,304 bytes (4MB) for weights only in fp32
MultiHeadAttention: {
  label: "MultiHeadAttention Module\nsizeof = ~1.05M parameters (d_model=512)"
  
  style: {
    fill: "#1a1f36"
    stroke: "#4f46e5"
    stroke-width: 4
    font-color: "#e2e8f0"
    shadow: true
    border-radius: 10
  }

  # Internal State & Parameters
  # These represent the learnable weights stored in GPU memory
  Parameters: {
    shape: class
    label: "Module State (Learnable Parameters)\nMemory Footprint: 4.19MB (fp32)"
    style: {
      fill: "#1e293b"
      stroke: "#6366f1"
      font-color: "#f1f5f9"
    }
    
    # Internal Hyperparameters
    "d_model": "int = 512 | Model Dimension"
    "num_heads": "int = 8 | Parallel Attention Heads"
    "d_k": "int = 64 | Head Dimension (d_model/h)"
    "scale": "float = 0.125 | Softmax scaling (1/sqrt(d_k))"
    
    # Learnable Weights with parameter counts and byte sizes
    "W_Q": "Linear(512, 512) | 262,144 params | 1,048,576 bytes"
    "W_K": "Linear(512, 512) | 262,144 params | 1,048,576 bytes"
    "W_V": "Linear(512, 512) | 262,144 params | 1,048,576 bytes"
    "W_O": "Linear(512, 512) | 262,144 params | 1,048,576 bytes"
    "dropout": "nn.Dropout(p=0.1) | Regularization"
  }

  # Public and Private Methods
  # Defines the functional API for the module
  Interface: {
    shape: class
    label: "Module Interface (Functional API)"
    style: {
      fill: "#1e293b"
      stroke: "#6366f1"
      font-color: "#f1f5f9"
    }
    
    "__init__(d_model, h, dropout)": "Constructor: Allocates Tensors"
    "forward(q, k, v, mask)": "Tuple[Output, AttentionWeights]"
    "- _init_weights()": "Private: Xavier Initialization"
    "- _split_heads(x)": "Private: View Transpose [B, L, D] -> [B, H, L, D_k]"
  }
}

# Initialization logic - Strategy implementation
# Enforces numerical stability via Glorot initialization
WeightInit: {
  shape: class
  label: "Weight Initialization Strategy"
  style: {
    fill: "#064e3b"
    stroke: "#059669"
    font-color: "#ecfdf5"
    stroke-dash: 0
  }
  
  "Init Method": "Xavier Uniform (Glorot)"
  "Gain": "nn.init.calculate_gain('relu')"
  "Distribution": "Uniform(-a, a) | a = sqrt(6/in+out)"
  "Target": "Apply to self.W_*.weight"
}

# Input Tensor Specification - Engineering Schema
# Defined by the Activation Map Layout
InputTensors: {
  shape: class
  label: "Input Tensors (fp32 Activations)"
  style: {
    fill: "#2e1065"
    stroke: "#7c3aed"
    font-color: "#f5f3ff"
  }
  
  "query": "float32[Batch, L_q, 512] | Query Vector"
  "key": "float32[Batch, L_k, 512] | Key Vector"
  "value": "float32[Batch, L_v, 512] | Value Vector"
  "mask": "Optional[bool][Batch, 1, L_q, L_k] | Padding/Causal Mask"
}

# Output Tensor Specification - Resultant activations
OutputTensors: {
  shape: class
  label: "Output Tensors (Resultant Maps)"
  style: {
    fill: "#450a0a"
    stroke: "#dc2626"
    font-color: "#fef2f2"
  }
  
  "output": "float32[Batch, L_q, 512] | Contextualized Projection"
  "attention": "float32[Batch, 8, L_q, L_k] | Computed Weights"
}

# -----------------------------------------------------------------------------
# Call Sequence and Dependency Relations
# -----------------------------------------------------------------------------

# Primary Data Flow: Input Activations to Module Interface
InputTensors -> MultiHeadAttention.Interface: {
  label: "forward(q, k, v, mask)"
  style: {
    stroke-dash: 3
    stroke: "#7c3aed"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}

# Resultant Data Flow: Interface return values
MultiHeadAttention.Interface -> OutputTensors: {
  label: "returns (Y, Attn)"
  style: {
    stroke-dash: 3
    stroke: "#dc2626"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}

# Structural Dependency: Initialization on Object Creation
MultiHeadAttention.Interface -> WeightInit: {
  label: "invokes on __init__"
  style: {
    stroke-dash: 5
    stroke: "#059669"
  }
}

# Internal Parameter Access: Interface utilizes Parameter state
MultiHeadAttention.Interface -> MultiHeadAttention.Parameters: "Read/Write Weights" {
  style.stroke: "#6366f1"
  style.stroke-dash: 2
}

# -----------------------------------------------------------------------------
# Metadata and Annotations
# -----------------------------------------------------------------------------

title: {
  label: "MultiHeadAttention Module Interface\n(Transformer Implementation Spec: Milestone 2)"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
    font-color: "#f8fafc"
  }
}

legend: {
  label: |md
    ### Tensor Dimensions & Constraints
    - **Batch (B)**: Number of concurrent samples in a GPU batch
    - **L_q, L_k, L_v**: Sequence lengths for temporal dimension
    - **d_model**: Hidden dimension (512) - must be divisible by `num_heads`
    - **d_k**: Scaled head dimension (d_model / 8 = 64)
    - **Memory**: fp32 = 4 bytes per element
  |
  shape: text
  style: {
    font-size: 14
    font-color: "#94a3b8"
    border-radius: 8
    stroke: "#334155"
    fill: "#0f172a"
  }
}

# Layout Positioning
title.near: top-center

# FIX: Changed 'near: MultiHeadAttention' to constant 'bottom-right' for ELK compatibility
legend.near: bottom-right