direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  d_model: "512"
  d_ff: "2048"
  batch_seq: "[batch, seq_len]"
  expansion_ratio: "4×"
}

# --- DOCUMENT METADATA ---
title: {
  label: "Position-Wise Feed-Forward Network (FFN)"
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}
subtitle: {
  label: "Two-layer MLP with 4× expansion, GELU activation, and dropout regularization"
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# --- MAIN ARCHITECTURE FLOW ---
ffn_flow: {
  label: "Computational Pipeline"
  
  input: {
    label: "Input Tensor (X)"
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
    input_shape: {
      label: "${batch_seq}, ${d_model}"
      shape: text
      style: {
        font-size: 12
        font: mono
      }
    }
    tooltip: "Shape: [B, S, 512]"
  }

  w1: {
    label: "W₁: Linear Layer\n(Expansion)"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
    w1_params: {
      label: "in=${d_model}\nout=${d_ff}"
      shape: text
      style: {
        font-size: 11
        font: mono
      }
    }
    w1_weights: {
      label: "Weights: [${d_model}, ${d_ff}]"
      shape: text
      style: {
        font-size: 10
        font: mono
      }
    }
  }

  intermediate: {
    label: "Expanded State"
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    inter_shape: {
      label: "${batch_seq}, ${d_ff}"
      shape: text
      style: {
        font-size: 12
        font: mono
      }
    }
  }

  gelu: {
    label: "GELU"
    shape: diamond
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
    }
    gelu_formula: {
      label: "0.5x(1 + erf(x/√2))"
      shape: text
      style: {
        font-size: 9
        font: mono
      }
    }
  }

  dropout: {
    label: "Dropout"
    shape: hexagon
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
      stroke-width: 2
    }
    dropout_rate: {
      label: "p=0.1"
      shape: text
      style: {
        font-size: 11
        font: mono
      }
    }
  }

  w2: {
    label: "W₂: Linear Layer\n(Projection)"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
    w2_params: {
      label: "in=${d_ff}\nout=${d_model}"
      shape: text
      style: {
        font-size: 11
        font: mono
      }
    }
    w2_weights: {
      label: "Weights: [${d_ff}, ${d_model}]"
      shape: text
      style: {
        font-size: 10
        font: mono
      }
    }
  }

  output: {
    label: "Output Tensor (Y)"
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
    output_shape: {
      label: "${batch_seq}, ${d_model}"
      shape: text
      style: {
        font-size: 12
        font: mono
      }
    }
  }

  # --- Sequence of Operations ---
  input -> w1: "x" {
    style.stroke: "#1976D2"
    style.stroke-width: 2
  }
  w1 -> intermediate: "xW₁ᵀ + b₁" {
    style.stroke: "#F57C00"
    style.stroke-width: 2
  }
  intermediate -> gelu: "z" {
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
  }
  gelu -> dropout: "GELU(z)" {
    style.stroke: "#388E3C"
    style.stroke-width: 2
  }
  dropout -> w2: "dropout(g)" {
    style.stroke: "#D32F2F"
    style.stroke-width: 2
  }
  w2 -> output: "y = g'W₂ᵀ + b₂" {
    style.stroke: "#F57C00"
    style.stroke-width: 2
  }
}

# --- TECHNICAL PANELS ---

dimensions_panel: {
  label: "Dimension Flow Transformation"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  dim_flow: {
    label: "${d_model} → ${d_ff} → ${d_model}"
    shape: text
    style: {
      font-size: 16
      bold: true
      font: mono
    }
  }
  expansion_label: {
    label: "↑ ${expansion_ratio} Expansion | ↓ ${expansion_ratio} Projection"
    shape: text
    style.font-size: 12
  }
}

impl_panel: {
  label: "Object Interface"
  PositionWiseFFN: {
    shape: class
    d_model: int = 512
    d_ff: int = 2048
    dropout_p: float = 0.1
    "+ forward(x: Tensor): Tensor"
  }
}

position_wise: {
  label: "Mathematical Invariants"
  shape: rectangle
  style: {
    fill: "#E0F7FA"
    stroke: "#00838F"
  }
  pw_desc: {
    label: "FFN(x) = max(0, xW₁ + b₁)W₂ + b₂\n(Note: GELU used in modern variants)\nApplied point-wise to each sequence position i."
    shape: text
    style.font-size: 11
  }
}

legend: {
  label: "Legend"
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
  }
  l1: "■ Linear Layer (Learnable)" { shape: text; style.font-size: 10 }
  l2: "◆ Non-linear Activation" { shape: text; style.font-size: 10 }
  l3: "⬡ Regularization Layer" { shape: text; style.font-size: 10 }
  l4: "■ Data Tensor" { shape: text; style.font-size: 10 }
}

# --- LAYOUT HINTS ---
title -> subtitle
subtitle -> ffn_flow

ffn_flow -> dimensions_panel
ffn_flow -> impl_panel
ffn_flow -> position_wise
ffn_flow -> legend