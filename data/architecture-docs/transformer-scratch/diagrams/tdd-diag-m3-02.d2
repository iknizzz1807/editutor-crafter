direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  d_model: "512"
  d_ff: "2048"
  expansion: "4×"
  seq_len: "T"
  batch: "B"
}

title: {
  label: "FFN Per-Position Processing Architecture"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# ==========================================
# CLASSES & STYLES
# ==========================================
classes: {
  class_dim: {
    style: {
      font-size: 11
      fill: transparent
      stroke: transparent
      italic: true
    }
  }
  class_tensor: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      font-size: 12
      shadow: true
    }
  }
  class_op: {
    shape: hexagon
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      font-size: 11
    }
  }
  class_weight: {
    shape: cylinder
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      font-size: 11
    }
  }
}

# ==========================================
# INPUT SECTION
# ==========================================
input_section: {
  label: "Input Context"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
  }
  input_tensor: {
    label: "Input Tensor\nX"
    class: class_tensor
    width: 120
    height: 80
  }
  input_dims: {
    label: "[B, T, d_model]\n[${batch}, ${seq_len}, ${d_model}]"
    class: class_dim
    label.near: bottom-center
  }
}

# ==========================================
# POSITION SPLIT
# ==========================================
position_split: {
  label: "Position Decomposition"
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
  }
  split_node: {
    label: "Split by\nPosition"
    shape: diamond
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  # Position nodes
  pos_0: {
    label: "Position 0\nx₀"
    class: class_tensor
    width: 80
    height: 50
    style.fill: "#E3F2FD"
  }
  pos_1: {
    label: "Position 1\nx₁"
    class: class_tensor
    width: 80
    height: 50
    style.fill: "#E8F5E9"
  }
  pos_2: {
    label: "Position 2\nx₂"
    class: class_tensor
    width: 80
    height: 50
    style.fill: "#FFF3E0"
  }
  pos_more: {
    label: "..."
    shape: text
    style.font-size: 24
  }
  pos_t: {
    label: "Position T-1\nxT₋₁"
    class: class_tensor
    width: 80
    height: 50
    style.fill: "#FCE4EC"
  }
  
  pos_dim_label: {
    label: "[B, 1, d_model] each"
    class: class_dim
    label.near: bottom-right
  }

  split_node -> pos_0: {style.stroke-dash: 3}
  split_node -> pos_1: {style.stroke-dash: 3}
  split_node -> pos_2: {style.stroke-dash: 3}
  split_node -> pos_more: {style.stroke-dash: 3}
  split_node -> pos_t: {style.stroke-dash: 3}
}

# ==========================================
# PARALLEL FFN LANES
# ==========================================
parallel_section: {
  label: "Parallel FFN Computation (Point-wise Feed Forward)"
  style: {
    fill: "#FFFDE7"
    stroke: "#F9A825"
    stroke-width: 2
  }

  lane_0: {
    label: "FFN Lane 0"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    w1_0: {label: "W₁·x₀ + b₁"; class: class_op; width: 100}
    gelu_0: {
      label: "GELU\n(z₁₀)"
      shape: circle
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    w2_0: {label: "W₂·z₁₀ + b₂"; class: class_op; width: 100}
    out_0: {label: "y₀"; class: class_tensor; width: 60; height: 40}
    w1_0 -> gelu_0 -> w2_0 -> out_0
  }

  lane_1: {
    label: "FFN Lane 1"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    w1_1: {label: "W₁·x₁ + b₁"; class: class_op; width: 100}
    gelu_1: {
      label: "GELU\n(z₁₁)"
      shape: circle
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    w2_1: {label: "W₂·z₁₁ + b₂"; class: class_op; width: 100}
    out_1: {label: "y₁"; class: class_tensor; width: 60; height: 40}
    w1_1 -> gelu_1 -> w2_1 -> out_1
  }

  lane_2: {
    label: "FFN Lane 2"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    w1_2: {label: "W₁·x₂ + b₁"; class: class_op; width: 100}
    gelu_2: {
      label: "GELU\n(z₁₂)"
      shape: circle
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    w2_2: {label: "W₂·z₁₂ + b₂"; class: class_op; width: 100}
    out_2: {label: "y₂"; class: class_tensor; width: 60; height: 40}
    w1_2 -> gelu_2 -> w2_2 -> out_2
  }

  lane_more: {
    label: "..."
    shape: text
    style.font-size: 28
  }

  lane_t: {
    label: "FFN Lane T-1"
    style.fill: "#FCE4EC"
    style.stroke: "#AD1457"
    w1_t: {label: "W₁·xT₋₁ + b₁"; class: class_op; width: 100}
    gelu_t: {
      label: "GELU\n(z₁T₋₁)"
      shape: circle
      style: {
        fill: "#FFEBEE"
        stroke: "#C62828"
        stroke-width: 2
      }
    }
    w2_t: {label: "W₂·z₁T₋₁ + b₂"; class: class_op; width: 100}
    out_t: {label: "yT₋₁"; class: class_tensor; width: 60; height: 40}
    w1_t -> gelu_t -> w2_t -> out_t
  }
}

# ==========================================
# SHARED WEIGHTS SECTION
# ==========================================
weights_section: {
  label: "Shared Parameters (Constant Across Positions)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-dash: 4
  }
  W1: {
    label: "W₁\n[d_ff, d_model]\n[${d_ff}, ${d_model}]"
    class: class_weight
  }
  b1: {
    label: "b₁\n[d_ff]\n[${d_ff}]"
    class: class_weight
    width: 80
  }
  W2: {
    label: "W₂\n[d_model, d_ff]\n[${d_model}, ${d_ff}]"
    class: class_weight
  }
  b2: {
    label: "b₂\n[d_model]\n[${d_model}]"
    class: class_weight
    width: 80
  }
}

# ==========================================
# OUTPUT SECTION
# ==========================================
output_section: {
  label: "Output Reconstruction"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
  }
  merge_node: {
    label: "Concat\nPositions"
    shape: diamond
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  output_tensor: {
    label: "Output Tensor\nY = FFN(X)"
    class: class_tensor
    width: 120
    height: 80
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }
  output_dims: {
    label: "[B, T, d_model]\n[${batch}, ${seq_len}, ${d_model}]"
    class: class_dim
    label.near: bottom-center
  }
  merge_node -> output_tensor
}

# ==========================================
# CONNECTIONS
# ==========================================
input_section.input_tensor -> position_split.split_node: "Decompose by Position" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}

position_split.pos_0 -> parallel_section.lane_0.w1_0: {style.stroke: "#1565C0"; style.stroke-width: 2}
position_split.pos_1 -> parallel_section.lane_1.w1_1: {style.stroke: "#2E7D32"; style.stroke-width: 2}
position_split.pos_2 -> parallel_section.lane_2.w1_2: {style.stroke: "#E65100"; style.stroke-width: 2}
position_split.pos_t -> parallel_section.lane_t.w1_t: {style.stroke: "#AD1457"; style.stroke-width: 2}

# Parameter sharing connections
weights_section.W1 -> parallel_section.lane_0.w1_0: {style.stroke-dash: 5; style.stroke: "#7B1FA2"}
weights_section.W1 -> parallel_section.lane_1.w1_1: {style.stroke-dash: 5; style.stroke: "#7B1FA2"}
weights_section.W1 -> parallel_section.lane_t.w1_t: {style.stroke-dash: 5; style.stroke: "#7B1FA2"}

weights_section.W2 -> parallel_section.lane_0.w2_0: {style.stroke-dash: 5; style.stroke: "#9C27B0"}
weights_section.W2 -> parallel_section.lane_1.w2_1: {style.stroke-dash: 5; style.stroke: "#9C27B0"}
weights_section.W2 -> parallel_section.lane_t.w2_t: {style.stroke-dash: 5; style.stroke: "#9C27B0"}

# Collector connections
parallel_section.lane_0.out_0 -> output_section.merge_node: {style.stroke: "#1565C0"; style.stroke-width: 2}
parallel_section.lane_1.out_1 -> output_section.merge_node: {style.stroke: "#2E7D32"; style.stroke-width: 2}
parallel_section.lane_2.out_2 -> output_section.merge_node: {style.stroke: "#E65100"; style.stroke-width: 2}
parallel_section.lane_t.out_t -> output_section.merge_node: {style.stroke: "#AD1457"; style.stroke-width: 2}

# ==========================================
# ANNOTATIONS & FORMULAS
# ==========================================
formula_box: {
  label: "Mathematical Logic"
  near: bottom-left
  grid-rows: 2
  style: {
    fill: "#ECEFF1"
    stroke: "#455A64"
    stroke-width: 2
    double-border: true
  }
  f1: "z₁ᵢ = GELU(W₁·xᵢ + b₁)" {
    shape: text
    style: {
      font: mono
      font-size: 14
      bold: true
    }
  }
  f2: "yᵢ = W₂·z₁ᵢ + b₂" {
    shape: text
    style: {
      font: mono
      font-size: 14
      bold: true
    }
  }
}

parallel_note: {
  label: "⚡ Parallelization Strategy:\nNo inter-position dependency.\nEnables O(1) time complexity given O(T) compute cores."
  shape: parallelogram
  near: bottom-center
  style: {
    fill: "#FFF9C4"
    stroke: "#F57F17"
    stroke-width: 2
    font-size: 12
    bold: true
  }
}

dim_flow: {
  label: "Dimension Pipeline"
  near: bottom-right
  grid-rows: 3
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-width: 2
  }
  d1: "Input: [B, T, 512]" {
    shape: text
    style: { font: mono; font-size: 11 }
  }
  d2: "Intermediate: [B, T, 2048]" {
    shape: text
    style: { font: mono; font-size: 11 }
  }
  d3: "Output: [B, T, 512]" {
    shape: text
    style: { font: mono; font-size: 11 }
  }
}

# ==========================================
# LEGEND
# ==========================================
legend: {
  label: "Legend / Key"
  near: top-right
  grid-rows: 3
  style: {
    fill: "#FAFAFA"
    stroke: "#757575"
    stroke-dash: 3
  }
  leg_tensor: "Tensor Block" {
    class: class_tensor
    width: 100
    height: 30
  }
  leg_op: "Linear Transformation" {
    class: class_op
    width: 100
  }
  leg_shared: "--- Shared Param Flow" {
    shape: text
    style: {
      stroke: "#7B1FA2"
      stroke-dash: 5
      font-size: 10
    }
  }
}