direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Token Embedding Lookup"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# Input Section
# batch size (B), sequence length (S)
input_section: {
  label: "Input"
  style.fill: "#E3F2FD"
  token_indices: {
    label: "Token Indices\n[batch, seq_len]"
    shape: rectangle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      font-size: 14
    }
  }
  index_example: {
    label: |md
      Example Indices:
      python
      [[2, 15, 8, 42],
       [7, 3, 19, 1]]
      
    |
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      font-size: 11
    }
  }
}

# Embedding Table (W_e)
# vocab_size (V) x model_dimension (D)
embedding_table: {
  label: "nn.Embedding\n(vocab_size × d_model)"
  shape: class
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
  }
  # Table visualization showing individual vector slots
  row_0: {label: "0"; shape: rectangle; style.fill: "#FFE0B2"}
  row_1: {label: "1"; shape: rectangle; style.fill: "#FFE0B2"}
  row_2: {label: "2 →"; shape: rectangle; style.fill: "#FFCC80"; style.bold: true}
  row_3: {label: "..."; shape: rectangle; style.fill: "#FFE0B2"}
  row_42: {label: "42 →"; shape: rectangle; style.fill: "#FFCC80"; style.bold: true}
  row_v: {label: "vocab-1"; shape: rectangle; style.fill: "#FFE0B2"}
  
  columns: {
    label: "d_model dimensions"
    shape: rectangle
    style: {
      fill: "#FFF3E0"
      stroke-dash: 3
    }
  }
  
  row_0 -- columns: {style.stroke-dash: 3; style.opacity: 0.3}
  row_1 -- columns: {style.stroke-dash: 3; style.opacity: 0.3}
  row_2 -- columns: {style.stroke-dash: 0; style.opacity: 1; style.stroke: "#E65100"; style.bold: true}
  row_42 -- columns: {style.stroke-dash: 0; style.opacity: 1; style.stroke: "#E65100"; style.bold: true}
}

# Lookup Operation
# Equivalent to matrix multiplication with one-hot encoded indices
lookup_op: {
  label: "Lookup\nOperation"
  shape: diamond
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
  }
}

# Raw Embeddings after table lookup
raw_embeddings: {
  label: "Raw Embeddings\n[batch, seq_len, d_model]"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
  }
}

# Scaling Decision
# Logic gate for Transformer paper specific implementation
scale_decision: {
  label: "scale_by_sqrt\n== True?"
  shape: diamond
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
  }
}

# Scale Operation: Prevents embedding values from being washed out by Positional Encoding
scale_op: {
  label: "× √d_model"
  shape: hexagon
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
  }
  note: {
    label: "Original Transformer\npaper scaling"
    shape: text
    style: {
      font-size: 10
      italic: true
      fill: transparent
    }
  }
}

scale_op -> scale_op.note: {style.stroke: transparent}

# Skip Scale (Standard in many modern BERT-like models)
skip_scale: {
  label: "Skip"
  shape: text
  style: {
    font-size: 12
    fill: transparent
  }
}

# Final Output ready for Positional Encoding addition
output: {
  label: "Output Embeddings\n[batch, seq_len, d_model]"
  shape: rectangle
  style: {
    fill: "#E0F7FA"
    stroke: "#00838F"
    double-border: true
    bold: true
  }
}

# Weight Initialization Details
weight_init: {
  label: "Weight Initialization:\nN(μ=0, σ=0.02)"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke-dash: 3
    font-size: 11
  }
}

# Connections defining data flow
input_section.token_indices -> lookup_op: {
  label: "indices"
  style.stroke: "#1976D2"
}

embedding_table -> lookup_op: {
  label: "weights"
  style.stroke: "#E65100"
}

lookup_op -> raw_embeddings: {
  label: "gather"
  style.stroke: "#7B1FA2"
}

raw_embeddings -> scale_decision: {style.stroke: "#388E3C"}

scale_decision -> scale_op: {
  label: "Yes"
  style.stroke: "#C2185B"
}

scale_decision -> skip_scale: {
  label: "No"
  style.stroke: "#888888"
}

skip_scale -> output: {style.stroke: "#888888"}
scale_op -> output: {style.stroke: "#C2185B"}

# Dimension flow annotation for engineers
dim_flow: {
  label: "[B, S] → Embedding → [B, S, D]"
  shape: text
  style: {
    font-size: 12
    italic: true
    fill: transparent
  }
}

# Metadata link
weight_init -> embedding_table: {
  style: {
    stroke-dash: 3
    stroke: "#666666"
  }
}