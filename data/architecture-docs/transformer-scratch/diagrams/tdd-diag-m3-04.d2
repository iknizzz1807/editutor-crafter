layout-engine: elk
direction: right
title: {
  label: Sinusoidal Positional Encoding Waves
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}
subtitle: {
  label: PE(pos,2i) = sin(pos / 10000^(2i/d_model))\nPE(pos,2i+1) = cos(pos / 10000^(2i/d_model))
  shape: text
  style.font-size: 14
  style.italic: true
  style.fill: "#F8F9FA"
}
# Position axis
positions: {
  shape: rectangle
  style.stroke: "#E0E0E0"
  width: 600
  pos_0: {
    label: "pos=0"
    shape: text
    style.font-size: 10
  }
  pos_5: {
    label: "pos=5"
    shape: text
    style.font-size: 10
  }
  pos_10: {
    label: "pos=10"
    shape: text
    style.font-size: 10
  }
  pos_15: {
    label: "pos=15"
    shape: text
    style.font-size: 10
  }
  pos_20: {
    label: "pos=20"
    shape: text
    style.font-size: 10
  }
}
# Dimension 0 - High frequency sin
dim_0_sin: {
  label: "dim 0 (sin)\nω = 10000^0"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#1565C0"
  style.fill: "#E3F2FD"
  wave: {
    label: "∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#1565C0"
  }
  freq_label: {
    label: "frequency: HIGH (period ≈ 1)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 1 - High frequency cos
dim_1_cos: {
  label: "dim 1 (cos)\nω = 10000^0"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#7B1FA2"
  style.fill: "#F3E5F5"
  wave: {
    label: "∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#7B1FA2"
  }
  freq_label: {
    label: "frequency: HIGH (period ≈ 1)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 2 - Medium frequency sin
dim_2_sin: {
  label: "dim 2 (sin)\nω = 10000^(2/8)"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#1565C0"
  style.fill: "#E3F2FD"
  wave: {
    label: "∿∿∿∿∿∿∿∿∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#1565C0"
  }
  freq_label: {
    label: "frequency: MEDIUM (period ≈ 3)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 3 - Medium frequency cos
dim_3_cos: {
  label: "dim 3 (cos)\nω = 10000^(2/8)"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#7B1FA2"
  style.fill: "#F3E5F5"
  wave: {
    label: "∿∿∿∿∿∿∿∿∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#7B1FA2"
  }
  freq_label: {
    label: "frequency: MEDIUM (period ≈ 3)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 4 - Low frequency sin
dim_4_sin: {
  label: "dim 4 (sin)\nω = 10000^(4/8)"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#1565C0"
  style.fill: "#E3F2FD"
  wave: {
    label: "∿∿∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#1565C0"
  }
  freq_label: {
    label: "frequency: LOW (period ≈ 10)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 5 - Low frequency cos
dim_5_cos: {
  label: "dim 5 (cos)\nω = 10000^(4/8)"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#7B1FA2"
  style.fill: "#F3E5F5"
  wave: {
    label: "∿∿∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#7B1FA2"
  }
  freq_label: {
    label: "frequency: LOW (period ≈ 10)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 6 - Very low frequency sin
dim_6_sin: {
  label: "dim 6 (sin)\nω = 10000^(6/8)"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#1565C0"
  style.fill: "#E3F2FD"
  wave: {
    label: "∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#1565C0"
  }
  freq_label: {
    label: "frequency: VERY LOW (period ≈ 31)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Dimension 7 - Very low frequency cos
dim_7_cos: {
  label: "dim 7 (cos)\nω = 10000^(6/8)"
  shape: rectangle
  width: 600
  height: 80
  style.stroke: "#7B1FA2"
  style.fill: "#F3E5F5"
  wave: {
    label: "∿∿"
    shape: text
    style.font-size: 24
    style.fill: "#7B1FA2"
  }
  freq_label: {
    label: "frequency: VERY LOW (period ≈ 31)"
    shape: text
    style.font-size: 9
    style.italic: true
  }
}
# Vertical position markers
position_fingerprint: {
  label: Position Fingerprint Example
  shape: rectangle
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.fill: "#E8F5E9"
  header: {
    label: "At position 5, each dimension captures different info:"
    shape: text
    style.bold: true
  }
  pos5_vec: {
    shape: class
    style.fill: "#C8E6C9"
    dim0: dim0: sin(5) ≈ -0.96
    dim1: dim1: cos(5) ≈ 0.28
    dim2: dim2: sin(1.58) ≈ 1.0
    dim3: dim3: cos(1.58) ≈ 0.0
    dim4: dim4: sin(0.5) ≈ 0.48
    dim5: dim5: cos(0.5) ≈ 0.88
    dim6: dim6: sin(0.16) ≈ 0.16
    dim7: dim7: cos(0.16) ≈ 0.99
  }
  result: {
    label: "Unique 8D fingerprint for position 5"
    shape: text
    style.bold: true
    style.fill: "#2E7D32"
  }
}
# Properties box
properties: {
  shape: rectangle
  style.stroke: "#FF9800"
  style.fill: "#FFF3E0"
  title: {
    label: "Key Properties"
    shape: text
    style.bold: true
    style.font-size: 14
  }
  prop1: {
    label: "• Each position has a unique encoding vector"
    shape: text
  }
  prop2: {
    label: "• Model can learn relative positions\n  (PE(pos+k) is linear function of PE(pos))"
    shape: text
  }
  prop3: {
    label: "• Generalizes to sequences longer\n  than training data"
    shape: text
  }
  prop4: {
    label: "• Fixed (not learned) - no parameters"
    shape: text
  }
}
# Legend
legend: {
  shape: rectangle
  style.stroke: "#9E9E9E"
  style.fill: "#FAFAFA"
  title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  sin_legend: {
    label: "■ Even dimensions (2i): sin wave"
    shape: text
    style.fill: "#1565C0"
  }
  cos_legend: {
    label: "■ Odd dimensions (2i+1): cos wave"
    shape: text
    style.fill: "#7B1FA2"
  }
  freq_legend: {
    label: "Frequency decreases as dimension increases\n   (higher dims = longer wavelength)"
    shape: text
    style.italic: true
    style.font-size: 10
  }
}
# Connections showing data flow
dim_0_sin -> dim_1_cos -> dim_2_sin -> dim_3_cos -> dim_4_sin -> dim_5_cos -> dim_6_sin -> dim_7_cos: {
  style.stroke-dash: 3
  style.stroke: "#BDBDBD"
}
# Group dimensions container
dimensions_group: {
  label: "d_model = 8 dimensions"
  shape: rectangle
  style.stroke-dash: 5
  style.stroke: "#9E9E9E"
  contains: [dim_0_sin, dim_1_cos, dim_2_sin, dim_3_cos, dim_4_sin, dim_5_cos, dim_6_sin, dim_7_cos]
}