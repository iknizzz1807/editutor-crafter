layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6c5ce7"
    data: "#0984e3"
    accent: "#00cec9"
    formula: "#ffeaa7"
    freq_high: "#ff7675"
    freq_low: "#55efc4"
  }
}

# --- GLOBAL STYLES ---
*.style: {
  font-size: 14
  stroke-width: 1
}

title: {
  label: |md
    # Sinusoidal Positional Encoding Waves
    ## Mathematical Formulation
    $PE(pos, 2i) = \sin(pos / 10000^{2i/d_{model}})$
    $PE(pos, 2i+1) = \cos(pos / 10000^{2i/d_{model}})$
  |
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# --- FREQUENCY CALCULATION ---
formula_box: {
  label: "Angular Frequency Derivation"
  shape: rectangle
  style: {
    fill: "#1e272e"
    stroke: "#00d4ff"
    stroke-width: 3
    font-color: white
  }
  freq_formula: {
    shape: text
    label: |md
      ### $\omega_i = \frac{1}{10000^{2i/d_{model}}}$
      
      | Variable | Description |
      | :--- | :--- |
      | **pos** | Position index in sequence (0 to L-1) |
      | **i** | Dimension index (0 to $d_{model}/2$) |
      | **$\omega_i$** | Angular frequency for dimension $i$ |

      **Key Rule:** As **i** increases, **$\omega_i$** geometric progression decreases from 1.0 to 0.0001.
    |
  }
}

# --- SPATIAL SAMPLING AXIS ---
positions: {
  label: "Spatial Axis: Time/Position (pos)"
  style: {
    fill: "#2d3436"
    font-color: white
    stroke: "#636e72"
  }
  pos_0: "pos=0" { shape: circle; style.fill: "#dfe6e9" }
  pos_10: "pos=10" { shape: circle; style.fill: "#dfe6e9" }
  pos_25: "pos=25" { shape: circle; style.fill: "#dfe6e9" }
  pos_50: "pos=50" { shape: circle; style.fill: "#dfe6e9" }
  
  pos_0 -> pos_10 -> pos_25 -> pos_50: { 
    style: {
      stroke: "#b2bec3"
      stroke-width: 2
    }
  }
}

# --- DIMENSION LAYERS ---
waves: {
  # Dimension 0: Highest frequency
  dim_0: {
    label: "High Frequency Band (i=0)"
    style: { fill: "#1e272e"; stroke: "#00d4ff" }
    wave_label: "$\omega_0 = 1.0$ | Period $T \approx 6.28$" { shape: text; style.font-color: "#00d4ff" }
    
    wave_viz: {
      label: "Discrete Sine Sample"
      p0: "" { shape: circle; width: 10; height: 10; style.fill: "#00d4ff" }
      p1: "" { shape: circle; width: 10; height: 10; style.fill: "#00d4ff" }
      p2: "" { shape: circle; width: 10; height: 10; style.fill: "#00d4ff" }
      p3: "" { shape: circle; width: 10; height: 10; style.fill: "#00d4ff" }
      p4: "" { shape: circle; width: 10; height: 10; style.fill: "#00d4ff" }
      p0 -> p1 -> p2 -> p3 -> p4: { style.stroke: "#00d4ff"; style.animated: true }
    }
    sin_eq: "$PE(pos,0) = \sin(pos \cdot 1.0)$" { shape: text; style.font-color: "#00d4ff" }
  }

  # Dimension 1: Cosine complement
  dim_1: {
    label: "Cosine Phase Shift (i=0)"
    style: { fill: "#1e272e"; stroke: "#ff7675" }
    wave_label_1: "Orthonormal basis component" { shape: text; style.font-color: "#ff7675" }
    cos_eq: "$PE(pos,1) = \cos(pos \cdot 1.0)$" { shape: text; style.font-color: "#ff7675" }
  }

  # Dimension 32: Medium frequency
  dim_32: {
    label: "Mid-Range Band (i=16)"
    style: { fill: "#1e272e"; stroke: "#f7b731" }
    wave_label_32: "$\omega_{16} \approx 0.045$ | Period $T \approx 140$" { shape: text; style.font-color: "#f7b731" }
    sin_eq_32: "$PE(pos,32) = \sin(pos \cdot 0.045)$" { shape: text; style.font-color: "#f7b731" }
  }

  # Dimension 126: Lowest frequency
  dim_126: {
    label: "Low Frequency / Global Context (i=63)"
    style: { fill: "#1e272e"; stroke: "#26de81" }
    wave_label_126: "$\omega_{63} \approx 0.0001$ | Quasi-static" { shape: text; style.font-color: "#26de81" }
    eq_126: "$PE(pos,126) = \sin(pos \cdot 10^{-4})$" { shape: text; style.font-color: "#26de81" }
  }
}

# --- FREQUENCY SPECTRUM ---
freq_spectrum: {
  label: "Frequency Spectrum (d_model=128)"
  style.fill: "#0f172a"
  
  spectrum_gradient: {
    label: ""
    width: 600
    height: 40
    style: {
      fill: "linear-gradient(90deg, #00d4ff, #4ecdc4, #f7b731, #a55eea, #26de81)"
      stroke: "#f8f9fa"
      stroke-width: 2
    }
  }
  
  axis_labels: {
    shape: text
    label: |md
      **High Frequency (Local Detail)** ------------------------------------------------------> **Low Frequency (Global Structure)**
      Index 0 (Fast Change)                                                           Index 127 (Slow Change)
    |
    style.font-color: white
  }
}

# --- EMBEDDING VECTOR LAYOUT ---
memory_layout: {
  label: "Positional Embedding Vector [1 x 128]"
  style.fill: "#1e272e"
  style.stroke: "#e056fd"
  style.stroke-width: 2

  vector_grid: {
    grid-columns: 8
    grid-gap: 5
    d0: "sin(p,0)" { style.fill: "#00d4ff" }
    d1: "cos(p,0)" { style.fill: "#ff7675" }
    d2: "sin(p,1)" { style.fill: "#00d4ff" }
    d3: "cos(p,1)" { style.fill: "#ff7675" }
    dots: "..." { shape: text; style.font-color: white }
    d126: "sin(p,63)" { style.fill: "#26de81" }
    d127: "cos(p,63)" { style.fill: "#26de81" }
  }

  note: "Unique binary-like fingerprint for every position index." {
    shape: text
    style.font-color: "#e056fd"
  }
}

# --- KEY INSIGHTS ---
key_insight: {
  label: "Architectural Advantages"
  style: { fill: "#2d3436"; stroke: "#fd79a8"; font-color: white }
  insight_text: {
    shape: text
    label: |md
      1. **Fixed Magnitude**: L2-norm remains relatively stable.
      2. **Extrapolation**: Can generalize to sequence lengths longer than trained.
      3. **Relative Encoding**: For any fixed offset $k$, $PE(pos+k)$ can be represented as a linear function of $PE(pos)$.
      4. **Determinism**: No learned parameters required; reduces model footprint.
    |
  }
}

# --- DATA SAMPLING TABLE ---
sampling_table: {
  label: "Encoding Values at Specific Dimensions"
  style: { fill: "#1e272e"; stroke: white; font-color: white }
  table_content: {
    shape: text
    label: |md
      | Position | Dim 0 (Fast) | Dim 32 (Med) | Dim 126 (Slow) |
      | :--- | :--- | :--- | :--- |
      | **0** | 0.000 | 0.000 | 0.000 |
      | **1** | 0.841 | 0.045 | 0.0001 |
      | **2** | 0.909 | 0.090 | 0.0002 |
      | **10** | -0.544 | 0.435 | 0.0010 |
      | **100** | -0.506 | -0.978 | 0.0100 |
    |
  }
}

# --- LOGICAL FLOW CONNECTIONS ---
formula_box -> waves.dim_0: "Define $\omega_i$" {
  style.stroke: "#00d4ff"
  style.stroke-width: 2
}

waves.dim_0 -> waves.dim_1: "Sine/Cosine Pair"
waves.dim_1 -> waves.dim_32: "Decrease Freq" { style.stroke-dash: 5 }
waves.dim_32 -> waves.dim_126: "Decrease Freq" { style.stroke-dash: 5 }

waves -> freq_spectrum: "Continuous Frequency Decay"
freq_spectrum -> memory_layout: "Map to Vector Indices"
memory_layout -> key_insight: "Property Analysis"
memory_layout -> sampling_table: "Resulting Values"

# Visual Alignment
waves.dim_0 -> positions: "Sample points" { 
  style: {
    stroke: "#636e72"
    stroke-dash: 3
    opacity: 0.5
  }
}