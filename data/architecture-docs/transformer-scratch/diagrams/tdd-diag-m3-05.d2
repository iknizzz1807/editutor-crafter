layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: {
  label: "Positional Encoding Heatmap (Transformer Architecture)"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: {
  label: "PE(pos,2i) = sin(pos/10000^(2i/d_model))  |  PE(pos,2i+1) = cos(pos/10000^(2i/d_model))"
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}

# Legend Section
legend: {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }
  
  legend_title: {
    label: "Value Scale & Encoding Type"
    shape: text
    style: {
      font-size: 14
      bold: true
      fill: "#ffffff"
    }
  }

  scale_row: {
    shape: rectangle
    style: {
      fill: "transparent"
      stroke: "transparent"
    }
    neg_label: "-1.0" { shape: text; style.font-color: "#ffffff" }
    color_neg_high: { shape: rectangle; width: 30; height: 20; style.fill: "#0000ff" }
    color_neg_mid: { shape: rectangle; width: 30; height: 20; style.fill: "#4444ff" }
    color_zero: { shape: rectangle; width: 30; height: 20; style.fill: "#000000" }
    color_pos_mid: { shape: rectangle; width: 30; height: 20; style.fill: "#ff4444" }
    color_pos_high: { shape: rectangle; width: 30; height: 20; style.fill: "#ff0000" }
    pos_label: "+1.0" { shape: text; style.font-color: "#ffffff" }

    neg_label -> color_neg_high -> color_neg_mid -> color_zero -> color_pos_mid -> color_pos_high -> pos_label: {
      style.stroke: transparent
    }
  }

  types: {
    shape: rectangle
    style.fill: transparent
    style.stroke: transparent
    
    sin_label: "◆ Sine (Even dimensions i=0,2,4...)" {
      shape: text
      style.font-color: "#00ccff"
    }
    cos_label: "◆ Cosine (Odd dimensions i=1,3,5...)" {
      shape: text
      style.font-color: "#ff6600"
    }
  }
}

# Axis Labels
dim_axis: {
  label: "← Dimensions (d_model=64) →"
  shape: text
  style: {
    font-size: 14
    fill: "#aaaaaa"
    bold: true
  }
}

pos_axis: {
  label: "↑\nP\no\ns\ni\n\nt\ni\no\nn\ns\n\n↓"
  shape: text
  style: {
    font-size: 12
    fill: "#aaaaaa"
    bold: true
  }
}

# Heatmap Grid Container
heatmap: {
  shape: rectangle
  grid-columns: 14
  style: {
    fill: "#0d0d1a"
    stroke: "#333366"
    stroke-width: 3
  }

  # Header Row
  # FIX: label must not be empty for text shapes
  axis_header: "Pos \\ Dim" { shape: text; style.font-color: "#ffffff"; style.font-size: 10 }
  d0: "0" { shape: text; style: { fill: "#00ccff"; font-size: 10; bold: true } }
  d1: "1" { shape: text; style: { fill: "#ff6600"; font-size: 10; bold: true } }
  d2: "2" { shape: text; style: { fill: "#00ccff"; font-size: 10; bold: true } }
  d3: "3" { shape: text; style: { fill: "#ff6600"; font-size: 10; bold: true } }
  d4: "4" { shape: text; style: { fill: "#00ccff"; font-size: 10; bold: true } }
  d5: "5" { shape: text; style: { fill: "#ff6600"; font-size: 10; bold: true } }
  d6: "6" { shape: text; style: { fill: "#00ccff"; font-size: 10; bold: true } }
  d7: "7" { shape: text; style: { fill: "#ff6600"; font-size: 10; bold: true } }
  d_gap: "..." { shape: text; style: { fill: "#666666"; font-size: 10 } }
  d60: "60" { shape: text; style: { fill: "#00ccff"; font-size: 10; bold: true } }
  d61: "61" { shape: text; style: { fill: "#ff6600"; font-size: 10; bold: true } }
  d62: "62" { shape: text; style: { fill: "#00ccff"; font-size: 10; bold: true } }
  d63: "63" { shape: text; style: { fill: "#ff6600"; font-size: 10; bold: true } }

  # Position 0 Row
  p0_l: "pos 0" { shape: text; style.font-color: "#888888" }
  p0_d0: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p0_d1: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p0_d2: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p0_d3: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p0_d4: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p0_d5: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p0_d6: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p0_d7: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p0_d8: { shape: rectangle; width: 24; height: 18; style.fill: "#222222" }
  p0_d60: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p0_d61: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p0_d62: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p0_d63: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }

  # Position 1 Row
  p1_l: "pos 1" { shape: text; style.font-color: "#888888" }
  p1_d0: { shape: rectangle; width: 24; height: 18; style.fill: "#ff3333" }
  p1_d1: { shape: rectangle; width: 24; height: 18; style.fill: "#ff3333" }
  p1_d2: { shape: rectangle; width: 24; height: 18; style.fill: "#ff2222" }
  p1_d3: { shape: rectangle; width: 24; height: 18; style.fill: "#ff2222" }
  p1_d4: { shape: rectangle; width: 24; height: 18; style.fill: "#ff1111" }
  p1_d5: { shape: rectangle; width: 24; height: 18; style.fill: "#ff1111" }
  p1_d6: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p1_d7: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p1_d8: { shape: rectangle; width: 24; height: 18; style.fill: "#222222" }
  p1_d60: { shape: rectangle; width: 24; height: 18; style.fill: "#110000" }
  p1_d61: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0808" }
  p1_d62: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p1_d63: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }

  # Position 2 Row
  p2_l: "pos 2" { shape: text; style.font-color: "#888888" }
  p2_d0: { shape: rectangle; width: 24; height: 18; style.fill: "#ff6666" }
  p2_d1: { shape: rectangle; width: 24; height: 18; style.fill: "#cc0000" }
  p2_d2: { shape: rectangle; width: 24; height: 18; style.fill: "#ff4444" }
  p2_d3: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p2_d4: { shape: rectangle; width: 24; height: 18; style.fill: "#ff2222" }
  p2_d5: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p2_d6: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p2_d7: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
  p2_d8: { shape: rectangle; width: 24; height: 18; style.fill: "#222222" }
  p2_d60: { shape: rectangle; width: 24; height: 18; style.fill: "#220000" }
  p2_d61: { shape: rectangle; width: 24; height: 18; style.fill: "#ff1010" }
  p2_d62: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p2_d63: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }

  # Row Ellipsis
  e_col_0: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_1: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_2: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_3: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_4: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_5: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_6: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_7: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_8: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_9: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_10: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_11: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_12: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }
  e_col_13: "⋮" { shape: text; style: { font-size: 20; fill: "#666666" } }

  # Position 100 Row
  p100_l: "pos 100" { shape: text; style.font-color: "#888888" }
  p100_d0: { shape: rectangle; width: 24; height: 18; style.fill: "#3333ff" }
  p100_d1: { shape: rectangle; width: 24; height: 18; style.fill: "#ff6666" }
  p100_d2: { shape: rectangle; width: 24; height: 18; style.fill: "#666666" }
  p100_d3: { shape: rectangle; width: 24; height: 18; style.fill: "#ffffcc" }
  p100_d4: { shape: rectangle; width: 24; height: 18; style.fill: "#5555ff" }
  p100_d5: { shape: rectangle; width: 24; height: 18; style.fill: "#ff3333" }
  p100_d6: { shape: rectangle; width: 24; height: 18; style.fill: "#aaaaaa" }
  p100_d7: { shape: rectangle; width: 24; height: 18; style.fill: "#ffaaaa" }
  p100_d8: { shape: rectangle; width: 24; height: 18; style.fill: "#222222" }
  p100_d60: { shape: rectangle; width: 24; height: 18; style.fill: "#770000" }
  p100_d61: { shape: rectangle; width: 24; height: 18; style.fill: "#ff3838" }
  p100_d62: { shape: rectangle; width: 24; height: 18; style.fill: "#000000" }
  p100_d63: { shape: rectangle; width: 24; height: 18; style.fill: "#ff0000" }
}

# Frequency explanation panel
freq_panel: {
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }
  freq_title: {
    label: "Frequency Bands (pos/10000^(2i/d_model))"
    shape: text
    style: {
      font-size: 14
      bold: true
      fill: "#ffffff"
    }
  }
  high_freq: "Dims 0-7: High frequency → Captures local position" {
    shape: text
    style: { fill: "#00ccff"; font-size: 11 }
  }
  mid_freq: "Dims 8-31: Medium frequency → Captures mid-range patterns" {
    shape: text
    style: { fill: "#88ff88"; font-size: 11 }
  }
  low_freq: "Dims 32-63: Low frequency → Captures global structure" {
    shape: text
    style: { fill: "#ff88ff"; font-size: 11 }
  }
  freq_title -> high_freq -> mid_freq -> low_freq: {
    style.stroke: transparent
  }
}

# Layout connections
title -> subtitle -> legend -> dim_axis -> heatmap -> pos_axis -> freq_panel: {
  style.stroke: transparent
}