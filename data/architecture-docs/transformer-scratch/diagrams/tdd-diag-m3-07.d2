direction: right
layout-engine: elk
title: {
  label: Embedding Composition Pipeline
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
# Input Stage
token_indices: {
  label: "Token Indices\n[B, S]"
  shape: parallelogram
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
    font-size: 14
  }
}
# Embedding Lookup Stage
embedding_lookup: {
  label: "nn.Embedding Lookup\nvocab_size × d_model"
  shape: hexagon
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-width: 2
    font-size: 14
  }
}
# Tensor after lookup
embedded: {
  label: "Embedded Tensor\n[B, S, D]"
  shape: parallelogram
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
    font-size: 14
  }
}
# Scaling Stage
scale_decision: {
  label: "scale = True?"
  shape: diamond
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
    stroke-width: 2
    font-size: 14
  }
}
scale_multiply: {
  label: "× √(d_model)"
  shape: circle
  style: {
    fill: "#FFEBEE"
    stroke: "#F44336"
    stroke-width: 2
    font-size: 14
  }
}
skip_scale: {
  label: "skip"
  shape: text
  style: {
    font-size: 12
    italic: true
  }
}
# Scaled tensor
scaled: {
  label: "Scaled Tensor\n[B, S, D]"
  shape: parallelogram
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-width: 2
    font-size: 14
  }
}
# Positional Encoding Component
pe_component: {
  label: "Positional Encoding\n(Precomputed Buffer)"
  shape: rectangle
  style: {
    fill: "#E0F7FA"
    stroke: "#00BCD4"
    stroke-width: 2
    font-size: 14
    double-border: true
  }
  pe_formula: {
    label: "PE(pos, 2i) = sin(pos/10000^(2i/D))\nPE(pos, 2i+1) = cos(pos/10000^(2i/D))"
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }
}
pe_buffer: {
  label: "PE Buffer\n[1, max_len, D]"
  shape: parallelogram
  style: {
    fill: "#E0F7FA"
    stroke: "#00BCD4"
    stroke-width: 2
    font-size: 14
  }
}
# Addition Operation
add_pe: {
  label: "+"
  shape: circle
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    stroke-width: 3
    font-size: 20
    bold: true
  }
}
# After PE addition
with_pe: {
  label: "Token + Position\n[B, S, D]"
  shape: parallelogram
  style: {
    fill: "#FCE4EC"
    stroke: "#E91E63"
    stroke-width: 2
    font-size: 14
  }
}
# Dropout Stage
dropout: {
  label: "Dropout(p=0.1)\nRegularization"
  shape: rectangle
  style: {
    fill: "#FFECB3"
    stroke: "#FFC107"
    stroke-width: 2
    font-size: 14
    stroke-dash: 4
  }
}
# Final Output
output: {
  label: "Output Embedding\n[B, S, D]"
  shape: parallelogram
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 3
    font-size: 14
    bold: true
  }
}
# Legend
legend: {
  label: Legend
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-width: 1
    font-size: 12
  }
  tensor_shape: {
    label: "Parallelogram = Tensor\n[B=batch, S=seq_len, D=d_model]"
    shape: text
  }
  operation: {
    label: "Circle/Hexagon = Operation"
    shape: text
  }
  buffer: {
    label: "Dashed = Stochastic (training)"
    shape: text
  }
}
# Connections
token_indices -> embedding_lookup: {
  label: "lookup"
  style: {
    stroke: "#4CAF50"
    stroke-width: 2
  }
}
embedding_lookup -> embedded: {
  style: {
    stroke: "#2196F3"
    stroke-width: 2
  }
}
embedded -> scale_decision: {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
  }
}
scale_decision -> scale_multiply: {
  label: "yes"
  style: {
    stroke: "#9C27B0"
    stroke-width: 2
  }
}
scale_decision -> skip_scale: {
  label: "no"
  style: {
    stroke: "#9E9E9E"
    stroke-width: 1
    stroke-dash: 3
  }
}
scale_multiply -> scaled: {
  style: {
    stroke: "#F44336"
    stroke-width: 2
  }
}
skip_scale -> scaled: {
  style: {
    stroke: "#9E9E9E"
    stroke-width: 1
    stroke-dash: 3
  }
}
pe_component -> pe_buffer: {
  label: "register_buffer"
  style: {
    stroke: "#00BCD4"
    stroke-width: 2
    stroke-dash: 5
  }
}
scaled -> add_pe: {
  style: {
    stroke: "#FF9800"
    stroke-width: 2
  }
}
pe_buffer -> add_pe: {
  label: "broadcast"
  style: {
    stroke: "#00BCD4"
    stroke-width: 2
  }
}
add_pe -> with_pe: {
  style: {
    stroke: "#3F51B5"
    stroke-width: 2
  }
}
with_pe -> dropout: {
  style: {
    stroke: "#E91E63"
    stroke-width: 2
  }
}
dropout -> output: {
  style: {
    stroke: "#388E3C"
    stroke-width: 3
  }
}
# Position legend
legend.pos: {
  x: 0
  y: 600
}