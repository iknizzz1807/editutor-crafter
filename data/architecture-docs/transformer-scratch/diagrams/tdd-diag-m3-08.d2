direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Dropout Placement Strategy
  ## Transformer Architecture Implementation Detail
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# Global Classes for Intel-Manual Quality
classes: {
  dropout_layer: {
    shape: rectangle
    style: {
      fill: "#dc3545"
      stroke: "#b02a37"
      stroke-width: 3
      font-color: white
      bold: true
      shadow: true
    }
  }
  standard_layer: {
    shape: rectangle
    style: {
      fill: "#0d6efd"
      stroke: "#0a58ca"
      font-color: white
    }
  }
  process_node: {
    shape: rectangle
    style: {
      fill: "#6f42c1"
      stroke: "#593fac"
      font-color: white
    }
  }
  annotation_text: {
    shape: text
    style: {
      font-size: 12
      italic: true
      font-color: "#dc3545"
    }
  }
}

# Legend Section
legend: {
  grid-rows: 1
  grid-columns: 4
  grid-gap: 20
  style: {
    fill: "#f8f9fa"
    stroke: "#dee2e6"
    stroke-dash: 2
  }
  
  dropout_indicator: " " {
    class: dropout_layer
    width: 40
    height: 20
  }
  dropout_label: "Dropout Applied (Training Only)" { shape: text }
  
  normal_flow: " " {
    class: standard_layer
    width: 40
    height: 20
  }
  normal_label: "Standard Transform Layer" { shape: text }
}

# Input Section
input_tokens: {
  label: "Input Token IDs\n[Batch, Seq_Len]"
  shape: parallelogram
  style: {
    fill: "#6c757d"
    stroke: "#5c636a"
    font-color: white
  }
}

# Embedding Stage
embedding_layer: {
  label: "Token Embedding\n(W_E ∈ Rᵈ_vocab × d_model)"
  class: standard_layer
}

positional_encoding: {
  label: "Positional Encoding\n(PE ∈ Rˢᵉᵠ × d_model)"
  class: standard_layer
}

add_pe: {
  label: "⊕"
  shape: circle
  style: {
    fill: "#495057"
    stroke: "#343a40"
    font-color: white
    font-size: 24
  }
}

# DROPOUT 1
dropout_1: {
  label: "DROPOUT 1\np_drop=0.1"
  class: dropout_layer
}

# Attention Block
attention_block: {
  label: "Multi-Head Self-Attention\n(Q, K, V Projection)"
  class: standard_layer
}

add_norm_1: {
  label: "LayerNorm(x + Sublayer(x))"
  class: process_node
}

# FFN Section
ffn_section: {
  label: "Point-wise Feed-Forward Network"
  style: {
    fill: "#fdfdfe"
    stroke: "#dee2e6"
    stroke-dash: 5
    stroke-width: 1
  }
  
  w1: {
    label: "Linear W₁\n(d_model → d_ff)"
    class: standard_layer
  }
  
  activation: {
    label: "GELU / ReLU"
    shape: rectangle
    style: {
      fill: "#198754"
      stroke: "#146c43"
      font-color: white
    }
  }

  # DROPOUT 2 - Internally inside FFN
  dropout_2: {
    label: "DROPOUT 2\np_drop=0.1"
    class: dropout_layer
  }

  w2: {
    label: "Linear W₂\n(d_ff → d_model)"
    class: standard_layer
  }

  w1 -> activation -> dropout_2 -> w2: {
    style: {
      stroke-width: 2
    }
  }
}

# Add & Norm 2
add_norm_2: {
  label: "LayerNorm(x + FFN(x))"
  class: process_node
}

# Output
output: {
  label: "Output to Layer N+1\n[Batch, Seq_Len, d_model]"
  shape: parallelogram
  style: {
    fill: "#6c757d"
    stroke: "#5c636a"
    font-color: white
  }
}

# Logic Flow Connections
input_tokens -> embedding_layer: "ids"
embedding_layer -> add_pe: "x_emb"
positional_encoding -> add_pe: "PE"
add_pe -> dropout_1: "x + PE" {
  style.stroke-width: 3
}

dropout_1 -> attention_block: "training_flow" {
  style: {
    stroke: "#dc3545"
    stroke-width: 2
    stroke-dash: 3
  }
}

attention_block -> add_norm_1: "Attention(x)"
add_norm_1 -> ffn_section.w1: "Residual x₁"

ffn_section.w2 -> add_norm_2: "FFN(x₁)"
add_norm_2 -> output: "Final x₂"

# Residual Skip Connections
add_norm_1 -> add_norm_2: "Residual Connection" {
  style: {
    stroke-dash: 8
    stroke: "#6f42c1"
    stroke-width: 2
  }
}

# Functional Annotations
dropout_1_note: "Bernoulli(1-p) mask applied\nto sum of Embed + Pos" {
  class: annotation_text
}
dropout_2_note: "Prevents co-adaptation of\nneurons in large d_ff layer" {
  class: annotation_text
}

dropout_1 -- dropout_1_note: { style.stroke-dash: 2 }
ffn_section.dropout_2 -- dropout_2_note: { style.stroke-dash: 2 }

# State Invariant Container
mode_indicator: {
  near: bottom-right
  shape: rectangle
  label: "SYSTEM STATE INVARIANTS"
  training: "MODE: TRAINING\nDropout: ENABLED\nScaling: 1/(1-p)" {
    style: {
      fill: "#fff3cd"
      stroke: "#ffc107"
      bold: true
    }
  }
  inference: "MODE: INFERENCE\nDropout: IDENTITY\nScaling: NONE" {
    style: {
      fill: "#d1e7dd"
      stroke: "#0f5132"
      bold: true
    }
  }
}