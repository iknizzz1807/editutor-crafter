direction: right
layout-engine: elk
theme-id: 4

title: {
  label: "Even/Odd Dimension Indexing for Positional Encoding"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# 1. Main PE tensor visualization: Matrix of Positional Encodings
pe_tensor: {
  label: "Position Encoding Matrix\npe[seq_len, d_model]"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }

  # Header row showing dimension indices
  dim_header: {
    label: "Dimension Indices (d)"
    shape: rectangle
    style: {
      fill: "#0d0d1a"
      stroke: transparent
    }
    d0: {label: "d=0"; shape: text; style.font-size: 10; style.font-color: "#8be9fd"}
    d1: {label: "d=1"; shape: text; style.font-size: 10; style.font-color: "#ff79c6"}
    d2: {label: "d=2"; shape: text; style.font-size: 10; style.font-color: "#8be9fd"}
    d3: {label: "d=3"; shape: text; style.font-size: 10; style.font-color: "#ff79c6"}
    d4: {label: "d=4"; shape: text; style.font-size: 10; style.font-color: "#8be9fd"}
    d5: {label: "d=5"; shape: text; style.font-size: 10; style.font-color: "#ff79c6"}
    ellipsis: {label: "..."; shape: text; style.font-size: 10; style.font-color: "#6272a4"}
  }

  # Sample rows for different positions
  pos0: {
    label: "pos=0"
    shape: rectangle
    style.fill: "#16213e"
    p0d0: {label: "sin(0·ω₀)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    p0d1: {label: "cos(0·ω₀)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
    p0d2: {label: "sin(0·ω₁)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    p0d3: {label: "cos(0·ω₁)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
    p0d4: {label: "sin(0·ω₂)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    p0d5: {label: "cos(0·ω₂)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
  }
  pos1: {
    label: "pos=1"
    shape: rectangle
    style.fill: "#1a1a2e"
    p1d0: {label: "sin(1·ω₀)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    p1d1: {label: "cos(1·ω₀)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
    p1d2: {label: "sin(1·ω₁)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    p1d3: {label: "cos(1·ω₁)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
    p1d4: {label: "sin(1·ω₂)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    p1d5: {label: "cos(1·ω₂)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
  }
  pos_ellipsis: {
    label: "⋮"
    shape: text
    style.font-size: 16
    style.font-color: "#6272a4"
  }
  pos_n: {
    label: "pos=n"
    shape: rectangle
    style.fill: "#16213e"
    pnd0: {label: "sin(n·ω₀)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    pnd1: {label: "cos(n·ω₀)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
    pnd2: {label: "sin(n·ω₁)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    pnd3: {label: "cos(n·ω₁)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
    pnd4: {label: "sin(n·ω₂)"; shape: text; style.font-size: 9; style.font-color: "#8be9fd"}
    pnd5: {label: "cos(n·ω₂)"; shape: text; style.font-size: 9; style.font-color: "#ff79c6"}
  }
}

# 2. Even indices slice: 0, 2, 4...
even_slice: {
  label: "Even Indices: pe[:, 0::2]"
  shape: rectangle
  style: {
    fill: "#0d3b66"
    stroke: "#8be9fd"
    stroke-width: 3
  }
  header: {
    label: "SINE encoding\nPE(pos, 2i) = sin(pos / 10000^(2i/d))"
    shape: text
    style.font-size: 12
    style.bold: true
    style.font-color: "#8be9fd"
  }
  indices: {
    label: "Indices: 0, 2, 4, 6, ..."
    shape: text
    style.font-size: 11
    style.font-color: "#8be9fd"
    style.opacity: 0.8
  }
  formula_box: {
    label: "pe[:, 0::2] = torch.sin(position * div_term)"
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#8be9fd"
      font: mono
      font-size: 10
      font-color: "#50fa7b"
    }
  }
  col_vis: {
    label: ""
    shape: rectangle
    style.fill: "#0d3b66"
    c0: {label: "col[0]"; shape: rectangle; style.fill: "#8be9fd"; style.font-color: "#0d3b66"; style.font-size: 9}
    c2: {label: "col[2]"; shape: rectangle; style.fill: "#8be9fd"; style.font-color: "#0d3b66"; style.font-size: 9}
    c4: {label: "col[4]"; shape: rectangle; style.fill: "#8be9fd"; style.font-color: "#0d3b66"; style.font-size: 9}
    c_ell: {label: "..."; shape: text; style.font-color: "#8be9fd"}
  }
}

# 3. Odd indices slice: 1, 3, 5...
odd_slice: {
  label: "Odd Indices: pe[:, 1::2]"
  shape: rectangle
  style: {
    fill: "#3d1a4f"
    stroke: "#ff79c6"
    stroke-width: 3
  }
  header_odd: {
    label: "COSINE encoding\nPE(pos, 2i+1) = cos(pos / 10000^(2i/d))"
    shape: text
    style.font-size: 12
    style.bold: true
    style.font-color: "#ff79c6"
  }
  indices_odd: {
    label: "Indices: 1, 3, 5, 7, ..."
    shape: text
    style.font-size: 11
    style.font-color: "#ff79c6"
    style.opacity: 0.8
  }
  formula_box_odd: {
    label: "pe[:, 1::2] = torch.cos(position * div_term)"
    shape: rectangle
    style: {
      fill: "#1a1a2e"
      stroke: "#ff79c6"
      font: mono
      font-size: 10
      font-color: "#50fa7b"
    }
  }
  col_vis_odd: {
    label: ""
    shape: rectangle
    style.fill: "#3d1a4f"
    c1: {label: "col[1]"; shape: rectangle; style.fill: "#ff79c6"; style.font-color: "#1a1a2e"; style.font-size: 9}
    c3: {label: "col[3]"; shape: rectangle; style.fill: "#ff79c6"; style.font-color: "#1a1a2e"; style.font-size: 9}
    c5: {label: "col[5]"; shape: rectangle; style.fill: "#ff79c6"; style.font-color: "#1a1a2e"; style.font-size: 9}
    co_ell: {label: "..."; shape: text; style.font-color: "#ff79c6"}
  }
}

# 4. Divisor term explanation
div_term_section: {
  label: "Divisor Term Calculation"
  shape: rectangle
  style: {
    fill: "#1e1e3f"
    stroke: "#bd93f9"
    stroke-width: 2
  }
  div_formula: {
    label: "div_term = exp(log(10000) * torch.arange(0, d_model, 2) / d_model)"
    shape: rectangle
    style: {
      fill: "#0d0d1a"
      stroke: "#bd93f9"
      font: mono
      font-size: 10
      font-color: "#f8f8f2"
    }
  }
  explanation: {
    label: ""
    shape: rectangle
    style.fill: "#1e1e3f"
    exp1: {
      label: "• For i=0: ω₀ = 1 / 10000^0 = 1"
      shape: text
      style.font-size: 10
      style.font-color: "#bd93f9"
    }
    exp2: {
      label: "• For i=1: ω₁ = 1 / 10000^(2/d_model)"
      shape: text
      style.font-size: 10
      style.font-color: "#bd93f9"
    }
    exp3: {
      label: "• For i=2: ω₂ = 1 / 10000^(4/d_model)"
      shape: text
      style.font-size: 10
      style.font-color: "#bd93f9"
    }
  }
  note: {
    label: "Note: Dimensions 2i and 2i+1 share the SAME divisor (ωᵢ)"
    shape: rectangle
    style: {
      fill: "#ff5555"
      stroke: "#ff5555"
      font-size: 10
      bold: true
      font-color: "#1a1a2e"
    }
  }
}

# 5. Python slice syntax explanation
slice_syntax: {
  label: "Python Slice Syntax"
  shape: rectangle
  style: {
    fill: "#282a36"
    stroke: "#6272a4"
  }
  syntax_even: {
    label: "0::2  →  start=0, step=2  →  [0, 2, 4, 6, ...]"
    shape: rectangle
    style: {
      fill: "#0d3b66"
      stroke: "#8be9fd"
      font: mono
      font-size: 10
      font-color: "#8be9fd"
    }
  }
  syntax_odd: {
    label: "1::2  →  start=1, step=2  →  [1, 3, 5, 7, ...]"
    shape: rectangle
    style: {
      fill: "#3d1a4f"
      stroke: "#ff79c6"
      font: mono
      font-size: 10
      font-color: "#ff79c6"
    }
  }
  explanation_syntax: {
    label: "Format: [start : stop(optional) : step]"
    shape: text
    style: {
      font-size: 10
      font-color: "#6272a4"
      italic: true
    }
  }
}

# 6. Dimension pairing visualization (Sin/Cos Pairs)
pairing_section: {
  label: "Dimension Pairing (Sin/Cos Pairs)"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#50fa7b"
    stroke-width: 2
  }
  pair0: {
    label: ""
    shape: rectangle
    style.fill: "#1a1a2e"
    p0_sin: {
      label: "dim 0\nsin"
      shape: rectangle
      style: {
        fill: "#8be9fd"
        font-color: "#0d3b66"
        font-size: 9
        bold: true
      }
    }
    p0_arrow: {
      label: "← ω₀ →"
      shape: text
      style: {
        font-size: 10
        font-color: "#50fa7b"
      }
    }
    p0_cos: {
      label: "dim 1\ncos"
      shape: rectangle
      style: {
        fill: "#ff79c6"
        font-color: "#1a1a2e"
        font-size: 9
        bold: true
      }
    }
  }
  pair1: {
    label: ""
    shape: rectangle
    style.fill: "#1a1a2e"
    p1_sin: {
      label: "dim 2\nsin"
      shape: rectangle
      style: {
        fill: "#8be9fd"
        font-color: "#0d3b66"
        font-size: 9
        bold: true
      }
    }
    p1_arrow: {
      label: "← ω₁ →"
      shape: text
      style: {
        font-size: 10
        font-color: "#50fa7b"
      }
    }
    p1_cos: {
      label: "dim 3\ncos"
      shape: rectangle
      style: {
        fill: "#ff79c6"
        font-color: "#1a1a2e"
        font-size: 9
        bold: true
      }
    }
  }
  pair2: {
    label: ""
    shape: rectangle
    style.fill: "#1a1a2e"
    p2_sin: {
      label: "dim 4\nsin"
      shape: rectangle
      style: {
        fill: "#8be9fd"
        font-color: "#0d3b66"
        font-size: 9
        bold: true
      }
    }
    p2_arrow: {
      label: "← ω₂ →"
      shape: text
      style: {
        font-size: 10
        font-color: "#50fa7b"
      }
    }
    p2_cos: {
      label: "dim 5\ncos"
      shape: rectangle
      style: {
        fill: "#ff79c6"
        font-color: "#1a1a2e"
        font-size: 9
        bold: true
      }
    }
  }
  pairing_note: {
    label: "Each pair (2i, 2i+1) uses the same frequency ωᵢ\nThis creates unique 2D positional signatures!"
    shape: text
    style: {
      font-size: 10
      font-color: "#50fa7b"
      italic: true
    }
  }
}

# 7. Logical Connections
pe_tensor -> even_slice: {
  label: "[:, 0::2]"
  style: {
    stroke: "#8be9fd"
    stroke-width: 2
    animated: true
  }
}
pe_tensor -> odd_slice: {
  label: "[:, 1::2]"
  style: {
    stroke: "#ff79c6"
    stroke-width: 2
    animated: true
  }
}
div_term_section -> pairing_section: {
  label: "defines ωᵢ"
  style: {
    stroke: "#bd93f9"
    stroke-dash: 3
  }
}
slice_syntax -> even_slice: {
  style: {
    stroke: "#8be9fd"
    stroke-dash: 3
    opacity: 0.5
  }
}
slice_syntax -> odd_slice: {
  style: {
    stroke: "#ff79c6"
    stroke-dash: 3
    opacity: 0.5
  }
}

# 8. Legend
legend: {
  label: "Legend"
  shape: rectangle
  style: {
    fill: "#1a1a2e"
    stroke: "#6272a4"
  }
  leg_sin: {
    label: "█ Sine (even indices)"
    shape: text
    style.font-size: 10
    style.font-color: "#8be9fd"
  }
  leg_cos: {
    label: "█ Cosine (odd indices)"
    shape: text
    style.font-size: 10
    style.font-color: "#ff79c6"
  }
  leg_div: {
    label: "█ Divisor term"
    shape: text
    style.font-size: 10
    style.font-color: "#bd93f9"
  }
}