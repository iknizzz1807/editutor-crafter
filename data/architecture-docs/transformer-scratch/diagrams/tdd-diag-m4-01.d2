layout-engine: elk
theme: 101
direction: right
title: LayerNorm Computation Algorithm {
  shape: text
  near: top-center
  style.font-size: 24
  style.bold: true
}
# Input Stage
input_tensor: {
  shape: rectangle
  label: "Input Tensor\nx ∈ ℝ^{B × S × D}"
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
}
# Step 1: Mean Computation
step1_container: {
  label: "Step 1: Compute Mean"
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  mean_formula: {
    shape: text
    label: "μ = (1/D) × Σ_{i=1}^{D} x_i"
  }
  mean_desc: {
    shape: text
    label: "Compute mean over feature dimension (dim=-1)"
  }
  mean_dim: {
    shape: rectangle
    label: "mean(x, dim=-1)\n→ μ ∈ ℝ^{B × S × 1}"
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
  }
}
# Step 2: Variance Computation
step2_container: {
  label: "Step 2: Compute Variance"
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  var_formula: {
    shape: text
    label: "σ² = (1/D) × Σ_{i=1}^{D} (x_i - μ)²"
  }
  var_desc: {
    shape: text
    label: "Compute variance over feature dimension"
  }
  var_dim: {
    shape: rectangle
    label: "var(x, dim=-1)\n→ σ² ∈ ℝ^{B × S × 1}"
    style.fill: "#E1BEE7"
    style.stroke: "#7B1FA2"
  }
}
# Step 3: Center Input
step3_container: {
  label: "Step 3: Center Input"
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  center_formula: {
    shape: text
    label: "x_centered = x - μ"
  }
  broadcast_note: {
    shape: text
    label: "Broadcast: ℝ^{B×S×D} - ℝ^{B×S×1}"
  }
  centered_tensor: {
    shape: rectangle
    label: "x_centered ∈ ℝ^{B × S × D}"
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
}
# Step 4: Normalize
step4_container: {
  label: "Step 4: Normalize"
  shape: rectangle
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  norm_formula: {
    shape: text
    label: "x̂ = (x - μ) / √(σ² + ε)"
  }
  epsilon_note: {
    shape: text
    label: "ε = 1e-6 (numerical stability)"
  }
  sqrt_var: {
    shape: diamond
    label: "√(σ² + ε)\n→ ℝ^{B × S × 1}"
    style.fill: "#B2EBF2"
    style.stroke: "#00838F"
  }
  x_norm: {
    shape: rectangle
    label: "x̂ ∈ ℝ^{B × S × D}\nZero mean, unit variance"
    style.fill: "#B2EBF2"
    style.stroke: "#00838F"
  }
}
# Step 5: Scale and Shift
step5_container: {
  label: "Step 5: Scale & Shift"
  shape: rectangle
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  gamma_param: {
    shape: circle
    label: "γ\n(scale)\n∈ ℝ^D"
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
  }
  beta_param: {
    shape: circle
    label: "β\n(shift)\n∈ ℝ^D"
    style.fill: "#FFECB3"
    style.stroke: "#FF8F00"
  }
  final_formula: {
    shape: text
    label: "y = γ ⊙ x̂ + β"
  }
  broadcast_scale: {
    shape: text
    label: "Element-wise multiply + broadcast"
  }
}
# Output
output_tensor: {
  shape: rectangle
  label: "Output Tensor\ny ∈ ℝ^{B × S × D}"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
}
# Learned Parameters Box (parallel to main flow)
learned_params: {
  label: "Learned Parameters"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  style.stroke-dash: 3
  gamma_desc: {
    shape: text
    label: "γ (gamma): nn.Parameter\nInitial: ones(d_model)"
  }
  beta_desc: {
    shape: text
    label: "β (beta): nn.Parameter\nInitial: zeros(d_model)"
  }
}
# Connections - Main Flow
input_tensor -> step1_container: "forward()" {
  style.stroke: "#1565C0"
}
step1_container.mean_dim -> step2_container.var_dim: "μ" {
  style.stroke: "#E65100"
}
input_tensor -> step3_container: "x" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}
step1_container.mean_dim -> step3_container: "μ" {
  style.stroke: "#E65100"
}
step3_container.centered_tensor -> step4_container: "x_centered" {
  style.stroke: "#2E7D32"
}
step2_container.var_dim -> step4_container.sqrt_var: "σ²" {
  style.stroke: "#7B1FA2"
}
step4_container.sqrt_var -> step4_container.x_norm: "divide" {
  style.stroke: "#00838F"
}
step4_container.x_norm -> step5_container: "x̂" {
  style.stroke: "#00838F"
}
step5_container.gamma_param -> step5_container: "scale" {
  style.stroke: "#FF8F00"
}
step5_container.beta_param -> step5_container: "shift" {
  style.stroke: "#FF8F00"
}
step5_container -> output_tensor: "y = γ·x̂ + β" {
  style.stroke: "#FF8F00"
}
# Learned params connection
learned_params -> step5_container.gamma_param: "trainable" {
  style.stroke: "#424242"
  style.stroke-dash: 3
}
learned_params -> step5_container.beta_param: "trainable" {
  style.stroke: "#424242"
  style.stroke-dash: 3
}
# Shape Legend
shape_legend: {
  label: "Tensor Shape Legend"
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  b_meaning: {
    shape: text
    label: "B = Batch size"
  }
  s_meaning: {
    shape: text
    label: "S = Sequence length"
  }
  d_meaning: {
    shape: text
    label: "D = d_model (feature dimension)"
  }
  dim_note: {
    shape: text
    label: "Normalization over D (last dim)"
  }
}
# Properties Panel
properties: {
  label: "Properties"
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  prop1: {
    shape: text
    label: "• Preserves input shape: [B, S, D]"
  }
  prop2: {
    shape: text
    label: "• Independent per position"
  }
  prop3: {
    shape: text
    label: "• Differentiable (gradient flows)"
  }
  prop4: {
    shape: text
    label: "• Pre-LN: stable gradients"
  }
}