direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Layer Normalization Positioning in Transformer Blocks
  ## Pre-LN vs Post-LN Architecture Comparison
  *Technical Specification for Gradient Flow & Numerical Stability*
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# -----------------------------------------------------------------------------
# Style Classes: Intel Manual Technical Quality
# -----------------------------------------------------------------------------
classes: {
  input_node: {
    shape: circle
    label: "x_in"
    tooltip: "Input Tensor [Batch, Seq, Dim]"
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  norm_node: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  sublayer_node: {
    shape: rectangle
    style: {
      fill: "#E3F2FD"
      stroke: "#2196F3"
      stroke-width: 2
      double-border: true
    }
  }
  add_node: {
    shape: circle
    label: "⊕"
    tooltip: "Element-wise Addition (Residual Connection)"
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      bold: true
    }
  }
  output_node: {
    shape: circle
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  dropout_node: {
    shape: rectangle
    style: {
      fill: "#ECEFF1"
      stroke: "#607D8B"
      stroke-dash: 3
    }
  }
  formula_text: {
    shape: text
    style: {
      font: mono
      font-size: 14
      font-color: "#2C3E50"
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 11
      italic: true
    }
  }
}

# -----------------------------------------------------------------------------
# Pre-LN Architecture Block (Stable Training)
# -----------------------------------------------------------------------------
Pre_LN: {
  label: "Pre-LN Architecture (GPT-2/3, LLaMA Standard)"
  tooltip: "The identity branch is a clean gradient highway."
  style: {
    fill: "#FAFAFA"
    stroke: "#4CAF50"
    stroke-width: 3
    border-radius: 10
  }

  input: {
    class: input_node
  }
  
  norm1: "Layer\nNorm" {
    class: norm_node
  }
  
  sublayer: {
    label: "Sublayer\n(MHA / FFN)"
    class: sublayer_node
  }
  
  dropout: "Dropout" {
    class: dropout_node
  }
  
  add: {
    class: add_node
  }
  
  output: "x_out" {
    class: output_node
  }

  # Data Flow - Residual Path
  input -> add: "Identity Path (Gradient Highway)" {
    style: {
      stroke: "#9C27B0"
      stroke-width: 3
      stroke-dash: 5
    }
  }

  # Data Flow - Transform Path
  input -> norm1: "x"
  norm1 -> sublayer: "Norm(x)"
  sublayer -> dropout: "F(Norm(x))"
  dropout -> add: "Residual Addition"
  add -> output
}

# -----------------------------------------------------------------------------
# Post-LN Architecture Block (Original Transformer)
# -----------------------------------------------------------------------------
Post_LN: {
  label: "Post-LN Architecture (Original Vaswani et al.)"
  tooltip: "The identity branch is modified by LayerNorm before the next layer."
  style: {
    fill: "#FAFAFA"
    stroke: "#F44336"
    stroke-width: 3
    border-radius: 10
  }

  input: {
    class: input_node
  }
  
  sublayer: {
    label: "Sublayer\n(MHA / FFN)"
    class: sublayer_node
  }
  
  dropout: "Dropout" {
    class: dropout_node
  }
  
  add: {
    class: add_node
  }
  
  norm1: "Layer\nNorm" {
    class: norm_node
  }
  
  output: "x_out" {
    class: output_node
  }

  # Data Flow - Residual Path
  input -> add: "Identity Path" {
    style: {
      stroke: "#9C27B0"
      stroke-width: 3
      stroke-dash: 5
    }
  }

  # Data Flow - Transform Path
  input -> sublayer: "x"
  sublayer -> dropout: "F(x)"
  dropout -> add: "Residual Addition"
  add -> norm1: "x + F(x)"
  norm1 -> output: "Norm(x + F(x))"
}

# -----------------------------------------------------------------------------
# Comparison & Legend Container
# -----------------------------------------------------------------------------
Comparison_Notes: {
  near: bottom-center
  
  legend: {
    label: "Mathematical Formulations"
    style: {
      fill: "#F5F5F5"
      stroke: "#666"
      stroke-width: 1
    }

    pre_note: {
      shape: text
      label: "■ Pre-LN: Stable for N-layers"
    }
    pre_formula: {
      class: formula_text
      label: "x_{l+1} = x_l + F(LayerNorm(x_l))"
    }
    
    divider: {
      shape: text
      label: "------------------------------------------------"
    }

    post_note: {
      shape: text
      label: "■ Post-LN: Unstable without Warmup"
    }
    post_formula: {
      class: formula_text
      label: "x_{l+1} = LayerNorm(x_l + F(x_l))"
    }
  }

  analysis: {
    label: "Convergence Characteristics"
    style: {
      fill: "#FFF8E1"
      stroke: "#FFC107"
      stroke-width: 1
    }

    pre_ln_analysis: {
      shape: text
      label: "PRE-LN BENEFITS:\n1. Gradient Flow: ∂L/∂x_l ≈ ∂L/∂x_L (Unimpeded identity).\n2. Initialization: Safe to use large learning rates immediately.\n3. Scalability: Enables training of 100B+ parameter models."
    }
    
    # Corrected the error: Ensuring label is not an empty string or just a space that might be stripped
    spacer_visual: {
      shape: text
      label: "--- Structural Stability Metrics ---"
      style.font-color: "#BDBDBD"
    }

    post_ln_analysis: {
      shape: text
      label: "POST-LN CHALLENGES:\n1. Gradient Scale: Norm at end causes vanishing/exploding gradients.\n2. Warmup: Requires careful LR scheduling to prevent divergence.\n3. Depth: Difficult to converge beyond 24-48 layers without tricks."
    }
  }
}

# Structural comparison connection
Pre_LN -> Post_LN: "LayerNorm Positioning Shift" {
  style: {
    stroke: "#333"
    stroke-width: 2
    stroke-dash: 5
  }
}

# Manual positioning to keep the analysis under the diagrams
Pre_LN -> Comparison_Notes.legend: {
  style.stroke: transparent
}
Post_LN -> Comparison_Notes.analysis: {
  style.stroke: transparent
}