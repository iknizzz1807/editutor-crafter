direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
  # Dimensioning constants for high-precision alignment
  box-width: 320
  box-height: 120
  op-width: 240
  op-height: 80
}

# -----------------------------------------------------------------------------
# GLOBAL CLASSES: INTEL MANUAL SPEC QUALITY
# -----------------------------------------------------------------------------
classes: {
  data-block: {
    shape: rectangle
    width: ${box-width}
    height: ${box-height}
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      font-color: "#0D47A1"
      bold: true
      shadow: true
    }
  }
  attention-block: {
    shape: rectangle
    width: ${box-width}
    height: ${box-height}
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      font-color: "#BF360C"
      bold: true
      shadow: true
    }
  }
  ffn-block: {
    shape: rectangle
    width: ${box-width}
    height: ${box-height}
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      font-color: "#4A148C"
      bold: true
      shadow: true
    }
  }
  operation-block: {
    shape: rectangle
    width: ${op-width}
    height: ${op-height}
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      font-color: "#1B5E20"
      bold: true
      border-radius: 10
    }
  }
  residual-arrow: {
    style: {
      stroke: "#455A64"
      stroke-width: 2
      stroke-dash: 5
      animated: true
    }
  }
  main-arrow: {
    style: {
      stroke: "#1565C0"
      stroke-width: 3
    }
  }
}

# -----------------------------------------------------------------------------
# DIAGRAM CONTENT
# -----------------------------------------------------------------------------
title: {
  label: "ENCODER LAYER ARCHITECTURE (POST-LN) | TDD SPEC v1.0.4"
  shape: text
  near: top-center
  style: {
    font-size: 32
    bold: true
    underline: true
    font-color: "#263238"
  }
}

# Inputs Section
input: {
  class: data-block
  label: "INPUT EMBEDDINGS\nShape: [Batch, Seq, 512]\nType: Float32\nOffset: 0x0000"
  tooltip: "Input tensor with positional encoding integrated"
}

# Sublayer 1: Attention Mechanism
sublayer1: {
  label: "SUBLAYER 1: MULTI-HEAD ATTENTION (MHSA)"
  style: {
    stroke: "#B0BEC5"
    stroke-dash: 4
    fill: "#FDFDFD"
  }
  
  self_attn: {
    class: attention-block
    label: "MULTI-HEAD SELF-ATTENTION\nHeads: 8 | d_k = d_v = 64\nW_Q, W_K, W_V ∈ ℝ^(512×512)"
  }

  add_norm_1: {
    class: operation-block
    label: "ADD & LAYER-NORM\nLN(x + MHSA(x))\nε = 1e-6"
  }
  
  self_attn -> add_norm_1: {
    class: main-arrow
    label: "MHSA_Output [512]"
  }
}

# Sublayer 2: Feed Forward Mechanism
sublayer2: {
  label: "SUBLAYER 2: POINT-WISE FEED-FORWARD (FFN)"
  style: {
    stroke: "#B0BEC5"
    stroke-dash: 4
    fill: "#FDFDFD"
  }

  ffn: {
    class: ffn-block
    label: "FEED-FORWARD NETWORK\nFC1: 512 → 2048 (ReLU)\nFC2: 2048 → 512 (Linear)"
  }

  add_norm_2: {
    class: operation-block
    label: "ADD & LAYER-NORM\nLN(z1 + FFN(z1))\nDropout Rate: 0.1"
  }
  
  ffn -> add_norm_2: {
    class: main-arrow
    label: "FFN_Output [512]"
  }
}

# Output Section
output: {
  class: data-block
  label: "ENCODER REPRESENTATION (z_2)\nShape: [Batch, Seq, 512]\nMemory: ~2MB/Layer"
}

# -----------------------------------------------------------------------------
# SIGNAL ROUTING (CONNECTIONS)
# -----------------------------------------------------------------------------

# Primary Forward Flow
input -> sublayer1.self_attn: {
  class: main-arrow
  label: "x_in"
}

sublayer1.add_norm_1 -> sublayer2.ffn: {
  class: main-arrow
  label: "z_1 (Intermediate State)"
}

sublayer2.add_norm_2 -> output: {
  class: main-arrow
  label: "z_out (Layer Final)"
}

# Residual Identity Connections (Skip Connections)
input -> sublayer1.add_norm_1: {
  class: residual-arrow
  label: "Identity Residual 1"
}

sublayer1.add_norm_1 -> sublayer2.add_norm_2: {
  class: residual-arrow
  label: "Identity Residual 2"
}

# -----------------------------------------------------------------------------
# DOCUMENTATION & LEGEND (FIXED POSITIONING)
# -----------------------------------------------------------------------------

formula_box: {
  shape: rectangle
  label: |md
    ### Encoder Layer Logic (Mathematical Spec)
    ---
    **Sublayer 1 Logic:**
    $Attention(Q, K, V) = \text{softmax}(\frac{QK^T}{\sqrt{d_k}})V$
    $z_1 = \text{LayerNorm}(x + \text{Dropout}(\text{MHSA}(x)))$
    
    **Sublayer 2 Logic:**
    $FFN(z_1) = \text{ReLU}(z_1 W_1 + b_1) W_2 + b_2$
    $z_2 = \text{LayerNorm}(z_1 + \text{Dropout}(FFN(z_1)))$
    
    **Hyperparameters:**
    - $d_{model} = 512$ (Internal Latent Dimension)
    - $d_{ff} = 2048$ (Hidden FFN Dimension)
    - $h = 8$ (Parallel Attention Heads)
    - $\gamma, \beta$ (LayerNorm Learnable Params)
  |
  near: top-right
  style: {
    fill: "#FFFDE7"
    stroke: "#F9A825"
    stroke-width: 1
    font-size: 14
  }
}

legend: {
  label: "IMPLEMENTATION LEGEND"
  shape: rectangle
  near: bottom-left
  style: {
    fill: "#FFFFFF"
    stroke: "#BDBDBD"
    stroke-dash: 4
  }
  
  primary: "Primary Signal Path (Float32 Tensor)" {
    style: {
      stroke: "#1565C0"
      stroke-width: 3
    }
  }
  
  residual: "Identity Shortcut (Gradients Flow-through)" {
    style: {
      stroke: "#455A64"
      stroke-dash: 5
      stroke-width: 2
    }
  }
}

engineering_note: |md
  **INTEGRATION SPECIFICATIONS:**
  1. **Weight Initialization:** Xavier/Glorot Uniform.
  2. **Memory Footprint:** 
     - Parameters: $d_{model}^2 \times 4$ (MHSA) + $d_{model} \times d_{ff} \times 2$ (FFN).
     - Approx. $12.6M$ parameters per Encoder block.
  3. **Operation Ordering:** Post-LN architecture. Norm is applied *after* the residual addition.
  4. **Parallelism:** MHSA heads can be computed concurrently.
| {
  near: top-left
  style: {
    font-size: 11
    font-color: "#37474F"
    fill: "#ECEFF1"
    stroke: "#90A4AE"
  }
}