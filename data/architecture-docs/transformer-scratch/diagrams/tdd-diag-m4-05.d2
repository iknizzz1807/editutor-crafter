direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Transformer Decoder Layer Structure\n(Pre-LN Variant)"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Style definitions
classes: {
  attention_block: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 8
      font-color: "#0D47A1"
    }
  }
  ffn_block: {
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
      border-radius: 8
      font-color: "#BF360C"
    }
  }
  norm_block: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 4
      font-color: "#1B5E20"
    }
  }
  add_block: {
    shape: circle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      border-radius: 50
      font-color: "#4A148C"
    }
  }
  input_output: {
    style: {
      fill: "#ECEFF1"
      stroke: "#455A64"
      stroke-width: 3
      border-radius: 8
      font-color: "#263238"
      bold: true
    }
  }
  external_input: {
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
      border-radius: 8
      font-color: "#B71C1C"
      stroke-dash: 4
    }
  }
  sublayer_container: {
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      stroke-width: 1
      stroke-dash: 2
      border-radius: 12
    }
  }
}

# External inputs (top section)
encoder_output: {
  label: "Encoder Output\n(memory)"
  class: external_input
  tooltip: "Hidden states from encoder\nUsed as Key and Value in cross-attention"
}
tgt_mask: {
  label: "Target Mask\n(Causal)"
  class: external_input
  tooltip: "Lower triangular mask\nPrevents attending to future tokens"
}
src_mask: {
  label: "Source Mask\n(Padding)"
  class: external_input
  tooltip: "Padding mask for encoder output\nPrevents attending to padding tokens"
}

# Main input
decoder_input: {
  label: "Decoder Layer\nInput\n(x)"
  class: input_output
  tooltip: "Input tensor: (batch, seq_len, d_model)\nEither from embedding layer or previous decoder layer"
}

# ==================== SUBLAYER 1: Masked Self-Attention ====================
sublayer1: {
  label: "Sublayer 1: Masked Self-Attention"
  class: sublayer_container
  
  norm1: {
    label: "Layer Norm 1\n(γ₁, β₁)"
    class: norm_block
    tooltip: "Pre-normalization\nLearnable scale γ and shift β\nμ = mean(x), σ = std(x)\noutput = γ · (x-μ)/σ + β"
  }
  
  masked_attn: {
    label: "Masked\nMulti-Head\nSelf-Attention"
    class: attention_block
    tooltip: "Q, K, V all from normalized input\nScaled dot-product attention\nApplied causal mask\nnum_heads parallel attention heads"
    
    q_proj: {
      label: "Q projection\nWq"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }
    k_proj: {
      label: "K projection\nWk"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }
    v_proj: {
      label: "V projection\nWv"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }
    scaled_dp: {
      label: "Scaled\nDot-Product\nAttention"
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
    concat: {
      label: "Concat\nHeads"
      style.fill: "#64B5F6"
      style.stroke: "#1565C0"
    }
    out_proj: {
      label: "Output\nWo"
      style.fill: "#42A5F5"
      style.stroke: "#1565C0"
    }
    
    q_proj -> scaled_dp
    k_proj -> scaled_dp
    v_proj -> scaled_dp
    scaled_dp -> concat
    concat -> out_proj
  }
  
  dropout1: {
    label: "Dropout"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
    style.border-radius: 4
  }
  
  add1: {
    label: "+"
    class: add_block
    tooltip: "Residual connection\nAdds original input to sublayer output"
  }
  
  norm1 -> masked_attn: "Q, K, V" {
    style.stroke-dash: 3
  }
  masked_attn -> dropout1
  dropout1 -> add1: "sublayer\noutput"
}

# ==================== SUBLAYER 2: Cross-Attention ====================
sublayer2: {
  label: "Sublayer 2: Cross-Attention (Encoder-Decoder)"
  class: sublayer_container
  
  norm2: {
    label: "Layer Norm 2\n(γ₂, β₂)"
    class: norm_block
    tooltip: "Pre-normalization before cross-attention"
  }
  
  cross_attn: {
    label: "Multi-Head\nCross-Attention"
    class: attention_block
    tooltip: "Q from decoder, K and V from encoder\nEnables attending to encoder representations\nEach head learns different alignments"
    
    q_proj2: {
      label: "Q from\nDecoder"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }
    k_proj2: {
      label: "K from\nEncoder"
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    v_proj2: {
      label: "V from\nEncoder"
      style.fill: "#C8E6C9"
      style.stroke: "#388E3C"
    }
    scaled_dp2: {
      label: "Scaled\nDot-Product\nAttention"
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
    concat2: {
      label: "Concat\nHeads"
      style.fill: "#64B5F6"
      style.stroke: "#1565C0"
    }
    out_proj2: {
      label: "Output\nWo"
      style.fill: "#42A5F5"
      style.stroke: "#1565C0"
    }
    
    q_proj2 -> scaled_dp2
    k_proj2 -> scaled_dp2
    v_proj2 -> scaled_dp2
    scaled_dp2 -> concat2
    concat2 -> out_proj2
  }
  
  dropout2: {
    label: "Dropout"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
    style.border-radius: 4
  }
  
  add2: {
    label: "+"
    class: add_block
    tooltip: "Residual connection\nAdds input to cross-attention output"
  }
  
  norm2 -> cross_attn: "Q"
  cross_attn -> dropout2
  dropout2 -> add2: "sublayer\noutput"
}

# ==================== SUBLAYER 3: Feed-Forward Network ====================
sublayer3: {
  label: "Sublayer 3: Position-wise Feed-Forward Network"
  class: sublayer_container
  
  norm3: {
    label: "Layer Norm 3\n(γ₃, β₃)"
    class: norm_block
    tooltip: "Pre-normalization before FFN"
  }
  
  ffn: {
    label: "FFN"
    class: ffn_block
    tooltip: "Two linear transformations with ReLU\nFFN(x) = max(0, xW₁ + b₁)W₂ + b₂\nd_ff typically = 4 × d_model"
    
    linear1: {
      label: "Linear 1\n(d_model → d_ff)"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
    }
    relu: {
      label: "ReLU"
      style.fill: "#FFCC80"
      style.stroke: "#EF6C00"
      shape: diamond
    }
    linear2: {
      label: "Linear 2\n(d_ff → d_model)"
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
    }
    
    linear1 -> relu
    relu -> linear2
  }
  
  dropout3: {
    label: "Dropout"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
    style.border-radius: 4
  }
  
  add3: {
    label: "+"
    class: add_block
    tooltip: "Final residual connection\nAdds input to FFN output"
  }
  
  norm3 -> ffn
  ffn -> dropout3
  dropout3 -> add3: "sublayer\noutput"
}

# Main output
decoder_output: {
  label: "Decoder Layer\nOutput\n(x')"
  class: input_output
  tooltip: "Output tensor: (batch, seq_len, d_model)\nPassed to next decoder layer or final projection"
}

# ==================== MAIN DATA FLOW ====================
decoder_input -> sublayer1.norm1: "x" {
  style: {
    stroke-width: 3
    stroke: "#1565C0"
  }
}

# Residual skip connection 1
sublayer1_add1_residual: {
  label: ""
  shape: circle
  style.opacity: 0
}
decoder_input -> sublayer1_add1_residual: {
  style: {
    stroke-width: 2
    stroke: "#7B1FA2"
    stroke-dash: 2
  }
}
sublayer1_add1_residual -> sublayer1.add1: "residual" {
  style: {
    stroke-width: 2
    stroke: "#7B1FA2"
    stroke-dash: 2
  }
}

sublayer1.add1 -> sublayer2.norm2: "x₁" {
  style: {
    stroke-width: 3
    stroke: "#1565C0"
  }
}

# Residual skip connection 2
sublayer2_add2_residual: {
  label: ""
  shape: circle
  style.opacity: 0
}
sublayer1.add1 -> sublayer2_add2_residual: {
  style: {
    stroke-width: 2
    stroke: "#7B1FA2"
    stroke-dash: 2
  }
}
sublayer2_add2_residual -> sublayer2.add2: "residual" {
  style: {
    stroke-width: 2
    stroke: "#7B1FA2"
    stroke-dash: 2
  }
}

sublayer2.add2 -> sublayer3.norm3: "x₂" {
  style: {
    stroke-width: 3
    stroke: "#1565C0"
  }
}

# Residual skip connection 3
sublayer3_add3_residual: {
  label: ""
  shape: circle
  style.opacity: 0
}
sublayer2.add2 -> sublayer3_add3_residual: {
  style: {
    stroke-width: 2
    stroke: "#7B1FA2"
    stroke-dash: 2
  }
}
sublayer3_add3_residual -> sublayer3.add3: "residual" {
  style: {
    stroke-width: 2
    stroke: "#7B1FA2"
    stroke-dash: 2
  }
}

sublayer3.add3 -> decoder_output: "x₃" {
  style: {
    stroke-width: 3
    stroke: "#1565C0"
  }
}

# ==================== EXTERNAL INPUT CONNECTIONS ====================
tgt_mask -> sublayer1.masked_attn.scaled_dp: "causal\nmask" {
  style: {
    stroke: "#C62828"
    stroke-dash: 4
    stroke-width: 2
  }
}

encoder_output -> sublayer2.cross_attn.k_proj2: "K" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}
encoder_output -> sublayer2.cross_attn.v_proj2: "V" {
  style: {
    stroke: "#388E3C"
    stroke-width: 2
  }
}

src_mask -> sublayer2.cross_attn.scaled_dp2: "padding\nmask" {
  style: {
    stroke: "#C62828"
    stroke-dash: 4
    stroke-width: 2
  }
}

# ==================== LEGEND ====================
legend: {
  label: "Legend"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 8
  }
  legend_title: {
    label: "Component Types"
    shape: text
    style.bold: true
  }
  att_legend: {
    label: "Attention Block"
    class: attention_block
  }
  ffn_legend: {
    label: "FFN Block"
    class: ffn_block
  }
  norm_legend: {
    label: "Layer Normalization"
    class: norm_block
  }
  add_legend: {
    label: "+"
    class: add_block
  }
  ext_legend: {
    label: "External Input"
    class: external_input
  }
  legend_title -> att_legend -> ffn_legend -> norm_legend -> add_legend -> ext_legend: {
    style.opacity: 0
  }
}

# ==================== ANNOTATIONS ====================
pre_ln_note: {
  label: "Pre-LN Pattern:\nLayerNorm applied BEFORE sublayer ops\nAdv: Stable training, better gradient flow"
  shape: text
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    border-radius: 8
    font-size: 11
    italic: true
  }
}
formula_note: {
  label: "Pre-LN: x + Dropout(sublayer(LN(x)))\nPost-LN: LN(x + Dropout(sublayer(x)))"
  shape: text
  style: {
    fill: "#E8EAF6"
    stroke: "#3F51B5"
    border-radius: 8
    font-size: 11
    font: mono
  }
}
dimension_note: {
  label: "d_k = d_model / heads\nd_ff = 4 × d_model"
  shape: text
  style: {
    fill: "#E0F7FA"
    stroke: "#00838F"
    border-radius: 8
    font-size: 11
  }
}