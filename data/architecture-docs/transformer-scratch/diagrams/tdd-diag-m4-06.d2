direction: right
vars: {
  d2-padding: 40
}
# Theme for technical documentation
theme: {
  colors: {
    background: "#1a1a2e"
    text: "#e8e8e8"
    encoder: "#3d5a80"
    decoder: "#ee6c4d"
    attention: "#98c1d9"
    query: "#f7b267"
    key: "#7eb8da"
    value: "#9bc53d"
    flow: "#e0fbfc"
  }
}
# Title
title: {
  label: Cross-Attention Information Flow
  shape: text
  style.font-size: 28
  style.bold: true
  style.fill: "transparent"
  style.stroke: "transparent"
}
subtitle: {
  label: "Decoder queries 'interrogate' encoder representations"
  shape: text
  style.font-size: 14
  style.fill: "transparent"
  style.stroke: "transparent"
  style.italic: true
}
# ENCODER BLOCK
encoder_block: {
  label: "ENCODER STACK"
  style.fill: "#3d5a80"
  style.stroke: "#293241"
  style.stroke-width: 3
  style.border-radius: 8
  encoder_layers: {
    label: "6× Encoder Layers"
    shape: rectangle
    style.fill: "#293241"
    style.stroke: "#3d5a80"
    enc_self_attn: {
      label: "Self-Attention\n+ FFN"
      shape: rectangle
      style.fill: "#3d5a80"
      style.stroke: "#98c1d9"
    }
  }
  encoder_output: {
    label: "Encoder Output\nH_enc ∈ ℝ^(n×d)"
    shape: hexagon
    style.fill: "#293241"
    style.stroke: "#7eb8da"
    style.stroke-width: 2
    style.font-color: "#e0fbfc"
  }
  encoder_layers -> encoder_output: {
    label: "contextualized\nrepresentations"
    style.stroke: "#98c1d9"
    style.stroke-width: 2
  }
}
# DECODER BLOCK
decoder_block: {
  label: "DECODER STACK"
  style.fill: "#ee6c4d"
  style.stroke: "#293241"
  style.stroke-width: 3
  style.border-radius: 8
  decoder_input: {
    label: "Decoder State\nH_dec ∈ ℝ^(m×d)"
    shape: hexagon
    style.fill: "#293241"
    style.stroke: "#f7b267"
    style.stroke-width: 2
    style.font-color: "#e0fbfc"
  }
  query_proj: {
    label: "Query Projection\nW_Q"
    shape: diamond
    style.fill: "#f7b267"
    style.stroke: "#293241"
    style.stroke-width: 2
  }
  query_vectors: {
    label: "Query Vectors\nQ = H_dec · W_Q\nQ ∈ ℝ^(m×d_k)"
    shape: rectangle
    style.fill: "#293241"
    style.stroke: "#f7b267"
    style.stroke-width: 2
    style.font-color: "#f7b267"
  }
  decoder_input -> query_proj: {
    style.stroke: "#f7b267"
    style.stroke-width: 2
  }
  query_proj -> query_vectors: {
    label: "project to\nquery space"
    style.stroke: "#f7b267"
    style.stroke-width: 2
  }
}
# KEY/VALUE PROJECTIONS (from encoder)
kv_projections: {
  label: "Key/Value Projections"
  style.fill: "#1a1a2e"
  style.stroke: "transparent"
  key_proj: {
    label: "Key Projection\nW_K"
    shape: diamond
    style.fill: "#7eb8da"
    style.stroke: "#293241"
    style.stroke-width: 2
  }
  value_proj: {
    label: "Value Projection\nW_V"
    shape: diamond
    style.fill: "#9bc53d"
    style.stroke: "#293241"
    style.stroke-width: 2
  }
  key_vectors: {
    label: "Key Vectors\nK = H_enc · W_K\nK ∈ ℝ^(n×d_k)"
    shape: rectangle
    style.fill: "#293241"
    style.stroke: "#7eb8da"
    style.stroke-width: 2
    style.font-color: "#7eb8da"
  }
  value_vectors: {
    label: "Value Vectors\nV = H_enc · W_V\nV ∈ ℝ^(n×d_v)"
    shape: rectangle
    style.fill: "#293241"
    style.stroke: "#9bc53d"
    style.stroke-width: 2
    style.font-color: "#9bc53d"
  }
  key_proj -> key_vectors: {
    style.stroke: "#7eb8da"
    style.stroke-width: 2
  }
  value_proj -> value_vectors: {
    style.stroke: "#9bc53d"
    style.stroke-width: 2
  }
}
# CROSS-ATTENTION MECHANISM
cross_attention: {
  label: "CROSS-ATTENTION MECHANISM"
  style.fill: "#98c1d9"
  style.stroke: "#293241"
  style.stroke-width: 3
  style.border-radius: 8
  qk_matmul: {
    label: "Q @ K^T"
    shape: circle
    style.fill: "#3d5a80"
    style.stroke: "#e0fbfc"
    style.font-color: "#e0fbfc"
  }
  scale: {
    label: "Scale\n÷ √d_k"
    shape: rectangle
    style.fill: "#293241"
    style.stroke: "#98c1d9"
    style.font-color: "#e0fbfc"
  }
  softmax: {
    label: "Softmax\n(rows)"
    shape: rectangle
    style.fill: "#ee6c4d"
    style.stroke: "#293241"
    style.font-color: "#e0fbfc"
  }
  attention_scores: {
    label: "Attention Scores\nα_ij = softmax(\n  Q_i · K_j / √d_k)"
    shape: parallelogram
    style.fill: "#293241"
    style.stroke: "#f7b267"
    style.stroke-width: 2
    style.font-color: "#e0fbfc"
  }
  weighted_sum: {
    label: "Weighted Sum\nΣ_j α_ij · V_j"
    shape: circle
    style.fill: "#9bc53d"
    style.stroke: "#293241"
    style.font-color: "#293241"
  }
  qk_matmul -> scale -> softmax -> attention_scores -> weighted_sum: {
    style.stroke: "#e0fbfc"
    style.stroke-width: 2
  }
}
# MULTI-HEAD OUTPUT
attention_output: {
  label: "Cross-Attention Output"
  style.fill: "#1a1a2e"
  style.stroke: "transparent"
  concat: {
    label: "Concat\nHeads"
    shape: rectangle
    style.fill: "#98c1d9"
    style.stroke: "#293241"
    style.font-color: "#293241"
  }
  output_proj: {
    label: "Output Projection\nW_O"
    shape: diamond
    style.fill: "#3d5a80"
    style.stroke: "#98c1d9"
  }
  context_vector: {
    label: "Context Vector\nC ∈ ℝ^(m×d)"
    shape: hexagon
    style.fill: "#293241"
    style.stroke: "#98c1d9"
    style.stroke-width: 2
    style.font-color: "#98c1d9"
  }
  concat -> output_proj -> context_vector: {
    style.stroke: "#98c1d9"
    style.stroke-width: 2
  }
}
# DECODER OUTPUT
decoder_ffn: {
  label: "FFN + LayerNorm\n(Decoder)"
  shape: rectangle
  style.fill: "#ee6c4d"
  style.stroke: "#293241"
  style.stroke-width: 2
  style.font-color: "#e0fbfc"
}
final_output: {
  label: "Output to Next\nDecoder Layer"
  shape: parallelogram
  style.fill: "#293241"
  style.stroke: "#ee6c4d"
  style.stroke-width: 2
  style.font-color: "#ee6c4d"
}
# CONNECTIONS - Encoder to KV Projections
encoder_block.encoder_output -> kv_projections.key_proj: {
  label: "H_enc"
  style.stroke: "#7eb8da"
  style.stroke-width: 3
  style.animated: true
}
encoder_block.encoder_output -> kv_projections.value_proj: {
  label: "H_enc"
  style.stroke: "#9bc53d"
  style.stroke-width: 3
  style.animated: true
}
# CONNECTIONS - Query to Cross-Attention
decoder_block.query_vectors -> cross_attention.qk_matmul: {
  label: "Q\n(decoder asks)"
  style.stroke: "#f7b267"
  style.stroke-width: 3
  style.animated: true
}
# CONNECTIONS - Key to Cross-Attention
kv_projections.key_vectors -> cross_attention.qk_matmul: {
  label: "K^T\n(encoder answers)"
  style.stroke: "#7eb8da"
  style.stroke-width: 3
  style.animated: true
}
# CONNECTIONS - Value to Cross-Attention
kv_projections.value_vectors -> cross_attention.weighted_sum: {
  label: "V\n(encoder content)"
  style.stroke: "#9bc53d"
  style.stroke-width: 3
  style.animated: true
}
# CONNECTIONS - Cross-Attention to Output
cross_attention.weighted_sum -> attention_output.concat: {
  label: "attention\nweights × V"
  style.stroke: "#98c1d9"
  style.stroke-width: 2
}
attention_output.context_vector -> decoder_ffn: {
  style.stroke: "#98c1d9"
  style.stroke-width: 2
}
decoder_ffn -> final_output: {
  label: "enriched with\nencoder context"
  style.stroke: "#ee6c4d"
  style.stroke-width: 2
}
# ANNOTATION BOX
annotation: {
  label: |md
    ### Cross-Attention: The "Interrogation" Pattern
    **Query (Q)**: "What information do I need from the encoder?"
    - Comes from decoder's current state
    - Represents the decoder's "question"
    **Key (K)**: "What information do I contain?"
    - Comes from encoder output
    - Index for matching against queries
    **Value (V)**: "What actual content do I offer?"
    - Comes from encoder output  
    - The information to be retrieved
    **Attention Score**: Compatibility(Q, K)
    - High score = relevant encoder position
    - Decoder "attends" to relevant encoder states
  |
  shape: rectangle
  style.fill: "#293241"
  style.stroke: "#98c1d9"
  style.stroke-width: 2
  style.border-radius: 8
  style.font-color: "#e0fbfc"
  near: bottom-center
}
# LEGEND
legend: {
  label: "Data Flow Legend"
  style.fill: "#293241"
  style.stroke: "#3d5a80"
  style.border-radius: 4
  enc_flow: {
    label: "Encoder → Attention"
    shape: rectangle
    style.fill: "transparent"
    style.stroke: "transparent"
  }
  dec_flow: {
    label: "Decoder → Query"
    shape: rectangle
    style.fill: "transparent"
    style.stroke: "transparent"
  }
  atn_flow: {
    label: "Attention Processing"
    shape: rectangle
    style.fill: "transparent"
    style.stroke: "transparent"
  }
}
# Layout positioning hints
title -> subtitle -> encoder_block: {style.opacity: 0}