vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

title: {
  label: "Causal Mask in Decoder Self-Attention"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

subtitle: {
  label: "Upper-Triangular Mask Pattern: Positions Attend Only to Self and Earlier Positions"
  shape: text
  near: top-center
  style: {
    font-size: 14
    italic: true
  }
}

# Sequence Position Labels
positions: {
  label: "Input Sequence Tokens"
  direction: right
  p0: "Position 0\n(TOKEN_0)" { style.fill: "#E8F4FD" }
  p1: "Position 1\n(TOKEN_1)" { style.fill: "#E8F4FD" }
  p2: "Position 2\n(TOKEN_2)" { style.fill: "#E8F4FD" }
  p3: "Position 3\n(TOKEN_3)" { style.fill: "#E8F4FD" }
  p4: "Position 4\n(TOKEN_4)" { style.fill: "#E8F4FD" }
}

# -----------------------------------------------------------------------------
# 1. Attention Score Matrix (Before Masking)
# -----------------------------------------------------------------------------
attention_matrix_container: {
  label: "Attention Score Matrix (scores = Q @ K^T / sqrt(d_k))"
  style: {
    fill: "#FAFAFA"
    stroke: "#333333"
    stroke-width: 2
  }
  
  col_header_container: {
    grid-columns: 5
    style.stroke: transparent
    col_k0: "K₀" { shape: text; style.bold: true }
    col_k1: "K₁" { shape: text; style.bold: true }
    col_k2: "K₂" { shape: text; style.bold: true }
    col_k3: "K₃" { shape: text; style.bold: true }
    col_k4: "K₄" { shape: text; style.bold: true }
  }
  
  row_label_container: {
    grid-rows: 5
    style.stroke: transparent
    row_q0: "Q₀" { shape: text; style.bold: true }
    row_q1: "Q₁" { shape: text; style.bold: true }
    row_q2: "Q₂" { shape: text; style.bold: true }
    row_q3: "Q₃" { shape: text; style.bold: true }
    row_q4: "Q₄" { shape: text; style.bold: true }
  }

  score_matrix: {
    grid-columns: 5
    style.stroke: transparent
    # Row 0
    cell_0_0: "s₀,₀" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_0_1: "s₀,₁" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_0_2: "s₀,₂" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_0_3: "s₀,₃" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_0_4: "s₀,₄" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    # Row 1
    cell_1_0: "s₁,₀" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_1_1: "s₁,₁" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_1_2: "s₁,₂" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_1_3: "s₁,₃" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_1_4: "s₁,₄" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    # Row 2
    cell_2_0: "s₂,₀" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_2_1: "s₂,₁" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_2_2: "s₂,₂" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_2_3: "s₂,₃" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_2_4: "s₂,₄" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    # Row 3
    cell_3_0: "s₃,₀" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_3_1: "s₃,₁" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_3_2: "s₃,₂" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_3_3: "s₃,₃" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_3_4: "s₃,₄" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    # Row 4
    cell_4_0: "s₄,₀" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_4_1: "s₄,₁" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_4_2: "s₄,₂" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_4_3: "s₄,₃" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
    cell_4_4: "s₄,₄" { style.fill: "#C8E6C9"; style.stroke: "#2E7D32" }
  }
}

# -----------------------------------------------------------------------------
# 2. Causal Mask Matrix
# -----------------------------------------------------------------------------
