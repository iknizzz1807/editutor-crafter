vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

# Transformer Encoder Stack - Pre-LN (LayerNorm-Inside) Variant
# Implementation-grade architectural specification for deep learning engineers.

classes: {
  tensor_shape: {
    style: {
      font-size: 11
      italic: true
      font-color: "#455A64"
    }
  }
  sublayer_box: {
    style: {
      fill: "#F8F9FA"
      stroke: "#90A4AE"
      stroke-width: 1
      stroke-dash: 3
      border-radius: 4
    }
  }
  norm_node: {
    shape: rectangle
    label: "LayerNorm\n(d_model=512)"
    style: {
      fill: "#E1F5FE"
      stroke: "#03A9F4"
      stroke-width: 2
    }
  }
  op_node: {
    shape: rectangle
    style: {
      fill: "#E8EAF6"
      stroke: "#3F51B5"
      bold: true
      stroke-width: 2
    }
  }
  add_node: {
    shape: circle
    label: "+"
    tooltip: "Residual Addition: x_out = x_in + Sublayer(Norm(x_in))"
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      stroke-width: 3
    }
  }
  residual_conn: {
    style: {
      stroke: "#FF9800"
      stroke-width: 3
      stroke-dash: 4
      animated: true
    }
  }
  data_bus: {
    style: {
      stroke: "#263238"
      stroke-width: 2
    }
  }
}

input: {
  shape: rectangle
  label: "Input Embeddings + Positional Encoding\nShape: [Batch, SeqLen, 512]"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 3
  }
}

encoder_stack: "Encoder Stack (N Layers)" {
  style: {
    fill: "#F5F5F5"
    stroke: "#263238"
    stroke-width: 3
    stroke-dash: 0
  }

  layer_1: "Encoder Layer 1" {
    style: {
      fill: "#FFFFFF"
      stroke: "#37474F"
      stroke-width: 2
    }
    
    mhsa_block: "Self-Attention Sublayer" {
      class: sublayer_box
      norm: { class: norm_node }
      attn: "Multi-Head Attention\nh=8, d_k=64" { 
        class: op_node 
        tooltip: "Attention(Q,K,V) = softmax(QK^T/√d_k)V"
      }
      add: { class: add_node }
      
      norm -> attn: "Normalized Flow"
      attn -> add: "Sublayer Output"
    }

    ffn_block: "Feed-Forward Sublayer" {
      class: sublayer_box
      norm: { class: norm_node }
      ffn: "Position-wise FFN\nd_ff=2048" { 
        class: op_node 
        tooltip: "FFN(x) = max(0, xW1 + b1)W2 + b2"
      }
      add: { class: add_node }
      
      norm -> ffn: "Normalized Flow"
      ffn -> add: "Sublayer Output"
    }

    mhsa_block.add -> ffn_block.norm: "Residual Result"
    
    # Residual Anchors
    mhsa_res_in: "" { shape: circle; width: 0; height: 0; style.opacity: 0 }
    ffn_res_in: "" { shape: circle; width: 0; height: 0; style.opacity: 0 }

    # Connection Logic for Layer 1 Residuals
    mhsa_res_in -> mhsa_block.norm: { class: data_bus }
    mhsa_res_in -> mhsa_block.add: "Identity Path" { class: residual_conn }
    
    ffn_res_in -> ffn_block.norm: { class: data_bus }
    ffn_res_in -> ffn_block.add: "Identity Path" { class: residual_conn }
    
    mhsa_block.add -> ffn_res_in: { class: data_bus }
  }

  ellipsis: "..." {
    shape: text
    style.font-size: 40
  }

  layer_n: "Encoder Layer N" {
    style: {
      fill: "#FFFFFF"
      stroke: "#37474F"
      stroke-width: 2
    }
    
    mhsa_block: "Self-Attention Sublayer" {
      class: sublayer_box
      norm: { class: norm_node }
      attn: "Multi-Head Attention" { class: op_node }
      add: { class: add_node }
      norm -> attn -> add
    }

    ffn_block: "Feed-Forward Sublayer" {
      class: sublayer_box
      norm: { class: norm_node }
      ffn: "Position-wise FFN" { class: op_node }
      add: { class: add_node }
      norm -> ffn -> add
    }

    mhsa_block.add -> ffn_block.norm
    
    mhsa_res_in: "" { shape: circle; width: 0; height: 0; style.opacity: 0 }
    ffn_res_in: "" { shape: circle; width: 0; height: 0; style.opacity: 0 }

    mhsa_res_in -> mhsa_block.norm
    mhsa_res_in -> mhsa_block.add: { class: residual_conn }
    
    ffn_res_in -> ffn_block.norm
    ffn_res_in -> ffn_block.add: { class: residual_conn }
    
    mhsa_block.add -> ffn_res_in
  }

  layer_1 -> ellipsis: { class: data_bus }
  ellipsis -> layer_n: { class: data_bus }
}

final_norm: "Final LayerNorm\n(Global Stream Norm)" {
  class: norm_node
  style.fill: "#FFECB3"
}

output: {
  shape: rectangle
  label: "Encoder Memory Keys/Values (Z)\nTo Decoder Cross-Attention"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 3
  }
}

# Top-level Global Wiring
input -> encoder_stack.layer_1.mhsa_res_in: "x_0" { class: data_bus }
encoder_stack.layer_n.ffn_block.add -> final_norm: "x_N (Pre-Final)" { class: data_bus }
final_norm -> output: "z" { class: data_bus }

# Detailed Legend & Implementation Specs
legend: "Architecture Specification" {
  near: bottom-right
  
  pre_ln: |md
  ### Pre-LN (LayerNorm-Inside)
  In this variant, LayerNorm is applied **before** 
  the sublayer operation. 
  
  **Equation:**
  `x_{l+1} = x_l + Sublayer(LayerNorm(x_l))`
  
  **Advantages:**
  - Improved gradient stability.
  - No warm-up period required for training.
  - Identity branch is strictly preserved.
  | {
    shape: rectangle
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
  }
  
  dims: |md
  ### Tensor Details
  - **d_model**: 512
  - **d_ff**: 2048 (4x expansion)
  - **Heads (h)**: 8
  - **d_k/d_v**: 64 (d_model / h)
  - **Param Count**: ~O(N * d_model^2)
  | {
    shape: rectangle
    style.fill: "#E1F5FE"
    style.stroke: "#03A9F4"
  }
}

# Implementation Tooltips
encoder_stack.layer_1.mhsa_block.attn.tooltip: "Learnable weights: W_Q, W_K, W_V ∈ R^{d_model × d_model}"
encoder_stack.layer_1.ffn_block.ffn.tooltip: "Linear1: 512->2048, Linear2: 2048->512"

# Visual Indicators for the Residual Identity Paths
(encoder_stack.layer_1.mhsa_res_in -> encoder_stack.layer_1.mhsa_block.add)[0].label: "Identity Stream"
(encoder_stack.layer_1.ffn_res_in -> encoder_stack.layer_1.ffn_block.add)[0].label: "Identity Stream"