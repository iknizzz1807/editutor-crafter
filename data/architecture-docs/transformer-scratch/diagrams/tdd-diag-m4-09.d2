direction: down
layout-engine: elk
theme-id: 4
title: {
  label: "Decoder Stack Composition\nTransformer Architecture - Cross-Attention Flow"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Legend
legend: {
  label: "Legend"
  shape: rectangle
  style: {
    stroke-dash: 4
    fill: "#f8f9fa"
  }
  legend_container: {
    enc_out_leg: {
      label: "Encoder Output\n(K, V)"
      shape: rectangle
      style.fill: "#e8f5e9"
    }
    res_leg: {
      label: "Residual\nConnection"
      shape: rectangle
      style.fill: "#e3f2fd"
    }
    attn_leg: {
      label: "Attention\nSublayer"
      shape: rectangle
      style.fill: "#fff3e0"
    }
    ffn_leg: {
      label: "Feed-Forward\nNetwork"
      shape: rectangle
      style.fill: "#fce4ec"
    }
    ln_leg: {
      label: "Layer\nNormalization"
      shape: rectangle
      style.fill: "#f3e5f5"
    }
  }
}
# Input embedding input
Input_Embeddings: {
  label: "Input Embeddings\n+ Positional Encoding"
  shape: rectangle
  style: {
    fill: "#bbdefb"
    stroke: "#1976d2"
    stroke-width: 2
  }
}
# Encoder Output - broadcasts to all decoder layers
Encoder_Output: {
  label: "Encoder Output\n(K, V for Cross-Attention)"
  shape: rectangle
  style: {
    fill: "#c8e6c9"
    stroke: "#388e3c"
    stroke-width: 3
  }
}
# Branch point for encoder output
encoder_branch: {
  label: "Broadcast to\nAll Layers"
  shape: diamond
  style: {
    fill: "#a5d6a7"
    stroke: "#2e7d32"
  }
}
# Decoder Layer 1
Decoder_Layer_1: {
  label: "Decoder Layer 1"
  shape: rectangle
  style: {
    fill: "#fafafa"
    stroke: "#424242"
    stroke-width: 2
  }
  input_1: {
    label: "Input x₁"
    shape: circle
    style.fill: "#e3f2fd"
  }
  ln1_1: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  masked_self_attn_1: {
    label: "Masked\nSelf-Attention\n(Q, K, V from x₁)"
    shape: rectangle
    style.fill: "#ffe0b2"
  }
  add1_1: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  ln2_1: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  cross_attn_1: {
    label: "Cross-Attention\n(Q from x₁, K,V\nfrom Encoder)"
    shape: rectangle
    style.fill: "#ffcc80"
    style: {
      stroke: "#e65100"
      stroke-width: 3
    }
  }
  add2_1: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  ln3_1: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  ffn_1: {
    label: "FFN\nd_model → d_ff → d_model"
    shape: rectangle
    style.fill: "#f8bbd9"
  }
  add3_1: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  output_1: {
    label: "Output x₁'"
    shape: circle
    style.fill: "#c8e6c9"
  }
  # Internal connections
  input_1 -> ln1_1 -> masked_self_attn_1 -> add1_1
  input_1 -> add1_1: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add1_1 -> ln2_1 -> cross_attn_1 -> add2_1
  add1_1 -> add2_1: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add2_1 -> ln3_1 -> ffn_1 -> add3_1
  add2_1 -> add3_1: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add3_1 -> output_1
}
# Decoder Layer 2
Decoder_Layer_2: {
  label: "Decoder Layer 2"
  shape: rectangle
  style: {
    fill: "#fafafa"
    stroke: "#424242"
    stroke-width: 2
  }
  input_2: {
    label: "Input x₂"
    shape: circle
    style.fill: "#e3f2fd"
  }
  ln1_2: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  masked_self_attn_2: {
    label: "Masked\nSelf-Attention\n(Q, K, V from x₂)"
    shape: rectangle
    style.fill: "#ffe0b2"
  }
  add1_2: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  ln2_2: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  cross_attn_2: {
    label: "Cross-Attention\n(Q from x₂, K,V\nfrom Encoder)"
    shape: rectangle
    style.fill: "#ffcc80"
    style: {
      stroke: "#e65100"
      stroke-width: 3
    }
  }
  add2_2: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  ln3_2: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  ffn_2: {
    label: "FFN\nd_model → d_ff → d_model"
    shape: rectangle
    style.fill: "#f8bbd9"
  }
  add3_2: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  output_2: {
    label: "Output x₂'"
    shape: circle
    style.fill: "#c8e6c9"
  }
  # Internal connections
  input_2 -> ln1_2 -> masked_self_attn_2 -> add1_2
  input_2 -> add1_2: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add1_2 -> ln2_2 -> cross_attn_2 -> add2_2
  add1_2 -> add2_2: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add2_2 -> ln3_2 -> ffn_2 -> add3_2
  add2_2 -> add3_2: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add3_2 -> output_2
}
# Ellipsis to indicate N layers
layer_ellipsis: {
  label: "⋮\n(Layers 3 to N-1)\n⋮"
  shape: text
  style: {
    font-size: 24
  }
}
# Decoder Layer N
Decoder_Layer_N: {
  label: "Decoder Layer N (N=6)"
  shape: rectangle
  style: {
    fill: "#fafafa"
    stroke: "#424242"
    stroke-width: 2
  }
  input_n: {
    label: "Input xₙ"
    shape: circle
    style.fill: "#e3f2fd"
  }
  ln1_n: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  masked_self_attn_n: {
    label: "Masked\nSelf-Attention\n(Q, K, V from xₙ)"
    shape: rectangle
    style.fill: "#ffe0b2"
  }
  add1_n: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  ln2_n: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  cross_attn_n: {
    label: "Cross-Attention\n(Q from xₙ, K,V\nfrom Encoder)"
    shape: rectangle
    style.fill: "#ffcc80"
    style: {
      stroke: "#e65100"
      stroke-width: 3
    }
  }
  add2_n: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  ln3_n: {
    label: "LayerNorm"
    shape: rectangle
    style.fill: "#f3e5f5"
  }
  ffn_n: {
    label: "FFN\nd_model → d_ff → d_model"
    shape: rectangle
    style.fill: "#f8bbd9"
  }
  add3_n: {
    label: "+"
    shape: circle
    style.fill: "#bbdefb"
  }
  output_n: {
    label: "Output xₙ'"
    shape: circle
    style.fill: "#c8e6c9"
  }
  # Internal connections
  input_n -> ln1_n -> masked_self_attn_n -> add1_n
  input_n -> add1_n: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add1_n -> ln2_n -> cross_attn_n -> add2_n
  add1_n -> add2_n: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add2_n -> ln3_n -> ffn_n -> add3_n
  add2_n -> add3_n: {
    label: "residual"
    style: {
      stroke-dash: 3
      stroke: "#1976d2"
    }
  }
  add3_n -> output_n
}
# Final LayerNorm (Pre-LN variant)
Final_LayerNorm: {
  label: "Final LayerNorm\n(Pre-LN variant)"
  shape: rectangle
  style: {
    fill: "#e1bee7"
    stroke: "#7b1fa2"
    stroke-width: 2
  }
}
# Output projection
Output_Projection: {
  label: "Linear Projection\n→ Softmax"
  shape: rectangle
  style: {
    fill: "#90caf9"
    stroke: "#1565c0"
    stroke-width: 2
  }
}
Output: {
  label: "Output\nProbabilities"
  shape: rectangle
  style: {
    fill: "#a5d6a7"
    stroke: "#2e7d32"
    stroke-width: 2
  }
}
# Vertical stack connections
Input_Embeddings -> Decoder_Layer_1.input_1: {
  label: "target\nembeddings"
}
Decoder_Layer_1.output_1 -> Decoder_Layer_2.input_2: {
  label: "x₁'"
}
Decoder_Layer_2.output_2 -> layer_ellipsis
layer_ellipsis -> Decoder_Layer_N.input_n
Decoder_Layer_N.output_n -> Final_LayerNorm: {
  label: "xₙ'"
}
Final_LayerNorm -> Output_Projection
Output_Projection -> Output
# Encoder output branching to all cross-attention layers
Encoder_Output -> encoder_branch
encoder_branch -> Decoder_Layer_1.cross_attn_1: {
  label: "K, V"
  style: {
    stroke: "#388e3c"
    stroke-width: 3
  }
}
encoder_branch -> Decoder_Layer_2.cross_attn_2: {
  label: "K, V"
  style: {
    stroke: "#388e3c"
    stroke-width: 3
  }
}
encoder_branch -> Decoder_Layer_N.cross_attn_n: {
  label: "K, V"
  style: {
    stroke: "#388e3c"
    stroke-width: 3
  }
}
# Annotation for key architecture decision
annotation: {
  label: "KEY: Encoder output provides K, V matrices\nto EVERY decoder layer's cross-attention.\nThis allows each layer to attend to the\nfull source sequence representation."
  shape: rectangle
  style: {
    fill: "#fff9c4"
    stroke: "#f9a825"
    stroke-dash: 4
    font: mono
  }
}