direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 300
  }
}

# Style definitions
classes: {
  component: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  sublayer: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
  }
  data: {
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
      shape: diamond
    }
  }
  flow: {
    style: {
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  residual: {
    style: {
      stroke: "#7B1FA2"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  cross: {
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
    }
  }
}

# Title
title: {
  label: "Full Transformer Wiring Diagram\nEncoder-Decoder Architecture"
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# ====================
# INPUT SECTION
# ====================
inputs: {
  label: "Inputs"
  src_tokens: {
    label: "Source Tokens\n[src_seq_len]"
    shape: hexagon
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
    }
  }
  tgt_tokens: {
    label: "Target Tokens\n[tgt_seq_len]"
    shape: hexagon
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
    }
  }
}

# ====================
# SOURCE EMBEDDING BRANCH
# ====================
source_embedding: {
  label: "Source Embedding"
  token_emb_src: {
    label: "TokenEmbedding\n(vocab_size, d_model)"
    class: component
  }
  pos_enc_src: {
    label: "PositionalEncoding\n(max_len, d_model)"
    class: component
  }
  add_src: {
    label: "+"
    shape: circle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  dropout_src: {
    label: "Dropout\n(p=0.1)"
    shape: rectangle
    class: sublayer
  }
  token_emb_src -> add_src: "element-wise" {class: flow}
  pos_enc_src -> add_src: "element-wise" {class: flow}
  add_src -> dropout_src {class: flow}
}

# ====================
# ENCODER STACK
# ====================
encoder_stack: {
  label: "Encoder Stack (N layers)"
  encoder_layer_1: {
    label: "EncoderLayer 1"
    enc_self_attn_1: {
      label: "MultiHeadAttention\n(Self-Attention)"
      class: sublayer
    }
    enc_norm1_1: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    enc_ffn_1: {
      label: "PositionWiseFFN\n(d_model → d_ff → d_model)"
      class: sublayer
    }
    enc_norm2_1: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    enc_self_attn_1 -> enc_norm1_1 {class: flow}
    enc_norm1_1 -> enc_ffn_1 {class: flow}
    enc_ffn_1 -> enc_norm2_1 {class: flow}
  }
  encoder_layer_n: {
    label: "EncoderLayer N"
    enc_self_attn_n: {
      label: "MultiHeadAttention\n(Self-Attention)"
      class: sublayer
    }
    enc_norm1_n: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    enc_ffn_n: {
      label: "PositionWiseFFN\n(d_model → d_ff → d_model)"
      class: sublayer
    }
    enc_norm2_n: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    enc_self_attn_n -> enc_norm1_n {class: flow}
    enc_norm1_n -> enc_ffn_n {class: flow}
    enc_ffn_n -> enc_norm2_n {class: flow}
  }
  enc_dots: {
    label: "..."
    shape: text
    style: {
      font-size: 20
    }
  }
  encoder_layer_1 -> enc_dots {class: flow}
  enc_dots -> encoder_layer_n {class: flow}
}

# Encoder output (memory)
encoder_output: {
  label: "Encoder Output (Memory)\n[batch, src_seq_len, d_model]"
  shape: stored_data
  style: {
    fill: "#C8E6C9"
    stroke: "#388E3C"
    stroke-width: 3
  }
}

# ====================
# TARGET EMBEDDING BRANCH
# ====================
target_embedding: {
  label: "Target Embedding"
  token_emb_tgt: {
    label: "TokenEmbedding\n(vocab_size, d_model)"
    class: component
  }
  pos_enc_tgt: {
    label: "PositionalEncoding\n(max_len, d_model)"
    class: component
  }
  add_tgt: {
    label: "+"
    shape: circle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  dropout_tgt: {
    label: "Dropout\n(p=0.1)"
    shape: rectangle
    class: sublayer
  }
  token_emb_tgt -> add_tgt: "element-wise" {class: flow}
  pos_enc_tgt -> add_tgt: "element-wise" {class: flow}
  add_tgt -> dropout_tgt {class: flow}
}

# ====================
# DECODER STACK
# ====================
decoder_stack: {
  label: "Decoder Stack (N layers)"
  decoder_layer_1: {
    label: "DecoderLayer 1"
    dec_masked_attn_1: {
      label: "MaskedMultiHeadAttention\n(Causal Self-Attention)"
      class: sublayer
      style: {
        fill: "#FFECB3"
      }
    }
    dec_norm1_1: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    dec_cross_attn_1: {
      label: "MultiHeadAttention\n(Cross-Attention)"
      class: sublayer
      style: {
        fill: "#FFCDD2"
      }
    }
    dec_norm2_1: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    dec_ffn_1: {
      label: "PositionWiseFFN\n(d_model → d_ff → d_model)"
      class: sublayer
    }
    dec_norm3_1: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    dec_masked_attn_1 -> dec_norm1_1 {class: flow}
    dec_norm1_1 -> dec_cross_attn_1 {class: flow}
    dec_cross_attn_1 -> dec_norm2_1 {class: flow}
    dec_norm2_1 -> dec_ffn_1 {class: flow}
    dec_ffn_1 -> dec_norm3_1 {class: flow}
  }
  decoder_layer_n: {
    label: "DecoderLayer N"
    dec_masked_attn_n: {
      label: "MaskedMultiHeadAttention\n(Causal Self-Attention)"
      class: sublayer
      style: {
        fill: "#FFECB3"
      }
    }
    dec_norm1_n: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    dec_cross_attn_n: {
      label: "MultiHeadAttention\n(Cross-Attention)"
      class: sublayer
      style: {
        fill: "#FFCDD2"
      }
    }
    dec_norm2_n: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    dec_ffn_n: {
      label: "PositionWiseFFN\n(d_model → d_ff → d_model)"
      class: sublayer
    }
    dec_norm3_n: {
      label: "LayerNorm"
      shape: circle
      style: {
        fill: "#E1BEE7"
        stroke: "#7B1FA2"
      }
    }
    dec_masked_attn_n -> dec_norm1_n {class: flow}
    dec_norm1_n -> dec_cross_attn_n {class: flow}
    dec_cross_attn_n -> dec_norm2_n {class: flow}
    dec_norm2_n -> dec_ffn_n {class: flow}
    dec_ffn_n -> dec_norm3_n {class: flow}
  }
  dec_dots: {
    label: "..."
    shape: text
    style: {
      font-size: 20
    }
  }
  decoder_layer_1 -> dec_dots {class: flow}
  dec_dots -> decoder_layer_n {class: flow}
}

# ====================
# OUTPUT PROJECTION
# ====================
output_projection: {
  label: "Output Projection"
  final_norm: {
    label: "Final LayerNorm"
    shape: circle
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      stroke-width: 3
    }
  }
  linear_proj: {
    label: "Linear Projection\n(d_model → vocab_size)"
    class: component
    style: {
      fill: "#B3E5FC"
    }
  }
  softmax: {
    label: "Softmax"
    shape: diamond
    style: {
      fill: "#F8BBD9"
      stroke: "#C2185B"
    }
  }
  final_norm -> linear_proj {class: flow}
  linear_proj -> softmax {class: flow}
}

# ====================
# OUTPUT
# ====================
output: {
  label: "Output Probabilities\n[batch, tgt_seq_len, vocab_size]"
  shape: stored_data
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    stroke-width: 3
  }
}

# ====================
# MAIN FLOW CONNECTIONS
# ====================
# Source path
inputs.src_tokens -> source_embedding.token_emb_src: "src_input_ids" {class: flow}
source_embedding.dropout_src -> encoder_stack.encoder_layer_1: "src_embed\n[batch, src_seq_len, d_model]" {class: flow}

# Encoder to memory
encoder_stack.encoder_layer_n -> encoder_output: "encoder_output\n(memory)" {class: flow}

# Target path
inputs.tgt_tokens -> target_embedding.token_emb_tgt: "tgt_input_ids" {class: flow}
target_embedding.dropout_tgt -> decoder_stack.decoder_layer_1: "tgt_embed\n[batch, tgt_seq_len, d_model]" {class: flow}

# Cross-attention connections (encoder to decoder)
encoder_output -> decoder_stack.decoder_layer_1.dec_cross_attn_1: "K, V from encoder" {class: cross}
encoder_output -> decoder_stack.decoder_layer_n.dec_cross_attn_n: "K, V from encoder" {class: cross}

# Decoder to output
decoder_stack.decoder_layer_n -> output_projection.final_norm: "decoder_output\n[batch, tgt_seq_len, d_model]" {class: flow}
output_projection.softmax -> output: "logits → probs" {class: flow}

# ====================
# LEGEND
# ====================
legend: {
  label: "Legend"
  flow_legend: {
    label: "→ Data Flow"
    shape: text
  }
  cross_legend: {
    label: "→ Cross-Attention"
    shape: text
    style: {
      font-color: "#D32F2F"
    }
  }
  residual_legend: {
    label: "⇢ Residual Connection"
    shape: text
    style: {
      font-color: "#7B1FA2"
    }
  }
}

# ====================
# DIMENSIONS ANNOTATION
# ====================
dimensions: {
  label: "Key Dimensions:\n• d_model = 512\n• d_ff = 2048\n• n_heads = 8\n• N = 6 layers\n• vocab_size = varies"
  shape: text
  style: {
    font-size: 12
    italic: true
  }
}