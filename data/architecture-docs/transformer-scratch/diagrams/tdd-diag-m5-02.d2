direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  pad-color: "#F5F5F5"
  sos-color: "#4CAF50"
  eos-color: "#F44336"
  token-color: "#2196F3"
  highlight-color: "#FF9800"
  dim-color: "#BDBDBD"
}

title: {
  label: "Teacher Forcing Data Preparation\nTarget Shift Operation for Autoregressive Training"
  shape: text
  near: top-center
  style.font-size: 24
  style.bold: true
}

# Step indicator
step_label: {
  label: "DATA PREP PIPELINE"
  shape: text
  style.font-size: 28
  style.bold: true
  style.fill: "#E3F2FD"
}

# INPUT CONTAINER
input_container: {
  label: "SOURCE TARGET SEQUENCE (tgt_tokens)\nShape: [Batch, Sequence_Length (T)]"
  input_seq: {
    label: ""
    grid-columns: 5
    grid-gap: 5
    i0: "<SOS>" {
      style.fill: "${sos-color}"
      style.stroke: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
    i1: "A" {
      style.fill: "${token-color}"
      style.stroke: "#1565C0"
      style.font-color: white
    }
    i2: "B" {
      style.fill: "${token-color}"
      style.stroke: "#1565C0"
      style.font-color: white
    }
    i3: "C" {
      style.fill: "${token-color}"
      style.stroke: "#1565C0"
      style.font-color: white
    }
    i4: "<EOS>" {
      style.fill: "${eos-color}"
      style.stroke: "#C62828"
      style.font-color: white
      style.bold: true
    }
  }
  idx_label: {
    label: "t-index:    0          1          2          3          4"
    shape: text
    style.font-size: 11
    style.font: mono
    style.font-color: "#666"
  }
}

# SHIFT OPERATION LOGIC
shift_op: {
  label: "SLICING LOGIC"
  slice_top: "DECODER INPUT SLICE\ntgt[:, :-1]" {
    style.fill: "#E8F5E9"
    style.stroke: "${sos-color}"
    style.stroke-width: 2
  }
  slice_bottom: "TARGET LABEL SLICE\ntgt[:, 1:]" {
    style.fill: "#FFEBEE"
    style.stroke: "${eos-color}"
    style.stroke-width: 2
  }
  
  slice_top -> slice_bottom: "Shift Left by 1" {
    style.stroke-dash: 3
    style.font-size: 12
  }
}

# OUTPUT CONTAINER
output_container: {
  label: "GENERATED TRAINING PAIRS"
  
  decoder_container: {
    label: "decoder_input [B, T-1]"
    decoder_seq: {
      grid-columns: 4
      grid-gap: 5
      d0: "<SOS>" {
        style.fill: "${sos-color}"
        style.stroke: "#2E7D32"
        style.font-color: white
        style.bold: true
      }
      d1: "A" {
        style.fill: "${token-color}"
        style.stroke: "#1565C0"
        style.font-color: white
      }
      d2: "B" {
        style.fill: "${token-color}"
        style.stroke: "#1565C0"
        style.font-color: white
      }
      d3: "C" {
        style.fill: "${token-color}"
        style.stroke: "#1565C0"
        style.font-color: white
      }
    }
    dec_idx: "idx:   0      1      2      3" {
      shape: text
      style.font: mono
      style.font-size: 11
    }
  }

  target_container: {
    label: "target_labels [B, T-1]"
    target_seq: {
      grid-columns: 4
      grid-gap: 5
      t0: "A" {
        style.fill: "${highlight-color}"
        style.stroke: "#E65100"
        style.font-color: white
        style.bold: true
      }
      t1: "B" {
        style.fill: "${highlight-color}"
        style.stroke: "#E65100"
        style.font-color: white
        style.bold: true
      }
      t2: "C" {
        style.fill: "${highlight-color}"
        style.stroke: "#E65100"
        style.font-color: white
        style.bold: true
      }
      t3: "<EOS>" {
        style.fill: "${eos-color}"
        style.stroke: "#C62828"
        style.font-color: white
        style.bold: true
      }
    }
    tgt_idx: "idx:   0      1      2      3" {
      shape: text
      style.font: mono
      style.font-size: 11
    }
  }
}

# ALIGNMENT VISUALIZATION
alignment_box: {
  label: "PREDICTION ALIGNMENT MAP"
  style.fill: "#FAFAFA"
  
  alignment_row: {
    grid-columns: 11
    grid-gap: 5
    
    p_d0: "<SOS>"; a0: "→"; p_t0: "A"
    sep1: " | " {shape: text}
    p_d1: "A"; a1: "→"; p_t1: "B"
    sep2: " | " {shape: text}
    p_d2: "B"; a2: "→"; p_t2: "C"
    
    p_d0.style.fill: "${sos-color}"
    p_t0.style.fill: "${highlight-color}"
    p_d1.style.fill: "${token-color}"
    p_t1.style.fill: "${highlight-color}"
    p_d2.style.fill: "${token-color}"
    p_t2.style.fill: "${highlight-color}"
    
    *.style.font-color: white
    *.style.font-size: 10
    a0.style.font-color: black; a1.style.font-color: black; a2.style.font-color: black
  }
}

# ALGORITHM SPECIFICATION
algorithm_steps: {
  label: "ALGORITHM: Teacher Forcing Preparation"
  step1: "1. DECODER INPUT Generation\nDiscard last token (T-1) to ensure the model\nnever sees the answer for the current timestep.\nCode: x = tgt[:, :-1]" {
    style.fill: "#E8F5E9"
    style.stroke: "${sos-color}"
  }
  step2: "2. TARGET LABEL Generation\nDiscard first token (0) as the model starts\npredicting from the first actual content token.\nCode: y = tgt[:, 1:]" {
    style.fill: "#FFEBEE"
    style.stroke: "${eos-color}"
  }
  invariant: "RESULTING INVARIANT\nAt every timestep 't', decoder_input[t] is the\nground truth token used to predict target_label[t]." {
    style.fill: "#FFF3E0"
    style.stroke: "${highlight-color}"
    style.bold: true
  }
  step1 -> step2 -> invariant: {style.stroke-width: 0}
}

# DROPPED TOKEN ANALYSIS
dropped_container: {
  label: "EXCLUDED TOKENS"
  dropped_from_decoder: {
    label: "<EOS>\n(Excluded from Input)"
    style.fill: "${dim-color}"
    style.stroke-dash: 4
  }
  dropped_from_target: {
    label: "<SOS>\n(Excluded from Labels)"
    style.fill: "${dim-color}"
    style.stroke-dash: 4
  }
}

# DATA MAPPING TABLE - Fixed from sql_table to Grid for compatibility
position_map: {
  label: "Position Alignment Table"
  grid-columns: 4
  grid-gap: 0
  
  h1: "Time Index" { style.fill: "#333"; style.font-color: white; style.bold: true }
  h2: "Input to Decoder" { style.fill: "#333"; style.font-color: white; style.bold: true }
  h3: "Expected Label" { style.fill: "#333"; style.font-color: white; style.bold: true }
  h4: "Prediction Task" { style.fill: "#333"; style.font-color: white; style.bold: true }

  r0c1: "0"; r0c2: "<SOS>"; r0c3: "A"; r0c4: "Predict A"
  r1c1: "1"; r1c2: "A"; r1c3: "B"; r1c4: "Predict B"
  r2c1: "2"; r2c2: "B"; r2c3: "C"; r2c4: "Predict C"
  r3c1: "3"; r3c2: "C"; r3c3: "<EOS>"; r3c4: "Predict EOS"
}

# CONNECTIONS - DATA FLOW
input_container.input_seq.i0 -> output_container.decoder_container.decoder_seq.d0: { style.stroke: "${sos-color}"; style.stroke-width: 2 }
input_container.input_seq.i1 -> output_container.decoder_container.decoder_seq.d1: { style.stroke: "${token-color}" }
input_container.input_seq.i2 -> output_container.decoder_container.decoder_seq.d2: { style.stroke: "${token-color}" }
input_container.input_seq.i3 -> output_container.decoder_container.decoder_seq.d3: { style.stroke: "${token-color}" }

input_container.input_seq.i1 -> output_container.target_container.target_seq.t0: { style.stroke: "${highlight-color}"; style.stroke-width: 2 }
input_container.input_seq.i2 -> output_container.target_container.target_seq.t1: { style.stroke: "${highlight-color}" }
input_container.input_seq.i3 -> output_container.target_container.target_seq.t2: { style.stroke: "${highlight-color}" }
input_container.input_seq.i4 -> output_container.target_container.target_seq.t3: { style.stroke: "${eos-color}"; style.stroke-width: 2 }

# HIDDEN LAYOUT HINTS - Corrected: Replacing "invisible" with "opacity: 0"
step_label -> input_container: {style.opacity: 0}
input_container -> shift_op: {style.opacity: 0}
shift_op -> output_container: {style.opacity: 0}
output_container -> alignment_box: {style.opacity: 0}
alignment_box -> algorithm_steps: {style.opacity: 0}
algorithm_steps -> dropped_container: {style.opacity: 0}
dropped_container -> position_map: {style.opacity: 0}