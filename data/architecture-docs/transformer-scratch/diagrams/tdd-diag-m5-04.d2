direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Label Smoothing Effect\nTransforming Hard Targets to Soft Targets"
  shape: text
  style.font-size: 24
  style.bold: true
  style.underline: true
}

# Hard Targets Container
hard_targets: {
  label: "STEP 1: Hard Targets\n(One-Hot Encoding)"
  style.fill: "#E8F4FD"
  style.stroke: "#2563EB"
  style.stroke-width: 3

  class_0: {
    label: "0"
    shape: rectangle
    style.fill: "#94A3B8"
    style.stroke: "#64748B"
    style.stroke-width: 2
    style.font-size: 18
    style.bold: true
    width: 60
    height: 60
  }
  class_1: {
    label: "0"
    shape: rectangle
    style.fill: "#94A3B8"
    style.stroke: "#64748B"
    style.stroke-width: 2
    style.font-size: 18
    style.bold: true
    width: 60
    height: 60
  }
  class_2: {
    label: "1"
    shape: rectangle
    style.fill: "#22C55E"
    style.stroke: "#15803D"
    style.stroke-width: 3
    style.font-size: 18
    style.bold: true
    width: 60
    height: 60
  }
  class_3: {
    label: "0"
    shape: rectangle
    style.fill: "#94A3B8"
    style.stroke: "#64748B"
    style.stroke-width: 2
    style.font-size: 18
    style.bold: true
    width: 60
    height: 60
  }

  class_0 -> class_1 -> class_2 -> class_3: {style.opacity: 0}

  true_label: {
    label: "True Class: 2"
    shape: text
    style.font-size: 14
    style.italic: true
    style.font-color: "#15803D"
  }
}

# Transformation Process
transformation: {
  label: "STEP 2: Apply Smoothing\ny_i = (1-ε) if i=true, else ε/(K-1)"
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.stroke-width: 3

  formula_box: {
    label: "ε = 0.1 (smoothing)\nK = 4 (num classes)\nK-1 = 3"
    shape: rectangle
    style.fill: "#FFFBEB"
    style.stroke: "#F59E0B"
    style.stroke-width: 2
    style.font-size: 14
  }
  calc_true: {
    label: "True Class:\n(1 - ε) = 0.9"
    shape: rectangle
    style.fill: "#DCFCE7"
    style.stroke: "#22C55E"
    style.stroke-width: 2
    style.font-size: 14
    style.bold: true
  }
  calc_other: {
    label: "Other Classes:\nε/(K-1) = 0.033"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 2
    style.font-size: 14
    style.bold: true
    style.font-color: "#DC2626"
  }

  formula_box -> calc_true -> calc_other: {style.opacity: 0}
}

# Soft Targets Container
soft_targets: {
  label: "STEP 3: Soft Targets\n(Smoothed Distribution)"
  style.fill: "#F0FDF4"
  style.stroke: "#15803D"
  style.stroke-width: 3

  soft_0: {
    label: "ε/(K-1)\n≈ 0.033"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 3
    style.font-size: 14
    style.bold: true
    style.font-color: "#DC2626"
    width: 70
    height: 70
  }
  soft_1: {
    label: "ε/(K-1)\n≈ 0.033"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 3
    style.font-size: 14
    style.bold: true
    style.font-color: "#DC2626"
    width: 70
    height: 70
  }
  soft_2: {
    label: "1-ε\n= 0.9"
    shape: rectangle
    style.fill: "#22C55E"
    style.stroke: "#15803D"
    style.stroke-width: 3
    style.font-size: 16
    style.bold: true
    width: 70
    height: 70
  }
  soft_3: {
    label: "ε/(K-1)\n≈ 0.033"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 3
    style.font-size: 14
    style.bold: true
    style.font-color: "#DC2626"
    width: 70
    height: 70
  }

  soft_0 -> soft_1 -> soft_2 -> soft_3: {style.opacity: 0}

  sum_note: {
    label: "Σ = 0.033 + 0.033 + 0.9 + 0.033 ≈ 1.0"
    shape: text
    style.font-size: 12
    style.italic: true
  }
}

# Arrows showing transformation
hard_targets -> transformation: "Apply\nFormula" {
  style.stroke: "#6366F1"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.animated: true
}

transformation -> soft_targets: "Output\nDistribution" {
  style.stroke: "#6366F1"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.animated: true
}

# Legend
legend: {
  label: "Legend"
  style.fill: "#F8FAFC"
  style.stroke: "#CBD5E1"

  true_class: {
    label: "True Class (unchanged)"
    shape: rectangle
    style.fill: "#22C55E"
    width: 100
    height: 30
  }
  changed_class: {
    label: "Changed (0 → ε/K)"
    shape: rectangle
    style.fill: "#FEE2E2"
    style.stroke: "#EF4444"
    style.stroke-width: 2
    style.font-color: "#DC2626"
    style.bold: true
    width: 100
    height: 30
  }
  true_class -> changed_class: {style.opacity: 0}
}

# Benefit note
benefit: {
  label: "💡 Benefit: Prevents overconfident predictions\nand improves model calibration"
  shape: text
  style.font-size: 14
  style.italic: true
  style.font-color: "#6366F1"
}

# Layout anchors
hard_targets -> legend: {style.opacity: 0}
soft_targets -> benefit: {style.opacity: 0}