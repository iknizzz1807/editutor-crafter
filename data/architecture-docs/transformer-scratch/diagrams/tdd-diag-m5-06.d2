direction: right
layout-engine: elk
title: {
  label: Gradient Clipping Mechanism\nImplementation-Grade Algorithm Diagram
  shape: text
  near: top-center
  style.font-size: 28
  style.bold: true
}
# ============================================================
# INPUT SECTION
# ============================================================
inputs: {
  shape: rectangle
  label: INPUTS
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  model_params: {
    label: "Model Parameters Θ\n{θ₁, θ₂, ..., θₙ}"
    shape: class
    style.fill: "#BBDEFB"
  }
  gradients: {
    label: "Gradients ∇Θ\n{∇θ₁, ∇θ₂, ..., ∇θₙ}"
    shape: class
    style.fill: "#BBDEFB"
  }
  max_norm: {
    label: "max_norm\n(hyperparameter)"
    shape: diamond
    style.fill: "#FFF9C4"
  }
}
# ============================================================
# STEP 1: COMPUTE TOTAL GRADIENT NORM
# ============================================================
step1_container: {
  label: STEP 1: Compute Total Gradient Norm
  shape: rectangle
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  step1_header: {
    shape: text
    label: "ALGORITHM: L2 Norm Computation"
    style.bold: true
    style.font-size: 14
  }
  # Loop visualization
  loop_container: {
    label: "FOR each parameter p ∈ Θ"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke-dash: 4
    param_block: {
      label: "Parameter p with gradient"
      shape: rectangle
      grad_tensor: {
        label: "p.grad\n[∂L/∂p₁, ∂L/∂p₂, ..., ∂L/∂pₘ]"
        shape: class
        style.fill: "#A5D6A7"
      }
    }
    compute_norm: {
      label: "Compute L2 Norm"
      shape: diamond
      formula_norm: {
        label: "param_norm = √(Σᵢ (p.grad[i])²)\n        = ||p.grad||₂"
        shape: text
        style.fill: "#DCEDC8"
      }
    }
    accumulate: {
      label: "Accumulate"
      shape: rectangle
      accum_formula: {
        label: "total_norm += param_norm²"
        shape: text
        style.fill: "#DCEDC8"
        style.bold: true
      }
    }
  }
  # Final computation
  final_norm: {
    label: "FINAL: total_norm = √(total_norm)"
    shape: rectangle
    style.fill: "#81C784"
    style.bold: true
    formula_final: {
      label: "total_norm = √(Σₚ ||∇θₚ||₂²)"
      shape: text
      style.font-size: 16
      style.bold: true
    }
  }
}
# ============================================================
# STEP 2: COMPUTE CLIPPING COEFFICIENT
# ============================================================
step2_container: {
  label: STEP 2: Compute Clipping Coefficient
  shape: rectangle
  style.fill: "#FFF3E0"
  style.stroke: "#EF6C00"
  style.stroke-width: 3
  coef_formula: {
    label: "clip_coef = max_norm / (total_norm + ε)"
    shape: text
    style.font-size: 18
    style.bold: true
  }
  epsilon_note: {
    label: "ε = 1e-6 (numerical stability)"
    shape: text
    style.italic: true
    style.font-size: 12
  }
  decision: {
    label: "Compare"
    shape: diamond
    style.fill: "#FFE0B2"
    condition: {
      label: "clip_coef < 1 ?"
      shape: text
      style.bold: true
      style.font-size: 16
    }
  }
  # YES branch - clipping needed
  clip_needed: {
    label: "YES: Clipping Required"
    shape: rectangle
    style.fill: "#FFCC80"
    explanation_yes: {
      label: "total_norm > max_norm\n→ Gradients too large\n→ Must scale down"
      shape: text
      style.font-size: 12
    }
  }
  # NO branch - no clipping
  no_clip: {
    label: "NO: No Clipping"
    shape: rectangle
    style.fill: "#C8E6C9"
    explanation_no: {
      label: "total_norm ≤ max_norm\n→ Gradients acceptable\n→ No modification needed"
      shape: text
      style.font-size: 12
    }
  }
}
# ============================================================
# STEP 3: APPLY CLIPPING
# ============================================================
step3_container: {
  label: STEP 3: Apply Clipping (if needed)
  shape: rectangle
  style.fill: "#FCE4EC"
  style.stroke: "#C2185B"
  style.stroke-width: 3
  apply_header: {
    shape: text
    label: "CONDITIONAL: IF clip_coef < 1"
    style.bold: true
    style.font-size: 14
  }
  apply_loop: {
    label: "FOR each parameter p ∈ Θ"
    shape: rectangle
    style.fill: "#F8BBD9"
    style.stroke-dash: 4
    before_grad: {
      label: "BEFORE"
      shape: rectangle
      style.fill: "#FFCDD2"
      grad_before: {
        label: "p.grad = [g₁, g₂, ..., gₘ]"
        shape: text
      }
    }
    scaling_op: {
      label: "Scale Operation"
      shape: diamond
      style.fill: "#E91E63"
      style.font-color: white
      scale_formula: {
        label: "p.grad *= clip_coef\n\np.grad[i] = g[i] × clip_coef"
        shape: text
        style.font-size: 14
        style.bold: true
        style.font-color: white
      }
    }
    after_grad: {
      label: "AFTER"
      shape: rectangle
      style.fill: "#C8E6C9"
      grad_after: {
        label: "p.grad = [g₁×c, g₂×c, ..., gₘ×c]\nwhere c = clip_coef"
        shape: text
        style.bold: true
      }
    }
  }
  result_state: {
    label: "POST-CLIP STATE"
    shape: rectangle
    style.fill: "#E1BEE7"
    new_norm: {
      label: "new_total_norm = max_norm"
      shape: text
      style.bold: true
      style.font-size: 14
    }
    direction_preserved: {
      label: "∇Θ direction preserved\n(only magnitude changed)"
      shape: text
      style.italic: true
    }
  }
}
# ============================================================
# OUTPUT SECTION
# ============================================================
outputs: {
  shape: rectangle
  label: OUTPUT
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  style.stroke-width: 2
  return_val: {
    label: "RETURN: total_norm\n(before clipping)"
    shape: class
    style.fill: "#BBDEFB"
    style.bold: true
  }
  clipped_grads: {
    label: "Clipped Gradients\n(ready for optimizer step)"
    shape: class
    style.fill: "#C8E6C9"
  }
}
# ============================================================
# INVARIANTS BOX
# ============================================================
invariants: {
  label: "INVARIANTS"
  shape: rectangle
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
  inv1: {
    label: "✓ After clipping: total_norm ≤ max_norm"
    shape: text
    style.font-size: 13
  }
  inv2: {
    label: "✓ Gradient direction preserved (only magnitude changes)"
    shape: text
    style.font-size: 13
  }
  inv3: {
    label: "✓ Prevents gradient explosion during training"
    shape: text
    style.font-size: 13
  }
}
# ============================================================
# NUMERICAL EXAMPLE
# ============================================================
example: {
  label: "NUMERICAL EXAMPLE"
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#455A64"
  style.stroke-width: 2
  ex_input: {
    label: "Input:\nmax_norm = 1.0\n||∇θ₁|| = 0.8, ||∇θ₂|| = 0.6"
    shape: text
    style.font-size: 11
  }
  ex_step1: {
    label: "Step 1:\ntotal_norm = √(0.8² + 0.6²) = √1.0 = 1.0"
    shape: text
    style.font-size: 11
  }
  ex_step2: {
    label: "Step 2:\nclip_coef = 1.0 / (1.0 + 1e-6) ≈ 1.0"
    shape: text
    style.font-size: 11
  }
  ex_step3: {
    label: "Step 3:\nclip_coef ≥ 1 → NO CLIPPING"
    shape: text
    style.font-size: 11
    style.fill: "#C8E6C9"
  }
  ex_input2: {
    label: "Alternative Input:\n||∇θ₁|| = 3.0, ||∇θ₂|| = 4.0"
    shape: text
    style.font-size: 11
  }
  ex2_step1: {
    label: "total_norm = √(9 + 16) = 5.0"
    shape: text
    style.font-size: 11
  }
  ex2_step2: {
    label: "clip_coef = 1.0 / 5.0 = 0.2"
    shape: text
    style.font-size: 11
  }
  ex2_step3: {
    label: "CLIP: all grads × 0.2\nnew_norm = 1.0"
    shape: text
    style.font-size: 11
    style.fill: "#FFCDD2"
    style.bold: true
  }
}
# ============================================================
# CONNECTIONS
# ============================================================
inputs -> step1_container: {
  label: "gradients available"
  style.stroke: "#1565C0"
  style.stroke-width: 2
}
step1_container.loop_container.param_block -> step1_container.loop_container.compute_norm: {
  label: "extract"
}
step1_container.loop_container.compute_norm -> step1_container.loop_container.accumulate: {
  label: "||·||₂"
}
step1_container.loop_container -> step1_container.final_norm: {
  label: "loop complete"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
step1_container.final_norm -> step2_container: {
  label: "total_norm"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
step2_container.decision -> step2_container.clip_needed: {
  label: "YES"
  style.stroke: "#EF6C00"
  style.stroke-width: 2
}
step2_container.decision -> step2_container.no_clip: {
  label: "NO"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
step2_container.clip_needed -> step3_container: {
  label: "proceed to clip"
  style.stroke: "#C2185B"
  style.stroke-width: 2
}
step3_container -> outputs: {
  label: "clipped gradients"
  style.stroke: "#C2185B"
  style.stroke-width: 2
}
step2_container.no_clip -> outputs: {
  label: "unchanged"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}