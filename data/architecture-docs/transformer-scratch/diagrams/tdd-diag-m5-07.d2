direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- CLASSES FOR TECHNICAL SPECIFICATION ---
classes: {
  header_purple: {
    style: {
      fill: "#EDE7F6"
      stroke: "#512DA8"
      stroke-width: 2
      font-size: 14
      bold: true
    }
  }
  data_blue: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  storage_cylinder: {
    shape: cylinder
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 3
    }
  }
  logic_step: {
    shape: rectangle
    style: {
      border-radius: 4
      stroke-width: 1
      fill: "#F5F5F5"
    }
  }
  token_box: {
    width: 100
    height: 45
    style: {
      font-size: 13
      text-transform: uppercase
      bold: true
      stroke-width: 2
    }
  }
  memory_offset: {
    shape: text
    style: {
      font: mono
      font-size: 11
      font-color: "#757575"
    }
  }
}

title: |'md
  # TDD-M5-07: Copy Task Dataset Implementation
  **Component:** `CopyDataset(torch.utils.data.Dataset)`
  **Memory Layout & Token Construction Logic**
  *Intel Manual Quality Specification v1.0.4*
'| {
  near: top-center
  shape: text
  style.font-size: 18
}

# --- 1. PARAMETER CONFIGURATION ---
dataset_config: {
  label: "Dataset Parameters (config)"
  class: header_purple
  
  n_samples: "count: 1000 (uint32)" {
    tooltip: "Total number of sequences in the synthetic epoch"
  }
  seq_len: "length: 10 (uint16)" {
    tooltip: "Length of the random portion of the sequence"
  }
  vocab_size: "vocab: 100 (uint16)" {
    tooltip: "Range of possible token IDs"
  }
}

# --- 2. SPECIAL TOKEN DEFINITIONS (OFFSETS 0-2) ---
special_token_map: {
  label: "Special Token Reserved IDs"
  class: header_purple
  style.fill: "#FFF3E0"
  
  pad: "ID: 0 (PAD)" { class: token_box; style.fill: "#BDBDBD" }
  sos: "ID: 1 (SOS)" { class: token_box; style.fill: "#FFCC80" }
  eos: "ID: 2 (EOS)" { class: token_box; style.fill: "#FFCC80" }
}

# --- 3. TENSOR GENERATION LOGIC ---
sequence_generator: {
  label: "Random Initialization Phase"
  class: logic_step
  style.fill: "#E8F5E9"
  
  torch_logic: |'python
    # Generates values in [3, vocab_size)
    # Shape: (N, L)
    data = torch.randint(
        low=3, 
        high=vocab_size, 
        size=(n_samples, seq_len)
    )
  '|
  
  constraint_check: "Invariant: token_id >= 3" {
    style.stroke-dash: 3
    style.font-color: red
  }
  
  torch_logic -> constraint_check
}

# --- 4. MEMORY STORAGE (FIXED BLOCK STRING) ---
sequences_memory: {
  label: "self.sequences"
  class: storage_cylinder
  description: "Shape: (1000, 10) | Dtype: torch.long"
  
  layout: |'md
    | Offset | Dim | Size (Bytes) |
    | :--- | :--- | :--- |
    | 0x00 | n_samples | 1000 |
    | 0x04 | seq_len | 10 |
    | **Total** | | **80,000** |
  '|
}

# --- 5. DATA RETRIEVAL (DATALOADER HOOK) ---
data_fetch: {
  label: "Dataset.__getitem__(idx)"
  class: logic_step
  
  extract_op: "Slice: seq = self.sequences[idx]" {
    shape: parallelogram
    style.fill: "#FCE4EC"
  }
  
  # Construction sub-process
  construction_logic: {
    label: "Sequence Transformation"
    style.stroke-dash: 2
    
    src_pipe: {
      label: "Source Construction"
      sos_bit -> cat_op_src: "prefix (1)"
      raw_seq -> cat_op_src: "data (10)"
      eos_bit -> cat_op_src: "suffix (1)"
      
      sos_bit: "[ 1 ]" { class: token_box; style.fill: "#FFCC80" }
      raw_seq: "[ T_0 ... T_9 ]" { class: token_box; width: 140; style.fill: "#E3F2FD" }
      eos_bit: "[ 2 ]" { class: token_box; style.fill: "#FFCC80" }
      
      cat_op_src: "torch.cat()" { shape: hexagon; style.fill: "#E1F5FE" }
    }
    
    tgt_pipe: {
      label: "Target Construction (Copy)"
      sos_bit_t -> cat_op_tgt: "prefix"
      raw_seq_t -> cat_op_tgt: "body"
      eos_bit_t -> cat_op_tgt: "suffix"
      
      sos_bit_t: "[ 1 ]" { class: token_box; style.fill: "#FFCC80" }
      raw_seq_t: "[ T_0 ... T_9 ]" { class: token_box; width: 140; style.fill: "#E3F2FD" }
      eos_bit_t: "[ 2 ]" { class: token_box; style.fill: "#FFCC80" }
      
      cat_op_tgt: "torch.cat()" { shape: hexagon; style.fill: "#E1F5FE" }
    }
  }
}

# --- 6. FINAL DATA STRUCTURE ---
dataset_output: {
  label: "Return Dictionary"
  class: data_blue
  
  src_field: "src_tokens" {
    label: "key: 'src_tokens'\nShape: (12,)\nStride: 8 bytes (64-bit long)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
  
  tgt_field: "tgt_tokens" {
    label: "key: 'tgt_tokens'\nShape: (12,)\nStride: 8 bytes (64-bit long)"
    shape: rectangle
    style.fill: "#BBDEFB"
  }
}

# --- 7. BYTE-LEVEL VISUALIZATION ---
bit_vis_container: {
  label: "Memory Representation (Single Sample View)"
  
  bit_vis: {
    grid-columns: 8
    grid-gap: 5
    
    # Byte indices (assuming 8-byte elements for torch.long)
    b0: "Offset +0x00" { class: memory_offset }
    b1: "Offset +0x08" { class: memory_offset }
    b2: "Offset +0x10" { class: memory_offset }
    b3: "Offset +0x18" { class: memory_offset }
    b4: "Offset +0x20" { class: memory_offset }
    b5: "Offset +0x28" { class: memory_offset }
    b6: "Offset +0x30" { class: memory_offset }
    b7: "Offset +0x38" { class: memory_offset }
    
    # Tokens
    t1: "SOS (1)" { class: token_box; style.fill: "#FFD54F" }
    t2: "Token_A" { class: token_box; style.fill: "#BBDEFB" }
    t3: "Token_B" { class: token_box; style.fill: "#BBDEFB" }
    t4: "Token_C" { class: token_box; style.fill: "#BBDEFB" }
    t5: "Token_D" { class: token_box; style.fill: "#BBDEFB" }
    t6: "Token_E" { class: token_box; style.fill: "#BBDEFB" }
    t7: "EOS (2)" { class: token_box; style.fill: "#FFD54F" }
    pad: "PAD (0)" { class: token_box; style.fill: "#EEEEEE" }
  }
}

# --- CONNECTIONS (DATA FLOW) ---
dataset_config.n_samples -> sequence_generator: "N"
dataset_config.seq_len -> sequence_generator: "L"
dataset_config.vocab_size -> sequence_generator: "V"

sequence_generator -> sequences_memory: "write to DRAM"
sequences_memory -> data_fetch.extract_op: "idx access"

special_token_map.sos -> data_fetch.construction_logic.src_pipe.sos_bit
special_token_map.eos -> data_fetch.construction_logic.src_pipe.eos_bit
data_fetch.extract_op -> data_fetch.construction_logic.src_pipe.raw_seq
data_fetch.extract_op -> data_fetch.construction_logic.tgt_pipe.raw_seq

data_fetch.construction_logic.src_pipe.cat_op_src -> dataset_output.src_field
data_fetch.construction_logic.tgt_pipe.cat_op_tgt -> dataset_output.tgt_field

dataset_output -> bit_vis_container: "Serialized Map"

# --- LEGEND & SPEC ---
tech_spec_legend: {
  label: "Technical Specification Legend"
  near: bottom-right
  
  purple: "Configuration/Metadata" { class: header_purple }
  blue: "Output Data Structure" { class: data_blue }
  green: "Execution Logic" { style.fill: "#E8F5E9"; style.stroke: "#2E7D32" }
  cylinder_shape: "Persistent Storage (Long)" { class: storage_cylinder }
}