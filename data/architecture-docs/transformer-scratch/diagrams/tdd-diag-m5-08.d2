vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- GLOBAL STYLES ---
classes: {
  mono_font: {
    style: {
      font: mono
      font-size: 14
    }
  }
}

# --- ARCHITECTURE DIAGRAM ---

Training Infrastructure: {
  style: {
    fill: "transparent"
    stroke: "#CCC"
    stroke-dash: 4
  }

  Trainer: {
    shape: class
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    # Fields
    model: "EncoderDecoderTransformer"
    optimizer: "torch.optim.Adam"
    scheduler: "TransformerLRScheduler"
    criterion: "MaskedCrossEntropyLoss"
    train_dataloader: "DataLoader"
    val_dataloader: "DataLoader"
    "global_step: int": "0"
    train_losses: "List[float]"
    val_losses: "List[float]"
    learning_rates: "List[float]"
    
    # Methods
    "train(epochs: int, eval_every: int)": "Dict[str, Any]"
    "train_step(batch: Dict[str, Tensor])": "float"
    "evaluate(dataloader: DataLoader)": "float"
    "save_checkpoint(path: str)": "None"
    "load_checkpoint(path: str)": "None"
    "_log_metrics(loss: float, lr: float)": "None"
  }

  TrainingConfig: {
    shape: class
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    
    # Hyperparameters
    "num_epochs: int": "10"
    "learning_rate: float": "1e-4"
    "weight_decay: float": "0.01"
    "warmup_steps: int": "4000"
    "max_grad_norm: float": "1.0"
    "batch_size: int": "32"
    "label_smoothing: float": "0.1"
    "checkpoint_dir: str": '"./checkpoints"'
    "eval_frequency: int": "100"
  }
}

Model Components: {
  style: {
    fill: "transparent"
    stroke: "#CCC"
    stroke-dash: 4
  }

  EncoderDecoderTransformer: {
    shape: class
    style.fill: "#E8F5E9"
    style.stroke: "#388E3C"
    
    # Fields
    encoder: "TransformerEncoder"
    decoder: "TransformerDecoder"
    src_embed: "InputEmbedding"
    tgt_embed: "InputEmbedding"
    src_pos: "PositionalEncoding"
    tgt_pos: "PositionalEncoding"
    generator: "nn.Linear"
    
    # Methods
    "forward(src: Tensor, tgt: Tensor, src_mask: Tensor, tgt_mask: Tensor)": "Tensor"
    "encode(src: Tensor, src_mask: Tensor)": "Tensor"
    "decode(memory: Tensor, tgt: Tensor, tgt_mask: Tensor)": "Tensor"
  }
}

Loss and Scheduling: {
  style: {
    fill: "transparent"
    stroke: "#CCC"
    stroke-dash: 4
  }

  MaskedCrossEntropyLoss: {
    shape: class
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    
    # Fields
    criterion: "nn.CrossEntropyLoss"
    pad_idx: "int"
    label_smoothing: "float"
    
    # Methods
    "forward(logits: Tensor, targets: Tensor, mask: Tensor)": "Tensor"
    "_compute_masked_loss(loss: Tensor, mask: Tensor)": "Tensor"
  }

  TransformerLRScheduler: {
    shape: class
    style.fill: "#FFEBEE"
    style.stroke: "#D32F2F"
    
    # Fields
    optimizer: "torch.optim.Optimizer"
    d_model: "int"
    warmup_steps: "int"
    "current_step: int": "0"
    
    # Methods
    "step()": "None"
    "get_lr()": "float"
    "_compute_scale_factor()": "float"
  }
}

Data Pipeline: {
  style: {
    fill: "transparent"
    stroke: "#CCC"
    stroke-dash: 4
  }

  DataLoader: {
    shape: class
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
    
    # Fields
    dataset: "CopyTaskDataset"
    batch_size: "int"
    shuffle: "bool"
    num_workers: "int"
    
    # Methods
    "__iter__()": "Iterator"
    "__len__()": "int"
  }

  CopyTaskDataset: {
    shape: class
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    
    # Fields
    vocab_size: "int"
    seq_len: "int"
    num_samples: "int"
    
    # Methods
    "__getitem__(idx: int)": "Dict[str, Tensor]"
    "__len__()": "int"
    "_generate_sample()": "Tuple[Tensor, Tensor]"
  }
}

# --- RELATIONSHIPS (Using Absolute Scoped IDs) ---

Training Infrastructure.TrainingConfig -> Training Infrastructure.Trainer: "configures" {
  style.stroke-dash: 3
  style.stroke: "#666"
}

Model Components.EncoderDecoderTransformer -> Training Infrastructure.Trainer.model: "owns" {
  style.stroke: "#1976D2"
}

Loss and Scheduling.MaskedCrossEntropyLoss -> Training Infrastructure.Trainer.criterion: "owns" {
  style.stroke: "#7B1FA2"
}

Loss and Scheduling.TransformerLRScheduler -> Training Infrastructure.Trainer.scheduler: "owns" {
  style.stroke: "#D32F2F"
}

Data Pipeline.DataLoader -> Training Infrastructure.Trainer.train_dataloader: "train" {
  style.stroke: "#00838F"
}

Data Pipeline.DataLoader -> Training Infrastructure.Trainer.val_dataloader: "val" {
  style.stroke: "#00838F"
  style.stroke-dash: 3
}

Data Pipeline.CopyTaskDataset -> Data Pipeline.DataLoader.dataset: "references" {
  style.stroke: "#C2185B"
}

# --- UI ELEMENTS ---

legend: {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#DDD"
    border-radius: 4
  }
  
  title: "Diagram Legend" {
    style.bold: true
  }

  comp: "───► Composition" {
    class: mono_font
  }
  agg: "- - -> Aggregation" {
    class: mono_font
  }
  flow: "- - -> Configures" {
    class: mono_font
  }
}

main_title: "Trainer Class Architecture (Module 5)" {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# Final styles via glob
***.style.font: mono