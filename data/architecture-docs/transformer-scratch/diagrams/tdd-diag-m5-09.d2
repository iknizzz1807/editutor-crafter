direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: text
  label: |md
    ### Output Projection with Weight Tying
    *Intel Manual Quality Specification - Neural Network Architecture*
    **Ref: IEEE/ISO-NN-2024-M5**
  |
}

# --- 1. DECODER INTERFACE ---
decoder_output: {
  label: "Decoder Output Stack\nTensor: [Batch, Seq, D_Model]"
  shape: parallelogram
  tooltip: "High-dimensional hidden states from final attention block"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

# --- 2. TRANSFORMATION LAYER ---
output_proj: {
  label: "Output Projection (Linear Layer)\n[D_Model] -> [Vocab_Size]"
  shape: hexagon
  style: {
    fill: "#FFF3E0"
    stroke: "#EF6C00"
    stroke-width: 2
  }
  
  op: {
    shape: text
    label: "MatMul + Bias"
    style.font-size: 10
  }
}

# --- 3. WEIGHT TYING SUBSYSTEM ---
group_tied: {
  label: "Shared Parameter Space (Weight Tying)"
  
  shared_weights: {
    shape: cylinder
    label: ||md
      **Shared Weight Matrix (W_shared)**
      Size: [Vocab_Size x D_Model]

      | Offset | Field | Type |
      | :--- | :--- | :--- |
      | 0x00 | Token_0_Vec | float16[d] |
      | ... | ... | ... |
      | 0xMAX | Token_V_Vec | float16[d] |
    ||
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      stroke-width: 3
    }
  }

  target_embedding: {
    label: "Input Embedding Layer\n(Lookup Table)"
    shape: rectangle
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-dash: 3
    }
  }

  weight_tie_indicator: {
    shape: text
    label: "⚖️ BI-DIRECTIONAL MEMORY MAPPING"
    style: {
      font-size: 12
      bold: true
      font-color: "#9C27B0"
    }
  }

  style: {
    fill: "#FAFAFA"
    stroke: "#9C27B0"
    stroke-dash: 4
    border-radius: 10
  }
}

# --- 4. RESULTANT TENSOR ---
vocab_logits: {
  label: "Vocabulary Logits\nTensor: [Batch, Seq, Vocab_Size]"
  shape: parallelogram
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
  }
}

# --- 5. TECHNICAL CALLOUTS ---
param_savings: {
  shape: rectangle
  label: |md
    **Optimization Metrics (O(V*D))**
    - **Physical Storage:** Shared Pointer 0x7FF
    - **Params Saved:** `vocab_size * d_model`
    - **Gradient Path:** Summed gradients from 
      In-Embedding and Out-Projection.
  |
  style: {
    fill: "#C8E6C9"
    stroke: "#4CAF50"
    font-size: 12
  }
}

implementation_note: {
  shape: text
  label: |latex
    \text{Logits} = \text{LayerNorm}(X_{dec}) \cdot W_{shared}^T + b
  |
}

# --- CONNECTIONS ---

# Data Flow: Forward Pass
decoder_output -> output_proj: "x ∈ ℝ^{d_{model}}" {
  style: {
    stroke-width: 2
    font-size: 11
  }
}

output_proj -> vocab_logits: "y = xW^T + b" {
  style: {
    stroke-width: 2
    font-size: 11
  }
}

# Weight Access (Logic)
group_tied.shared_weights -> output_proj: "Shared Pointer (Transposed Access)" {
  style: {
    stroke: "#9C27B0"
    stroke-dash: 5
    stroke-width: 2
  }
}

# Visualizing the identity map of the two layers
group_tied.target_embedding <-> group_tied.shared_weights: "Identity Map (Memory Pointer)" {
  style: {
    stroke: "#9C27B0"
    stroke-width: 4
  }
}

# Hidden alignment edge to keep shared space near projection
output_proj -- group_tied: {
  style.opacity: 0
}

# Metadata Footer
footer: {
  shape: text
  label: "Architecture Design Grade: Production Specification (O(V*D))"
  style.font-size: 10
}