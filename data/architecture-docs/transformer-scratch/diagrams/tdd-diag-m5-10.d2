vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

direction: right

# --- CLASSES & STYLES ---
classes: {
  explanation_box: {
    style: {
      stroke-width: 1
      border-radius: 4
      shadow: true
    }
  }
  standard_val: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  warning_val: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
    }
  }
  memory_header: {
    style: {
      fill: "#9C27B0"
      font-color: white
      bold: true
    }
  }
}

# --- OPTIMIZER CONFIGURATION ---
# Fixed: Removed \n from the sql_table label to prevent compilation error
AdamOptimizer: {
  shape: sql_table
  label: "Adam Optimizer Memory State"
  style: {
    fill: "#9C27B0"
    stroke: "#4527A0"
    font-color: "#FFFFFF"
    stroke-width: 2
  }

  beta1: "float32 (0.9)" {
    constraint: "0x00 [4B]"
    style.fill: "#E3F2FD"
  }
  beta2: "float32 (0.98)" {
    constraint: "0x04 [4B]"
    style.fill: "#FFF3E0"
  }
  epsilon: "float32 (1e-9)" {
    constraint: "0x08 [4B]"
    style.fill: "#E3F2FD"
  }
  m_ptr: "void* (Momentum)" {
    constraint: "0x0C [8B]"
    style.fill: "#E3F2FD"
  }
  v_ptr: "void* (Velocity)" {
    constraint: "0x14 [8B]"
    style.fill: "#E3F2FD"
  }
  padding: "int64 (Alignment)" {
    constraint: "0x1C [4B]"
    style.fill: "#EEEEEE"
  }
  
  # Method description as a nested text near the table since sql_table headers are restricted
  info: "sizeof: 32 Bytes (Aligned)" {
    near: top-right
    shape: text
    style.font-size: 10
  }
}

# --- DETAILED EXPLANATIONS ---

Beta1Explanation: {
  class: [explanation_box; standard_val]
  label: |md
    ### beta1 = 0.9
    ---
    **Role:** Exponential decay rate for first moment (gradient mean).
    **Status:** Standard value ✓
    **Impact:** Controls how much "history" of the gradient direction is kept.
  |
}

Beta2Explanation: {
  class: [explanation_box; warning_val]
  label: |md
    ### beta2 = 0.98 ⚠️
    ---
    **Role:** Non-standard decay for second moment (variance).
    **Context:** Transformer "Attention Is All You Need" (2017).
    **Logic:** Faster decay (0.98 vs 0.999) aids convergence in specific warmup schedules.
  |
}

EpsilonExplanation: {
  class: [explanation_box; standard_val]
  label: |md
    ### epsilon = 1e-9
    ---
    **Role:** Numerical stability constant.
    **Function:** Prevents division by zero in bias-corrected variance estimates.
    **Status:** Standard value ✓
  |
}

# --- CONNECTIONS ---

AdamOptimizer.beta1 -> Beta1Explanation: {
  style: {
    stroke: "#4CAF50"
    stroke-dash: 3
    stroke-width: 2
  }
}

AdamOptimizer.beta2 -> Beta2Explanation: {
  style: {
    stroke: "#FF9800"
    stroke-dash: 3
    stroke-width: 2
  }
}

AdamOptimizer.epsilon -> EpsilonExplanation: {
  style: {
    stroke: "#4CAF50"
    stroke-dash: 3
    stroke-width: 2
  }
}

# --- ANNOTATIONS ---

Title: {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
    font-color: "#1565C0"
  }
  label: "Adam Optimizer Configuration & Hyperparameter Analysis"
}

Note: {
  shape: rectangle
  near: bottom-center
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    stroke-width: 2
  }
  label: |md
    ## 📝 Implementation Insight: beta2=0.98
    - **Adaptation:** Faster tracking of gradient variance changes compared to default 0.999.
    - **Stability:** Crucial when using high learning rates with short linear warmups (Transformer-specific).
    - **Memory:** Total state footprint is 3x parameter size: (Params [W] + Momentum [M] + Velocity [V]).
  |
}

# Documentation Metadata
Legend: {
  near: bottom-right
  direction: down
  title: "Key"
  standard: Standard Config {
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
  }
  modified: Optimized / Modified {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  padding: Padding / Alignment {
    style.fill: "#EEEEEE"
    style.stroke: "#9E9E9E"
  }
}