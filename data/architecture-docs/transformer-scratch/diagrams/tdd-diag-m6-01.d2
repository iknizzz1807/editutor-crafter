direction: down
layout-engine: elk
title: {
  label: "Greedy Decoding Loop\nTransformer Autoregressive Generation"
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}
step1_encode: {
  label: "STEP 1: Encode Source\n(Execute Once)"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}
step1_details: {
  label: "encoder_output = model.encode(src_tokens)\n• Process entire source sequence\n• Cache encoder hidden states\n• Shape: [batch, src_len, d_model]"
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font-size: 11
    multiple: true
  }
}
step2_init: {
  label: "STEP 2: Initialize Generation"
  shape: rectangle
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}
step2_details: {
  label: "generated = [batch_size, 1]\nfilled with <sos> token_id\n• Start of sequence marker\n• First decoder input"
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font-size: 11
    multiple: true
  }
}
loop_container: {
  label: "STEP 3: Generation Loop (for step in range(max_len))"
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 3
    stroke-dash: 4
    font-size: 14
    bold: true
  }
  step3a_mask: {
    label: "3a: Create Causal Mask"
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF8F00"
      font-size: 12
    }
  }
  step3b_decode: {
    label: "3b: Decoder Forward Pass"
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF8F00"
      font-size: 12
    }
  }
  step3c_logits: {
    label: "3c: Extract Logits\nlogits = decoder_out[:, -1, :]\nGet predictions for last position"
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF8F00"
      font-size: 12
      multiple: true
    }
  }
  step3d_argmax: {
    label: "3d: Argmax Selection\nnext_token = argmax(logits)\nGreedy: highest probability token"
    shape: rectangle
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      stroke-width: 2
      font-size: 12
      multiple: true
    }
  }
  step3e_append: {
    label: "3e: Append Token\ngenerated = concat([generated, next_token])\nGrow the sequence"
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FF8F00"
      font-size: 12
      multiple: true
    }
  }
  step3f_eos: {
    label: "3f: Check EOS\nif next_token == <eos>:\n    break loop"
    shape: diamond
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
      font-size: 12
    }
  }
  step3a_mask -> step3b_decode
  step3b_decode -> step3c_logits
  step3c_logits -> step3d_argmax
  step3d_argmax -> step3e_append
  step3e_append -> step3f_eos
}
step4_return: {
  label: "STEP 4: Return Generated Sequence"
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}
step4_details: {
  label: "return generated\n• Complete target sequence\n• Shape: [batch, seq_len]\n• Ends with <eos> or max_len"
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    font-size: 11
    multiple: true
  }
}
encoder_cache: {
  label: "Encoder Output\n(Cached)"
  shape: cylinder
  style: {
    fill: "#E0F7FA"
    stroke: "#00695C"
    font-size: 11
  }
}
generated_seq: {
  label: "Generated\nSequence"
  shape: cylinder
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    font-size: 11
  }
}
# Main flow connections
step1_encode -> step2_init: {
  label: "encoder_output"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
step2_init -> loop_container: {
  label: "generated=[<sos>]"
  style: {
    stroke: "#1565C0"
    stroke-width: 2
  }
}
loop_container -> step4_return: {
  label: "EOS or max_len"
  style: {
    stroke: "#E65100"
    stroke-width: 2
  }
}
# Side connections to caches
step1_encode -> encoder_cache: {
  style: {
    stroke: "#00695C"
    stroke-dash: 3
  }
}
encoder_cache -> loop_container: {
  label: "cross-attention"
  style: {
    stroke: "#00695C"
    stroke-dash: 3
  }
}
loop_container -> generated_seq: {
  style: {
    stroke: "#7B1FA2"
    stroke-dash: 3
  }
}
generated_seq -> loop_container: {
  label: "decoder input"
  style: {
    stroke: "#7B1FA2"
    stroke-dash: 3
  }
}
step4_return -> step4_details
# Detail box connections
step1_encode -> step1_details: {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
}
step2_init -> step2_details: {
  style: {
    stroke: "#9E9E9E"
    stroke-dash: 2
  }
}
# Loop back arrow
loop_back: {
  label: "Continue\n(autoregressive)"
  shape: text
  style: {
    font-size: 10
    italic: true
  }
}
loop_container -> loop_back -> loop_container: {
  style: {
    stroke: "#E65100"
    stroke-width: 2
    stroke-dash: 4
    animated: true
  }
}
legend: {
  label: "Legend"
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    font-size: 10
  }
  one_time: {
    label: "Green: Execute Once"
    shape: rectangle
    style: { fill: "#E8F5E9" }
  }
  init: {
    label: "Blue: Initialization"
    shape: rectangle
    style: { fill: "#E3F2FD" }
  }
  loop_step: {
    label: "Orange: Loop Step"
    shape: rectangle
    style: { fill: "#FFF8E1" }
  }
  decision: {
    label: "Purple: Decision/Selection"
    shape: rectangle
    style: { fill: "#FCE4EC" }
  }
  one_time -> init -> loop_step -> decision: {
    style: { stroke: "transparent" }
  }
}