vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Attention Complexity Analysis
  **Naive Generation: O(n³) vs KV Cache: O(n²)**
| {near: top-center}
direction: right
NAIVE_GENERATION: "Naive Generation\n(No KV Cache)" {
  style.fill: "#FFE4E1"
  style.stroke: "#CD5C5C"
  style.stroke-width: 2
  explanation_naive: |md
    Each step recomputes attention
    over ALL previous positions
    Step 1: 1² = 1 ops
    Step 2: 2² = 4 ops  
    Step 3: 3² = 9 ops
    ...
    Step n: n² ops
    **Total: O(n³)**
  | {shape: text}
  naive_formula: "Σ(i=1 to n) i² = n(n+1)(2n+1)/6 ≈ n³/3"
}
KV_CACHE_GENERATION: "KV Cache Generation" {
  style.fill: "#E0FFE0"
  style.stroke: "#228B22"
  style.stroke-width: 2
  explanation_cache: |md
    Keys and Values cached,
    only new token processed
    Step 1: 1 op
    Step 2: 2 ops
    Step 3: 3 ops
    ...
    Step n: n ops
    **Total: O(n²)**
  | {shape: text}
  cache_formula: "Σ(i=1 to n) i = n(n+1)/2 ≈ n²/2"
}
NAIVE_GENERATION -> KV_CACHE_GENERATION: "Speedup Factor: ~n/3" {
  style.stroke: "#4169E1"
  style.stroke-width: 3
  style.bold: true
}
COMPLEXITY_COMPARISON: {
  grid-columns: 3
  grid-gap: 20
  header_seq: "Sequence Length (n)" {class: header}
  header_naive: "Naive O(n³)" {class: header}
  header_cache: "KV Cache O(n²)" {class: header}
  seq_10: "10 tokens"
  naive_10: "1,000 ops"
  cache_10: "100 ops"
  seq_50: "50 tokens"
  naive_50: "125,000 ops"
  cache_50: "2,500 ops"
  seq_100: "100 tokens"
  naive_100: "1,000,000 ops"
  cache_100: "10,000 ops"
  seq_500: "500 tokens"
  naive_500: "125,000,000 ops"
  cache_500: "250,000 ops"
  *.class: data
}
classes: {
  header: {
    style: {
      bold: true
      underline: true
      fill: "#E6E6FA"
    }
  }
  data: {
    style.fill: white
    style.stroke: "#D3D3D3"
  }
}
SPEEDUP_VISUAL: {
  direction: right
  naive_bar: "Naive\nn³ Growth" {
    width: 400
    height: 200
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 2
  }
  cache_bar: "KV Cache\nn² Growth" {
    width: 100
    height: 50
    style.fill: "#E0FFE0"
    style.stroke: "#228B22"
    style.stroke-width: 2
  }
  speedup_label: |md
    **100-token generation:**
    ~100x fewer FLOPs
    Measured: 2-5x wall-clock
    (Python overhead)
  | {shape: text}
}
MEMORY_FOOTPRINT: "KV Cache Memory" {
  style.fill: "#E6E6FA"
  style.stroke: "#9370DB"
  mem_formula: |md
    Memory per layer:
    `batch × heads × seq × d_k × 4 bytes × 2 (K+V)`
    Example (batch=1, layers=6, heads=8, d_k=64):
    - 100 tokens: **2.46 MB**
    - 500 tokens: **12.3 MB**
    - 1000 tokens: **24.6 MB**
    Linear growth with sequence length
  | {shape: text}
}
ATTENTION_FLOW_NAIVE: "Naive: Step-by-Step Recomputation" {
  style.fill: "#FFF0F5"
  style.stroke: "#DB7093"
  step1_n: "Step 1: Compute K,V for pos 1\nAttention: Q₁ × K₁ᵀ (1×1)"
  step2_n: "Step 2: Recompute K,V for pos 1,2\nAttention: Q₂ × K₁,₂ᵀ (1×2)"
  step3_n: "Step 3: Recompute K,V for pos 1,2,3\nAttention: Q₃ × K₁,₂,₃ᵀ (1×3)"
  step_n_n: "Step n: Recompute ALL K,V\nAttention: Qₙ × K₁...ₙᵀ (1×n)"
  step1_n -> step2_n -> step3_n -> step_n_n {
    style.stroke: "#CD5C5C"
    style.stroke-dash: 3
  }
}
ATTENTION_FLOW_CACHE: "KV Cache: Incremental Update" {
  style.fill: "#F0FFF0"
  style.stroke: "#2E8B57"
  step1_c: "Step 1: Compute K₁,V₁ → Cache\nAttention: Q₁ × K₁ᵀ (1×1)"
  step2_c: "Step 2: Compute K₂,V₂ → Cache\nAttention: Q₂ × K₁,₂ᵀ (1×2)\n**Reuses K₁,V₁**"
  step3_c: "Step 3: Compute K₃,V₃ → Cache\nAttention: Q₃ × K₁,₂,₃ᵀ (1×3)\n**Reuses K₁,₂,V₁,₂**"
  step_n_c: "Step n: Compute Kₙ,Vₙ → Cache\nAttention: Qₙ × K₁...ₙᵀ (1×n)\n**Reuses ALL previous K,V**"
  step1_c -> step2_c -> step3_c -> step_n_c {
    style.stroke: "#228B22"
    style.stroke-dash: 3
  }
}
BOTTOM_LINE: |md
  ### Key Insight
  - **Without cache**: Each new token triggers full sequence re-encoding (quadratic attention, n times → cubic)
  - **With cache**: Each new token only attends to cached history (linear per step → quadratic total)
  - **Practical speedup**: 2-5x measured (theoretical ~n/3) due to Python overhead and memory access patterns
| {near: bottom-center}