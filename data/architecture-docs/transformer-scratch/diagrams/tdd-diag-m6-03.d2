direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# --- GLOBAL STYLES & CLASSES ---
classes: {
  terminal: {
    shape: oval
    style.stroke-width: 2
  }
  process: {
    shape: rectangle
    style.stroke-width: 2
  }
  data_store: {
    shape: parallelogram
    style.stroke-width: 2
  }
  decision: {
    shape: diamond
    style.stroke-width: 2
  }
}

title: |md
  ### Transformer Inference & Generation (Module m6)
  **Architecture: KV Cache & Autoregressive Decoding**
| {
  near: top-center
  shape: text
}

# --- MAIN COMPONENTS ---

source_tokens: {
  label: "Source Tokens\n(Prompt Input)"
  class: terminal
  style.fill: "#E3F2FD"
}

encoder: {
  label: "Encoder Stack\n(Context Encoding)"
  class: process
  style.fill: "#FFF3E0"
  
  encoder_layers: {
    label: "6× Encoder Layers\nSelf-Attention + FFN"
    shape: rectangle
    style.stroke-dash: 3
  }
}

encoder_output: {
  label: "Memory Keys/Values\n(Context Matrix)"
  class: data_store
  style.fill: "#F3E5F5"
}

decoder: {
  label: "Decoder Stack\n(Generation Core)"
  class: process
  style.fill: "#E8F5E9"
  
  decoder_layers: {
    label: "6× Decoder Layers\n(Causal + Cross-Attn)"
    shape: rectangle
    style.double-border: true
  }
}

kv_cache: {
  label: "KV Cache\n(In-Memory Tensors)"
  class: data_store
  style.fill: "#FFEBEE"
  
  k_cache: { 
    label: "K Cache\n[batch, heads, seq, d_k]" 
    tooltip: "Stores keys from previous time steps"
  }
  v_cache: { 
    label: "V Cache\n[batch, heads, seq, d_v]" 
    tooltip: "Stores values from previous time steps"
  }
  
  k_cache -> v_cache: { style.opacity: 0 }
}

output_projection: {
  label: "Language Model Head"
  class: process
  style.fill: "#FFF8E1"
  
  linear: { label: "Linear(d_model → vocab_size)" }
  softmax: { label: "Softmax (Log Probabilities)" }
  linear -> softmax
}

logits: {
  label: "Vocabulary Logits"
  class: data_store
  style.fill: "#E0F7FA"
}

sampling: {
  label: "Sampling\nStrategy?"
  class: decision
  style.fill: "#FCE4EC"
}

greedy: {
  label: "Greedy\nargmax(logits)"
  class: process
  style.fill: "#C8E6C9"
}

temperature: {
  label: "Temperature\nlogits / T"
  class: process
  style.fill: "#B3E5FC"
}

top_k: {
  label: "Top-k\nTruncate to k"
  class: process
  style.fill: "#FFE0B2"
}

top_p: {
  label: "Top-p\nNucleus Filter"
  class: process
  style.fill: "#E1BEE7"
}

beam: {
  label: "Beam Search\nTrack N paths"
  class: process
  style.fill: "#FFCDD2"
}

next_token: {
  label: "Selected Token ID\n(wₜ)"
  class: terminal
  style.fill: "#B2DFDB"
}

generated_sequence: {
  label: "Full Generated\nSequence"
  class: terminal
  style.fill: "#DCEDC8"
}

# --- CONFIGURATION BOX ---

gen_config: {
  label: "GenerationConfig (Hyperparameters)"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 5

  max_length: "max_length: int"
  num_beams: "num_beams: int = 1"
  temperature: "temperature: float = 0.7"
  top_p: "top_p: float = 0.9"
  do_sample: "do_sample: bool = True"
  eos_token_id: "eos_token_id: int"
}

# --- CONNECTIONS ---

source_tokens -> encoder: "N prompt tokens"
encoder -> encoder_output: "Cross-Attn Memory"

encoder_output -> decoder: "Memory K,V"
decoder <-> kv_cache: "Read Cache / Append New KV" {
  style.stroke-width: 3
  style.stroke: "#D32F2F"
}

decoder -> output_projection: "Final Hidden State [1, d_model]"
output_projection -> logits
logits -> sampling

gen_config -> sampling: "Control Params"

sampling -> greedy: "strategy=greedy"
sampling -> temperature: "do_sample=true"
sampling -> top_k: "top_k > 0"
sampling -> top_p: "top_p < 1.0"
sampling -> beam: "num_beams > 1"

greedy -> next_token
temperature -> next_token
top_k -> next_token
top_p -> next_token
beam -> next_token

next_token -> generated_sequence: "Concatenate"
generated_sequence -> decoder: "Input for t+1\n(Autoregressive)" {
  style.stroke-dash: 5
  style.animated: true
}

# --- LEGEND ---

legend: {
  shape: rectangle
  near: bottom-right
  style.fill: white
  style.stroke: gray
  
  l1: "→ Forward Flow"
  l2: "↔ State Update (KV)"
  l3: "- - → Autoregressive Loop"
  
  l1 -> l2 -> l3: { style.opacity: 0 }
}