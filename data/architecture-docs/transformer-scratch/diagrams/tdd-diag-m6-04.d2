direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: |md
  # KV Cache Data Structure
  ## Memory Layout & Tensor Orchestration
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
    bold: true
  }
}

# 1. Main KVCache Architecture
KVCache: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    stroke-width: 2
  }
  
  # Header: Purple per persona rules
  header: "@dataclass KVCache" {
    shape: rectangle
    style: {
      fill: "#6e41ab"
      stroke: "#9d70ff"
      font-color: white
      bold: true
    }
  }

  # Data components: Blue per persona rules
  storage: {
    keys: "List[torch.Tensor]" {
      style: {
        fill: "#3b82f6"
        stroke: "#60a5fa"
        font-color: white
      }
      tooltip: "Shape: [B, H, S, D]"
    }
    values: "List[torch.Tensor]" {
      style: {
        fill: "#3b82f6"
        stroke: "#60a5fa"
        font-color: white
      }
      tooltip: "Shape: [B, H, S, D]"
    }
  }

  header -> storage.keys: "ptr_to_list" {style.stroke: orange}
  header -> storage.values: "ptr_to_list" {style.stroke: orange}
}

# 2. Memory Layout / Layer Structure
LayerStructure: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
    double-border: true
  }
  
  label: "Memory Layout: L Layers (Contiguous Blocks)"
  
  L0: "Layer 0 [Offset 0x00]" {
    shape: rectangle
    style.fill: "#16213e"
    k: "keys[0] (float16/32)" { style.fill: "#0f3460" }
    v: "values[0] (float16/32)" { style.fill: "#0f3460" }
  }

  L1: "Layer 1 [Offset 0x...]" {
    shape: rectangle
    style.fill: "#16213e"
    k: "keys[1]" { style.fill: "#0f3460" }
    v: "values[1]" { style.fill: "#0f3460" }
  }

  LDots: "..." { shape: text; style.font-size: 30 }

  LN: "Layer L-1" {
    shape: rectangle
    style.fill: "#16213e"
    k: "keys[L-1]" { style.fill: "#0f3460" }
    v: "values[L-1]" { style.fill: "#0f3460" }
  }

  L0 -> L1 -> LDots -> LN: "Sequential Allocation"
}

# 3. Tensor Shape Definition (FIXED SQL TABLE)
TensorShape: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
  }
  
  label: "Tensor Descriptor (Shape Breakdown)"

  # Corrected SQL Table: Rows are flat pairs, no nested children blocks
  dims: {
    shape: sql_table
    style.fill: "#0f3460"
    style.stroke: "#e94560"
    
    batch: "int64" {constraint: "Dim 0 (N)"}
    num_heads: "int64" {constraint: "Dim 1 (H)"}
    seq_len: "int64" {constraint: "Dim 2 (S)"}
    head_dim: "int64" {constraint: "Dim 3 (D)"}
  }

  desc: |md
    ### Dimension Metadata
    - **batch**: Parallel inference streams
    - **num_heads**: Attention parallelism
    - **seq_len**: Dynamic growth (+1/step)
    - **head_dim**: Embedding subspace size
  | {
    style.font-size: 12
  }

  dims -> desc
}

# 4. Interface / Methods
Methods: {
  style: {
    fill: "#1a1a2e"
    stroke: "#4a4a6a"
  }
  
  label: "Public API & State Management"

  create: "create(n_layers, n_heads, d_k)" {
    shape: rectangle
    style.stroke: "#00d9ff"
    style.fill: "#16213e"
  }
  
  update: "update(layer_idx, new_k, new_v)" {
    shape: rectangle
    style.stroke: "#00d9ff"
    style.fill: "#16213e"
    tooltip: "In-place concatenation"
  }

  get: "get_layer(layer_idx)" {
    shape: rectangle
    style.stroke: "#00d9ff"
    style.fill: "#16213e"
  }

  clear: "reset_cache()" {
    shape: rectangle
    style.stroke: "#e94560"
    style.fill: "#16213e"
  }
}

# 5. Efficiency Analysis
Complexity: {
  shape: rectangle
  style: {
    fill: "#10b981" # Green per persona (Success/Efficiency)
    stroke: "#14ffec"
    stroke-width: 3
    shadow: true
  }
  label: |md
    ## Performance Optimization
    ---
    **Standard Attn:** O(N³)
    **KV-Cached Attn:** O(N²)
    ---
    Prevents redundant projection 
    of past keys/values during 
    incremental generation.
  |
}

# Inter-component Connections
KVCache.storage -> LayerStructure: "Physical Mapping" {
  style.stroke-dash: 3
  style.stroke: "#e94560"
}

KVCache.storage -> TensorShape.dims: "Memory View" {
  style.stroke-dash: 3
  style.stroke: "#e94560"
}

Methods -> KVCache: "mutates" {
  style.stroke: "#00d9ff"
  style.stroke-width: 2
}

LayerStructure -> Complexity: "enables" {
  style.stroke: "#14ffec"
  style.stroke-width: 2
  target-arrowhead: triangle
}