layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}

title: ScaledDotProductAttention Memory Layout {
  near: top-center
  shape: text
  style.font-size: 28
}

# Memory address scale
scale: {
  style.fill: transparent
  style.stroke: transparent
  offset_0: "0x0000" { shape: text }
  offset_8: "0x0008" { shape: text }
  offset_16: "0x0010" { shape: text }
  offset_24: "0x0018" { shape: text }
  offset_32: "0x0020" { shape: text }
  offset_40: "0x0028" { shape: text }
  offset_48: "0x0030" { shape: text }
  offset_56: "0x0038" { shape: text }
  offset_64: "0x0040" { shape: text }
  offset_0 -- offset_8 -- offset_16 -- offset_24 -- offset_32 -- offset_40 -- offset_48 -- offset_56 -- offset_64 {
    style.stroke: transparent
  }
}

# Header section (8 bytes)
header: {
  shape: rectangle
  label: "Class Header\nvtable ptr + refcount"
  style.fill: "#9B59B6"
  style.stroke: "#7D3C98"
  style.font-color: white
  width: 200
  height: 60
}

# Q Pointer (8 bytes)
q_ptr: {
  shape: rectangle
  label: "*Tensor Q\n[B, seq_len, 64]"
  style.fill: "#FFA500"
  style.stroke: "#CC8400"
  style.font-color: white
  width: 200
  height: 60
}

# K Pointer (8 bytes)
k_ptr: {
  shape: rectangle
  label: "*Tensor K\n[B, seq_len, 64]"
  style.fill: "#FFA500"
  style.stroke: "#CC8400"
  style.font-color: white
  width: 200
  height: 60
}

# V Pointer (8 bytes)
v_ptr: {
  shape: rectangle
  label: "*Tensor V\n[B, seq_len, 64]"
  style.fill: "#FFA500"
  style.stroke: "#CC8400"
  style.font-color: white
  width: 200
  height: 60
}

# Attention Scores Pointer (8 bytes)
scores_ptr: {
  shape: rectangle
  label: "*scores\n[B, seq_q, seq_k]"
  style.fill: "#FFA500"
  style.stroke: "#CC8400"
  style.font-color: white
  width: 200
  height: 60
}

# Weights Pointer (8 bytes)
weights_ptr: {
  shape: rectangle
  label: "*weights\n[B, seq_q, d_v]"
  style.fill: "#FFA500"
  style.stroke: "#CC8400"
  style.font-color: white
  width: 200
  height: 60
}

# Output Pointer (8 bytes)
output_ptr: {
  shape: rectangle
  label: "*output\n[B, seq_q, d_v]"
  style.fill: "#FFA500"
  style.stroke: "#CC8400"
  style.font-color: white
  width: 200
  height: 60
}

# Padding (8 bytes)
padding: {
  shape: rectangle
  label: "Padding\n(8 bytes)"
  style.fill: "#E0E0E0"
  style.stroke: "#BDC3C7"
  style.font-color: "#5D6D7E"
  width: 200
  height: 60
}

# Size annotations on right
sizes: {
  style.fill: transparent
  style.stroke: transparent
  size_8_1: "8 B" { shape: text }
  size_8_2: "8 B" { shape: text }
  size_8_3: "8 B" { shape: text }
  size_8_4: "8 B" { shape: text }
  size_8_5: "8 B" { shape: text }
  size_8_6: "8 B" { shape: text }
  size_8_7: "8 B" { shape: text }
  size_8_8: "8 B" { shape: text }
  size_8_1 -- size_8_2 -- size_8_3 -- size_8_4 -- size_8_5 -- size_8_6 -- size_8_7 -- size_8_8 {
    style.stroke: transparent
  }
}

# Cache line marker
cache_line_marker: "─── Cache Line 0 (64 bytes) ───" {
  shape: text
  style.underline: true
  style.font-size: 14
  style.bold: true
}

# Total size annotation
total_size: |md
  **Total: 64 bytes (1 cache line)**
  │ Purple: Header
  │ Orange: Pointers (7 × 8B)
  │ Gray: Padding
| {
  shape: rectangle
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  style.border-radius: 8
}

# Legend
legend: {
  legend_title: "Legend" {
    shape: text
    style.bold: true
  }
  purple_box: "" { 
    style.fill: "#9B59B6"
    width: 20
    height: 14 
  }
  purple_label: "Header" { shape: text }
  orange_box: "" { 
    style.fill: "#FFA500"
    width: 20
    height: 14 
  }
  orange_label: "Pointers" { shape: text }
  gray_box: "" { 
    style.fill: "#E0E0E0"
    width: 20
    height: 14 
  }
  gray_label: "Padding" { shape: text }
  purple_box -- purple_label { style.stroke: transparent }
  orange_box -- orange_label { style.stroke: transparent }
  gray_box -- gray_label { style.stroke: transparent }
}

# Layout connections
header -- q_ptr -- k_ptr -- v_ptr -- scores_ptr -- weights_ptr -- output_ptr -- padding {
  style.stroke: "#2C3E50"
  style.stroke-dash: 0
  style.stroke-width: 1
}

# Align scale with memory blocks
scale.offset_0 -- header: { style.stroke: transparent }
sizes.size_8_1 -- header: { style.stroke: transparent }

# Cache line grouping
cache_line_group: {
  style.stroke: "#2980B9"
  style.stroke-dash: 5
  style.fill: transparent
}

total_size -- legend: { style.stroke: transparent }