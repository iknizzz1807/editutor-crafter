vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

title: |md
  # Greedy Decoding Algorithm
  ### Step-by-Step Autoregressive Generation
|
title.near: top-center
title.style: {
  font-size: 24
  bold: true
}

direction: right

# --- STYLES & CLASSES ---
classes: {
  step_container: {
    style: {
      stroke-width: 4
      border-radius: 10
      shadow: true
    }
  }
  logic_block: {
    style: {
      fill: "white"
      stroke-width: 1
      border-radius: 4
    }
  }
}

# --- STEP 1: INITIALIZATION ---
step1_init: {
  label: "Step 1: Initialization"
  class: step_container
  style: {
    fill: "#E8F4F8"
    stroke: "#3B82F6"
  }

  encode_op: {
    label: "Encoder Forward Pass"
    class: logic_block
    encode_detail: ||md
      **Operation**: `encoder_output = model.encode(src_tokens)`
      - **Input**: `src_tokens [Batch, Src_Seq_Len]`
      - **Output**: `memory [Batch, Src_Seq_Len, Hidden_Dim]`
      - **Context**: Computed once per sequence.
    ||
  }

  init_gen: {
    label: "Buffer Setup"
    class: logic_block
    init_detail: ||md
      - `generated = [Batch, 1]` (Initialize with `<SOS>`)
      - `finished = [Batch]` (Boolean mask, all `False`)
      - `max_len = 512`
    ||
  }
  
  encode_op -> init_gen
}

# --- STEP 2: LOOP ---
step2_loop: {
  label: "Step 2: Generation Loop (Autoregressive)"
  class: step_container
  style: {
    fill: "#F0F8FF"
    stroke: "#7B2D8E"
  }

  loop_header: {
    label: "WHILE (step < max_len) AND (NOT finished.all())"
    shape: parallelogram
    style.fill: "#FFF9E6"
  }

  sub_process: {
    grid-columns: 2
    grid-gap: 20
    
    masking: {
      label: "1. Causal Masking"
      class: logic_block
      detail: ||md
        **Mask**: `Triu(Ones(L, L), 1)`
        Prevents model from looking at 
        future tokens during decode.
      ||
    }
    
    inference: {
      label: "2. Decoder Forward"
      class: logic_block
      detail: ||md
        **Call**: `model.decode(gen, memory, mask)`
        **Logits**: `[B, cur_len, Vocab]`
      ||
    }

    selection: {
      label: "3. Argmax Selection"
      class: logic_block
      style.stroke: "#EF4444"
      detail: ||md
        **Token**: `logits[:, -1, :].argmax(-1)`
        **Type**: Greedy (Local Optima)
      ||
    }

    update: {
      label: "4. State Update"
      class: logic_block
      detail: ||md
        - `generated.append(next_token)`
        - `finished |= (next_token == <EOS>)`
      ||
    }
  }

  loop_header -> sub_process.masking
}

# --- STEP 3: OUTPUT ---
step3_return: {
  label: "Step 3: Post-Processing"
  class: step_container
  style: {
    fill: "#ECFDF5"
    stroke: "#10B981"
  }
  
  return_desc: ||md
    **Return Value**: `generated_tokens [Batch, Result_Len]`
    
    **Post-Steps**:
    1. Strip padding tokens.
    2. Truncate after first `<EOS>`.
    3. Detach from computation graph.
  ||
}

# --- GLOBAL CONNECTIONS ---
step1_init -> step2_loop: "Enter Loop"
step2_loop -> step3_return: "Terminating Condition Met"

# --- ANNOTATIONS ---
complexity_note: ||md
  ### Complexity Analysis (Per Sequence)
  | Component | Complexity |
  | :--- | :--- |
  | **Memory Usage** | $O(B \cdot L \cdot D)$ |
  | **Time (Std)** | $O(L^2)$ |
  | **Time (KV Cache)** | $O(L)$ |
  
  **KV Cache Optimization**:
  By caching Key/Value pairs from previous 
  steps, we avoid $O(L^2)$ redundant dot 
  products in the Self-Attention layers.
||
complexity_note.near: bottom-right
complexity_note.style: {
  stroke: "#94A3B8"
  fill: "#F8FAFC"
  font-size: 12
}

legend: {
  B: Batch Size
  L: Sequence Length
  D: Model Dimension
  V: Vocab Size
}
legend.near: top-right
legend.style: {
  stroke-dash: 3
  font-size: 10
}

style: {
  fill: "#FFFFFF"
}