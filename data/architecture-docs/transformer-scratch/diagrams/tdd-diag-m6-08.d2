direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Temperature Effect on Sampling\nProbability Distribution Changes with Temperature Scaling"
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Input Section: Raw Logit values before normalization
input_section: {
  label: "Input Logits (Z)"
  style: {
    fill: "#E8F4FD"
    stroke: "#2563EB"
    stroke-width: 2
  }
  
  logits_box: {
    label: "Original Logits\n[2.0, 1.0, 0.5, 0.1]"
    shape: rectangle
    style: {
      fill: "#2563EB"
      font-color: white
      bold: true
      stroke: "#1E40AF"
      stroke-width: 2
    }
  }
  
  vocab_labels: {
    label: "Token A  →  2.0\nToken B  →  1.0\nToken C  →  0.5\nToken D  →  0.1"
    shape: text
    style: {
      font-size: 11
      font-color: "#64748B"
    }
  }
}

# Temperature Scaling Formula: Z_i / T
formula_section: {
  label: "Temperature Scaling Transformation"
  style: {
    fill: "#FEF3C7"
    stroke: "#F59E0B"
    stroke-width: 2
  }
  
  formula: {
    label: "scaled_logits = logits / T"
    shape: rectangle
    style: {
      fill: "#F59E0B"
      font-color: white
      bold: true
      font-size: 16
      stroke: "#D97706"
      stroke-width: 2
    }
  }
  
  formula_note: {
    label: "Higher T (Heat) → Increases entropy (Uniformity)\nLower T (Cold) → Decreases entropy (Focus)"
    shape: text
    style: {
      font-size: 11
      font-color: "#92400E"
    }
  }
}

input_section -> formula_section: "Apply Temperature (T)" {
  style: {
    stroke: "#F59E0B"
    stroke-width: 2
    animated: true
  }
}

# Comparison Section: Visualizing the 3 regimes
comparison_section: {
  label: "Temperature Comparison Regimes"
  style: {
    fill: "#F8FAFC"
    stroke: "#94A3B8"
    stroke-width: 1
    stroke-dash: 5
  }

  # Regime 1: Cold (Exploitation)
  cold_temp: {
    label: "T = 0.1 (Cold)\nLow Entropy / Deterministic"
    style: {
      fill: "#DCFCE7"
      stroke: "#16A34A"
      stroke-width: 3
    }
    cold_desc: {
      label: "Sharp Distribution"
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#166534"
      }
    }
    cold_probs: {
      label: "Probabilities:\n[0.9999, 0.0001, 0.0000, 0.0000]"
      shape: rectangle
      style: {
        fill: "#22C55E"
        font-color: white
        font-size: 12
      }
    }
    cold_visual: {
      label: "┃\n┃ ← Token A dominates\n┃\n‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾"
      shape: text
      style: {
        font-size: 10
        font-color: "#166534"
      }
    }
    cold_behavior: {
      label: "• High precision\n• Repetitive output\n• Argmax behavior"
      shape: text
      style: {
        font-size: 10
        font-color: "#15803D"
      }
    }
  }

  # Regime 2: Standard (Identity)
  std_temp: {
    label: "T = 1.0 (Standard)\nNatural Softmax"
    style: {
      fill: "#DBEAFE"
      stroke: "#2563EB"
      stroke-width: 3
    }
    std_desc: {
      label: "Natural Distribution"
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#1E40AF"
      }
    }
    std_probs: {
      label: "Probabilities:\n[0.62, 0.23, 0.10, 0.05]"
      shape: rectangle
      style: {
        fill: "#3B82F6"
        font-color: white
        font-size: 12
      }
    }
    std_visual: {
      label: "┃\n┃ ┃\n┃ ┃ ┃\n┃ ┃ ┃ ┃ ← Normal\n‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾"
      shape: text
      style: {
        font-size: 10
        font-color: "#1E40AF"
      }
    }
    std_behavior: {
      label: "• Default AI behavior\n• Human-like flow\n• Natural variation"
      shape: text
      style: {
        font-size: 10
        font-color: "#1D4ED8"
      }
    }
  }

  # Regime 3: Hot (Exploration)
  hot_temp: {
    label: "T = 5.0 (Hot)\nHigh Entropy / Stochastic"
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 3
    }
    hot_desc: {
      label: "Flat Distribution"
      shape: text
      style: {
        font-size: 14
        bold: true
        font-color: "#991B1B"
      }
    }
    hot_probs: {
      label: "Probabilities:\n[0.27, 0.25, 0.22, 0.26]"
      shape: rectangle
      style: {
        fill: "#EF4444"
        font-color: white
        font-size: 12
      }
    }
    hot_visual: {
      label: "┃ ┃ ┃ ┃\n┃ ┃ ┃ ┃ ← Uniform\n┃ ┃ ┃ ┃\n‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾‾"
      shape: text
      style: {
        font-size: 10
        font-color: "#991B1B"
      }
    }
    hot_behavior: {
      label: "• Maximum creativity\n• Risk of hallucinations\n• High randomness"
      shape: text
      style: {
        font-size: 10
        font-color: "#B91C1C"
      }
    }
  }
}

formula_section -> comparison_section: "Softmax Operation" {
  style: {
    stroke: "#64748B"
    stroke-width: 2
    animated: true
  }
}

# Output Results
output_section: {
  label: "Final Token Selection"
  style: {
    fill: "#F1F5F9"
    stroke: "#475569"
    stroke-width: 2
  }
  
  output_note: {
    label: "Sum of Probs (ΣP) always = 1.0\nT modifies variance, not relative ranking"
    shape: text
    style: {
      font-size: 11
      italic: true
      font-color: "#475569"
    }
  }
  
  recommendation: {
    label: "Optimum Performance Range\nT ∈ [0.7, 1.2]"
    shape: rectangle
    style: {
      fill: "#8B5CF6"
      font-color: white
      bold: true
      stroke: "#7C3AED"
      stroke-width: 2
    }
  }
}

comparison_section -> output_section: "Weighted Sampling" {
  style: {
    stroke-dash: 3
    stroke: "#8B5CF6"
  }
}

# Visualization Legend
legend: {
  label: "Distribution Signature Legend"
  style: {
    fill: "#F8FAFC"
    stroke: "#E2E8F0"
  }
  near: bottom-center
  
  bar_cold: "T < 1.0: ████░░░░░░ (Peak Selection)" {
    shape: text
    style: { font-size: 11; font-color: "#16A34A" }
  }
  bar_std: "T = 1.0: █▓▓░░░░░░░ (Natural Sample)" {
    shape: text
    style: { font-size: 11; font-color: "#2563EB" }
  }
  bar_hot: "T > 1.0: ▓▓▓▓▓▓▓▓▓▓ (Random Sample)" {
    shape: text
    style: { font-size: 11; font-color: "#DC2626" }
  }
}

# Algorithm Implementation Logic
algorithm_box: {
  label: "Temperature Sampling Logic"
  shape: rectangle
  near: top-right
  style: {
    fill: "#1E293B"
    font-color: "#F8FAFC"
    stroke: "#0F172A"
    stroke-width: 2
  }
  
  step1: "1. IF T ≈ 0: RETURN argmax(logits)" {
    shape: text
    style: { font-size: 11; font-color: "#94A3B8" }
  }
  step2: "2. scaled_logits = logits / T" {
    shape: text
    style: { font-size: 11; font-color: "#94A3B8" }
  }
  step3: "3. probabilities = Softmax(scaled_logits)" {
    shape: text
    style: { font-size: 11; font-color: "#94A3B8" }
  }
  step4: "4. token = MultinomialSample(probabilities)" {
    shape: text
    style: { font-size: 11; font-color: "#94A3B8" }
  }
}

input_section -> algorithm_box: {
  style: {
    stroke-dash: 3
    stroke: "#94A3B8"
    opacity: 0.5
  }
}