direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Generation Strategies Comparison\nAutoregressive Text Generation in Transformers"
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

# Common Input
Input: {
  shape: hexagon
  style.fill: "#E8F5E9"
  label: "Context + Prompt\n(Tokenized)"
}

Transformer: {
  shape: diamond
  style.fill: "#FFF3E0"
  label: "Transformer\nForward Pass"
}

# Greedy Decoding Column
Greedy_Decoding: {
  label: "Greedy Decoding"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  
  Process: {
    shape: rectangle
    style.stroke-dash: 2
    
    Select: "argmax(P(y_t | y_<t, x))" {
      shape: diamond
    }
    Token: "Single Token\nHighest Probability" {
      shape: rectangle
    }
    Next: "Append & Continue" {
      shape: circle
    }
    
    Select -> Token: "select"
    Token -> Next: "emit"
    Next -> Select: "loop until <EOS>"
  }
  
  Characteristics: {
    shape: rectangle
    label: ||md
### Implementation (PyTorch)
python
# Single step - No lookahead
logits = model(context)
next_token = logits.argmax(dim=-1)

||
  }
  
  Pros: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: ||md
### ✅ Pros
- **Fastest**: O(n) sequential steps
- **Deterministic**: Reproducible outputs
- **Simple**: Minimal implementation
- **Low memory**: No hypothesis storage
- **Real-time**: Suitable for streaming
||
  }
  
  Cons: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: ||md
### ❌ Cons
- **No diversity**: Always same output
- **Local optima**: Misses global best
- **Repetitive**: Prone to phrase loops
- **Short-term**: Ignores future context
||
  }
}

# Beam Search Column
Beam_Search: {
  label: "Beam Search"
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  
  Process: {
    shape: rectangle
    style.stroke-dash: 2
    
    Init: "Initialize k beams\n(k=5 typical)" {
      shape: rectangle
    }
    Expand: "Expand all beams\nAccumulate log-probs" {
      shape: rectangle
    }
    Prune: "Keep top-k\nhypotheses" {
      shape: diamond
    }
    Score: "Apply length penalty\nscore = log P / L^α" {
      shape: rectangle
    }
    Select: "Return best\ncompleted sequence" {
      shape: circle
    }
    
    Init -> Expand: "expand"
    Expand -> Prune: "evaluate"
    Prune -> Expand: "continue"
    Prune -> Score: "all complete"
    Score -> Select: "finalize"
  }
  
  Characteristics: {
    shape: rectangle
    label: ||md
### Implementation
python
# Maintain k hypotheses
beams = [(start_token, 0.0)]
for step in range(max_len):
    candidates = []
    for seq, score in beams:
        logits = model(seq)
        top_k = logits.topk(k)
        # expand & accumulate score
    beams = sorted(candidates)[:k]

||
  }
  
  Pros: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: ||md
### ✅ Pros
- **Quality**: Explores more paths
- **Global view**: Considers sequence
- **Configurable**: Width vs. Speed
- **Standard**: Translation/Summarization
||
  }
  
  Cons: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: ||md
### ❌ Cons
- **Slower**: O(k × n) computations
- **Memory**: Stores k active sequences
- **Limited**: Still deterministic
- **Bias**: Needs alpha penalty tuning
||
  }
}

# Sampling Column
Sampling: {
  label: "Sampling (Temperature)"
  style.fill: "#FFF8E1"
  style.stroke: "#F57C00"
  
  Process: {
    shape: rectangle
    style.stroke-dash: 2
    
    Temp: "Apply Temperature\nP' = softmax(logits/T)" {
      shape: rectangle
    }
    Filter: "Top-k & Top-p\n(Nucleus) Filtering" {
      shape: diamond
    }
    Sample: "Random Sample\nfrom distribution" {
      shape: rectangle
    }
    Emit: "Emit Token\nContinue" {
      shape: circle
    }
    
    Temp -> Filter: "scale"
    Filter -> Sample: "restrict"
    Sample -> Emit: "draw"
    Emit -> Temp: "loop"
  }
  
  Characteristics: {
    shape: rectangle
    label: ||md
### Implementation
python
# Temperature scaling
logits = model(context) / T
probs = softmax(logits)

# Nucleus (Top-p) Filtering
sorted_p, sorted_i = probs.sort(desc=True)
cumulative_p = sorted_p.cumsum(dim=-1)
# filter where cumulative_p > p

||
  }
  
  Pros: {
    shape: rectangle
    style.fill: "#C8E6C9"
    label: ||md
### ✅ Pros
- **Diversity**: Creative generation
- **Dynamic**: Controllable knobs
- **Natural**: Human-like variation
- **Stories**: Best for creative writing
||
  }
  
  Cons: {
    shape: rectangle
    style.fill: "#FFCDD2"
    label: ||md
### ❌ Cons
- **Inconsistent**: Non-deterministic
- **Coherence**: Can hallucinate nonsense
- **Tuning**: Requires careful T, p values
- **Critical Apps**: Unreliable for facts
||
  }
}

# KV Cache (shared optimization)
KV_Cache: {
  label: ||md
## KV Cache (Key-Value) Optimization
**All strategies utilize this to reduce O(n²) to O(n)**

1. **Store**: Cache $K_{1..t-1}$ and $V_{1..t-1}$ across steps.
2. **Compute**: Only generate $Q_t, K_t, V_t$ for current token.
3. **Concat**: $K_{full} = [K_{cached}, K_t]$, $V_{full} = [V_{cached}, V_t]$.
4. **Attend**: Compute Attention using new $Q_t$ and expanded $K, V$.
||
  shape: rectangle
  style.fill: "#ECEFF1"
  style.stroke: "#607D8B"
}

# Comparison Summary
Comparison_Matrix: {
  label: ||md
## Strategy Selection Guide

| Criterion | Greedy | Beam | Sampling |
| :--- | :--- | :--- | :--- |
| **Speed** | ⚡ Fastest | 🐢 Slower | ⚡ Fast |
| **Quality** | ⭐ Good | ⭐⭐ Best | 🎲 Variable |
| **Diversity** | ❌ None | ❌ Low | ✅ High |
| **Reproducible** | ✅ Yes | ✅ Yes | ❌ No |
| **Memory** | 💾 Low | 💾 Medium | 💾 Low |
| **Use Case** | Chatbots | Translation | Creative |
||
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
}

