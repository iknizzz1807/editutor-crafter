direction: right
layout-engine: elk
title: KV Cache Speedup Benchmark {
  shape: text
  near: top-center
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
subtitle: Generation Time Comparison (Naive vs Cached) {
  shape: text
  style: {
    font-size: 16
    italic: true
  }
}
# Legend
legend: {
  style.stroke-dash: 3
  naive_legend: "● Naive (No Cache) - O(n³)"
  cached_legend: "● With KV Cache - O(n²)"
  naive_legend.style.fill: "#E74C3C"
  cached_legend.style.fill: "#27AE60"
}
# X-Axis: Sequence Lengths
seq_10: "Seq Length\n10 tokens" {
  style: {
    fill: "#ECF0F1"
    stroke: "#BDC3C7"
  }
}
seq_25: "Seq Length\n25 tokens" {
  style: {
    fill: "#ECF0F1"
    stroke: "#BDC3C7"
  }
}
seq_50: "Seq Length\n50 tokens" {
  style: {
    fill: "#ECF0F1"
    stroke: "#BDC3C7"
  }
}
seq_100: "Seq Length\n100 tokens" {
  style: {
    fill: "#ECF0F1"
    stroke: "#BDC3C7"
  }
}
seq_200: "Seq Length\n200 tokens" {
  style: {
    fill: "#ECF0F1"
    stroke: "#BDC3C7"
  }
}
# Naive Generation Times (ms) - without KV cache
naive_10: "45ms" {
  style: {
    fill: "#E74C3C"
    stroke: "#C0392B"
    font-color: white
    bold: true
  }
}
naive_25: "180ms" {
  style: {
    fill: "#E74C3C"
    stroke: "#C0392B"
    font-color: white
    bold: true
  }
}
naive_50: "720ms" {
  style: {
    fill: "#E74C3C"
    stroke: "#C0392B"
    font-color: white
    bold: true
  }
}
naive_100: "2.8s" {
  style: {
    fill: "#E74C3C"
    stroke: "#C0392B"
    font-color: white
    bold: true
  }
}
naive_200: "11.2s" {
  style: {
    fill: "#E74C3C"
    stroke: "#C0392B"
    font-color: white
    bold: true
  }
}
# Cached Generation Times (ms) - with KV cache
cached_10: "22ms" {
  style: {
    fill: "#27AE60"
    stroke: "#1E8449"
    font-color: white
    bold: true
  }
}
cached_25: "65ms" {
  style: {
    fill: "#27AE60"
    stroke: "#1E8449"
    font-color: white
    bold: true
  }
}
cached_50: "190ms" {
  style: {
    fill: "#27AE60"
    stroke: "#1E8449"
    font-color: white
    bold: true
  }
}
cached_100: "620ms" {
  style: {
    fill: "#27AE60"
    stroke: "#1E8449"
    font-color: white
    bold: true
  }
}
cached_200: "2.1s" {
  style: {
    fill: "#27AE60"
    stroke: "#1E8449"
    font-color: white
    bold: true
  }
}
# Speedup Metrics
speedup_10: "2.0x\nfaster" {
  style: {
    fill: "#F39C12"
    stroke: "#D68910"
    font-color: white
    bold: true
    stroke-dash: 2
  }
}
speedup_25: "2.8x\nfaster" {
  style: {
    fill: "#F39C12"
    stroke: "#D68910"
    font-color: white
    bold: true
    stroke-dash: 2
  }
}
speedup_50: "3.8x\nfaster" {
  style: {
    fill: "#F39C12"
    stroke: "#D68910"
    font-color: white
    bold: true
    stroke-dash: 2
  }
}
speedup_100: "4.5x\nfaster" {
  style: {
    fill: "#F39C12"
    stroke: "#D68910"
    font-color: white
    bold: true
    stroke-dash: 2
  }
}
speedup_200: "5.3x\nfaster" {
  style: {
    fill: "#F39C12"
    stroke: "#D68910"
    font-color: white
    bold: true
    stroke-dash: 2
  }
}
# Data Flow Connections - Naive path
seq_10 -> naive_10: "No Cache" {
  style: {
    stroke: "#E74C3C"
    stroke-width: 3
  }
}
naive_10 -> naive_25: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 3
  }
}
naive_25 -> naive_50: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 3
  }
}
naive_50 -> naive_100: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 3
  }
}
naive_100 -> naive_200: {
  style: {
    stroke: "#E74C3C"
    stroke-width: 3
  }
}
# Data Flow Connections - Cached path
seq_10 -> cached_10: "KV Cache" {
  style: {
    stroke: "#27AE60"
    stroke-width: 3
  }
}
cached_10 -> cached_25: {
  style: {
    stroke: "#27AE60"
    stroke-width: 3
  }
}
cached_25 -> cached_50: {
  style: {
    stroke: "#27AE60"
    stroke-width: 3
  }
}
cached_50 -> cached_100: {
  style: {
    stroke: "#27AE60"
    stroke-width: 3
  }
}
cached_100 -> cached_200: {
  style: {
    stroke: "#27AE60"
    stroke-width: 3
  }
}
# Speedup indicator connections
naive_10 -> speedup_10 -> cached_10: {
  style: {
    stroke: "#F39C12"
    stroke-width: 2
    stroke-dash: 4
  }
}
naive_25 -> speedup_25 -> cached_25: {
  style: {
    stroke: "#F39C12"
    stroke-width: 2
    stroke-dash: 4
  }
}
naive_50 -> speedup_50 -> cached_50: {
  style: {
    stroke: "#F39C12"
    stroke-width: 2
    stroke-dash: 4
  }
}
naive_100 -> speedup_100 -> cached_100: {
  style: {
    stroke: "#F39C12"
    stroke-width: 2
    stroke-dash: 4
  }
}
naive_200 -> speedup_200 -> cached_200: {
  style: {
    stroke: "#F39C12"
    stroke-width: 2
    stroke-dash: 4
  }
}
# Performance target annotation
target_box: "✓ Target Met: ≥2x speedup at 100 tokens" {
  style: {
    fill: "#2ECC71"
    stroke: "#27AE60"
    font-color: white
    bold: true
  }
}
# Complexity labels
complexity_naive: "Complexity: O(n³)" {
  style: {
    fill: "#FADBD8"
    stroke: "#E74C3C"
    italic: true
  }
}
complexity_cached: "Complexity: O(n²)" {
  style: {
    fill: "#D5F5E3"
    stroke: "#27AE60"
    italic: true
  }
}
naive_100 -> complexity_naive
cached_100 -> complexity_cached
speedup_100 -> target_box