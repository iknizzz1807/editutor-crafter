direction: right
layout: elk
TransformerGenerator: {
  shape: class
  style: {
    fill: "#1e1e2e"
    stroke: "#89b4fa"
    font-color: "#cdd6f4"
  }
  _header: {
    label: "TransformerGenerator"
    shape: text
    style: {
      font-color: "#89b4fa"
      bold: true
      underline: true
    }
  }
  # Constructor
  __init__: {
    shape: text
    style: { font-color: "#a6e3a1" }
    label: "+ __init__(model, sos_token_id, eos_token_id,\n         pad_token_id, device='cuda')"
  }
  # Main method
  generate: {
    shape: text
    style: { font-color: "#f9e2af" }
    label: "+ generate(src_tokens, max_len=100,\n         strategy='greedy', ...) → Tensor | List[Tuple]"
  }
}
# Parameters detail panel
generate_params: {
  label: "generate() Parameters"
  shape: rectangle
  style: {
    fill: "#181825"
    stroke: "#f38ba8"
    font-color: "#cdd6f4"
  }
  src_tokens: {
    label: "src_tokens: Tensor\nSource token IDs"
    shape: text
    style: { font-color: "#94e2d5" }
  }
  max_len: {
    label: "max_len: int = 100\nMaximum output length"
    shape: text
    style: { font-color: "#94e2d5" }
  }
  strategy: {
    label: "strategy: str = 'greedy'\n'greedy' | 'beam' | 'sample'"
    shape: text
    style: { font-color: "#fab387" }
  }
  beam_params: {
    label: "Beam Search\n───────────────\nbeam_width: int = 4\nlength_penalty: float = 0.0"
    shape: text
    style: { font-color: "#cba6f7" }
  }
  sample_params: {
    label: "Sampling\n───────────────\ntemperature: float = 1.0\ntop_k: Optional[int] = None\ntop_p: Optional[float] = None"
    shape: text
    style: { font-color: "#f9e2af" }
  }
  cache_params: {
    label: "Optimization\n───────────────\nuse_cache: bool = True\n(KV caching O(n²) vs O(n³))"
    shape: text
    style: { font-color: "#89dceb" }
  }
}
# Strategy outcomes
strategies: {
  label: "Decoding Strategies"
  shape: rectangle
  style: {
    fill: "#181825"
    stroke: "#89b4fa"
  }
  greedy: {
    label: "GREEDY\n───────\nargmax selection\nDeterministic output\nReturns: Tensor"
    shape: text
    style: { font-color: "#a6e3a1" }
  }
  beam: {
    label: "BEAM\n───────\nTop-k hypotheses\nLog-probability scoring\nReturns: Tensor | List[Tuple]"
    shape: text
    style: { font-color: "#cba6f7" }
  }
  sample: {
    label: "SAMPLE\n───────\nTemperature-controlled\nStochastic diversity\nReturns: Tensor"
    shape: text
    style: { font-color: "#f9e2af" }
  }
}
# GenerationConfig dataclass
config: {
  shape: class
  style: {
    fill: "#1e1e2e"
    stroke: "#f38ba8"
    font-color: "#cdd6f4"
  }
  _header: {
    label: "@dataclass GenerationConfig"
    shape: text
    style: {
      font-color: "#f38ba8"
      bold: true
    }
  }
  fields: {
    label: "max_len: int = 100\nstrategy: str = 'greedy'\nbeam_width: int = 4\nlength_penalty: float = 0.0\ntemperature: float = 1.0\ntop_k: Optional[int] = None\ntop_p: Optional[float] = None\nuse_cache: bool = True\nearly_stopping: bool = True"
    shape: text
    style: { font-color: "#cdd6f4" }
  }
}
# Connections
TransformerGenerator -> strategies: {
  label: "strategy selection"
  style: { stroke: "#89b4fa"; stroke-dash: 3 }
}
TransformerGenerator -> generate_params: {
  label: "parameters"
  style: { stroke: "#f38ba8"; stroke-dash: 3 }
}
config -> TransformerGenerator: {
  label: "configures"
  style: { stroke: "#a6e3a1"; stroke-dash: 3 }
}
# Legend
legend: {
  label: "Legend\n───────\n🟢 Constructor\n🟡 Main method\n🟣 Beam params\n🟠 Sample params\n🔵 Optimization"
  shape: text
  style: {
    font-color: "#6c7086"
  }
}