direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Vector Database Architecture"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Row 1: Query API (Top Layer)
row_api: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  query_api: {
    label: "M6: Query API & Server"
    width: 600
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
      border-radius: 8
    }
    rest_endpoints: {
      label: "REST API Endpoints"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
      ep1: "POST /collections"
      ep2: "POST /collections/{id}/vectors"
      ep3: "POST /collections/{id}/search"
      ep4: "DELETE /collections/{id}"
    }
    request_handler: {
      label: "Request Handler"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
      rh1: "Validation"
      rh2: "Timeout Enforcement"
      rh3: "Filter Strategy"
      rh4: "Batch Operations"
    }
    concurrency: {
      label: "Concurrency Control"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
      cc1: "RwLock (Read/Write)"
      cc2: "Collection Manager"
      cc3: "Error Handling"
    }
  }
}
# Row 2: Index & Search Layer
row_index: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  hnsw_index: {
    label: "M4: HNSW Index"
    width: 380
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
      border-radius: 8
    }
    layer_graph: {
      label: "Layered Graph Structure"
      shape: class
      +assign_layer(): "usize"
      +insert(node_id): "void"
      +search(query, k): "Vec<Result>"
      -nodes: "HashMap<NodeId, HNSWNode>"
      -entry_point: "Option<NodeId>"
      -max_layer: "usize"
    }
    greedy_search: {
      label: "Greedy Search"
      shape: rectangle
      style.fill: "#BBDEFB"
      gs1: "Candidate Queue"
      gs2: "Backtracking"
      gs3: "Layer Descent"
    }
  }
  bruteforce: {
    label: "M3: Brute-Force KNN"
    width: 280
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 3
      border-radius: 8
    }
    linear_scan: {
      label: "Linear Scan Engine"
      shape: class
      +search(query, k): "Vec<SearchResult>"
      +search_filtered(query, k, pred): "Vec<SearchResult>"
      +search_threshold(query, threshold): "Vec<SearchResult>"
      -storage: "&VectorStorage"
      -metric: "&dyn Metric"
    }
    topk_selector: {
      label: "Top-K Selector"
      shape: rectangle
      style.fill: "#FFE0B2"
      ts1: "Max-Heap (distances)"
      ts2: "Min-Heap (similarities)"
      ts3: "O(N log k) complexity"
    }
    ground_truth: {
      label: "Ground Truth Generator"
      shape: rectangle
      style.fill: "#FFE0B2"
      gt1: "Exact KNN Results"
      gt2: "Recall@k Computation"
    }
  }
}
# Row 3: Quantization Layer
row_quant: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  quantization: {
    label: "M5: Vector Quantization"
    width: 500
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 3
      border-radius: 8
    }
    sq8: {
      label: "Scalar Quantization (SQ8)"
      shape: class
      +train(storage, sample_size): "ScalarQuantizer"
      +quantize(vector): "Vec<u8>"
      +l2_distance(query, codes): "f32"
      -dimension_stats: "Vec<DimensionStats>"
      -dimension: "usize"
    }
    pq: {
      label: "Product Quantization (PQ)"
      shape: class
      +train(vectors, M, iterations): "ProductQuantizer"
      +quantize(vector): "Vec<u8>"
      -codebooks: "Vec<SubspaceCodebook>"
      -num_subspaces: "usize"
      -subspace_dim: "usize"
    }
    adc: {
      label: "Asymmetric Distance Computation"
      shape: rectangle
      style.fill: "#E1BEE7"
      adc1: "Precompute M×256 Lookup"
      adc2: "O(M) per distance"
      adc3: "10-100x speedup"
    }
    compression_stats: {
      label: "Compression Ratios"
      shape: rectangle
      style.fill: "#E1BEE7"
      cs1: "SQ8: 4x"
      cs2: "PQ (M=8): 32x"
      cs3: "Memory vs Recall Tradeoff"
    }
  }
}
# Row 4: Distance Metrics Layer
row_distance: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  distance_metrics: {
    label: "M2: Distance Metrics"
    width: 600
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 3
      border-radius: 8
    }
    metric_impl: {
      label: "Metric Implementations"
      shape: class
      +distance(a, b): "f32"
      +is_similarity(): "bool"
      +name(): "&str"
      DotProduct: "Higher = better"
      Euclidean: "Lower = better"
      Cosine: "Lower = better"
    }
    simd_optimization: {
      label: "SIMD Optimization"
      shape: rectangle
      style.fill: "#FFCDD2"
      simd1: "AVX2 (256-bit)"
      simd2: "8 floats per instruction"
      simd3: "3x+ speedup"
    }
    numerical_stability: {
      label: "Numerical Stability"
      shape: rectangle
      style.fill: "#FFCDD2"
      ns1: "Kahan Summation"
      ns2: "Zero-vector Handling"
      ns3: "Pre-normalized Fast Path"
    }
  }
}
# Row 5: Storage Foundation Layer
row_storage: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  storage_engine: {
    label: "M1: Vector Storage Engine"
    width: 700
    style: {
      fill: "#E0F7FA"
      stroke: "#00838F"
      stroke-width: 3
      border-radius: 8
    }
    aligned_buffer: {
      label: "AlignedVectorBuffer"
      shape: class
      +new(count): "Self"
      +as_slice(): "&[f32]"
      +as_mut_slice(): "&mut [f32]"
      +vector_ptr(i, dim): "Option<*const f32>"
      -ptr: "NonNull<f32>"
      -capacity: "usize"
      -layout: "Layout"
    }
    vector_storage: {
      label: "VectorStorage"
      shape: class
      +insert(id, vector, meta): "Result<(), InsertError>"
      +insert_batch(vectors): "Result<Vec<Result>, InsertError>"
      +get(id): "Result<VectorWithMetadata, RetrievalError>"
      +delete(id): "Result<(), DeletionError>"
      +iter_live(): "Iterator"
      +compact(): "usize"
      +save(path): "io::Result<()>"
      +load(path): "io::Result<Self>"
      -buffer: "AlignedVectorBuffer"
      -id_to_slot: "HashMap<u64, (usize, u32)>"
      -slots: "Vec<Option<VectorSlot>>"
      -free_list: "Vec<usize>"
    }
    persistence: {
      label: "Persistence"
      shape: rectangle
      style.fill: "#B2EBF2"
      p1: "Memory-Mapped Files"
      p2: "Atomic Write-Rename"
      p3: "Crash Recovery"
    }
    alignment: {
      label: "Memory Layout"
      shape: rectangle
      style.fill: "#B2EBF2"
      a1: "64-byte Alignment"
      a2: "Contiguous Allocation"
      a3: "SIMD-Ready"
    }
  }
}
# Data Flow Arrows
row_api.query_api.request_handler -> row_index.hnsw_index: "search(query, k)"
row_api.query_api.request_handler -> row_index.bruteforce: "search(query, k)"
row_api.query_api.request_handler -> row_quant.quantization: "quantized mode"
row_index.hnsw_index -> row_distance.distance_metrics: "distance(a, b)"
row_index.bruteforce -> row_distance.distance_metrics: "distance(a, b)"
row_index.hnsw_index -> row_storage.storage_engine: "get_vector(id)"
row_index.bruteforce -> row_storage.storage_engine: "iter_live()"
row_quant.quantization -> row_storage.storage_engine: "train()"
row_api.query_api.rest_endpoints -> row_api.query_api.request_handler: "parse request"
row_api.query_api.request_handler -> row_api.query_api.concurrency: "acquire lock"
# Insert Flow (dashed, different color)
row_api.query_api.rest_endpoints -> row_storage.storage_engine: "insert vector" {
  style: {
    stroke: "#2E7D32"
    stroke-dash: 4
  }
}
row_storage.storage_engine -> row_index.hnsw_index: "add to index" {
  style: {
    stroke: "#1565C0"
    stroke-dash: 4
  }
}
# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  title: "Data Flow"
  query_flow: "Query Path" {
    style.stroke: "#1565C0"
  }
  insert_flow: "Insert Path" {
    style: {
      stroke: "#2E7D32"
      stroke-dash: 4
    }
  }
  distance_call: "Distance Computation" {
    style.stroke: "#C62828"
  }
}
# Layer Labels
layer_labels: {
  near: center-left
  style: {
    fill: transparent
    stroke: transparent
  }
  l5: "L5: API Layer" {
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#666666"
    }
  }
  l4: "L4: Index Layer" {
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#666666"
    }
  }
  l3: "L3: Compression" {
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#666666"
    }
  }
  l2: "L2: Computation" {
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#666666"
    }
  }
  l1: "L1: Foundation" {
    shape: text
    style: {
      font-size: 14
      italic: true
      font-color: "#666666"
    }
  }
}