direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------------------
# ROOT LEVEL ANNOTATIONS
# -----------------------------------------------------------------------------------------
title: "SIMD Alignment: Why 32/64 Bytes Matter (storage.h)" {
  shape: text
  near: top-center
  style.font-size: 18
  style.bold: true
}

# -----------------------------------------------------------------------------------------
# ROW 1: COMPARISON (ALIGNED VS MISALIGNED)
# -----------------------------------------------------------------------------------------
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  aligned: {
    direction: down
    label: "ALIGNED LOAD (Correct)"
    
    aligned_desc: {
      label: "Address % 64 == 0"
      shape: rectangle
      style.fill: "#14532d"
      style.stroke: "#22c55e"
      style.font-color: "#22c55e"
      style.bold: true
    }

    aligned_memory: {
      label: "Memory Layout (0x00 Alignment)"
      shape: rectangle
      style.fill: "#1e293b"
      style.stroke: "#475569"
      
      header: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        marker: "0x00" { shape: text; style.font-color: "#94a3b8"; style.font-size: 12 }
      }

      aligned_bytes: {
        grid-columns: 8
        grid-gap: 2
        b0: "f32[0]" { shape: rectangle; style.fill: "#22c55e"; style.stroke: "#16a34a"; style.font-color: "#052e16"; width: 60 }
        b1: "f32[1]" { shape: rectangle; style.fill: "#22c55e"; style.stroke: "#16a34a"; style.font-color: "#052e16"; width: 60 }
        b2: "f32[2]" { shape: rectangle; style.fill: "#22c55e"; style.stroke: "#16a34a"; style.font-color: "#052e16"; width: 60 }
        b3: "f32[3]" { shape: rectangle; style.fill: "#22c55e"; style.stroke: "#16a34a"; style.font-color: "#052e16"; width: 60 }
        b4: "f32[4]" { shape: rectangle; style.fill: "#3b82f6"; style.stroke: "#2563eb"; style.font-color: "#ffffff"; width: 60 }
        b5: "f32[5]" { shape: rectangle; style.fill: "#3b82f6"; style.stroke: "#2563eb"; style.font-color: "#ffffff"; width: 60 }
        b6: "f32[6]" { shape: rectangle; style.fill: "#3b82f6"; style.stroke: "#2563eb"; style.font-color: "#ffffff"; width: 60 }
        b7: "f32[7]" { shape: rectangle; style.fill: "#3b82f6"; style.stroke: "#2563eb"; style.font-color: "#ffffff"; width: 60 }
      }

      footer: "64-byte Cache Line Boundary" {
        style.stroke-dash: 4
        style.stroke: "#f59e0b"
        style.font-size: 10
      }
    }

    aligned_avx2_reg: {
      label: "AVX2 YMM Register (256-bit)"
      shape: rectangle
      style.fill: "#22c55e"
      style.stroke: "#16a34a"
      style.stroke-width: 3
      style.font-color: "#052e16"
      style.bold: true
      height: 40
    }

    aligned_instr: {
      label: "T1: _mm256_load_ps(ptr)"
      code: |'c
        // 1 Instruction
        // 1 Memory Access
        vmovaps ymm0, [rax]
      '|
      style.font: mono
    }

    aligned_cycles: "Latency: 1 Cycle" {
      shape: rectangle
      style.fill: "#064e3b"
      style.font-color: "#34d399"
      style.bold: true
    }
  }

  misaligned: {
    direction: down
    label: "MISALIGNED LOAD (Performance Critical)"
    
    misaligned_desc: {
      label: "Address % 64 == 0x10"
      shape: rectangle
      style.fill: "#7f1d1d"
      style.stroke: "#ef4444"
      style.font-color: "#fca5a5"
      style.bold: true
    }

    misaligned_memory: {
      label: "Memory Layout (Split Load)"
      shape: rectangle
      style.fill: "#1e293b"
      style.stroke: "#475569"
      
      header: {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        marker: "0x10" { shape: text; style.font-color: "#94a3b8"; style.font-size: 12 }
        padding: "pad" { shape: rectangle; style.fill: "#374151"; width: 60; height: 20 }
      }

      misaligned_bytes: {
        grid-columns: 8
        grid-gap: 2
        mb0: "f32[0]" { shape: rectangle; style.fill: "#ef4444"; style.stroke: "#dc2626"; width: 60 }
        mb1: "f32[1]" { shape: rectangle; style.fill: "#ef4444"; style.stroke: "#dc2626"; width: 60 }
        mb2: "f32[2]" { shape: rectangle; style.fill: "#ef4444"; style.stroke: "#dc2626"; width: 60 }
        mb3: "f32[3]" { shape: rectangle; style.fill: "#ef4444"; style.stroke: "#dc2626"; width: 60 }
        mb4: "f32[4]" { shape: rectangle; style.fill: "#ef4444"; style.stroke: "#dc2626"; width: 60 }
        mb5: "f32[5]" { shape: rectangle; style.fill: "#ef4444"; style.stroke: "#dc2626"; width: 60 }
        mb6: "f32[6]" { shape: rectangle; style.fill: "#fbbf24"; width: 60; label: "CROSS" }
        mb7: "f32[7]" { shape: rectangle; style.fill: "#fbbf24"; width: 60; label: "CROSS" }
      }

      boundary: "CACHE LINE SPLIT HERE" {
        style.stroke: "#ef4444"
        style.stroke-width: 2
        style.bold: true
      }
    }

    misaligned_instr: {
      label: "T1: _mm256_loadu_ps(ptr)"
      code: |'c
        // Hardware must perform:
        // 2 Cache line fetches
        // Byte-shuffling/Merge
        vmovups ymm0, [rax]
      '|
      style.font: mono
      style.stroke: "#f59e0b"
    }

    misaligned_cycles: "Latency: 3-7 Cycles" {
      shape: rectangle
      style.fill: "#450a0a"
      style.font-color: "#ef4444"
      style.bold: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# ROW 2: AVX-512 AND ALLOCATION LOGIC
# -----------------------------------------------------------------------------------------
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  avx512: {
    direction: down
    label: "AVX-512 ZMM Register (64 Bytes)"
    zmm_reg: {
      shape: sql_table
      label: "ZMM0 Register State"
      r0: "0x00 | float | f32[0..3]  (Low 128)"
      r1: "0x10 | float | f32[4..7]"
      r2: "0x20 | float | f32[8..11]"
      r3: "0x30 | float | f32[12..15] (High 128)"
      sz: "Total: 64 Bytes (Full Cache Line)"
    }
    note: "AVX-512 alignment is mandatory for performance parity with AVX2."
  }

  alignment_calc: {
    direction: down
    label: "Memory Management (storage.h)"
    calc_code: {
      label: "Aligned Allocation (Rust/C++)"
      code: |'rust
        // 64-byte alignment
        let layout = Layout::from_size_align(
            vec_len * 4, 
            64 
        ).unwrap();
        let ptr = alloc(layout);
        // Guaranteed: ptr % 64 == 0
      '|
    }
    formula: "padded_width = (width + 15) & ~15" {
      shape: callout
      style.font: mono
    }
  }
}

# -----------------------------------------------------------------------------------------
# ROW 3: CACHE LINE VISUALIZATION
# -----------------------------------------------------------------------------------------
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  cache_line: {
    direction: down
    label: "Intel x86 Cache Line (64B)"
    visual: {
      grid-columns: 16
      grid-gap: 1
      c0: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c1: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c2: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c3: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c4: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c5: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c6: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c7: { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 20; label: "" }
      c8: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c9: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c10: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c11: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c12: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c13: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c14: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
      c15: { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 20; label: "" }
    }
    summary: "Efficiency: 100% (Aligned) vs 50% (Split Load)" {
      style.font-color: "#94a3b8"
      style.italic: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-center
  direction: right
  style.fill: "#0f172a"
  style.stroke: "#334155"
  style.border-radius: 4

  l1: "AVX2 Valid" { shape: rectangle; style.fill: "#22c55e"; width: 20; height: 10 }
  l2: "AVX-512 Valid" { shape: rectangle; style.fill: "#3b82f6"; width: 20; height: 10 }
  l3: "Penalty/Split" { shape: rectangle; style.fill: "#fbbf24"; width: 20; height: 10 }
  l4: "Padding" { shape: rectangle; style.fill: "#374151"; width: 20; height: 10 }
}

row1.aligned -> row2.avx512: "Direct Map"
row1.misaligned -> row3.cache_line: "Double Access" { style.stroke: "#ef4444" }