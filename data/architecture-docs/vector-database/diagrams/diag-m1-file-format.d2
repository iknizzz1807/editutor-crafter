direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Persistent Storage File Format (vectors.bin)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  file_layout: {
    direction: down
    label: "File Layout (mmap-ready)"
    magic: {
      shape: rectangle
      label: "MAGIC\n\"VECTORS1\"\n8 bytes"
      width: 160
      style: {
        fill: "#E8D5E8"
        stroke: "#8B5A8B"
        stroke-width: 2
      }
    }
    version: {
      shape: rectangle
      label: "VERSION\nu32 = 1\n4 bytes"
      width: 160
      style: {
        fill: "#D5E8D5"
        stroke: "#5A8B5A"
        stroke-width: 2
      }
    }
    header: {
      shape: sql_table
      label: "HEADER (64 bytes)"
      width: 160
      f0: "0x00 | u32 | raw_dim"
      f1: "0x04 | u32 | padded_dim"
      f2: "0x08 | u32 | capacity"
      f3: "0x0C | u32 | live_count"
      f4: "0x10 | u32 | alignment"
      f5: "0x14 | [u8; 36] | _reserved"
      total: "Total: 64 bytes"
    }
    vector_section: {
      shape: rectangle
      label: "VECTOR DATA SECTION\n[capacity × padded_dim × 4 bytes]\n\nContiguous f32 array\nAligned to 64-byte boundary\n\nvectors.bin[64..64+N×D×4]"
      width: 160
      height: 140
      style: {
        fill: "#D5E8F0"
        stroke: "#5A8BAF"
        stroke-width: 2
      }
    }
    idmap_section: {
      shape: rectangle
      label: "ID-TO-OFFSET INDEX\nlen: u64\nbincode(HashMap<u64, (usize, u32)>)\n\nMaps external ID → (slot_idx, generation)"
      width: 160
      height: 80
      style: {
        fill: "#F0E8D5"
        stroke: "#AF8B5A"
        stroke-width: 2
      }
    }
    slots_section: {
      shape: rectangle
      label: "SLOTS ARRAY\n[capacity entries]\n\nEach: is_present: u8\n      id: u64 (if present)\n      generation: u32 (if present)"
      width: 160
      height: 80
      style: {
        fill: "#E8F0D5"
        stroke: "#8BAF5A"
        stroke-width: 2
      }
    }
    metadata_section: {
      shape: rectangle
      label: "METADATA SECTION\nlen: u64\nbincode(Vec<Option<VectorMetadata>>)\n\nContains fields HashMap,\ntimestamp, is_deleted flag"
      width: 160
      height: 80
      style: {
        fill: "#F0D5E8"
        stroke: "#AF5A8B"
        stroke-width: 2
      }
    }
    magic -> version: ""
    version -> header: ""
    header -> vector_section: ""
    vector_section -> idmap_section: ""
    idmap_section -> slots_section: ""
    slots_section -> metadata_section: ""
  }
  offsets: {
    direction: down
    label: "Byte Offsets"
    off0: {
      label: "0x000"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    off8: {
      label: "0x008"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    offC: {
      label: "0x00C"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    off40: {
      label: "0x040"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    offVar1: {
      label: "variable"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    offVar2: {
      label: "variable"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    offVar3: {
      label: "variable"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    offEOF: {
      label: "EOF"
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
    off0 -> off8 -> offC -> off40 -> offVar1 -> offVar2 -> offVar3 -> offEOF
  }
  file_layout.magic -> offsets.off0: {
    style.stroke-dash: 3
    style.stroke: "#888888"
  }
  file_layout.header -> offsets.off40: {
    style.stroke-dash: 3
    style.stroke: "#888888"
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  atomic_write: {
    direction: down
    label: "Atomic Write Pattern (Crash Safety)"
    step1: {
      label: "Step 1: Write to Temp"
      code: |'c
        let temp_path = path.with_extension("tmp");
        let mut file = OpenOptions::new()
            .write(true)
            .create(true)
            .truncate(true)
            .open(&temp_path)?;
        // Write header
        file.write_all(&header_bytes)?;
        // Write vector data
        file.write_all(&vector_bytes)?;
        // Write index + metadata
        file.write_all(&index_bytes)?;
        file.write_all(&metadata_bytes)?;
      '|
      width: 380
      style: {
        fill: "#F5F5F5"
        stroke: "#666666"
        border-radius: 8
      }
    }
    step2: {
      label: "Step 2: Sync to Disk"
      code: |'c
        // Force OS to flush all writes to physical disk
        // This is the durability guarantee point
        file.sync_all()?;
      '|
      width: 380
      style: {
        fill: "#E8F5E8"
        stroke: "#4CAF50"
        border-radius: 8
      }
    }
    step3: {
      label: "Step 3: Atomic Rename"
      code: |'c
        // POSIX guarantees atomic rename
        // Either old file exists OR new file exists
        // Never partial/corrupted state
        std::fs::rename(&temp_path, path)?;
      '|
      width: 380
      style: {
        fill: "#E3F2FD"
        stroke: "#2196F3"
        border-radius: 8
      }
    }
    step1 -> step2: "write complete"
    step2 -> step3: "fsync done"
  }
  crash_scenarios: {
    direction: down
    label: "Crash Safety Analysis"
    crash1: {
      label: "Crash before fsync"
      code: |'md
        **Result**: Temp file may be partial/corrupted
        **Recovery**: Original `vectors.bin` intact
        (rename never executed)
        **Action**: Delete `vectors.tmp`, retry
      '|
      width: 340
      style: {
        fill: "#FFF3E0"
        stroke: "#FF9800"
        border-radius: 8
      }
    }
    crash2: {
      label: "Crash during rename"
      code: |'md
        **Result**: Either old OR new file exists
        (POSIX atomic guarantee)
        **Recovery**: 
        - If `vectors.bin` exists → use it
        - If `vectors.tmp` exists → delete it
        (incomplete rename)
        **Action**: Check both, pick complete one
      '|
      width: 340
      style: {
        fill: "#E8F5E9"
        stroke: "#4CAF50"
        border-radius: 8
      }
    }
    crash3: {
      label: "Crash after rename"
      code: |'md
        **Result**: New `vectors.bin` is complete
        **Recovery**: Load new file directly
        **Action**: Normal startup
      '|
      width: 340
      style: {
        fill: "#E3F2FD"
        stroke: "#2196F3"
        border-radius: 8
      }
    }
    crash1 -> crash2 -> crash3
  }
}
atomic_write.step1 -> crash_scenarios.crash1: {
  label: "crash point"
  style.stroke-dash: 3
  style.stroke: "#FF5722"
}
atomic_write.step2 -> crash_scenarios.crash2: {
  label: "crash point"
  style.stroke-dash: 3
  style.stroke: "#FF5722"
}
atomic_write.step3 -> crash_scenarios.crash3: {
  label: "crash point"
  style.stroke-dash: 3
  style.stroke: "#FF5722"
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  header_struct: {
    direction: down
    label: "FileHeader struct (64 bytes)"
    header_class: {
      shape: class
      label: "FileHeader (C repr, POD)"
      magic: "[u8; 8]"
      version: "u32"
      raw_dim: "u32"
      padded_dim: "u32"
      capacity: "u32"
      live_count: "u32"
      alignment: "u32"
      _reserved: "[u8; 36]"
    }
    note: {
      label: |md
        **Size**: Exactly 64 bytes
        **Alignment**: 8-byte aligned
        **Endianness**: Little-endian
        **Magic**: `"VECTORS1"` = v1 format
      |
      width: 280
      style: {
        fill: "#FFF8E1"
        stroke: "#FFC107"
        border-radius: 8
      }
    }
    header_class -> note
  }
  mmap_flow: {
    direction: down
    label: "Memory-Mapped Read Path"
    mmap_open: {
      label: "Open & Map File"
      code: |'c
        let file = File::open(path)?;
        let file_len = file.metadata()?.len() as usize;
        // Map entire file into virtual memory
        // OS pages in data on-demand
        let mmap = unsafe { Mmap::map(&file)? };
      '|
      width: 380
      style: {
        fill: "#E8EAF6"
        stroke: "#3F51B5"
        border-radius: 8
      }
    }
    mmap_parse: {
      label: "Parse Header (Zero-Copy)"
      code: |'c
        // Read header directly from mmap
        // No memcpy into separate buffer
        let header: &FileHeader = unsafe {
            &*(mmap.as_ptr() as *const FileHeader)
        };
        // Validate magic bytes
        if &header.magic != b"VECTORS1" {
            return Err(InvalidFormat);
        }
      '|
      width: 380
      style: {
        fill: "#E8EAF6"
        stroke: "#3F51B5"
        border-radius: 8
      }
    }
    mmap_access: {
      label: "Access Vectors (On-Demand Paging)"
      code: |'c
        // Vector i starts at offset:
        //   64 + i * padded_dim * 4
        // 
        // OS loads only touched pages
        // 4KB page = ~256 vectors (768d)
        let offset = 64 + idx * header.padded_dim * 4;
        let vector: &[f32] = unsafe {
            std::slice::from_raw_parts(
                mmap.as_ptr().add(offset) as *const f32,
                header.raw_dim
            )
        };
      '|
      width: 380
      style: {
        fill: "#E8EAF6"
        stroke: "#3F51B5"
        border-radius: 8
      }
    }
    mmap_open -> mmap_parse: "file mapped"
    mmap_parse -> mmap_access: "header validated"
  }
  mmap_benefits: {
    direction: down
    label: "mmap Benefits"
    benefit1: {
      label: "Lazy Loading"
      code: |'md
        **100GB file? No problem.**
        Only pages you touch are loaded.
        Mapping is instant; no read() syscall.
        OS prefetcher optimizes sequential access.
      '|
      width: 280
      style: {
        fill: "#E8F5E9"
        stroke: "#4CAF50"
        border-radius: 8
      }
    }
    benefit2: {
      label: "OS Page Cache"
      code: |'md
        **No double-buffering.**
        mmap shares the OS page cache.
        Multiple processes share same physical pages.
        Contrast: read() copies kernel→userspace.
      '|
      width: 280
      style: {
        fill: "#E8F5E9"
        stroke: "#4CAF50"
        border-radius: 8
      }
    }
    benefit3: {
      label: "Instant Startup"
      code: |'md
        **No load time.**
        Traditional: read entire file → O(GB)
        mmap: just map virtual addresses → O(ms)
        First access triggers page fault → load.
      '|
      width: 280
      style: {
        fill: "#E8F5E9"
        stroke: "#4CAF50"
        border-radius: 8
      }
    }
    benefit1 -> benefit2 -> benefit3
  }
}
legend: {
  near: bottom-center
  direction: right
  l1: {
    label: "Header/Metadata"
    shape: rectangle
    width: 80
    style.fill: "#E8D5E8"
  }
  l2: {
    label: "Vector Data"
    shape: rectangle
    width: 80
    style.fill: "#D5E8F0"
  }
  l3: {
    label: "Index/Maps"
    shape: rectangle
    width: 80
    style.fill: "#F0E8D5"
  }
  l4: {
    label: "Crash-Safe"
    shape: rectangle
    width: 80
    style.fill: "#E8F5E9"
  }
}