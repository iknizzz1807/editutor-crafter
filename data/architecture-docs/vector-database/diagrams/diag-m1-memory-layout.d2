direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Contiguous Vector Storage Memory Layout
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fragmented: {
    direction: down
    label: "❌ Fragmented Allocation"
    frag_desc: |md
      Each `Vec<f32>` is a separate heap allocation.
      Memory addresses are scattered.
      CPU prefetcher cannot predict access pattern.
    |
    frag_mem: {
      label: "Heap Memory"
      style.fill: "#FFE4E1"
      style.stroke: "#CD5C5C"
      vec0: {
        label: "Vec<f32>\n0x7F2A...0010"
        style.fill: "#FFA07A"
      }
      gap1: "..." {style.fill: transparent; style.stroke: transparent}
      vec1: {
        label: "Vec<f32>\n0x7F2A...8C40"
        style.fill: "#FFA07A"
      }
      gap2: "..." {style.fill: transparent; style.stroke: transparent}
      vec2: {
        label: "Vec<f32>\n0x7F2A...F200"
        style.fill: "#FFA07A"
      }
      gap3: "..." {style.fill: transparent; style.stroke: transparent}
      vec3: {
        label: "Vec<f32>\n0x7F2A...3A10"
        style.fill: "#FFA07A"
      }
    }
    frag_perf: {
      label: "Performance Impact"
      shape: rectangle
      style.fill: "#FFF0F0"
      style.stroke: "#CD5C5C"
      p1: "• Random access pattern"
      p2: "• Cache misses on every vector"
      p3: "• Memory bandwidth: <1 GB/s"
      p4: "• Prefetcher: DISABLED"
    }
  }
  contiguous: {
    direction: down
    label: "✅ Contiguous Allocation"
    cont_desc: |md
      Single allocation for all vector data.
      Sequential memory addresses.
      CPU prefetcher anticipates access pattern.
    |
    cont_mem: {
      label: "Aligned Buffer (64-byte boundary)"
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      header: {
        label: "File Header\n64 bytes"
        style.fill: "#81C784"
        rows: [
          "0x00-0x07: magic 'VECTORS1'"
          "0x08-0x0B: version=1"
          "0x0C-0x0F: dimension=768"
          "0x10-0x13: count=N"
          "0x14-0x17: alignment=64"
          "...reserved..."
        ]
      }
      vec_data: {
        label: "Vector Data (contiguous)"
        style.fill: "#A5D6A7"
        v0: {
          label: "Vector 0\noffset=0x40"
          style.fill: "#C8E6C9"
        }
        v1: {
          label: "Vector 1\noffset=0xC40"
          style.fill: "#C8E6C9"
        }
        v2: {
          label: "Vector 2\noffset=0x1840"
          style.fill: "#C8E6C9"
        }
        v3: {
          label: "Vector 3\noffset=0x2440"
          style.fill: "#C8E6C9"
        }
        vdot: {
          label: "..."
          style.fill: transparent
          style.stroke: transparent
        }
        vn: {
          label: "Vector N-1"
          style.fill: "#C8E6C9"
        }
      }
    }
    cont_perf: {
      label: "Performance Impact"
      shape: rectangle
      style.fill: "#F0FFF0"
      style.stroke: "#4CAF50"
      p1: "• Sequential access pattern"
      p2: "• Cache lines prefetched"
      p3: "• Memory bandwidth: 50+ GB/s"
      p4: "• Prefetcher: OPTIMAL"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  index_struct: {
    direction: down
    label: "ID → Offset Index"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    idx_desc: |md
      HashMap<u64, (index, generation)>
      O(1) lookup by vector ID
    |
    idx_table: {
      label: "Hash Map Index"
      shape: sql_table
      style.fill: "#BBDEFB"
      id0: "ID: 42 | (index=0, gen=1)"
      id1: "ID: 17 | (index=1, gen=1)"
      id2: "ID: 99 | (index=2, gen=1)"
      id3: "ID: 3  | (index=3, gen=1)"
      iddot: "..."
      idn: "ID: N  | (index=N-1, gen=1)"
    }
    idx_note: |md
      Index maps external IDs to internal
      slot positions for O(1) retrieval.
      Generation counters prevent ABA bugs.
    |
  }
  alignment: {
    direction: down
    label: "Memory Alignment Detail"
    align_box: {
      style.fill: "#FFF8E1"
      style.stroke: "#FF9800"
      cache_line: {
        label: "Cache Line (64 bytes)"
        style.fill: "#FFE0B2"
        style.stroke: "#F57C00"
        cl_desc: |md
          L1/L2 cache loads 64 bytes at once.
          Aligned access = single cache load.
          Misaligned = 2 cache loads (penalty).
        |
      }
      simd_reg: {
        label: "SIMD Register Widths"
        style.fill: "#FFCC80"
        style.stroke: "#EF6C00"
        sse: "SSE:   128-bit (16 bytes, 4 floats)"
        avx: "AVX2:  256-bit (32 bytes, 8 floats)"
        avx512: "AVX-512: 512-bit (64 bytes, 16 floats)"
      }
      align_req: {
        label: "Alignment Requirements"
        style.fill: "#FFE0B2"
        req1: "_mm256_load_ps: 32-byte aligned"
        req2: "_mm512_load_ps: 64-byte aligned"
        req3: "Misaligned → segfault or slow"
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  padding: {
    direction: down
    label: "Padding for Alignment"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    pad_example: {
      label: "Example: dim=100"
      unpadded: {
        label: "Without Padding"
        style.fill: "#E1BEE7"
        up_bytes: "100 × 4 = 400 bytes"
        up_align: "400 mod 64 = 16 (not aligned)"
        up_result: "❌ Next vector misaligned"
      }
      padded: {
        label: "With Padding"
        style.fill: "#CE93D8"
        p_bytes: "Round up to 448 bytes"
        p_pad: "48 bytes padding (wasted)"
        p_align: "448 mod 64 = 0 ✓"
        p_result: "✓ Every vector aligned"
      }
    }
    pad_cost: {
      label: "Padding Cost Analysis"
      style.fill: "#E1BEE7"
      dim768: "dim=768: 3072 bytes (no padding needed)"
      dim100: "dim=100: 400→448 bytes (12% overhead)"
      dim50: "dim=50:  200→256 bytes (28% overhead)"
    }
  }
  code_struct: {
    direction: down
    label: "AlignedVectorBuffer (Rust)"
    shape: class
    style.fill: "#E8EAF6"
    style.stroke: "#3F51B5"
    -ptr: "NonNull<f32>"
    -capacity: "usize"
    -layout: "Layout"
    +new(count: usize): "Self"
    +as_slice(): "&[f32]"
    +as_mut_slice(): "&mut [f32]"
    +vector_ptr(i, dim): "Option<*const f32>"
  }
}
legend: {
  near: bottom-center
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: "🟥 Red = Fragmented/slow path"
  l2: "🟩 Green = Contiguous/fast path"
  l3: "🟦 Blue = Index structures"
  l4: "🟨 Yellow = Alignment details"
  l5: "🟪 Purple = Padding overhead"
}
fragmented.frag_mem -> contiguous.cont_mem: "Transform" {
  style.stroke: "#4CAF50"
  style.stroke-width: 3
  style.animated: true
  label: "Single allocation\nreplaces N allocations"
}
index_struct.idx_table -> contiguous.cont_mem.vec_data: "offset lookup" {
  style.stroke: "#2196F3"
  style.stroke-dash: 3
  label: "ID→slot"
}