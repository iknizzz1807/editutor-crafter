direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "Memory-Mapped File Lifecycle for Vector Storage"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}

row_states: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  state_col: {
    direction: down
    states_label: {
      label: "mmap Lifecycle States"
      style: {
        fill: "#E8F4FD"
        stroke: "#2196F3"
        stroke-width: 2
        bold: true
      }
    }
    open: {
      shape: circle
      label: "OPEN"
      style: {
        fill: "#C8E6C9"
        stroke: "#4CAF50"
        stroke-width: 3
      }
    }
    mapped: {
      shape: circle
      label: "MMAP"
      style: {
        fill: "#BBDEFB"
        stroke: "#2196F3"
        stroke-width: 3
      }
    }
    active: {
      shape: circle
      label: "ACTIVE\n(Read/Write)"
      style: {
        fill: "#FFF9C4"
        stroke: "#FFC107"
        stroke-width: 3
      }
    }
    synced: {
      shape: circle
      label: "SYNCED"
      style: {
        fill: "#E1BEE7"
        stroke: "#9C27B0"
        stroke-width: 3
      }
    }
    unmapped: {
      shape: circle
      label: "UNMAPPED"
      style: {
        fill: "#FFCCBC"
        stroke: "#FF5722"
        stroke-width: 3
      }
    }
    closed: {
      shape: circle
      label: "CLOSED"
      style: {
        fill: "#CFD8DC"
        stroke: "#607D8B"
        stroke-width: 3
        double-border: true
      }
    }
    open -> mapped: "mmap() | map" {
      style: {
        stroke: "#2196F3"
        stroke-width: 2
      }
    }
    mapped -> active: "ptr access | fault" {
      style: {
        stroke: "#4CAF50"
        stroke-width: 2
      }
    }
    active -> active: "RW | ptr" {
      style: {
        stroke: "#FFC107"
        stroke-width: 2
        stroke-dash: 4
      }
    }
    active -> synced: "msync() | flush" {
      style: {
        stroke: "#9C27B0"
        stroke-width: 2
      }
    }
    synced -> active: "continue" {
      style: {
        stroke: "#FF9800"
        stroke-width: 2
      }
    }
    active -> unmapped: "munmap() | drop" {
      style: {
        stroke: "#FF5722"
        stroke-width: 2
      }
    }
    synced -> unmapped: "munmap() | drop" {
      style: {
        stroke: "#FF5722"
        stroke-width: 2
      }
    }
    unmapped -> closed: "close() | release" {
      style: {
        stroke: "#607D8B"
        stroke-width: 2
      }
    }
  }
  spacer: {
    width: 80
    style.stroke: transparent
    style.fill: transparent
  }
  memory_col: {
    direction: down
    memory_label: {
      label: "Virtual Memory Mapping"
      style: {
        fill: "#E8F4FD"
        stroke: "#2196F3"
        stroke-width: 2
        bold: true
      }
    }
    vaddr_space: {
      label: "Process Virtual Address Space"
      style: {
        fill: "#F3E5F5"
        stroke: "#7B1FA2"
        stroke-width: 2
      }
      vpage0: {
        label: "Page 0\n0x0000"
        shape: rectangle
        style: {
          fill: "#E1BEE7"
          stroke: "#7B1FA2"
        }
      }
      vpage1: {
        label: "Page 1\n0x1000"
        shape: rectangle
        style: {
          fill: "#E1BEE7"
          stroke: "#7B1FA2"
        }
      }
      vpage2: {
        label: "Page 2\n0x2000"
        shape: rectangle
        style: {
          fill: "#FFECB3"
          stroke: "#FF8F00"
          stroke-dash: 4
        }
      }
      vpage3: {
        label: "Page 3\n0x3000"
        shape: rectangle
        style: {
          fill: "#E1BEE7"
          stroke: "#7B1FA2"
        }
      }
    }
  }
}

row_middle: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  page_cache: {
    direction: down
    label: "OS Page Cache"
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
    cache_label: {
      label: "In-Memory Pages (4KB each)"
      style: {
        fill: transparent
        stroke: transparent
        font-size: 12
        italic: true
      }
    }
    cached_p0: {
      label: "Clean\nPage 0"
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
      }
    }
    cached_p1: {
      label: "Clean\nPage 1"
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
      }
    }
    cached_p2: {
      label: "DIRTY\nPage 2"
      shape: rectangle
      style: {
        fill: "#FFCDD2"
        stroke: "#C62828"
        stroke-width: 3
        animated: true
      }
    }
    cached_p3: {
      label: "Clean\nPage 3"
      shape: rectangle
      style: {
        fill: "#BBDEFB"
        stroke: "#1976D2"
      }
    }
  }
  spacer2: {
    width: 60
    style.stroke: transparent
    style.fill: transparent
  }
  disk_file: {
    direction: down
    label: "Disk File: vectors.bin"
    style: {
      fill: "#ECEFF1"
      stroke: "#455A64"
      stroke-width: 2
    }
    file_label: {
      label: "Persistent Storage"
      style: {
        fill: transparent
        stroke: transparent
        font-size: 12
        italic: true
      }
    }
    disk_p0: {
      label: "Block 0"
      shape: rectangle
      style: {
        fill: "#CFD8DC"
        stroke: "#546E7A"
      }
    }
    disk_p1: {
      label: "Block 1"
      shape: rectangle
      style: {
        fill: "#CFD8DC"
        stroke: "#546E7A"
      }
    }
    disk_p2: {
      label: "Block 2\n(stale)"
      shape: rectangle
      style: {
        fill: "#CFD8DC"
        stroke: "#546E7A"
        stroke-dash: 3
      }
    }
    disk_p3: {
      label: "Block 3"
      shape: rectangle
      style: {
        fill: "#CFD8DC"
        stroke: "#546E7A"
      }
    }
  }
}

page_cache.cached_p0 -> disk_file.disk_p0: "4KB | lazy load" {
  style: {
    stroke: "#1976D2"
    stroke-dash: 4
  }
}
page_cache.cached_p2 -> disk_file.disk_p2: "4KB | writeback" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    animated: true
  }
}

row_fault: {
  direction: down
  label: "Page Fault Handling Sequence"
  style: {
    fill: "#FFF8E1"
    stroke: "#FF8F00"
    stroke-width: 2
  }
  fault_step1: {
    label: "1. CPU Access"
    code: |'c
      // Access unmapped page
      float val = vector_ptr[128];
    '|
    width: 320
  }
  fault_step2: {
    label: "2. Page Fault"
    code: |'c
      // CPU raises #PF
      // OS checks: valid mmap region?
      // Yes -> allocate page frame
    '|
    width: 320
  }
  fault_step3: {
    label: "3. Disk I/O"
    code: |'c
      // OS reads 4KB from file
      // into newly allocated page
    '|
    width: 320
  }
  fault_step4: {
    label: "4. Map & Resume"
    code: |'c
      // Update page tables
      // Mark page clean
      // Resume instruction
    '|
    width: 320
  }
  fault_step1 -> fault_step2: "triggers"
  fault_step2 -> fault_step3: "not cached"
  fault_step3 -> fault_step4: "done"
}

row_tombstone: {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  before_col: {
    direction: down
    label: "Before: Scattered with Tombstones"
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      stroke-width: 2
    }
    before_slot0: {
      shape: sql_table
      label: "Slot 0"
      f0: "vec_id | 1"
      f1: "status | LIVE"
      sz: "768 floats"
      style.fill: "#C8E6C9"
    }
    before_slot1: {
      shape: sql_table
      label: "Slot 1"
      f0: "vec_id | 2"
      f1: "status | TOMBSTONE"
      sz: "deleted"
      style: {
        fill: "#FFCDD2"
        stroke: "#C62828"
      }
    }
    before_slot2: {
      shape: sql_table
      label: "Slot 2"
      f0: "vec_id | 3"
      f1: "status | LIVE"
      sz: "768 floats"
      style.fill: "#C8E6C9"
    }
  }
  arrow_compact: {
    label: "compact()"
    shape: rectangle
    width: 120
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
      bold: true
    }
  }
  after_col: {
    direction: down
    label: "After: Contiguous Live Vectors"
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    after_slot0: {
      shape: sql_table
      label: "Slot 0"
      f0: "vec_id | 1"
      f1: "status | LIVE"
      sz: "768 floats"
      style.fill: "#C8E6C9"
    }
    after_slot1: {
      shape: sql_table
      label: "Slot 1"
      f0: "vec_id | 3"
      f1: "status | LIVE"
      sz: "768 floats"
      style.fill: "#C8E6C9"
    }
    after_free: {
      shape: sql_table
      label: "Free Space"
      f0: "available | 1 slot"
      style: {
        fill: "#E3F2FD"
        stroke: "#1565C0"
        stroke-dash: 4
      }
    }
  }
  before_col -> arrow_compact -> after_col: "Type | Compact"
}

row_persistence: {
  direction: down
  label: "Crash-Safe Persistence Pattern"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
  persist_step1: {
    label: "Step 1: Write to Temp"
    code: |'c
      int tmp_fd = open("vectors.bin.tmp", 
                        O_WRONLY | O_CREAT, 0644);
      write(tmp_fd, vector_data, data_size);
    '|
    width: 400
  }
  persist_step2: {
    label: "Step 2: Sync to Disk"
    code: |'c
      // Force data to stable storage
      fsync(tmp_fd); 
    '|
    width: 400
  }
  persist_step3: {
    label: "Step 3: Atomic Rename"
    code: |'c
      // Atomic operation
      rename("vectors.bin.tmp", "vectors.bin");
    '|
    width: 400
  }
  persist_step1 -> persist_step2: "write"
  persist_step2 -> persist_step3: "sync"
}

legend: {
  near: bottom-right
  direction: right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-width: 1
  }
  leg_clean: {
    label: "Clean Page"
    shape: rectangle
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
    }
  }
  leg_dirty: {
    label: "Dirty Page"
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      animated: true
    }
  }
  leg_live: {
    label: "Live Vector"
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
    }
  }
}