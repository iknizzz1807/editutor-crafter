direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Tombstone Deletion and Compaction {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  before: "BEFORE: Scattered Tombstones" {
    direction: down
    style: {
      fill: "#fef3f3"
      stroke: "#dc2626"
      stroke-width: 2
    }
    before_label: {
      shape: text
      label: "Storage State: 8 slots, 3 tombstones"
      style: {
        font-size: 14
        bold: true
        font-color: "#7f1d1d"
      }
    }
    before_storage: {
      direction: right
      grid-columns: 4
      grid-gap: 4
      slot0: {
        shape: rectangle
        label: "Vec 0\nID=10"
        style: {
          fill: "#dcfce7"
          stroke: "#16a34a"
        }
      }
      slot1: {
        shape: rectangle
        label: "TOMBSTONE\nID=20 ✗"
        style: {
          fill: "#fecaca"
          stroke: "#dc2626"
          stroke-dash: 3
          font-color: "#991b1b"
        }
      }
      slot2: {
        shape: rectangle
        label: "Vec 2\nID=30"
        style: {
          fill: "#dcfce7"
          stroke: "#16a34a"
        }
      }
      slot3: {
        shape: rectangle
        label: "TOMBSTONE\nID=40 ✗"
        style: {
          fill: "#fecaca"
          stroke: "#dc2626"
          stroke-dash: 3
          font-color: "#991b1b"
        }
      }
      slot4: {
        shape: rectangle
        label: "Vec 4\nID=50"
        style: {
          fill: "#dcfce7"
          stroke: "#16a34a"
        }
      }
      slot5: {
        shape: rectangle
        label: "TOMBSTONE\nID=60 ✗"
        style: {
          fill: "#fecaca"
          stroke: "#dc2626"
          stroke-dash: 3
          font-color: "#991b1b"
        }
      }
      slot6: {
        shape: rectangle
        label: "Vec 6\nID=70"
        style: {
          fill: "#dcfce7"
          stroke: "#16a34a"
        }
      }
      slot7: {
        shape: rectangle
        label: "Vec 7\nID=80"
        style: {
          fill: "#dcfce7"
          stroke: "#16a34a"
        }
      }
    }
    before_legend: {
      shape: rectangle
      label: |md
        **Legend:**
        🟢 Live vector (5 total)
        🔴 Tombstone (3 total)
        **Wasted space:** 3 slots × 3KB = 9KB
      |
      style: {
        fill: "#fff7ed"
        stroke: "#fdba74"
        font-size: 12
      }
    }
    before_id_map: {
      label: "ID → Slot Index (BEFORE)"
      shape: sql_table
      style: {
        fill: "#f0f9ff"
        stroke: "#0284c7"
      }
      f0: "ID | Slot | Status"
      r0: "10 | 0 | LIVE"
      r1: "20 | 1 | DELETED"
      r2: "30 | 2 | LIVE"
      r3: "40 | 3 | DELETED"
      r4: "50 | 4 | LIVE"
      r5: "60 | 5 | DELETED"
      r6: "70 | 6 | LIVE"
      r7: "80 | 7 | LIVE"
    }
  }
}
arrow: "compact()" {
  shape: text
  near: center-left
  style: {
    font-size: 20
    bold: true
    font-color: "#7c3aed"
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  after: "AFTER: Compacted Storage" {
    direction: down
    style: {
      fill: "#f0fdf4"
      stroke: "#16a34a"
      stroke-width: 2
    }
    after_label: {
      shape: text
      label: "Storage State: 5 slots, 0 tombstones"
      style: {
        font-size: 14
        bold: true
        font-color: "#14532d"
      }
    }
    after_storage: {
      direction: right
      grid-columns: 5
      grid-gap: 4
      new_slot0: {
        shape: rectangle
        label: "Vec 0\nID=10"
        style: {
          fill: "#dcfce7"
          stroke: "#16a34a"
        }
      }
      new_slot1: {
        shape: rectangle
        label: "Vec 1\nID=30"
        style: {
          fill: "#dbeafe"
          stroke: "#2563eb"
        }
      }
      new_slot2: {
        shape: rectangle
        label: "Vec 2\nID=50"
        style: {
          fill: "#dbeafe"
          stroke: "#2563eb"
        }
      }
      new_slot3: {
        shape: rectangle
        label: "Vec 3\nID=70"
        style: {
          fill: "#dbeafe"
          stroke: "#2563eb"
        }
      }
      new_slot4: {
        shape: rectangle
        label: "Vec 4\nID=80"
        style: {
          fill: "#dbeafe"
          stroke: "#2563eb"
        }
      }
    }
    after_legend: {
      shape: rectangle
      label: |md
        **Legend:**
        🟢 Unmoved vector
        🔵 Relocated vector
        **Reclaimed:** 3 slots × 3KB = 9KB
        **New capacity:** 5 slots
      |
      style: {
        fill: "#fff7ed"
        stroke: "#fdba74"
        font-size: 12
      }
    }
    after_id_map: {
      label: "ID → Slot Index (AFTER)"
      shape: sql_table
      style: {
        fill: "#f0f9ff"
        stroke: "#0284c7"
      }
      f0: "ID | Slot | Changed"
      s0: "10 | 0 | —"
      s2: "30 | 1 | 2→1 ✓"
      s4: "50 | 2 | 4→2 ✓"
      s6: "70 | 3 | 6→3 ✓"
      s7: "80 | 4 | 7→4 ✓"
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  process: "Compaction Algorithm" {
    direction: down
    style: {
      fill: "#faf5ff"
      stroke: "#7c3aed"
      stroke-width: 2
    }
    process_title: {
      shape: text
      label: "compaction.rs:compact()"
      style: {
        font-size: 16
        bold: true
        font-color: "#581c87"
      }
    }
    step1: {
      label: "Step 1: Build old→new mapping"
      code: |'rust
        let mut old_to_new = vec![None; capacity];
        let mut next_new = 0;
        for old_idx in 0..capacity {
          if is_live(old_idx) {
            old_to_new[old_idx] = Some(next_new);
            next_new += 1;
          }
        }
      '|
      style: {
        fill: "#fdf4ff"
        stroke: "#d946ef"
      }
    }
    step2: {
      label: "Step 2: Copy live vectors contiguously"
      code: |'rust
        for (old_idx, new_idx) in old_to_new.iter().enumerate() {
          if let Some(new) = new_idx {
            copy_vector(old_idx, *new);
          }
        }
      '|
      style: {
        fill: "#fdf4ff"
        stroke: "#d946ef"
      }
    }
    step3: {
      label: "Step 3: Update ID→slot index"
      code: |'rust
        for (&id, &(old, gen)) in &id_to_slot {
          if let Some(new) = old_to_new[old] {
            id_to_slot.insert(id, (new, gen));
          } else {
            id_to_slot.remove(&id);
          }
        }
      '|
      style: {
        fill: "#fdf4ff"
        stroke: "#d946ef"
      }
    }
    step4: {
      label: "Step 4: Shrink capacity"
      code: |'rust
        capacity = live_count;
        free_list.clear();
        // Truncate slots/metadata arrays
      '|
      style: {
        fill: "#fdf4ff"
        stroke: "#d946ef"
      }
    }
  }
  stats: "Compaction Statistics" {
    direction: down
    shape: rectangle
    style: {
      fill: "#fefce8"
      stroke: "#ca8a04"
      stroke-width: 2
    }
    stats_title: {
      shape: text
      label: "Performance Impact"
      style: {
        font-size: 16
        bold: true
        font-color: "#713f12"
      }
    }
    stats_content: {
      shape: rectangle
      label: |md
        **Time Complexity:** O(N) single pass
        **Space Overhead:** O(N) for old_to_new map
        **When to Compact:**
        • Tombstone ratio > 30%
        • After bulk deletes
        • During maintenance windows
        **Trade-off:**
        • Compaction blocks writes
        • Run during low traffic
        • Consider incremental compaction
      |
      style: {
        fill: "#fefce8"
        font-size: 12
      }
    }
  }
}
before.before_id_map -> after.after_id_map: "Index rebuilt\ncontiguously" {
  style: {
    stroke: "#7c3aed"
    stroke-width: 3
    animated: true
  }
}