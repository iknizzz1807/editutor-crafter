direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  vector_box: {
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 2
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
  }
  compute_node: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  fast_path_style: {
    style: {
      fill: "#C8E6C9"
      stroke: "#1B5E20"
      stroke-width: 3
    }
  }
  slow_path_style: {
    style: {
      fill: "#FFECB3"
      stroke: "#F57C00"
      stroke-width: 2
      stroke-dash: 3
    }
  }
  storage_box: {
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
  result_box: {
    style: {
      fill: "#E0E0E0"
      stroke: "#424242"
      stroke-width: 2
    }
  }
}

title_node: {
  shape: rectangle
  label: "Vector Similarity: Pre-Normalized Fast Path Logic"
  style: {
    font-size: 24
    bold: true
    fill: transparent
    stroke: transparent
  }
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  input_vectors: {
    class: vector_box
    label: "Input Buffers"
    a: "float32[] a_vec"
    b: "float32[] b_vec"
  }
  
  meta_store: {
    class: storage_box
    label: "Metadata Registry"
    flag_table: {
      shape: sql_table
      label: "struct VectorMeta (vector_meta.h)"
      f0: "0x00 | uint64_t | vector_id"
      f1: "0x08 | bool     | is_normalized"
      f2: "0x0C | float    | cached_norm"
      sz: "Total: 16 bytes"
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  gate_logic: "Normalization Check" {
    direction: right
    style.stroke-dash: 2
    
    check_a: {
      class: decision
      label: "a.is_norm?"
    }
    
    check_b: {
      class: decision
      label: "b.is_norm?"
    }
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  fast_lane: {
    class: fast_path_style
    label: "SIMD FAST PATH"
    
    calc_dot: {
      class: compute_node
      label: "Kernel: dot_product_f32"
      code: |'c
        // 768d vector ≈ 192 instructions (AVX-512)
        float dot = _mm512_reduce_add_ps(
          _mm512_mul_ps(va, vb)
        );
      '|
    }
    
    calc_final: {
      class: compute_node
      label: "Identity Mapping"
      code: |'c
        // Since norm(a)=norm(b)=1.0
        float cos_sim = dot;
        float dist = 1.0f - cos_sim;
      '|
    }
  }
  
  slow_lane: {
    class: slow_path_style
    label: "FALLBACK SLOW PATH"
    
    calc_norms: {
      class: compute_node
      label: "Kernel: L2_norm"
      code: |'c
        float na = sqrt(sum(a[i]*a[i]));
        float nb = sqrt(sum(b[i]*b[i]));
      '|
    }
    
    calc_full: {
      class: compute_node
      label: "Full Cosine Formula"
      code: |'c
        float dot = dot_product(a, b);
        float cos_sim = dot / (na * nb);
        float dist = 1.0f - cos_sim;
      '|
    }
  }
}

row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  final_output: {
    class: result_box
    label: "Query Result"
    val: "float32 distance"
  }
  
  perf_stats: {
    shape: sql_table
    label: "Efficiency Matrix (768d)"
    r1: "Fast Path | ~768 FLOPs  | 1.0x (Base)"
    r2: "Slow Path | ~2304 FLOPs | 3.0x Cost"
    r3: "Benefit   | Bypass sqrt | No division"
  }
}

# Connections
row1.input_vectors -> row2.gate_logic.check_a: "vectors"
row1.meta_store.flag_table.f1 -> row2.gate_logic.check_a: "bool"
row1.meta_store.flag_table.f1 -> row2.gate_logic.check_b: "bool"

row2.gate_logic.check_a -> row3.fast_lane: "true" { style.stroke: green }
row2.gate_logic.check_b -> row3.fast_lane: "true" { style.stroke: green }

row2.gate_logic.check_a -> row3.slow_lane: "false" { style.stroke: orange; style.stroke-dash: 3 }
row2.gate_logic.check_b -> row3.slow_lane: "false" { style.stroke: orange; style.stroke-dash: 3 }

row3.fast_lane.calc_dot -> row3.fast_lane.calc_final: "float"
row3.fast_lane.calc_final -> row4.final_output: "cos_dist"

row3.slow_lane.calc_norms -> row3.slow_lane.calc_full: "norms"
row3.slow_lane.calc_full -> row4.final_output: "cos_dist"

# Metadata and Notes
legend_node: {
  near: bottom-right
  label: "Color Code"
  fast: "Green: Bypass Norm (Fast)" { class: fast_path_style }
  slow: "Yellow: Compute Norm (Slow)" { class: slow_path_style }
}

implementation_notes: {
  near: bottom-center
  label: |'md
    ### Optimization Constraints
    1. **Strict Normalization**: Vector must satisfy `|1.0 - L2(v)| < 1e-6` to set `is_normalized`.
    2. **SIMD Alignment**: Input buffers should be 64-byte aligned for AVX-512 efficiency.
    3. **Metadata Sync**: Registry must be updated during write/upsert operations.
  '|
  style: {
    stroke: "#424242"
    fill: "#FAFAFA"
  }
}