direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Floating-Point Accumulation Error: Kahan Summation"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  scalar_flow: {
    direction: down
    label: "Standard Accumulation"
    style.fill: "#FFF0F0"
    style.stroke: "#CC0000"
    inputs: {
      label: "Input Products"
      shape: rectangle
      width: 280
      p0: "p₀ = a₀ × b₀"
      p1: "p₁ = a₁ × b₁"
      p2: "p₂ = a₂ × b₂"
      dots: "..."
      pn: "p₇₆₇ = a₇₆₇ × b₇₆₇"
    }
    acc_loop: {
      label: "Accumulation Loop (768 iterations)"
      shape: rectangle
      width: 280
      code: |'c
        sum = 0.0f;
        for (i = 0; i < 768; i++) {
          sum += p[i];  // Each += loses bits!
        }
      '|
      style.fill: "#FFE0E0"
    }
    error_growth: {
      label: "Error Growth per Addition"
      shape: rectangle
      width: 280
      style.fill: "#FFD0D0"
      e0: "e₀ = 0"
      e1: "e₁ ≈ |p₁| × 2⁻²⁴"
      e2: "e₂ ≈ (|p₁| + |p₂|) × 2⁻²⁴"
      formula: "Total error ≈ Σ|pᵢ| × 2⁻²⁴ × √i"
    }
    result: {
      label: "Final Result"
      shape: rectangle
      width: 280
      sum: "sum = 12.34567890..."
      error: "error ≈ ±0.00000412"
      bits_lost: "Lost ~6 bits of precision"
      style.fill: "#FFC0C0"
    }
  }
  kahan_flow: {
    direction: down
    label: "Kahan (Compensated) Summation"
    style.fill: "#F0FFF0"
    style.stroke: "#008800"
    inputs2: {
      label: "Input Products"
      shape: rectangle
      width: 280
      p0: "p₀ = a₀ × b₀"
      p1: "p₁ = a₁ × b₁"
      p2: "p₂ = a₂ × b₂"
      dots: "..."
      pn: "p₇₆₇ = a₇₆₇ × b₇₆₇"
    }
    kahan_loop: {
      label: "Kahan Accumulation Loop"
      shape: rectangle
      width: 280
      code: |'c
        sum = 0.0f;
        c = 0.0f;  // Compensation
        for (i = 0; i < 768; i++) {
          y = p[i] - c;      // Compensated input
          t = sum + y;       // Alas, sum big, y small
          c = (t - sum) - y; // Recover lost bits!
          sum = t;
        }
      '|
      style.fill: "#E0FFE0"
    }
    recovery: {
      label: "Error Recovery Mechanism"
      shape: rectangle
      width: 280
      style.fill: "#D0FFD0"
      step1: "1. y = pᵢ - c (subtract prior error)"
      step2: "2. t = sum + y (add with rounding)"
      step3: "3. c = (t - sum) - y (capture new error)"
      invariant: "c tracks the 'lost' low bits"
    }
    result2: {
      label: "Final Result"
      shape: rectangle
      width: 280
      sum: "sum = 12.34567890..."
      error: "error ≈ ±0.00000001"
      bits_kept: "Preserved ~23 bits of precision"
      style.fill: "#C0FFC0"
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  dim_128: {
    direction: down
    label: "128 Dimensions"
    width: 200
    style.fill: "#E8F5E9"
    bar_128: {
      shape: rectangle
      width: 180
      label: "Error: ~0.00001%"
      style.fill: "#4CAF50"
    }
    note_128: {
      shape: text
      label: "Negligible\n~2 bits lost"
    }
  }
  dim_768: {
    direction: down
    label: "768 Dimensions"
    width: 200
    style.fill: "#FFF8E1"
    bar_768: {
      shape: rectangle
      width: 180
      label: "Error: ~0.001%"
      style.fill: "#FFC107"
    }
    note_768: {
      shape: text
      label: "Noticeable\n~5 bits lost"
    }
  }
  dim_1536: {
    direction: down
    label: "1536 Dimensions"
    width: 200
    style.fill: "#FFEBEE"
    bar_1536: {
      shape: rectangle
      width: 180
      label: "Error: ~0.01%"
      style.fill: "#F44336"
    }
    note_1536: {
      shape: text
      label: "Significant\n~7 bits lost"
    }
  }
}
error_table: {
  shape: sql_table
  label: "Accumulation Error by Dimension (f32)"
  col1: "Dim"
  col2: "Standard Error"
  col3: "Kahan Error"
  col4: "Improvement"
  r128: "128  |  ~2⁻¹⁸      |  ~2⁻²³     |  32x"
  r256: "256  |  ~2⁻¹⁷      |  ~2⁻²³     |  64x"
  r512: "512  |  ~2⁻¹⁶      |  ~2⁻²³     |  128x"
  r768: "768  |  ~2⁻¹⁵.₅    |  ~2⁻²³     |  256x"
  r1536: "1536 |  ~2⁻¹⁵      |  ~2⁻²³     |  512x"
  r3072: "3072 |  ~2⁻¹⁴      |  ~2⁻²².₅   |  ~512x"
}
comparison: {
  label: "Key Insight"
  shape: callout
  width: 500
  text: |md
    **Standard accumulation** loses O(√n) bits of precision because each
    addition rounds the result. For 768 dimensions, this costs ~5 bits.
    **Kahan summation** tracks the rounding error (`c`) and subtracts it
    from the next term, recovering most lost precision. Cost: 4x more
    operations, but still faster than using f64.
    **Rule of thumb**: Use Kahan for dimensions > 512 where distance
    comparisons must be accurate to 1e-5 or better.
  |
}
scalar_flow -> error_table: "Error grows\nwith dimension" {
  style.stroke: "#CC0000"
  style.stroke-dash: 3
}
kahan_flow -> error_table: "Error bounded\nby machine ε" {
  style.stroke: "#008800"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  standard: {
    label: "Standard: O(√n) error growth"
    shape: rectangle
    style.fill: "#FFC0C0"
  }
  kahan: {
    label: "Kahan: O(1) error (machine epsilon)"
    shape: rectangle
    style.fill: "#C0FFC0"
  }
}