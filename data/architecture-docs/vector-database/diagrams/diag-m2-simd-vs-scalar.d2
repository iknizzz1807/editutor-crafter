direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "SIMD vs Scalar Distance Computation" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  scalar_section: {
    direction: down
    label: "SCALAR APPROACH"
    style: {
      fill: "#fff0f0"
      stroke: "#cc0000"
      stroke-width: 2
    }
    scalar_loop: {
      label: "Loop Iteration (128-dim = 128 iterations)"
      width: 380
      code: |'c
        // Scalar: process 1 float at a time
        for (int i = 0; i < 128; i++) {
          diff = a[i] - b[i];      // 1 op
          sum += diff * diff;       // 1 op
        }
        // Total: 256 operations
      '|
      style.fill: "#ffe6e6"
    }
    scalar_ops: {
      direction: right
      label: "Per Iteration"
      op1: "Load a[i]" {
        shape: rectangle
        style.fill: "#ffcccc"
      }
      op2: "Load b[i]" {
        shape: rectangle
        style.fill: "#ffcccc"
      }
      op3: "Subtract" {
        shape: rectangle
        style.fill: "#ffcccc"
      }
      op4: "Multiply" {
        shape: rectangle
        style.fill: "#ffcccc"
      }
      op5: "Accumulate" {
        shape: rectangle
        style.fill: "#ffcccc"
      }
      op1 -> op2 -> op3 -> op4 -> op5
    }
    scalar_stats: {
      shape: sql_table
      label: "Scalar Performance (128-dim)"
      iterations: "Iterations | 128"
      ops_per_iter: "Ops/iter | 4 (2 load, 1 sub, 1 mul, 1 add)"
      total_ops: "Total ops | 512"
      throughput: "Throughput | ~50M ops/sec"
      latency: "Latency | ~2.5 μs per distance"
    }
  }
  simd_section: {
    direction: down
    label: "SIMD APPROACH (AVX2)"
    style: {
      fill: "#f0fff0"
      stroke: "#00aa00"
      stroke-width: 2
    }
    simd_loop: {
      label: "Loop Iteration (128-dim = 16 iterations)"
      width: 380
      code: |'c
        // SIMD: process 8 floats at once
        for (int i = 0; i < 128; i += 8) {
          va = _mm256_load_ps(&a[i]);    // 8 floats
          vb = _mm256_load_ps(&b[i]);    // 8 floats
          vdiff = _mm256_sub_ps(va, vb); // 8 subs
          sum = _mm256_fmadd_ps(vdiff,   // 8 muls
                                vdiff, sum);
        }
        // Total: 64 vector ops = 512 scalar ops
      '|
      style.fill: "#e6ffe6"
    }
    simd_ops: {
      direction: right
      label: "Per Iteration (8 floats)"
      s_op1: "Load 8x a" {
        shape: rectangle
        style.fill: "#ccffcc"
      }
      s_op2: "Load 8x b" {
        shape: rectangle
        style.fill: "#ccffcc"
      }
      s_op3: "8x Subtract" {
        shape: rectangle
        style.fill: "#ccffcc"
        style.bold: true
      }
      s_op4: "8x FMA" {
        shape: rectangle
        style.fill: "#ccffcc"
        style.bold: true
      }
      s_op1 -> s_op2 -> s_op3 -> s_op4
    }
    simd_stats: {
      shape: sql_table
      label: "SIMD Performance (128-dim)"
      iterations: "Iterations | 16"
      ops_per_iter: "Ops/iter | 4 (but 8x parallelism)"
      total_ops: "Vector ops | 64"
      throughput: "Throughput | ~200M ops/sec"
      latency: "Latency | ~0.6 μs per distance"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  register_comparison: {
    direction: down
    label: "Register Utilization"
    scalar_reg: {
      label: "Scalar Register (32-bit)"
      shape: rectangle
      width: 300
      style: {
        fill: "#ffcccc"
        stroke: "#cc0000"
      }
      code: |'
        ┌─────────────────┐
        │   float32 val   │
        └─────────────────┘
            4 bytes
      '|
    }
    simd_reg: {
      label: "AVX2 Register (256-bit)"
      shape: rectangle
      width: 300
      style: {
        fill: "#ccffcc"
        stroke: "#00aa00"
      }
      code: |'
        ┌───┬───┬───┬───┬───┬───┬───┬───┐
        │f0 │f1 │f2 │f3 │f4 │f5 │f6 │f7 │
        └───┴───┴───┴───┴───┴───┴───┴───┘
                 32 bytes (8 floats)
      '|
    }
  }
  memory_bandwidth: {
    direction: down
    label: "Memory Bandwidth"
    mem_scalar: {
      shape: rectangle
      width: 280
      style.fill: "#ffe6e6"
      code: |'
        Scalar Memory Access Pattern:
        128 iterations × 2 loads
        = 256 memory ops
        Cache line utilization: ~6%
        (only 4 of 64 bytes used per load)
      '|
    }
    mem_simd: {
      shape: rectangle
      width: 280
      style.fill: "#e6ffe6"
      code: |'
        SIMD Memory Access Pattern:
        16 iterations × 2 loads
        = 32 memory ops
        Cache line utilization: ~50%
        (32 of 64 bytes used per load)
      '|
    }
  }
  speedup_box: {
    direction: down
    label: "Speedup Summary"
    speedup_visual: {
      shape: rectangle
      width: 280
      style: {
        fill: "#e6f3ff"
        stroke: "#0066cc"
        stroke-width: 2
      }
      code: |'
        ┌─────────────────────────────┐
        │   4x THROUGHPUT GAIN        │
        │                             │
        │   Scalar: ~50M ops/sec      │
        │   SIMD:   ~200M ops/sec     │
        │                             │
        │   128-dim distance:         │
        │   • Scalar: 2.5 μs          │
        │   • SIMD:   0.6 μs          │
        └─────────────────────────────┘
      '|
    }
    key_factors: {
      shape: class
      label: "Why SIMD Wins"
      factor1: "8 floats per instruction"
      factor2: "Fused multiply-add (FMA)"
      factor3: "Better cache utilization"
      factor4: "Fewer loop iterations"
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  scalar_legend: "Scalar" {
    shape: rectangle
    style.fill: "#ffcccc"
  }
  simd_legend: "SIMD" {
    shape: rectangle
    style.fill: "#ccffcc"
  }
}