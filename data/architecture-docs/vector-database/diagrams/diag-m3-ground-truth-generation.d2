direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Ground Truth Export for Recall Measurement"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  inputs: "Input Data" {
    direction: down
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    storage: {
      label: "VectorStorage"
      shape: cylinder
      style.fill: white
    }
    queries: {
      label: "Query Vectors\n[N × dim]"
      shape: document
      style.fill: white
    }
    metric: {
      label: "DistanceMetric\n(cosine, l2, dot)"
      shape: diamond
      style.fill: white
    }
  }
  process: "Generation Process" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    step1: {
      label: "Step 1: Load Storage"
      code: |'rust
  let storage = VectorStorage::load(path)?;
  let live_count = storage.live_count();
      '|
      width: 320
    }
    step2: {
      label: "Step 2: Iterate Queries"
      code: |'rust
  for (q_idx, query) in queries.iter().enumerate() {
    // Process each query
  }
      '|
      width: 320
    }
    step3: {
      label: "Step 3: Brute-Force KNN"
      code: |'rust
  let search = BruteForceSearch::new(&storage, &metric);
  let results = search.search(query, k);
  // Exact top-k: O(N) distance computations
      '|
      width: 320
    }
    step4: {
      label: "Step 4: Collect Results"
      code: |'rust
  let top_k: Vec<(u64, f32)> = results.iter()
    .map(|r| (r.id, r.score))
    .collect();
  ground_truth.queries.push((query.clone(), top_k));
      '|
      width: 320
    }
  }
  output: "Output Format" {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    gt_struct: {
      label: "GroundTruth Structure"
      shape: class
      metric_name: "String"
      k: "usize"
      queries: "Vec<(Vec<f32>, Vec<(u64, f32)>)>"
    }
    file_format: {
      label: "JSON File Format"
      width: 340
      code: |'json
{
  "metric_name": "cosine",
  "k": 10,
  "queries": [
    {
      "0": [0.1, 0.2, ...],
      "1": [[42, 0.05], [17, 0.12], ...]
    }
  ]
}
      '|
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  flow: "Data Flow" {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    flowchart: {
      direction: down
      label: ""
      start: {
        label: "Generate N Query Vectors\n(random or from test set)"
        shape: oval
        style.fill: white
      }
      bf_search: {
        label: "Brute-Force Search\nfor each query"
        shape: rectangle
        style.fill: white
      }
      collect: {
        label: "Collect (query_id, [top_k_ids])"
        shape: rectangle
        style.fill: white
      }
      serialize: {
        label: "Serialize to JSON"
        shape: rectangle
        style.fill: white
      }
      write: {
        label: "Write to ground_truth.json"
        shape: document
        style.fill: white
      }
      start -> bf_search: "N queries"
      bf_search -> collect: "exact results"
      collect -> serialize: "GroundTruth struct"
      serialize -> write: "JSON bytes"
    }
  }
  usage: "Usage in M4 (HNSW Recall)" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    recall_flow: {
      direction: down
      label: ""
      load_gt: {
        label: "Load Ground Truth"
        shape: oval
        style.fill: white
      }
      hnsw_search: {
        label: "HNSW Search\n(approximate)"
        shape: rectangle
        style.fill: white
      }
      compare: {
        label: "Compare: GT ∩ Approx"
        shape: rectangle
        style.fill: white
      }
      compute_recall: {
        label: "Recall@k = |intersection| / k"
        shape: rectangle
        style.fill: "#FFF9C4"
        style.stroke: "#FBC02D"
        style.bold: true
      }
      load_gt -> hnsw_search: "same queries"
      hnsw_search -> compare: "approx top-k"
      compare -> compute_recall: "count matches"
    }
    recall_code: {
      label: "Recall Computation"
      width: 380
      code: |'rust
fn compute_recall(
    gt: &GroundTruth,
    approx: &[SearchResult],
    k: usize
) -> f64 {
    let exact_ids: HashSet<u64> = gt.queries[i]
        .1.iter().take(k)
        .map(|(id, _)| *id).collect();
    let approx_ids: HashSet<u64> = approx
        .iter().take(k)
        .map(|r| r.id).collect();
    exact_ids.intersection(&approx_ids).count() 
        as f64 / k as f64
}
      '|
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  spec: "File Format Specification" {
    direction: down
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    fields: {
      label: "GroundTruth JSON Fields"
      shape: sql_table
      field: "Field | Type | Description"
      metric_name: "metric_name | String | Distance metric used"
      k: "k | usize | Number of neighbors"
      queries: "queries | Array | Query vectors + results"
      query_vec: "  queries[i].0 | Vec<f32> | Query vector data"
      query_res: "  queries[i].1 | Vec<(u64,f32)> | Top-k (id, distance)"
    }
    example: {
      label: "Example: 2 Queries, k=3"
      width: 400
      code: |'json
{
  "metric_name": "cosine",
  "k": 3,
  "queries": [
    [[0.1, 0.2, 0.3], [[5, 0.02], [12, 0.05], [3, 0.08]]],
    [[0.4, 0.5, 0.6], [[7, 0.01], [2, 0.03], [9, 0.07]]]
  ]
}
      '|
    }
  }
  timing: "Performance Considerations" {
    direction: down
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    timing_table: {
      label: "Generation Time by Scale"
      shape: sql_table
      header: "Dataset Size | Dim | k | Queries | Time"
      row1: "10K vectors | 128 | 10 | 100 | ~1s"
      row2: "100K vectors | 768 | 10 | 100 | ~15s"
      row3: "1M vectors | 768 | 10 | 100 | ~2-3min"
      note: "Note: Generation is O(N × Q × dim)"
    }
    tips: {
      label: "Best Practices"
      width: 380
      code: |'text
• Generate once, reuse for all experiments
• Use same random seed for reproducibility
• Store queries separately for large datasets
• Compress JSON with gzip for large files
• Version ground truth with index snapshots
      '|
    }
  }
}
inputs.storage -> process.step1: "load vectors"
inputs.queries -> process.step2: "N queries"
inputs.metric -> process.step3: "distance fn"
process.step4 -> output.gt_struct: "GroundTruth"
output.gt_struct -> output.file_format: "serialize"
flow.flowchart.write -> usage.recall_flow.load_gt: "ground_truth.json"
usage.recall_flow.compute_recall -> usage.recall_code: "implementation"
legend: {
  near: bottom-center
  label: ""
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  exact: {
    label: "Exact Search\n(Brute-Force)"
    shape: rectangle
    style.fill: "#E8F4FD"
  }
  approx: {
    label: "Approximate\n(HNSW)"
    shape: rectangle
    style.fill: "#FFEBEE"
  }
  file: {
    label: "Serialized\n(JSON)"
    shape: document
    style.fill: "#E8F5E9"
  }
  exact -> approx: "compare"
  approx -> file: "measure"
}