direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Max-Heap Top-K Selection"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}
# Legend for complexity comparison
legend: {
  near: top-right
  label: "Complexity Comparison"
  legend_box: {
    shape: rectangle
    style.fill: "#f8f9fa"
    style.stroke: "#dee2e6"
    heap_row: "Max-Heap: O(N log k)"
    sort_row: "Full Sort: O(N log N)"
    example: {
      label: "Example (N=1000, k=10)"
      shape: text
      style.font-size: 14
    }
    heap_ops: "Heap: 1000 × 3.3 = 3,300 ops"
    sort_ops: "Sort: 1000 × 10 = 10,000 ops"
    speedup: "Speedup: 3x faster"
    heap_row.style.font-color: "#2e7d32"
    sort_row.style.font-color: "#c62828"
    speedup.style.font-color: "#1565c0"
    speedup.style.bold: true
  }
}
# Linear scan flow
scan_flow: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scan_label: {
    label: "Linear Scan\nProcess each vector"
    shape: rectangle
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    width: 140
  }
  arrow1: {
    shape: text
    label: "→"
    style.font-size: 24
  }
  compute_label: {
    label: "Compute\nDistance"
    shape: rectangle
    style.fill: "#fff3e0"
    style.stroke: "#f57c00"
    width: 120
  }
  arrow2: {
    shape: text
    label: "→"
    style.font-size: 24
  }
  compare_label: {
    label: "Compare to\nHeap Max"
    shape: diamond
    style.fill: "#fce4ec"
    style.stroke: "#c2185b"
    width: 120
    height: 80
  }
  arrow3: {
    shape: text
    label: "→"
    style.font-size: 24
  }
  heap_label: {
    label: "Update\nHeap"
    shape: rectangle
    style.fill: "#e8f5e9"
    style.stroke: "#388e3c"
    width: 100
  }
}
scan_flow.scan_label -> scan_flow.compute_label
scan_flow.compute_label -> scan_flow.compare_label
scan_flow.compare_label -> scan_flow.heap_label
# Max-Heap visualization
heap_section: {
  direction: down
  label: "Max-Heap (k=5) During Scan"
  heap_state: {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    # State 1: Initial heap with 5 elements
    state1: {
      direction: down
      label: "Step 1\nHeap Full"
      s1_root: {
        label: "0.89"
        shape: circle
        style.fill: "#ffcdd2"
        style.stroke: "#c62828"
        style.stroke-width: 3
      }
      s1_level1: {
        direction: right
        style.stroke: transparent
        s1_l1_left: {
          label: "0.72"
          shape: circle
          style.fill: "#fff9c4"
          style.stroke: "#f9a825"
        }
        s1_l1_right: {
          label: "0.65"
          shape: circle
          style.fill: "#c8e6c9"
          style.stroke: "#388e3c"
        }
      }
      s1_level2: {
        direction: right
        style.stroke: transparent
        s1_l2_left: {
          label: "0.31"
          shape: circle
          style.fill: "#c8e6c9"
          style.stroke: "#388e3c"
        }
        s1_l2_right: {
          label: "0.45"
          shape: circle
          style.fill: "#c8e6c9"
          style.stroke: "#388e3c"
        }
      }
      s1_root -> s1_l1_left
      s1_root -> s1_l1_right
      s1_l1_left -> s1_l2_left
      s1_l1_left -> s1_l2_right
      max_label1: {
        label: "← MAX\n(evict if\nnew < 0.89)"
        shape: text
        style.font-size: 11
        style.font-color: "#c62828"
      }
      s1_root -> max_label1: {style.stroke: transparent}
    }
    # Arrow between states
    state_arrow1: {
      label: "New dist = 0.23\n0.23 < 0.89\n→ EVICT MAX"
      shape: text
      style.font-size: 12
      style.font-color: "#1565c0"
    }
    # State 2: After eviction and insertion
    state2: {
      direction: down
      label: "Step 2\nAfter Insert"
      s2_root: {
        label: "0.72"
        shape: circle
        style.fill: "#ffcdd2"
        style.stroke: "#c62828"
        style.stroke-width: 3
      }
      s2_level1: {
        direction: right
        style.stroke: transparent
        s2_l1_left: {
          label: "0.45"
          shape: circle
          style.fill: "#fff9c4"
          style.stroke: "#f9a825"
        }
        s2_l1_right: {
          label: "0.65"
          shape: circle
          style.fill: "#c8e6c9"
          style.stroke: "#388e3c"
        }
      }
      s2_level2: {
        direction: right
        style.stroke: transparent
        s2_l2_left: {
          label: "0.31"
          shape: circle
          style.fill: "#c8e6c9"
          style.stroke: "#388e3c"
        }
        s2_l2_right: {
          label: "0.23"
          shape: circle
          style.fill: "#bbdefb"
          style.stroke: "#1976d2"
          style.bold: true
        }
      }
      s2_root -> s2_l1_left
      s2_root -> s2_l1_right
      s2_l1_left -> s2_l2_left
      s2_l1_left -> s2_l2_right
      max_label2: {
        label: "← NEW MAX"
        shape: text
        style.font-size: 11
        style.font-color: "#c62828"
      }
      s2_root -> max_label2: {style.stroke: transparent}
      new_label: {
        label: "← NEW"
        shape: text
        style.font-size: 11
        style.font-color: "#1976d2"
        style.bold: true
      }
      s2_l2_right -> new_label: {style.stroke: transparent}
    }
    # Arrow to skip
    state_arrow2: {
      label: "New dist = 0.95\n0.95 > 0.72\n→ SKIP"
      shape: text
      style.font-size: 12
      style.font-color: "#c62828"
    }
    # State 3: Final heap
    state3: {
      direction: down
      label: "Final\n(k smallest)"
      s3_root: {
        label: "0.45"
        shape: circle
        style.fill: "#a5d6a7"
        style.stroke: "#2e7d32"
        style.stroke-width: 3
      }
      s3_level1: {
        direction: right
        style.stroke: transparent
        s3_l1_left: {
          label: "0.31"
          shape: circle
          style.fill: "#a5d6a7"
          style.stroke: "#2e7d32"
        }
        s3_l1_right: {
          label: "0.23"
          shape: circle
          style.fill: "#a5d6a7"
          style.stroke: "#2e7d32"
        }
      }
      s3_level2: {
        direction: right
        style.stroke: transparent
        s3_l2_left: {
          label: "0.12"
          shape: circle
          style.fill: "#a5d6a7"
          style.stroke: "#2e7d32"
        }
        s3_l2_right: {
          label: "0.08"
          shape: circle
          style.fill: "#a5d6a7"
          style.stroke: "#2e7d32"
        }
      }
      s3_root -> s3_l1_left
      s3_root -> s3_l1_right
      s3_l1_left -> s3_l2_left
      s3_l1_left -> s3_l2_right
      final_label: {
        label: "5 smallest\ndistances"
        shape: text
        style.font-size: 12
        style.font-color: "#2e7d32"
        style.bold: true
      }
      s3_root -> final_label: {style.stroke: transparent}
    }
  }
}
# Algorithm pseudocode
algorithm: {
  label: "Heap-Based Top-K Algorithm"
  algo_content: {
    shape: rectangle
    style.fill: "#fafafa"
    style.stroke: "#9e9e9e"
    width: 420
    code: |'text
    // Max-heap stores k smallest distances seen
    // Root = WORST candidate (largest distance)
    for each vector v in database (N total):
        d = distance(query, v)
        if heap.size < k:
            heap.push(d, v.id)  // Fill heap first
        else if d < heap.max:   // Better than worst?
            heap.pop()          // Evict worst
            heap.push(d, v.id)  // Insert new
    return heap.elements sorted ascending
    '|
  }
}
# Key insight box
insight: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  key_insight: {
    label: "Key Insight: Max-Heap Inversion"
    shape: rectangle
    style: {
      fill: "#fff8e1"
      stroke: "#ff8f00"
      stroke-width: 2
    }
    width: 380
    content: {
      shape: text
      label: "For DISTANCE metrics (lower = better):\n• Keep MAX-heap of size k\n• Root = worst candidate in top-k\n• Evict root when finding better\n\nFor SIMILARITY metrics (higher = better):\n• Keep MIN-heap of size k  \n• Root = worst candidate in top-k\n• Evict root when finding better"
      style.font-size: 12
    }
  }
  complexity_box: {
    label: "Why O(N log k) Beats O(N log N)"
    shape: rectangle
    style: {
      fill: "#e8f5e9"
      stroke: "#2e7d32"
      stroke-width: 2
    }
    width: 340
    content: {
      shape: text
      label: "Full Sort: O(N log N)\n• Sort ALL N = 1000 elements\n• 1000 × log₂(1000) ≈ 10,000 comparisons\n\nMax-Heap: O(N log k)  \n• Maintain k = 10 element heap\n• 1000 × log₂(10) ≈ 3,300 comparisons\n• 3x fewer operations!\n\nMemory: k floats vs N floats"
      style.font-size: 12
    }
  }
}
# Memory comparison
memory: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  full_sort_mem: {
    label: "Full Sort Memory\n\nStore all N distances\nN = 1,000,000\n4 MB (1M floats)"
    shape: rectangle
    style: {
      fill: "#ffcdd2"
      stroke: "#c62828"
    }
    width: 160
  }
  vs_label: {
    shape: text
    label: "vs"
    style.font-size: 20
    style.bold: true
  }
  heap_mem: {
    label: "Heap Memory\n\nStore only k distances\nk = 10\n40 bytes (10 floats)"
    shape: rectangle
    style: {
      fill: "#c8e6c9"
      stroke: "#2e7d32"
    }
    width: 160
  }
  reduction: {
    label: "100,000x\nless memory!"
    shape: text
    style: {
      font-size: 14
      font-color: "#2e7d32"
      bold: true
    }
  }
}
full_sort_mem -> vs_label -> heap_mem -> reduction: {style.stroke: transparent}
# Scan flow to heap connection
scan_flow -> heap_section: "distances flow\ninto heap" {
  style.stroke-dash: 3
  style.stroke: "#1976d2"
}