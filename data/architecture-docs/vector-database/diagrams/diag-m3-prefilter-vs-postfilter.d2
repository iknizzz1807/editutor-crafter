direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    prefilter: "#E8F5E9"
    postfilter: "#E3F2FD"
    decision: "#FFF8E1"
    highlight: "#FF5722"
    code_bg: "#FAFAFA"
  }
}

title: {
  label: "Pre-Filter vs Post-Filter Tradeoff Logic"
  near: top-center
  shape: rectangle
  style: {
    font-size: 28
    bold: true
    stroke-width: 0
    fill: transparent
  }
}

row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  prefilter: "PRE-FILTER STRATEGY" {
    direction: down
    style.fill: ${colors.prefilter}
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    pf_desc: "Metadata evaluation PRIOR to ANN traversal" {
      style.stroke-width: 0
      style.font-size: 12
    }

    pf_flow: {
      direction: down
      pf_start: "Query + Filter" {
        shape: oval
        style.fill: white
      }
      pf_filter: "Apply Metadata Predicate" {
        shape: diamond
        style.fill: "#C8E6C9"
      }
      pf_subset: "Matching Vector Subset (e.g. 5% of 1M)" {
        shape: rectangle
        style.fill: "#A5D6A7"
        style.stroke-dash: 3
      }
      pf_dist: "Compute Subset Distances (50K Ops)" {
        shape: rectangle
        style.fill: white
      }
      pf_topk: "Return Top-K Results" {
        shape: step
      }

      pf_start -> pf_filter: "init"
      pf_filter -> pf_subset: "predicate matched"
      pf_subset -> pf_dist: "filter set"
      pf_dist -> pf_topk: "rank"
    }

    pf_pros: {
      label: |'md
        **PROS (Latency Focus)**
        - Skips 95% of distance computation
        - Drastically lower compute cost
        - Memory-efficient candidate set
      '|
      style.stroke-width: 0
    }

    pf_cons: {
      label: |'md
        **CONS (Accuracy Risk)**
        - HNSW graph navigation may fail
        - Potential for disconnected graph nodes
        - May return fewer than K results
      '|
      style.stroke-width: 0
      style.font-color: "#C62828"
    }
  }

  postfilter: "POST-FILTER STRATEGY" {
    direction: down
    style.fill: ${colors.postfilter}
    style.stroke: "#2196F3"
    style.stroke-width: 2

    po_desc: "Metadata evaluation AFTER ANN traversal" {
      style.stroke-width: 0
      style.font-size: 12
    }

    po_flow: {
      direction: down
      po_start: "Query + Filter" {
        shape: oval
        style.fill: white
      }
      po_search: "HNSW Global Search (1M Candidates)" {
        shape: rectangle
        style.fill: "#BBDEFB"
      }
      po_dist: "Compute Full Distances (K*Oversample)" {
        shape: rectangle
        style.fill: white
      }
      po_filter: "Apply Metadata Predicate" {
        shape: diamond
        style.fill: "#90CAF9"
      }
      po_topk: "Return Filtered Top-K" {
        shape: step
      }

      po_start -> po_search: "init"
      po_search -> po_dist: "candidates"
      po_dist -> po_filter: "distances"
      po_filter -> po_topk: "predicate pass"
    }

    po_pros: {
      label: |'md
        **PROS (Accuracy Focus)**
        - HNSW navigability fully preserved
        - Guaranteed nearest neighbor in set
        - Stable recall performance
      '|
      style.stroke-width: 0
    }

    po_cons: {
      label: |'md
        **CONS (Compute Waste)**
        - Wastes compute on non-matching nodes
        - Requires high oversampling (K * 20)
        - Higher latency for selective filters
      '|
      style.stroke-width: 0
      style.font-color: "#C62828"
    }
  }
}

row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  spacer: {
    width: 200
    label: " "
    style.stroke-width: 0
    style.fill: transparent
  }

  decision_engine: "SELECTIVITY-BASED DECIDER" {
    direction: down
    style.fill: ${colors.decision}
    style.stroke: "#FFA000"
    style.stroke-width: 2

    dec_flow: {
      direction: down
      req: "Search Request" { shape: oval }
      est: "Estimate Selectivity" { shape: rectangle }
      thresh: "Selectivity > 0.30?" { shape: diamond }
      
      pre_path: "Route: PRE-FILTER" {
        style.fill: ${colors.prefilter}
      }
      post_path: "Route: POST-FILTER" {
        style.fill: ${colors.postfilter}
      }

      req -> est: "input"
      est -> thresh: "prob"
      thresh -> pre_path: "Yes (>30%)"
      thresh -> post_path: "No (<30%)"
    }

    selectivity_table: {
      shape: sql_table
      label: "Heuristic Table (filter.go)"
      row1: "Predicate | Ratio | Strategy"
      row2: "cat = 'electronics' | 0.05 | Post-Filter"
      row3: "price < 1000 | 0.35 | Pre-Filter"
      row4: "status = 'active' | 0.85 | Pre-Filter"
    }
  }
}

row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }

  implementation: "IMPLEMENTATION LOGIC (engine_filter.go)" {
    direction: down
    style.fill: ${colors.code_bg}
    
    t1_code: {
      label: "T1: Selectivity Estimation"
      width: 450
      code: |'go
        func getSelectivity(p Predicate, s Stats) float64 {
            sample := s.GetMetadataSample(1000)
            matches := 0
            for _, m := range sample {
                if p.Eval(m) { matches++ }
            }
            return float64(matches) / 1000.0
        }
      '|
    }

    t2_code: {
      label: "T2: Strategy Selection"
      width: 450
      code: |'go
        func selectStrategy(sel float64) Strategy {
            if sel > 0.30 {
                return StrategyPreFilter
            }
            return StrategyPostFilter
        }
      '|
    }
  }

  nav_warning: "HNSW NAVIGABILITY CAVEAT" {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"

    msg: {
      label: |'md
        **THE NAVIGATION PROBLEM**
        Pre-filtering removes graph edges. 
        If the entry point or intermediate 
        bridges are filtered, HNSW search 
        terminates early.
        
        **FALLBACK:**
        Pre-filter typically executes 
        brute-force on the ID-set if 
        selectivity is high.
      '|
      style.stroke-width: 0
    }

    fallback_code: {
      label: "Pre-Filter Fallback (brute.go)"
      width: 400
      code: |'go
        func preFilterANN(q []float32, k int, ids []ID) {
            // If subset is small enough, brute force
            // is faster and more accurate than ANN
            return BruteForce(q, k, ids)
        }
      '|
    }
  }
}

legend: {
  near: bottom-right
  direction: right
  l1: "Pre-Filter" { style.fill: ${colors.prefilter} }
  l2: "Post-Filter" { style.fill: ${colors.postfilter} }
  l3: "Logic Control" { style.fill: ${colors.decision} }
}