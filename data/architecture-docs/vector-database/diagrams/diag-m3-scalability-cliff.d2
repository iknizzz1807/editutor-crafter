direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    green: "#22c55e"
    yellow: "#eab308"
    red: "#ef4444"
    gray: "#6b7280"
    blue: "#3b82f6"
    purple: "#8b5cf6"
  }
}

title_node: {
  label: |'md
    # Brute-Force Scalability: Where It Breaks
    ### Latency vs Dataset Size (k=10, 768 dimensions)
  '|
  shape: rectangle
  style: {
    stroke: transparent
    fill: transparent
    font-size: 20
  }
}

row_main: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  graph_container: {
    direction: down
    label: "Complexity Visualizer"
    style.fill: "#1e293b"
    style.stroke: "#334155"
    style.border-radius: 8
    
    y_axis: {
      label: |'md
        **Query Latency**
        (milliseconds)
      '|
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
    }
    
    grid_lines: {
      direction: down
      grid_10ms: {
        label: "10ms Line (SLA Target)"
        width: 600
        height: 2
        style.fill: ${colors.green}
        style.stroke: ${colors.green}
        style.opacity: 0.3
      }
      grid_100ms: {
        label: "100ms Line (Degraded)"
        width: 600
        height: 2
        style.fill: ${colors.yellow}
        style.stroke: ${colors.yellow}
        style.opacity: 0.3
      }
      grid_1000ms: {
        label: "1000ms Line (Unusable)"
        width: 600
        height: 2
        style.fill: ${colors.red}
        style.stroke: ${colors.red}
        style.opacity: 0.3
      }
    }
    
    x_axis: {
      label: "**Dataset Size (N vectors)**"
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
    }
  }
}

