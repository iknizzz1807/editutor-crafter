row_curve: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  curve_annotation: {
    label: |'md
      **O(N) Linear Growth**
      Each query computes distance to ALL N vectors.
      Computation cost doubles as dataset doubles.
    '|
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: ${colors.blue}
    style.font-color: white
    width: 350
  }
}

row_zones: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  zone_green: {
    direction: down
    label: "Interactive Zone"
    style.fill: ${colors.green}
    style.opacity: 0.2
    style.stroke: ${colors.green}
    style.border-radius: 4
    width: 220
    desc_green: {
      label: |'md
        - Sub-10ms latency
        - Real-time search
        - Brute-force is viable
      '|
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      style.font-color: ${colors.green}
    }
  }
  
  zone_yellow: {
    direction: down
    label: "Performance Degradation"
    style.fill: ${colors.yellow}
    style.opacity: 0.2
    style.stroke: ${colors.yellow}
    style.border-radius: 4
    width: 220
    desc_yellow: {
      label: |'md
        - 50ms - 500ms delay
        - Noticeable to users
        - Time to optimize
      '|
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      style.font-color: ${colors.yellow}
    }
  }
  
  zone_red: {
    direction: down
    label: "Scalability Cliff"
    style.fill: ${colors.red}
    style.opacity: 0.2
    style.stroke: ${colors.red}
    style.border-radius: 4
    width: 220
    desc_red: {
      label: |'md
        - >1000ms latency
        - Frequent timeouts
        - ANN Index Required
      '|
      shape: rectangle
      style.stroke: transparent
      style.fill: transparent
      style.font-color: ${colors.red}
    }
  }
}

row_why: "" {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  why_box: {
    label: |'md
      ## THE CASE FOR HNSW INDEXING
      | Scale | Brute-Force | HNSW (Estimated) | Speedup |
      |-------|-------------|------------------|---------|
      | 10K   | ~5ms        | ~1ms             | 5x      |
      | 100K  | ~50ms       | ~2ms             | 25x     |
      | 1M    | ~500ms      | ~5ms             | **100x** |
      | 10M   | >5000ms     | ~10ms            | **500x** |
      
      **HNSW Logic:** O(log N) vs O(N) Complexity.
    '|
    shape: rectangle
    style.fill: "#0f172a"
    style.stroke: ${colors.purple}
    style.stroke-width: 2
    style.border-radius: 8
    width: 550
  }
}

row_insight: "" {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  insight_box: {
    label: |'md
      ### Analysis: The Scalability Cliff
      Brute-force KNN has **linear complexity O(N)** because every query must calculate
      the distance to every single stored vector. While functional for small sets,
      this behavior creates a hard performance ceiling as datasets reach 1M+ vectors.
      
      **HNSW** (Hierarchical Navigable Small Worlds) solves this by building a graph
      of vectors where connections prioritize proximity. Traversal occurs through 
      hierarchical layers, reaching the neighborhood of the result in O(log N) steps.
    '|
    shape: rectangle
    style.fill: "#1e1b4b"
    style.stroke: ${colors.purple}
    style.border-radius: 8
    width: 650
  }
}

row_formula: "" {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  formula_box: {
    label: |'md
      **Brute-Force Latency Calculation:**
      `Latency = (N × d) / (Cores × Throughput)`
      - N: Vector Count
      - d: Dimensionality (768)
      - SIMD Throughput: ~1M Dot-Products/Sec
      
      *At 1M vectors, you must compute 768 million float operations per query.*
    '|
    shape: rectangle
    style.fill: "#1e293b"
    style.stroke: ${colors.gray}
    style.border-radius: 4
    width: 500
  }
}

# Cross-container connections with qualified IDs
row_zones.zone_green -> row_zones.zone_yellow: "Increased N" {
  style.stroke: ${colors.gray}
  style.stroke-dash: 3
}
row_zones.zone_yellow -> row_zones.zone_red: "Increased N" {
  style.stroke: ${colors.gray}
  style.stroke-dash: 3
}

row_data.zone_10k.point_10k -> row_data.zone_100k.point_100k: "O(N) Step" {
  style.stroke: ${colors.green}
  style.stroke-width: 2
}
row_data.zone_100k.point_100k -> row_data.zone_1m.point_1m: "Linear Growth" {
  style.stroke: ${colors.yellow}
  style.stroke-width: 2
}
row_data.zone_1m.point_1m -> row_data.zone_10m.point_10m: "CLIFF!" {
  style.stroke: ${colors.red}
  style.stroke-width: 4
  style.animated: true
}