direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------------------
# ROOT LEVEL COMPONENTS
# -----------------------------------------------------------------------------------------

title: {
  label: |'md
    # HNSW Parameter Tuning: efSearch Tradeoff Analysis
    *Optimization Guide for Vector Search Performance*
  '|
  near: top-center
}

# -----------------------------------------------------------------------------------------
# ROW 1: VISUAL PERFORMANCE CURVES
# -----------------------------------------------------------------------------------------

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  recall_performance: {
    direction: down
    label: "Recall@10 vs efSearch (Search Depth)"
    
    y_axis: "Metric: Recall Accuracy" { shape: parallelogram }
    
    graph_area: {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      
      ef10: "ef=10 | 0.72" { style.fill: "#FF5722"; style.font-color: white }
      ef25: "ef=25 | 0.85" { style.fill: "#FF9800"; style.font-color: white }
      ef50: "ef=50 | 0.91" { style.fill: "#4CAF50"; style.font-color: white }
      ef100: "ef=100 | 0.95" { style.fill: "#2196F3"; style.font-color: white }
      ef200: "ef=200 | 0.97" { style.fill: "#9C27B0"; style.font-color: white }
      ef500: "ef=500 | 0.99" { style.fill: "#607D8B"; style.font-color: white }
      
      ef10 -> ef25 -> ef50: "Steep Gain"
      ef50 -> ef100 -> ef200 -> ef500: "Plateau"
    }
    
    x_axis: "Parameter: efSearch (Size of Dynamic Candidate List)" { shape: parallelogram }
  }

  latency_performance: {
    direction: down
    label: "Query Latency vs efSearch"
    
    y_axis: "Metric: Latency (ms)" { shape: parallelogram }
    
    graph_area: {
      style.stroke: "#F44336"
      style.stroke-width: 2
      
      lat10: "ef=10 | 0.8ms" { style.fill: "#FF5722"; style.font-color: white }
      lat25: "ef=25 | 1.2ms" { style.fill: "#FF9800"; style.font-color: white }
      lat50: "ef=50 | 1.8ms" { style.fill: "#4CAF50"; style.font-color: white }
      lat100: "ef=100 | 3.2ms" { style.fill: "#2196F3"; style.font-color: white }
      lat200: "ef=200 | 6.5ms" { style.fill: "#9C27B0"; style.font-color: white }
      lat500: "ef=500 | 18ms" { style.fill: "#607D8B"; style.font-color: white }
      
      lat10 -> lat25 -> lat50 -> lat100 -> lat200 -> lat500: "Linear Growth O(efSearch)"
    }
    
    x_axis: "Parameter: efSearch" { shape: parallelogram }
  }
}

# -----------------------------------------------------------------------------------------
# ROW 2: PARAMETER DATA & INSIGHTS
# -----------------------------------------------------------------------------------------

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  tradeoff_guide: {
    label: "Engineering Reference: Parameter Selection"
    width: 550
    table: |'md
      | efSearch | Recall@10 | Latency | Implementation Context |
      |----------|-----------|---------|------------------------|
      | 10       | ~0.72     | 0.8ms   | High-throughput/Low Precision |
      | 25       | ~0.85     | 1.2ms   | Fast Approximate Search |
      | **50**   | **~0.91** | **1.8ms**| **Recommended Default** |
      | 100      | ~0.95     | 3.2ms   | Precision Critical |
      | 200      | ~0.97     | 6.5ms   | Accuracy over Speed |
      | 500      | ~0.99+    | 18ms    | Quality Benchmark only |
    '|
  }

  insights: {
    label: "Key Analysis Insights"
    direction: down
    
    sweet_spot: {
      label: "The efSearch [50, 100] Window"
      desc: |'md
        - Optimal balance for multi-tenant SaaS.
        - Recall curves flatten significantly after 100.
        - Computation cost increases linearly with every increment.
      '|
    }
    diminishing_returns: {
      label: "Efficiency Metrics"
      desc: |'md
        - **10 to 50**: +19% precision for 1ms cost.
        - **100 to 500**: +4% precision for 15ms cost.
        - *Recommendation*: Do not exceed 200 for production APIs.
      '|
    }
    
    sweet_spot -> diminishing_returns
  }
}

# -----------------------------------------------------------------------------------------
# ROW 3: IMPLEMENTATION LOGIC & RESOURCE IMPACT
# -----------------------------------------------------------------------------------------

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  implementation: {
    label: "Algorithm: efSearch Selection Logic"
    width: 500
    code: |'c
      // Logic for dynamic parameter adjustment
      int get_optimal_ef(float target_recall, int deadline_ms) {
          if (deadline_ms < 2) return 50;  // Latency cap
          
          if (target_recall > 0.98) return 200;
          if (target_recall > 0.94) return 100;
          if (target_recall > 0.89) return 50;  // Standard
          
          return 25; // High-speed fallback
      }
      
      // efSearch scale is per query
      search_request.params["ef"] = get_optimal_ef(0.95, 5);
    '|
  }

  memory_and_storage: {
    label: "Resource Impact Matrix"
    width: 450
    details: |'md
      ### Parameter Scope
      **efSearch** is a *Query-Time* parameter.
      - **Memory Impact**: 0 Bytes (Transient Queue only)
      - **Storage Impact**: 0 Bytes
      - **CPU Impact**: High (Linear)
      
      ### Index Build-Time Constants
      These parameters (not efSearch) control memory:
      - **M**: Max connections per node (Memory: O(M * N))
      - **efConstruction**: Quality of index build (Time: O(N log N))
    '|
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND & METADATA
# -----------------------------------------------------------------------------------------

legend: {
  label: "Diagram Legend"
  recall_indicator: "Recall Curve (Accuracy)" {
    style.fill: "#4CAF50"
    style.stroke: "#4CAF50"
  }
  latency_indicator: "Latency Curve (Speed)" {
    style.fill: "#F44336"
    style.stroke: "#F44336"
  }
  optimal_zone: "Production Sweet Spot (50-100)" {
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-dash: 4
  }
}

legend.near: bottom-right