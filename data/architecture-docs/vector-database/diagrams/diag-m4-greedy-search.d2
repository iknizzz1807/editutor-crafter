direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # HNSW Greedy Search with Layer Descent
  **Hierarchical traversal from entry point to base layer candidates**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phase1: {
    direction: down
    label: "Phase 1: Top Layer Descent"
    layer2_init: {
      label: "Layer 2 (Top)"
      style.fill: "#E8F4FD"
      style.stroke: "#2196F3"
      entry: {
        shape: circle
        label: "Entry\n(E)"
        style.fill: "#4CAF50"
        style.font-color: white
        style.stroke: "#388E3C"
      }
      n2a: {
        shape: circle
        label: "A"
        style.fill: "#BBDEFB"
      }
      n2b: {
        shape: circle
        label: "B"
        style.fill: "#BBDEFB"
      }
      entry -- n2a: {
        style.stroke: "#666"
        style.stroke-dash: 3
      }
      entry -- n2b: {
        style.stroke: "#666"
        style.stroke-dash: 3
      }
    }
    step1: {
      label: "Step 1: Greedy at L2"
      width: 280
      code: |'rust
        // Entry point is only node at L2
        // ef = 1 (just find closest)
        current = entry_point
        dist = distance(query, entry)
        candidates = [(entry, dist)]
      '|
    }
    layer1_descent: {
      label: "Layer 1"
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
      n1a: {
        shape: circle
        label: "A"
        style.fill: "#FFE0B2"
      }
      n1b: {
        shape: circle
        label: "B"
        style.fill: "#FFE0B2"
      }
      n1c: {
        shape: circle
        label: "C"
        style.fill: "#FFE0B2"
      }
      n1d: {
        shape: circle
        label: "D"
        style.fill: "#FFC107"
        style.stroke: "#FF8F00"
        style.stroke-width: 3
      }
      n1a -- n1b
      n1b -- n1c
      n1c -- n1d
      n1a -- n1d: {
        style.stroke-dash: 3
      }
    }
    step2: {
      label: "Step 2: Greedy at L1"
      width: 280
      code: |'rust
        // Descend to L1, start from entry's neighbors
        for neighbor in entry.neighbors(L1) {
          d = distance(query, neighbor)
          if d < best_dist {
            best = neighbor
          }
        }
        // D is closest → becomes entry for L0
      '|
    }
  }
  phase2: {
    direction: down
    label: "Phase 2: Base Layer Search"
    layer0_search: {
      label: "Layer 0 (Base)"
      style.fill: "#FCE4EC"
      style.stroke: "#E91E63"
      n0a: {
        shape: circle
        label: "A"
        style.fill: "#F8BBD9"
      }
      n0b: {
        shape: circle
        label: "B"
        style.fill: "#F8BBD9"
      }
      n0c: {
        shape: circle
        label: "C"
        style.fill: "#F8BBD9"
      }
      n0d: {
        shape: circle
        label: "D"
        style.fill: "#F8BBD9"
      }
      query: {
        shape: diamond
        label: "Q"
        style.fill: "#9C27B0"
        style.font-color: white
      }
      n0e: {
        shape: circle
        label: "E"
        style.fill: "#E91E63"
        style.font-color: white
        style.stroke: "#880E4F"
        style.stroke-width: 3
      }
      n0f: {
        shape: circle
        label: "F"
        style.fill: "#F8BBD9"
      }
      n0a -- n0b
      n0b -- n0c
      n0c -- n0d
      n0d -- query: {
        style.stroke: "#9C27B0"
        style.stroke-width: 2
      }
      n0d -- n0e
      n0e -- n0f
      n0a -- n0d: {
        style.stroke-dash: 3
      }
    }
    step3: {
      label: "Step 3: Expand at L0"
      width: 280
      code: |'rust
        // At L0, use efSearch candidates
        // Start from D (closest from L1)
        candidates = min_heap()
        results = max_heap(size=ef)
        candidates.push(D, dist(D,Q))
        while !candidates.empty() {
          c = candidates.pop_min()
          if c.dist > results.max().dist {
            break  // Pruning condition
          }
          explore_neighbors(c)
        }
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  queue_mgmt: {
    direction: down
    label: "Priority Queue Management"
    candidates_queue: {
      label: "Candidates (Min-Heap)"
      shape: class
      +push(node, dist): void
      +pop_min(): (node, dist)
      +peek_min(): (node, dist)
      +len(): usize
      -heap: BinaryHeap<Reverse>
    }
    results_queue: {
      label: "Results (Max-Heap)"
      shape: class
      +push(node, dist): void
      +pop_max(): (node, dist)
      +peek_max(): (node, dist)
      +len(): usize
      -heap: BinaryHeap
    }
    pruning: {
      label: "Pruning Condition"
      width: 300
      code: |'rust
        // Terminate when closest candidate
        // is farther than worst result
        if candidates.peek_min().dist 
           > results.peek_max().dist {
          break  // No better results possible
        }
      '|
    }
  }
  trace: {
    direction: down
    label: "Execution Trace"
    trace_table: {
      shape: sql_table
      label: "Search Trace (efSearch=3)"
      step: "Step | Layer | Action | Candidates | Results"
      s1: "1 | L2 | Start at E | [(E,0.8)] | [(E,0.8)]"
      s2: "2 | L1 | Explore A,B,C,D | [(D,0.3)] | [(D,0.3)]"
      s3: "3 | L0 | Start from D | [(D,0.3)] | [(D,0.3)]"
      s4: "4 | L0 | Add E (neighbor) | [(E,0.1)] | [(E,0.1),(D,0.3)]"
      s5: "5 | L0 | Add F (neighbor) | [(F,0.4)] | [(E,0.1),(D,0.3),(F,0.4)]"
      s6: "6 | L0 | Prune: 0.4>0.4 | [] | Top-3 found"
    }
    final: {
      label: "Final Results"
      width: 300
      code: |'rust
        // Return top-k from results heap
        return results.into_sorted_vec()
          .take(k)
          .collect();
        // [(E, 0.1), (D, 0.3), (F, 0.4)]
      '|
    }
  }
}
layer2_init.entry -> layer1_descent.n1d: "Descend\nclosest" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.animated: true
}
layer1_descent.n1d -> layer0_search.n0d: "Descend\nclosest" {
  style.stroke: "#FF9800"
  style.stroke-width: 2
  style.animated: true
}
layer0_search.n0d -> layer0_search.query: "Expand\nneighbors" {
  style.stroke: "#9C27B0"
  style.stroke-dash: 4
}
legend: {
  near: bottom-right
  legend_title: {
    label: "Legend"
    shape: rectangle
    style.fill: white
    style.stroke: "#666"
  }
  entry_node: {
    shape: circle
    label: "Entry Point"
    style.fill: "#4CAF50"
  }
  visited: {
    shape: circle
    label: "Visited"
    style.fill: "#FFC107"
  }
  result: {
    shape: circle
    label: "In Results"
    style.fill: "#E91E63"
  }
  query_node: {
    shape: diamond
    label: "Query"
    style.fill: "#9C27B0"
  }
}