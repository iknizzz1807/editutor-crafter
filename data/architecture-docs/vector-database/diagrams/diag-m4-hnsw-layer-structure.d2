            stroke-width: 1
          }
        }
        target: {
          label: "Q"
          shape: circle
          width: 22
          style: {
            fill: "#EF4444"
            stroke: "#B91C1C"
            stroke-width: 2
            font-color: white
            bold: true
          }
        }
        b17: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b18: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
      }
      b1 -- b2: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b2 -- b3: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b7 -- b8: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b8 -- b9: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b9 -- target: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b13 -- b14: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b14 -- b15: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b15 -- target: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      target -- b17: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b1 -- b7: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b6 -- b12: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
      b12 -- b18: {
        style.stroke: "#A855F7"
        style.stroke-width: 1
        style.opacity: 0.5
      }
