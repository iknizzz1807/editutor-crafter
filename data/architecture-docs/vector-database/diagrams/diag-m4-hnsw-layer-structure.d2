direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: HNSW Hierarchical Layer Structure {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_layers: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  layer_section: {
    direction: down
    layer3_container: {
      label: "Layer 3 (Top)"
      style: {
        fill: "#E8F4FD"
        stroke: "#2563EB"
        stroke-width: 2
        border-radius: 8
      }
      node_L3_A: {
        shape: circle
        style: {
          fill: "#3B82F6"
          stroke: "#1D4ED8"
          stroke-width: 2
          font-color: white
        }
      }
      node_L3_B: {
        shape: circle
        style: {
          fill: "#3B82F6"
          stroke: "#1D4ED8"
          stroke-width: 2
          font-color: white
        }
      }
      node_L3_A -- node_L3_B: {
        style: {
          stroke: "#3B82F6"
          stroke-width: 3
        }
      }
    }
    spacer3: {
      width: 20
      height: 30
      style.fill: transparent
      style.stroke: transparent
    }
    layer2_container: {
      label: "Layer 2"
      style: {
        fill: "#FEF3C7"
        stroke: "#D97706"
        stroke-width: 2
        border-radius: 8
      }
      row2a: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        node_L2_1: {
          shape: circle
          width: 40
          style: {
            fill: "#F59E0B"
            stroke: "#B45309"
            stroke-width: 2
            font-color: white
          }
        }
        node_L2_2: {
          shape: circle
          width: 40
          style: {
            fill: "#F59E0B"
            stroke: "#B45309"
            stroke-width: 2
            font-color: white
          }
        }
      }
      row2b: "" {
        direction: right
        style.stroke: transparent
        style.fill: transparent
        node_L2_3: {
          shape: circle
          width: 40
          style: {
            fill: "#F59E0B"
            stroke: "#B45309"
            stroke-width: 2
            font-color: white
          }
        }
        node_L2_4: {
          shape: circle
          width: 40
          style: {
            fill: "#F59E0B"
            stroke: "#B45309"
            stroke-width: 2
            font-color: white
          }
        }
      }
      node_L2_1 -- node_L2_2: {
        style.stroke: "#F59E0B"
        style.stroke-width: 2
      }
      node_L2_1 -- node_L2_3: {
        style.stroke: "#F59E0B"
        style.stroke-width: 2
      }
      node_L2_2 -- node_L2_4: {
        style.stroke: "#F59E0B"
        style.stroke-width: 2
      }
      node_L2_3 -- node_L2_4: {
        style.stroke: "#F59E0B"
        style.stroke-width: 2
      }
    }
    spacer2: {
      width: 20
      height: 30
      style.fill: transparent
      style.stroke: transparent
    }
    layer1_container: {
      label: "Layer 1"
      style: {
        fill: "#DCFCE7"
        stroke: "#16A34A"
        stroke-width: 2
        border-radius: 8
