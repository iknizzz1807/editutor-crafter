            stroke: "#15803D"
            stroke-width: 1
          }
        }
        node_L1_8: {
          shape: circle
          width: 30
          style: {
            fill: "#22C55E"
            stroke: "#15803D"
            stroke-width: 1
          }
        }
      }
      node_L1_1 -- node_L1_2: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_2 -- node_L1_3: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_3 -- node_L1_4: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_5 -- node_L1_6: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_6 -- node_L1_7: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_7 -- node_L1_8: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_1 -- node_L1_5: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
      node_L1_4 -- node_L1_8: {
        style.stroke: "#22C55E"
        style.stroke-width: 1
        style.opacity: 0.7
      }
    }
    spacer1: {
      width: 20
      height: 30
      style.fill: transparent
      style.stroke: transparent
    }
    layer0_container: {
      label: "Layer 0 (Base)"
      style: {
        fill: "#F3E8FF"
        stroke: "#9333EA"
        stroke-width: 2
        border-radius: 8
