      row1a: "" {
        direction: right
        grid-columns: 4
        grid-gap: 8
        style.stroke: transparent
        style.fill: transparent
        node_L1_1: {
          shape: circle
          width: 30
          style: {
            fill: "#22C55E"
            stroke: "#15803D"
            stroke-width: 1
          }
        }
        node_L1_2: {
          shape: circle
          width: 30
          style: {
            fill: "#22C55E"
            stroke: "#15803D"
            stroke-width: 1
          }
        }
        node_L1_3: {
          shape: circle
          width: 30
          style: {
            fill: "#22C55E"
            stroke: "#15803D"
            stroke-width: 1
          }
        }
        node_L1_4: {
          shape: circle
          width: 30
          style: {
            fill: "#22C55E"
            stroke: "#15803D"
            stroke-width: 1
          }
        }
      }
      row1b: "" {
        direction: right
        grid-columns: 4
        grid-gap: 8
        style.stroke: transparent
        style.fill: transparent
        node_L1_5: {
          shape: circle
          width: 30
          style: {
            fill: "#22C55E"
            stroke: "#15803D"
            stroke-width: 1
          }
        }
        node_L1_6: {
          shape: circle
          width: 30
          style: {
