  }
  info_section: {
    direction: down
    width: 320
    style: {
      fill: "#FAFAFA"
      stroke: "#E5E7EB"
      border-radius: 8
    }
    entry_point: {
      label: "Entry Point"
      width: 280
      code: |'c
        // Start at top layer
        // Node with highest level
        current = entry_point
      '|
      style: {
        fill: "#DBEAFE"
        stroke: "#3B82F6"
      }
    }
    descent: {
      label: "Greedy Descent"
      width: 280
      code: |'c
        // For each layer L to 1:
        //   Find nearest in layer L
        //   Move to next layer down
        while (layer > 0) {
          current = greedy_search(
            current, layer, ef=1
          )
          layer--
        }
      '|
      style: {
        fill: "#FEF3C7"
        stroke: "#D97706"
      }
    }
    base_search: {
      label: "Base Layer Search"
      width: 280
      code: |'c
        // At layer 0: full search
        // with efSearch candidates
        results = greedy_search(
          current, 0, ef=efSearch
        )
        return top_k(results)
      '|
      style: {
        fill: "#F3E8FF"
        stroke: "#9333EA"
      }
    }
    complexity: {
      label: "Complexity"
      shape: sql_table
      f1: "Nodes at Layer 3 | ~N / 8"
      f2: "Nodes at Layer 2 | ~N / 4"
      f3: "Nodes at Layer 1 | ~N / 2"
      f4: "Nodes at Layer 0 | N (all)"
      f5: "Search Time     | O(log N)"
    }
  }
}
layer_section.layer3_container.node_L3_A -> layer_section.layer2_container.node_L2_1: {
  label: "descend"
  style: {
    stroke: "#DC2626"
    stroke-width: 2
    stroke-dash: 4
  }
}
layer_section.layer2_container.node_L2_3 -> layer_section.layer1_container.node_L1_5: {
  style: {
    stroke: "#DC2626"
    stroke-width: 2
    stroke-dash: 4
  }
}
layer_section.layer1_container.node_L1_6 -> layer_section.layer0_container.target: {
  label: "to query"
  style: {
    stroke: "#DC2626"
    stroke-width: 2
    stroke-dash: 4
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#F9FAFB"
    stroke: "#D1D5DB"
    border-radius: 6
  }
  leg_title: {
    label: "Key"
    shape: text
    style: {
      bold: true
      font-size: 14
    }
  }
  ep: {
    label: "Entry Point"
    shape: circle
    width: 20
    style.fill: "#3B82F6"
  }
  q: {
    label: "Query Target"
    shape: circle
    width: 20
    style.fill: "#EF4444"
  }
  path: {
    label: "Descent Path"
    shape: rectangle
    width: 40
    height: 8
    style: {
      fill: "#DC2626"
      stroke-dash: 4
    }
  }
}
layer_section.node_L3_A.style.fill: "#DC2626"
layer_section.node_L3_A.style.stroke: "#991B1B"
layer_section.node_L3_A.label: "EP"
layer_section.node_L3_A.style.font-color: white