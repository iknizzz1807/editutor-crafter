      base_row1: "" {
        direction: right
        grid-columns: 6
        grid-gap: 6
        style.stroke: transparent
        style.fill: transparent
        b1: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b2: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b3: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b4: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b5: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b6: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
      }
      base_row2: "" {
        direction: right
        grid-columns: 6
        grid-gap: 6
        style.stroke: transparent
        style.fill: transparent
        b7: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b8: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b9: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b10: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b11: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b12: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
      }
      base_row3: "" {
        direction: right
        grid-columns: 6
        grid-gap: 6
        style.stroke: transparent
        style.fill: transparent
        b13: {
          shape: circle
          width: 22
          style: {
            fill: "#A855F7"
            stroke: "#7E22CE"
            stroke-width: 1
          }
        }
        b14: {
          shape: circle
