direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    formula-bg: "#E8F4F8"
    level-0: "#4CAF50"
    level-1: "#2196F3"
    level-2: "#FF9800"
    level-3: "#9C27B0"
    level-4: "#F44336"
    level-5: "#795548"
    header-bg: "#263238"
    card-bg: "#FFFFFF"
    accent: "#00BCD4"
  }
}
title: {
  label: "HNSW Probabilistic Level Assignment"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    font-color: "#1A237E"
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  formula_card: {
    style: {
      fill: ${colors.card-bg}
      stroke: "#90A4AE"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
    header: "Level Assignment Formula" {
      style: {
        fill: ${colors.header-bg}
        font-color: white
        font-size: 18
        bold: true
      }
    }
    formula_box: {
      style.fill: ${colors.formula-bg}
      style.border-radius: 4
      eq1: |latex
        \text{level} = \lfloor -\ln(\text{uniform}()) \times m_L \rfloor
      |
      spacer: ""
      eq2: |latex
        m_L = \frac{1}{\ln(M)}
      |
    }
    explanation: {
      style.fill: transparent
      style.font-size: 14
      line1: "• uniform() returns random value in (0, 1)"
      line2: "• M = max connections per node (default: 16)"
      line3: "• mL = 1/ln(16) ≈ 0.36"
      line4: ""
      line5: "Creates exponential distribution:"
      line6: "• Each level has ~1/e fewer nodes"
      line7: "• Higher layers = fewer nodes"
    }
  }
  skip_list_card: {
    style: {
      fill: ${colors.card-bg}
      stroke: "#90A4AE"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
    header: "Skip List Analogy" {
      style: {
        fill: ${colors.header-bg}
        font-color: white
        font-size: 18
        bold: true
      }
    }
    skip_visual: {
      style.fill: transparent
      layer4: "Layer 4:    ●───────────────────────────●" {
        style: {
          font: mono
          font-color: ${colors.level-4}
        }
      }
      layer3: "Layer 3:    ●───────────●───────────●───●" {
        style: {
          font: mono
          font-color: ${colors.level-3}
        }
      }
      layer2: "Layer 2:    ●───────●───●───────●───●───●" {
        style: {
          font: mono
          font-color: ${colors.level-2}
        }
      }
      layer1: "Layer 1:    ●───●───●───●───●───●───●───●" {
        style: {
          font: mono
          font-color: ${colors.level-1}
        }
      }
      layer0: "Layer 0:    ●─●─●─●─●─●─●─●─●─●─●─●─●─●─●─●" {
        style: {
          font: mono
          font-color: ${colors.level-0}
        }
      }
      note: "Each node 'promoted' to higher layers\nwith probability 1/e ≈ 36.8%" {
        style: {
          font-size: 13
          italic: true
          font-color: "#616161"
        }
      }
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  distribution_card: {
    style: {
      fill: ${colors.card-bg}
      stroke: "#90A4AE"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
    width: 500
    header: "Probability Distribution (M=16, mL=0.36)" {
      style: {
        fill: ${colors.header-bg}
        font-color: white
        font-size: 18
        bold: true
      }
    }
    prob_table: {
      shape: sql_table
      label: "Level Probability Table"
      l0: "0 | 63.2% | P(0) = 1 - 1/e"
      l1: "1 | 23.3% | P(1) = 1/e - 1/e²"
      l2: "2 | 8.6%  | P(2) = 1/e² - 1/e³"
      l3: "3 | 3.1%  | P(3) = 1/e³ - 1/e⁴"
      l4: "4 | 1.2%  | P(4) = 1/e⁴ - 1/e⁵"
      l5: "5+ | 0.6% | Higher levels"
    }
    formula_note: |latex
      P(\text{level} \geq k) = e^{-k \cdot m_L}
    | {
      style: {
        font-size: 14
      }
    }
  }
  histogram_card: {
    style: {
      fill: ${colors.card-bg}
      stroke: "#90A4AE"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
    width: 450
    header: "Expected Node Counts (100K vectors, M=16)" {
      style: {
        fill: ${colors.header-bg}
        font-color: white
        font-size: 18
        bold: true
      }
    }
    hist: {
      style.fill: transparent
      bar0: "████████████████████████████████████████████ 63,212" {
        style: {
          font: mono
          font-color: ${colors.level-0}
        }
      }
      bar1: "████████████████ 23,255" {
        style: {
          font: mono
          font-color: ${colors.level-1}
        }
      }
      bar2: "██████ 8,555" {
        style: {
          font: mono
          font-color: ${colors.level-2}
        }
      }
      bar3: "███ 3,151" {
        style: {
          font: mono
          font-color: ${colors.level-3}
        }
      }
      bar4: "█ 1,160" {
        style: {
          font: mono
          font-color: ${colors.level-4}
        }
      }
      bar5: "▌ 427" {
        style: {
          font: mono
          font-color: ${colors.level-5}
        }
      }
      legend: "Each █ ≈ 1,500 nodes" {
        style: {
          font-size: 12
          italic: true
          font-color: "#757575"
        }
      }
    }
    stats: {
      style: {
        fill: "#F5F5F5"
        border-radius: 4
        font-size: 13
      }
      stat1: "Expected max level: ⌊ln(N) / ln(M)⌋ ≈ 4"
      stat2: "Avg connections per node: 1/(1-e⁻¹) ≈ 1.58 layers"
      stat3: "Top layer: entry point for search"
    }
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  code_card: {
    style: {
      fill: ${colors.card-bg}
      stroke: "#90A4AE"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
    header: "Rust Implementation" {
      style: {
        fill: ${colors.header-bg}
        font-color: white
        font-size: 18
        bold: true
      }
    }
    code: |'rust
      fn assign_layer(m: usize, rng: &mut impl Rng) -> usize {
          let ml = 1.0 / (m as f64).ln();  // mL = 1/ln(M)
          let uniform: f64 = rng.gen();     // random in (0, 1)
          let level = (-uniform.ln() * ml).floor() as usize;
          level
      }
      // Example: M=16, mL=0.36
      // uniform=0.5  → level = floor(-ln(0.5) × 0.36) = 0
      // uniform=0.1  → level = floor(-ln(0.1) × 0.36) = 0
      // uniform=0.01 → level = floor(-ln(0.01) × 0.36) = 1
    '|
  }
  key_insight: {
    style: {
      fill: "#FFF8E1"
      stroke: "#FFB300"
      stroke-width: 2
      border-radius: 8
    }
    insight_header: "🔑 Key Insight" {
      style: {
        font-size: 16
        bold: true
        font-color: "#FF6F00"
      }
    }
    insight_text: {
      style.fill: transparent
      line1: "The exponential distribution ensures:"
      line2: ""
      line3: "• O(log N) expected search time"
      line4: "• Each layer prunes search space by ~1/e"
      line5: "• Similar to skip list promotion"
      line6: ""
      line7: "Randomness replaces complex rebalancing!"
    }
  }
}
formula_card -> distribution_card: "produces" {
  style.stroke-dash: 3
  style.stroke: "#90A4AE"
}
distribution_card -> histogram_card: "applied to" {
  style.stroke-dash: 3
  style.stroke: "#90A4AE"
}
skip_list_card -> distribution_card: "same principle" {
  style.stroke-dash: 3
  style.stroke: "#90A4AE"
}