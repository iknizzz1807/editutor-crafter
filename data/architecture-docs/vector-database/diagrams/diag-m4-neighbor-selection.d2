row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  heuristic_logic: {
    label: "Heuristic Algorithm (diversity filter)"
    width: 420
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    code: |'rust
      fn select_neighbors_heuristic(
        candidates: &[Candidate],
        m: usize,
      ) -> Vec<NodeId> {
        let mut selected: Vec<NodeId> = Vec::new();
        for candidate in candidates.sorted_by_distance() {
          // Check if candidate is closer to query
          // than to any already-selected neighbor
          let is_diverse = selected.iter().all(|&s| {
            let dist_to_selected = distance(candidate, s);
            dist_to_selected >= candidate.dist_to_query
          });
          if is_diverse {
            selected.push(candidate.id);
            if selected.len() >= m { break; }
          }
        }
        selected
      }
    '|
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cluster_problem: {
    label: "Problem: Clustered Neighbors"
    direction: down
    style.fill: "#fef2f2"
    style.stroke: "#ef4444"
    cluster_query: {
      shape: circle
      label: "Q"
      style.fill: "#3b82f6"
      style.font-color: white
    }
    cluster_group: {
      label: ""
      direction: right
      style.fill: transparent
      style.stroke: transparent
      cluster_a: {
        shape: circle
        label: "A"
        style.fill: "#22c55e"
        style.font-color: white
        width: 30
      }
      cluster_b: {
        shape: circle
        label: "B"
        style.fill: "#22c55e"
        style.font-color: white
        width: 30
      }
      cluster_c: {
        shape: circle
        label: "C"
        style.fill: "#22c55e"
        style.font-color: white
        width: 30
      }
    }
    far_node: {
      shape: circle
      label: "D"
      style.fill: "#f59e0b"
      style.font-color: white
    }
    cluster_query -> cluster_group: "0.1-0.2"
    cluster_query -> far_node: "0.3"
    cluster_group -> cluster_group: {
      style.stroke: "#22c55e"
      style.stroke-dash: 2
      label: "very close"
    }
    note: |md
      **Simple**: A, B, C selected (all clustered)
      **Heuristic**: A, D selected (diverse directions)
      Clustered neighbors limit graph reachability
    |
  }
  impact_metrics: {
    label: "Impact on Recall & Navigability"
    direction: down
    style.fill: "#f0fdf4"
    style.stroke: "#22c55e"
    metrics: {
      shape: sql_table
      label: "Recall Comparison (100K vectors, M=16)"
      m1: "Metric | Simple | Heuristic"
      m2: "Recall@10 | 0.87 | 0.94"
      m3: "Recall@100 | 0.92 | 0.97"
      m4: "Avg hops | 12.3 | 8.7"
      m5: "Dead ends | 2.1% | 0.3%"
    }
    insight: |md
      **Key Insight:**
      Simple selection creates "local traps" where
      greedy search cannot escape clustered regions.
      Heuristic maintains long-range connections
      that enable navigation across the graph.
    |
  }
}
