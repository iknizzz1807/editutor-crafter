direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: "HNSW Index Serialization Format (hnsw.idx)"
  style.font-size: 32
  style.bold: true
}

# ROW 1: BINARY SPECIFICATION
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  binary_spec: "Binary File Layout Specification" {
    direction: right
    style.fill: "#F8F9FA"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    header: {
      shape: sql_table
      label: "struct FileHeader (hnsw_io.rs)"
      magic: "0x00 | [u8; 8] | magic: b'HNSWIDX1'"
      ver: "0x08 | u32     | version: 1"
      m: "0x0C | u32     | m: Max connections"
      m0: "0x10 | u32     | m_max0: Layer 0 connections"
      efc: "0x14 | u32     | ef_construction"
      efs: "0x18 | u32     | ef_search_default"
      mult: "0x1C | f64     | level_multiplier"
      cnt: "0x24 | u64     | total_node_count"
      max_l: "0x2C | u32     | highest_layer"
      ep_id: "0x30 | u64     | entry_point_id"
      metric: "0x38 | u32     | metric_type (0=L2, 1=IP)"
      res: "0x3C | u32     | reserved_padding"
      total: "Size: 64 bytes"
    }

    layer_registry: {
      label: "Layer-to-Node Maps"
      style.fill: "#FFF9C4"
      
      l_top: {
        shape: sql_table
        label: "Layer N Section"
        n: "0x00 | u32      | node_count"
        ids: "0x04 | [u64; n] | member_node_ids"
      }
      
      l_base: {
        shape: sql_table
        label: "Layer 0 Section (Base)"
        n: "0x00 | u32      | node_count"
        ids: "0x04 | [u64; n] | all_node_ids"
      }
    }

    edge_data: {
      label: "Adjacency List Blocks"
      style.fill: "#E8F5E9"

      node_block: {
        shape: sql_table
        label: "NodeAdjacencyEntry"
        id: "0x00 | u64 | vector_id"
        ml: "0x08 | u32 | max_layer_attained"
        l0: "0x0C | u32 | layer0_edge_count"
        e0: "0x10 | [u64; m0] | layer0_neighbors"
        l1: "VAR  | u32 | layer1_edge_count"
        e1: "VAR  | [u64; m] | layer1_neighbors"
        rem: "VAR  | struct | Repeating layers"
      }
    }

    header -> layer_registry: "64B Offset"
    layer_registry -> edge_data: "Map | locate"
  }
}

# ROW 2: IO LIFECYCLE
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  serialization: "Save Process (Memory -> Disk)" {
    direction: right
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"

    mem_index: {
      shape: class
      label: "HNSWIndex (RAM)"
      -nodes: "HashMap<u64, Box<Node>>"
      -entry_point: "u64"
      -max_level: "usize"
      +save_to_file(path): "Result"
    }

    write_buffer: {
      label: "BufWriter | encode"
      style.fill: "#E91E63"
      style.font-color: white
    }

    disk_file: {
      shape: document
      label: "hnsw.idx"
      style.fill: "#BBDEFB"
    }

    mem_index -> write_buffer: "Serialize"
    write_buffer -> disk_file: "binary stream"
  }

  deserialization: "Load Process (Disk -> Memory)" {
    direction: right
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"

    disk_input: {
      shape: document
      label: "hnsw.idx"
      style.fill: "#BBDEFB"
    }

    read_logic: {
      label: "MmapReader | decode"
      style.fill: "#1976D2"
      style.font-color: white
    }

    restored_index: {
      shape: class
      label: "HNSWIndex (RAM)"
      -nodes: "HashMap<u64, Box<Node>>"
      -entry_point: "u64"
      +load_from_file(path): "Self"
    }

    disk_input -> read_logic: "bytes"
    read_logic -> restored_index: "Reconstruct"
  }
}

# ROW 3: ADVANCED TOPICS & QA
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  incremental: "Large Index Management" {
    direction: right
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"

    chunks: "Chunked Write Logic" {
      direction: right
      c1: "Chunk: Headers" { style.fill: "#C5CAE9" }
      c2: "Chunk: Nodes" { style.fill: "#C8E6C9" }
      c3: "Chunk: Edges" { style.fill: "#FFCCBC" }
    }

    streaming: {
      label: "O_DIRECT | Write"
      style.fill: "#9C27B0"
      style.font-color: white
    }

    final_file: "Large Index File" {
      shape: cylinder
    }

    chunks -> streaming: "128MB Pages"
    streaming -> final_file: "Direct IO"
  }

  verification: "Data Integrity Verification" {
    direction: right
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"

    checksum_step: {
      shape: sql_table
      label: "struct Footer"
      crc: "0x00 | u64 | crc64_checksum"
      magic: "0x08 | u64 | EOF_MAGIC"
    }

    validation_logic: {
      label: "Integrity Check"
      style.stroke-dash: 4
    }

    success: "VALID INDEX" {
      style.fill: "#4CAF50"
      style.font-color: white
    }

    checksum_step -> validation_logic: "CRC64 | parity"
    validation_logic -> success: "Verified"
  }
}

legend: {
  label: "Implementation Memory Map (M=16, 768d)"
  style.fill: "#F5F5F5"
  row1: "Small Index (100K): ~13.2 MB on disk"
  row2: "Medium Index (1M): ~132 MB on disk"
  row3: "Large Index (10M): ~1.3 GB on disk"
  row4: "Disk Format Overhead: < 1% total"
}
legend.near: bottom-right

# Global Relationships
row1 -> row2: "Read/Write | protocol"
row2 -> row3: "Extended | features"