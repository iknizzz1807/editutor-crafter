      style.stroke-width: 2
      time_1m_hnsw: |md
        **~5ms**
        Graph traversal
        ~600 hops
        ✓ Log(N) scaling
      |
    }
    speedup_1m: {
      label: "100x faster"
      shape: oval
      style.fill: "#FFF9C4"
      style.stroke: "#FBC02D"
      style.stroke-width: 2
