}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scale_1m: {
    direction: down
    label: "1M Vectors"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    style.stroke-width: 2
    bf_1m: {
      label: "Brute-Force"
      shape: rectangle
      width: 180
      height: 160
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      style.stroke-width: 3
      time_1m_bf: |md
        **~500ms**
        Linear scan
        1,000,000 distances
        ⚠️ Scalability cliff
      |
    }
    hnsw_1m: {
      label: "HNSW"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
