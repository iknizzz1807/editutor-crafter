direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # HNSW vs Brute-Force: Latency Comparison
  **The scalability cliff where approximation wins**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  scale_10k: {
    direction: down
    label: "10K Vectors"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    bf_10k: {
      label: "Brute-Force"
      shape: rectangle
      width: 180
      style.fill: "#FFCDD2"
      style.stroke: "#E53935"
      style.stroke-width: 2
      time_10k_bf: |md
        **~5ms**
        Linear scan
        10,000 distances
      |
    }
    hnsw_10k: {
      label: "HNSW"
      shape: rectangle
      width: 180
      style.fill: "#C8E6C9"
      style.stroke: "#43A047"
      style.stroke-width: 2
      time_10k_hnsw: |md
        **~1ms**
        Graph traversal
        ~200 hops
      |
    }
    speedup_10k: {
      label: "5x faster"
      shape: oval
      style.fill: "#FFF9C4"
      style.stroke: "#FBC02D"
    }
  }
}
