  }
}
scale_10k.bf_10k -> scale_100k.bf_100k: "10x data\n= 10x time" {
  style.stroke: "#E53935"
  style.stroke-width: 3
  style.stroke-dash: 4
}
scale_100k.bf_100k -> scale_1m.bf_1m: "10x data\n= 10x time" {
  style.stroke: "#E53935"
  style.stroke-width: 3
  style.stroke-dash: 4
}
scale_10k.hnsw_10k -> scale_100k.hnsw_100k: "10x data\n≈ 2x time" {
  style.stroke: "#43A047"
  style.stroke-width: 2
}
scale_100k.hnsw_100k -> scale_1m.hnsw_1m: "10x data\n≈ 2.5x time" {
  style.stroke: "#43A047"
  style.stroke-width: 2
}
recall_box: {
  label: "Recall Tradeoff"
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
  style.stroke-width: 2
  recall_table: {
    shape: sql_table
    label: "Recall@10 (768d, efSearch=100)"
    r1: "Algorithm | Recall | Latency @ 1M"
    r2: "Brute-Force | 1.00 (100%) | ~500ms"
    r3: "HNSW | 0.95 (95%) | ~5ms"
    r4: "HNSW+PQ | 0.92 (92%) | ~3ms"
  }
  insight: |md
    **Key insight**: HNSW trades 5% recall
    for 100x latency improvement.
    For most applications, 95% recall is
    indistinguishable from perfect recall.
  |
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: "#E0E0E0"
  bf_legend: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  bf_label: "Brute-Force O(N)"
  hnsw_legend: {
    shape: rectangle
    width: 20
    height: 20
    style.fill: "#C8E6C9"
    style.stroke: "#43A047"
  }
  hnsw_label: "HNSW O(log N)"
}
complexity_box: {
  label: "Complexity Analysis"
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  formula: |md
    **Brute-Force**: O(N × d) per query
    - N = number of vectors
    - d = dimensionality (768)
    - Latency scales linearly with N
    **HNSW**: O(log N × M × d) per query
    - M = max connections (16)
    - log N layers to traverse
    - Latency scales logarithmically with N
  |
}
scale_1m -> recall_box
recall_box -> complexity_box