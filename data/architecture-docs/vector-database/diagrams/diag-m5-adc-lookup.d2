direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STYLES & CLASSES ---
classes: {
  row_container: {
    style: {
      stroke: transparent
      fill: transparent
    }
  }
  quantized_node: {
    style: {
      fill: "#FCE4EC"
      stroke: "#880E4F"
    }
  }
  float_node: {
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
  }
}

# --- DIAGRAM CONTENT ---

header: {
  label: "Asymmetric Distance Computation (ADC) Architecture"
  style: {
    font-size: 24
    bold: true
    fill: transparent
    stroke: transparent
  }
}

row1: "" {
  class: row_container
  direction: right
  
  query_vec: {
    shape: class
    label: "Query Vector q (float32)"
    +dimensions: "768-dim"
    +type: "Full Precision"
    +storage: "3072 bytes"
  }

  split_op: "Split into M=8 subvectors" {
    style.stroke-dash: 3
  }

  sub_vectors: "Sub-vectors (q⁰...q⁷)" {
    direction: right
    style.fill: "#E3F2FD"
    
    sv0: "q⁰: 96-dim" { style.fill: "#BBDEFB" }
    sv1: "q¹: 96-dim" { style.fill: "#BBDEFB" }
    sv_dot: "..." { style.fill: transparent; style.stroke: transparent }
    sv7: "q⁷: 96-dim" { style.fill: "#BBDEFB" }
  }

  query_vec -> sub_vectors: "Decompose"
}

row2: "" {
  class: row_container
  direction: right

  codebooks: "Pre-trained Codebooks (C)" {
    direction: right
    style.fill: "#FFF3E0"
    
    cb0: "Codebook 0" {
      shape: cylinder
      label: "256 centroids\n(k-means)"
    }
    cb1: "Codebook 1" {
      shape: cylinder
    }
    cb_dot: "..." { style.fill: transparent; style.stroke: transparent }
    cb7: "Codebook 7" {
      shape: cylinder
    }
  }
}

row1.sub_vectors -> row2.codebooks: "L2 Distance | Precompute"

row3: "" {
  class: row_container
  direction: right

  lut: "Lookup Table (LUT)" {
    direction: right
    label: "LUT (M × 256 distances)"
    style.fill: "#E8F5E9"
    
    lut0: {
      shape: sql_table
      label: "LUT[0] (distances to centroids 0..255)"
      r0: "0x00 | d(q⁰, c₀⁰)"
      r1: "0x04 | d(q⁰, c₁⁰)"
      r_dot: "... | ..."
      r255: "0xFF | d(q⁰, c₂₅₅⁰)"
    }
    lut_dot: "..." { style.fill: transparent; style.stroke: transparent }
    lut7: {
      shape: sql_table
      label: "LUT[7]"
      r0: "0x00 | d(q⁷, c₀⁷)"
      r_dot: "... | ..."
    }
  }
}

row2.codebooks -> row3.lut: "M x 256 floats"

row4: "" {
  class: row_container
  direction: right

  stored_pq: {
    shape: sql_table
    label: "Stored PQ Vector (x)"
    style.fill: "#FCE4EC"
    byte0: "0 | uint8 | code[0]"
    byte1: "1 | uint8 | code[1]"
    byte_dot: "... | ... | ..."
    byte7: "7 | uint8 | code[7]"
    total: "Total: 8 bytes"
  }

  compute_engine: {
    label: "Approximate Distance Summation"
    proc: |md
      **Distance Formula:**
      $d(q, x) \approx \sum_{m=0}^{M-1} LUT[m][code[m]]$
      
      **Example Calculation:**
      $LUT[0][code_0] + LUT[1][code_1] + \dots$
    |
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
  }
}

row3.lut -> row4.compute_engine: "Table Access"
row4.stored_pq -> row4.compute_engine: "Indices"

comparison_block: "Performance Analysis" {
  direction: right
  style.fill: "#F5F5F5"
  
  naive_path: {
    label: "Naive Symmetric Distance"
    style.fill: "#FFCDD2"
    procedure_info: |md
      1. Decompress 8 codes -> 768 floats
      2. Compute full L2 distance
      **Complexity: O(d) ops**
    |
  }

  adc_path: {
    label: "Asymmetric Distance (ADC)"
    style.fill: "#C8E6C9"
    procedure_info: |md
      1. 1x Precompute LUT (M*256)
      2. M Lookups + M-1 Additions
      **Complexity: O(M) lookups**
    |
  }
  
  efficiency: {
    label: "Result"
    style.fill: "#B3E5FC"
    stats: |md
      **96x Reduction in Compute**
      768 float ops -> 8 lookups
    |
  }
}

row4.compute_engine -> comparison_block: "Evaluation"

legend: {
  label: "Core Architecture Insight"
  near: bottom-right
  insight: |md
    **ADC Principle:**
    The query $q$ stays in full precision (float32).
    Only stored database vectors $x$ are quantized.
    This avoids quantization error on the query and
    enables the high-speed LUT scan.
  |
  style.fill: "#FFF8E1"
}

# --- CONNECTIONS ---
row1.sub_vectors -> row2.codebooks: "Compute LUT"
row3.lut -> row4.compute_engine: "Lookup"
naive_path -> adc_path: "vs" { style.stroke-dash: 3 }