direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    pq: "#E8D5B7"
    exact: "#B5E8B5"
    query: "#B5D8E8"
    result: "#D8B5E8"
    candidate: "#FFE4B5"
  }
}

title_node: {
  label: |md
    # HNSW + PQ Two-Phase Search
    **Phase 1:** Fast approximate search (HNSW + Quantized)
    **Phase 2:** Exact re-ranking (Full precision fetch)
  |
  style.stroke: transparent
  style.fill: transparent
}
title_node.near: top-center

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  query_box: {
    label: "Input Context"
    style.fill: ${colors.query}
    query_data: {
      shape: sql_table
      label: "Query Vector (float32)"
      d1: "0x00 | float[768] | embedding"
      sz: "Size: 3072 bytes (3KB)"
    }
  }

  phase1: {
    label: "Phase 1: Traversal & Quantized Distance"
    style.fill: ${colors.pq}
    
    hnsw_logic: {
      label: "HNSW Graph Walk"
      l2: "Layer 2 (Top)"
      l1: "Layer 1"
      l0: "Layer 0 (Base)"
      l2 -> l1: "Descend"
      l1 -> l0: "Local Search"
    }

    pq_lookup: {
      shape: sql_table
      label: "PQ Distance (ADC)"
      m0: "M=0 | Lookup 256 bits"
      m1: "M=1 | Lookup 256 bits"
      dots: "..."
      m7: "M=7 | Lookup 256 bits"
      ops: "Cost: 8 LUT + 7 adds"
    }
    hnsw_logic -> pq_lookup: "node evaluation"
  }

  candidates: {
    label: "Candidate Heap"
    style.fill: ${colors.candidate}
    cand_table: {
      shape: sql_table
      label: "Top-100 (PQ Dist)"
      c1: "ID: 42 | d=0.082"
      c2: "ID: 17 | d=0.091"
      c3: "ID: 89 | d=0.095"
      dots: "..."
      c100: "ID: 31 | d=0.234"
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  rerank_action: "Rerank Logic" {
    shape: parallelogram
    label: "Fetch Full Vectors | Rerank_K=100"
    style.fill: "#EEEEEE"
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  phase2: {
    label: "Phase 2: High-Precision Reranking"
    style.fill: ${colors.exact}
    
    exact_compute: {
      shape: sql_table
      label: "Exact Compute Core"
      f1: "Fetch: Disk/Flash Full Vec"
      f2: "Math: 768-dim L2 Distance"
      f3: "Simd: AVX-512 Optimized"
      cost: "Total: 100 x 768 Ops"
    }
  }

  results: {
    label: "Final Result Set"
    style.fill: ${colors.result}
    result_table: {
      shape: sql_table
      label: "Top-10 (Exact)"
      r1: "ID: 17 | d=0.078"
      r2: "ID: 89 | d=0.089"
      r3: "ID: 42 | d=0.091"
      note: "Note: ID 17 Corrected to #1"
    }
  }
}

# High-level data flow
row1.query_box -> row1.phase1: "Query"
row1.phase1 -> row1.candidates: "100 Nodes"
row1.candidates -> row2.rerank_action: "ID List"
row2.rerank_action -> row3.phase2: "Full Vectors"
row3.phase2 -> row3.results: "Re-ordered Top-10"

legend: {
  label: "Legend"
  direction: right
  l1: "PQ Approximate"; l1.style.fill: ${colors.pq}
  l2: "Exact Precision"; l2.style.fill: ${colors.exact}
  l3: "Final Output"; l3.style.fill: ${colors.result}
}
legend.near: bottom-center

params: {
  label: "Hyper-Parameters"
  config: {
    shape: sql_table
    label: "Search Tuning"
    k: "Final K: 10"
    rk: "Rerank K: 100"
    ef: "efSearch: 128"
    ov: "Oversample: 10x"
  }
}
params.near: bottom-right

flow_summary: {
  label: "Implementation Notes"
  summary: |md
    **Search Efficiency:**
    - **PQ Phase:** Eliminates 99.9% of candidates using quantized lookups.
    - **Exact Phase:** Refines final ranking to recover recall lost in quantization.
    - **Latencies:** Phase 1 (~5ms) >> Phase 2 (~0.5ms).
  |
}
flow_summary.near: bottom-left