direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Usage: FP32 vs SQ8 vs PQ
  ### 1M vectors × 768 dimensions
| {near: top-center}
row_bars: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fp32: {
    direction: down
    label: "FP32"
    style.fill: "#E8E8E8"
    width: 600
    height: 400
    bar_fp32: {
      label: "3,072 MB (3 GB)"
      shape: rectangle
      width: 550
      height: 350
      style: {
        fill: "#4A90D9"
        stroke: "#2E5A8A"
        stroke-width: 2
        font-color: white
        font-size: 18
        bold: true
      }
    }
    recall_fp32: {
      label: "Recall@10: 1.00"
      style: {
        fill: "#2E5A8A"
        font-color: white
        border-radius: 4
      }
    }
  }
  sq8: {
    direction: down
    label: "SQ8"
    style.fill: "#E8E8E8"
    width: 200
    height: 400
    bar_sq8: {
      label: "768 MB"
      shape: rectangle
      width: 87
      height: 87
      style: {
        fill: "#5CB85C"
        stroke: "#3D8B3D"
        stroke-width: 2
        font-color: white
        font-size: 14
        bold: true
      }
    }
    recall_sq8: {
      label: "Recall@10: 0.92"
      style: {
        fill: "#3D8B3D"
        font-color: white
        border-radius: 4
      }
    }
  }
  pq: {
    direction: down
    label: "PQ (M=48)"
    style.fill: "#E8E8E8"
    width: 100
    height: 400
    bar_pq: {
      label: "48 MB"
      shape: rectangle
      width: 12
      height: 12
      style: {
        fill: "#F0AD4E"
        stroke: "#C87F0A"
        stroke-width: 2
        font-color: "#333"
        font-size: 12
        bold: true
      }
    }
    recall_pq: {
      label: "Recall@10: 0.85"
      style: {
        fill: "#C87F0A"
        font-color: white
        border-radius: 4
      }
    }
  }
}
compression_table: {
  shape: sql_table
  label: "Compression Analysis (1M × 768d vectors)"
  storage: "Storage | Bytes/Vector | Total | Compression | Recall@10"
  fp32_row: "FP32 | 3,072 | 3,072 MB | 1× (baseline) | 1.00"
  sq8_row: "SQ8 | 768 | 768 MB | 4× | 0.92"
  pq_row: "PQ (M=48) | 48 | 48 MB | 64× | 0.85"
  style: {
    fill: "#F5F5F5"
    stroke: "#CCCCCC"
  }
}
legend: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  legend_title: {
    label: "Memory-Accuracy Tradeoff"
    style: {
      font-size: 16
      bold: true
      underline: true
    }
  }
  legend_fp32: {
    label: "■ FP32: Full precision, no accuracy loss"
    style.fill: transparent
    style.font-color: "#4A90D9"
  }
  legend_sq8: {
    label: "■ SQ8: 4× compression, 8% recall loss"
    style.fill: transparent
    style.font-color: "#5CB85C"
  }
  legend_pq: {
    label: "■ PQ: 64× compression, 15% recall loss"
    style.fill: transparent
    style.font-color: "#F0AD4E"
  }
  legend_note: {
    label: "PQ M=48: 48 subspaces × 1 byte = 48 bytes/vector"
    style: {
      fill: "#FFF9E6"
      stroke: "#F0AD4E"
      font: mono
      font-size: 11
    }
  }
}
formula_box: {
  label: "Memory Formula"
  code: |'c
    // Per-vector memory (768 dimensions)
    FP32: 768 × 4 bytes = 3,072 bytes
    SQ8:  768 × 1 byte  =   768 bytes  (4× reduction)
    PQ:   48 × 1 byte   =    48 bytes  (64× reduction)
    // For 1M vectors
    FP32: 3,072 bytes × 1,000,000 = 3,072 MB
    SQ8:    768 bytes × 1,000,000 =   768 MB
    PQ:      48 bytes × 1,000,000 =    48 MB
  '|
  style: {
    fill: "#F0F0F0"
    stroke: "#999999"
    font: mono
    font-size: 12
  }
  width: 380
}
insight_box: {
  label: "Key Insight"
  code: |md
    **64× compression** enables searching **100M vectors** on a single 64GB server that could only hold **~20M** vectors at FP32 precision.
    Trade-off: PQ's 15% recall loss is often acceptable for applications where **speed and scale** matter more than perfect ranking.
  |
  style: {
    fill: "#E8F4E8"
    stroke: "#5CB85C"
    stroke-width: 2
  }
  width: 400
}
row_bars -> compression_table: "visual comparison | tabular data"
compression_table -> legend
legend -> formula_box
formula_box -> insight_box