direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Product Quantization: Subspace Decomposition
| {near: top-center}
row_original: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  original_label: "Original Vector" {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      font-color: "#1565C0"
      bold: true
    }
  }
  original_vector: {
    direction: right
    label: "128 dimensions × float32"
    style.fill: "#E3F2FD"
    dim0: "d₀" {style.fill: "#BBDEFB"}
    dim1: "d₁" {style.fill: "#BBDEFB"}
    dim2: "d₂" {style.fill: "#BBDEFB"}
    dim_ellipsis: "..." {shape: text; style.font-size: 20}
    dim127: "d₁₂₇" {style.fill: "#BBDEFB"}
  }
  original_memory: {
    label: "Memory: 128 × 4 bytes = **512 bytes**"
    shape: text
    style: {
      font-color: "#1565C0"
      font-size: 18
      bold: true
    }
  }
}
arrow_split: |md
  ↓ **Split into M=8 subspaces**
| {style.font-size: 16}
row_subspaces: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  subspace_label: "Subspace Decomposition" {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
      font-color: "#E65100"
      bold: true
    }
  }
  subspace_0: {
    label: "Subspace 0\nDims 0-15"
    style.fill: "#FFE0B2"
    dims: "16 floats" {shape: text; style.font-size: 12}
  }
  subspace_1: {
    label: "Subspace 1\nDims 16-31"
    style.fill: "#FFCC80"
    dims: "16 floats" {shape: text; style.font-size: 12}
  }
  subspace_ellipsis: "..." {
    shape: text
    style.font-size: 24
  }
  subspace_7: {
    label: "Subspace 7\nDims 112-127"
    style.fill: "#FFB74D"
    dims: "16 floats" {shape: text; style.font-size: 12}
  }
}
arrow_codebooks: |md
  ↓ **Each subspace has 256 centroids (k=256)**
| {style.font-size: 16}
row_codebook: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  codebook_label: "Codebook Training\n(K-Means, k=256)" {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
      font-color: "#2E7D32"
      bold: true
    }
  }
  codebook_0: {
    label: "Codebook 0"
    style.fill: "#C8E6C9"
    entry0: "c₀₀" {style.fill: "#A5D6A7"}
    entry1: "c₀₁" {style.fill: "#A5D6A7"}
    entry_ellipsis: "⋮" {shape: text; style.font-size: 16}
    entry255: "c₀,₂₅₅" {style.fill: "#A5D6A7"}
    note: "256 centroids\n× 16 dims each" {shape: text; style.font-size: 10; style.font-color: "#555"}
  }
  codebook_ellipsis: "..." {
    shape: text
    style.font-size: 24
  }
  codebook_7: {
    label: "Codebook 7"
    style.fill: "#C8E6C9"
    entry0: "c₇₀" {style.fill: "#A5D6A7"}
    entry1: "c₇₁" {style.fill: "#A5D6A7"}
    entry_ellipsis: "⋮" {shape: text; style.font-size: 16}
    entry255: "c₇,₂₅₅" {style.fill: "#A5D6A7"}
    note: "256 centroids\n× 16 dims each" {shape: text; style.font-size: 10; style.font-color: "#555"}
  }
}
arrow_encode: |md
  ↓ **Encode: find nearest centroid per subspace**
| {style.font-size: 16}
row_encoded: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  encoded_label: "Quantized Codes" {
    style: {
      fill: "#FCE4EC"
      stroke: "#E91E63"
      stroke-width: 2
      font-color: "#AD1457"
      bold: true
    }
  }
  encoded_vector: {
    label: "8 uint8 codes"
    style.fill: "#F8BBD9"
    code0: "42" {style.fill: "#F48FB1"; style.font: mono}
    code1: "17" {style.fill: "#F48FB1"; style.font: mono}
    code2: "255" {style.fill: "#F48FB1"; style.font: mono}
    code3: "0" {style.fill: "#F48FB1"; style.font: mono}
    code4: "128" {style.fill: "#F48FB1"; style.font: mono}
    code5: "63" {style.fill: "#F48FB1"; style.font: mono}
    code6: "201" {style.fill: "#F48FB1"; style.font: mono}
    code7: "88" {style.fill: "#F48FB1"; style.font: mono}
  }
  encoded_memory: {
    label: "Memory: 8 × 1 byte = **8 bytes**"
    shape: text
    style: {
      font-color: "#AD1457"
      font-size: 18
      bold: true
    }
  }
}
row_summary: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  compression_box: {
    label: "Compression Summary"
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
      border-radius: 8
    }
    before: {
      label: "Before (FP32)"
      shape: text
      style.font-color: "#1565C0"
    }
    before_val: "512 bytes" {
      shape: text
      style: {font-size: 20; bold: true; font-color: "#1565C0"}
    }
    after: {
      label: "After (PQ)"
      shape: text
      style.font-color: "#AD1457"
    }
    after_val: "8 bytes" {
      shape: text
      style: {font-size: 20; bold: true; font-color: "#AD1457"}
    }
    ratio: {
      label: "Compression Ratio"
      shape: text
      style.font-color: "#2E7D32"
    }
    ratio_val: "**64×** reduction" {
      shape: text
      style: {font-size: 24; bold: true; font-color: "#2E7D32"}
    }
    overhead: {
      label: "Codebook Overhead"
      shape: text
      style.font-color: "#666"
    }
    overhead_val: "8 × 256 × 16 × 4 = 128 KB\n(amortized across all vectors)" {
      shape: text
      style: {font-size: 12; font-color: "#666"}
    }
  }
}
row_mapping: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  mapping_label: "Encoding Process" {
    style: {
      fill: "#ECEFF1"
      stroke: "#607D8B"
      stroke-width: 2
    }
  }
  step1: {
    label: "Step 1"
    style.fill: "#CFD8DC"
    desc: "Extract 16-dim\nsubvector" {shape: text; style.font-size: 11}
  }
  step2: {
    label: "Step 2"
    style.fill: "#CFD8DC"
    desc: "Find nearest\ncentroid (0-255)" {shape: text; style.font-size: 11}
  }
  step3: {
    label: "Step 3"
    style.fill: "#CFD8DC"
    desc: "Store centroid\nindex as uint8" {shape: text; style.font-size: 11}
  }
  step4: {
    label: "Repeat"
    style.fill: "#CFD8DC"
    desc: "For all 8\nsubspaces" {shape: text; style.font-size: 11}
  }
}
subspace_0 -> codebook_0: "train k-means" {style.stroke-dash: 3; style.stroke: "#4CAF50"}
subspace_7 -> codebook_7: "train k-means" {style.stroke-dash: 3; style.stroke: "#4CAF50"}
codebook_0 -> encoded_vector.code0: "nearest" {style.stroke: "#E91E63"; style.stroke-width: 2}
codebook_7 -> encoded_vector.code7: "nearest" {style.stroke: "#E91E63"; style.stroke-width: 2}
legend: {
  near: bottom-right
  label: "Key Insight"
  style: {
    fill: "#FFFDE7"
    stroke: "#FFC107"
    border-radius: 4
  }
  insight: |md
    **Why 64× matters:**
    • 1M vectors @ 768d = 3 GB → **48 MB** with PQ
    • Fits in cache, enables billion-scale on commodity hardware
    • ADC computes distances via lookup, not decompression
  |
}