direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  endpoint: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
      border-radius: 4
      font: mono
    }
  }
  storage_layer: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  index_layer: {
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
      stroke-width: 2
    }
  }
  distance_layer: {
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
      stroke-width: 2
    }
  }
  method: {
    style: {
      fill: "#FAFAFA"
      stroke: "#9E9E9E"
      border-radius: 2
      font: mono
      font-size: 11
    }
  }
}

title: {
  label: "Query API Architecture"
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
    underline: true
  }
}

# HTTP Layer
row_endpoints: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client: {
    shape: person
    label: "Client (HTTP/gRPC)"
    style.fill: "#E3F2FD"
  }
  api_gateway: "API Gateway (Actix-Web)" {
    style: {
      fill: "#BBDEFB"
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
}

# Collection Endpoints
row_collections: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  collection_endpoints: "Collection Endpoints" {
    direction: down
    style.fill: "#E3F2FD"
    post_coll: {
      class: endpoint
      label: "POST /collections"
    }
    get_coll: {
      class: endpoint
      label: "GET /collections"
    }
    del_coll: {
      class: endpoint
      label: "DELETE /collections/{id}"
    }
  }
}

# Vector Endpoints
row_vectors: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  vector_endpoints: "Vector Endpoints" {
    direction: down
    style.fill: "#E3F2FD"
    post_vec: {
      class: endpoint
      label: "POST /vectors"
    }
    post_search: {
      class: endpoint
      label: "POST /vectors/search"
    }
    del_vec: {
      class: endpoint
      label: "DELETE /vectors/{id}"
    }
    post_batch: {
      class: endpoint
      label: "POST /vectors/_batch"
    }
  }
}

# Service Layer
service_layer: "Service Layer (Query API)" {
  direction: right
  style: {
    fill: "#F5F5F5"
    stroke: "#616161"
    stroke-width: 2
    border-radius: 8
  }
  collection_mgr: {
    shape: class
    class: method
    label: "Collection Manager"
    +create_collection(id, config): "Result"
    +list_collections(): "Vec"
    +delete_collection(id): "Result"
    +get_collection(id): "Result"
  }
  vector_ops: {
    shape: class
    class: method
    label: "Vector Operations"
    +insert(id, vector, meta): "Result"
    +batch_insert(vectors): "Result"
    +delete(id): "Result"
  }
  search_ops: {
    shape: class
    class: method
    label: "Search Engine"
    +search(query, k, filter): "Result"
    +search_filtered(query, k, pred): "Result"
    +choose_filter_strategy(pred): "Strategy"
  }
  concurrent: {
    shape: class
    class: method
    label: "Concurrency Control"
    -rw_lock: "RwLock"
    +timeout_check(deadline): "bool"
    +batch_optimization(): "amortized"
  }
}

# Core Layers
core_layers: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  storage: {
    shape: sql_table
    label: "Storage Layer (M1)"
    class: storage_layer
    row1: "0x00 | AlignedBuffer | 64-byte aligned"
    row2: "0x40 | VectorStorage | contiguous data"
    row3: "0x80 | HashMap | metadata storage"
    total: "Total: Segmented Memory"
  }

  distance: {
    shape: sql_table
    label: "Distance Layer (M2)"
    class: distance_layer
    row1: "Module | Scalar | fallback impl"
    row2: "Module | SIMD | AVX2/AVX-512"
    row3: "Module | Runtime | auto-dispatch"
  }

  search_layer: "Search Layer (M3, M4, M5)" {
    direction: down
    brute_force: {
      shape: class
      class: method
      label: "Brute-Force KNN (M3)"
      style.fill: "#FFEBEE"
      +linear_scan(query, k): "Vec"
      +heap_top_k(selector): "O(N log k)"
    }
    hnsw: {
      shape: class
      label: "HNSW Index (M4)"
      class: index_layer
      +insert(node_id): "layer assignment"
      +search(query, k, ef): "Vec"
      +search_layer(ep, ef): "LayerResult"
    }
    quant: {
      shape: class
      class: method
      label: "Quantization (M5)"
      style.fill: "#E0F7FA"
      -SQ8: "4x compression"
      -PQ_M: "16-32x compression"
      +ADC(query): "lookup table"
    }
    brute_force -> hnsw: "fallback"
    hnsw -> quant: "optimized"
  }
}

# Request/Response Flow Annotations
flow_annotations: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  
  insert_flow: "Insert Flow" {
    shape: sequence_diagram
    api: API Gateway
    service: Service Layer
    storage: Storage (M1)
    index: HNSW (M4)
    api -> service: "POST /vectors"
    service -> storage: "validate & store"
    storage -> index: "add to graph"
    index -> service: "complete"
    service -> api: "201 Created"
  }
  
  search_flow: "Search Flow" {
    shape: sequence_diagram
    api: API Gateway
    service: Service Layer
    distance: Distance (M2)
    search: Search Layer
    storage: Storage (M1)
    api -> service: "POST /search"
    service -> search: "strategy choice"
    search -> distance: "compute scores"
    distance -> search: "SIMD results"
    search -> storage: "fetch meta"
    storage -> search: "metadata"
    search -> service: "sort top-k"
    service -> api: "results[]"
  }
}

# Connections
client -> api_gateway: "HTTP/gRPC"
api_gateway -> row_collections: "collection routes"
api_gateway -> row_vectors: "vector routes"
collection_endpoints -> service_layer.collection_mgr: "management"
vector_endpoints -> service_layer.vector_ops: "mutations"
vector_endpoints -> service_layer.search_ops: "queries"
service_layer -> core_layers.storage: "IO ops"
service_layer -> core_layers.distance: "math ops"
service_layer -> core_layers.search_layer: "KNN logic"

# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    border-radius: 4
  }
  title: "Layer Map" {
    shape: text
    style.bold: true
  }
  http: "HTTP/API Layer" {
    style.fill: "#E3F2FD"
  }
  svc: "Service Layer" {
    style.fill: "#F5F5F5"
  }
  stor: "Storage (M1)" {
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
  dist: "Distance (M2)" {
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
  }
  srch: "Search (M3-M5)" {
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
}

data_flow: {
  near: bottom-center
  label: "Data Flow: Request -> Validation -> Lock -> Compute -> Unlock -> Response"
  shape: text
  style: {
    font-size: 11
    italic: true
    font-color: "#616161"
  }
}