direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Collection Lifecycle Management {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
states: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  creating: {
    shape: oval
    label: "CREATING\n(index init)"
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 2
    }
  }
  active: {
    shape: oval
    label: "ACTIVE\n(serving queries)"
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
  }
  deleting: {
    shape: oval
    label: "DELETING\n(cleanup)"
    style: {
      fill: "#FFCDD2"
      stroke: "#C62828"
      stroke-width: 2
    }
  }
  deleted: {
    shape: oval
    label: "DELETED"
    style: {
      fill: "#E0E0E0"
      stroke: "#757575"
      stroke-width: 2
      stroke-dash: 3
    }
  }
}
creating -> active: "Index built\nvectors loaded" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
active -> deleting: "DELETE /collections/{id}" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
deleting -> deleted: "Resources freed\nIndex destroyed" {
  style.stroke: "#757575"
  style.stroke-width: 2
  style.stroke-dash: 3
}
active -> active: "INSERT / SEARCH\n(bulk ops)" {
  style.stroke: "#1976D2"
  style.stroke-width: 2
  style.stroke-dash: 5
}
config_panel: {
  label: "Collection Config\n(stored at creation)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1565C0"
    border-radius: 8
  }
  dimension: {
    shape: sql_table
    label: "Immutable Settings"
    f1: "dimension | usize | 768"
    f2: "metric | DistanceMetric | Cosine"
    f3: "storage | StorageConfig | Float32"
  }
  hnsw_params: {
    shape: sql_table
    label: "HNSW Parameters"
    f1: "M | usize | 16"
    f2: "M0 | usize | 32"
    f3: "efConstruction | usize | 200"
    f4: "efSearch | usize | 50"
  }
}
creating_detail: {
  label: "CREATING Phase"
  style: {
    fill: "#FFF8E1"
    stroke: "#F9A825"
    border-radius: 8
  }
  width: 320
  step1: {
    label: "1. Allocate Storage"
    code: |'rust
      storage = VectorStorage::new(
        config.dimension,
        StorageConfig::default()
      );
    '|
  }
  step2: {
    label: "2. Initialize HNSW Index"
    code: |'rust
      index = HNSWIndex::new(
        config.hnsw,
        metric.clone()
      );
    '|
  }
  step3: {
    label: "3. Bulk Insert (if provided)"
    code: |'rust
      for vector in initial_vectors {
        index.insert(id, storage, rng);
      }
    '|
  }
}
bulk_insert_flow: {
  label: "Bulk Insert Flow"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    border-radius: 8
  }
  direction: down
  validate: {
    shape: diamond
    label: "Validate\nAll Vectors?"
  }
  batch_insert: {
    label: "Batch Insert\n(storage.insert_batch)"
    style.fill: "#E1BEE7"
  }
  index_build: {
    label: "Build Index\n(parallel HNSW insert)"
    style.fill: "#E1BEE7"
  }
  success: {
    label: "Collection ACTIVE"
    style.fill: "#C8E6C9"
  }
  error: {
    label: "Rollback\nCollection DELETED"
    style.fill: "#FFCDD2"
  }
  validate -> batch_insert: "Yes"
  batch_insert -> index_build
  index_build -> success
  validate -> error: "Validation\nFailed" {
    style.stroke: "#C62828"
    style.stroke-dash: 3
  }
}
deleting_detail: {
  label: "DELETING Phase"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    border-radius: 8
  }
  width: 280
  cleanup: {
    label: "Resource Cleanup"
    code: |'rust
      // 1. Drop HNSW index
      drop(index);
      // 2. Flush and close storage
      storage.save(path)?;
      // 3. Remove from registry
      collections.remove(id);
      // 4. Delete files
      fs::remove_file(path)?;
    '|
  }
}
creating_detail -> creating: "creates" {
  style.stroke: "#F9A825"
  style.stroke-dash: 3
}
deleting_detail -> deleting: "processes" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
config_panel -> creating: "config" {
  style.stroke: "#1565C0"
  style.stroke-dash: 3
}
legend: {
  near: bottom-right
  label: "State Transitions"
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  normal: {
    label: "Normal transition"
    style.fill: transparent
  }
  error_path: {
    label: "Error path"
    style.fill: transparent
    style.stroke-dash: 3
  }
  self_loop: {
    label: "Active operations"
    style.fill: transparent
    style.stroke-dash: 5
  }
}