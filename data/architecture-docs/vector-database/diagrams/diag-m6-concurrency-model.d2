direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Concurrent Access: Read-Write Lock Model"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  readers: {
    direction: down
    label: "Readers (Multiple Concurrent)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    r1: {
      label: "Reader 1"
      shape: person
      style.fill: "#C8E6C9"
    }
    r2: {
      label: "Reader 2"
      shape: person
      style.fill: "#C8E6C9"
    }
    r3: {
      label: "Reader N"
      shape: person
      style.fill: "#C8E6C9"
      style.stroke-dash: 3
    }
  }
  lock_state: {
    direction: down
    label: "Lock State Machine"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    unlocked: {
      shape: circle
      label: "UNLOCKED"
      style.fill: "#FFEB3B"
      style.stroke: "#F57C00"
    }
    shared_locked: {
      shape: circle
      label: "SHARED\n(Read Lock)"
      style.fill: "#4CAF50"
      style.font-color: white
    }
    exclusive_locked: {
      shape: circle
      label: "EXCLUSIVE\n(Write Lock)"
      style.fill: "#F44336"
      style.font-color: white
    }
    unlocked -> shared_locked: "read_lock()\n[multiple allowed]" {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    shared_locked -> unlocked: "read_unlock()\n[last reader]" {
      style.stroke: "#4CAF50"
      style.stroke-dash: 3
    }
    unlocked -> exclusive_locked: "write_lock()\n[exclusive]" {
      style.stroke: "#F44336"
      style.stroke-width: 2
    }
    exclusive_locked -> unlocked: "write_unlock()" {
      style.stroke: "#F44336"
      style.stroke-dash: 3
    }
  }
  writer: {
    direction: down
    label: "Writer (Exclusive)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    w1: {
      label: "Writer"
      shape: person
      style.fill: "#FFCDD2"
    }
    blocked: {
      label: "Blocked\n(waiting)"
      shape: diamond
      style.fill: "#FFCDD2"
      style.stroke: "#F44336"
      style.stroke-dash: 4
    }
    w1 -> blocked: "if readers\nactive" {
      style.stroke-dash: 4
      style.stroke: "#F44336"
    }
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  readers -> lock_state: "acquire\nshared" {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    style.animated: true
  }
  lock_state -> writer: "grants\nexclusive" {
    style.stroke: "#F44336"
    style.stroke-width: 2
  }
}
cow_section: {
  label: "Copy-on-Write Alternative (HNSW Updates)"
  style.fill: "#E3F2FD"
  style.stroke: "#2196F3"
  cow_flow: {
    direction: right
    original: {
      label: "Original\nSnapshot v1"
      shape: cylinder
      style.fill: "#BBDEFB"
    }
    copy: {
      label: "Copy for\nModification"
      shape: cylinder
      style.fill: "#90CAF9"
      style.stroke-dash: 3
    }
    modified: {
      label: "Modified\nSnapshot v2"
      shape: cylinder
      style.fill: "#64B5F6"
    }
    original -> copy: "clone" {
      style.stroke-dash: 3
      style.stroke: "#2196F3"
    }
    copy -> modified: "apply\nupdates" {
      style.stroke: "#2196F3"
      style.stroke-width: 2
    }
  }
  swap: {
    label: "Atomic Pointer Swap"
    shape: hexagon
    style.fill: "#1976D2"
    style.font-color: white
  }
  cow_flow.modified -> swap: {
    style.stroke: "#1976D2"
    style.stroke-width: 3
  }
  benefits: {
    label: "|md\n  **Benefits:**\n  - Readers never block\n  - Consistent snapshots\n  - No lock contention\n\n  **Trade-offs:**\n  - O(N) write cost\n  - Memory overhead\n  - Garbage collection\n|"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  swap -> benefits: {
    style.stroke: transparent
  }
}
deadlock_section: {
  label: "Deadlock Prevention Strategy"
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
  deadlock_rules: {
    shape: sql_table
    label: "Lock Ordering Rules (storage.h)"
    r1: "1 | Global → Collection | Acquire global lock first"
    r2: "2 | Collection → Storage | Acquire collection before storage"
    r3: "3 | Storage → Index | Acquire storage before index"
    r4: "4 | Timeout | All locks use try_lock with timeout"
  }
  violation: {
    label: "Deadlock Violation Example"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke-dash: 4
    code: |'rust
      // ❌ WRONG: Lock order violation
      let index = collection.index.write();
      let storage = collection.storage.write(); // DEADLOCK!
      // ✅ CORRECT: Consistent order
      let storage = collection.storage.write();
      let index = collection.index.write();
    '|
  }
  deadlock_rules -> violation: "prevents" {
    style.stroke: "#E91E63"
    style.stroke-dash: 3
  }
}
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: {
    label: "Shared Lock (Read)"
    shape: rectangle
    style.fill: "#4CAF50"
    style.font-color: white
  }
  l2: {
    label: "Exclusive Lock (Write)"
    shape: rectangle
    style.fill: "#F44336"
    style.font-color: white
  }
  l3: {
    label: "Blocked/Waiting"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke-dash: 4
  }
  l4: {
    label: "CoW Operation"
    shape: rectangle
    style.fill: "#2196F3"
    style.font-color: white
  }
}