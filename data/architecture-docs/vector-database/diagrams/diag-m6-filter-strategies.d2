direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Pre-Filter vs Post-Filter for ANN Search"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  query_start: {
    label: "Search Query"
    shape: oval
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    width: 140
  }
  selectivity_check: {
    label: "Estimate\nPredicate\nSelectivity"
    shape: diamond
    style.fill: "#FFF3E0"
    style.stroke: "#F57C00"
    width: 140
  }
}
row2: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  low_sel: {
    label: "LOW\n(< 30%)"
    shape: hexagon
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.font-color: "#C62828"
    width: 100
  }
  high_sel: {
    label: "HIGH\n(> 30%)"
    shape: hexagon
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.font-color: "#2E7D32"
    width: 100
  }
}
row3: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  post_filter_box: {
    label: "POST-FILTER Strategy"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-width: 2
    width: 280
    pf_step1: {
      label: "1. ANN Search on ALL vectors"
      shape: rectangle
      style.fill: white
    }
    pf_step2: {
      label: "2. Retrieve k × oversample"
      shape: rectangle
      style.fill: white
    }
    pf_step3: {
      label: "3. Filter results"
      shape: rectangle
      style.fill: white
    }
    pf_step4: {
      label: "4. Return top-k matches"
      shape: rectangle
      style.fill: white
    }
    pf_step1 -> pf_step2 -> pf_step3 -> pf_step4
  }
  pre_filter_box: {
    label: "PRE-FILTER Strategy"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    width: 280
    pref_step1: {
      label: "1. Evaluate predicate"
      shape: rectangle
      style.fill: white
    }
    pref_step2: {
      label: "2. Identify matching IDs"
      shape: rectangle
      style.fill: white
    }
    pref_step3: {
      label: "3. Search among matches"
      shape: rectangle
      style.fill: white
    }
    pref_step4: {
      label: "4. Return top-k"
      shape: rectangle
      style.fill: white
    }
    pref_step1 -> pref_step2 -> pref_step3 -> pref_step4
  }
}
query_start -> selectivity_check: "query + filter"
selectivity_check -> low_sel: "few match"
selectivity_check -> high_sel: "many match"
low_sel -> post_filter_box
high_sel -> pre_filter_box
row4: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  post_result: {
    label: "Result"
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    width: 280
    post_out: {
      label: "✓ Full recall preserved\n⚠ May return < k results\n⚠ Higher latency (scan more)"
      shape: text
      style.font-size: 14
      style.fill: transparent
    }
  }
  pre_result: {
    label: "Result"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    width: 280
    pre_out: {
      label: "✓ Lower latency (scan less)\n✓ Always returns k results\n⚠ HNSW graph may be non-navigable"
      shape: text
      style.font-size: 14
      style.fill: transparent
    }
  }
}
post_filter_box -> post_result
pre_filter_box -> pre_result
recall_section: {
  label: "Recall Impact Visualization"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  recall_title: {
    label: "Why Pre-Filter Can Miss True Nearest"
    shape: text
    style.font-size: 16
    style.bold: true
  }
  recall_row: "" {
    direction: right
    graph_before: {
      label: "Full HNSW Graph"
      shape: rectangle
      style.fill: white
      width: 200
      gb_explain: {
        label: |md
          - All nodes connected
          - Entry point at top
          - Long-range jumps possible
        |
        shape: text
        style.fill: transparent
      }
    }
    graph_filtered: {
      label: "After Filtering"
      shape: rectangle
      style.fill: white
      width: 200
      gf_explain: {
        label: |md
          - Filtered nodes removed
          - Entry point may be gone
          - Graph disconnected!
        |
        shape: text
        style.fill: transparent
      }
    }
    graph_problem: {
      label: "The Problem"
      shape: rectangle
      style.fill: "#FFEBEE"
      width: 200
      gp_explain: {
        label: |md
          - True nearest in filtered region
          - No path to reach it
          - Recall drops to ~0%
        |
        shape: text
        style.fill: transparent
      }
    }
  }
  graph_before -> graph_filtered: "apply filter"
  graph_filtered -> graph_problem: "traversal fails"
}
row5: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  decision_table: {
    label: "Decision Matrix"
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#607D8B"
    width: 600
    table_content: {
      shape: sql_table
      label: "Filter Strategy Selection"
      row1: "Selectivity | Strategy | Latency | Recall | Notes"
      row2: "< 10%       | POST     | High    | 100%   | Oversample 10-20x"
      row3: "10-30%      | POST     | Medium  | 95%+   | Oversample 5-10x"
      row4: "30-50%      | AUTO     | Medium  | 95%+   | Depends on graph"
      row5: "> 50%       | PRE      | Low     | 90%+   | Graph still navigable"
      row6: "> 80%       | PRE      | Low     | 95%+   | Near-full scan anyway"
    }
  }
}
legend: {
  near: bottom-right
  label: "Strategy Summary"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  leg_content: {
    label: |md
      **POST-FILTER** (low selectivity)
      - Scan all, filter results
      - Preserves recall
      - May need oversampling
      **PRE-FILTER** (high selectivity)
      - Filter first, then search
      - Faster when most match
      - Can break HNSW navigation
    |
    shape: text
    style.fill: transparent
  }
}