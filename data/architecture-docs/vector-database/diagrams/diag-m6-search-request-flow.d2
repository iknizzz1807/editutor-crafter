direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Search Request Processing Flow
  Query path: HTTP → Validation → Strategy Selection → Index Search → Re-ranking → Response
|
title.near: top-center

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  http: {
    label: "HTTP Request (search.rs)"
    node_info: "POST /api/v1/collections/{id}/search"
    width: 250
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
  }
  validation: {
    label: "Request Validation"
    checks: {
      shape: class
      label: "Validation Logic"
      +dimension(v): "bool"
      +k_bounds(k): "bool"
      +filter_syntax(f): "bool"
      +timeout_ms(t): "bool"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  collection_lookup: {
    label: "Collection Lookup"
    width: 200
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
    code: |'rust
      collections.read()
        .get(&collection_id)?
    '|
  }
  timeout_check_1: {
    label: "⏱ Timeout Check #1"
    shape: diamond
    width: 140
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  lock_acquire: {
    label: "Lock Acquisition"
    mechanism: "RwLock::read()"
    style.fill: "#E1BEE7"
    style.stroke: "#8E24AA"
    note: "Allows concurrent readers"
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  filter_strategy: {
    label: "Filter Strategy Selection"
    width: 220
    style.fill: "#B2DFDB"
    style.stroke: "#00897B"
    strategy_logic: {
      shape: class
      label: "Strategy Decision"
      +estimate_selectivity(p): "float"
      +threshold_check(s): "bool"
      +choose_path(): "Strategy"
    }
  }
  timeout_check_2: {
    label: "⏱ Timeout Check #2"
    shape: diamond
    width: 140
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  mode_select: {
    label: "Search Mode Selection"
    width: 200
    mode_logic: {
      shape: class
      label: "Mode Decision"
      +auto_mode(cnt): "Mode"
      +brute_force(): "Mode"
      +index_search(): "Mode"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  prefilter: {
    label: "Pre-Filter Path"
    details: "Fallback to Brute Force"
    width: 220
    style.fill: "#C8E6C9"
    style.stroke: "#43A047"
    style.stroke-dash: 3
    workflow_logic: |md
      1. Full Collection Scan
      2. Predicate Evaluation
      3. Vector Distance Calc
    |
  }
  postfilter: {
    label: "Post-Filter Path"
    details: "HNSW + On-the-fly Filter"
    width: 220
    style.fill: "#C8E6C9"
    style.stroke: "#43A047"
    workflow_logic: |md
      1. HNSW search (k * 10)
      2. Apply Filter Predicate
      3. Return top-k
    |
  }
  hnsw_search: {
    label: "HNSW Index Search"
    width: 220
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    hnsw_algo: {
      shape: class
      label: "HNSW Traversal"
      -entry_point: "NodeId"
      -ef_search: "usize"
      +search(q, k): "Vec<Res>"
      +traverse_layers(): "void"
    }
  }
}

row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  quantized_check: {
    label: "Quantized Storage?"
    shape: diamond
    width: 150
    style.fill: "#FFE0B2"
    style.stroke: "#F57C00"
  }
  rerank: {
    label: "Re-ranking"
    details: "Exact Distance Calculation"
    width: 200
    style.fill: "#FCE4EC"
    style.stroke: "#C2185B"
    logic: |md
      - Fetch FP32 vectors
      - Compute true dist
      - Re-sort candidates
    |
  }
  direct_result: {
    label: "Direct Result"
    details: "FP32 distances available"
    width: 180
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }
}

row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  result_assembly: {
    label: "Result Assembly"
    width: 220
    style.fill: "#E0E0E0"
    style.stroke: "#616161"
    assembly_steps: {
      shape: class
      label: "Response Builder"
      +fetch_metadata(ids): "Map"
      +sort_results(): "void"
      +truncate(k): "void"
      +calc_latency(): "Duration"
    }
  }
  response: {
    label: "HTTP Response (200 OK)"
    width: 200
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    payload: |'json
      {
        "results": [
          {"id": 42, "score": 0.95}
        ],
        "latency_ms": 5.2
      }
    '|
  }
}

error_paths: {
  label: "Exception Handlers"
  style.stroke: "#E53935"
  style.stroke-dash: 5
  timeout_error: {
    label: "Timeout Error (408)"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  validation_error: {
    label: "Validation Error (400)"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
  not_found_error: {
    label: "Not Found Error (404)"
    style.fill: "#FFCDD2"
    style.stroke: "#E53935"
  }
}

legend_box: {
  label: "Diagram Legend"
  shape: sql_table
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  row1: "⏱ | Timeout checkpoint"
  row2: "◇ | Decision point"
  row3: "→ | Data flow"
}
legend_box.near: bottom-right

# Connections with corrected styles
row1.http -> row1.validation: "JSON body"
row1.validation -> row2.collection_lookup: "valid"
row1.validation -> error_paths.validation_error: "invalid" {
  style.stroke-dash: 4; style.stroke: "#E53935"
}

row2.collection_lookup -> row2.timeout_check_1: "Collection"
row2.collection_lookup -> error_paths.not_found_error: "missing" {
  style.stroke-dash: 4; style.stroke: "#E53935"
}

row2.timeout_check_1 -> row2.lock_acquire: "not expired"
row2.timeout_check_1 -> error_paths.timeout_error: "expired" {
  style.stroke-dash: 4; style.stroke: "#E53935"
}

row2.lock_acquire -> row3.filter_strategy: "read lock"
row3.filter_strategy -> row3.timeout_check_2: "decision"
row3.timeout_check_2 -> row3.mode_select: "not expired"
row3.timeout_check_2 -> error_paths.timeout_error: "expired" {
  style.stroke-dash: 4; style.stroke: "#E53935"
}

row3.mode_select -> row4.hnsw_search: "Index mode"
row3.mode_select -> row4.prefilter: "BF mode"

row3.filter_strategy -> row4.prefilter: "high selectivity"
row3.filter_strategy -> row4.postfilter: "low selectivity"

row4.postfilter -> row4.hnsw_search: "oversample"
row4.hnsw_search -> row5.quantized_check: "candidates"
row4.prefilter -> row5.quantized_check: "candidates"

row5.quantized_check -> row5.rerank: "Yes (SQ8/PQ)"
row5.quantized_check -> row5.direct_result: "No (FP32)"

row5.rerank -> row6.result_assembly: "Exact scores"
row5.direct_result -> row6.result_assembly: "Exact scores"
row6.result_assembly -> row6.response: "Final JSON"

# Annotation Note
rerank_note: {
  label: "Implementation Note"
  note: "Re-ranking corrects quantization error via FP32 distance"
  style.fill: "#FFF3E0"
  style.stroke: "#FFB74D"
}
rerank_note.near: bottom-left