direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: |'md
    # Concurrent Stress Test Scenario
    **60s Duration | 10 Writers | 100 Readers**
  '|
}
title.near: top-center

row_config: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  test_params: {
    label: "Test Configuration (stress_test.rs)"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    duration: "60 seconds"
    threads: "110 total"
    dataset: "100K vectors (768d)"
    ops_target: "10K ops/sec"
  }

  lock_policy: {
    label: "RwLock Policy (sync_policy.h)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    reader_access: "Shared | Parallel"
    writer_access: "Exclusive | Blocking"
    ordering: "Fair FIFO"
    timeout: "100ms Try-Lock"
  }
}

row_pools: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  writer_pool: {
    direction: down
    label: "Writer Group (10 Threads)"
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    
    ops: {
      shape: class
      label: "WriterOps (writer.rs)"
      +insert_vec(v, m): "Result"
      +delete_vec(id): "Result"
      +update_meta(id, m): "Result"
      -lock_write(): "void"
    }
    
    timing: {
      label: "Latency Profile"
      acquire: "1-50ms"
      execution: "0.1-5ms"
    }
  }

  reader_pool: {
    direction: down
    label: "Reader Group (100 Threads)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"

    ops: {
      shape: class
      label: "ReaderOps (reader.rs)"
      +search(q, k): "Vec<Hit>"
      +get_vec(id): "Option<Vec>"
      -lock_read(): "void"
    }

    timing: {
      label: "Latency Profile"
      acquire: "0.01-1ms"
      execution: "5-50ms"
    }
  }
}

# Cross-container dependency annotation
writer_pool.ops -> reader_pool.ops: "Lock Contention | Block" {
  style.stroke: "#F44336"
  style.stroke-dash: 4
}

row_state: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  shared_memory: {
    direction: down
    label: "Protected Shared State"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    
    lock_ctrl: {
      shape: diamond
      label: "RwLock Controller"
    }
    
    vector_store: {
      shape: cylinder
      label: "VectorStorage (mmap)"
    }
    
    hnsw_index: {
      shape: hexagon
      label: "HNSW Graph"
    }

    lock_ctrl -> vector_store: "Mutex | Guard"
    lock_ctrl -> hnsw_index: "Mutex | Guard"
  }

  state_machine: {
    direction: down
    label: "Lock State Evolution"
    style.fill: "#FCE4EC"
    style.stroke: "#E91E63"
    
    unlocked: { shape: circle; label: "IDLE" }
    reading: { shape: circle; label: "READ_BUSY" }
    writing: { shape: circle; label: "WRITE_LOCKED" }

    unlocked -> reading: "R_ACQ"
    reading -> unlocked: "R_REL"
    unlocked -> writing: "W_ACQ"
    writing -> unlocked: "W_REL"
    reading -> writing: "WAIT_READERS" {
      style.stroke: "#F44336"
      style.stroke-dash: 2
    }
  }
}

row_logic: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  verification: {
    direction: down
    label: "Invariant Checks"
    style.fill: "#E0F2F1"
    style.stroke: "#009688"
    
    integrity: {
      label: "Data Integrity"
      dist_check: "dist(a,a) == 0"
      ptr_check: "No orphaned nodes"
    }
    
    accuracy: {
      label: "Search Accuracy"
      recall_min: "Recall@10 > 0.90"
      variance: "Var < 0.05"
    }
  }

  impl_node: {
    label: "Assertion Logic (stress_test.rs)"
    impl_code: {
      shape: code
      label: "verify_invariants"
      code: |'rust
        fn verify(store: &Store, idx: &Index) {
          for (id, v, _) in store.iter() {
            assert!(metric.dist(v, v) < 1e-6);
          }
          assert!(idx.is_reachable(idx.entry));
          assert!(measure_recall() >= 0.90);
        }
      '|
    }
  }
}

row_outcome: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  metrics: {
    direction: right
    label: "Observed Performance"
    style.fill: "#E3F2FD"
    style.stroke: "#1976D2"
    
    throughput: {
      label: "Throughput"
      r_sec: "10K Reads/s"
      w_sec: "150 Writes/s"
    }
    
    latency: {
      label: "Latency (p99)"
      r_p99: "85ms"
      w_p99: "420ms"
    }
  }

  summary_node: {
    label: "Final Verdict"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 3
    result: "PASSED: 0 Corruptions"
    status: "All threads exit 0"
  }
}

row_config -> row_pools: "Initialize Threads"
row_pools -> row_state: "Execute Ops"
row_state -> row_logic: "Validate State"
row_logic -> row_outcome: "Report Results"