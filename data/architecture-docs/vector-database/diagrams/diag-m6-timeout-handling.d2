  label: "timeout"
  style.stroke: "#C44"
  style.stroke-dash: 4
}
candidate_expansion -> early_term: "is_expired() == true" {
  label: "timeout"
  style.stroke: "#C44"
  style.stroke-dash: 4
}
brute_force -> early_term: "is_expired() == true" {
  label: "timeout"
  style.stroke: "#C44"
  style.stroke-dash: 4
}
legend: {
  near: bottom-right
  label: "Legend"
  check: "Periodic check"
  check.style.fill: "#E8F4FD"
  timeout: "Timeout path"
  timeout.style.fill: "#FFE4E4"
  timeout.style.stroke: "#C44"
  timeout.style.stroke-dash: 4
}