direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Query Timeout Mechanism
  Implementation showing deadline propagation and early termination
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  client: {
    label: "Client Request"
    width: 200
    code: |'rust
      SearchRequest {
        vector: Vec<f32>,
        k: 10,
        timeout_ms: 100,
      }
    '|
  }
  api_layer: {
    label: "API Layer"
    width: 240
    code: |'rust
      // Calculate deadline from timeout
      let deadline = Instant::now() 
        + Duration::from_millis(req.timeout_ms);
      let mut search = TimedSearch::new(
        collection, 
        deadline
      );
    '|
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timed_search: {
    label: "TimedSearch Struct (m6/query.rs)"
    width: 300
    code: |'rust
      pub struct TimedSearch<'a> {
        collection: &'a ThreadSafeCollection,
        deadline: Instant,
        cancelled: Arc<AtomicBool>,
      }
      impl TimedSearch<'a> {
        pub fn is_expired(&self) -> bool {
          self.cancelled.load(Relaxed) 
            || Instant::now() > self.deadline
        }
      }
    '|
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_traversal: {
    label: "Layer Descent with Timeout Checks"
    direction: down
    layer3: {
      label: "Layer 3 (Top)"
      width: 180
      code: |'rust
        // Entry point
        if is_expired() { 
          return Err(Timeout);
        }
        greedy_search(layer=3, ef=1);
      '|
      style.fill: "#E8F4FD"
    }
    layer2: {
      label: "Layer 2"
      width: 180
      code: |'rust
        // Check between layers
        if is_expired() { 
          return Err(Timeout);
        }
        greedy_search(layer=2, ef=1);
      '|
      style.fill: "#D1E9FC"
    }
    layer1: {
      label: "Layer 1"
      width: 180
      code: |'rust
        // Check between layers
        if is_expired() { 
          return Err(Timeout);
        }
        greedy_search(layer=1, ef=1);
      '|
      style.fill: "#BAD7F9"
    }
    layer0: {
      label: "Layer 0 (Base)"
      width: 180
      code: |'rust
        // Final layer with efSearch
        if is_expired() { 
          return Err(Timeout);
        }
        greedy_search(layer=0, ef=efSearch);
      '|
      style.fill: "#A3C5F6"
    }
  }
  candidate_expansion: {
    label: "Candidate Expansion Loop"
    width: 320
    code: |'rust
      // Inside search_layer()
      while let Some(closest) = candidates.pop() {
        // CHECK: Timeout on every iteration
        if is_expired() {
          // Early termination
          return Err(SearchError::Timeout);
        }
        // Expand neighbors
        for neighbor in node.neighbors(layer) {
          let dist = distance(query, neighbor);
          candidates.push(neighbor, dist);
          results.consider(neighbor, dist);
        }
      }
    '|
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  brute_force: {
    label: "Brute-Force Timeout (Per-Vector Check)"
    width: 340
    code: |'rust
      // Check every N vectors (not every vector)
      const CHECK_INTERVAL: usize = 1000;
      for (i, (id, vector, meta)) in storage.iter_live().enumerate() {
        // Periodic timeout check
        if i % CHECK_INTERVAL == 0 && is_expired() {
          return Err(SearchError::Timeout);
        }
        let dist = metric.distance(query, vector);
        selector.consider(id, dist);
      }
    '|
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  early_term: {
    label: "Early Termination Response"
    width: 280
    style.fill: "#FFE4E4"
    style.stroke: "#C44"
    code: |'rust
      pub enum SearchError {
        Timeout,  // Query exceeded deadline
        // ... other errors
      }
      // HTTP Response:
      // 408 Request Timeout
      // { "error": "Query timeout" }
    '|
  }
  partial_results: {
    label: "Partial Result Option"
    width: 280
    style.fill: "#FFF4E4"
    style.stroke: "#C82"
    code: |'rust
      // Alternative: return partial results
      pub struct SearchResponse {
        results: Vec<SearchResult>,
        latency_ms: f64,
        timed_out: bool,  // true if early exit
        candidates_scanned: usize,
      }
    '|
  }
}
