  style.stroke: "#666"
  style.stroke-dash: 3
}
layer_traversal.layer1 -> layer_traversal.layer0: "descend" {
  style.stroke: "#666"
  style.stroke-dash: 3
}
timed_search -> candidate_expansion: "expand candidates" {
  style.stroke: "#4A90D9"
}
timed_search -> brute_force: "brute-force path" {
  style.stroke: "#4A90D9"
}
