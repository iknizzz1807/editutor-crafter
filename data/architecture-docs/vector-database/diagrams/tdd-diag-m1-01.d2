  style.stroke: orange
  style.stroke-dash: 3 
  style.animated: true
}
MemoryMap.v0_pad -> MemoryMap.v1_data: "64B Stride" { 
  style.stroke: orange
  style.stroke-dash: 3 
}
MemoryMap.v1_pad -> MemoryMap.v2_data: "64B Stride" { 
  style.stroke: orange
  style.stroke-dash: 3 
}