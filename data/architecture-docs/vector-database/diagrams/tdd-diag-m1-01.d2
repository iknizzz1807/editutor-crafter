direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Contiguous Vector Storage Memory Layout
  **SIMD-Aligned Buffer (AVX-512 Ready)**
  *Implementation Spec: Fixed-width float32 vectors with 64-byte alignment*
| {
  near: top-center
  shape: text
}

Legend: {
  near: top-right
  header: "Header Metadata" { style.fill: "#6a1b9a"; style.font-color: white }
  data: "Vector Data Segment" { style.fill: "#1e88e5"; style.font-color: white }
  padding: "Alignment Padding" { style.fill: "#bdbdbd" }
  free: "Free/Unallocated Capacity" { style.fill: "#43a047"; style.font-color: white }
}

MemoryMap: {
  grid-columns: 3
  grid-gap: 0
  vertical-gap: 0
  
  # Column Headers
  c1: "Byte Offset" { shape: text; style.bold: true; style.underline: true }
  c2: "Memory Block (Physical Layout)" { shape: text; style.bold: true; style.underline: true }
  c3: "Field Size" { shape: text; style.bold: true; style.underline: true }

  # --- ROW: HEADER ---
  off_0: "0x0000" { shape: text }
  header: "FileHeader\n(Magic, Version, Dims, Capacity, LiveCount)" {
    style: {
      fill: "#6a1b9a"
      font-color: white
      stroke-width: 2
      bold: true
    }
  }
  size_0: "64 Bytes" { shape: text }

  # --- CACHE LINE BOUNDARY ---
  cl_1: "" {
    grid-column-span: 3
    height: 4
    style: {
      stroke: "#000000"
      stroke-dash: 5
      stroke-width: 2
    }
  }

  # --- ROW: VECTOR 0 ---
  off_1: "0x0040" { shape: text }
  v0_data: "Vector Index 0: Float32 Array [dim=12]\nElements: [v0..v11]" {
    style: {
      fill: "#1e88e5"
      font-color: white
      bold: true
    }
  }
  size_1: "48 Bytes" { shape: text }

  # --- ROW: PADDING 0 ---
  off_2: "0x0070" { shape: text }
  v0_pad: "Alignment Padding (Zeroed)\n[Ensures Vector 1 starts at 64B boundary]" {
    style: {
      fill: "#bdbdbd"
      stroke-dash: 2
      font-size: 10
    }
  }
  size_2: "16 Bytes" { shape: text }

  # --- CACHE LINE BOUNDARY ---
  cl_2: "" {
    grid-column-span: 3
    height: 4
    style: {
      stroke: "#000000"
      stroke-dash: 5
      stroke-width: 2
    }
  }

  # --- ROW: VECTOR 1 ---
  off_3: "0x0080" { shape: text }
  v1_data: "Vector Index 1: Float32 Array [dim=12]" {
    style: {
      fill: "#1e88e5"
      font-color: white
      bold: true
    }
  }
  size_3: "48 Bytes" { shape: text }

  # --- ROW: PADDING 1 ---
  off_4: "0x00B0" { shape: text }
  v1_pad: "Alignment Padding (Zeroed)" {
    style: {
      fill: "#bdbdbd"
      stroke-dash: 2
      font-size: 10
    }
  }
  size_4: "16 Bytes" { shape: text }

  # --- CACHE LINE BOUNDARY ---
  cl_3: "" {
    grid-column-span: 3
    height: 4
    style: {
      stroke: "#000000"
      stroke-dash: 5
      stroke-width: 2
    }
  }

  # --- ROW: VECTOR 2 ---
  off_5: "0x00C0" { shape: text }
  v2_data: "Vector Index 2: Float32 Array [dim=12]" {
    style: {
      fill: "#1e88e5"
      font-color: white
    }
  }
  size_5: "48 Bytes" { shape: text }

  # --- ROW: FREE SPACE ---
  off_6: "..." { shape: text }
  free: "Unallocated Memory Capacity\n(Zero-initialized via mmap / alloc_zeroed)" {
    style: {
      fill: "#43a047"
      font-color: white
      fill-pattern: grain
    }
  }
  size_6: "Remaining" { shape: text }
}

Formulas: |md
  ## Offset Calculation Logic
  - `vector_bytes` = `dim * sizeof(float32)` (e.g., 12 * 4 = 48)
  - `alignment` = `64` (Standard x86_64 Cache Line)
  - `stride` = `ceil(vector_bytes / alignment) * alignment` (e.g., 64)
  - `byte_offset(i)` = `sizeof(Header) + (i * stride)`
  
  ## SIMD Safety
  - **AVX-512**: Requires 64-byte alignment for `_mm512_load_ps`.
  - **AVX2**: Requires 32-byte alignment. This layout satisfies both.
  - **Prefetching**: Sequential access triggers hardware prefetchers.
| {
  near: bottom-left
  shape: text
  style.font-size: 12
}

Annotations: {
  near: bottom-right
  avx: "AVX-512 Ready" {
    shape: rectangle
    style: {
      fill: orange
      border-radius: 999
      bold: true
    }
  }
  prefetch: "Hardware Prefetcher Optimized" {
    shape: rectangle
    style: {
      fill: skyblue
      border-radius: 999
      bold: true
    }
  }
}

