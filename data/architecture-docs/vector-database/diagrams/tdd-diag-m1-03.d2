direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

classes: {
  memory_header: {
    label: "AVX-512 Block"
    style: {
      fill: "#e1d5e7"
      stroke: "#9673a6"
      stroke-width: 2
      bold: true
    }
  }
  avx_data: {
    label: "AVX2 Block"
    style: {
      fill: "#dae8fc"
      stroke: "#6c8ebf"
    }
  }
  padding_data: {
    label: "Padding"
    style: {
      fill: "#f5f5f5"
      stroke: "#b3b3b3"
    }
  }
  penalty_data: {
    label: "Misaligned Load"
    style: {
      fill: "#f8cecc"
      stroke: "#b85450"
      stroke-width: 3
    }
  }
  boundary_line: {
    height: 12
    style: {
      fill: "#333333"
      stroke: "#000000"
      stroke-width: 1
    }
  }
  offset_label: {
    shape: text
    style: {
      font: mono
      bold: true
      font-size: 14
    }
  }
}

# --- MAIN SPECIFICATION ---
simd_alignment_spec: "SIMD Alignment Detail: 32/64 Byte Boundaries" {
  style: {
    stroke: "#333333"
    stroke-width: 2
    fill: white
  }

  page_start: "OFFSET 0x0000 | PHYSICAL PAGE BOUNDARY (4096B)" {
    class: boundary_line
    style.fill: black
    style.bold: true
  }

  # --- ALIGNED SCENARIO ---
  aligned_section: "SCENARIO A: ALIGNED LOAD CONFIGURATION (OPTIMAL)" {
    grid-columns: 1
    style.fill: "#fdfdfd"
    style.stroke: "#228b22" # Forest Green for success
    style.stroke-width: 2
    
    cl_0: "CACHE LINE 0 (Offsets 0x00 - 0x3F) | 64B" {
      grid-columns: 3
      grid-gap: 15
      style.stroke-dash: 5
      
      off_0: "0x00" { class: offset_label }
      avx2_v0: "Data: AVX2 Vector [0] (ymm0)" {
        class: avx_data
        tooltip: "32-byte alignment satisfied (0x00 % 32 == 0)"
        width: 400
      }
      sz_0: "32 Bytes" { class: offset_label }
      
      off_1: "0x20" { class: offset_label }
      unused_padding: "Alignment Padding (Internal)" {
        class: padding_data
        width: 400
      }
      sz_1: "32 Bytes" { class: offset_label }
    }

    cache_boundary_0: "0x40 | CACHE LINE BOUNDARY (ALIGN 64)" {
      class: boundary_line
      style.stroke-dash: 0
      style.fill: "#444444"
    }

    cl_1: "CACHE LINE 1 (Offsets 0x40 - 0x7F) | 64B" {
      grid-columns: 3
      grid-gap: 15
      style.stroke-dash: 5
      
      off_2: "0x40" { class: offset_label }
      avx512_v0: "Data: AVX-512 Vector [0] (zmm0)" {
        class: memory_header
        tooltip: "64-byte alignment satisfied (0x40 % 64 == 0)"
        width: 400
      }
      sz_2: "64 Bytes" { class: offset_label }
    }
  }

  spacer: "" {
    style: {
      stroke-width: 0
      fill: transparent
    }
    height: 40
  }

  # --- MISALIGNED SCENARIO ---
  misaligned_section: "SCENARIO B: MISALIGNED LOAD PENALTY (CRITICAL)" {
    grid-columns: 1
    style.fill: "#fff5f5"
    style.stroke: "#cc0000"
    style.stroke-width: 2
    
    cl_mis_0: "CACHE LINE N (Offsets 0x00 - 0x3F)" {
      grid-columns: 3
      grid-gap: 15
      style.stroke-dash: 5
      
      off_3: "0x00" { class: offset_label }
      pre_data: "Preceding Data (Standard Alignment)" {
        class: avx_data
        width: 400
      }
      sz_3: "48 Bytes" { class: offset_label }
      
      off_4: "0x30" { class: offset_label }
      load_start: "AVX-512 Segment A (Split)" {
        class: penalty_data
        width: 400
      }
      sz_4: "16 Bytes" { class: offset_label }
    }

    boundary_crossing: "0x40 | CRITICAL BOUNDARY CROSSING (SPLIT CACHE ACCESS)" {
      style: {
        stroke: "#ff0000"
        stroke-width: 6
        font-color: "#ff0000"
        bold: true
      }
      height: 20
    }

    cl_mis_1: "CACHE LINE N+1 (Offsets 0x40 - 0x7F)" {
      grid-columns: 3
      grid-gap: 15
      style.stroke-dash: 5
      
      off_5: "0x40" { class: offset_label }
      load_end: "AVX-512 Segment B (Split)" {
        class: penalty_data
        width: 400
      }
      sz_5: "48 Bytes" { class: offset_label }
      
      off_6: "0x70" { class: offset_label }
      post_data: "Post Padding / Unrelated Data" {
        class: padding_data
        width: 400
      }
      sz_6: "16 Bytes" { class: offset_label }
    }
  }
}

# --- GLOBAL ANNOTATIONS ---
# Fix: Using constant value for 'near' for ELK compatibility
notes: |md
  ### SIMD Hardware Constraints & Optimization Manual
  - **AVX2 Alignment (ymm)**: Requires **32-byte** alignment. 
    - Using `vmovaps` on unaligned addresses causes `#GP(0)` fault.
    - Using `vmovups` (unaligned) is safer but slower if crossing lines.
  - **AVX-512 Alignment (zmm)**: Requires **64-byte** alignment.
    - Native width is 512-bits (64 bytes).
    - Alignment to 64B ensures the entire vector resides within a single cache line.
  - **The Split Load Penalty**: 
    - When a load straddles two cache lines (Scenario B), the Load/Store Unit (LSU) must split the operation.
    - **Latency**: Costs 2+ extra cycles to merge results from two different L1D sets.
    - **Throughput**: Consumes two load ports instead of one, causing stalls in superscalar execution.
  - **Implementation Strategy**:
    - Allocators should use `_mm_malloc(size, 64)` or `std::aligned_alloc(64, size)`.
    - Ensure `row_pitch` is a multiple of 64 bytes to maintain alignment across 2D structures.
| {
  near: bottom-center
  style.stroke-width: 1
  style.stroke: "#999999"
  style.fill: "#fafafa"
  style.border-radius: 4
}

# --- LEGEND ---
# Fix: Using constant value for 'near' for ELK compatibility
legend: "Hardware Memory Map Legend" {
  near: top-right
  direction: right
  
  l1: "AVX-512 Aligned" {
    class: memory_header
    width: 120
  }
  l2: "AVX2 Aligned" {
    class: avx_data
    width: 120
  }
  l3: "Padding (Inactive)" {
    class: padding_data
    width: 120
  }
  l4: "Boundary Split" {
    class: penalty_data
    width: 120
  }
}

# Logic Flow Indicator
simd_alignment_spec.aligned_section -> simd_alignment_spec.misaligned_section: "Optimization Comparison" {
  style.stroke-dash: 3
  style.stroke: "#666666"
  style.animated: true
}