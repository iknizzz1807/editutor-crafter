direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
  }
}

# STATE MACHINE: Tombstone Deletion Lifecycle
# Milestone Reference: vector-database-m1 (Storage Engine)

"●": {
  shape: circle
  style: {
    fill: black
    stroke-width: 0
  }
}

Active: {
  label: "ACTIVE STATE"
  description: |md
    **Invariant:**
    - `id_to_slot.contains(id)`
    - `metadata.is_deleted == false`
    - `slot.generation == current`
  |
  style.fill: "#E4DBFE"
}

Tombstoned: {
  label: "TOMBSTONED STATE"
  description: |md
    **Invariant:**
    - `!id_to_slot.contains(id)`
    - `metadata.is_deleted == true`
    - `index` resides in `free_list`
  |
  style.fill: "#FFF9C9"
}

Free: {
  label: "FREE / RECLAIMED"
  description: |md
    **Invariant:**
    - `!id_to_slot.contains(id)`
    - `slot == None`
    - `index` available for immediate reuse
  |
  style.fill: "#ACE1AF"
}

# Transitions

"●" -> Active: "Vector Ingest" {
  style.stroke: "#6772E5"
}

Active -> Tombstoned: "delete(id)" {
  label: |md
    **Trigger:** `delete(id)`
    **Guard:** `id` exists in `id_to_slot`
    **Action:** 
    1. `metadata.is_deleted = true`
    2. `id_to_slot.remove(id)`
    3. `free_list.push(index)`
  |
  style.font-color: "#9E2146"
}

Tombstoned -> Free: "compact()" {
  label: |md
    **Trigger:** `compact()`
    **Guard:** `live_count < capacity`
    **Action:** 
    1. Build `old_to_new` mapping
    2. Physically rewrite buffer
    3. `free_list.clear()`
  |
  style.stroke-dash: 3
}

Free -> Active: "insert(id)" {
  label: |md
    **Trigger:** `insert(id)`
    **Guard:** `free_list.len() > 0`
    **Action:** 
    1. `index = free_list.pop()`
    2. `generation++` (ABA Prevention)
    3. `write_vector(index)`
  |
  style.stroke: "#167c3c"
}

# ILLEGAL TRANSITIONS (Red Dashed)
Tombstoned -> Active: "ILLEGAL: Direct Recovery" {
  style: {
    stroke: red
    stroke-dash: 5
  }
}

Active -> Free: "ILLEGAL: Bypass Tombstone" {
  style: {
    stroke: red
    stroke-dash: 5
  }
}

# Legend/Annotation
Legend: {
  near: bottom-center
  shape: package
  label: "System Invariants"
  
  info: |md
    - **O(1) Check:** `id_to_slot` lookup
    - **O(N) Reclaim:** Physical compaction
    - **ABA Protection:** `slot.generation` increment on `Free -> Active`
  |
}