direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

# PERSISTENT STORAGE FILE FORMAT: MEMORY LAYOUT
# All fields are Little-Endian (LE) unless otherwise specified.
# Byte offsets are provided in the left column.

file_format: "Persistent Storage File Format (.bin)" {
  style: {
    stroke-width: 4
    fill: "#ffffff"
  }

  # --- HEADER SECTION (0x00 - 0x3F) ---
  header: {
    label: "FileHeader Segment (0x00 - 0x3F) | Total: 64 Bytes"
    style: {
      fill: "#DCD0FF" # Purple: Header
      stroke: "#9b59b6"
      stroke-width: 2
    }

    m_00: "0x00 | magic: [u8; 8] (\"VECTORS1\") | size: 8B"
    v_08: "0x08 | format_version: u32 | size: 4B"
    d_0C: "0x0C | raw_dimension: u32 | size: 4B"
    p_10: "0x10 | padded_dimension: u32 | size: 4B"
    c_14: "0x14 | total_capacity: u32 | size: 4B"
    l_18: "0x18 | live_vector_count: u32 | size: 4B"
    a_1C: "0x1C | alignment_bytes: u32 | size: 4B"
    r_20: "0x20 | _reserved: [u8; 32] (Zero Padding) | size: 32B" {
      style.fill: "#ecf0f1" # Gray: Padding
    }
  }

  cache_line_boundary: "----------------------- 64B CACHE LINE BOUNDARY (0x40) -----------------------" {
    shape: text
    style: {
      font-color: "#7f8c8d"
      stroke-dash: 5
      bold: true
    }
  }

  # --- VECTOR DATA SECTION ---
  vector_data: {
    label: "Vector Data Segment (0x40 - VARIES)"
    style: {
      fill: "#ebf5fb" # Blue: Data
      stroke: "#3498db"
      stroke-width: 2
    }

    data_payload: "0x40 | f32 Contiguous Array: [ capacity × padded_dim ] | size: (C * P * 4) Bytes"
    alignment_note: |md
      **IMPLEMENTATION DETAIL:**
      Each vector start index `i` is located at:
      `offset = 0x40 + (i * padded_dim * 4)`
      Ensure `padded_dim * 4` is a multiple of `FileHeader.alignment`.
    | {
      shape: text
      style.font-size: 12
    }
  }

  page_boundary: "======================= 4096B PAGE BOUNDARY (Varies) =======================" {
    shape: text
    style: {
      font-color: "#2c3e50"
      stroke-width: 3
      bold: true
    }
  }

  # --- ID MAP SECTION (Bincode Serialized) ---
  id_map: {
    label: "ID Mapping Segment (Bincode Encoded)"
    style: {
      fill: "#fef5e7" # Orange: Pointers/Mapping
      stroke: "#e67e22"
      stroke-width: 2
    }

    len_prefix: "OFFSET | id_map_len: u64 | size: 8B" { 
      style.fill: "#DCD0FF" 
      style.bold: true
    }
    hash_map_data: "OFFSET + 8 | HashMap<u64, (slot_idx: usize, gen: u32)> | size: Variable"
  }

  # --- SLOTS SECTION ---
  slots: {
    label: "Slot Registry Segment"
    style: {
      fill: "#ebf5fb" # Blue: Data
      stroke: "#3498db"
      stroke-width: 2
    }

    content: "OFFSET | [ (is_present: u8, external_id: u64, generation: u32) ] × capacity | size: Variable"
  }

  # --- METADATA SECTION (Bincode Serialized) ---
  metadata: {
    label: "Metadata Segment"
    style: {
      fill: "#ebf5fb"
      stroke: "#3498db"
      stroke-width: 2
    }

    meta_len: "OFFSET | metadata_len: u64 | size: 8B" { 
      style.fill: "#DCD0FF" 
      style.bold: true
    }
    meta_payload: "OFFSET + 8 | Vec<Option<VectorMetadata>> | size: Variable"
  }

  # Structural order for the linear file layout
  header -> cache_line_boundary -> vector_data -> page_boundary -> id_map -> slots -> metadata
}

# --- ANNOTATIONS & LEGEND ---
# Using constant positioning as required by ELK engine

annotations: {
  near: bottom-left
  growth_math: "Total File Size = 64 + (C * P * 4) + IDMap_Len + Slots_Len + Meta_Len + 16 (prefixes)" {
    shape: text
    style: {
      italic: true
      font-size: 14
    }
  }
  direction_indicator: "Disk Growth Direction: Linear (0x00 -> EOF) ➔" {
    shape: text
    style: {
      font-color: "#27ae60"
      bold: true
    }
  }
}

legend: {
  label: "Byte Layout Color Code"
  near: bottom-right
  style: {
    stroke: "#333333"
    fill: "#ffffff"
    stroke-width: 1
  }
  
  header_color: "Header / Prefix (Control)" {
    style.fill: "#DCD0FF"
  }
  data_color: "Vector / Component Data" {
    style.fill: "#ebf5fb"
  }
  padding_color: "Reserved / Alignment Padding" {
    style.fill: "#ecf0f1"
  }
  mapping_color: "Lookup / Index Mapping" {
    style.fill: "#fef5e7"
  }
}