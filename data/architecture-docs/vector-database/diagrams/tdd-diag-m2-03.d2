direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    center: true
  }
}

# -----------------------------------------------------------------------------
# GLOBAL CLASSES & STYLING
# -----------------------------------------------------------------------------
classes: {
  header_box: {
    style: {
      fill: "#673ab7"
      font-color: white
      bold: true
    }
  }
  data_lane: {
    style: {
      fill: "#2196f3"
      font-color: white
      stroke: "#0d47a1"
      stroke-width: 1
    }
  }
  operation_step: {
    style: {
      stroke: "#f44336"
      stroke-width: 2
      border-radius: 10
    }
  }
  code_block: {
    style: {
      stroke: "#673ab7"
      stroke-width: 1
      fill: "#f5f5f5"
      font: mono
    }
  }
}

# -----------------------------------------------------------------------------
# GLOBAL TITLE
# -----------------------------------------------------------------------------
title: {
  shape: text
  label: |md
    # AVX2 Horizontal Sum Reduction
    **Input:** `__m256` (8 x f32) → **Output:** `f32` (Scalar)
    *Algorithm: extract128 -> addps -> movehdup -> addps -> movehl -> addss*
  |
  near: top-center
}

# -----------------------------------------------------------------------------
# STEP 0: INITIAL STATE
# -----------------------------------------------------------------------------
Step_0: {
  class: operation_step
  label: "0. Input Register (__m256 v)"
  
  reg: {
    grid-columns: 8
    grid-gap: 0
    s7: "s7\n[255:224]" { class: data_lane }
    s6: "s6\n[223:192]" { class: data_lane }
    s5: "s5\n[191:160]" { class: data_lane }
    s4: "s4\n[159:128]" { class: data_lane }
    s3: "s3\n[127:96]" { class: data_lane }
    s2: "s2\n[95:64]" { class: data_lane }
    s1: "s1\n[63:32]" { class: data_lane }
    s0: "s0\n[31:0]" { class: data_lane }
  }
  
  details: {
    shape: text
    label: |md
      **YMM0 Layout (256-bit)**
      - **High Lane:** [255:128]
      - **Low Lane:** [127:0]
    |
  }
}

# -----------------------------------------------------------------------------
# STEP 1: EXTRACTION
# -----------------------------------------------------------------------------
Step_1: {
  class: operation_step
  label: "1. Extract 128-bit Lanes"
  
  hi: {
    label: "hi (__m128) [255:128]"
    grid-columns: 4
    grid-gap: 0
    style.fill: "#e3f2fd"
    h7: "s7"; h6: "s6"; h5: "s5"; h4: "s4"
  }
  
  lo: {
    label: "lo (__m128) [127:0]"
    grid-columns: 4
    grid-gap: 0
    style.fill: "#e3f2fd"
    l3: "s3"; l2: "s2"; l1: "s1"; l0: "s0"
  }

  instr: {
    class: code_block
    label: |cpp
      __m128 hi = _mm256_extractf128_ps(v, 1);
      __m128 lo = _mm256_castps256_ps128(v);
    |
  }
}

# -----------------------------------------------------------------------------
# STEP 2: PARALLEL ADDITION
# -----------------------------------------------------------------------------
Step_2: {
  class: operation_step
  label: "2. Vector Addition"
  
  sum128: {
    label: "sum128 = hi + lo"
    grid-columns: 4
    grid-gap: 0
    r3: "s3+s7" { style: { font-color: red; bold: true; fill: "#bbdefb" } }
    r2: "s2+s6" { style: { font-color: red; bold: true; fill: "#bbdefb" } }
    r1: "s1+s5" { style: { font-color: red; bold: true; fill: "#bbdefb" } }
    r0: "s0+s4" { style: { font-color: red; bold: true; fill: "#bbdefb" } }
  }

  instr: {
    class: code_block
    label: |cpp
      __m128 sum128 = _mm_add_ps(hi, lo);
    |
  }
}

# -----------------------------------------------------------------------------
# STEP 3: INTRA-LANE REDUCTION
# -----------------------------------------------------------------------------
Step_3: {
  class: operation_step
  label: "3. Horizontal Shuffle & Pairwise Add"
  
  shuf: {
    label: "shuf (_mm_movehdup_ps)"
    grid-columns: 4
    grid-gap: 0
    style.fill: "#e8f5e9"
    v3: "s3+s7"; v2: "s3+s7"; v1: "s1+s5"; v0: "s1+s5"
  }

  sums: {
    label: "sums (Partial Totals)"
    grid-columns: 4
    grid-gap: 0
    x3: "---"
    x2: "Σ(s2,3,6,7)" { style: { fill: "#ffcc80"; font-color: red; bold: true } }
    x1: "---"
    x0: "Σ(s0,1,4,5)" { style: { fill: "#ffcc80"; font-color: red; bold: true } }
  }

  instr: {
    class: code_block
    label: |cpp
      __m128 shuf = _mm_movehdup_ps(sum128);
      __m128 sums = _mm_add_ps(sum128, shuf);
    |
  }
}

# -----------------------------------------------------------------------------
# STEP 4: FINAL REDUCTION
# -----------------------------------------------------------------------------
Step_4: {
  class: operation_step
  label: "4. Final Scalar Extraction"
  
  res_box: {
    label: "Accumulated Sum: Σ(s0...s7)"
    style: {
      fill: "#fb8c00"
      stroke: "#e65100"
      stroke-width: 4
      font-color: white
      bold: true
      font-size: 18
    }
  }

  instr: {
    class: code_block
    label: |cpp
      // Move High-to-Low and Sum Scalars
      __m128 temp = _mm_movehl_ps(sums, sums);
      __m128 res  = _mm_add_ss(sums, temp);
      float out   = _mm_cvtss_f32(res);
    |
  }
}

# -----------------------------------------------------------------------------
# DATA FLOW CONNECTIONS
# -----------------------------------------------------------------------------

# Bit-accurate mapping
Step_0.reg.s7 -> Step_1.hi.h7: { style.stroke-dash: 3 }
Step_0.reg.s4 -> Step_1.hi.h4: { style.stroke-dash: 3 }
Step_0.reg.s3 -> Step_1.lo.l3: { style.stroke-dash: 3 }
Step_0.reg.s0 -> Step_1.lo.l0: { style.stroke-dash: 3 }

# Arithmetic flows
Step_1.hi -> Step_2.sum128: "SIMD ADD" { style.stroke: "#f44336"; style.stroke-width: 2 }
Step_1.lo -> Step_2.sum128: "SIMD ADD" { style.stroke: "#f44336"; style.stroke-width: 2 }

Step_2.sum128 -> Step_3.shuf: "Shuffle [1,1,3,3]"
Step_3.shuf -> Step_3.sums: "Pairwise Add"

Step_3.sums.x2 -> Step_4.res_box: "movehl" { style.stroke: "#ff9800"; style.animated: true }
Step_3.sums.x0 -> Step_4.res_box: "addss" { style.stroke: "#ff9800"; style.animated: true }

# Global Stage Connection
Step_0 -> Step_1 -> Step_2 -> Step_3 -> Step_4: {
  style.stroke-width: 6
  style.stroke: "#dddddd"
}

# -----------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------
legend: {
  near: bottom-right
  l_head: "LEGEND" { class: header_box }
  l_data: "Data Lane" { class: data_lane }
  l_change: "Resultant Value" {
    style: {
      fill: "#bbdefb"
      font-color: red
      bold: true
    }
  }
}