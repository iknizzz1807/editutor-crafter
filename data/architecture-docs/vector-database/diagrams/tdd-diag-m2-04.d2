layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
  }
}

# --- HEADER AND CONTEXT ---
title: |md
  # Kahan Summation: Precision Recovery Logic
  ### Goal: Accumulate 768 products without O(N) float32 drift
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# --- LEGEND ---
legend: {
  near: bottom-right
  val_change: "Value Changed (Step Target)" {
    style: {
      stroke: red
      stroke-width: 4
      fill: "#ffcccc"
    }
  }
  precision_loss: "IEEE 754 Truncation / Drift" {
    style: {
      stroke-dash: 3
      stroke: gray
    }
  }
  data_field: "Stable Data Field" {
    style: {
      fill: "#B6DDF6"
    }
  }
}

# --- ALGORITHM STEPS ---

step_1: "1. Correct Input (y = input - c)" {
  registers: {
    grid-columns: 2
    grid-gap: 0
    
    r1_n: "sum [f32]" {style.stroke: gray}
    r1_v: "1000.0000" {style.fill: "#B6DDF6"}
    
    r2_n: "c [error]" {style.stroke: gray}
    r2_v: "-0.0000012" {style.fill: lightgray}
    
    r3_n: "input [val]" {style.stroke: gray}
    r3_v: "0.0000055" {style.fill: "#B6DDF6"}
    
    r4_n: "y [corrected]" {style.stroke: red; style.stroke-width: 3}
    r4_v: "0.0000067" {
      style: {
        fill: "#ffcccc"
        bold: true
      }
    }
  }
  annotation: |md
    ### Step 1: Error Compensation
    `c` tracks the lost precision from the *previous* addition.
    By subtracting `c` from the current `input`, we "re-inject" the 
    lost bits back into the flow before they are truncated again.
  |
}

step_2: "2. Trial Addition (t = sum + y)" {
  registers: {
    grid-columns: 2
    grid-gap: 0
    
    r1_n: "sum [f32]" {style.stroke: gray}
    r1_v: "1000.0000" {style.fill: "#B6DDF6"}
    
    r2_n: "y [corrected]" {style.stroke: gray}
    r2_v: "0.0000067" {style.fill: "#B6DDF6"}
    
    r3_n: "t [trial]" {style.stroke: red; style.stroke-width: 3}
    r3_v: "1000.0000" {
      style: {
        fill: "#ffcccc"
        bold: true
      }
    }
    
    loss_label: "Shift-out Loss" {style.stroke: gray; style.stroke-dash: 3}
    loss_val: "0.0000067" {style.stroke: gray; style.stroke-dash: 3}
  }
  annotation: |md
    ### Step 2: The Precision Gap
    `sum` is 10^3, `y` is ~10^-6. 
    The 23-bit mantissa of an `f32` cannot hold both.
    Adding `y` causes its lower bits to shift right and drop.
    `t` becomes exactly 1000.0000.
  |
}

step_3: "3. Error Capture (c = (t - sum) - y)" {
  registers: {
    grid-columns: 2
    grid-gap: 0
    
    r1_n: "t [trial]" {style.stroke: gray}
    r1_v: "1000.0000" {style.fill: "#B6DDF6"}
    
    r2_n: "sum [prev]" {style.stroke: gray}
    r2_v: "1000.0000" {style.fill: "#B6DDF6"}
    
    r3_n: "diff [high bits]" {style.stroke: gray}
    r3_v: "0.0000" {style.fill: "#B6DDF6"}
    
    r4_n: "y [input]" {style.stroke: gray}
    r4_v: "0.0000067" {style.fill: "#B6DDF6"}
    
    r5_n: "c [new error]" {style.stroke: red; style.stroke-width: 3}
    r5_v: "-0.0000067" {
      style: {
        fill: "#ffcccc"
        bold: true
      }
    }
  }
  annotation: |md
    ### Step 3: Mathematical Recovery
    Algebraically, `(sum + y) - sum - y` should be 0.
    In floating point:
    1. `(t - sum)` recovers the *actual* increment applied.
    2. Subtracting `y` from that increment reveals the **lost part**.
  |
}

step_4: "4. Update Accumulator (sum = t)" {
  registers: {
    grid-columns: 2
    grid-gap: 0
    
    r1_n: "sum [final]" {style.stroke: red; style.stroke-width: 3}
    r1_v: "1000.0000" {
      style: {
        fill: "#ffcccc"
        bold: true
      }
    }
    
    r2_n: "c [carry-forward]" {style.stroke: gray}
    r2_v: "-0.0000067" {style.fill: lightgray}
  }
  annotation: |md
    ### Step 4: Finalization
    We store the trial sum. Even though `sum` is "missing" the bits, 
    the variable `c` now holds them for the next loop.
  |
}

# --- CONNECTIONS ---

step_1 -> step_2: "Compute trial result"
step_2 -> step_3: "Quantify loss"
step_3 -> step_4: "Store state"
step_4 -> step_1: "Next iteration (i+1)" {
  style.stroke-dash: 5
  style.animated: true
}

# --- COMPARISON VIEW ---

comparison: "Accumulation Drift (768 Dimensions)" {
  style.fill: "#f9f9f9"
  style.stroke-width: 2
  
  scalar_sum: "Standard Float32 Accumulation" {
    shape: rectangle
    style.stroke: red
    label: |md
      **Error: O(N * ε)**
      Loss: ~5.1e-4
      [#######---]
      Bits lost: 7-9
    |
  }
  
  kahan_sum: "Kahan Recovery Accumulation" {
    shape: rectangle
    style.stroke: green
    label: |md
      **Error: O(ε)**
      Loss: ~1.2e-7
      [##########]
      Full precision maintained
    |
  }
}

step_2.registers.loss_val -> comparison.scalar_sum: "Uncaptured Drift" {
  style.stroke: red
  style.stroke-width: 2
}

# --- BIT LEVEL MAPPING ---

bits: "IEEE 754 f32 Internal Visualization" {
  grid-columns: 1
  style.fill: "#f0f4f8"
  
  sum_bits: "Sum (Exponent: 136): [0][10001000][11110100004400000000000]" {
    style.font: mono
    style.font-size: 14
  }
  y_bits: "   y (Exponent: 109): [0][01101101][11011110000000000000000]" {
    style.font: mono
    style.font-size: 14
  }
  t_bits: "   t (Trial Result):  [0][10001000][11110100004400000000000] <--- TRUNCATED" {
    style.font: mono
    style.font-color: red
    style.font-size: 14
    style.bold: true
  }
}

step_2 -> bits: "Mantissa Alignment (27-bit Shift)" {
  style.stroke-dash: 2
}

# --- GLOBAL STYLING ---
***.style.border-radius: 4
(*** -> ***)[*]: {
  style.stroke: "#444444"
}