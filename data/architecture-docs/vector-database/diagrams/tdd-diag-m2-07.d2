direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

DistanceMetricsHierarchy: "M2: Distance Engine - Metric Trait Hierarchy" {
  style: {
    stroke: "#4B0082"
    stroke-width: 4
    fill: "#F8F8FF"
    double-border: true
  }

  Metric: {
    shape: class
    label: "<<trait>>\nMetric"
    tooltip: "Core interface for all distance and similarity computations."
    
    # Method Signatures: Type-safe and implementation-ready
    "distance(a: &[f32], b: &[f32])": "f32"
    "is_similarity()": "bool"
    "name()": "&'static str"
    "batch_distance(query: &[f32], vectors: I)": "Vec<(u64, f32)>"
    
    style: {
      stroke: "#4B0082"
      stroke-width: 3
      fill: "#E6E6FA"
      font-size: 16
      bold: true
    }
  }

  DotProduct: {
    shape: class
    label: "DotProductMetric"
    "is_similarity()": "true"
    "name()": "\"dot\""
    "distance()": "Σ(a_i * b_i)"
    
    # Memory Layout Metadata
    _meta: "sizeof = 0 bytes (ZST)" {
      style: {
        font-size: 11
        italic: true
        font-color: "#546E7A"
      }
    }
    style: {
      fill: "#E3F2FD"
      stroke: "#1E88E5"
      stroke-width: 2
    }
  }

  Euclidean: {
    shape: class
    label: "EuclideanMetric"
    "is_similarity()": "false"
    "name()": "\"l2\""
    "distance()": "sqrt(Σ(a_i - b_i)²)"
    
    _meta: "sizeof = 0 bytes (ZST)" {
      style: {
        font-size: 11
        italic: true
        font-color: "#546E7A"
      }
    }
    style: {
      fill: "#E3F2FD"
      stroke: "#1E88E5"
      stroke-width: 2
    }
  }

  Cosine: {
    shape: class
    label: "CosineMetric"
    "is_similarity()": "false"
    "name()": "\"cosine\""
    "distance()": "1.0 - (dot / (norm_a * norm_b))"
    
    _meta: "sizeof = 0 bytes (ZST)" {
      style: {
        font-size: 11
        italic: true
        font-color: "#546E7A"
      }
    }
    style: {
      fill: "#E3F2FD"
      stroke: "#1E88E5"
      stroke-width: 2
    }
  }

  # Implementation Relationships
  DotProduct -> Metric: "implements" {
    style: {
      stroke: "#4B0082"
      stroke-width: 2
      stroke-dash: 5
    }
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
  }

  Euclidean -> Metric: "implements" {
    style: {
      stroke: "#4B0082"
      stroke-width: 2
      stroke-dash: 5
    }
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
  }

  Cosine -> Metric: "implements" {
    style: {
      stroke: "#4B0082"
      stroke-width: 2
      stroke-dash: 5
    }
    target-arrowhead: {
      shape: triangle
      style.filled: false
    }
  }
}

Types: {
  near: top-right
  label: "Type Definitions & Alignment"
  
  # Technical Spec for Engineers
  "f32": "IEEE 754 (4 Bytes) | Align: 32B (AVX)"
  "u64": "Vector ID (8 Bytes)"
  "I": "Iterator<Item = (u64, &[f32])>"
  "SIMD": "Targets: AVX2, AVX-512, NEON"
  
  style: {
    fill: "#FFFACD"
    stroke: "#DAA520"
    stroke-dash: 3
    stroke-width: 2
    font-size: 13
  }
}

Legend: {
  near: bottom-center
  
  Header: "Diagram Notation" {
    ImplLink: "Trait Implementation" {
      style.font-size: 12
    }
    TraitRef: "Target Interface" {
      style.opacity: 0.6
    }
    ImplLink -> TraitRef: {
      style: {
        stroke-dash: 5
        stroke-width: 2
      }
      target-arrowhead: {
        shape: triangle
        style.filled: false
      }
    }
  }
  
  ImplementationNotes: |md
    ### ⚠️ Implementation Critical Path
    1. **Zero-Cost Abstraction**: All `Metric` types are ZSTs. No heap allocation on init.
    2. **SIMD Alignment**: All input slices `&[f32]` MUST be 32-byte aligned for AVX-512 optimization paths.
    3. **Polarity**: `is_similarity()` return value determines `TopKSelector` priority (Max-Heap for similarity, Min-Heap for distance).
    4. **Cache Usage**: `batch_distance` utilizes prefetching for the `query` vector to keep it in L1 cache during iteration.
  |

  style: {
    stroke: "#B0BEC5"
    stroke-width: 1
    fill: "#ECEFF1"
    border-radius: 8
    shadow: true
  }
}

# Explicit sizing for documentation clarity
DistanceMetricsHierarchy.Metric.width: 320
DistanceMetricsHierarchy.DotProduct.width: 280
DistanceMetricsHierarchy.Euclidean.width: 280
DistanceMetricsHierarchy.Cosine.width: 280