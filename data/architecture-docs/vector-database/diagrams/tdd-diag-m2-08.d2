direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- STYLING & CLASSES ---
classes: {
  header_cell: {
    style: {
      fill: "#2c3e50"
      font-color: "#ffffff"
      bold: true
      stroke: "#1a252f"
      stroke-width: 2
    }
  }
  metric_similarity: {
    style: {
      fill: "#d1e7dd"
      stroke: "#0f5132"
      font-color: "#0f5132"
      bold: true
    }
  }
  metric_distance: {
    style: {
      fill: "#f8d7da"
      stroke: "#842029"
      font-color: "#842029"
      bold: true
    }
  }
  heap_min: {
    style: {
      fill: "#fff3cd"
      stroke: "#856404"
      stroke-dash: 2
    }
  }
  heap_max: {
    style: {
      fill: "#cfe2ff"
      stroke: "#084298"
      stroke-dash: 2
    }
  }
  byte_header: {
    style: {
      fill: "#E1BEE7" # Purple (Header)
      font-color: black
      bold: true
    }
  }
  byte_data: {
    style: {
      fill: "#BBDEFB" # Blue (Data)
      font-color: black
    }
  }
  byte_padding: {
    style: {
      fill: "#E0E0E0" # Gray (Padding)
      opacity: 0.8
    }
  }
  offset_label: {
    style: {
      font-size: 10
      font: mono
      stroke-width: 0
    }
  }
}

# --- DOCUMENTATION TITLE ---
title: |md
  # TOP-K SELECTION CONVENTION
  ## Implementation Reference for Vector Search Heaps
| {
  near: top-center
}

# --- MAIN CONTENT WRAPPER ---
# We use a container to avoid the grid-cell 'near' error and manage layout flow
Vector_Engine_Reference: {
  
  # --- ORDERING CONVENTION TABLE ---
  ordering_convention: {
    label: "Metric to Heap Mapping Table"
    grid-columns: 5
    grid-gap: 0
    style.stroke: "#333333"
    style.stroke-width: 1

    # Header Row
    h1: "METRIC" { class: header_cell }
    h2: "TYPE" { class: header_cell }
    h3: "RANGE" { class: header_cell }
    h4: "OPTIMAL" { class: header_cell }
    h5: "HEAP TYPE" { class: header_cell }

    # Dot Product
    r1c1: "Dot Product (IP)"
    r1c2: "Similarity" { class: metric_similarity }
    r1c3: "(-inf, +inf)"
    r1c4: "Higher is Better"
    r1c5: "MIN-HEAP\n(Root = Smallest)" { class: heap_min; tooltip: "Evict if new > root" }

    # Euclidean
    r2c1: "L2 (Euclidean)"
    r2c2: "Distance" { class: metric_distance }
    r2c3: "[0, +inf)"
    r2c4: "Lower is Better"
    r2c5: "MAX-HEAP\n(Root = Largest)" { class: heap_max; tooltip: "Evict if new < root" }

    # Cosine Similarity
    r3c1: "Cosine Similarity"
    r3c2: "Similarity" { class: metric_similarity }
    r3c3: "[-1, 1]"
    r3c4: "Higher is Better"
    r3c5: "MIN-HEAP\n(Root = Smallest)" { class: heap_min }

    # Jaccard / Hamming
    r4c1: "Hamming Dist"
    r4c2: "Distance" { class: metric_distance }
    r4c3: "[0, bit_len]"
    r4c4: "Lower is Better"
    r4c5: "MAX-HEAP\n(Root = Largest)" { class: heap_max }
  }

  # --- DATA STRUCTURE MEMORY LAYOUT ---
  search_result_struct: {
    label: "struct SearchResult (Packed Alignment)"
    
    grid-columns: 1
    grid-gap: 10
    style.fill: "#f9f9f9"

    mem_view: {
      grid-columns: 3
      grid-gap: 0
      
      o0: "0x00" { class: offset_label }
      f0: "Vector ID (u64 / Primary Key)" { class: byte_header; width: 300 }
      s0: "8 Bytes" { class: offset_label }

      o1: "0x08" { class: offset_label }
      f1: "Score (f32 / Metric Result)" { class: byte_data; width: 300 }
      s1: "4 Bytes" { class: offset_label }

      o2: "0x0C" { class: offset_label }
      f2: "Alignment Padding (Reserved)" { class: byte_padding; width: 300 }
      s2: "4 Bytes" { class: offset_label }
    }
    
    footer: "sizeof(SearchResult) = 16 Bytes (128 bits)" {
      shape: text
      style.italic: true
      style.font-size: 12
    }
  }

  # --- ALGORITHM STATE: TOP-K UPDATE ---
  algorithm_logic: {
    label: "Update Top-K Selection Logic (TDD)"

    step_1: |md
      ### Step 1: Compare
      Evaluate incoming candidate `C`.
      rust
      let root = heap.peek();
      let is_better = if is_similarity {
          C.score > root.score
      } else {
          C.score < root.score
      };
      
    |
    
    step_2: |md
      ### Step 2: Swap & Re-Heap
      If `is_better` is **true**:
      1. `heap.pop_root()` -> Remove weakest candidate
      2. `heap.push(C)` -> Insert new candidate
      3. `heapify_down()` -> Restore heap property
    |
    
    step_1 -> step_2: "Result: Better Result Found" {
      style.stroke: green
      style.bold: true
    }
  }

  ordering_convention -> search_result_struct: "Constraint: Alignment"
  search_result_struct -> algorithm_logic: "Update State"
}

# --- EXTERNAL ACTORS & FLOW ---
M2: "Metric Calculation Engine" {
  shape: diamond
  style.fill: "#eeeeee"
}
M3: "Heap-based Top-K Collector" {
  shape: parallelogram
  style.fill: "#eeeeee"
}

M2 -> Vector_Engine_Reference.ordering_convention: "Provides Raw Score"
Vector_Engine_Reference.ordering_convention -> M3: "Configures Heap Direction"
M3 -> Vector_Engine_Reference.search_result_struct: "Serializes Output"

# --- GLOBAL STYLES ---
***.style.font: mono
(*** -> ***)[*].style.stroke: orange
(*** -> ***)[*].style.stroke-width: 2