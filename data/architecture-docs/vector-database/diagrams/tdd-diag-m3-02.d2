direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Max-Heap Top-K Selection Algorithm
  **Context:** Finding $k$ smallest distances (nearest neighbors)
  **Invariant:** Root of Max-Heap is the **worst** (largest) distance in current top-$k$.
| {
  near: top-center
  shape: text
}

step_1: "Step 1: Initialization" {
  k_val: "Config: k = 3"
  heap: "Empty Max-Heap" {
    shape: circle
    style.stroke-dash: 3
  }
  input: "Candidate (ID: 10, Dist: 5.2)" {
    shape: parallelogram
  }
  input -> heap: "Insert directly"
}

step_2: "Step 2: Initial Filling" {
  heap: {
    root: "ID: 12 | Dist: 7.8" {
      style.fill: "#ffcccc"
      tooltip: "Worst (Max) Distance"
    }
    l: "ID: 10 | Dist: 5.2"
    r: "ID: 11 | Dist: 3.1"
    root -> l
    root -> r
  }
  status: "Heap is FULL (count = 3)" {
    shape: text
  }
}

step_3: "Step 3: Comparison" {
  incoming: "ID: 13 | Dist: 2.1" {
    shape: parallelogram
    style.stroke: red
    style.bold: true
  }
  heap_root: "ID: 12 | Dist: 7.8" {
    style.fill: "#ffcccc"
  }
  
  logic: "2.1 < 7.8?" {
    shape: diamond
  }
  
  incoming -> logic
  heap_root -> logic
  logic -> action: "TRUE: Better candidate found" {
    style.stroke: green
  }
}

step_4: "Step 4: Eviction & Rebalance" {
  evicted: "ID: 12 | Dist: 7.8" {
    style.stroke: red
    style.stroke-dash: 5
    style.opacity: 0.5
  }
  
  new_heap: {
    root: "**ID: 10 | Dist: 5.2**" {
      style.fill: "#ffcccc"
      style.stroke: red
    }
    l: "**ID: 13 | Dist: 2.1**" {
      style.stroke: red
    }
    r: "ID: 11 | Dist: 3.1"
    root -> l
    root -> r
  }
  
  evicted -> new_heap.root: "Pop root, Push 2.1, Heapify" {
    style.animated: true
  }
}

step_5: "Step 5: Extraction & Sort" {
  raw_list: "[5.2, 2.1, 3.1]" {
    shape: step
  }
  
  final_sort: "Final Result (Best First)" {
    r1: "1. ID: 13 | Dist: 2.1" { style.fill: "#ccffcc" }
    r2: "2. ID: 11 | Dist: 3.1"
    r3: "3. ID: 10 | Dist: 5.2"
    r1 -> r2 -> r3
  }
  
  raw_list -> final_sort: "Ascending Sort (Distances)"
}

step_1 -> step_2 -> step_3 -> step_4 -> step_5

legend: {
  near: bottom-center
  m1: "Red/Bold: Mutated state" { style.font-color: red }
  m2: "Pink: Max-Heap Root (Worst in set)" { style.fill: "#ffcccc" }
  m3: "Green: Nearest Neighbor (Best)" { style.fill: "#ccffcc" }
}