layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    center: true
    pad: 20
  }
}

# --- COMPLEXITY COMPARISON SECTION ---
complexity_comparison: "Top-K Selection Strategy: Computational Cost Comparison" {
  description: |md
    ### Scenario: N=1,000,000 vectors, k=10
    Evaluation of total comparisons required to determine the top-k nearest neighbors 
    after distance calculation. 
    **Metric:** Total floating-point comparisons ($C$).
  |
  style: {
    fill: "#f8f9fa"
    stroke: "#2c3e50"
    stroke-width: 2
  }

  visual_bench: {
    grid-columns: 1
    vertical-gap: 80

    heap_method: {
      label: "O(N log k) - Bounded Max-Heap"
      
      bar_container: {
        bar: " " {
          width: 165
          height: 40
          style: {
            fill: "#4baae5"
            stroke: "#2c3e50"
            stroke-width: 2
            shadow: true
          }
        }
      }
      
      metrics: {
        shape: sql_table
        comparisons: "uint64" {constraint: "3,321,928 ops"}
        memory_overhead: "byte_size" {constraint: "40B (k * sizeof(f32))"}
        complexity: "notation" {constraint: "O(N log k)"}
        cache_locality: "rating" {constraint: "HIGH"}
        status: "flag" {
          label: "OPTIMAL"
          style.fill: "#ACE1AF"
          style.bold: true
        }
      }
      
      (bar_container.bar -> metrics)[0]: "6.06x Speedup" {
        style: {
          stroke: "#167c3c"
          stroke-width: 3
          animated: true
        }
      }
    }

    sort_method: {
      label: "O(N log N) - Naive Full Sort"
      
      bar_container: {
        bar: " " {
          width: 800
          height: 40
          style: {
            fill: "#FE7070"
            stroke: "#9E2146"
            stroke-width: 2
            shadow: true
          }
        }
      }
      
      metrics: {
        shape: sql_table
        comparisons: "uint64" {constraint: "19,931,568 ops"}
        memory_overhead: "byte_size" {constraint: "4.0MB (N * sizeof(f32))"}
        complexity: "notation" {constraint: "O(N log N)"}
        cache_locality: "rating" {constraint: "LOW (Thrashing)"}
        status: "flag" {
          label: "INEFFICIENT"
          style.fill: "#FFCCCB"
          style.bold: true
        }
      }
      
      (bar_container.bar -> metrics)[0]: "Baseline"
    }
  }

  legend: "Selection Logic Reference" {
    near: bottom-right
    content: |md
      **Selection Logic Details:**
      - **Heap**: Maintains a k-element Bounded Max-Heap. 
        Only $N$ comparisons against `heap.top()`.
        Insertions are $O(\log k)$.
      - **Sort**: Collects all $N$ distances into contiguous memory. 
        Sorting is $O(N \log N)$ with Quicksort/Timsort.
    |
    style: {
      stroke-dash: 2
      fill: "#fdfdfd"
      border-radius: 5
    }
  }
}

# --- ARCHITECTURAL CLASS DEFINITIONS ---
selection_logic: "TopKSelector Implementation" {
  shape: class
  style.fill: "#eef2f3"
  style.stroke: "#4baae5"
  style.stroke-width: 2
  
  +heap_size: uint32 = 10
  +current_max: float32
  +elements: "MaxHeapNode[k]"
  
  +push(dist: float32, id: uint32): void
  +peek(): float32
  +replace_max(dist: float32, id: uint32): void
  +extract_sorted(): "VectorID[]"
}

# --- INTEL-STYLE MEMORY LAYOUT ---
heap_node_layout: "Memory Layout: Max-Heap Node" {
  style.fill: "#ffffff"
  style.stroke: "#333333"
  style.stroke-width: 2

  grid: {
    grid-columns: 4
    grid-gap: 0
    
    # Header Row
    h1: "Offset" {style.bold: true; style.fill: "#eeeeee"}
    h2: "Field" {style.bold: true; style.fill: "#eeeeee"}
    h3: "Size" {style.bold: true; style.fill: "#eeeeee"}
    h4: "Color Key" {style.bold: true; style.fill: "#eeeeee"}

    # Data Rows
    row1_off: "0x00"
    row1_fld: "distance (f32)"
    row1_siz: "4B"
    c1: " " {style.fill: "#4baae5"} # Data (Blue)

    row2_off: "0x04"
    row2_fld: "vector_id (u32)"
    row2_siz: "4B"
    c2: " " {style.fill: "#f39c12"} # Pointer/ID (Orange)

    row3_off: "0x08"
    row3_fld: "padding (alignment)"
    row3_siz: "8B"
    c3: " " {style.fill: "#d3d3d3"} # Padding (Gray)
  }

  footer: "Total Size: 16 Bytes (Aligned to 64-bit word boundary)" {
    shape: text
    style.font-size: 11
    style.italic: true
  }
}

# --- CONNECTIONS & INTERFACES ---
storage_engine: "M1: Vector Storage" {
  shape: cylinder
  style.fill: "#DEE1EB"
}

# System flow
complexity_comparison.visual_bench.heap_method -> storage_engine: "Reads via iter_live()" {
  style.stroke-dash: 5
  style.stroke: "#7f8c8d"
}

# Implements interface connection (hollow triangle)
selection_logic -> complexity_comparison.visual_bench.heap_method.metrics: "Implements Strategy" {
  source-arrowhead: {
    shape: triangle
    style.filled: false
  }
}

# Link layout to code
selection_logic -> heap_node_layout: "Memory structure" {
  style.stroke: "#f39c12"
}

# --- DIAGRAM ANNOTATIONS (INTEL SPEC STYLE) ---

# Page boundary indicator
page_boundary: "--- 4096B Page Boundary ---" {
  shape: text
  near: top-center
  style: {
    font-size: 14
    font-color: "#333333"
    bold: true
  }
}

# Cache Line indicators
cl_indicator: "--- 64B Cache Line Boundary (Dashed) ---" {
  shape: text
  near: bottom-center
  style: {
    font-size: 11
    font-color: "#e74c3c"
    stroke-dash: 3
  }
}

# Global Style Overrides for Manual Quality
***.style.font: mono
(*** -> ***)[*]: {
  style.stroke-width: 1.5
}