direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

# --- CLASSES ---
classes: {
  json_object: {
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      stroke-width: 3
      border-radius: 4
      shadow: true
    }
  }
  json_array: {
    style: {
      fill: "#F3E5F5"
      stroke: "#4A148C"
      stroke-width: 2
      stroke-dash: 4
    }
  }
  spec_box: {
    style: {
      fill: "#FAFAFA"
      stroke: "#757575"
      stroke-width: 1
      border-radius: 8
    }
  }
}

# --- SCHEMA STRUCTURE ---

ground_truth: GroundTruth Root {
  class: json_object
  metric_name: "string [cosine|l2|ip]"
  k: "u32 (neighbor depth)"
  queries: "Array<QueryEntry>"
  
  label: "GroundTruth Container\n(Serialized Export Root)"
}

query_entry: QueryEntry {
  class: json_object
  query_vector: "f32[D] (Dense Vector)"
  results: "Array<NeighborPair>"
  
  label: "QueryEntry\n(Query Context + Results)"
}

neighbor_pair: NeighborPair {
  class: json_object
  id: "u64 (Internal Vector ID)"
  distance: "f32 (Calculated Score)"
  
  label: "NeighborPair\n(Candidate Result)"
}

# --- RELATIONSHIPS ---

# ERROR FIXED: source-arrowhead and target-arrowhead moved outside of the style block.
(ground_truth.queries -> query_entry): "Composition (1..N)" {
  source-arrowhead: * {
    shape: diamond
    style.filled: true
  }
  target-arrowhead: triangle
  style: {
    stroke: "#4A148C"
    stroke-width: 3
  }
}

# ERROR FIXED: source-arrowhead and target-arrowhead moved outside of the style block.
(query_entry.results -> neighbor_pair): "Result Set (K entries)" {
  source-arrowhead: * {
    shape: diamond
    style.filled: true
  }
  target-arrowhead: triangle
  style: {
    stroke: "#4A148C"
    stroke-width: 3
  }
}

# --- IMPLEMENTATION DETAILS ---

implementation_spec: |md
  ### Serialization Specification
  - **Encoding**: UTF-8 JSON Standard
  - **Float Precision**: IEEE 754 decimal
  - **Ordering Invariants**: 
    - `queries` follows the input query sequence.
    - `results` must be sorted by `distance` ASC (for L2) or DESC (for Cosine).
  - **Compliance**: Required for Recall@K evaluation pipelines.
| {
  class: spec_box
  near: top-right
}

# --- DATA LAYOUT EXAMPLE ---

example_json: |json
  {
    "metric_name": "cosine",
    "k": 3,
    "queries": [
      {
        "query_vector": [0.1, 0.2, 0.5],
        "results": [
          {"id": 1042, "distance": 0.001},
          {"id": 88,   "distance": 0.015},
          {"id": 921,  "distance": 0.044}
        ]
      }
    ]
  }
| {
  shape: code
  label: "Serialized Export Example (Reference)"
  near: bottom-left
}

# --- METRICS ANNOTATION ---

size_estimate: |md
  ### Storage Overhead Estimate
  - **Fixed Header**: ~128 bytes
  - **Per Query (Estimate)**:
    - $D \times 12$ bytes (Vector Data)
    - $K \times 48$ bytes (Neighbor Metadata)
  - **Example (D=768, K=10)**: 
    - Approx 8.1 KB per query entry
    - 1M queries = ~8.1 GB Storage
| {
  class: spec_box
  near: bottom-right
}

# --- HEADER TITLE ---
title: |md
  # VECTOR DB: GROUND TRUTH EXPORT FORMAT (JSON)
  ## TDD Section M3-06: Evaluator Interface
| {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}