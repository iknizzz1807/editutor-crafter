direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# -----------------------------------------------------------------------------
# CLASSES FOR ALGORITHM STATE VISUALIZATION
# -----------------------------------------------------------------------------
classes: {
  intersection_hit: {
    style: {
      stroke: "#d73a49"
      stroke-width: 4
      fill: "#fff5f5"
      font-color: "#d73a49"
      bold: true
      shadow: true
    }
  }
  metric_box: {
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
      stroke-width: 2
      border-radius: 5
    }
  }
  gt_header: {
    style: {
      fill: "#e8f5e9"
      stroke: "#2e7d32"
    }
  }
  hnsw_header: {
    style: {
      fill: "#fff3e0"
      stroke: "#ef6c00"
    }
  }
}

# -----------------------------------------------------------------------------
# RECALL@K CALCULATION ALGORITHM
# -----------------------------------------------------------------------------
recall_calculation: {
  grid-columns: 2
  grid-gap: 60
  style: {
    stroke: "#444444"
    stroke-width: 1
    fill: "#fdfdfd"
  }

  # --- STEP 1 ---
  step_1: "1. Extract Top-K Sets" {
    description: |md
      ### Extraction Phase
      Extract the top-k results from the **Ground Truth** (Brute Force) index and the **Approximate** (HNSW) index.
      
      **Configuration:**
      - `k = 5`
      - Metric: Euclidean (L2) Distance
    |
    
    exact_list: "Ground Truth (S_exact)" {
      shape: sql_table
      class: gt_header
      id_10: "ID: 10" {constraint: "dist: 0.12"}
      id_22: "ID: 22" {constraint: "dist: 0.15"}
      id_35: "ID: 35" {constraint: "dist: 0.18"}
      id_48: "ID: 48" {constraint: "dist: 0.21"}
      id_51: "ID: 51" {constraint: "dist: 0.25"}
    }

    approx_list: "HNSW Results (S_approx)" {
      shape: sql_table
      class: hnsw_header
      id_10: "ID: 10" {constraint: "dist: 0.12"}
      id_22: "ID: 22" {constraint: "dist: 0.15"}
      id_99: "ID: 99" {constraint: "dist: 0.19"}
      id_48: "ID: 48" {constraint: "dist: 0.22"}
      id_51: "ID: 51" {constraint: "dist: 0.26"}
    }
  }

  # --- STEP 2 ---
  step_2: "2. Identity Set Intersection" {
    description: |md
      ### Comparison Phase
      Perform logical intersection: `Hits = S_exact ∩ S_approx`.
      Identify elements present in the Ground Truth set that were successfully retrieved by the ANN index.
    |

    comparison_view: {
      direction: right
      set_exact: "S_exact" {
        style.stroke-dash: 3
        id_10: "10" {class: intersection_hit}
        id_22: "22" {class: intersection_hit}
        id_35: "35" {style.opacity: 0.4}
        id_48: "48" {class: intersection_hit}
        id_51: "51" {class: intersection_hit}
      }

      set_approx: "S_approx" {
        style.stroke-dash: 3
        id_10: "10" {class: intersection_hit}
        id_22: "22" {class: intersection_hit}
        id_99: "99" {style.stroke: gray; style.opacity: 0.4}
        id_48: "48" {class: intersection_hit}
        id_51: "51" {class: intersection_hit}
      }
      
      set_exact.id_10 -> set_approx.id_10: "HIT" {style: {stroke: "#d73a49"; stroke-width: 2; animated: true}}
      set_exact.id_22 -> set_approx.id_22: "HIT" {style: {stroke: "#d73a49"; stroke-width: 2; animated: true}}
      set_exact.id_48 -> set_approx.id_48: "HIT" {style: {stroke: "#d73a49"; stroke-width: 2; animated: true}}
      set_exact.id_51 -> set_approx.id_51: "HIT" {style: {stroke: "#d73a49"; stroke-width: 2; animated: true}}
    }
  }

  # --- STEP 3 ---
  step_3: "3. Compute Cardinality" {
    description: |md
      ### Aggregation Phase
      Calculate numerator and denominator for the recall ratio. 
      `n = |Hits|`
      `k = |S_exact|`
    |
    
    intersection_logic: "Intersection Result" {
      style.fill: "#fff5f5"
      
      items: {
        grid-columns: 2
        i10: "10" {class: intersection_hit}
        i22: "22" {class: intersection_hit}
        i48: "48" {class: intersection_hit}
        i51: "51" {class: intersection_hit}
      }
      
      metrics: {
        count_box: "Numerator (n) = 4" {
          class: metric_box
          style.bold: true
        }
        k_param: "Denominator (k) = 5" {
          shape: rectangle
          style: {
            fill: "#f3e5f5"
            stroke: "#7b1fa2"
            bold: true
            border-radius: 5
          }
        }
      }
    }
  }

  # --- STEP 4 ---
  step_4: "4. Final Recall@K" {
    description: |md
      ### Final Calculation
      The ratio represents the percentage of true neighbors correctly identified.
      `Recall@k = n / k`
    |

    calc_panel: {
      formula: "4 / 5" {
        style.font-size: 30
        style.font: mono
      }
      result: "0.8" {
        shape: hexagon
        style: {
          fill: "#d73a49"
          font-color: "#ffffff"
          bold: true
          font-size: 40
        }
      }
      
      formula -> result: "Evaluates to" {style.stroke-width: 3}
    }
    
    summary_legend: {
      label: |md
        ### Execution Summary
        - **Total Hits:** 4
        - **Total Misses:** 1 (ID: 35)
        - **False Positives:** 1 (ID: 99)
        - **Final Metric:** **80.00%**
      |
      style.fill: "#f8f9fa"
      style.stroke: "#cccccc"
    }
  }
}

# -----------------------------------------------------------------------------
# CONTROL FLOW & ANNOTATIONS
# -----------------------------------------------------------------------------
recall_calculation.step_1 -> recall_calculation.step_2: "Process Sets"
recall_calculation.step_2 -> recall_calculation.step_3: "Aggregate Hits"
recall_calculation.step_3 -> recall_calculation.step_4: "Compute Ratio"

implementation_note: |md
  ## Engineering Implementation Note
  In vector database benchmarking (ANN-Benchmarks), **Recall@k** measures retrieval quality. 
  
  **Implementation Logic:**
  1. Generate Ground Truth via `exhaust_search()` (O(N*D)).
  2. Query ANN Index (e.g., HNSW) to get `approx_neighbors`.
  3. Cast both to HashSets for O(1) intersection check.
  4. Return `len(intersect) / k`.
| {
  near: recall_calculation.step_4
  style: {
    stroke: "#01579b"
    fill: "#e1f5fe"
    font-size: 14
  }
}