direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
  # PERFORMANCE SPECIFICATION: BRUTE-FORCE KNN SCALABILITY
  ## O(N * d) Complexity Analysis & Latency Thresholds
'| {
  near: top-center
}

# Define Zones
interactive_zone: "INTERACTIVE ZONE (SLA < 100ms)" {
  style: {
    stroke: "#10b981"
    fill: "#f0fdf4"
    stroke-width: 4
  }
  
  step_10k: "STAGE 1: 10,000 Vectors" {
    shape: sql_table
    style.fill: "#3b82f6"
    latency: "5ms" {constraint: "FAST"}
    throughput: "200 QPS"
    cache_hit: "L3 Persistent"
  }

  step_100k: "STAGE 2: 100,000 Vectors" {
    shape: sql_table
    style.fill: "#3b82f6"
    latency: "50ms" {constraint: "UI-SMOOTH"}
    throughput: "20 QPS"
    cache_hit: "RAM-Paging"
  }
}

warning_zone: "WARNING ZONE (SLA 100ms - 1s)" {
  style: {
    stroke: "#f59e0b"
    fill: "#fffbeb"
    stroke-width: 4
  }

  step_1m: "STAGE 3: 1,000,000 Vectors" {
    shape: sql_table
    style.fill: "#f59e0b"
    latency: "500ms" {constraint: "LAG"}
    throughput: "2 QPS"
    bottleneck: "Memory BW"
  }
}

critical_zone: "IMPRACTICAL ZONE (SLA > 1s)" {
  style: {
    stroke: "#ef4444"
    fill: "#fef2f2"
    stroke-dash: 5
    stroke-width: 4
  }

  step_10m: "STAGE 4: 10,000,000 Vectors" {
    shape: sql_table
    style.fill: "#ef4444"
    latency: "5,000ms" {constraint: "TIMEOUT"}
    throughput: "0.2 QPS"
    status: "DEAD ON ARRIVAL"
  }
}

# Transitions
interactive_zone.step_10k -> interactive_zone.step_100k: "10x Growth" {
  style: {
    stroke: "#3b82f6"
    stroke-width: 2
  }
}

interactive_zone.step_100k -> warning_zone.step_1m: "LINEAR SCALING LIMIT" {
  style: {
    stroke: "#f59e0b"
    stroke-width: 4
    animated: true
  }
}

warning_zone.step_1m -> critical_zone.step_10m: "THE CLIFF" {
  style: {
    stroke: "#ef4444"
    stroke-width: 6
    animated: true
  }
}

# Performance Invariants Annotations
# Using |'md ... '| to handle markdown pipes safely
invariants: |'md
  ### SCALING INVARIANTS (d=768, f32)
  - **Memory Load**: $N \times 768 \times 4$ bytes
  - **Ops/Query**: $N \times 768$ Multiply-Adds
  - **BW Limit**: $\approx 50$ GB/s (Dual Channel DDR4)
  
  | Count | Data Size | Theoretical Min Latency |
  |-------|-----------|-------------------------|
  | 10K   | 30.7 MB   | 0.6ms (L3 BW)           |
  | 100K  | 307.2 MB  | 6.1ms (RAM BW)          |
  | 1M    | 3.07 GB   | 61.4ms (RAM BW)         |
  | 10M   | 30.7 GB   | 614.4ms (RAM BW)        |
  
  *Note: Real latency includes heap maintenance O(N log k) and thread overhead.*
'| {
  near: bottom-center
  style.fill: "#f8fafc"
}

# Legend
legend: {
  near: bottom-right
  fast: "Interactive" {
    style.fill: "#3b82f6"
  }
  warn: "Degraded" {
    style.fill: "#f59e0b"
  }
  fail: "Impractical" {
    style.fill: "#ef4444"
  }
}

# Styling specific nodes for "Technical Design" look
***.style.font: mono
interactive_zone.step_10k.style.font-color: white
interactive_zone.step_100k.style.font-color: white
warning_zone.step_1m.style.font-color: white
critical_zone.step_10m.style.font-color: white