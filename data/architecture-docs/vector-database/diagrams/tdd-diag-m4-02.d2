direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  ### Probabilistic Level Assignment Distribution
  **Formula:** `level = floor(-ln(uniform) * mL)`
  *where mL = 1 / ln(M)*
| {
  near: top-center
}

# Formula Logic
logic: {
  shape: package
  label: "Assignment Logic"
  style.fill: "#f8f9fa"
  
  rng: "Uniform Random\nU ∈ (0, 1]" {
    shape: hexagon
    tooltip: "PRNG generating float between 0 and 1"
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
      stroke-width: 2
    }
  }

  calc: "Scale & Floor\n-ln(U) * (1/ln(M))" {
    shape: parallelogram
    tooltip: "Inverse transform sampling to create exponential distribution"
    style: {
      fill: "#fff9c4"
      stroke: "#fbc02d"
      stroke-width: 2
    }
  }

  rng -> calc: "u" {
    style: {
      font-size: 14
      bold: true
    }
  }
}

# Distribution Plot Visualization
distribution: {
  label: "Exponential Decay of Node Counts"
  style.stroke-dash: 3
  
  l0: "Layer 0: Base Layer (All Nodes)" {
    width: 400
    height: 40
    style: {
      fill: "#1a237e"
      font-color: white
      bold: true
    }
  }

  l1: "Layer 1: Express Lane" {
    width: 200
    height: 40
    style: {
      fill: "#283593"
      font-color: white
    }
  }

  l2: "Layer 2: Regional Hubs" {
    width: 100
    height: 40
    style: {
      fill: "#3949ab"
      font-color: white
    }
  }

  l3: "Layer 3: Global Hubs" {
    width: 50
    height: 40
    style: {
      fill: "#5c6bc0"
      font-color: white
    }
  }

  # Layout constraints to simulate a hierarchical stack
  l0 -> l1 -> l2 -> l3: {
    style: {
      stroke-width: 0
    }
  }
}

# Probability Annotations
# FIX: 'near' set to constant 'bottom-right' for ELK compatibility
stats: {
  near: bottom-right
  label: "Statistical Probability (M=2)"
  style.fill: "#f3f4f6"
  
  p0: "P(L=0) ≈ 50.0%" {
    shape: text
    style.font-color: "#1a237e"
    style.bold: true
  }
  p1: "P(L=1) ≈ 25.0%" {
    shape: text
    style.font-color: "#283593"
  }
  p2: "P(L=2) ≈ 12.5%" {
    shape: text
    style.font-color: "#3949ab"
  }
  p3: "P(L=3) ≈ 6.25%" {
    shape: text
    style.font-color: "#5c6bc0"
  }
}

# Logical Flow Connections
logic.calc -> distribution.l0: "Resulting Level" {
  style: {
    stroke: "#ef6c00"
    stroke-width: 3
    animated: true
  }
}

# Technical Specification Footnote
note: |md
  **Key Implementation Details:** 
  1. Each layer $L_i$ contains roughly $1/M$ the nodes of layer $L_{i-1}$. 
  2. This structure facilitates **O(log N)** search complexity.
  3. The `mL` constant (optimal 1/ln(M)) ensures a balanced skip-list property.
| {
  near: bottom-center
  style: {
    stroke: "#90a4ae"
    fill: "#eceff1"
  }
}

# Satellite Component Reference
M4_INDEX: HNSW Index Structure {
  shape: circle
  style.fill: gray
  style.opacity: 0.2
}

distribution -> M4_INDEX: "Defines Graph\nHierarchy" {
  style.stroke-dash: 5
  style.stroke: "#78909c"
}