direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
    pad: 20
  }
}

# -----------------------------------------------------------------------------
# MEMORY LAYOUT SPECIFICATION (Intel Manual Style)
# -----------------------------------------------------------------------------
memory_layout: {
  shape: sql_table
  near: top-center
  style: {
    stroke: black
    stroke-width: 2
    fill: "#f8f9fa"
  }

  0x00: "Header (Magic + Version)" {constraint: "8B (Purple)"; style.fill: "#e1d5e7"}
  0x08: "Max Level (L)" {constraint: "4B (Orange)"; style.fill: "#ffe6cc"}
  0x0C: "Entry Point ID" {constraint: "4B (Orange)"; style.fill: "#ffe6cc"}
  0x10: "M (Max Neighbors)" {constraint: "4B (Data)"; style.fill: "#dae8fc"}
  0x14: "efConstruction" {constraint: "4B (Data)"; style.fill: "#dae8fc"}
  0x18: "Padding (Alignment)" {constraint: "8B (Gray)"; style.fill: "#f5f5f5"}
  "---": "--- CACHE LINE BOUNDARY (64B) ---" {style.stroke-dash: 5}
  0x40: "Vector Data Pointer" {constraint: "8B (Orange)"; style.fill: "#ffe6cc"}
  0x48: "Neighbor Adjacency List" {constraint: "Var (Blue)"; style.fill: "#dae8fc"}
}

# -----------------------------------------------------------------------------
# HNSW SEARCH SEQUENCE
# -----------------------------------------------------------------------------
hnsw_search: {
  shape: sequence_diagram

  api: "QueryAPI: REST" {
    style.fill: "#e1d5e7"
    style.stroke: "#9673a6"
    style.stroke-width: 2
  }
  hnsw: "HNSWIndex: Graph" {
    style.fill: "#e1d5e7"
    style.stroke: "#9673a6"
    style.stroke-width: 2
  }
  storage: "VectorStorage: Mmap" {
    style.fill: "#dae8fc"
    style.stroke: "#6c8ebf"
    style.stroke-width: 2
  }
  simd: "DistanceMetrics: AVX2" {
    style.fill: "#ffe6cc"
    style.stroke: "#d79b00"
    style.stroke-width: 2
  }

  # Execution Sequence
  api -> hnsw.search_active: "search(query: *const f32, k: u32, ef: u32)"
  hnsw."[ENTRY] Sub-linear traversal initialized"

  hnsw.search_active -> hnsw.search_active: "AngelRwLock.acquire_shared() ▼"
  hnsw."Shared read access granted"

  hnsw.search_active -> hnsw.search_active: "curr = self.entry_node"
  hnsw.search_active -> hnsw.search_active: "L = self.max_layer"

  # PHASE 1: LAYER DESCENT
  descent_group: "PHASE 1: Hierarchical Layer Descent (L..1)" {
    hnsw.search_active -> storage: "get_vector_ptr(curr)"
    storage -> hnsw.search_active: "curr_ptr: *const f32"
    hnsw.search_active -> simd: "_mm256_dist_ps(query, curr_ptr)"
    simd -> hnsw.search_active: "d_best: f32"

    descent_loop: "FOR layer FROM L DOWNTO 1" {
      hnsw.search_active -> hnsw.search_active: "neighbors = node.get_adj(layer)"
      
      neighbor_loop: "FOR EACH nb IN neighbors" {
        hnsw.search_active -> storage: "get_vector_ptr(nb)"
        storage -> hnsw.search_active: "nb_ptr"
        hnsw.search_active -> simd: "L2_Distance(query, nb_ptr)"
        simd -> hnsw.search_active: "d_nb"
        
        greedy_update: "IF d_nb < d_best" {
          hnsw.search_active -> hnsw.search_active: "curr = nb; d_best = d_nb"
          hnsw."Update greedy local optimum"
        }
      }
      hnsw.search_active -> hnsw.search_active: "layer -= 1"
    }
  }

  # PHASE 2: BASE LAYER SEARCH
  base_group: "PHASE 2: Base Layer Beam Search (Layer 0)" {
    hnsw.search_active -> hnsw.search_active: "Init candidate_min_heap, result_max_heap"
    
    beam_search: "WHILE !candidates.is_empty()" {
      hnsw.search_active -> hnsw.search_active: "closest = candidates.pop_min()"
      
      hnsw.search_active -> hnsw.search_active: "IF closest.dist > results.peek_max().dist BREAK"
      
      hnsw.search_active -> hnsw.search_active: "neighbors = node.get_adj(0)"
      
      inner_loop: "FOR EACH nb IN neighbors" {
        hnsw.search_active -> storage: "get_vector_ptr(nb)"
        storage -> hnsw.search_active: "nb_ptr"
        hnsw.search_active -> simd: "AVX2_Compute(query, nb_ptr)"
        simd -> hnsw.search_active: "d_nb"
        
        heap_update: "IF d_nb < results.max() OR results.len() < ef" {
          hnsw.search_active -> hnsw.search_active: "results.insert(nb, d_nb)"
          hnsw.search_active -> hnsw.search_active: "candidates.insert(nb, d_nb)"
        }
      }
    }
  }

  hnsw.search_active -> hnsw.search_active: "AngelRwLock.release_shared() ▲"

  hnsw.search_active -> api: "ResultSet { top_k: Vec<u32>, distances: Vec<f32> }" {
    style: {
      stroke: "#0000FF"
      stroke-width: 2
    }
  }
}

# -----------------------------------------------------------------------------
# IMPLEMENTATION ANNOTATIONS
# -----------------------------------------------------------------------------
search_timing: |md
  ### Engineering Specification: Milestone 4
  - **Complexity**: $O(\ln(N))$ layer visits + $O(efSearch \cdot M)$ base comparisons.
  - **SIMD Optimization**: Distance metrics must use `_mm256_loadu_ps` and `_mm256_sub_ps`.
  - **Memory Safety**: `VectorStorage` utilizes `mmap(MAP_SHARED)` with read-only protection during search.
  - **Locking Strategy**: `AngelRwLock` uses a 32-bit atomic state for shared/exclusive tracking.
| {
  near: bottom-center
  style: {
    font-size: 14
    fill: "#fcfcfc"
    stroke: "#cccccc"
    stroke-width: 1
    border-radius: 4
  }
}