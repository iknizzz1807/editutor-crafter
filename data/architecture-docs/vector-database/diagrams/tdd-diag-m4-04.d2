direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# SATELLITE CONTEXT REFERENCES
# HNSWIndex (M4): Orchestrates search
# DistanceMetrics (M2): Provides dist(q, v)
# VectorStorage (M1): Provides raw vector data

"HNSW Greedy Search Algorithm: Two-Heap Structure": {
  
  "Step 1: Initialization": {
    "Min-Heap (Candidates)": {
      "label": "Min-Heap: Candidates to Explore\n(Closest First)"
      "C1": "Entry Point A: 0.45" {style.fill: "#C7F1FF"}
    }
    "Max-Heap (Results)": {
      "label": "Max-Heap: Best Results (efSearch=3)\n(Furthest/Worst at Top)"
      "R1": "Entry Point A: 0.45" {style.fill: "#B5AFF6"}
    }
    
    note: |md
      - **Invariants**: 
        - Candidates: `dist(Top) = min(dist(C))`
        - Results: `dist(Top) = max(dist(R))`
    | {shape: text}
  }

  "Step 2: Expansion & Distance Computation": {
    "direction": "down"
    "Min-Heap": {
      "top": "**Node A: 0.45**" {style.stroke: red; style.stroke-width: 4}
      "exploring": "Neighbors of A: [B, C]"
      "top" -> "exploring": "Pop"
    }
    "Distance Computation (M2)": {
      "shape": "rectangle"
      "style.fill": "#E4DBFE"
      "calc": "dist(Q, B) = 0.12\ndist(Q, C) = 0.55"
    }
    "Min-Heap"."exploring" -> "Distance Computation (M2)"
  }

  "Step 3: State Update (Internal Mutation)": {
    "Candidates": {
      "label": "Min-Heap (Updated)"
      "top": "**Node B: 0.12**" {style.fill: red; style.font-color: white}
      "n2": "Node C: 0.55"
      "top" -> "n2"
    }
    "Results": {
      "label": "Max-Heap (Bounded ef=3)"
      "worst": "**Node C: 0.55**" {style.fill: red; style.font-color: white}
      "mid": "Node A: 0.45"
      "best": "**Node B: 0.12**" {style.stroke: blue}
      "worst" -> "mid" -> "best"
    }
    "Candidates"."top" -> "Results"."best": "Push if < worst"
  }

  "Step 4: Termination Condition": {
    "Comparison": {
      "label": "Greedy Search Termination Logic"
      "shape": "diamond"
      "check": "dist(MinHeap.Top) > dist(MaxHeap.Top)?"
    }
    "State_A": {
      "label": "Search Continues"
      "val": "0.12 < 0.55"
      "style.fill": "#ACE1AF"
    }
    "State_B": {
      "label": "**TERMINATE**"
      "val": "dist(next) > worst allowed"
      "style.fill": "#FE7070"
    }
    "Comparison" -> "State_A": "False"
    "Comparison" -> "State_B": "True"
    
    "Footer": |md
      ### Logic for Termination
      When the **closest unexplored candidate** is further from the query 
      than the **furthest result** in our current top-k (efSearch), 
      no further exploration can improve the result set.
    | {shape: text}
  }
}

# Cross-Module Call Sequence
"HNSWIndex (M4)" -> "DistanceMetrics (M2)": "compute(q, neighbor)"
"DistanceMetrics (M2)" -> "VectorStorage (M1)": "get_vector_ptr(id)" {style.stroke-dash: 5}

# Styling
"HNSW Greedy Search Algorithm: Two-Heap Structure"."Step 1: Initialization".style.stroke: "#DEE1EB"
"HNSW Greedy Search Algorithm: Two-Heap Structure"."Step 3: State Update (Internal Mutation)".style.fill: "#f9f9f9"