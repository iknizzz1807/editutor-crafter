direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# NODE INSERTION PROCESS: HNSW INCREMENTAL BUILD
# Consistent with Milestone M4: HNSW Index

Step 1: Assign Target Layer {
  shape: package
  explanation: |md
    ### Probabilistic Level Assignment
    Uses the skip-list formula: `floor(-ln(rand()) * ml)`
    New Node **ID: 105** is assigned to **Max Layer: 2**.
  |
  
  distribution: {
    grid-rows: 3
    L2: "Layer 2 (12.5%)" { style.fill: "#E4DBFE"; style.stroke: red; style.bold: true }
    L1: "Layer 1 (25%)" { style.fill: "#DEE1EB" }
    L0: "Layer 0 (50%)" { style.fill: "#DEE1EB" }
  }
}

Step 2: Find Entry Point {
  shape: package
  explanation: |md
    ### Layer Descent
    Start at global `entry_point` (Node 42) on highest Layer 3.
    Greedily move to closest neighbor at each layer until reaching **Layer 3**.
  |
  
  graph_state: {
    L3: {
      EP: "Node 42 (Entry)"
      EP -> Next: "Dist=0.45" { style.stroke: red; style.stroke-width: 4 }
      Next: "**Node 12**" { style.stroke: red; style.bold: true }
    }
  }
}

Step 3: Search for Neighbors {
  shape: package
  explanation: |md
    ### ef_construction Search
    At Layers 2, 1, and 0, execute `search_layer` with `ef=200`.
    Collect best candidates to connect to the new node.
  |
  
  candidates: {
    L2_List: "Candidates: [12, 18, 22]" { style.stroke: red; style.bold: true }
    L1_List: "Candidates: [12, 18, 22, 45, 56]"
    L0_List: "Candidates: [12, 18, 22, 45, 56, 88, 92]"
  }
}

Step 4: Bidirectional Connection {
  shape: package
  explanation: |md
    ### Edge Creation
    New **Node 105** connects to selected neighbors.
    Neighbors MUST update their lists to point back to 105.
  |
  
  links: {
    Node_105: "**New Node 105**" { style.stroke: red; style.bold: true; style.fill: "#C7F1FF" }
    N1: "Neighbor 12"
    N2: "Neighbor 18"
    
    Node_105 <-> N1: "**New Edge**" { style.stroke: red; style.stroke-width: 3; style.animated: true }
    Node_105 <-> N2: "**New Edge**" { style.stroke: red; style.stroke-width: 3; style.animated: true }
  }
}

Step 5: Pruning Invariants {
  shape: package
  explanation: |md
    ### Overflow Handling
    If `Neighbor 12` now has `M > M_max` (e.g., > 16 edges),
    re-sort neighbors by distance and **PRUNE** the farthest.
  |
  
  prune_logic: {
    direction: right
    Before: {
      N12: "Node 12"
      N12 -> List: "[...16 edges..., 105]"
    }
    After: {
      N12: "Node 12"
      N12 -> List: "[...15 edges..., 105]"
      Pruned: "~~Node 88~~" { style.stroke: gray; style.opacity: 0.5 }
      List -> Pruned: "Dropped (Farthest)" { style.stroke-dash: 5 }
    }
  }
}

# Sequencing the algorithm flow
Step 1 -> Step 2 -> Step 3 -> Step 4 -> Step 5

# Annotations for Engineers
Legend: {
  near: bottom-right
  note: |md
    **Implementation Details**
    - `M_max`: Max edges (Layers 1+)
    - `M_max0`: Max edges (Layer 0, usually 2*M)
    - `efConstruction`: Search beam width during build
  |
}