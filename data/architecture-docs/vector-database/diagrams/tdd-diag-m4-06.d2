layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

# HNSW Bidirectional Edge Maintenance
# This diagram specifies the algorithmic steps for inserting a new node A
# into an existing graph layer, ensuring all edges are reciprocal.

title: |md
  # HNSW Bidirectional Edge Maintenance
  **Algorithm Specification: M4-INSERTION-PHASE-2**
  *Ensures Graph Navigability via Reciprocal Connectivity*
| {
  near: top-center
}

# --- STYLES & CLASSES ---
classes: {
  new_node: {
    style: {
      fill: "#e1f5fe"
      stroke: "#01579b"
      stroke-width: 4
      bold: true
      shadow: true
    }
  }
  existing_node: {
    style: {
      fill: "#f5f5f5"
      stroke: "#424242"
      stroke-dash: 0
    }
  }
  modified: {
    style: {
      stroke: "#d32f2f"
      stroke-width: 5
      font-color: "#d32f2f"
      bold: true
    }
  }
  neighbor_set: {
    shape: sql_table
    style: {
      fill: "#fff9c4"
      stroke: "#fbc02d"
    }
  }
  metadata_text: {
    shape: text
    style: {
      font-size: 12
      italic: true
      font: mono
    }
  }
}

# --- STEP 1: INITIAL STATE ---
step1: "Step 1: Neighbor Selection" {
  explanation: |md
    ### Candidates Identified
    Node **A** has searched Layer *L* using HNSW heuristic search 
    and identified **B, C, D** as its `M` nearest neighbors.
  |
  
  node_a: "Node A (New)" {
    class: new_node
    neighbors_list: "" {
      shape: sql_table
      class: neighbor_set
      u64_id: "ID: 0xAF42"
      layer_l: "Layer L: { Ø }"
    }
  }

  node_b: "Node B" { class: existing_node }
  node_c: "Node C" { class: existing_node }
  node_d: "Node D" { class: existing_node }

  node_a -> node_b: "dist=0.12" { style.stroke-dash: 3 }
  node_a -> node_c: "dist=0.15" { style.stroke-dash: 3 }
  node_a -> node_d: "dist=0.22" { style.stroke-dash: 3 }
}

# --- STEP 2: FORWARD LINKS ---
step2: "Step 2: Update Node A Neighbors" {
  explanation: |md
    ### Node A Mutated
    `A.neighbors[L].insert({B, C, D})`
    The adjacency list for Node A is persisted in memory.
  |

  node_a: "Node A (New)" {
    class: new_node
    neighbors_list: "" {
      shape: sql_table
      class: neighbor_set
      u64_id: "ID: 0xAF42"
      layer_l: "**Layer L: { B, C, D }**" { class: modified }
    }
  }

  node_b: "Node B" { class: existing_node }
  node_c: "Node C" { class: existing_node }
  node_d: "Node D" { class: existing_node }

  node_a -> node_b: "1. Link" { class: modified }
  node_a -> node_c: "2. Link" { class: modified }
  node_a -> node_d: "3. Link" { class: modified }
}

# --- STEP 3: RECIPROCAL LINKS ---
step3: "Step 3: Reciprocal Connection" {
  explanation: |md
    ### Bidirectional Consistency
    For each neighbor `N` in `{B, C, D}`:
    `N.neighbors[L].insert(A)`
    *Crucial for graph navigability from established nodes to new ones.*
  |

  node_a: "Node A" { class: new_node }

  node_b: "Node B" {
    class: existing_node
    list: "Layer L Adjacency" {
      shape: sql_table
      class: neighbor_set
      entries: "..., **A**" { class: modified }
    }
  }
  
  node_c: "Node C" {
    class: existing_node
    list: "Layer L Adjacency" {
      shape: sql_table
      class: neighbor_set
      entries: "..., **A**" { class: modified }
    }
  }

  node_d: "Node D" {
    class: existing_node
    list: "Layer L Adjacency" {
      shape: sql_table
      class: neighbor_set
      entries: "..., **A**" { class: modified }
    }
  }

  node_b -> node_a: "Reciprocal" { class: modified; style.stroke: orange }
  node_c -> node_a: "Reciprocal" { class: modified; style.stroke: orange }
  node_d -> node_a: "Reciprocal" { class: modified; style.stroke: orange }
}

# --- STEP 4: PRUNING ---
step4: "Step 4: Constraint Enforcement (Pruning)" {
  explanation: |md
    ### Overfill Check
    `IF node.neighbors[L].len() > M_max:`
    Run `prune_neighbors_heuristic(node, L, M_max)`
    Node **D** was at capacity; the link to **E** is dropped 
    to maintain logarithmic search complexity.
  |

  node_d: "Node D" {
    class: existing_node
    status: "MUTATING: PRUNE" {
      style: { fill: "#ffcdd2"; font-color: "#b71c1c"; bold: true }
    }
  }
  
  node_a: "Node A" { class: new_node }

  node_e: "Node E (Weakest)" {
    style.opacity: 0.3
    style.stroke-dash: 5
  }

  node_d -> node_a: "Kept (New)" { 
    style: {
      stroke: green
      stroke-width: 3 
    }
  }
  node_d -> node_e: "ILLEGAL: OVER M_MAX" { 
    style: {
      stroke: red
      stroke-dash: 8
      opacity: 0.4
    }
  }
}

# Layout flow
step1 -> step2 -> step3 -> step4: "Next State"

# Legend
legend: {
  near: bottom-right
  new: "New Node (A)" { class: new_node }
  modified_label: "Mutated Field" { class: modified }
  recip: "Reciprocal Edge" { style.stroke: orange }
  drop: "Pruned/Dropped Edge" { style.stroke: red; style.stroke-dash: 5 }
}

# Implementation Logic (Raw Implementation Reference)
impl_spec: |go
// HNSW Insertion Logic (Phase 2: Edge Maintenance)
// current_layer: Layer to update
// q: New node point
// neighbors: Result of searchNeighbors(q, M)
func (h *HNSW) addBidirectionalLinks(q *Node, layer int, neighbors []uint64) {
    for _, neighborID := range neighbors {
        neighbor := h.nodes[neighborID]
        neighbor.Lock()
        
        // Step 3: Add reciprocal link to neighbor
        neighbor.Neighbors[layer] = append(neighbor.Neighbors[layer], q.ID)
        
        // Step 4: Enforce max degree M_max
        if len(neighbor.Neighbors[layer]) > h.M_max {
            neighbor.Neighbors[layer] = h.pruneHeuristic(
                neighbor, 
                layer, 
                h.M_max,
            )
        }
        neighbor.Unlock()
    }
}
| {
  near: bottom-left
  shape: text
  style: {
    font-size: 14
    stroke: "#eeeeee"
    fill: "#fcfcfc"
  }
}