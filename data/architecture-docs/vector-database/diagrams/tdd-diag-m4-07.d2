layout-engine: elk
theme-id: 4

direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

# --- TECHNICAL CLASSES: INTEL MANUAL QUALITY ---
classes: {
  step_container: {
    style: {
      stroke: "#2C3E50"
      stroke-width: 2
      border-radius: 8
      fill: "#F8F9FA"
    }
  }
  node_normal: {
    shape: circle
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      stroke-width: 2
    }
  }
  node_query: {
    shape: hexagon
    label: "Query (Q)"
    style: {
      fill: "#FFF9C4"
      stroke: "#FBC02D"
      stroke-width: 3
      double-border: true
    }
  }
  node_changed: {
    style: {
      fill: "#FFEBEE"
      stroke: "#D32F2F"
      stroke-width: 5
      bold: true
      shadow: true
    }
  }
  rejected: {
    style: {
      stroke-dash: 4
      opacity: 0.4
      fill: "#EEEEEE"
    }
  }
  metric_link: {
    style: {
      stroke: "#95A5A6"
      stroke-width: 1
      stroke-dash: 3
      font-size: 11
    }
  }
}

# --- DIAGRAM CONTENT ---

title: |md
  # Neighbor Selection Heuristic Implementation Spec
  **Algorithm Parameters:** Max Degree ($M$) = 2.
  **Objective:** Spatial pruning to prevent graph "clumping" and ensure long-range traversal.
  **Core Logic:** Select candidate $C$ only if it is closer to Query $Q$ than to any already selected neighbor $R$.
| {
  near: top-center
  style.font-size: 18
}

STEP_1: "1. INITIAL STATE & CANDIDATE EVALUATION" {
  class: step_container
  
  Q: {class: node_query}
  
  C1: "C1\nd(Q)=1.0" {class: node_normal}
  C2: "C2\nd(Q)=1.2" {class: node_normal}
  C3: "C3\nd(Q)=1.5" {class: node_normal}
  C4: "C4\nd(Q)=2.0" {class: node_normal}

  # Distance Matrix Representation
  C1 -- C2: "d=0.5" {class: metric_link}
  
  note: |md
    ### Step Analysis
    - **Buffer:** [C1, C2, C3, C4]
    - **Sort:** Ascending by distance to Q.
    - **Context:** C1 and C2 are spatially correlated (close to each other).
  |
}

STEP_2: "2. NAIVE SELECTION (FAILURE CASE)" {
  class: step_container
  
  Q: {class: node_query}
  
  C1: "C1\n[SELECTED]" {class: [node_normal; node_changed]}
  C2: "C2\n[SELECTED]" {class: [node_normal; node_changed]}
  C3: "C3" {class: node_normal}
  C4: "C4" {class: node_normal}

  Q -> C1: "Rank 1" {style.stroke: blue}
  Q -> C2: "Rank 2" {style.stroke: blue}
  
  result: |md
    ### Naive Result
    **Set:** {C1, C2}
    **Failure:** Poor spatial diversity. C2 adds little new directional information.
    Graph becomes "narrow" and difficult to navigate.
  |
}

STEP_3: "3. HEURISTIC SELECTION: PRIMARY PICK" {
  class: step_container
  
  Q: {class: node_query}
  C1: "C1\n[SELECTED]" {class: [node_normal; node_changed]}
  
  Q -> C1: "Closest" {style.stroke-width: 3}

  logic: |md
    ### Processing:
    1. Always select closest: **C1**.
    2. Add to active set: $R = \{C1\}$
    3. $M$ slots remaining: 1.
  |
}

STEP_4: "4. HEURISTIC: DIVERSITY PRUNING (C2)" {
  class: step_container
  
  Q: {class: node_query}
  C1: "C1\n(Existing)" {class: node_normal}
  C2: "C2\n(REJECTED)" {class: [node_normal; rejected]}
  
  C2 -> Q: "d=1.2" {class: metric_link}
  C2 -> C1: "d=0.5" {
    style: {
      stroke: red
      stroke-width: 4
    }
  }

  check: |md
    ### Pruning Rule Check:
    Is $d(C_i, Q) < d(C_i, R)$?
    - $d(C_2, Q) = 1.2$
    - $d(C_2, C_1) = 0.5$
    - **Result:** $0.5 < 1.2 \implies$ **REJECT**
    *C2 is "occluded" by C1.*
  |
}

STEP_5: "5. HEURISTIC: FINAL DIVERSE SET" {
  class: step_container
  
  Q: {class: node_query}
  C1: "C1\n(Selected)" {class: [node_normal; node_changed]}
  C2: "C2\n(Pruned)" {class: [node_normal; rejected]}
  C3: "C3\n(Selected)" {class: [node_normal; node_changed]}
  C4: "C4" {class: node_normal}

  Q -> C1: "Pick 1" {style.stroke: green}
  Q -> C3: "Pick 2" {style.stroke: green}

  outcome: |md
    ### Final Selection:
    **Result Set:** {C1, C3}
    **Logic:** C3 (d=1.5) is preferred over C2 (d=1.2) because it is 
    farther from C1 than it is from Q, ensuring a broad search frontier.
    This maintains the "Small World" property of the graph.
  |
}

# --- CONTROL FLOW ---

STEP_1 -> STEP_2: "Naive Implementation" {
  style: {
    stroke-dash: 5
    font-color: gray
  }
}

STEP_1 -> STEP_3: "Heuristic (HNSW/NSG)" {
  style: {
    stroke-width: 4
    stroke: green
  }
}

STEP_3 -> STEP_4: "Evaluate Next Candidate"
STEP_4 -> STEP_5: "Iterate until |R|=M"

# --- LEGEND ---
legend: {
  near: bottom-right
  query: "Query Node" { class: node_query }
  selected: "Selected Neighbor" { class: [node_normal; node_changed] }
  rejected_node: "Pruned (Redundant)" { class: [node_normal; rejected] }
  
  annotate: |md
    **Constraint:** $d(C, Q) < d(C, R)$
  |
}