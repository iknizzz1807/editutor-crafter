direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- Performance Tradeoff Map ---
# This diagram visualizes how the 'efSearch' hyperparameter affects the vector database query performance.
# efSearch determines the search breadth in the HNSW graph.
TRADE-OFF_ANALYSIS: {
  label: "HNSW PERFORMANCE TRADEOFF: efSearch Parameter Space"
  style: {
    stroke-width: 2
    fill: "#f8f9fa"
    border-radius: 8
  }

  # --- Axis: The Parameter Input ---
  # efSearch controls the size of the dynamic candidate list during query traversal.
  efSearch_Axis: {
    label: "Dynamic Candidate List Size (efSearch)"
    shape: rectangle
    style: {
      fill: "#e9ecef"
      stroke-dash: 3
    }

    EF_10: "efSearch = 10" {
      tooltip: "Low accuracy, maximum throughput"
      style.fill: "#dee2e6"
    }
    EF_50: "efSearch = 50" {
      tooltip: "The standard production balance"
      style.fill: "#ced4da"
    }
    EF_100: "efSearch = 100" {
      tooltip: "High precision target; standard sweet spot"
      style.fill: "#adb5bd"
    }
    EF_200: "efSearch = 200" {
      tooltip: "Near-exact results with higher cost"
      style.fill: "#6c757d"
      style.font-color: white
    }
    EF_500: "efSearch = 500" {
      tooltip: "Maximum quality priority; significant latency penalty"
      style.fill: "#495057"
      style.font-color: white
    }

    EF_10 -> EF_50 -> EF_100 -> EF_200 -> EF_500: "Increasing Beam Width" {
      style.stroke-width: 2
    }
  }

  # --- Resulting Metrics ---
  # Measured outputs based on the efSearch configuration.
  # METRICS is a special object (grid).
  METRICS: {
    grid-columns: 2
    style.stroke-width: 0
    
    RECALL_CURVE: {
      label: "Recall@k (Search Accuracy)"
      style.fill: "#e7f5ff"
      style.stroke: "#339af0"
      
      R1: "70%" { style.fill: "#74c0fc" }
      R2: "90%" { style.fill: "#4dabf7" }
      R3: "95%" { style.fill: "#339af0" }
      R4: "98%" { style.fill: "#228be6" }
      R5: "99%+" { style.fill: "#1c7ed6"; style.font-color: white }
      
      R1 -> R2 -> R3 -> R4 -> R5: "Logarithmic Growth" {
        style.stroke: "#1971c2"
        style.animated: true
      }
    }

    LATENCY_COST: {
      label: "Query Latency (Compute / ms)"
      style.fill: "#fff5f5"
      style.stroke: "#fa5252"
      
      L1: "Very Low" { style.fill: "#ffc9c9" }
      L2: "Low" { style.fill: "#ff8787" }
      L3: "Moderate" { style.fill: "#fa5252" }
      L4: "High" { style.fill: "#f03e3e"; style.font-color: white }
      L5: "Very High" { style.fill: "#e03131"; style.font-color: white }
      
      L1 -> L2 -> L3 -> L4 -> L5: "Linear Growth: O(ef × M)" {
        style.stroke: "#c92a2a"
        style.animated: true
      }
    }
  }

  # --- Optimal Region Annotation ---
  # FIXED: near refers to the non-special object container, not a descendant of a grid.
  OPTIMAL_ZONE: "OPTIMAL OPERATING REGION" {
    style: {
      fill: "#ebfbee"
      stroke: "#40c057"
      stroke-width: 4
      stroke-dash: 0
      bold: true
    }
    description: |md
      **Sweet Spot (efSearch 50-100)**
      - **Recall:** 90% to 95%
      - **Latency:** Sub-5ms target (Dataset dependent)
      - **Backtracking:** Sufficient buffer to escape local minima in L0.
    |
  }

  # --- Documentation & Analysis Logic ---
  # FIXED: near refers to the root container to avoid grid cell descendant issues.
  REASONING: |md
    ### HNSW Traversal Logic
    1. **Beam Width:** `efSearch` defines the size of the dynamic candidate list maintained during the greedy traversal of the base layer (Layer 0).
    2. **Probability:** As `ef` grows, the probability of reaching the *true* nearest neighbor increases as the search tracks more local minima.
    3. **Complexity:** Distance computations scale linearly as $O(ef \times M)$, where $M$ is the number of connections per node.
  | {
    shape: text
  }
}

# --- Relationship Mappings (Causal Connections) ---
# Mapping the parameter steps to accuracy gains
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_10  -> TRADE-OFF_ANALYSIS.METRICS.RECALL_CURVE.R1: "Accuracy Map"
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_50  -> TRADE-OFF_ANALYSIS.METRICS.RECALL_CURVE.R2: "Accuracy Map"
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_100 -> TRADE-OFF_ANALYSIS.METRICS.RECALL_CURVE.R3: "Accuracy Map"
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_200 -> TRADE-OFF_ANALYSIS.METRICS.RECALL_CURVE.R4: "Accuracy Map"
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_500 -> TRADE-OFF_ANALYSIS.METRICS.RECALL_CURVE.R5: "Accuracy Map"

# Mapping the parameter steps to latency costs
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_10  -> TRADE-OFF_ANALYSIS.METRICS.LATENCY_COST.L1: "Latency Map" { style.stroke: "#adb5bd" }
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_50  -> TRADE-OFF_ANALYSIS.METRICS.LATENCY_COST.L2: "Latency Map" { style.stroke: "#adb5bd" }
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_100 -> TRADE-OFF_ANALYSIS.METRICS.LATENCY_COST.L3: "Latency Map" { style.stroke: "#adb5bd" }
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_200 -> TRADE-OFF_ANALYSIS.METRICS.LATENCY_COST.L4: "Latency Map" { style.stroke: "#adb5bd" }
TRADE-OFF_ANALYSIS.efSearch_Axis.EF_500 -> TRADE-OFF_ANALYSIS.METRICS.LATENCY_COST.L5: "Latency Map" { style.stroke: "#adb5bd" }

# Styling group-level causal relationship
TRADE-OFF_ANALYSIS.efSearch_Axis -> TRADE-OFF_ANALYSIS.METRICS: "Causal Impact" {
  style: {
    stroke-width: 4
    stroke: "#dee2e6"
    opacity: 0.2
  }
}