direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# GLOBAL STYLES & CLASSES
classes: {
  header_node: {
    label: "HEADER"
    style: {
      fill: "#6a1b9a"
      font-color: white
      bold: true
      stroke-width: 2
      border-radius: 4
    }
  }
  data_node: {
    style: {
      fill: "#1565c0"
      font-color: white
      stroke-width: 1
      border-radius: 2
    }
  }
  logic_box: {
    style: {
      stroke: "#ef6c00"
      stroke-width: 3
      fill: "#fff3e0"
      stroke-dash: 5
      border-radius: 8
    }
  }
}

# 1. MEMORY LAYOUT ANALOGY (Architecture Specs)
# Exact byte offsets left, field sizes right
node_memory_layout: {
  label: "MEMORY LAYOUT: HNSW-SkipList Node (Total 128 Bytes)"
  shape: sql_table
  style: {
    fill: "#f5f5f5"
    stroke: "#757575"
    stroke-width: 2
  }
  
  "0x00": "Vector Pointer / Data Payload" {
    constraint: "16B [Orange]"
    style.fill: "#ffe0b2"
  }
  "0x10": "Max Layer Level (l)" {
    constraint: "4B [Purple]"
    style.fill: "#e1bee7"
  }
  "0x14": "Next Pointer Array [l]" {
    constraint: "Variable [Orange]"
    style.fill: "#ffe0b2"
  }
  "0x40": "--- Cache Line Boundary (64B) ---" {
    constraint: "MARKER"
    style: {
      stroke-dash: 5
      font-size: 10
      font-color: "#757575"
    }
  }
  "0x44": "Metadata / Lock Flags" {
    constraint: "8B [Gray]"
    style.fill: "#eeeeee"
  }
  "0x4C": "Padding to 128B" {
    constraint: "Remaining [Green]"
    style.fill: "#e8f5e9"
  }
}

# 2. PROBABILITY MODEL (The Governing Logic)
probability_logic: {
  label: "PROBABILISTIC LAYER ASSIGNMENT: Exponential Decay"
  class: logic_box
  
  formula: |md
    ### Layer Selection Logic
    python
    def get_random_level(ml):
        # Inverse transform sampling
        # ml = level multiplier = 1 / ln(M)
        return floor(-ln(random.uniform(0, 1)) * ml)
    
    - **Uniform Random**: $U(0,1)$
    - **ml**: Level Multiplier $1 / \ln(M)$
    - **M**: Max fan-out factor (usually 16-64)
    - **Goal**: Maintain $O(\log N)$ search complexity
  |
  
  distribution_graph: {
    shape: parallelogram
    label: "P(L=i) = (1/M)^i Exponential Sparsity"
    style.fill: "#fff9c4"
  }
}

# 3. SKIP LIST ANALOGY (1D Structure)
skip_list: {
  label: "SKIP LIST: 1D Search Structure (O(log N))"
  style: {
    stroke: "#1565c0"
    fill: "#e3f2fd"
    stroke-width: 2
    border-radius: 8
  }

  levels: {
    grid-rows: 4
    grid-gap: 50
    
    l3: {
      label: "Express Level 3 (Top)"
      h: "Head"; n50: "Node 50"
      h.class: header_node
      n50.class: data_node
      h -> n50: "Skip Segment" { style.stroke-width: 3 }
    }
    
    l2: {
      label: "Express Level 2"
      h: "Head"; n25: "Node 25"; n50: "Node 50"
      h.class: header_node
      n25.class: data_node
      n50.class: data_node
      h -> n25 -> n50
    }
    
    l1: {
      label: "Express Level 1"
      h: "Head"; n10: "Node 10"; n25: "Node 25"; n30: "Node 30"; n50: "Node 50"
      h.class: header_node
      n10.class: data_node; n25.class: data_node; n30.class: data_node; n50.class: data_node
      h -> n10 -> n25 -> n30 -> n50
    }
    
    l0: {
      label: "Base Level 0 (All Nodes)"
      h: "Head"; v10: "10"; v20: "20"; v25: "25"; v30: "30"; v40: "40"; v50: "50"
      h.class: header_node
      v10.class: data_node; v20.class: data_node; v25.class: data_node; v30.class: data_node
      v40.class: data_node; v50.class: data_node
      h -> v10 -> v20 -> v25 -> v30 -> v40 -> v50
    }
  }
}

# 4. HNSW GRAPH STRUCTURE (High-D Reality)
hnsw_graph: {
  label: "HNSW GRAPH: Hierarchical Navigable Small Worlds"
  style: {
    stroke: "#2e7d32"
    fill: "#e8f5e9"
    stroke-width: 2
    border-radius: 8
  }

  levels: {
    grid-rows: 4
    grid-gap: 50

    l3: {
      label: "Layer 3: Global Routing (Sparsest)"
      shape: cloud
      ep: "Entry Point"; v50: "V_50"
      ep.class: header_node
      v50.class: data_node
      ep -> v50: "Initial Entry" { style.stroke-width: 3; style.stroke: orange }
    }

    l2: {
      label: "Layer 2: Regional Search"
      shape: cloud
      v25: "V_25"; v50: "V_50"
      v25.class: data_node; v50.class: data_node
      v25 <-> v50: "Regional Link"
    }

    l1: {
      label: "Layer 1: Neighborhood Search"
      shape: cloud
      v10: "V_10"; v25: "V_25"; v30: "V_30"; v50: "V_50"
      v10.class: data_node; v25.class: data_node; v30.class: data_node; v50.class: data_node
      v10 <-> v25
      v25 <-> v30
      v30 <-> v50
    }

    l0: {
      label: "Layer 0: Local Precision (Dense)"
      shape: cloud
      n10: "10"; n20: "20"; n25: "25"; n30: "30"; n40: "40"; n50: "50"
      n10.class: data_node; n20.class: data_node; n25.class: data_node
      n30.class: data_node; n40.class: data_node; n50.class: data_node
      n10 <-> n20 <-> n25 <-> n30 <-> n40 <-> n50
    }
  }
}

# 5. CROSS-MODEL MAPPING & LOGIC FLOW
probability_logic -> skip_list.levels: "Governs Promotion" {
  style.stroke: "#ef6c00"
  style.stroke-width: 2
}
probability_logic -> hnsw_graph.levels: "Governs Max_Layer" {
  style.stroke: "#ef6c00"
  style.stroke-width: 2
}

# Cross-analogy mappings (Skip-List -> HNSW)
skip_list.levels.l3 -> hnsw_graph.levels.l3: "Entry Point Logic Mapping" {
  style.stroke-dash: 5; 
  style.stroke: gray;
  target-arrowhead: diamond
}
skip_list.levels.l2 -> hnsw_graph.levels.l2: "Long-Range Routing Mapping" {
  style.stroke-dash: 5; 
  style.stroke: gray;
  target-arrowhead: diamond
}
skip_list.levels.l1 -> hnsw_graph.levels.l1: "Cluster Navigation Mapping" {
  style.stroke-dash: 5; 
  style.stroke: gray;
  target-arrowhead: diamond
}
skip_list.levels.l0 -> hnsw_graph.levels.l0: "Base Geometry Mapping" {
  style.stroke-dash: 5; 
  style.stroke: gray;
  target-arrowhead: diamond
}

# 6. IMPLEMENTATION LEGEND
legend: {
  near: bottom-center
  
  description: |md
    ### ENGINEER IMPLEMENTATION GUIDE:
    1. **Layer Assignment**: Calculate random level *once* per node during `INSERT`.
    2. **Probability**: $P = 1/M$ ensures $log(N)$ levels total.
    3. **Locking Strategy**:
       - Layers $1 \dots L$: Optimistic `compare-and-swap` (CAS).
       - Layer $0$: Full mutex or fine-grained neighbor locking.
    4. **Memory Optimization**: Fixed-size pointer arrays for levels.
  |
  
  header_key: "ENTRY NODE" { class: header_node }
  data_key: "DATA NODE" { class: data_node }
  logic_key: "LOGIC FLOW" { 
    style: {
      stroke: "#ef6c00"
      stroke-dash: 5
      stroke-width: 2
    }
  }
}