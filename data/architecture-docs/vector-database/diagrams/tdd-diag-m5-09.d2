direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # RECALL QUALITY VS MEMORY EFFICIENCY
  **Benchmark Environment:** 100,000 vectors, 768 dimensions, k=10
| {
  near: top-center
  shape: text
}

# --- Y-AXIS (RECALL) ---
y_axis: {
  grid-rows: 11
  grid-gap: 0
  style.stroke-width: 0
  "1.00": { shape: text }
  "0.95": { shape: text }
  "0.90": { shape: text }
  "0.85": { shape: text }
  "0.80": { shape: text }
  "0.75": { shape: text }
  "0.70": { shape: text }
  "0.65": { shape: text }
  "0.60": { shape: text }
  "0.55": { shape: text }
  "0.50": { shape: text }
}

# --- COMPARISON MATRIX ---
comparison_matrix: {
  grid-columns: 4
  grid-gap: 40
  
  # Headers
  h1: "**STORAGE STRATEGY**" { shape: text }
  h2: "**MEM USAGE (100K)**" { shape: text }
  h3: "**RECALL@10**" { shape: text }
  h4: "**LATENCY (ADC)**" { shape: text }

  # FP32 (Baseline)
  fp32_label: "FP32 (Full Precision)" {
    style.fill: "#fce7c6"
    style.stroke: orange
    tooltip: "Ground Truth baseline"
  }
  fp32_mem: "307.2 MB" { style.fill: "#eeeeee" }
  fp32_recall: "**1.000**" { 
    style.fill: "#ffffff"
    style.bold: true
  }
  fp32_lat: "50.0 ms" { style.fill: "#eeeeee" }

  # SQ8
  sq8_label: "SQ8 (Scalar Quantization)" {
    style.fill: "#e1d5e7"
    style.stroke: purple
    tooltip: "4x compression via per-dimension min/max"
  }
  sq8_mem: "76.8 MB (4x)" { style.fill: "#eeeeee" }
  sq8_recall: "**0.921**" { 
    style.fill: "#ffffff"
    style.bold: true
    style.font-color: "#6a0dad"
  }
  sq8_lat: "12.5 ms" { style.fill: "#eeeeee" }

  # PQ-M16
  pq16_label: "PQ-M16 (16 Subspaces)" {
    style.fill: "#dae8fc"
    style.stroke: blue
    tooltip: "Higher resolution codebooks (16 bytes/vec)"
  }
  pq16_mem: "1.6 MB (192x)" { style.fill: "#eeeeee" }
  pq16_recall: "**0.902**" { 
    style.fill: "#ffffff"
    style.bold: true
    style.font-color: blue
  }
  pq16_lat: "0.8 ms" { style.fill: "#eeeeee" }

  # PQ-M8
  pq8_label: "PQ-M8 (8 Subspaces)" {
    style.fill: "#d5e8d4"
    style.stroke: green
    tooltip: "Maximum efficiency (8 bytes/vec)"
  }
  pq8_mem: "0.8 MB (384x)" { style.fill: "#eeeeee" }
  pq8_recall: "**0.854**" { 
    style.fill: "#ffffff"
    style.bold: true
    style.font-color: green
  }
  pq8_lat: "0.4 ms" { style.fill: "#eeeeee" }
}

# --- VISUAL CURVE SIMULATION ---
recall_curve: {
  grid-columns: 1
  grid-gap: 2
  style.fill: transparent
  style.stroke-width: 0

  point_fp32: "FP32 [1.00]" {
    width: 400
    height: 30
    style.fill: orange
    style.stroke-width: 2
  }
  
  gap1: "" { style.opacity: 0; height: 40 }

  point_sq8: "SQ8 [0.92]" {
    width: 360
    height: 30
    style.fill: purple
    style.stroke-width: 2
  }

  gap2: "" { style.opacity: 0; height: 10 }

  point_pq16: "PQ-M16 [0.90]" {
    width: 340
    height: 30
    style.fill: blue
    style.stroke-width: 2
  }

  gap3: "" { style.opacity: 0; height: 25 }

  point_pq8: "PQ-M8 [0.85]" {
    width: 300
    height: 30
    style.fill: green
    style.stroke-width: 2
  }
}

# --- ANNOTATIONS ---
notes: |md
  ### Key Findings
  1. **SQ8** provides the best balance for general use, maintaining high fidelity (>0.92 recall) with a fixed 4x memory reduction.
  2. **Product Quantization (PQ)** is required for billion-scale sets, offering massive (>100x) compression.
  3. **Recall Drop:** PQ-M8 exhibits a ~15% recall loss compared to FP32, necessitating a **Re-ranking Phase (M5)** using exact distances on the final candidate set to recover accuracy.
  4. **Performance:** ADC distance computation on PQ data is ~100x faster than full-precision L2 calculation.
| {
  shape: text
  near: bottom-left
}

# Connections to show drop-off
comparison_matrix.fp32_recall -> recall_curve.point_fp32: "Perfect" { style.stroke-dash: 3 }
comparison_matrix.sq8_recall -> recall_curve.point_sq8: "-7.9%"
comparison_matrix.pq16_recall -> recall_curve.point_pq16: "-9.8%"
comparison_matrix.pq8_recall -> recall_curve.point_pq8: "-14.6%"

y_axis."1.00" -> recall_curve.point_fp32
y_axis."0.90" -> recall_curve.point_pq16
y_axis."0.85" -> recall_curve.point_pq8