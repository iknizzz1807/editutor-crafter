direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
}

shape: sequence_diagram

st1: Search Thread 1 {
  shape: person
  style.stroke: "#2b78e4"
}
st2: Search Thread 2 {
  shape: person
  style.stroke: "#2b78e4"
}
coll: Collection Handle {
  style.fill: "#e1d5e7"
}
it: Ingest Thread (Writer) {
  shape: person
  style.stroke: "#cc0000"
}

st1 -> coll: "storage.read().unwrap()"
coll -> st1: "▼ acquire_shared() [RefCount: 1]" {
  style.stroke: "#2b78e4"
  style.bold: true
}

st1.search_op: |md
  **Executing Search**
  - Iterate `buffer.as_slice()`
  - Compute `SIMD distance`
  - Update `TopKSelector`
|

st2 -> coll: "storage.read().unwrap()"
coll -> st2: "▼ acquire_shared() [RefCount: 2]" {
  style.stroke: "#2b78e4"
  style.bold: true
}

st2.search_op: |md
  **Concurrent Read**
  - Shared access to `AlignedVectorBuffer`
  - O(1) ID lookup in `HashMap`
|

it -> coll: "storage.write().unwrap()"
coll -> it: "BLOCKING: Reader Count > 0" {
  style.stroke: "#cc0000"
  style.stroke-dash: 5
}

st1 -> coll: "drop(Guard)"
coll."Decrement RefCount [1]"

st2 -> coll: "drop(Guard)"
coll."Decrement RefCount [0]"

coll -> it: "▼ acquire_exclusive()" {
  style.stroke: "#cc0000"
  style.bold: true
}

it.write_op: |md
  **Exclusive Mutation**
  - `insert_batch()`
  - `grow_capacity()` if needed
  - Update `HNSWIndex` edges
|

it -> coll: "▲ release_exclusive()" {
  style.stroke: "#cc0000"
  style.bold: true
}

# Documentation Overlay
legend: {
  near: bottom-right
  read: "Shared Read Lock" {
    style.stroke: "#2b78e4"
    style.fill: "#2b78e4"
  }
  write: "Exclusive Write Lock" {
    style.stroke: "#cc0000"
    style.fill: "#cc0000"
  }
}

title: |md
  ### M6: Concurrent Access Model (RwLock)
  *Visualizing Reader-Writer Isolation Invariants*
| {
  near: top-center
}