direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- Classes & Styling ---
classes: {
  step_box: {
    style: {
      stroke-width: 2
      border-radius: 5
    }
  }
  decision_diamond: {
    shape: diamond
    style: {
      fill: "#fff2cc"
      stroke: "#d6b656"
    }
  }
  path_pre: {
    style: {
      fill: "#dae8fc"
      stroke: "#6c8ebf"
      stroke-width: 3
    }
  }
  path_post: {
    style: {
      fill: "#d5e8d4"
      stroke: "#82b366"
      stroke-width: 3
    }
  }
  highlight: {
    style: {
      stroke: "#ff0000"
      bold: true
    }
  }
}

# --- Main Diagram ---
FilterStrategy_Auto: "FilterStrategy::Auto Decision Engine" {
  
  # Step 1: Input Analysis
  Step1: "1. Receive SearchRequest" {
    class: step_box
    label: |md
      ### Input Parameters
      - **Query**: `Vec<f32>`
      - **Filter**: `Predicate`
      - **K**: `usize`
    |
  }

  # Step 2: Sampling Phase
  Step2: "2. Estimate Selectivity (S)" {
    class: step_box
    label: |md
      ### Estimation Logic
      - Sample size: `N = min(100, live_count)`
      - Iteration: `storage.iter_live().take(N)`
      - **S = matching_count / N**
    |
  }

  # Step 3: Decision Logic
  Step3: "3. Threshold Evaluation" {
    class: decision_diamond
    label: "Is S > 0.30?"
  }

  # Branch A: Pre-Filtering
  Step4A: "4a. Execute Pre-Filter Path" {
    class: path_pre
    label: |md
      ### Strategy: Subset Scan
      - **Why**: High density of matches.
      - **Action**: 
        1. Scan `Metadata` for all matching IDs.
        2. Filter storage subset.
        3. Brute-force `Distance` on subset.
      - **Tradeoff**: Fast, low memory.
    |
  }

  # Branch B: Post-Filtering
  Step4B: "4b. Execute Post-Filter Path" {
    class: path_post
    label: |md
      ### Strategy: ANN + Re-rank
      - **Why**: Low density (Needle in haystack).
      - **Action**:
        1. HNSW search with oversampling `(k * factor)`.
        2. Evaluate `Predicate` on result set.
        3. Re-rank/Fill until `k` matches found.
      - **Tradeoff**: Maintains HNSW complexity.
    |
  }

  # Final Step: Result
  Step5: "5. Return Top-K Results" {
    class: step_box
    style.fill: "#f8cecc"
  }

  # Connections
  Step1 -> Step2: "Pass Predicate"
  Step2 -> Step3: "Calculated S"
  
  Step3 -> Step4A: "Yes (> 30%)" {
    style: {
      stroke: "#6c8ebf"
      animated: true
    }
  }
  
  Step3 -> Step4B: "No (<= 30%)" {
    style: {
      stroke: "#82b366"
      animated: true
    }
  }

  Step4A -> Step5
  Step4B -> Step5
}

# --- Supplemental Documentation ---
Legend: {
  near: bottom-right
  
  PreFilterNote: |md
    **Pre-Filter (S > 0.3)**: 
    When many vectors match, 
    narrowing the pool first is
    computationally cheaper.
  | {
    style.fill: "#dae8fc"
  }

  PostFilterNote: |md
    **Post-Filter (S <= 0.3)**:
    When few vectors match, 
    Pre-filtering breaks HNSW
    graph navigability. Better 
    to search broadly and trim.
  | {
    style.fill: "#d5e8d4"
  }
}

# Consistency with Master Map
MetadataRegistry: {
  shape: sql_table
  id: u64 {constraint: PK}
  fields: jsonb
  is_deleted: bool
}

MetadataRegistry -> FilterStrategy_Auto.Step2: "Provides Sample Data" {
  style.stroke-dash: 5
}