vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # REST API Endpoint Map
  **Vector Database v1.0**
  *Implementation Specification*
| {
  near: top-center
}

API_Router: {
  shape: package
  label: "HTTP Server (axum/tokio)\nListen: 0.0.0.0:8080"
  style.fill: "#f8f9fa"
  
  Collection_Routes: {
    shape: sql_table
    label: "Collection Management APIs"
    "POST /collections": "Create new vector space"
    "GET /collections": "List all active collections"
    "GET /collections/{id}": "Get metadata & stats"
    "DELETE /collections/{id}": "Drop collection & storage"
  }

  Vector_Routes: {
    shape: sql_table
    label: "Vector Data APIs"
    "POST /collections/{id}/vectors": "Insert single vector"
    "POST /collections/{id}/vectors/batch": "Bulk ingest (O(N) amortized)"
    "GET /collections/{id}/vectors/{vid}": "Fetch vector + metadata"
    "DELETE /collections/{id}/vectors/{vid}": "Tombstone deletion"
  }

  Search_Routes: {
    shape: sql_table
    label: "Search & Index APIs"
    "POST /collections/{id}/search": "ANN or Brute-Force KNN"
    "POST /collections/{id}/build": "Trigger HNSW construction"
  }
}

CollectionHandler: {
  shape: class
  definition: "src/api/handlers/collection.rs"
  
  + create_collection(req: CreateCollectionRequest): Result<ApiResponse<CollectionResponse>, ApiError>
  + list_collections(): Result<ApiResponse<ListCollectionsResponse>, ApiError>
  + delete_collection(name: String): Result<ApiResponse<()>, ApiError>
  
  config: CollectionConfig
}

# Separated from class to fix nesting error
CollectionConfig: {
  shape: class
  dimension: "usize (4 to 4096)"
  metric: DistanceMetricDto
  hnsw_config: HnswConfig
}

VectorHandler: {
  shape: class
  definition: "src/api/handlers/vector.rs"
  
  + insert_vector(name: String, req: InsertRequest): Result<ApiResponse<InsertResponse>, ApiError>
  + insert_batch(name: String, req: InsertBatchRequest): Result<ApiResponse<InsertBatchResponse>, ApiError>
  + delete_vector(name: String, vid: String): Result<ApiResponse<DeleteResponse>, ApiError>
}

SearchHandler: {
  shape: class
  definition: "src/api/handlers/search.rs"
  
  + search(name: String, req: SearchRequest): Result<ApiResponse<SearchResponse>, ApiError>
  
  # Moved internal_logic children into methods to fix nesting error
  - selectivity_estimation(predicate: FilterDto): f64
  - dispatch_strategy(selectivity: f64): FilterStrategy
}

# Request DTO Models
Data_Transfer_Objects: {
  SearchRequest: {
    shape: class
    vector: "Vec<f32>"
    k: "usize (default=10)"
    filter: "Option<FilterDto>"
    strategy: "SearchStrategyDto"
    timeout_ms: u64
  }

  CreateCollectionRequest: {
    shape: class
    name: String
    dimension: usize
    metric: "enum {l2, cosine, dot}"
    storage: "enum {fp32, sq8, pq}"
  }
}

# Connections
API_Router.Collection_Routes -> CollectionHandler: "Dispatches to"
API_Router.Vector_Routes -> VectorHandler: "Dispatches to"
API_Router.Search_Routes -> SearchHandler: "Dispatches to"

CollectionHandler -- Data_Transfer_Objects.CreateCollectionRequest: "Parses"
SearchHandler -- Data_Transfer_Objects.SearchRequest: "Parses"

CollectionHandler -> CollectionConfig: "Contains"

# Core Dependencies
CollectionHandler -> M1_Storage: "Initializes M1" {style.stroke-dash: 5}
VectorHandler -> M1_Storage: "Writes to M1"
SearchHandler -> M3_BruteForce: "Executes (Small N)"
SearchHandler -> M4_HNSW: "Executes (Large N)"
SearchHandler -> M2_Distance: "Calls for scoring"

M1_Storage: "M1: Vector Storage" {
  style.fill: "#f2f2f2"
  tooltip: "On-disk segment management"
}
M2_Distance: "M2: Distance Metrics" {
  style.fill: "#f2f2f2"
  tooltip: "SIMD optimized kernels"
}
M3_BruteForce: "M3: Brute Force KNN" {
  style.fill: "#f2f2f2"
}
M4_HNSW: "M4: HNSW Index" {
  style.fill: "#f2f2f2"
  tooltip: "Hierarchical Navigable Small Worlds"
}

legend: {
  near: bottom-right
  note: |md
    ### Legend
    - **Solid Arrow**: Ownership / Direct Call
    - **Dashed Arrow**: Dependency / Reference
    - **sql_table**: API Endpoint Map (Routing Table)
    - **class**: Implementation Logic & Type Definitions
  |
}