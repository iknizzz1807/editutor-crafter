direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# FilterPredicate AST: Evaluation Tree
# Detailed byte-level architecture for recursive evaluation of Boolean filter expressions.

ast_root: "FilterPredicate::And" {
  shape: class
  "0x00: discriminant": "u8 (And=0)"
  "0x08: predicates": "Vec<Box<FilterPredicate>> (24B)"
  
  "sizeof": "32 bytes (64-bit alignment)"

  "+ evaluate(metadata: &VectorMetadata)": "bool"
  "+ estimate_selectivity()": "Option<f64>"
  
  style: {
    fill: "#E4DBFE"
    stroke: "#6772E5"
    stroke-width: 2
  }
}

match_branch: "FilterPredicate::Match" {
  shape: class
  "0x00: field": "String (24B)"
  "0x18: value": "MetadataValue (24B)"
  "0x30: discriminant": "u8 (Match=1)"
  
  "sizeof": "56 bytes"

  "+ evaluate(metadata: &VectorMetadata)": "bool"
  
  style: {
    fill: "#C7F1FF"
    stroke: "#3f87a6"
  }
}

or_branch: "FilterPredicate::Or" {
  shape: class
  "0x00: discriminant": "u8 (Or=2)"
  "0x08: predicates": "Vec<Box<FilterPredicate>> (24B)"
  
  "sizeof": "32 bytes"

  "+ evaluate(metadata: &VectorMetadata)": "bool"
  
  style: {
    fill: "#E4DBFE"
    stroke: "#6772E5"
  }
}

range_leaf: "FilterPredicate::Range" {
  shape: class
  "0x00: field": "String (24B)"
  "0x18: gt": "Option<f64> (16B)"
  "0x28: lt": "Option<f64> (16B)"
  "0x38: discriminant": "u8 (Range=3)"
  
  "sizeof": "64 bytes (1 cache line)"

  "+ evaluate(metadata: &VectorMetadata)": "bool"
  
  style: {
    fill: "#C7F1FF"
    stroke: "#3f87a6"
  }
}

in_leaf: "FilterPredicate::In" {
  shape: class
  "0x00: field": "String (24B)"
  "0x18: values": "Vec<MetadataValue> (24B)"
  "0x30: discriminant": "u8 (In=4)"
  
  "sizeof": "56 bytes"

  "+ evaluate(metadata: &VectorMetadata)": "bool"
  
  style: {
    fill: "#C7F1FF"
    stroke: "#3f87a6"
  }
}

# Ownership Hierarchy (Solid Arrows)
# Vector storage implies heap allocation for child nodes
ast_root -> match_branch: "Boxed Child [0]" {
  style: {
    stroke-width: 2
  }
}

ast_root -> or_branch: "Boxed Child [1]" {
  style: {
    stroke-width: 2
  }
}

or_branch -> range_leaf: "Boxed Child [0]" {
  style: {
    stroke-width: 2
  }
}

or_branch -> in_leaf: "Boxed Child [1]" {
  style: {
    stroke-width: 2
  }
}

# Documentation and Structural Legend
legend: {
  near: bottom-right
  
  match_box: "Leaf Node (Data Access)" {
    style: {
      fill: "#C7F1FF"
      stroke: "#3f87a6"
    }
  }
  logical_box: "Logical Operator (Recursive)" {
    style: {
      fill: "#E4DBFE"
      stroke: "#6772E5"
    }
  }
  
  annotation: |md
    ### Implementation Grade AST
    - **Solid Arrow**: Ownership via `Vec<Box<FilterPredicate>>`
    - **Evaluation**: Recursive DFS with short-circuiting logic.
    - **Byte Layout**: Offsets assume 64-bit architecture (Rust `repr(C)` or similar).
    - **Cache Alignment**: `Range` node fits exactly one 64B cache line.
  |
}

# External Reference (Dashed Arrow)
metadata_ref: "VectorMetadata" {
  shape: cylinder
  style: {
    stroke-dash: 3
    fill: "#f5f5f5"
  }
}

ast_root -> metadata_ref: "references (read-only)" {
  style: {
    stroke-dash: 5
    stroke: orange
  }
}

match_branch -> metadata_ref: "lookup(field)" {
  style: {
    stroke-dash: 5
    stroke: orange
  }
}

range_leaf -> metadata_ref: "lookup(field)" {
  style: {
    stroke-dash: 5
    stroke: orange
  }
}