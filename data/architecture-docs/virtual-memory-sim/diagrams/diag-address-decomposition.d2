direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # 32-Bit Virtual Address Decomposition
  Multi-Level Page Table Address Translation
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  address_bits: {
    direction: down
    label: "Virtual Address (32 bits)"
    bit_layout: {
      label: ""
      direction: right
      dir_idx: {
        label: "Page Directory\nIndex"
        shape: rectangle
        width: 140
        style: {
          fill: "#E8D4F0"
          stroke: "#7B4B94"
          stroke-width: 2
          font-color: "#4A2C60"
          bold: true
        }
      }
      pt_idx: {
        label: "Page Table\nIndex"
        shape: rectangle
        width: 140
        style: {
          fill: "#B8D4E8"
          stroke: "#2E6B8A"
          stroke-width: 2
          font-color: "#1A4A60"
          bold: true
        }
      }
      offset: {
        label: "Offset"
        shape: rectangle
        width: 140
        style: {
          fill: "#D4E8D4"
          stroke: "#4B8A4B"
          stroke-width: 2
          font-color: "#2C602C"
          bold: true
        }
      }
    }
    bit_ranges: {
      label: ""
      direction: right
      dir_bits: {
        label: "31 ─ 22"
        shape: rectangle
        width: 140
        style: {
          fill: "#F4E8F8"
          stroke: "#7B4B94"
          stroke-width: 1
          font: mono
          font-size: 20
        }
      }
      pt_bits: {
        label: "21 ─ 12"
        shape: rectangle
        width: 140
        style: {
          fill: "#D4E8F4"
          stroke: "#2E6B8A"
          stroke-width: 1
          font: mono
          font-size: 20
        }
      }
      off_bits: {
        label: "11 ─ 0"
        shape: rectangle
        width: 140
        style: {
          fill: "#E8F4E8"
          stroke: "#4B8A4B"
          stroke-width: 1
          font: mono
          font-size: 20
        }
      }
    }
    bit_count: {
      label: ""
      direction: right
      dir_cnt: {
        label: "10 bits"
        shape: rectangle
        width: 140
        style: {
          fill: transparent
          stroke: transparent
          font-color: "#7B4B94"
          italic: true
        }
      }
      pt_cnt: {
        label: "10 bits"
        shape: rectangle
        width: 140
        style: {
          fill: transparent
          stroke: transparent
          font-color: "#2E6B8A"
          italic: true
        }
      }
      off_cnt: {
        label: "12 bits"
        shape: rectangle
        width: 140
        style: {
          fill: transparent
          stroke: transparent
          font-color: "#4B8A4B"
          italic: true
        }
      }
    }
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  example: {
    direction: down
    label: "Example: 0x12345678"
    hex_addr: {
      label: "Virtual Address: 0x12345678"
      shape: rectangle
      width: 420
      style: {
        fill: "#FFF8E8"
        stroke: "#C4A000"
        stroke-width: 2
        font: mono
        font-size: 24
        bold: true
      }
    }
    binary: {
      label: ""
      direction: right
      bin_dir: {
        label: |md
          **0001 0010 01**
          (binary)
        |
        shape: rectangle
        width: 140
        style: {
          fill: "#E8D4F0"
          stroke: "#7B4B94"
          font: mono
          font-size: 14
        }
      }
      bin_pt: {
        label: |md
          **10 0101 0110**
          (binary)
        |
        shape: rectangle
        width: 140
        style: {
          fill: "#B8D4E8"
          stroke: "#2E6B8A"
          font: mono
          font-size: 14
        }
      }
      bin_off: {
        label: |md
          **0111 1000**
          (binary)
        |
        shape: rectangle
        width: 140
        style: {
          fill: "#D4E8D4"
          stroke: "#4B8A4B"
          font: mono
          font-size: 14
        }
      }
    }
    decimal: {
      label: ""
      direction: right
      dec_dir: {
        label: |md
          **73**
          (decimal)
        |
        shape: rectangle
        width: 140
        style: {
          fill: "#F4E8F8"
          stroke: "#7B4B94"
          font: mono
          font-size: 16
        }
      }
      dec_pt: {
        label: |md
          **598**
          (decimal)
        |
        shape: rectangle
        width: 140
        style: {
          fill: "#D4E8F4"
          stroke: "#2E6B8A"
          font: mono
          font-size: 16
        }
      }
      dec_off: {
        label: |md
          **0x678**
          (hex)
        |
        shape: rectangle
        width: 140
        style: {
          fill: "#E8F4E8"
          stroke: "#4B8A4B"
          font: mono
          font-size: 16
        }
      }
    }
  }
}
row3: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  extraction: {
    direction: down
    label: "Bit Extraction Code (C)"
    code_block: {
      label: "Address Decomposition"
      width: 450
      code: |'c
        #define PAGE_SHIFT    12
        #define PAGE_MASK     0xFFF
        #define DIR_SHIFT     22
        #define DIR_MASK      0x3FF
        #define TABLE_SHIFT   12
        #define TABLE_MASK    0x3FF
        uint32_t va = 0x12345678;
        uint32_t dir_index  = (va >> 22) & 0x3FF;  // = 73
        uint32_t table_index = (va >> 12) & 0x3FF; // = 598
        uint32_t offset     = va & 0xFFF;          // = 0x678
        uint32_t vpn        = va >> 12;            // = 0x12345
      '|
      style: {
        fill: "#2D2D2D"
        stroke: "#555555"
        font-color: "#E0E0E0"
        font: mono
      }
    }
  }
}
row4: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  legend: {
    direction: right
    label: "Legend"
    vpn_box: {
      label: ""
      direction: right
      vpn_color: {
        label: ""
        shape: rectangle
        width: 20
        style.fill: "#9B59B6"
      }
      vpn_text: {
        label: "VPN = dir_index + table_index (20 bits)"
        shape: text
        style.font-size: 14
      }
    }
    offset_box: {
      label: ""
      direction: right
      offset_color: {
        label: ""
        shape: rectangle
        width: 20
        style.fill: "#27AE60"
      }
      offset_text: {
        label: "Offset passes through unchanged"
        shape: text
        style.font-size: 14
      }
    }
  }
}
row5: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  capacities: {
    direction: down
    label: "Capacity Summary"
    cap_table: {
      shape: sql_table
      label: "Structure Sizes"
      f0: "Field | Bits | Entries | Coverage"
      f1: "Page Directory Index | 10 | 1,024 | 1,024 page tables"
      f2: "Page Table Index | 10 | 1,024 | 1,024 pages per table"
      f3: "Offset | 12 | 4,096 | 4 KB per page"
      f4: "Total | 32 | 2²⁰ | 4 GB address space"
    }
  }
  formulas: {
    direction: down
    label: "Key Formulas"
    formula_block: {
      label: "Translation Math"
      width: 380
      code: |'c
        // VPN extraction (which page)
        vpn = va >> PAGE_SHIFT;
        // Offset extraction (where in page)  
        offset = va & PAGE_MASK;
        // Physical address composition
        pa = (pfn << PAGE_SHIFT) | offset;
        // Why 12 bits? 2^12 = 4096 = 4KB
        // Why 10 bits? 2^10 = 1024 entries
      '|
      style: {
        fill: "#F8F8F8"
        stroke: "#CCCCCC"
        font: mono
      }
    }
  }
}
address_bits.bit_layout.dir_idx -> example.hex_addr: "decomposes"
example.hex_addr -> extraction.code_block: "computed by"