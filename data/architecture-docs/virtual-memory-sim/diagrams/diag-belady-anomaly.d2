    label: "4 Frames (FIFO)"
    # Frame states as a grid
    frames_4: {
      grid-columns: 5
      grid-gap: 0
      # Header row
      h_access: "Access"
      h_f0: "F0"
      h_f1: "F1"
      h_f2: "F2"
      h_f3: "F3"
      # Step 1: Access 1
      s1_a: "1"
      s1_0: "1"
      s1_1: "-"
      s1_2: "-"
      s1_3: "-"
      # Step 2: Access 2
      s2_a: "2"
      s2_0: "1"
      s2_1: "2"
      s2_2: "-"
      s2_3: "-"
      # Step 3: Access 3
      s3_a: "3"
      s3_0: "1"
      s3_1: "2"
      s3_2: "3"
      s3_3: "-"
