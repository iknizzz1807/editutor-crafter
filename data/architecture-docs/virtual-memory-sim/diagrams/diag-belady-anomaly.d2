      s4_a: "4"
      s4_0: "1"
      s4_1: "2"
      s4_2: "3"
      s4_3: "4"
      # Step 5: Access 1 (HIT)
      s5_a: "1"
      s5_0: "1"
      s5_1: "2"
      s5_2: "3"
      s5_3: "4"
      # Step 6: Access 2 (HIT)
      s6_a: "2"
      s6_0: "1"
      s6_1: "2"
      s6_2: "3"
      s6_3: "4"
      # Step 7: Access 5 (evict 1)
      s7_a: "5"
      s7_0: "5"
      s7_1: "2"
      s7_2: "3"
      s7_3: "4"
      # Step 8: Access 1 (evict 2)
      s8_a: "1"
      s8_0: "5"
      s8_1: "1"
      s8_2: "3"
      s8_3: "4"
      # Step 9: Access 2 (evict 3)
      s9_a: "2"
      s9_0: "5"
      s9_1: "1"
      s9_2: "2"
      s9_3: "4"
      # Step 10: Access 3 (evict 4)
      s10_a: "3"
      s10_0: "5"
      s10_1: "1"
      s10_2: "2"
      s10_3: "3"
      # Step 11: Access 4 (HIT)
      s11_a: "4"
      s11_0: "5"
      s11_1: "1"
      s11_2: "2"
      s11_3: "3"
      # Step 12: Access 5 (HIT)
      s12_a: "5"
      s12_0: "5"
      s12_1: "1"
      s12_2: "2"
      s12_3: "3"
    }
    # Style the grid
    frames_4.*.style: {
      fill: "#F8D7DA"
      stroke: "#721C24"
      stroke-width: 1
      font-size: 14
    }
    frames_4.h_*.style: {
      fill: "#721C24"
      font-color: white
      bold: true
    }
    frames_4.s*_a.style: {
      fill: "#FFF3CD"
      stroke: "#856404"
    }
    result_4: {
      label: "Result: 10 Page Faults"
      style: {
        fill: "#F8D7DA"
        stroke: "#DC3545"
        stroke-width: 3
        bold: true
        font-size: 18
