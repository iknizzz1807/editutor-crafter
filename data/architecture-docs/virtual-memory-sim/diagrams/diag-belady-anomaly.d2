# Arrow showing anomaly
case_3frames.result_3 -> case_4frames.result_4: "+1 frame\n+1 fault" {
  style: {
    stroke: "#DC3545"
    stroke-width: 4
    bold: true
    font-size: 16
    animated: true
  }
}
# Row 3: Explanation
explanation: {
  direction: down
  label: "Why Does This Happen?"
  cause: {
    width: 600
    code: |'c
      // FIFO only considers LOAD ORDER, not ACCESS PATTERN
      // With 3 frames: page 1 evicted just BEFORE being reused
      // With 4 frames: page 1 stays LONGER, evicted just BEFORE reuse
      // The extra frame changes eviction TIMING, not just capacity
    '|
  }
  insight: {
    label: |md
      **Key Insight**: FIFO is NOT a stack algorithm.
      Pages in memory with N+1 frames are NOT always a superset
      of pages with N frames. This violates the inclusion property.
    |
    style: {
      fill: "#FFF3CD"
      stroke: "#856404"
      stroke-width: 2
    }
  }
  fix: {
    label: |md
      **The Fix**: LRU and Optimal are stack algorithms.
      They are IMMUNE to Bélády's anomaly — more frames
      never increases faults.
    |
    style: {
      fill: "#D4EDDA"
      stroke: "#28A745"
      stroke-width: 2
    }
  }
}
# Comparison table
comparison: {
  direction: right
  label: "Fault Comparison by Algorithm"
  algo_table: {
    shape: sql_table
    label: "Page Faults (12 accesses)"
    row_algo: "Algorithm | 3 Frames | 4 Frames | 5 Frames"
    row_fifo: "FIFO | 9 | 10 ❌ | 6"
    row_lru: "LRU | 10 | 8 | 6"
    row_opt: "Optimal | 7 | 6 | 5"
  }
  algo_table.row_fifo.style.fill: "#F8D7DA"
}
# Legend
legend: {
  near: bottom-right
  label: "Legend"
  hit: "🟢 HIT: Page in frame"
  fault: "🔴 FAULT: Page loaded"
  anomaly: "❌ ANOMALY: More faults with more frames"
  style: {
    fill: "#F8F9FA"
    stroke: "#DEE2E6"
    font-size: 12
  }
}
# Flow annotation
flow_note: {
  label: |md
    **Trace the anomaly:**
    - At step 7, both cases fault on page 5
    - 3-frames evicts page 4 (loaded at step 4)
    - 4-frames evicts page 1 (loaded at step 1)
    - Page 1 is needed at step 8!
    - 4-frames must fault again to reload page 1
    - 3-frames still has page 1 in memory
  |
  style: {
    fill: "#E2E3E5"
    stroke: "#383D41"
    stroke-width: 2
  }
}