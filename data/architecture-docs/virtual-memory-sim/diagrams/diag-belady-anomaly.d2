direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Bélády's Anomaly
  **More frames can cause MORE page faults with FIFO**
| {near: top-center}
subtitle: |md
  Access Pattern: `1 → 2 → 3 → 4 → 1 → 2 → 5 → 1 → 2 → 3 → 4 → 5`
| {near: top-center}
# Row 1: 3 Frames Case
row_3frames: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  case_3frames: {
    direction: down
    label: "3 Frames (FIFO)"
    # Frame states as a grid
    frames_3: {
      grid-columns: 4
      grid-gap: 0
      # Header row
      h_access: "Access"
      h_f0: "F0"
      h_f1: "F1"
      h_f2: "F2"
      # Step 1: Access 1
      s1_a: "1"
      s1_0: "1"
      s1_1: "-"
      s1_2: "-"
      # Step 2: Access 2
      s2_a: "2"
      s2_0: "1"
      s2_1: "2"
      s2_2: "-"
      # Step 3: Access 3
      s3_a: "3"
      s3_0: "1"
      s3_1: "2"
      s3_2: "3"
      # Step 4: Access 4 (evict 1)
      s4_a: "4"
      s4_0: "4"
      s4_1: "2"
      s4_2: "3"
      # Step 5: Access 1 (evict 2)
      s5_a: "1"
      s5_0: "4"
      s5_1: "1"
      s5_2: "3"
      # Step 6: Access 2 (evict 3)
      s6_a: "2"
      s6_0: "4"
      s6_1: "1"
      s6_2: "2"
      # Step 7: Access 5 (evict 4)
      s7_a: "5"
      s7_0: "5"
      s7_1: "1"
      s7_2: "2"
      # Step 8: Access 1 (HIT)
      s8_a: "1"
      s8_0: "5"
      s8_1: "1"
      s8_2: "2"
      # Step 9: Access 2 (HIT)
      s9_a: "2"
      s9_0: "5"
      s9_1: "1"
      s9_2: "2"
      # Step 10: Access 3 (evict 5)
      s10_a: "3"
      s10_0: "3"
      s10_1: "1"
      s10_2: "2"
      # Step 11: Access 4 (evict 1)
      s11_a: "4"
      s11_0: "3"
      s11_1: "4"
      s11_2: "2"
      # Step 12: Access 5 (HIT)
      s12_a: "5"
      s12_0: "3"
      s12_1: "4"
      s12_2: "5"
    }
    # Style the grid
    frames_3.*.style: {
      fill: "#E8F4E8"
      stroke: "#4A7C59"
      stroke-width: 1
      font-size: 14
    }
    frames_3.h_*.style: {
      fill: "#4A7C59"
      font-color: white
      bold: true
    }
    frames_3.s*_a.style: {
      fill: "#FFF3CD"
      stroke: "#856404"
    }
    result_3: {
      label: "Result: 9 Page Faults"
      style: {
        fill: "#D4EDDA"
        stroke: "#28A745"
        stroke-width: 3
        bold: true
        font-size: 18
      }
    }
  }
}
