direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  process_box: {
    style: {
      fill: "#E8F4E8"
      stroke: "#2D7D2D"
      stroke-width: 2
      border-radius: 8
    }
  }
  directory_box: {
    style: {
      fill: "#FFF4E6"
      stroke: "#E67E22"
      stroke-width: 2
    }
  }
  tlb_box: {
    style: {
      fill: "#E6F3FF"
      stroke: "#3498DB"
      stroke-width: 2
    }
  }
  cr3_reg: {
    style: {
      fill: "#FFE6E6"
      stroke: "#E74C3C"
      stroke-width: 2
      font: mono
    }
  }
  transition_arrow: {
    style: {
      stroke: "#9B59B6"
      stroke-width: 3
      animated: true
    }
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_a: "State 1: Process A Running" {
    direction: down
    class: process_box
    width: 400
    cpu_state_a: "CPU State" {
      direction: right
      cr3_a: "CR3 Register\n0x1000" {
        class: cr3_reg
        shape: rectangle
        width: 120
      }
    }
    tlb_a: "TLB Cache" {
      class: tlb_box
      direction: down
      width: 350
      label: "TLB (Process A entries)"
      entry_a1: "Entry 0: VPN 0x1 → PFN 0x42 | ASID=A"
      entry_a2: "Entry 1: VPN 0x2 → PFN 0x17 | ASID=A"
      entry_a3: "Entry 2: VPN 0x8 → PFN 0x99 | ASID=A"
    }
    dir_label_a: "Page Directory A" {
      class: directory_box
      width: 350
      dir_a: {
        shape: sql_table
        label: "Page Directory (PFN 0x1000)"
        r0: "Index 0 | PT at PFN 0x50"
        r1: "Index 1 | PT at PFN 0x51"
        r2: "Index 2 | PT at PFN 0x52"
        r3: "... | ..."
      }
    }
    cr3_a -> tlb_a: "translations"
    cr3_a -> dir_label_a.dir_a: "points to"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  transition: "Context Switch Event" {
    direction: down
    style.fill: "#F5E6FF"
    style.stroke: "#9B59B6"
    style.stroke-width: 2
    style.border-radius: 8
    width: 350
    trigger: {
      label: "OS Scheduler"
      code: |'c
        // save Process A state
        save_registers(proc_a);
        // Switch to Process B
        cr3 = proc_b->cr3;  // 0x2000
        // Flush TLB (or change ASID)
        tlb_flush();
        // Resume Process B
        restore_registers(proc_b);
      '|
      width: 300
    }
    note: "CR3 write triggers\nTLB invalidation"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_b: "State 2: Process B Running" {
    direction: down
    class: process_box
    width: 400
    cpu_state_b: "CPU State" {
      direction: right
      cr3_b: "CR3 Register\n0x2000" {
        class: cr3_reg
        shape: rectangle
        width: 120
        style.fill: "#E6FFE6"
      }
    }
    tlb_b: "TLB Cache" {
      class: tlb_box
      direction: down
      width: 350
      label: "TLB (FLUSHED - now empty)"
      style.fill: "#F0F0F0"
      style.stroke: "#888888"
      style.stroke-dash: 3
      empty1: "Entry 0: INVALID"
      empty2: "Entry 1: INVALID"
      empty3: "Entry 2: INVALID"
    }
    dir_label_b: "Page Directory B" {
      class: directory_box
      width: 350
      dir_b: {
        shape: sql_table
        label: "Page Directory (PFN 0x2000)"
        r0: "Index 0 | PT at PFN 0x80"
        r1: "Index 1 | PT at PFN 0x81"
        r2: "Index 5 | PT at PFN 0x85"
        r3: "... | ..."
      }
    }
    cr3_b -> tlb_b: "cold start\n(misses)"
    cr3_b -> dir_label_b.dir_b: "points to"
  }
}
row1.state_a -> row2.transition: "save context" {
  class: transition_arrow
}
row2.transition -> row3.state_b: "load context" {
  class: transition_arrow
}
legend: "Context Switch Effects" {
  near: bottom-right
  style.fill: white
  style.stroke: "#666"
  item1: "1. CR3 updated → new page directory root"
  item2: "2. TLB flushed → all old entries invalid"
  item3: "3. Subsequent accesses → TLB miss + page walk"
  item4: "4. Same VPN in A and B → different PFNs"
  item1.style.font-color: "#E74C3C"
  item2.style.font-color: "#3498DB"
  item3.style.font-color: "#9B59B6"
  item4.style.font-color: "#2D7D2D"
}