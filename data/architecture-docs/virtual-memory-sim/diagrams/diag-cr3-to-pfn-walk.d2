direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Page Table Walk: CR3 → Physical Address" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  cr3_box: CR3 Register {
    shape: rectangle
    width: 180
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
      stroke-width: 2
      font: mono
    }
    cr3_label: "cr3" {
      shape: text
      style.font: mono
    }
    cr3_desc: "Page Directory\nBase Address" {
      shape: text
      style: {
        font-size: 11
        font-color: "#666666"
      }
    }
  }
  va_box: Virtual Address (32-bit) {
    shape: rectangle
    width: 280
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 2
    }
    va_bits: {
      direction: right
      style.stroke: transparent
      pd_bits: "PD Index\n(10 bits)" {
        shape: rectangle
        width: 80
        style: {
          fill: "#FFCC80"
          stroke: "#E65100"
        }
      }
      pt_bits: "PT Index\n(10 bits)" {
        shape: rectangle
        width: 80
        style: {
          fill: "#FFB74D"
          stroke: "#E65100"
        }
      }
      off_bits: "Offset\n(12 bits)" {
        shape: rectangle
        width: 80
        style: {
          fill: "#FFA726"
          stroke: "#E65100"
        }
      }
    }
    va_range: "Bits: 31-22    |    21-12    |    11-0" {
      shape: text
      style: {
        font-size: 10
        font: mono
        font-color: "#666666"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pd_box: Page Directory {
    shape: rectangle
    width: 200
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 2
    }
    pd_entries: {
      direction: down
      pd_0: "PDE[0]"
      pd_dots: "..."
      pd_n: "PDE[n]"
      pd_target: "PDE[PD_Index]" {
        style: {
          fill: "#A5D6A7"
          bold: true
        }
      }
    }
    pd_size: "1024 entries × 4 bytes = 4 KB" {
      shape: text
      style: {
        font-size: 10
        font-color: "#666666"
      }
    }
  }
  pde_box: PDE (Page Directory Entry) {
    shape: class
    label: "struct pde_t"
    page_table_pfn: "uint32_t"
    present: "bool"
    writable: "bool"
    user_accessible: "bool"
    style: {
      fill: "#C8E6C9"
      stroke: "#2E7D32"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  pt_box: Page Table {
    shape: rectangle
    width: 200
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 2
    }
    pt_entries: {
      direction: down
      pt_0: "PTE[0]"
      pt_dots: "..."
      pt_n: "PTE[n]"
      pt_target: "PTE[PT_Index]" {
        style: {
          fill: "#CE93D8"
          bold: true
        }
      }
    }
    pt_size: "1024 entries × 4 bytes = 4 KB" {
      shape: text
      style: {
        font-size: 10
        font-color: "#666666"
      }
    }
  }
  pte_box: PTE (Page Table Entry) {
    shape: class
    label: "struct pte_t"
    pfn: "uint32_t"
    valid: "bool"
    readable: "bool"
    writable: "bool"
    dirty: "bool"
    referenced: "bool"
    style: {
      fill: "#E1BEE7"
      stroke: "#7B1FA2"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  compose_box: Address Composition {
    shape: rectangle
    width: 300
    style: {
      fill: "#FFF8E1"
      stroke: "#F57C00"
      stroke-width: 2
    }
    compose_title: "Physical Address = (PFN << 12) | Offset" {
      shape: text
      style: {
        font: mono
        bold: true
      }
    }
    compose_formula: {
      direction: right
      style.stroke: transparent
      pfn_part: "PFN (20 bits)" {
        shape: rectangle
        width: 100
        style: {
          fill: "#FFCC80"
          stroke: "#E65100"
        }
      }
      concat: "||" {
        shape: text
        style.font-size: 20
      }
      off_part: "Offset (12 bits)" {
        shape: rectangle
        width: 100
        style: {
          fill: "#FFA726"
          stroke: "#E65100"
        }
      }
    }
  }
  pa_box: Physical Address {
    shape: rectangle
    width: 180
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
    }
    pa_value: "0xXXXXXXXX" {
      shape: text
      style: {
        font: mono
        font-size: 18
        bold: true
      }
    }
    pa_desc: "Actual RAM location" {
      shape: text
      style: {
        font-size: 11
        font-color: "#666666"
      }
    }
  }
}
legend: Memory Access Count {
  near: bottom-right
  shape: rectangle
  width: 220
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 3
  }
  leg_title: "Memory References:" {
    shape: text
    style.bold: true
  }
  leg_1: "① Read PDE from Page Directory" {
    shape: text
    style.font-size: 11
  }
  leg_2: "② Read PTE from Page Table" {
    shape: text
    style.font-size: 11
  }
  leg_3: "③ Read/Write data at PA" {
    shape: text
    style.font-size: 11
  }
  leg_total: "Total: 3 memory accesses per translation" {
    shape: text
    style: {
      font-size: 11
      bold: true
      font-color: "#D32F2F"
    }
  }
}
cr3_box -> pd_box: "① Memory Access\n(base + PD_Index × 4)" {
  style: {
    stroke: "#2E86AB"
    stroke-width: 2
  }
}
va_box.va_bits.pd_bits -> pd_box.pd_entries.pd_target: "PD_Index" {
  style: {
    stroke: "#E65100"
    stroke-dash: 3
  }
}
pd_box.pd_entries.pd_target -> pde_box: "read entry" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}
pde_box -> pt_box: "② Memory Access\n(PDE.page_table_pfn × 4096 + PT_Index × 4)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
va_box.va_bits.pt_bits -> pt_box.pt_entries.pt_target: "PT_Index" {
  style: {
    stroke: "#E65100"
    stroke-dash: 3
  }
}
pt_box.pt_entries.pt_target -> pte_box: "read entry" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
pte_box -> compose_box.pfn_part: "PFN" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 2
  }
}
va_box.va_bits.off_bits -> compose_box.off_part: "Offset" {
  style: {
    stroke: "#E65100"
    stroke-dash: 3
  }
}
compose_box -> pa_box: "③ Memory Access\n(read/write data)" {
  style: {
    stroke: "#1565C0"
    stroke-width: 3
  }
}
note_cache: "Without TLB: Each translation requires 2-4 memory accesses for page table walk (depends on levels). With TLB hit: 0 extra accesses!" {
  near: bottom-center
  shape: callout
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
  }
}