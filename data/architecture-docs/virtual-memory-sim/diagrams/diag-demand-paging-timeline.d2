direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Demand Paging Timeline" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
timeline: {
  grid-columns: 4
  grid-gap: 40
  t0_label: "T0\n(Initial)" {
    style: {
      bold: true
      fill: "#E8E8E8"
      stroke: "#666666"
      stroke-width: 2
    }
  }
  t1_label: "T1\nR 0x1A000" {
    style: {
      bold: true
      fill: "#FFE4E1"
      stroke: "#DC143C"
      stroke-width: 2
    }
  }
  t2_label: "T2\nR 0x1A100" {
    style: {
      bold: true
      fill: "#E8F5E9"
      stroke: "#228B22"
      stroke-width: 2
    }
  }
  t3_label: "T3\nR 0x2B000" {
    style: {
      bold: true
      fill: "#FFE4E1"
      stroke: "#DC143C"
      stroke-width: 2
    }
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  t0: "T0: Initial State" {
    direction: down
    style.fill: "#F5F5F5"
    page_table_t0: {
      shape: sql_table
      label: "Page Table (pte_t*)"
      vpn_1a: "VPN 0x1A | valid=0 | pfn=-- | R=1 W=1"
      vpn_2b: "VPN 0x2B | valid=0 | pfn=-- | R=1 W=1"
      note: "All entries invalid (demand paging)"
    }
    phys_mem_t0: {
      shape: sql_table
      label: "Physical Memory"
      frame_0: "Frame 0  | FREE"
      frame_1: "Frame 1  | FREE"
      frame_2: "Frame 2  | FREE"
      free: "free_count = 3"
    }
    stats_t0: {
      shape: class
      label: "Statistics"
      -total_accesses: "0"
      -page_faults: "0"
    }
  }
  t1: "T1: First Access to 0x1A000" {
    direction: down
    style.fill: "#FFF0F0"
    flow_t1: {
      label: "Translation Flow"
      width: 300
      code: |'c
        va = 0x1A000
        vpn = 0x1A, offset = 0x000
        pte = page_table[0x1A]
        if (!pte->valid) {
          // PAGE FAULT!
          pfn = allocate_frame()  // Frame 0
          pte->pfn = 0
          pte->valid = 1
        }
        pa = (0 << 12) | 0x000 = 0x0000
      '|
    }
    page_table_t1: {
      shape: sql_table
      label: "Page Table (after fault)"
      vpn_1a: "VPN 0x1A | valid=1 | pfn=0  | R=1 W=1"
      vpn_2b: "VPN 0x2B | valid=0 | pfn=-- | R=1 W=1"
      updated: "PTE updated!"
      style.fill: "#FFE4E1"
    }
    phys_mem_t1: {
      shape: sql_table
      label: "Physical Memory"
      frame_0: "Frame 0  | VPN 0x1A (zeroed)"
      frame_1: "Frame 1  | FREE"
      frame_2: "Frame 2  | FREE"
      free: "free_count = 2"
      style.fill: "#E8F5E9"
    }
    stats_t1: {
      shape: class
      label: "Statistics"
      -total_accesses: "1"
      -page_faults: "1"
    }
    event_t1: "PAGE FAULT → Frame allocated" {
      shape: callout
      style: {
        fill: "#FFE4E1"
        stroke: "#DC143C"
      }
    }
  }
  t2: "T2: Re-access 0x1A100" {
    direction: down
    style.fill: "#F0FFF0"
    flow_t2: {
      label: "Translation Flow"
      width: 300
      code: |'c
        va = 0x1A100
        vpn = 0x1A, offset = 0x100
        pte = page_table[0x1A]
        if (pte->valid) {
          // FAST PATH - no fault!
          pte->referenced = 1
        }
        pa = (0 << 12) | 0x100 = 0x0100
      '|
    }
    page_table_t2: {
      shape: sql_table
      label: "Page Table (hit)"
      vpn_1a: "VPN 0x1A | valid=1 | pfn=0  | ref=1"
      vpn_2b: "VPN 0x2B | valid=0 | pfn=-- | R=1 W=1"
      unchanged: "No structural change"
      style.fill: "#E8F5E9"
    }
    phys_mem_t2: {
      shape: sql_table
      label: "Physical Memory"
      frame_0: "Frame 0  | VPN 0x1A"
      frame_1: "Frame 1  | FREE"
      frame_2: "Frame 2  | FREE"
      free: "free_count = 2"
    }
    stats_t2: {
      shape: class
      label: "Statistics"
      -total_accesses: "2"
      -page_faults: "1"
    }
    event_t2: "TLB/PT HIT → No fault" {
      shape: callout
      style: {
        fill: "#E8F5E9"
        stroke: "#228B22"
      }
    }
  }
  t3: "T3: First Access to 0x2B000" {
    direction: down
    style.fill: "#FFF0F0"
    flow_t3: {
      label: "Translation Flow"
      width: 300
      code: |'c
        va = 0x2B000
        vpn = 0x2B, offset = 0x000
        pte = page_table[0x2B]
        if (!pte->valid) {
          // PAGE FAULT!
          pfn = allocate_frame()  // Frame 1
          pte->pfn = 1
          pte->valid = 1
        }
        pa = (1 << 12) | 0x000 = 0x1000
      '|
    }
    page_table_t3: {
      shape: sql_table
      label: "Page Table (after fault)"
      vpn_1a: "VPN 0x1A | valid=1 | pfn=0  | ref=1"
      vpn_2b: "VPN 0x2B | valid=1 | pfn=1  | R=1 W=1"
      updated: "New PTE valid!"
      style.fill: "#FFE4E1"
    }
    phys_mem_t3: {
      shape: sql_table
      label: "Physical Memory"
      frame_0: "Frame 0  | VPN 0x1A"
      frame_1: "Frame 1  | VPN 0x2B (zeroed)"
      frame_2: "Frame 2  | FREE"
      free: "free_count = 1"
      style.fill: "#E8F5E9"
    }
    stats_t3: {
      shape: class
      label: "Statistics"
      -total_accesses: "3"
      -page_faults: "2"
    }
    event_t3: "PAGE FAULT → Frame allocated" {
      shape: callout
      style: {
        fill: "#FFE4E1"
        stroke: "#DC143C"
      }
    }
  }
}
t0 -> t1: "R 0x1A000\nFAULT" {
  style: {
    stroke: "#DC143C"
    stroke-width: 3
    bold: true
  }
}
t1 -> t2: "R 0x1A100\nHIT" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
    bold: true
  }
}
t2 -> t3: "R 0x2B000\nFAULT" {
  style: {
    stroke: "#DC143C"
    stroke-width: 3
    bold: true
  }
}
legend: {
  near: bottom-center
  direction: right
  fault: "PAGE FAULT" {
    shape: rectangle
    style: {
      fill: "#FFE4E1"
      stroke: "#DC143C"
      stroke-width: 2
    }
  }
  hit: "TLB/PT HIT" {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#228B22"
      stroke-width: 2
    }
  }
  free: "FREE FRAME" {
    shape: rectangle
    style: {
      fill: "#F5F5F5"
      stroke: "#666666"
      stroke-dash: 3
    }
  }
}