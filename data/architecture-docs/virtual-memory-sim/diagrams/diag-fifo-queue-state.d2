direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # FIFO Replacement: Queue Evolution
  **FIFO evicts by load order, ignoring access recency**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t1: {
    label: "T1: Page A Loaded"
    width: 280
    queue_t1: {
      shape: queue
      label: "FIFO Queue"
      style.fill: "#E8F5E9"
    }
    frames_t1: {
      label: "Frames"
      shape: sql_table
      f0: "0 | A"
      f1: "1 | -"
      f2: "2 | -"
    }
    access_t1: {
      label: "Access: A"
      width: 120
      code: |'c
        R 0x1000  // VPN A
        // Fault → load A
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t2: {
    label: "T2: Page B Loaded"
    width: 280
    queue_t2: {
      shape: queue
      label: "FIFO Queue"
      style.fill: "#E8F5E9"
    }
    frames_t2: {
      label: "Frames"
      shape: sql_table
      f0: "0 | A"
      f1: "1 | B"
      f2: "2 | -"
    }
    access_t2: {
      label: "Access: B"
      width: 120
      code: |'c
        R 0x2000  // VPN B
        // Fault → load B
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t3: {
    label: "T3: Page C Loaded"
    width: 280
    queue_t3: {
      shape: queue
      label: "FIFO Queue"
      style.fill: "#E8F5E9"
    }
    frames_t3: {
      label: "Frames"
      shape: sql_table
      f0: "0 | A"
      f1: "1 | B"
      f2: "2 | C"
    }
    access_t3: {
      label: "Access: C"
      width: 120
      code: |'c
        R 0x3000  // VPN C
        // Fault → load C
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t4: {
    label: "T4: Page D Requested (FAULT)"
    width: 280
    queue_t4: {
      shape: queue
      label: "FIFO Queue"
      style.fill: "#FFEBEE"
    }
    frames_t4: {
      label: "Frames"
      shape: sql_table
      f0: "0 | D"
      f1: "1 | B"
      f2: "2 | C"
      f0.style.fill: "#FFCDD2"
    }
    access_t4: {
      label: "Access: D"
      width: 120
      code: |'c
        R 0x4000  // VPN D
        // Fault → evict A!
      '|
      style.stroke: red
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  t5: {
    label: "T5: A Accessed Again (FAULT!)"
    width: 280
    queue_t5: {
      shape: queue
      label: "FIFO Queue"
      style.fill: "#FFEBEE"
    }
    frames_t5: {
      label: "Frames"
      shape: sql_table
      f0: "0 | A"
      f1: "1 | B"
      f2: "2 | C"
      f0.style.fill: "#FFCDD2"
    }
    access_t5: {
      label: "Access: A"
      width: 120
      code: |'c
        R 0x1000  // VPN A
        // FAULT! A was evicted
      '|
      style.stroke: red
    }
  }
}
t1 -> t2: "load B"
t2 -> t3: "load C"
t3 -> t4: "load D\n(evict A)"
t4 -> t5: "access A\n(FAULT!)"
problem_box: {
  label: "The FIFO Problem"
  width: 600
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
  problem: |md
    **FIFO ignores access patterns!**
    Even though page A was accessed at T5 (just now), FIFO evicts it
    because it was loaded *first*—not because it's "old" in terms
    of recency of use.
    Compare with LRU: A would survive because it was recently used.
  |
}
problem_box.near: bottom-center
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  legend_title: "Legend"
  green: "Loaded page" {style.fill: "#E8F5E9"}
  red: "Evicted / Fault" {style.fill: "#FFCDD2"}
  queue_shape: "Queue head → tail (evict from head)"
}