direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  hardware: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
  software: {
    style: {
      fill: "#FFF3E0"
      stroke: "#FF9800"
      stroke-width: 2
    }
  }
  decision: {
    shape: diamond
    style: {
      fill: "#FCE4EC"
      stroke: "#E91E63"
    }
  }
  data: {
    shape: rectangle
    style: {
      fill: "#E8F5E9"
      stroke: "#4CAF50"
    }
  }
  storage: {
    shape: cylinder
    style: {
      fill: "#F3E5F5"
      stroke: "#9C27B0"
    }
  }
  error: {
    style: {
      fill: "#FFEBEE"
      stroke: "#F44336"
      stroke-dash: 4
    }
  }
}
title: {
  label: |md
    # Complete Translation Pipeline: Virtual Address → Physical Address
    *Data flow through TLB, Page Tables, and Swap subsystem*
  |
  near: top-center
  shape: text
  style.font-size: 20
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  input: {
    direction: down
    label: "INPUT"
    va: {
      label: "Virtual Address\n0x00401234"
      class: data
      width: 140
      bitfield: {
        shape: sql_table
        label: "32-bit VA Decomposition"
        dir: "0x00401234 >> 22 & 0x3FF"
        tbl: "0x00401234 >> 12 & 0x3FF"
        off: "0x00401234 & 0xFFF"
        note_dir: "Directory Index = 1"
        note_tbl: "Table Index = 1"
        note_off: "Offset = 0x234"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tlb_stage: {
    direction: down
    label: "TLB STAGE (Hardware)"
    tlb_lookup: {
      label: "TLB Lookup"
      class: hardware
      width: 160
      tlb_struct: {
        shape: sql_table
        label: "TLB Entry Fields"
        f0: "vpn: uint32_t"
        f1: "pfn: uint32_t"
        f2: "asid: uint32_t"
        f3: "valid: bool"
        f4: "readable: bool"
        f5: "writable: bool"
        f6: "dirty: bool"
      }
    }
    tlb_hit: {
      label: "TLB Hit?"
      class: decision
    }
    tlb_miss: {
      label: "TLB Miss\n→ Page Table Walk"
      class: hardware
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  walk_stage: {
    direction: down
    label: "PAGE TABLE WALK (Hardware)"
    cr3: {
      label: "CR3 Register\n(Page Directory Base)"
      class: hardware
      width: 160
    }
    pde_read: {
      label: "Read PDE\npage_directory[dir_index]"
      class: hardware
    }
    pde_present: {
      label: "PDE\npresent?"
      class: decision
    }
    pte_read: {
      label: "Read PTE\npage_table[tbl_index]"
      class: hardware
    }
    pte_valid: {
      label: "PTE\nvalid?"
      class: decision
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  perm_stage: {
    direction: down
    label: "PERMISSION CHECK"
    perm_check: {
      label: "Permission\nCheck"
      class: decision
    }
    perm_ok: {
      label: "Update Bits\nreferenced=1\ndirty=1 (if write)"
      class: hardware
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  compose: {
    direction: down
    label: "ADDRESS COMPOSITION"
    pa_compose: {
      label: "Compose PA\n(pfn << 12) | offset"
      class: data
      width: 160
      formula: {
        shape: sql_table
        label: "Physical Address"
        pfn: "PFN from PTE (20 bits)"
        off_copy: "Offset (12 bits)"
        result: "= 0x7F000234"
      }
    }
    phys_mem: {
      label: "Physical Memory\nFrame Pool"
      class: storage
      width: 160
      frame_info: {
        shape: sql_table
        label: "Frame Pool State"
        total: "total_frames: 64"
        free: "free_count: 3"
        used: "frames used: 61"
      }
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fault_stage: {
    direction: down
    label: "PAGE FAULT HANDLER (OS)"
    fault_detect: {
      label: "Page Fault\nException"
      class: software
      width: 160
    }
    check_swap: {
      label: "Page in\nSwap?"
      class: decision
    }
    alloc_frame: {
      label: "Allocate Frame\n(free_list or evict)"
      class: software
    }
    need_evict: {
      label: "Free\nFrame?"
      class: decision
    }
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  replace_stage: {
    direction: down
    label: "PAGE REPLACEMENT"
    select_victim: {
      label: "Select Victim\n(FIFO/LRU/Clock)"
      class: software
      width: 160
    }
    check_dirty: {
      label: "Victim\nDirty?"
      class: decision
    }
    write_swap: {
      label: "Write to Swap\nmemcpy + disk I/O"
      class: storage
    }
    discard_clean: {
      label: "Discard\n(clean page)"
      class: software
    }
  }
}
row8: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  swap_stage: {
    direction: down
    label: "SWAP SUBSYSTEM"
    swap_space: {
      label: "Swap Space"
      class: storage
      width: 160
      swap_struct: {
        shape: sql_table
        label: "swap_slot_t"
        data: "data[4096]"
        vpn: "vpn: uint32_t"
        occupied: "occupied: bool"
      }
    }
    swap_read: {
      label: "Read from Swap\n(DMA transfer)"
      class: storage
    }
    swap_map: {
      label: "Swap Map\nvpn → slot_index"
      class: data
    }
  }
}
row9: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  update_stage: {
    direction: down
    label: "UPDATE & RETRY"
    update_pte: {
      label: "Update PTE\nvalid=1, pfn=frame"
      class: software
      width: 160
    }
    update_tlb: {
      label: "Insert TLB Entry\nvpn → pfn"
      class: hardware
    }
    retry: {
      label: "Retry Instruction"
      class: hardware
    }
  }
}
row10: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  error_stage: {
    direction: down
    label: "ERROR PATHS"
    prot_fault: {
      label: "Protection Fault\n(SIGSEGV)"
      class: error
      width: 140
    }
    dir_fault: {
      label: "Directory Invalid\n(Unmapped Region)"
      class: error
    }
    oom: {
      label: "Out of Memory\n(Swap Full)"
      class: error
    }
  }
}
# Main flow: Input to TLB
input.va -> tlb_stage.tlb_lookup: "vpn=1\nasid=0"
# TLB flow
tlb_stage.tlb_lookup -> tlb_stage.tlb_hit: "compare all entries"
# TLB hit path (fast)
tlb_stage.tlb_hit -> compose.pa_compose: "HIT\npfn cached" {
  label: "YES"
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
# TLB miss path (slow)
tlb_stage.tlb_hit -> walk_stage.cr3: "MISS\nstart walk" {
  label: "NO"
  style.stroke: "#FF9800"
}
tlb_stage.tlb_miss -> walk_stage.cr3: "vpn → walk"
# Page table walk
walk_stage.cr3 -> walk_stage.pde_read: "dir_base"
walk_stage.pde_read -> walk_stage.pde_present: "pde"
# PDE present check
walk_stage.pde_present -> fault_stage.fault_detect: "NO" {
  label: "NO"
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
walk_stage.pde_present -> walk_stage.pte_read: "page_table_addr" {
  label: "YES"
  style.stroke: "#4CAF50"
}
walk_stage.pte_read -> walk_stage.pte_valid: "pte"
# PTE valid check
walk_stage.pte_valid -> fault_stage.fault_detect: "NO\nPage Fault" {
  label: "NO"
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
walk_stage.pte_valid -> perm_stage.perm_check: "pte" {
  label: "YES"
  style.stroke: "#4CAF50"
}
# Permission check
perm_stage.perm_check -> error_stage.prot_fault: "VIOLATION" {
  label: "DENY"
  style.stroke: "#F44336"
  style.stroke-dash: 4
}
perm_stage.perm_check -> perm_stage.perm_ok: "ALLOW" {
  label: "OK"
  style.stroke: "#4CAF50"
}
perm_stage.perm_ok -> compose.pa_compose: "pfn + offset"
# Compose to physical memory
compose.pa_compose -> compose.phys_mem: "physical_addr"
# Page fault handling
fault_stage.fault_detect -> fault_stage.check_swap: "handle fault"
fault_stage.check_swap -> swap_stage.swap_read: "YES\nreload" {
  label: "YES"
  style.stroke: "#9C27B0"
}
fault_stage.check_swap -> fault_stage.alloc_frame: "NO\nzero-fill" {
  label: "NO"
  style.stroke: "#2196F3"
}
fault_stage.alloc_frame -> fault_stage.need_evict: "request frame"
fault_stage.need_evict -> replace_stage.select_victim: "NO free frames" {
  label: "NO"
  style.stroke: "#FF9800"
}
fault_stage.need_evict -> update_stage.update_pte: "frame available" {
  label: "YES"
  style.stroke: "#4CAF50"
}
# Replacement flow
replace_stage.select_victim -> replace_stage.check_dirty: "victim_vpn"
replace_stage.check_dirty -> replace_stage.write_swap: "YES\ndirty=1" {
  label: "YES"
  style.stroke: "#9C27B0"
}
replace_stage.check_dirty -> replace_stage.discard_clean: "NO\nclean" {
  label: "NO"
  style.stroke: "#2196F3"
}
replace_stage.write_swap -> swap_stage.swap_space: "write 4KB"
replace_stage.discard_clean -> update_stage.update_pte: "invalidate PTE"
# Swap operations
swap_stage.swap_space -> swap_stage.swap_read: "slot data"
swap_stage.swap_read -> swap_stage.swap_map: "lookup slot"
swap_stage.swap_map -> update_stage.update_pte: "frame loaded"
# Update and retry
update_stage.update_pte -> update_stage.update_tlb: "PTE ready"
update_stage.update_tlb -> update_stage.retry: "TLB cached"
update_stage.retry -> input.va: "re-execute" {
  style.stroke: "#4CAF50"
  style.animated: true
}
# Error connections
error_stage.dir_fault -> fault_stage.fault_detect: "unmapped"
error_stage.oom -> replace_stage.select_victim: "swap full"
# Statistics annotation
stats: {
  near: bottom-center
  label: |md
    **Statistics Collected:**
    - total_accesses, tlb_hits, tlb_misses
    - page_faults, protection_faults
    - swap_writes, swap_reads, swap_discards
    - evictions, thrashing_warnings
  |
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  hw: {
    label: "Hardware (Fast)"
    class: hardware
  }
  sw: {
    label: "Software (OS)"
    class: software
  }
  err: {
    label: "Error Path"
    class: error
  }
  stor: {
    label: "Storage (Slow)"
    class: storage
  }
}