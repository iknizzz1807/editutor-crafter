direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Two-Level Page Table: Bit Extraction {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
# Main 32-bit VA decomposition
va_decomposition: {
  label: "32-bit Virtual Address Decomposition"
  bit_positions: {
    shape: sql_table
    label: "Virtual Address Bit Layout"
    row31_22: "31-22    | PD Index   | 10 bits  | Page Directory entry"
    row21_12: "21-12    | PT Index   | 10 bits  | Page Table entry"
    row11_0: "11-0     | Offset     | 12 bits  | Byte within page"
    total: "Total: 32 bits (2³² = 4 GB address space)"
  }
  visual_layout: {
    label: "Visual Bit Layout"
    width: 600
    diagram: |'c
      ┌─────────────────────┬─────────────────────┬─────────────────────┐
      │   Directory Index   │     Table Index     │       Offset        │
      │      (10 bits)      │      (10 bits)      │      (12 bits)      │
      │     bits 31-22      │     bits 21-12      │      bits 11-0      │
      └─────────────────────┴─────────────────────┴─────────────────────┘
               │                    │                     │
               ▼                    ▼                     ▼
          ┌─────────┐          ┌─────────┐           ┌─────────┐
          │1024 PDEs│          │1024 PTEs│           │ 4096 B  │
          │per proc │          │per PDE  │           │ 4 KB    │
          └─────────┘          └─────────┘           └─────────┘
    '|
  }
}
# Constants and macros
constants: {
  label: "Extraction Constants (C)"
  width: 380
  code: |'c
    #define PAGE_SHIFT      12
    #define PAGE_SIZE       4096    // 2^12
    #define PAGE_MASK       0xFFF   // 12 bits set
    #define DIR_SHIFT       22
    #define DIR_MASK        0x3FF   // 10 bits set
    #define TABLE_SHIFT     12
    #define TABLE_MASK      0x3FF   // 10 bits set
  '|
}
# Extraction functions
extraction: {
  label: "Bit Extraction Functions (C)"
  width: 420
  code: |'c
    static inline uint32_t 
    get_directory_index(uint32_t va) {
        // Extract bits 31-22
        return (va >> DIR_SHIFT) & DIR_MASK;
    }
    static inline uint32_t 
    get_table_index(uint32_t va) {
        // Extract bits 21-12
        return (va >> TABLE_SHIFT) & TABLE_MASK;
    }
    static inline uint32_t 
    get_offset(uint32_t va) {
        // Extract bits 11-0
        return va & PAGE_MASK;
    }
  '|
}
# Example computation
example: {
  label: "Example: VA 0x00401234"
  width: 450
  computation: |'c
    uint32_t va = 0x00401234;
    // Directory Index (bits 31-22)
    // 0x00401234 >> 22 = 0x1
    uint32_t dir_idx = (va >> 22) & 0x3FF;  // = 1
    // Table Index (bits 21-12)  
    // 0x00401234 >> 12 = 0x401
    // 0x401 & 0x3FF = 0x1
    uint32_t table_idx = (va >> 12) & 0x3FF; // = 1
    // Offset (bits 11-0)
    // 0x00401234 & 0xFFF = 0x234
    uint32_t offset = va & 0xFFF;           // = 0x234
  '|
}
# Breakdown visualization
breakdown: {
  label: "0x00401234 Bit-by-Bit Breakdown"
  table: {
    shape: sql_table
    label: "Address Decomposition"
    row_hex: "Hex       | 0x00401234         | Full address"
    row_bin: "Binary    | 0000 0000 0100 0000 0001 0010 0011 0100"
    row_pd: "PD Index   | 0000000001         | = 0x1 (dir 1)"
    row_pt: "PT Index   | 0000000001         | = 0x1 (table 1)"
    row_off: "Offset     | 0010 0011 0100     | = 0x234"
    note: "Covers: PD[1] -> PT[1] -> byte 0x234"
  }
}
# Coverage explanation
coverage: {
  label: "Coverage Per Level"
  dir_coverage: {
    shape: sql_table
    label: "Directory Entry Coverage"
    row_range: "Each PDE | Covers 4 MB | 1024 pages × 4 KB"
    row_total: "Total    | 1024 PDEs  | 4 GB address space"
    row_sparse: "Sparse   | Only allocate PDEs for used regions"
  }
  pt_coverage: {
    shape: sql_table
    label: "Page Table Entry Coverage"
    row_range: "Each PTE | Covers 4 KB | One page"
    row_total: "Per PT   | 1024 PTEs  | 4 MB of VA space"
    row_alloc: "On-demand| Allocated when region first accessed"
  }
}
# Memory savings
savings: {
  label: "Memory Efficiency"
  comparison: {
    shape: sql_table
    label: "Flat vs Two-Level (32-bit)"
    row_flat: "Flat Table    | 1,048,576 entries × 4B | 4 MB (always)"
    row_two_dir: "Two-Level Dir | 1,024 entries × 4B    | 4 KB (always)"
    row_two_pt: "Two-Level PT  | 1,024 × 4B per table  | 4 KB each"
    row_sparse: "Sparse (3 reg)| 4 KB + 3×4 KB         | 16 KB total"
    row_savings: "Savings       | 4 MB vs 16 KB         | 256× reduction"
  }
}
# Arrows showing flow
va_decomposition -> constants: "defines constants"
constants -> extraction: "used by"
extraction -> example: "applied to"
example -> breakdown: "breakdown of"
breakdown -> coverage: "explains"
coverage -> savings: "enables"