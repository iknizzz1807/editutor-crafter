direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  label: |'md
    # Protection Fault Detection Flowchart
    Decision tree distinguishing page faults (valid=0) from protection faults (valid=1, permission denied)
  '|
  near: top-center
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent
}

row1: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  entry: {
    direction: down
    label: "Memory Access Request"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    read_req: {
      label: "Read Request"
      shape: parallelogram
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
    }
    write_req: {
      label: "Write Request"
      shape: parallelogram
      style.fill: "#FFF3CD"
      style.stroke: "#FFC107"
    }
  }
}

row2: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  valid_check: {
    direction: down
    label: "Step 1: Validity Check"
    style.fill: "#F8F9FA"
    style.stroke: "#6C757D"
    valid_decision: {
      label: "PTE.valid == 1?"
      shape: diamond
      style.fill: "#E2E3E5"
      style.stroke: "#6C757D"
    }
  }
}

row3: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  page_fault_box: {
    label: "PAGE FAULT"
    shape: rectangle
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
    style.bold: true
    style.font-color: "#721C24"
    pf_desc: |md
      **Cause:** Page not in physical memory
      **Resolution:** OS allocates frame, loads from swap/zero-fills, sets valid=1, retries
    |
  }
  perm_check: {
    direction: down
    label: "Step 2: Permission Check"
    style.fill: "#F8F9FA"
    style.stroke: "#6C757D"
    read_perm: {
      label: "Read?\nPTE.readable == 1?"
      shape: diamond
      style.fill: "#D4EDDA"
      style.stroke: "#28A745"
    }
    write_perm: {
      label: "Write?\nPTE.writable == 1?"
      shape: diamond
      style.fill: "#FFF3CD"
      style.stroke: "#FFC107"
    }
  }
}

row4: {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  prot_fault_read: {
    label: "PROTECTION FAULT\n(Read Violation)"
    shape: rectangle
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
    style.bold: true
    style.font-color: "#721C24"
    pfr_desc: |md
      **Cause:** Read from non-readable page
      **Example:** Reading from write-only memory-mapped I/O
      **Resolution:** SIGSEGV (fatal)
    |
  }
  prot_fault_write: {
    label: "PROTECTION FAULT\n(Write Violation)"
    shape: rectangle
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
    style.bold: true
    style.font-color: "#721C24"
    pfw_desc: |md
      **Cause:** Write to read-only page
      **Example:** Writing to code segment, string literals, .rodata
      **Resolution:** SIGSEGV (fatal)
    |
  }
  success_box: {
    label: "TRANSLATION OK"
    shape: rectangle
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
    style.bold: true
    style.font-color: "#155724"
    success_desc: |'md
      **Actions:**
      • Set PTE.referenced = 1
      • If write: set PTE.dirty = 1
      • Compose PA = (PFN << 12) | offset
      • Return physical address
    '|
  }
}

legend: {
  label: "Legend"
  style.fill: "#F8F9FA"
  style.stroke: "#DEE2E6"
  pf: {
    label: "Page Fault (valid=0)"
    shape: rectangle
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
  }
  prot: {
    label: "Protection Fault (valid=1)"
    shape: rectangle
    style.fill: "#F8D7DA"
    style.stroke: "#DC3545"
  }
  ok: {
    label: "Successful Translation"
    shape: rectangle
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
}
legend.near: bottom-right

pte_struct: {
  label: "Page Table Entry (PTE)"
  shape: class
  +pfn: "uint32_t"
  +valid: "bool"
  +readable: "bool"
  +writable: "bool"
  +dirty: "bool"
  +referenced: "bool"
}
pte_struct.near: bottom-left

code_snippet: {
  label: "Translation Logic (C)"
  width: 420
  code: |'c
    // Check valid bit FIRST
    if (!pte->valid) {
        stats->page_faults++;       // Page not in memory
        return TRANSLATE_PAGE_FAULT;
    }
    // Then check permissions
    if (is_write && !pte->writable) {
        stats->protection_faults++; // Permission denied
        return TRANSLATE_PROTECTION_FAULT;
    }
    if (!is_write && !pte->readable) {
        stats->protection_faults++; // Permission denied
        return TRANSLATE_PROTECTION_FAULT;
    }
    // Success: update bits and return PA
    pte->referenced = true;
    if (is_write) pte->dirty = true;
    return (pte->pfn << 12) | offset;
  '|
}
code_snippet.near: bottom-center

# Connections
row1.entry.read_req -> row2.valid_check.valid_decision: "VA + op" {
  style.stroke: "#28A745"
}
row1.entry.write_req -> row2.valid_check.valid_decision: "VA + op" {
  style.stroke: "#FFC107"
}
row2.valid_check.valid_decision -> row3.page_fault_box: "No (valid=0)" {
  style.stroke: "#DC3545"
  style.stroke-dash: 4
}
row2.valid_check.valid_decision -> row3.perm_check.read_perm: "Yes (valid=1)" {
  style.stroke: "#28A745"
}
row2.valid_check.valid_decision -> row3.perm_check.write_perm: "Yes (valid=1)" {
  style.stroke: "#28A745"
}
row3.perm_check.read_perm -> row4.prot_fault_read: "No (R=0)" {
  style.stroke: "#DC3545"
  style.stroke-dash: 4
}
row3.perm_check.read_perm -> row4.success_box: "Yes (R=1)" {
  style.stroke: "#28A745"
}
row3.perm_check.write_perm -> row4.prot_fault_write: "No (W=0)" {
  style.stroke: "#DC3545"
  style.stroke-dash: 4
}
row3.perm_check.write_perm -> row4.success_box: "Yes (W=1)" {
  style.stroke: "#28A745"
}