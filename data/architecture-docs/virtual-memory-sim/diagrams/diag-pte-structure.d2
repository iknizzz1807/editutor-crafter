row_bit_fields -> row_bit_labels: "bit position" {style.stroke: transparent}
field_details: {
  direction: down
  label: "Control Bit Definitions"
  present_detail: {
    direction: right
    label: ""
    p_flag: {
      label: "P (Present)"
      shape: hexagon
      style: {
        fill: ${colors.present}
        font-color: white
        bold: true
      }
    }
    p_info: {
      width: 450
      p_meaning: |md
        **Meaning**: Page is present in physical memory
        **0** = Page not in memory → triggers page fault
        **1** = Page valid, translation can proceed
      |
      p_mask: {
        label: |'c
          #define PTE_PRESENT    0x00000001
          #define PTE_PRESENT_MASK 0x1
          // Test: if (pte & PTE_PRESENT)
          // Set:   pte |= PTE_PRESENT
          // Clear: pte &= ~PTE_PRESENT
        '|
        width: 420
        style.fill: "#F8F9FA"
        style.stroke: "#DEE2E6"
      }
    }
  }
  rw_detail: {
    direction: right
    label: ""
    rw_flag: {
      label: "R/W"
      shape: hexagon
      style: {
        fill: ${colors.rw}
        font-color: white
        bold: true
      }
    }
    rw_info: {
      width: 450
      rw_meaning: |md
        **Meaning**: Read/Write permission
        **0** = Read-only access (writes trigger protection fault)
        **1** = Read-write access allowed
      |
      rw_mask: {
        label: |'c
          #define PTE_WRITABLE   0x00000002
          #define PTE_RW_MASK    0x2
          // Test: if (pte & PTE_WRITABLE)
          // Set:   pte |= PTE_WRITABLE
          // Clear: pte &= ~PTE_WRITABLE
        '|
        width: 420
        style.fill: "#F8F9FA"
        style.stroke: "#DEE2E6"
      }
    }
  }
  us_detail: {
    direction: right
    label: ""
    us_flag: {
      label: "U/S"
      shape: hexagon
      style: {
        fill: ${colors.user_super}
        font-color: white
        bold: true
      }
    }
    us_info: {
      width: 450
      us_meaning: |md
        **Meaning**: User/Supervisor privilege level
        **0** = Supervisor only (kernel mode, ring 0)
        **1** = User accessible (user mode, ring 3)
      |
      us_mask: {
        label: |'c
          #define PTE_USER       0x00000004
          #define PTE_USER_MASK  0x4
          // Test: if (pte & PTE_USER)
          // Set:   pte |= PTE_USER
          // Clear: pte &= ~PTE_USER
        '|
        width: 420
        style.fill: "#F8F9FA"
        style.stroke: "#DEE2E6"
      }
    }
  }
  a_detail: {
    direction: right
    label: ""
    a_flag: {
      label: "A (Accessed)"
      shape: hexagon
      style: {
        fill: ${colors.accessed}
        font-color: white
        bold: true
      }
    }
    a_info: {
      width: 450
      a_meaning: |md
        **Meaning**: Page has been accessed (read OR write)
        **Set by hardware** on any access to this page
        **Used by OS** for LRU/Clock page replacement
      |
      a_mask: {
        label: |'c
          #define PTE_ACCESSED   0x00000020
          #define PTE_A_MASK     0x20
          // Test: if (pte & PTE_ACCESSED)
          // Clear: pte &= ~PTE_ACCESSED  // OS resets periodically
        '|
        width: 420
        style.fill: "#F8F9FA"
        style.stroke: "#DEE2E6"
      }
    }
  }
  d_detail: {
    direction: right
    label: ""
    d_flag: {
      label: "D (Dirty)"
      shape: hexagon
      style: {
        fill: ${colors.dirty}
        font-color: white
        bold: true
      }
    }
    d_info: {
      width: 450
      d_meaning: |md
        **Meaning**: Page has been written to (modified)
        **Set by hardware** on write to this page
        **Used by OS** to decide if swap write needed on eviction
      |
      d_mask: {
        label: |'c
          #define PTE_DIRTY      0x00000040
          #define PTE_D_MASK     0x40
          // Test: if (pte & PTE_DIRTY)
          // Clear: pte &= ~PTE_DIRTY  // OS resets after writeback
        '|
        width: 420
        style.fill: "#F8F9FA"
        style.stroke: "#DEE2E6"
      }
    }
  }
  pfn_detail: {
    direction: right
    label: ""
    pfn_flag: {
      label: "PFN"
      shape: hexagon
      style: {
        fill: ${colors.pfn}
        font-color: white
        bold: true
      }
    }
    pfn_info: {
      width: 450
      pfn_meaning: |md
        **Meaning**: Physical Frame Number (bits 31-12)
        Specifies which 4KB frame in physical memory
        Combined with 12-bit offset to form physical address
      |
      pfn_mask: {
        label: |'c
          #define PTE_PFN_SHIFT  12
          #define PTE_PFN_MASK   0xFFFFF000
          // Extract: pfn = (pte & PTE_PFN_MASK) >> PTE_PFN_SHIFT
          // Set:     pte = (pte & ~PTE_PFN_MASK) | (pfn << 12)
        '|
        width: 420
        style.fill: "#F8F9FA"
        style.stroke: "#DEE2E6"
      }
    }
  }
}
complete_struct: {
  label: "C Structure Definition (vm_simulator.h)"
  struct_def: {
    shape: class
    label: "pte_t (Page Table Entry)"
    +pfn: "uint32_t /* bits 31-12 */"
    +_reserved: "uint32_t:3 /* bits 11-9 */"
    +global: "bool /* bit 8 */"
    +ps: "bool /* bit 7 */"
    +dirty: "bool /* bit 6 */"
    +accessed: "bool /* bit 5 */"
    +_reserved2: "uint32_t:2 /* bits 4-3 */"
    +user: "bool /* bit 2 */"
    +writable: "bool /* bit 1 */"
    +present: "bool /* bit 0 */"
  }
  note: |md
    **Hardware View**: Single 32-bit value accessed via bit masks
    **Software View**: Structure with named boolean fields for clarity
    **Translation**: Compiler packs struct to 4 bytes (sizeof(pte_t) == 4)
  |
}
usage_example: {
  label: "Common Operations"
  ops: {
    label: |'c
      // Extract PFN for address translation
      static inline uint32_t pte_get_pfn(uint32_t pte) {
          return (pte & PTE_PFN_MASK) >> PTE_PFN_SHIFT;
      }
      // Check if page is present (valid)
      static inline bool pte_is_present(uint32_t pte) {
          return (pte & PTE_PRESENT) != 0;
      }
      // Check write permission
      static inline bool pte_is_writable(uint32_t pte) {
          return (pte & PTE_WRITABLE) != 0;
      }
      // Mark page as accessed (called on every memory access)
      static inline void pte_set_accessed(uint32_t *pte) {
          *pte |= PTE_ACCESSED;
      }
      // Mark page as dirty (called on write)
      static inline void pte_set_dirty(uint32_t *pte) {
          *pte |= PTE_DIRTY;
      }
      // Compose physical address from PTE and offset
      static inline uint32_t compose_pa(uint32_t pte, uint32_t offset) {
          return (pte_get_pfn(pte) << 12) | (offset & 0xFFF);
      }
    '|
    width: 500
    style.fill: "#1E1E1E"
    style.font-color: "#D4D4D4"
    style.stroke: "#3C3C3C"
  }
}
legend: {
  near: bottom-right
  legend_title: {
    label: "Legend"
    style.bold: true
    style.underline: true
  }
  hw_set: {
    label: "Hardware-set bits"
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#FF9800"
  }
  sw_ctrl: {
    label: "Software-controlled bits"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  hw_note: |md
    **A** and **D** are set by hardware, cleared by OS
    **P**, **R/W**, **U/S** are set/cleared by OS only
  |
}
row_bit_fields -> field_details: "bit definitions"
field_details -> complete_struct: "C representation"
complete_struct -> usage_example: "implementation"