direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Page Replacement Algorithms: Visual Comparison
  **Access Pattern:** `1, 2, 3, 4, 1, 2, 5, 1, 2, 3, 4, 5` (12 accesses, 5 unique pages)
| {
  near: top-center
  shape: text
  style.font-size: 20
}
legend: {
  near: bottom-center
  grid-columns: 4
  grid-gap: 20
  style.fill: transparent
  style.stroke: transparent
  l1: |md
    **🔴 FAULT**
    Page not in memory
  | {style.fill: "#FFE4E1"}
  l2: |md
    **🟢 HIT**
    Page found in frame
  | {style.fill: "#E8F5E9"}
  l3: |md
    **⚡ EVICT**
    Page replaced
  | {style.fill: "#FFF3E0"}
  l4: |md
    **📊 3 Frames**
    Memory constraint
  | {style.fill: "#E3F2FD"}
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  trace_panel: {
    direction: down
    label: "Access Trace"
    trace_data: {
      shape: sql_table
      label: "Memory Accesses (simulator.c)"
      step: "Step | VPN | Op"
      s1: "1    | 1   | R"
      s2: "2    | 2   | R"
      s3: "3    | 3   | R"
      s4: "4    | 4   | R"
      s5: "5    | 1   | R"
      s6: "6    | 2   | R"
      s7: "7    | 5   | R"
      s8: "8    | 1   | R"
      s9: "9    | 2   | R"
      s10: "10   | 3   | R"
      s11: "11   | 4   | R"
      s12: "12   | 5   | R"
      note: "12 accesses, 5 unique VPNs, 3 frames"
    }
  }
  fifo_panel: {
    direction: down
    label: "FIFO Replacement"
    style.fill: "#FFF8E1"
    fifo_code: {
      label: "FIFO Algorithm (replacer.c:fifo_evict)"
      width: 400
      code: |'c
        uint32_t fifo_evict(fifo_t *fifo) {
          // Evict oldest entry (queue head)
          uint32_t victim = fifo->queue[fifo->head];
          fifo->head = (fifo->head + 1) % fifo->capacity;
          return victim;  // Load order only!
        }
      '|
    }
    fifo_trace: {
      shape: sql_table
      label: "FIFO Execution Trace"
      col: "Step | F0 | F1 | F2 | Action"
      t1: "1    | 1  | -  | -  | FAULT (load 1)"
      t2: "2    | 1  | 2  | -  | FAULT (load 2)"
      t3: "3    | 1  | 2  | 3  | FAULT (load 3)"
      t4: "4    | 4  | 2  | 3  | EVICT 1→4"
      t5: "5    | 4  | 1  | 3  | EVICT 2→1"
      t6: "6    | 4  | 1  | 2  | EVICT 3→2"
      t7: "7    | 5  | 1  | 2  | EVICT 4→5"
      t8: "8    | 5  | 1  | 2  | HIT"
      t9: "9    | 5  | 1  | 2  | HIT"
      t10: "10   | 5  | 3  | 2  | EVICT 1→3"
      t11: "11   | 5  | 3  | 4  | EVICT 2→4"
      t12: "12   | 5  | 3  | 4  | HIT"
      total: "FAULTS: 9 | EVICTIONS: 7"
    }
    fifo_stats: {
      shape: rectangle
      label: |md
        **FIFO Results:**
        - Page Faults: **9**
        - Evictions: **7**
        - Hit Rate: **25%**
        - ⚠️ Evicts page 1 at step 4 (needed at step 5!)
      |
      style.fill: "#FFCDD2"
    }
  }
  lru_panel: {
    direction: down
    label: "LRU Replacement"
    style.fill: "#E8F5E9"
    lru_code: {
      label: "LRU Algorithm (replacer.c:lru_evict)"
      width: 400
      code: |'c
        uint32_t lru_evict(lru_t *lru) {
          // Find page with oldest access time
          uint64_t oldest = UINT64_MAX;
          uint32_t victim = 0;
          for (i = 0; i < lru->count; i++) {
            if (lru->entries[i].last_access < oldest) {
              oldest = lru->entries[i].last_access;
              victim = lru->entries[i].vpn;
            }
          }
          return victim;  // Recency-aware!
        }
      '|
    }
    lru_trace: {
      shape: sql_table
      label: "LRU Execution Trace"
      col: "Step | F0 | F1 | F2 | Action"
      t1: "1    | 1  | -  | -  | FAULT (load 1)"
      t2: "2    | 1  | 2  | -  | FAULT (load 2)"
      t3: "3    | 1  | 2  | 3  | FAULT (load 3)"
      t4: "4    | 4  | 2  | 3  | EVICT 1→4 (1 oldest)"
      t5: "5    | 1  | 2  | 3  | EVICT 4→1 (4 oldest)"
      t6: "6    | 1  | 2  | 3  | HIT (refresh 2)"
      t7: "7    | 5  | 2  | 3  | EVICT 1→5 (1 oldest)"
      t8: "8    | 1  | 2  | 3  | EVICT 5→1 (5 oldest)"
      t9: "9    | 1  | 2  | 3  | HIT (refresh 2)"
      t10: "10   | 3  | 2  | 3  | HIT (refresh 3)"
      t11: "11   | 4  | 2  | 3  | EVICT 1→4"
      t12: "12   | 5  | 2  | 3  | EVICT 4→5"
      total: "FAULTS: 10 | EVICTIONS: 7"
    }
    lru_stats: {
      shape: rectangle
      label: |md
        **LRU Results:**
        - Page Faults: **10**
        - Evictions: **7**
        - Hit Rate: **17%**
        - ✅ Uses access recency for decisions
      |
      style.fill: "#C8E6C9"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  clock_panel: {
    direction: down
    label: "Clock (Second-Chance) Replacement"
    style.fill: "#E3F2FD"
    clock_code: {
      label: "Clock Algorithm (replacer.c:clock_evict)"
      width: 420
      code: |'c
        uint32_t clock_evict(clock_t *c, pte_t *pt) {
          while (true) {
            uint32_t vpn = c->vpns[c->hand];
            if (!c->referenced[c->hand]) {
              // Found victim - hasn't been "second-chanced"
              remove_entry(c, c->hand);
              return vpn;
            }
            // Give second chance: clear ref, move on
            c->referenced[c->hand] = false;
            c->hand = (c->hand + 1) % c->count;
          }
        }
      '|
    }
    clock_trace: {
      shape: sql_table
      label: "Clock Execution Trace"
      col: "Step | F0 | F1 | F2 | Hand | Action"
      t1: "1    | 1R | -  | -  | 0    | FAULT"
      t2: "2    | 1R | 2R | -  | 0    | FAULT"
      t3: "3    | 1R | 2R | 3R | 0    | FAULT"
      t4: "4    | 4R | 2R | 3R | 1    | Clear 1, evict"
      t5: "5    | 1R | 2R | 3R | 2    | Clear 2, evict 2"
      t6: "6    | 1R | 2R | 3R | 2    | Refresh 2"
      t7: "7    | 5R | 2R | 3R | 3    | Clear 3, evict 3"
      t8: "8    | 1R | 2R | 3R | 0    | HIT"
      t9: "9    | 1R | 2R | 3R | 0    | HIT"
      t10: "10   | 3R | 2R | 3R | 0    | HIT"
      t11: "11   | 4R | 2R | 3R | 1    | Evict 1"
      t12: "12   | 5R | 2R | 3R | 2    | Evict 4"
      total: "FAULTS: ~9-10 | Uses referenced bit"
    }
    clock_stats: {
      shape: rectangle
      label: |md
        **Clock Results:**
        - Page Faults: **9-10** (varies by timing)
        - Evictions: **7**
        - ✅ Hardware-friendly (uses R bit only)
        - ✅ O(1) amortized eviction
      |
      style.fill: "#BBDEFB"
    }
  }
  optimal_panel: {
    direction: down
    label: "Optimal (Bélády's) Replacement"
    style.fill: "#F3E5F5"
    optimal_code: {
      label: "Optimal Algorithm (replacer.c:optimal_evict)"
      width: 420
      code: |'c
        uint32_t optimal_evict(opt_t *opt, 
                              uint32_t *loaded,
                              uint32_t n) {
          int64_t farthest = -1;
          uint32_t victim = loaded[0];
          for (i = 0; i < n; i++) {
            int64_t next = find_next_use(opt->trace, 
                              opt->pos, loaded[i]);
            if (next == -1) return loaded[i]; // Never again!
            if (next > farthest) {
              farthest = next;
              victim = loaded[i];
            }
          }
          return victim;  // Perfect prediction!
        }
      '|
    }
    optimal_trace: {
      shape: sql_table
      label: "Optimal Execution Trace"
      col: "Step | F0 | F1 | F2 | Action"
      t1: "1    | 1  | -  | -  | FAULT"
      t2: "2    | 1  | 2  | -  | FAULT"
      t3: "3    | 1  | 2  | 3  | FAULT"
      t4: "4    | 1  | 2  | 4  | EVICT 3 (used at 10)"
      t5: "5    | 1  | 2  | 4  | HIT"
      t6: "6    | 1  | 2  | 4  | HIT"
      t7: "7    | 1  | 2  | 5  | EVICT 4 (used at 11)"
      t8: "8    | 1  | 2  | 5  | HIT"
      t9: "9    | 1  | 2  | 5  | HIT"
      t10: "10   | 1  | 2  | 3  | EVICT 5 (used at 12)"
      t11: "11   | 1  | 4  | 3  | EVICT 2 (never!)"
      t12: "12   | 1  | 5  | 3  | EVICT 4 (never!)"
      total: "FAULTS: 7 | EVICTIONS: 5"
    }
    optimal_stats: {
      shape: rectangle
      label: |md
        **Optimal Results:**
        - Page Faults: **7** (theoretical minimum!)
        - Evictions: **5**
        - Hit Rate: **42%**
        - 🎯 Lower bound for all algorithms
        - ❌ Requires future knowledge
      |
      style.fill: "#E1BEE7"
    }
  }
  belady_panel: {
    direction: down
    label: "Bélády's Anomaly Demonstration"
    style.fill: "#FFEBEE"
    belady_explain: {
      label: "Why FIFO Can Get WORSE with More Memory"
      width: 380
      code: |'c
        // With 3 frames: FIFO gets 9 faults
        // With 4 frames: FIFO gets 10 faults!
        // 
        // The anomaly occurs because FIFO's eviction
        // depends ONLY on load order, not access pattern.
        // More frames → different queue state → 
        // different (worse) eviction timing.
        //
        // LRU and Optimal are "stack algorithms":
        // pages(N+1 frames) ⊇ pages(N frames)
        // More frames never hurts!
      '|
    }
    belady_table: {
      shape: sql_table
      label: "Faults vs Frame Count"
      hdr: "Frames | FIFO | LRU | Clock | Optimal"
      r3: "3      | 9    | 10  | 9-10  | 7"
      r4: "4      | 10 ⚠️| 8   | 8     | 6"
      r5: "5      | 5    | 5   | 5     | 5"
      r6: "6      | 5    | 5   | 5     | 5"
      note: "⚠️ FIFO got WORSE with 4 frames!"
    }
    anomaly_box: {
      shape: diamond
      label: |md
        **ANOMALY DETECTED**
        FIFO: 9→10 faults
        when adding a frame!
      |
      style.fill: "#FFCDD2"
    }
  }
}
comparison_summary: {
  label: "Algorithm Comparison Summary"
  summary_table: {
    shape: sql_table
    label: "Trade-offs (replacer.h)"
    col: "Algorithm | Complexity | Locality | Hardware | Anomaly"
    fifo: "FIFO      | O(1)       | None     | Trivial  | YES ⚠️"
    lru: "LRU       | O(n) scan  | Temporal | Timestamp| No"
    clock: "Clock     | O(1) amrt  | Approx   | R bit    | No"
    opt: "Optimal   | O(n×m)     | Perfect  | Future   | No"
    rec: "Recommendation: Clock for production, Optimal for benchmarking"
  }
  key_insight: {
    label: |md
      **Key Insight:** The 3-frame constraint forces early evictions.
      - FIFO evicts blindly by age → can evict "hot" pages
      - LRU tracks actual usage → respects locality
      - Clock approximates LRU with minimal hardware support
      - Optimal proves 7 faults is the theoretical minimum
    |
    style.fill: "#FFF9C4"
  }
}
trace_panel -> fifo_panel: "Simulate"
trace_panel -> lru_panel: "Simulate"
trace_panel -> clock_panel: "Simulate"
trace_panel -> optimal_panel: "Simulate"
fifo_panel -> belady_panel: "Anomaly!"
lru_panel -> comparison_summary: "Stats"
clock_panel -> comparison_summary: "Stats"
optimal_panel -> comparison_summary: "Baseline"