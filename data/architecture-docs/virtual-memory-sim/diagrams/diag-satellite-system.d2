direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Virtual Memory Simulator: System Overview
  Complete address translation pipeline with TLB caching, multi-level page tables, and page replacement
| {near: top-center}
legend: {
  near: bottom-right
  label: Legend
  shape: rectangle
  style.fill: "#f8f9fa"
  legend_data: |md
    **Data Flow** → Translation requests
    **Control Flow** ⤏ Metadata/signals
    **Fault Path** ⇢ Error handling
  |
}
row_input: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  trace_input: {
    label: "Trace Input\n(trace_parser.c)"
    shape: document
    style.fill: "#e3f2fd"
    style.stroke: "#1976d2"
    width: 180
    format: {
      label: "Format"
      shape: rectangle
      style.fill: "#bbdefb"
      line1: "R 0x00001000"
      line2: "W 0x00002000"
      line3: "..."
    }
    access_t: {
      shape: class
      label: "memory_access_t"
      is_write: "bool"
      virtual_address: "uint32_t"
    }
  }
  trace_input -> format
  format -> access_t: "parse"
}
row_core: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  translation_pipeline: {
    label: "Address Translation Pipeline"
    direction: down
    style.fill: "#fff3e0"
    style.stroke: "#ff9800"
    tlb_stage: {
      label: "Stage 1: TLB Lookup\n(Milestone 2)"
      direction: right
      style.fill: "#ffe0b2"
      tlb: {
        shape: class
        label: "tlb_t (TLB)"
        entries: "tlb_entry_t*"
        capacity: "uint32_t"
        current_asid: "uint32_t"
        hits: "uint64_t"
        misses: "uint64_t"
      }
      tlb_entry: {
        shape: sql_table
        label: "tlb_entry_t"
        f0: "0x00 | uint32_t | vpn"
        f1: "0x04 | uint32_t | pfn"
        f2: "0x08 | uint32_t | asid"
        f3: "0x0C | bool     | valid"
        f4: "0x0D | bool     | readable"
        f5: "0x0E | bool     | writable"
        f6: "0x0F | bool     | dirty"
        f7: "0x10 | bool     | referenced"
        f8: "0x14 | uint64_t | last_used"
        sz: "Total: 24 bytes"
      }
      tlb -> tlb_entry: "contains"
    }
    hit_path: {
      label: "TLB HIT"
      shape: oval
      style.fill: "#c8e6c9"
      style.stroke: "#4caf50"
    }
    miss_path: {
      label: "TLB MISS"
      shape: oval
      style.fill: "#ffcdd2"
      style.stroke: "#f44336"
    }
    tlb_stage -> hit_path: "vpn+asid match"
    tlb_stage -> miss_path: "no match"
    page_table_stage: {
      label: "Stage 2: Page Table Walk\n(Milestone 1, 3)"
      direction: down
      style.fill: "#e1f5fe"
      cr3_reg: {
        label: "CR3 Register\n(Page Directory Base)"
        shape: rectangle
        style.fill: "#b3e5fc"
        style.stroke: "#0288d1"
        style.bold: true
        width: 160
        cr3_val: "cr3: uint32_t"
        process_id: "current_process"
      }
      multi_level: {
        label: "Multi-Level Page Table"
        direction: right
        pml4: {
          shape: class
          label: "Page Directory\n(CR3 → PDEs)"
          dir_entries: "pde_t[1024]"
        }
        pd_arrow: {
          label: "PDE.pfn"
          shape: text
        }
        pt: {
          shape: class
          label: "Page Table\n(PTEs)"
          pt_entries: "pte_t[1024]"
        }
        pml4 -> pd_arrow -> pt
      }
      pte_struct: {
        shape: sql_table
        label: "pte_t (Page Table Entry)"
        f0: "0x00 | uint32_t | pfn"
        f1: "0x04 | bool     | valid"
        f2: "0x05 | bool     | readable"
        f3: "0x06 | bool     | writable"
        f4: "0x07 | bool     | dirty"
        f5: "0x08 | bool     | referenced"
        sz: "Total: 12 bytes"
      }
      cr3_reg -> multi_level: "root"
      multi_level -> pte_struct: "walks to"
    }
    fault_detector: {
      label: "Fault Detection"
      direction: right
      style.fill: "#fce4ec"
      page_fault: {
        label: "Page Fault\n(valid=0)"
        shape: diamond
        style.fill: "#f8bbd9"
        style.stroke: "#c2185b"
      }
      prot_fault: {
        label: "Protection Fault\n(R/W violation)"
        shape: diamond
        style.fill: "#f8bbd9"
        style.stroke: "#c2185b"
      }
    }
    miss_path -> page_table_stage
    page_table_stage -> fault_detector
    fault_detector -> page_fault: "valid==0" {
      style.stroke-dash: 4
      style.stroke: "#c2185b"
    }
    fault_detector -> prot_fault: "permission denied" {
      style.stroke-dash: 4
      style.stroke: "#c2185b"
    }
    phys_mem_stage: {
      label: "Stage 3: Physical Memory\n(Milestone 1)"
      direction: down
      style.fill: "#e8f5e9"
      phys_mem: {
        shape: class
        label: "physical_memory_t"
        frames: "uint8_t**"
        total_frames: "uint32_t"
        free_list: "uint32_t*"
        free_count: "uint32_t"
      }
      frame_pool: {
        label: "Frame Pool"
        shape: rectangle
        style.fill: "#c8e6c9"
        width: 200
        frame0: "Frame 0: 4KB"
        frame1: "Frame 1: 4KB"
        frame_n: "..."
        frame_n1: "Frame N-1: 4KB"
      }
      phys_mem -> frame_pool: "manages"
    }
    hit_path -> phys_mem_stage: "pfn direct"
    page_table_stage -> phys_mem_stage: "pte.pfn << 12 | offset"
  }
}
row_replacement: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  replacement: {
    label: "Page Replacement Engine\n(Milestone 4)"
    direction: down
    style.fill: "#f3e5f5"
    style.stroke: "#7b1fa2"
    trigger: {
      label: "Eviction Trigger\n(free_count == 0)"
      shape: diamond
      style.fill: "#e1bee7"
    }
    algos: {
      label: "Replacement Algorithms"
      direction: right
      fifo: {
        shape: rectangle
        label: "FIFO\nQueue"
        style.fill: "#d1c4e9"
      }
      lru: {
        shape: rectangle
        label: "LRU\nTimestamps"
        style.fill: "#d1c4e9"
      }
      clock: {
        shape: rectangle
        label: "Clock\nReferenced bits"
        style.fill: "#d1c4e9"
      }
      optimal: {
        shape: rectangle
        label: "Optimal\nLookahead"
        style.fill: "#b39ddb"
      }
    }
    victim_select: {
      label: "Victim Selection"
      shape: rectangle
      style.fill: "#e1bee7"
    }
    trigger -> algos: "select algorithm"
    algos -> victim_select: "return victim VPN"
  }
  swap: {
    label: "Swap Space\n(Milestone 4)"
    direction: down
    style.fill: "#e0f7fa"
    style.stroke: "#00838f"
    swap_struct: {
      shape: class
      label: "swap_space_t"
      slots: "swap_slot_t*"
      total_slots: "uint32_t"
      free_list: "uint32_t*"
      free_count: "uint32_t"
    }
    swap_slot: {
      shape: sql_table
      label: "swap_slot_t"
      f0: "0x000 | uint8_t[4096] | data"
      f1: "0x1000| uint32_t     | vpn"
      f2: "0x1004| uint32_t     | process_id"
      f3: "0x1008| bool         | occupied"
      sz: "Total: 4104 bytes"
    }
    swap_map: {
      shape: class
      label: "swap_mapping_t"
      swap_slot: "int32_t"
      in_swap: "bool"
    }
    swap_struct -> swap_slot: "contains"
    swap_struct -> swap_map: "tracks"
    swap_ops: {
      label: "Swap Operations"
      direction: right
      writeback: {
        label: "Write-Back\n(dirty pages)"
        shape: rectangle
        style.fill: "#b2ebf2"
      }
      reload: {
        label: "Reload\n(on fault)"
        shape: rectangle
        style.fill: "#b2ebf2"
      }
    }
    swap_slot -> swap_ops
  }
}
row_context: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  context: {
    label: "Cross-Cutting Concerns"
    direction: right
    style.fill: "#fafafa"
    style.stroke: "#9e9e9e"
    style.stroke-dash: 3
    asid_ctx: {
      label: "ASID Context\n(Milestone 2)"
      direction: down
      asid: {
        shape: class
        label: "ASID Management"
        current_asid: "uint32_t"
        asid_pool: "bool[256]"
      }
      asid_desc: |md
        - Per-process address space ID
        - TLB entries tagged with ASID
        - No flush on context switch
      |
      asid -> asid_desc
    }
    cr3_ctx: {
      label: "CR3 / Process Context\n(Milestone 3)"
      direction: down
      cr3_mgmt: {
        shape: class
        label: "Process Management"
        pid: "uint32_t"
        cr3: "uint32_t"
        page_directory: "pde_t*"
      }
      cr3_desc: |md
        - CR3 = page directory root
        - Context switch = CR3 change
        - Per-process page tables
      |
      cr3_mgmt -> cr3_desc
    }
  }
}
row_stats: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stats: {
    label: "Statistics Collection"
    direction: right
    style.fill: "#fff8e1"
    style.stroke: "#ff8f00"
    stats_struct: {
      shape: sql_table
      label: "stats_t"
      f0: "total_accesses | uint64_t"
      f1: "page_faults     | uint64_t"
      f2: "protection_flt  | uint64_t"
      f3: "tlb_hits        | uint64_t"
      f4: "tlb_misses      | uint64_t"
      f5: "swap_writes     | uint64_t"
      f6: "swap_reads      | uint64_t"
      f7: "swap_discards   | uint64_t"
      f8: "thrashing_warn  | uint64_t"
      sz: "Total: 72 bytes"
    }
    metrics: {
      label: "Key Metrics"
      direction: down
      tlb_rate: "TLB Hit Rate: hits/total"
      fault_rate: "Page Fault Rate: faults/total"
      ws_size: "Working Set Size"
      mem_overhead: "Memory Overhead"
    }
    stats_struct -> metrics: "computes"
  }
}
row_milestones: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  milestones: {
    label: "Milestone Anchors"
    direction: right
    style.fill: "#eceff1"
    m1: {
      label: "M1: Single-Level\nPage Table"
      shape: rectangle
      style.fill: "#ffcdd2"
      link: "#virtual-memory-sim-m1"
    }
    m2: {
      label: "M2: TLB\nCaching"
      shape: rectangle
      style.fill: "#c8e6c9"
      link: "#virtual-memory-sim-m2"
    }
    m3: {
      label: "M3: Multi-Level\nPage Tables"
      shape: rectangle
      style.fill: "#bbdefb"
      link: "#virtual-memory-sim-m3"
    }
    m4: {
      label: "M4: Page\nReplacement"
      shape: rectangle
      style.fill: "#d1c4e9"
      link: "#virtual-memory-sim-m4"
    }
  }
}
trace_input -> tlb_stage: "memory_access_t" {
  style.stroke: "#1976d2"
  style.stroke-width: 2
}
page_fault -> replacement: "trigger eviction" {
  style.stroke-dash: 4
  style.stroke: "#c2185b"
  style.animated: true
}
replacement -> swap: "write-back dirty page" {
  style.stroke: "#7b1fa2"
}
swap -> phys_mem_stage: "reload page" {
  style.stroke: "#00838f"
  style.stroke-dash: 3
}
replacement -> phys_mem_stage: "allocate frame" {
  style.stroke: "#7b1fa2"
}
tlb_stage -> stats: "hits/misses" {
  style.stroke-dash: 3
  style.stroke: "#ff9800"
}
page_table_stage -> stats: "faults" {
  style.stroke-dash: 3
  style.stroke: "#0288d1"
}
replacement -> stats: "swap I/O" {
  style.stroke-dash: 3
  style.stroke: "#7b1fa2"
}
asid_ctx -> tlb_stage: "ASID tag" {
  style.stroke-dash: 5
  style.stroke: "#9e9e9e"
}
cr3_ctx -> page_table_stage: "CR3 root" {
  style.stroke-dash: 5
  style.stroke: "#9e9e9e"
}