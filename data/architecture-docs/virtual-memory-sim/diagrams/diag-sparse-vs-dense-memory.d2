direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Memory Overhead: Flat vs Multi-Level Page Tables" {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    stroke: transparent
    fill: transparent
  }
  scenario1: {
    direction: down
    label: "Scenario 1: Dense Address Space"
    desc1: |md
      **All 1024 page regions accessed**
      (Full 4 GB virtual address space mapped)
    | {
      shape: rectangle
      width: 380
      style.fill: lightyellow
    }
    flat1: {
      label: "Flat Page Table"
      shape: sql_table
      f0: "VPN 0       | PTE"
      f1: "VPN 1       | PTE"
      f2: "VPN 2       | PTE"
      f3: "...          | ..."
      f4: "VPN 1048575 | PTE"
      sz: "Total: 1,048,576 × 4B = **4 MB**"
      style: {
        fill: "#FFD6D6"
        stroke: "#CC0000"
      }
    }
    multi1: {
      label: "Two-Level Page Table"
      shape: sql_table
      d0: "Page Directory (1024 PDEs)"
      d1: "    └─ Page Table 0 (1024 PTEs)"
      d2: "    └─ Page Table 1 (1024 PTEs)"
      d3: "    └─ ..."
      d4: "    └─ Page Table 1023 (1024 PTEs)"
      sz: "Total: 4 KB + (1024 × 4 KB) = **4,100 KB**"
      style: {
        fill: "#D6FFD6"
        stroke: "#006600"
      }
    }
    verdict1: |md
      **Dense space:** Flat is slightly better
      (4 MB vs 4.1 MB — 2.5% overhead for indirection)
    | {
      shape: rectangle
      width: 380
      style.fill: lightgray
    }
  }
  scenario2: {
    direction: down
    label: "Scenario 2: Sparse Address Space"
    desc2: |md
      **Only 10 page regions accessed**
      (Code, heap, stack, a few libraries)
    | {
      shape: rectangle
      width: 380
      style.fill: lightyellow
    }
    flat2: {
      label: "Flat Page Table"
      shape: sql_table
      f0: "VPN 0       | PTE"
      f1: "VPN 1       | PTE"
      f2: "VPN 2       | PTE"
      f3: "...          | ..."
      f4: "VPN 1048575 | PTE"
      sz: "Total: 1,048,576 × 4B = **4 MB** (unchanged!)"
      style: {
        fill: "#FFD6D6"
        stroke: "#CC0000"
      }
    }
    multi2: {
      label: "Two-Level Page Table"
      shape: sql_table
      d0: "Page Directory (1024 PDEs)"
      d1: "    └─ Page Table 1 (code)"
      d2: "    └─ Page Table 4 (heap)"
      d3: "    └─ Page Table 64 (lib)"
      d4: "    └─ ... (7 more tables)"
      d5: "    └─ Page Table 511 (stack)"
      sz: "Total: 4 KB + (10 × 4 KB) = **44 KB**"
      style: {
        fill: "#D6FFD6"
        stroke: "#006600"
      }
    }
    verdict2: |md
      **Sparse space:** Multi-level wins dramatically
      (44 KB vs 4 MB — **90× reduction!**)
    | {
      shape: rectangle
      width: 380
      style: {
        fill: "#90EE90"
        bold: true
      }
    }
  }
}
comparison: {
  direction: down
  label: "Key Insight"
  insight: |md
    **The Compression Principle**
    Multi-level tables allocate second-level structures *on demand*.
    If `PDE[5].present == false`, the entire 4 MB region (1024 pages)
    is unmapped — **zero bytes allocated** for that region's page table.
    Real processes are sparse: code + heap + stack + a few libraries
    typically touch <1% of their virtual address space.
  | {
    shape: rectangle
    width: 800
    style: {
      fill: "#E8F4FD"
      stroke: "#2196F3"
      stroke-width: 2
    }
  }
}
legend: {
  near: bottom-center
  direction: right
  flat_legend: {
    shape: rectangle
    label: ""
    width: 20
    height: 20
    style.fill: "#FFD6D6"
    style.stroke: "#CC0000"
  }
  flat_label: "Flat Table (always 4 MB)"
  multi_legend: {
    shape: rectangle
    label: ""
    width: 20
    height: 20
    style.fill: "#D6FFD6"
    style.stroke: "#006600"
  }
  multi_label: "Multi-Level (scales with usage)"
}
scenario1.verdict1 -> comparison.insight: "Dense"
scenario2.verdict2 -> comparison.insight: "Sparse"