direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Statistics Collection Architecture {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  tlb_module: TLB Cache {
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    tlb_stats: {
      shape: class
      label: TLB Statistics (tlb.h)
      -hits: "uint64_t"
      -misses: "uint64_t"
      -flushes: "uint64_t"
      -evictions: "uint64_t"
      +tlb_lookup(): "tlb_entry_t*"
      +tlb_insert(): "void"
      +tlb_flush(): "void"
    }
    collection_tlb: {
      label: "Collection Points"
      width: 280
      code: |'c
        // tlb_lookup() increments:
        //   hits++   on TLB match
        //   misses++ on page table walk
        // tlb_flush() increments:
        //   flushes++
        // tlb_find_victim() increments:
        //   evictions++
      '|
    }
  }
  pt_module: Page Table {
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    pt_stats: {
      shape: class
      label: Walk Statistics (mmu.h)
      -walks: "uint64_t"
      -walk_cycles: "uint64_t"
      -dir_accesses: "uint64_t"
      -table_accesses: "uint64_t"
      +walk_two_level(): "walk_output_t"
      +walk_three_level(): "walk_output_t"
    }
    collection_pt: {
      label: "Collection Points"
      width: 280
      code: |'c
        // walk_two_level() increments:
        //   walks++
        //   dir_accesses++ (PDE read)
        //   table_accesses++ (PTE read)
        //   walk_cycles += elapsed
      '|
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  fault_module: Page Fault Handler {
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    fault_stats: {
      shape: class
      label: Fault Statistics (fault.c)
      -total_faults: "uint64_t"
      -demand_alloc: "uint64_t"
      -swap_in: "uint64_t"
      -protection: "uint64_t"
      -dir_not_present: "uint64_t"
      +handle_page_fault(): "void"
    }
    collection_fault: {
      label: "Collection Points"
      width: 280
      code: |'c
        // handle_page_fault() increments:
        //   total_faults++
        //   demand_alloc++ (new frame)
        //   swap_in++ (from swap)
        //   protection++ (perm violation)
        //   dir_not_present++ (PDE=0)
      '|
    }
  }
  repl_module: Page Replacement {
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    repl_stats: {
      shape: class
      label: Replacement Stats (repl.c)
      -evictions: "uint64_t"
      -dirty_writes: "uint64_t"
      -clean_discards: "uint64_t"
      -fifo_faults: "uint64_t"
      -lru_faults: "uint64_t"
      -clock_faults: "uint64_t"
      -optimal_faults: "uint64_t"
      +allocate_frame_with_eviction(): "int32_t"
    }
    collection_repl: {
      label: "Collection Points"
      width: 280
      code: |'c
        // allocate_frame_with_eviction():
        //   evictions++
        //   dirty_writes++ (if pte->dirty)
        //   clean_discards++ (if !pte->dirty)
        // Per-algorithm tracking:
        //   fifo_faults++, lru_faults++, etc.
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  swap_module: Swap Space {
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    swap_stats: {
      shape: class
      label: Swap Statistics (swap.c)
      -swap_writes: "uint64_t"
      -swap_reads: "uint64_t"
      -swap_discards: "uint64_t"
      -slots_used: "uint32_t"
      -slots_total: "uint32_t"
      +swap_alloc(): "int32_t"
      +swap_free(): "void"
      +write_to_swap(): "void"
      +read_from_swap(): "void"
    }
    collection_swap: {
      label: "Collection Points"
      width: 280
      code: |'c
        // write_to_swap() increments:
        //   swap_writes++
        // read_from_swap() increments:
        //   swap_reads++
        // swap_alloc() updates:
        //   slots_used++
        // swap_free() updates:
        //   slots_used--
      '|
    }
  }
  ws_module: Working Set {
    style.fill: "#E0F7FA"
    style.stroke: "#00838F"
    ws_stats: {
      shape: class
      label: Working Set Stats (working_set.c)
      -window_size: "uint32_t"
      -current_size: "uint32_t"
      -peak_size: "uint32_t"
      -thrashing_events: "uint64_t"
      +working_set_record(): "void"
      +working_set_size(): "uint32_t"
      +check_thrashing(): "bool"
    }
    collection_ws: {
      label: "Collection Points"
      width: 280
      code: |'c
        // working_set_record() updates:
        //   current_size (distinct VPNs)
        //   peak_size = max(peak, current)
        // check_thrashing() increments:
        //   thrashing_events++
        //   (when WS > num_frames)
      '|
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  aggregator: Statistics Aggregator {
    style.fill: "#FCE4EC"
    style.stroke: "#AD1457"
    style.double-border: true
    agg_struct: {
      shape: sql_table
      label: struct stats_t (stats.h)
      f0: "0x00 | uint64_t | total_accesses"
      f1: "0x08 | uint64_t | page_faults"
      f2: "0x10 | uint64_t | protection_faults"
      f3: "0x18 | uint64_t | tlb_hits"
      f4: "0x20 | uint64_t | tlb_misses"
      f5: "0x28 | uint64_t | tlb_flushes"
      f6: "0x30 | uint64_t | tables_allocated"
      f7: "0x38 | uint64_t | pages_allocated"
      f8: "0x40 | uint64_t | swap_writes"
      f9: "0x48 | uint64_t | swap_reads"
      f10: "0x50 | uint64_t | swap_discards"
      f11: "0x58 | uint64_t | evictions"
      f12: "0x60 | uint64_t | thrashing_warnings"
      sz: "Total: 104 bytes"
    }
    agg_func: {
      shape: class
      label: Reporter Functions
      +aggregate_stats(): "void"
      +print_statistics(): "void"
      +compare_algorithms(): "void"
      +export_csv(): "void"
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  report: Final Report Generator {
    style.fill: "#ECEFF1"
    style.stroke: "#37474F"
    style.shadow: true
    report_content: {
      shape: class
      label: Report Output (report.c)
      +generate_summary(): "void"
      +format_hit_rates(): "char*"
      +format_fault_rates(): "char*"
      +format_swap_activity(): "char*"
      +format_belady_comparison(): "char*"
    }
    report_example: {
      label: "Sample Output"
      width: 420
      code: |'text
        ========================================
              SIMULATION STATISTICS          
        ========================================
        Total accesses:         10,000
        TLB hits:              9,500 (95.00%)
        TLB misses:              500 (5.00%)
        Page faults:             150 (1.50%)
        Protection faults:         2
        Swap writes:              45
        Swap reads:               45
        Thrashing warnings:        3
        ========================================
      '|
    }
  }
}
tlb_module.tlb_stats -> aggregator.agg_struct: "hits, misses\nflushes, evictions"
pt_module.pt_stats -> aggregator.agg_struct: "walks, cycles\naccesses"
fault_module.fault_stats -> aggregator.agg_struct: "faults by type"
repl_module.repl_stats -> aggregator.agg_struct: "evictions\ndirty writes"
swap_module.swap_stats -> aggregator.agg_struct: "read/write\ncounts"
ws_module.ws_stats -> aggregator.agg_struct: "thrashing\nevents"
aggregator.agg_struct -> aggregator.agg_func: "aggregate"
aggregator.agg_func -> report.report_content: "formatted\ndata"
report.report_content -> report.report_example: "generate"
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 3
  l1: "Blue (TLB)" {
    style.fill: "#E8F4FD"
  }
  l2: "Orange (Page Table)" {
    style.fill: "#FFF3E0"
  }
  l3: "Red (Faults)" {
    style.fill: "#FFEBEE"
  }
  l4: "Purple (Replacement)" {
    style.fill: "#F3E5F5"
  }
  l5: "Green (Swap)" {
    style.fill: "#E8F5E9"
  }
  l6: "Cyan (Working Set)" {
    style.fill: "#E0F7FA"
  }
}