direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Simulated Swap Space Organization (swap.h)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  swap_space: {
    direction: down
    label: "swap_space_t"
    style.fill: "#E8F4E8"
    style.stroke: "#2E7D32"
    swap_struct: {
      shape: sql_table
      label: "struct swap_space_t"
      f0: "0x00 | swap_slot_t* | slots"
      f1: "0x08 | uint32_t    | total_slots"
      f2: "0x0C | uint32_t*   | free_list"
      f3: "0x10 | uint32_t    | free_count"
      sz: "Total: ~32 bytes"
    }
    swap_slots: {
      direction: right
      label: "Swap Slot Array"
      style.fill: "#FFF3E0"
      slot0: {
        label: "Slot 0"
        shape: rectangle
        style.fill: "#FFCCBC"
        width: 100
        height: 60
      }
      slot1: {
        label: "Slot 1"
        shape: rectangle
        style.fill: "#FFCCBC"
        width: 100
        height: 60
      }
      slot2: {
        label: "Slot 2"
        shape: rectangle
        style.fill: "#FFCCBC"
        width: 100
        height: 60
      }
      slot3: {
        label: "Slot N"
        shape: rectangle
        style.fill: "#E0E0E0"
        style.stroke-dash: 3
        width: 100
        height: 60
      }
    }
    swap_struct -> slot0: "slots[]"
  }
  swap_slot_struct: {
    direction: down
    label: "Swap Slot Entry"
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    slot_entry: {
      shape: sql_table
      label: "struct swap_slot_t"
      f0: "0x00 | uint8_t[4096] | data"
      f1: "0x1000 | uint32_t   | vpn"
      f2: "0x1004 | uint32_t   | process_id"
      f3: "0x1008 | bool       | occupied"
      sz: "Total: 4104 bytes"
    }
    slot_entry.style.fill: "#BBDEFB"
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  swap_map: {
    direction: down
    label: "Swap Mapping (per VPN)"
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    mapping_struct: {
      shape: sql_table
      label: "swap_mapping_t[VPN]"
      f0: "0 | int32_t | swap_slot"
      f1: "4 | bool    | in_swap"
      sz: "8 bytes per entry"
    }
    mapping_example: {
      label: "Example State"
      shape: sql_table
      f0: "VPN 0   | slot=-1  | in_swap=false"
      f1: "VPN 1   | slot=3   | in_swap=true"
      f2: "VPN 2   | slot=-1  | in_swap=false"
      f3: "VPN 3   | slot=7   | in_swap=true"
    }
    mapping_example.style.fill: "#E1BEE7"
  }
  free_list: {
    direction: down
    label: "Free List Management"
    style.fill: "#FFFDE7"
    style.stroke: "#F9A825"
    free_struct: {
      shape: sql_table
      label: "free_list[]"
      f0: "[0] | 5"
      f1: "[1] | 12"
      f2: "[2] | 3"
      f3: "[...] | ..."
      f4: "free_count = N"
    }
    free_struct.style.fill: "#FFF9C4"
    alloc_code: {
      label: "swap_alloc()"
      width: 280
      code: |'c
        int32_t swap_alloc(swap_space_t *s) {
          if (s->free_count == 0) return -1;
          return s->free_list[--s->free_count];
        }
      '|
    }
    free_code: {
      label: "swap_free()"
      width: 280
      code: |'c
        void swap_free(swap_space_t *s, uint32_t idx) {
          s->slots[idx].occupied = false;
          s->free_list[s->free_count++] = idx;
        }
      '|
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  phys_mem: {
    direction: down
    label: "Physical Memory"
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    frame0: {
      label: "Frame 0\n(VPN 5)"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 100
      height: 50
    }
    frame1: {
      label: "Frame 1\n(VPN 1)"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 100
      height: 50
    }
    frame2: {
      label: "Frame 2\n(VPN 8)"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 100
      height: 50
    }
    frame_victim: {
      label: "Frame 3\n(VPN 1)\nDIRTY!"
      shape: rectangle
      style.fill: "#EF5350"
      style.font-color: white
      style.bold: true
      width: 100
      height: 50
    }
  }
}
writeback: {
  direction: right
  label: "Write-Back Path (Eviction)"
  style.fill: "#E8F5E9"
  style.stroke: "#388E3C"
  width: 500
  wb_step1: {
    label: "1. Check Dirty Bit"
    code: |'c
      if (pte->dirty) {
        // Must write to swap
      }
    '|
    width: 200
  }
  wb_step2: {
    label: "2. Allocate Swap Slot"
    code: |'c
      int32_t slot = swap_alloc(swap);
      if (slot < 0) return -1;
    '|
    width: 200
  }
  wb_step3: {
    label: "3. Copy Frame → Slot"
    code: |'c
      memcpy(swap->slots[slot].data,
             frames[pfn], PAGE_SIZE);
    '|
    width: 220
  }
  wb_step4: {
    label: "4. Update Mapping"
    code: |'c
      swap_map[vpn].slot = slot;
      swap_map[vpn].in_swap = true;
    '|
    width: 200
  }
  wb_step1 -> wb_step2 -> wb_step3 -> wb_step4
}
read_path: {
  direction: right
  label: "Read Path (Page Fault Recovery)"
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  width: 500
  rd_step1: {
    label: "1. Page Fault on VPN"
    code: |'c
      if (!pte->valid) {
        // Check swap_map
      }
    '|
    width: 200
  }
  rd_step2: {
    label: "2. Check in_swap"
    code: |'c
      if (swap_map[vpn].in_swap) {
        slot = swap_map[vpn].slot;
      }
    '|
    width: 220
  }
  rd_step3: {
    label: "3. Copy Slot → Frame"
    code: |'c
      memcpy(frames[pfn],
             swap->slots[slot].data,
             PAGE_SIZE);
    '|
    width: 220
  }
  rd_step4: {
    label: "4. Free Swap Slot"
    code: |'c
      swap_free(swap, slot);
      swap_map[vpn].in_swap = false;
    '|
    width: 200
  }
  rd_step1 -> rd_step2 -> rd_step3 -> rd_step4
}
phys_mem.frame_victim -> swap_space.swap_slots.slot2: "write-back\n(dirty=1)" {
  style.stroke: "#D32F2F"
  style.stroke-width: 3
  style.animated: true
  label: "memcpy 4KB"
}
swap_space.swap_slots.slot1 -> phys_mem.frame1: "read on fault" {
  style.stroke: "#1976D2"
  style.stroke-width: 3
  style.animated: true
  style.stroke-dash: 5
}
swap_map.mapping_example -> swap_space.swap_slots: "vpn → slot lookup" {
  style.stroke: "#7B1FA2"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  direction: right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  legend_title: {
    label: "Legend"
    shape: text
    style.bold: true
  }
  dirty_page: {
    label: "Dirty Page\n(needs write-back)"
    shape: rectangle
    style.fill: "#EF5350"
    style.font-color: white
    width: 100
  }
  clean_page: {
    label: "Clean Page\n(discard OK)"
    shape: rectangle
    style.fill: "#A5D6A7"
    width: 100
  }
  swap_occupied: {
    label: "Swap Slot\n(occupied)"
    shape: rectangle
    style.fill: "#FFCCBC"
    width: 100
  }
  swap_free: {
    label: "Swap Slot\n(free)"
    shape: rectangle
    style.fill: "#E0E0E0"
    style.stroke-dash: 3
    width: 100
  }
  write_arrow: {
    label: "Write-Back"
    shape: text
  }
  read_arrow: {
    label: "Read on Fault"
    shape: text
  }
}
stats: {
  near: bottom-right
  label: "Statistics (stats_t)"
  shape: sql_table
  style.fill: "#ECEFF1"
  f0: "swap_writes   | uint64_t"
  f1: "swap_reads    | uint64_t"
  f2: "swap_discards | uint64_t"
  f3: "Updated on each path"
}