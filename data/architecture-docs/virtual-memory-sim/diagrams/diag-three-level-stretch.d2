direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: "Three-Level Page Table Structure (32-bit: 2+9+9+12)" {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {stroke: transparent; fill: transparent}
  va_bits: {
    direction: down
    label: "32-bit Virtual Address Decomposition"
    bit_layout: {
      shape: sql_table
      label: "Bit Field Layout"
      f0: "31-30 | PML4 Index | 2 bits | 4 entries max"
      f1: "29-21 | PD Index   | 9 bits | 512 entries"
      f2: "20-12 | PT Index   | 9 bits | 512 entries"
      f3: "11-0  | Offset     | 12 bits | 4096 bytes"
    }
    coverage: {
      label: "Coverage per Level"
      width: 320
      code: |'c
        PML4 entry: 1 GB (bits 31-30)
        PD entry:   2 MB (bits 29-21)
        PT entry:   4 KB (bits 20-12)
        Byte:       1 B  (bits 11-0)
      '|
    }
  }
  why_4: {
    direction: down
    label: "Why Only 4 PML4 Entries?"
    style.fill: "#E8F4FD"
    explanation: {
      width: 340
      code: |'c
        // 32-bit VA uses bits 0-31
        // PML4 index = bits 31-30
        // 2^2 = 4 possible values
        #define PML4_MASK  0x3    // 0b11
        #define PML4_SHIFT 30
        // 4 entries cover entire 4 GB:
        // Entry 0: 0x00000000-0x3FFFFFFF
        // Entry 1: 0x40000000-0x7FFFFFFF
        // Entry 2: 0x80000000-0xBFFFFFFF
        // Entry 3: 0xC0000000-0xFFFFFFFF
      '|
    }
    note: "Root level is tiny: 4 entries × 8 bytes = 32 bytes"
  }
}
row2: "" {
  direction: right
  style: {stroke: transparent; fill: transparent}
  walk: {
    direction: down
    label: "Three-Level Walk (CR3 → Physical)"
    cr3: {
      shape: cylinder
      label: "CR3 Register\n(Page Map L4 Base)"
      style.fill: "#B8D4E8"
    }
    cr3 -> pml4_array: "points to"
    pml4_array: {
      shape: sql_table
      label: "PML4 (Page Map Level 4)"
      e0: "0 | present | pdpt_pfn | covers 0x0-0x3FFF..."
      e1: "1 | present | pdpt_pfn | covers 0x4-0x7FFF..."
      e2: "2 | 0       | —        | unmapped"
      e3: "3 | present | pdpt_pfn | covers 0xC-0xFFFF..."
      sz: "4 entries × 8 bytes = 32 bytes"
    }
    pml4_array -> pdpt: "PML4[idx] → PDPT"
    pdpt: {
      shape: sql_table
      label: "PDPT (Page Dir Ptr Table)"
      e0: "0 | present | page_dir_pfn"
      e1: "1 | present | page_dir_pfn"
      e2: "..."
      e3: "511 | 0 | —"
      sz: "512 entries × 8 bytes = 4 KB"
    }
    pdpt -> pd: "PDPT[idx] → Page Directory"
    pd: {
      shape: sql_table
      label: "Page Directory"
      e0: "0 | present | page_table_pfn"
      e1: "1 | present | page_table_pfn"
      e2: "..."
      e3: "511 | 0 | —"
      sz: "512 entries × 8 bytes = 4 KB"
    }
    pd -> pt: "PD[idx] → Page Table"
    pt: {
      shape: sql_table
      label: "Page Table"
      e0: "0 | present | pfn | 4 KB frame"
      e1: "1 | present | pfn | 4 KB frame"
      e2: "..."
      e3: "511 | 0 | —   | —"
      sz: "512 entries × 8 bytes = 4 KB"
    }
    pt -> frame: "PTE[idx] → Frame"
    frame: {
      shape: cylinder
      label: "Physical Frame\n(4 KB)"
      style.fill: "#C8E6C9"
    }
  }
  memory_cost: {
    direction: down
    label: "Memory Cost Analysis"
    style.fill: "#FFF3E0"
    sparse: {
      shape: sql_table
      label: "Sparse Address Space"
      r0: "PML4:      32 bytes (always)"
      r1: "PDPT:      4 KB × N (on demand)"
      r2: "Page Dir:  4 KB × M (on demand)"
      r3: "Page Table: 4 KB × K (on demand)"
      r4: "Total: ~16-100 KB typical"
    }
    dense: {
      shape: sql_table
      label: "Dense (Worst Case)"
      r0: "PML4:      32 bytes"
      r1: "PDPTs:     4 × 4 KB = 16 KB"
      r2: "Page Dirs: 2048 × 4 KB = 8 MB"
      r3: "Page Tables: 1M × 4 KB = 4 GB"
      r4: "Flat table: 4 MB (simpler!)"
    }
    insight: {
      label: "Key Insight"
      width: 280
      style.fill: "#FFCDD2"
      code: |'c
        Three-level only wins for
        VERY sparse address spaces.
        For 32-bit, two-level (10+10+12)
        is usually better.
        Three-level shines on 64-bit
        where sparse space is huge.
      '|
    }
  }
}
row3: "" {
  direction: right
  style: {stroke: transparent; fill: transparent}
  compare: {
    direction: down
    label: "32-bit vs 64-bit Comparison"
    bit32: {
      shape: class
      label: "32-bit (PAE-style)"
      -levels: "3"
      -split: "2+9+9+12"
      -root_entries: "4"
      -addr_space: "4 GB"
      -use_case: "PAE (36-bit phys)"
    }
    bit64: {
      shape: class
      label: "64-bit (x86-64)"
      -levels: "4"
      -split: "9+9+9+9+12"
      -root_entries: "512"
      -addr_space: "256 TB (48-bit VA)"
      -use_case: "All modern CPUs"
    }
    bit64_la57: {
      shape: class
      label: "64-bit (LA57)"
      -levels: "5"
      -split: "9+9+9+9+9+12"
      -root_entries: "512"
      -addr_space: "128 PB (57-bit VA)"
      -use_case: "Future expansion"
    }
  }
  x86_64: {
    direction: down
    label: "x86-64 Four-Level Layout"
    style.fill: "#F3E5F5"
    x86_bits: {
      shape: sql_table
      label: "48-bit Virtual Address"
      f0: "47-39 | PML4 Index | 9 bits"
      f1: "38-30 | PDPT Index | 9 bits"
      f2: "29-21 | PD Index   | 9 bits"
      f3: "20-12 | PT Index   | 9 bits"
      f4: "11-0  | Offset     | 12 bits"
      f5: "Total: 4 levels × 512-way"
    }
    x86_walk: {
      label: "Full Walk Cost"
      width: 300
      code: |'c
        CR3 → PML4[9 bits]
            → PDPT[9 bits]
            → PD[9 bits]
            → PT[9 bits]
            → Physical Addr
        4 memory accesses per translation
        (without TLB)
        TLB hit: 1-2 cycles
        TLB miss: 50-200+ cycles
      '|
    }
    x86_note: {
      label: "Why 48-bit VA?"
      width: 280
      style.fill: "#E1BEE7"
      code: |'c
        Full 64-bit would need 52+ bits
        of VPN → impossibly large tables.
        48-bit = 256 TB per process
        (more than enough for now)
        Top 16 bits must match bit 47
        (sign extension requirement)
      '|
    }
  }
}
legend: {
  near: bottom-right
  label: "Legend"
  style.fill: "#FAFAFA"
  l1: "PML4 = Page Map Level 4 (root)"
  l2: "PDPT = Page Directory Pointer Table"
  l3: "PD = Page Directory"
  l4: "PT = Page Table"
  l5: "PFN = Physical Frame Number"
}