direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: TLB Coherency: The Stale Entry Problem {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: "T1: Initial State" {
    direction: down
    width: 350
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    page_table_t1: {
      shape: sql_table
      label: "Page Table"
      row0: "VPN | PFN | Valid"
      row1: "0   | --  | 0"
      row2: "1   | 42  | 1"
      row3: "2   | --  | 0"
      row4: "3   | 17  | 1"
    }
    tlb_t1: {
      shape: sql_table
      label: "TLB Cache"
      trow0: "VPN | PFN | Valid"
      trow1: "1   | 42  | 1"
      trow2: "3   | 17  | 1"
    }
    note1: {
      label: |md
        VPN 1 → PFN 42
        Cached in TLB ✓
      |
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
    }
  }
  step2: "T2: OS Evicts Page" {
    direction: down
    width: 350
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    page_table_t2: {
      shape: sql_table
      label: "Page Table (MODIFIED)"
      row0: "VPN | PFN | Valid"
      row1: "0   | --  | 0"
      row2: "1   | --  | 0"
      row3: "2   | --  | 0"
      row4: "3   | 17  | 1"
      style.fill: "#FFCCBC"
    }
    tlb_t2: {
      shape: sql_table
      label: "TLB (STALE!)"
      trow0: "VPN | PFN | Valid"
      trow1: "1   | 42  | 1"
      trow2: "3   | 17  | 1"
      style.fill: "#FFCDD2"
    }
    note2: {
      label: |md
        OS set valid=0
        But TLB still has
        old entry!
      |
      shape: rectangle
      style.fill: transparent
      style.stroke: transparent
      style.font-color: "#D32F2F"
      style.bold: true
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3: "T3: Process Accesses VPN 1" {
    direction: down
    width: 350
    style.fill: "#FFEBEE"
    style.stroke: "#F44336"
    va_decomp: {
      label: "Virtual Address: 0x00001234"
      vpn: "VPN = 1"
      offset: "Offset = 0x234"
      shape: rectangle
      style.fill: "#FFCDD2"
    }
    tlb_lookup: {
      label: "TLB Lookup"
      result: "VPN 1 found!"
      pfn: "Returns PFN 42"
      shape: diamond
      style.fill: "#FFCDD2"
    }
    wrong_access: {
      label: |md
        **BUG!** Accesses PFN 42
        But PFN 42 now contains
        completely different data!
      |
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      style.bold: true
    }
  }
  step4: "T4: The Fix - Invalidate TLB" {
    direction: down
    width: 350
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    fix_code: {
      label: "Fix: Always Invalidate"
      code: |'c
        void evict_page(uint32_t vpn) {
          // Step 1: Invalidate TLB FIRST
          tlb_invalidate(vpn, current_asid);
          // Step 2: Then modify page table
          page_table[vpn].valid = false;
          page_table[vpn].pfn = 0;
          // Now safe: TLB will miss
          // on next access to this VPN
        }
      '|
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    writeback_note: {
      label: |md
        **Critical:** Write back dirty bit
        to page_table BEFORE invalidating!
        Otherwise dirty data is lost.
      |
      shape: rectangle
      style.fill: "#FFF9C4"
      style.stroke: "#FBC02D"
    }
  }
}
step1 -> step2: "OS replaces\nVPN 1" {
  style.stroke: "#FF9800"
  style.stroke-width: 3
  style.animated: true
}
step2 -> step3: "Process reads\nVPN 1" {
  style.stroke: "#F44336"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.animated: true
}
step2 -> step4: "REQUIRED" {
  style.stroke: "#2196F3"
  style.stroke-width: 3
  style.bold: true
}
legend: {
  near: bottom-center
  label: "TLB Coherency Rules"
  rule1: "1. Invalidate TLB entry BEFORE modifying PTE"
  rule2: "2. Write back dirty/referenced bits on eviction"
  rule3: "3. TLB miss after invalidation forces fresh page table walk"
  shape: rectangle
  style.fill: "#E8EAF6"
  style.stroke: "#3F51B5"
}
problem_arrow: step3.wrong_access -> step2.tlb_t2 {
  style.stroke: "#D32F2F"
  style.stroke-width: 2
  style.stroke-dash: 3
  label: "Stale TLB entry\ncauses wrong access"
}