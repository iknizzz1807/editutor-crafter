direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: TLB Lookup and Miss Handling {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  va: {
    label: "Virtual Address\n0x00401234"
    shape: rectangle
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    width: 140
  }
  decompose: {
    label: "Address\nDecompose"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    width: 120
  }
  vpn_offset: {
    shape: sql_table
    label: "Address Fields"
    vpn: "bits 31-12 | uint32_t | VPN = 0x401"
    offset: "bits 11-0  | uint16_t | Offset = 0x234"
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  tlb: {
    label: "TLB Cache"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    width: 320
    tlb_header: {
      shape: sql_table
      label: "TLB Entry Structure (tlb_entry_t)"
      f0: "0x00 | uint32_t | vpn        // Virtual Page Number"
      f1: "0x04 | uint32_t | pfn        // Physical Frame Number"
      f2: "0x08 | uint32_t | asid       // Address Space ID"
      f3: "0x0C | bool     | valid      // Entry is valid"
      f4: "0x0D | bool     | readable   // Read permission"
      f5: "0x0E | bool     | writable   // Write permission"
      f6: "0x0F | bool     | dirty      // Modified flag"
      f7: "0x10 | bool     | referenced // Accessed flag"
      f8: "0x18 | uint64_t | last_used  // LRU timestamp"
      sz: "Total: 24 bytes per entry"
    }
    lookup: {
      label: "TLB Lookup"
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 280
      code: |'c
        // Fully associative search
        for (i = 0; i < tlb->capacity; i++) {
          entry = &tlb->entries[i];
          if (entry->valid &&
              entry->vpn == vpn &&
              entry->asid == current_asid) {
            return entry;  // HIT
          }
        }
        return NULL;  // MISS
      '|
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  hit_path: {
    label: "HIT Path (Fast)"
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.stroke-width: 3
    width: 200
    hit_check: {
      label: "Permission Check"
      shape: diamond
      style.fill: "#A5D6A7"
      width: 120
    }
    hit_result: {
      label: "Return PFN\n(1-2 cycles)"
      shape: rectangle
      style.fill: "#81C784"
      style.stroke: "#1B5E20"
      style.bold: true
    }
  }
  miss_path: {
    label: "MISS Path (Slow)"
    shape: rectangle
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 3
    width: 380
    page_table_walk: {
      label: "Page Table Walk"
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 340
      code: |'c
        // Walk the page table (in memory)
        pte_t *pte = &page_table[vpn];
        if (!pte->valid) {
          return PAGE_FAULT;  // Not in memory
        }
        if (is_write && !pte->writable) {
          return PROTECTION_FAULT;
        }
        // Update access bits
        pte->referenced = true;
        if (is_write) pte->dirty = true;
        return pte->pfn;
      '|
    }
    tlb_insert: {
      label: "TLB Insert"
      shape: rectangle
      style.fill: "#EF9A9A"
      width: 340
      code: |'c
        void tlb_insert(tlb_t *tlb, uint32_t vpn,
                        uint32_t pfn, pte_t *pte) {
          int slot = find_slot_or_victim(tlb);
          if (slot_is_occupied) {
            evict_and_writeback(slot);  // LRU eviction
          }
          entry->vpn = vpn;
          entry->pfn = pfn;
          entry->asid = current_asid;
          entry->valid = true;
          entry->last_used = ++tlb->clock;
        }
      '|
    }
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  lru_eviction: {
    label: "LRU Victim Selection"
    shape: rectangle
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    width: 400
    lru_code: {
      label: "LRU Algorithm"
      shape: rectangle
      style.fill: "#E1BEE7"
      width: 360
      code: |'c
        int tlb_find_victim_lru(tlb_t *tlb) {
          uint64_t oldest = UINT64_MAX;
          int victim = 0;
          for (i = 0; i < tlb->capacity; i++) {
            if (tlb->entries[i].last_used < oldest) {
              oldest = tlb->entries[i].last_used;
              victim = i;
            }
          }
          // Write back dirty bit before eviction
          if (tlb->entries[victim].dirty) {
            page_table[entry->vpn].dirty = true;
          }
          return victim;
        }
      '|
    }
    eviction_state: {
      shape: sql_table
      label: "Eviction State Example"
      e0: "Entry 0 | last_used: 1000 | vpn: 0x1"
      e1: "Entry 1 | last_used: 5000 | vpn: 0x2"
      e2: "Entry 2 | last_used: 200  | vpn: 0x3 ← VICTIM (oldest)"
      e3: "Entry 3 | last_used: 3000 | vpn: 0x4"
      note: "Clock=5500, Entry 2 evicted for new translation"
    }
  }
}
row5: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  result: {
    label: "Physical Address Composition"
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    width: 350
    compose: {
      shape: sql_table
      label: "Final Physical Address"
      step1: "1 | PFN from TLB/Page Table | 0x7F"
      step2: "2 | Offset preserved      | 0x234"
      step3: "3 | Compose: (pfn << 12) | offset"
      result: "Result | Physical Address    | 0x7F234"
    }
  }
  stats: {
    shape: class
    label: "Statistics (stats_t)"
    +total_accesses: "uint64_t"
    +tlb_hits: "uint64_t"
    +tlb_misses: "uint64_t"
    +tlb_hit_rate: "double (%)"
    +evictions: "uint64_t"
    +flushes: "uint64_t"
  }
}
# Connections
va -> decompose: "split"
decompose -> vpn_offset: "VPN + Offset"
vpn_offset.vpn -> tlb.lookup: "search"
tlb.lookup -> hit_path.hit_check: "HIT" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  style.bold: true
}
tlb.lookup -> miss_path.page_table_walk: "MISS" {
  style.stroke: "#C62828"
  style.stroke-width: 3
  style.stroke-dash: 4
}
hit_path.hit_check -> hit_path.hit_result: "OK" {
  style.stroke: "#2E7D32"
}
hit_path.hit_check -> miss_path.page_table_walk: "PROTECTION\nFAULT" {
  style.stroke: "#C62828"
  style.stroke-dash: 4
}
miss_path.page_table_walk -> miss_path.tlb_insert: "PFN obtained"
miss_path.tlb_insert -> lru_eviction: "TLB full?\nevict"
lru_eviction -> miss_path.tlb_insert: "slot freed"
hit_path.hit_result -> result.compose: "PFN"
miss_path.tlb_insert -> result.compose: "PFN"
result -> stats: "update"