direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: TLB Entry Structure with ASID Tag {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  tlb_entry: {
    shape: sql_table
    label: "struct tlb_entry_t (mmu.h)"
    f0: "bits 63:56 | uint8_t  | asid"
    f1: "bits 55:36 | uint32_t | vpn"
    f2: "bits 35:16 | uint32_t | pfn"
    f3: "bit 15     | bool     | dirty"
    f4: "bit 14     | bool     | accessed"
    f5: "bit 13     | bool     | readable"
    f6: "bit 12     | bool     | writable"
    f7: "bit 11     | bool     | valid"
    sz: "Total: 64 bits (8 bytes)"
  }
  bit_layout: {
    label: "TLB Entry Bit Layout (64-bit)"
    width: 450
    asid_box: {
      label: "ASID"
      width: 80
      style.fill: "#E8D4F8"
    }
    vpn_box: {
      label: "VPN\n20 bits"
      width: 100
      style.fill: "#B8D4E8"
    }
    pfn_box: {
      label: "PFN\n20 bits"
      width: 100
      style.fill: "#D4E8B8"
    }
    flags_box: {
      label: "D A R W V\n5 bits"
      width: 90
      style.fill: "#E8E8D4"
    }
    asid_box -> vpn_box -> pfn_box -> flags_box: {
      style.stroke: transparent
    }
    bit_nums: |md
      63    56 55        36 35        16 15        11 10 0
    |
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  why_asid: {
    label: "Why ASID?"
    width: 350
    code: |'c
      // WITHOUT ASID: Flush entire TLB
      void context_switch_no_asid() {
        tlb_flush_all();  // Expensive!
        // All 64 entries invalidated
        // Next accesses: 64 TLB misses
      }
      // WITH ASID: Just change current_asid
      void context_switch_with_asid() {
        current_asid = next->asid;  // Cheap!
        // Old entries stay, won't match
        // Warm TLB preserved across switch
      }
    '|
  }
  asid_width: {
    shape: sql_table
    label: "ASID Space Analysis"
    r0: "8-bit ASID  | 256 processes"
    r1: "12-bit ASID | 4096 processes"
    r2: "16-bit ASID | 65536 processes"
    r3: "On exhaustion: flush + recycle"
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  lookup: {
    label: "Fully-Associative Lookup"
    width: 420
    code: |'c
      // Parallel compare across all entries
      tlb_entry_t* tlb_lookup(tlb_t *tlb, uint32_t vpn) {
        for (uint32_t i = 0; i < tlb->capacity; i++) {
          tlb_entry_t *e = &tlb->entries[i];
          if (e->valid &&
              e->vpn == vpn &&
              e->asid == tlb->current_asid) {  // MUST MATCH!
            return e;  // HIT
          }
        }
        return NULL;  // MISS
      }
    '|
  }
  match_diagram: {
    label: "Tag Match Logic"
    width: 380
    va_in: "Virtual Address\n(VPN + Offset)"
    comparator: {
      shape: diamond
      label: "ASID + VPN\nMatch?"
    }
    hit: "TLB HIT\nReturn PFN" {
      style.fill: "#90EE90"
    }
    miss: "TLB MISS\nWalk Page Table" {
      style.fill: "#FFB6C1"
    }
    va_in -> comparator: "lookup"
    comparator -> hit: "Yes" {
      style.stroke: green
      style.stroke-width: 2
    }
    comparator -> miss: "No" {
      style.stroke-dash: 4
    }
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  context_flow: {
    label: "Context Switch Behavior"
    width: 400
    proc_a: "Process A\n(ASID=1)" {
      shape: rectangle
      style.fill: "#E8D4F8"
    }
    proc_b: "Process B\n(ASID=2)" {
      shape: rectangle
      style.fill: "#D4E8B8"
    }
    tlb_state: "TLB State\n(Mixed ASIDs)" {
      shape: cylinder
      style.fill: "#F5F5F5"
    }
    proc_a -> tlb_state: "VPN 1 -> PFN 42\n(ASID=1)" {
      label: "access"
    }
    proc_b -> tlb_state: "VPN 1 -> PFN 99\n(ASID=2)" {
      label: "access"
    }
    tlb_state -> proc_a: "Same VPN,\ndifferent PFN!" {
      style.stroke-dash: 3
      label: "isolated"
    }
  }
  entry_table: {
    shape: sql_table
    label: "Example: TLB with Mixed ASIDs"
    e0: "0 | ASID=1 | VPN=0x1 | PFN=0x2A | Valid"
    e1: "1 | ASID=2 | VPN=0x1 | PFN=0x63 | Valid"
    e2: "2 | ASID=1 | VPN=0x5 | PFN=0x0F | Valid"
    e3: "3 | ASID=3 | VPN=0x2 | PFN=0x71 | Valid"
    note: "Same VPN in different ASIDs = different entries"
  }
}
legend: {
  near: bottom-right
  label: "Field Semantics"
  shape: rectangle
  style.fill: "#F0F0F0"
  l1: "ASID: Address Space ID (process tag)"
  l2: "VPN: Virtual Page Number (lookup key)"
  l3: "PFN: Physical Frame Number (result)"
  l4: "D: Dirty (page was written)"
  l5: "A: Accessed (any reference)"
  l6: "R/W: Permission bits"
  l7: "Valid: Entry contains data"
}
legend.l1.style.font-size: 14
legend.l2.style.font-size: 14
legend.l3.style.font-size: 14
legend.l4.style.font-size: 14
legend.l5.style.font-size: 14
legend.l6.style.font-size: 14
legend.l7.style.font-size: 14