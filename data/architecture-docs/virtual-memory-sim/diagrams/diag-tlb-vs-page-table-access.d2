direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: TLB Hit vs Miss: Memory Access Count {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row_hit_miss: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hit_side: {
    direction: down
    label: "TLB HIT"
    hit_flow: {
      direction: down
      label: "Translation Path (1 memory access)"
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      style.stroke-width: 2
      va_hit: {
        label: "Virtual Address\n0x00401234"
        shape: rectangle
        style.fill: "#C8E6C9"
      }
      tlb_box: {
        direction: down
        label: "TLB Lookup"
        shape: rectangle
        style.fill: "#81C784"
        style.stroke: "#2E7D32"
        style.stroke-width: 3
        tlb_search: |md
          **Parallel CAM Search**
          - 16-64 entries checked simultaneously
          - VPN match + ASID match = HIT
          - **Latency: 1-2 cycles**
        |
      }
      hit_arrow: {
        shape: rectangle
        width: 180
        label: ""
        style.fill: transparent
      }
      pfn_hit: {
        label: "PFN: 0x7F\n(Direct from TLB)"
        shape: rectangle
        style.fill: "#A5D6A7"
        style.stroke: "#2E7D32"
      }
      data_access_hit: {
        label: "Data Memory Access"
        shape: rectangle
        style.fill: "#66BB6A"
        style.stroke: "#2E7D32"
        style.stroke-width: 2
        data_hit: |md
          **Read physical frame 0x7F**
          - L1 cache check: 4-8 cycles
          - Cache hit → data returned
          - **1 memory access total**
        |
      }
    }
    va_hit -> tlb_box: "extract VPN"
    tlb_box -> pfn_hit: "HIT: PFN cached"
    pfn_hit -> data_access_hit: "(PFN << 12) | offset"
  }
  miss_side: {
    direction: down
    label: "TLB MISS"
    miss_flow: {
      direction: down
      label: "Translation Path (2+ memory accesses)"
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      style.stroke-width: 2
      va_miss: {
        label: "Virtual Address\n0x00401234"
        shape: rectangle
        style.fill: "#FFCDD2"
      }
      tlb_miss_box: {
        label: "TLB Lookup"
        shape: rectangle
        style.fill: "#EF9A9A"
        style.stroke: "#C62828"
        tlb_miss_text: |md
          **Parallel CAM Search**
          - No matching entry found
          - Must walk page table
          - **Latency: 1-2 cycles (search)**
        |
      }
      pt_walk: {
        label: "Page Table Walk"
        shape: rectangle
        style.fill: "#E57373"
        style.stroke: "#C62828"
        style.stroke-width: 2
        pt_text: |md
          **Memory Access #1: Read PTE**
          - Fetch PTE from page_table[VPN]
          - Check valid bit, permissions
          - Update referenced/dirty bits
          - **Latency: 50-200 cycles** (if not cached)
        |
      }
      tlb_fill: {
        label: "TLB Fill"
        shape: rectangle
        style.fill: "#EF5350"
        style.stroke: "#C62828"
        fill_text: |md
          **Insert translation into TLB**
          - May evict existing entry
          - Cache VPN → PFN mapping
        |
      }
      pfn_miss: {
        label: "PFN: 0x7F\n(From page table)"
        shape: rectangle
        style.fill: "#FF8A65"
        style.stroke: "#C62828"
      }
      data_access_miss: {
        label: "Data Memory Access"
        shape: rectangle
        style.fill: "#E53935"
        style.stroke: "#C62828"
        style.stroke-width: 2
        data_miss: |md
          **Read physical frame 0x7F**
          - L1 cache check: 4-8 cycles
          - **2 memory accesses total**
          - (PTE read + data read)
        |
      }
    }
    va_miss -> tlb_miss_box: "extract VPN"
    tlb_miss_box -> pt_walk: "MISS: walk page table"
    pt_walk -> tlb_fill: "PTE found"
    tlb_fill -> pfn_miss: "cache translation"
    pfn_miss -> data_access_miss: "(PFN << 12) | offset"
  }
}
cost_comparison: {
  direction: down
  label: "Latency Cost Comparison"
  cost_table: {
    shape: sql_table
    label: "Memory Access Latency Breakdown"
    row1: "TLB Hit (fast path) | 1-2 cycles | TLB lookup only"
    row2: "TLB Miss + PT in L1 | 5-10 cycles | L1 cache hit for PTE"
    row3: "TLB Miss + PT in L2 | 15-25 cycles | L2 cache hit for PTE"
    row4: "TLB Miss + PT in L3 | 40-60 cycles | L3 cache hit for PTE"
    row5: "TLB Miss + PT in RAM | 100-200 cycles | Full memory walk"
    row6: "Page Fault (disk) | 10M+ cycles | SSD/HDD I/O"
    total: "Multiplier: Miss can be 50-100× slower"
  }
}
multi_level: {
  direction: down
  label: "Multi-Level Page Tables: The Problem Gets Worse"
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  ml_flow: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    single: {
      direction: down
      label: "Single-Level"
      style.fill: "#FFE0B2"
      s1: {
        label: "TLB Hit"
        shape: rectangle
        style.fill: "#A5D6A7"
      }
      s2: {
        label: "1 access\n(data only)"
        shape: rectangle
        style.fill: "#81C784"
      }
      s3: {
        label: "TLB Miss"
        shape: rectangle
        style.fill: "#EF9A9A"
      }
      s4: {
        label: "2 accesses\n(PTE + data)"
        shape: rectangle
        style.fill: "#E57373"
      }
      s1 -> s2
      s3 -> s4
    }
    two_level: {
      direction: down
      label: "Two-Level (32-bit)"
      style.fill: "#FFCC80"
      t1: {
        label: "TLB Hit"
        shape: rectangle
        style.fill: "#A5D6A7"
      }
      t2: {
        label: "1 access\n(data only)"
        shape: rectangle
        style.fill: "#81C784"
      }
      t3: {
        label: "TLB Miss"
        shape: rectangle
        style.fill: "#EF9A9A"
      }
      t4: {
        label: "3 accesses\n(PDE + PTE + data)"
        shape: rectangle
        style.fill: "#E57373"
      }
      t1 -> t2
      t3 -> t4
    }
    four_level: {
      direction: down
      label: "Four-Level (x86-64)"
      style.fill: "#FFB74D"
      f1: {
        label: "TLB Hit"
        shape: rectangle
        style.fill: "#A5D6A7"
      }
      f2: {
        label: "1 access\n(data only)"
        shape: rectangle
        style.fill: "#81C784"
      }
      f3: {
        label: "TLB Miss"
        shape: rectangle
        style.fill: "#EF9A9A"
      }
      f4: {
        label: "5 accesses\n(PML4+PDPT+PD+PT+data)"
        shape: rectangle
        style.fill: "#E57373"
        style.stroke-width: 3
      }
      f1 -> f2
      f3 -> f4
    }
  }
  insight: {
    label: |md
      **Key Insight**: TLB hit cost is constant (1-2 cycles) regardless of page table depth.
      TLB miss cost scales linearly with levels: 2 → 3 → 5 memory accesses.
      This is why TLB coverage matters MORE on 64-bit systems with deep page tables.
    |
    shape: rectangle
    style.fill: "#FFE0B2"
    style.stroke: "#E65100"
    width: 500
  }
}
hit_rate_impact: {
  direction: down
  label: "Why TLB Hit Rate Dominates Performance"
  rate_table: {
    shape: sql_table
    label: "Effective Access Time (EAT) Calculation"
    formula: "EAT = (Hit_Rate × TLB_Hit_Time) + (Miss_Rate × TLB_Miss_Time)"
    row1: "99% hit rate | EAT = 0.99×2 + 0.01×150 = 3.5 cycles"
    row2: "95% hit rate | EAT = 0.95×2 + 0.05×150 = 9.4 cycles"
    row3: "90% hit rate | EAT = 0.90×2 + 0.10×150 = 16.8 cycles"
    row4: "80% hit rate | EAT = 0.80×2 + 0.20×150 = 31.6 cycles"
    row5: "50% hit rate | EAT = 0.50×2 + 0.50×150 = 76.0 cycles"
    conclusion: "Dropping from 99% to 90% hit rate = 5× slower memory access"
  }
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  green_box: {
    label: "Fast Path"
    shape: rectangle
    style.fill: "#A5D6A7"
    width: 80
  }
  red_box: {
    label: "Slow Path"
    shape: rectangle
    style.fill: "#EF9A9A"
    width: 80
  }
  orange_box: {
    label: "Scaling Cost"
    shape: rectangle
    style.fill: "#FFB74D"
    width: 80
  }
}