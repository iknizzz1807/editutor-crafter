direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Access Trace File Format
  Input format for the Virtual Memory Simulator
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  syntax: Syntax Specification {
    direction: down
    width: 420
    format: {
      label: "Line Format"
      width: 400
      code: |'text
        <OP> <ADDRESS>
        OP:      'R' (read) or 'W' (write)
        ADDRESS: Hexadecimal with 0x prefix
        SEP:     Single space between fields
      '|
    }
    rules: {
      label: "Parsing Rules"
      shape: class
      +parse_op: "char → bool is_write"
      +parse_addr: "string → uint32_t"
      +skip_line: "line[0] in {'#', '\\n', '\\0'}"
      +case_insensitive: "'r'/'R' → read"
      +address_width: "32-bit (8 hex digits max)"
    }
  }
  example: Example Trace {
    direction: down
    width: 480
    trace: {
      label: "traces/example.trace"
      width: 460
      code: |'text
        # Memory access trace - 10 entries
        # OP  ADDRESS    Comment
        R 0x00001000    # Page 1, read
        W 0x00001004    # Page 1, write
        R 0x00002000    # Page 2, read
        W 0x00003000    # Page 3, write
        R 0x00001000    # Page 1, read again
        W 0x00001008    # Page 1, another write
        R 0x00004000    # Page 4, read
        W 0x00002004    # Page 2, write
        R 0x00005000    # Page 5, read
        W 0x00001000    # Page 1, write again
      '|
    }
    legend: {
      direction: right
      width: 460
      style.fill: "#E8F4E8"
      rbox: "'R' = Read Access" {
        style.fill: "#D4E8D4"
      }
      wbox: "'W' = Write Access" {
        style.fill: "#E8D4D4"
      }
      cbox: "'#' = Comment Line" {
        style.fill: "#E8E8D4"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  parsing: Parsing Pipeline {
    direction: down
    width: 420
    step1: {
      label: "1. Read Line"
      width: 400
      code: |'c
        char line[256];
        fgets(line, sizeof(line), fp);
      '|
    }
    step2: {
      label: "2. Skip Comments"
      width: 400
      code: |'c
        if (line[0] == '#' || line[0] == '\n') 
          continue;  // skip
      '|
    }
    step3: {
      label: "3. Parse Fields"
      width: 400
      code: |'c
        char op;
        unsigned int addr;
        sscanf(line, "%c 0x%X", &op, &addr);
        access->is_write = (op == 'W');
        access->virtual_address = addr;
      '|
    }
    step1 -> step2 -> step3
  }
  structure: Parsed Structure {
    direction: down
    width: 480
    struct: {
      label: "memory_access_t (simulator.h)"
      shape: class
      +is_write: "bool"
      +virtual_address: "uint32_t"
    }
    array: {
      label: "Parsed Trace Array"
      shape: class
      +accesses: "memory_access_t*"
      +count: "size_t"
      +capacity: "size_t"
    }
    struct -> array: "array of"
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  stats: Expected Output Statistics {
    direction: down
    width: 900
    output: {
      label: "Simulation Output (64 frames)"
      width: 880
      code: |'text
        ========================================
                 SIMULATION STATISTICS          
        ========================================
        Total memory accesses:  10
        Page faults:            5
        Protection faults:      0
        Page fault rate:        50.00%
        Physical frames used:   5 / 64
        ========================================
        TLB STATISTICS (if enabled):
        TLB capacity:           16 entries
        TLB hits:               5
        TLB misses:             5
        TLB hit rate:           50.00%
        ========================================
      '|
    }
    breakdown: {
      direction: right
      width: 880
      col1: Page Access Breakdown {
        shape: sql_table
        label: "VPN Access Count"
        p1: "0x1 | 5 accesses | 2 read, 3 write"
        p2: "0x2 | 2 accesses | 1 read, 1 write"
        p3: "0x3 | 1 access   | write only"
        p4: "0x4 | 1 access   | read only"
        p5: "0x5 | 1 access   | read only"
        tot: "Total | 10 accesses | 5 read, 5 write"
      }
      col2: Fault Analysis {
        shape: sql_table
        label: "Page Fault Log"
        f1: "VPN 0x1 | R 0x00001000 | Fault (first access)"
        f2: "VPN 0x2 | R 0x00002000 | Fault (first access)"
        f3: "VPN 0x3 | W 0x00003000 | Fault (first access)"
        f4: "VPN 0x4 | R 0x00004000 | Fault (first access)"
        f5: "VPN 0x5 | R 0x00005000 | Fault (first access)"
        note: "5 unique pages → 5 faults (demand paging)"
      }
    }
  }
}
footer: |md
  **Trace file format is reproducible** — same input always produces same output, enabling deterministic testing and algorithm comparison.
| {near: bottom-center}
syntax -> parsing: "defines format for"
example -> stats: "produces"
structure -> parsing: "outputs"