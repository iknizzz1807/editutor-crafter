direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: "Single-Level Address Translation Flow (translation.c)"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_input: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  virtual_addr: {
    shape: class
    label: "Virtual Address (32-bit)"
    +bits_31_12: "uint32_t vpn"
    +bits_11_0: "uint32_t offset"
  }
  extraction: {
    label: "Bit Extraction"
    width: 280
    code: |'c
      vpn = va >> PAGE_SHIFT;    // va >> 12
      offset = va & PAGE_MASK;   // va & 0xFFF
    '|
  }
}
row_pagetable: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  page_table: {
    shape: sql_table
    label: "Page Table (page_table[VPN])"
    row0: "0x000 | pte_t | entry[0]"
    row1: "0x004 | pte_t | entry[1]"
    row2: "0x008 | pte_t | entry[2]"
    row3: "0x00C | pte_t | entry[3]"
    row4: "0x010 | pte_t | ..."
    rown: "...   | pte_t | entry[vpn]"
    note: "Array: 1,048,576 entries (2^20)"
  }
  pte: {
    shape: sql_table
    label: "Page Table Entry (pte_t)"
    f0: "0x00 | uint32_t | pfn"
    f1: "0x04 | bool     | valid"
    f2: "0x05 | bool     | readable"
    f3: "0x06 | bool     | writable"
    f4: "0x07 | bool     | dirty"
    f5: "0x08 | bool     | referenced"
    sz: "Total: 9 bytes (padded to 12)"
  }
}
row_check: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  valid_check: {
    shape: diamond
    label: "pte.valid?"
    width: 140
  }
  perm_check: {
    shape: diamond
    label: "Check\nPermissions"
    width: 140
    style.fill: "#FFF9C4"
  }
}
row_fault: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  fault_handler: {
    label: "Page Fault Handler (fault.c)"
    width: 320
    code: |'c
      // 1. Find free frame
      pfn = allocate_frame(phys_mem);
      // 2. Zero-fill or load from swap
      memset(frames[pfn], 0, PAGE_SIZE);
      // 3. Update PTE
      pte->pfn = pfn;
      pte->valid = true;
      pte->dirty = false;
      pte->referenced = false;
    '|
    style.fill: "#FFCDD2"
  }
  protection_fault: {
    label: "Protection Fault"
    shape: diamond
    width: 140
    style.fill: "#EF9A9A"
  }
}
row_access: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  op_type: {
    shape: diamond
    label: "is_write?"
    width: 120
  }
  read_path: {
    label: "Read Path"
    width: 200
    code: |'c
      pte->referenced = true;
      // dirty unchanged
    '|
    style.fill: "#C8E6C9"
  }
  write_path: {
    label: "Write Path"
    width: 200
    code: |'c
      pte->referenced = true;
      pte->dirty = true;
    '|
    style.fill: "#BBDEFB"
  }
}
row_output: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  compose: {
    label: "Compose Physical Address"
    width: 280
    code: |'c
      physical_addr = (pte->pfn << PAGE_SHIFT) 
                    | offset;
      // = (pfn * 4096) + offset
    '|
    style.fill: "#E1BEE7"
  }
  phys_addr: {
    shape: class
    label: "Physical Address"
    +bits_31_12: "uint32_t pfn"
    +bits_11_0: "uint32_t offset"
    +value: "uint32_t pa"
    style.fill: "#C5E1A5"
  }
}
row_memory: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  physical_mem: {
    shape: sql_table
    label: "Physical Memory (frames[pfn])"
    f0: "Frame 0   | 4 KB | 0x00000000-0x00000FFF"
    f1: "Frame 1   | 4 KB | 0x00001000-0x00001FFF"
    f2: "Frame 2   | 4 KB | 0x00002000-0x00002FFF"
    fn: "Frame n   | 4 KB | ..."
    note: "Configurable frame count"
  }
}
row_stats: "" {
  direction: right
  style: { stroke: transparent; fill: transparent }
  stats: {
    shape: sql_table
    label: "Statistics (stats_t)"
    s0: "total_accesses   | uint64_t"
    s1: "page_faults      | uint64_t"
    s2: "protection_faults| uint64_t"
  }
}
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  label: "Legend"
  l1: "Red = Error/Fault Path"
  l2: "Green = Read Path"
  l3: "Blue = Write Path"
  l4: "Purple = Address Composition"
  l1.style.fill: "#FFCDD2"
  l2.style.fill: "#C8E6C9"
  l3.style.fill: "#BBDEFB"
  l4.style.fill: "#E1BEE7"
}
# Connections
row_input.virtual_addr -> row_input.extraction: "decompose"
row_input.extraction -> row_pagetable.page_table: "vpn"
row_pagetable.page_table -> row_pagetable.pte: "index by vpn"
row_pagetable.pte -> row_check.valid_check: "read PTE"
row_check.valid_check -> row_check.perm_check: "valid=1"
row_check.valid_check -> row_fault.fault_handler: "valid=0\nPAGE FAULT" {
  style.stroke-dash: 4
  style.stroke: red
}
row_fault.fault_handler -> row_check.valid_check: "retry\ntranslation" {
  style.stroke-dash: 4
  style.stroke: orange
  style.animated: true
}
row_check.perm_check -> row_access.op_type: "OK"
row_check.perm_check -> row_fault.protection_fault: "violation\n(e.g., W on RO)" {
  style.stroke-dash: 4
  style.stroke: red
}
row_access.op_type -> row_access.read_path: "false"
row_access.op_type -> row_access.write_path: "true"
row_access.read_path -> row_output.compose: "update bits"
row_access.write_path -> row_output.compose: "update bits"
row_output.compose -> row_output.phys_addr: "return"
row_output.phys_addr -> row_memory.physical_mem: "access data"
# Statistics updates
row_fault.fault_handler -> row_stats.stats: "page_faults++" {
  style.stroke-dash: 3
  style.stroke: gray
}
row_fault.protection_fault -> row_stats.stats: "protection_faults++" {
  style.stroke-dash: 3
  style.stroke: gray
}