vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F59E0B"
    control: "#10B981"
    text-muted: "#6B7280"
  }
}
title: |md
  # Virtual Memory Simulator: System Component Overview
| {near: top-center}
direction: right
# Input Layer
trace_input: Trace File Input {
  shape: rectangle
  style.fill: "${colors.header}"
  style.font-color: white
  style.stroke: "#7C3AED"
  format: |md
    
    R 0x00001000
    W 0x00002000
    R 0x00003000
    
  |
  trace_parser: Trace Parser {
    shape: rectangle
    style.fill: "${colors.data}"
    style.font-color: white
    parse_line: parse_trace_line()
    memory_access: memory_access_t {is_write, virtual_address}
  }
}
# Translation Core
translation_core: Translation Core {
  style.fill: "#F3F4F6"
  style.stroke: "#D1D5DB"
  addr_decomp: Address Decomposition {
    shape: rectangle
    style.fill: "${colors.pointer}"
    style.font-color: white
    vpn_extract: "vpn = va >> 12"
    offset_extract: "offset = va & 0xFFF"
    bit_layout: |md
      
      ┌────────────────┬────────────┐
      │ VPN (20 bits)  │ Offset (12)│
      │ bits 31-12     │ bits 11-0  │
      └────────────────┴────────────┘
      
    |
  }
  page_table: Single-Level Page Table {
    shape: rectangle
    style.fill: "${colors.header}"
    style.font-color: white
    pte_array: "pte_t page_table[1048576]"
    pte_fields: |md
      c
      typedef struct {
        uint32_t pfn;
        bool valid;
        bool readable;
        bool writable;
        bool dirty;
        bool referenced;
      } pte_t;
      
    |
  }
  translation_logic: Translation Logic {
    shape: rectangle
    style.fill: "${colors.control}"
    style.font-color: white
    check_valid: "1. Check valid bit"
    check_perms: "2. Check permissions"
    update_bits: "3. Update dirty/referenced"
    compose_pa: "4. pa = (pfn << 12) | offset"
  }
}
# Physical Memory
physical_memory: Physical Memory {
  shape: cylinder
  style.fill: "${colors.data}"
  style.font-color: white
  style.multiple: true
  frame_pool: Frame Pool {
    shape: rectangle
    style.fill: "#1E40AF"
    frames: "frames[0..N-1]"
    free_list: "free_list[0..N-1]"
    free_count: "free_count"
    allocation: |md
      
      allocate_frame():
        if free_count == 0:
          return -1
        return free_list[--free_count]
      
    |
  }
  frame_layout: |md
    
    ┌─────────────────────────────┐
    │ Frame 0: 4096 bytes         │
    ├─────────────────────────────┤
    │ Frame 1: 4096 bytes         │
    ├─────────────────────────────┤
    │ ...                         │
    ├─────────────────────────────┤
    │ Frame N-1: 4096 bytes       │
    └─────────────────────────────┘
    
  |
}
# Output Layer
output_layer: Translation Output {
  shape: rectangle
  style.fill: "${colors.control}"
  style.font-color: white
  success: TRANS_OK {
    style.fill: "#059669"
    physical_address: "physical_address = (pfn << 12) | offset"
  }
  page_fault: TRANS_PAGE_FAULT {
    style.fill: "#DC2626"
    condition: "valid == false"
    action: "Demand paging → allocate_frame()"
  }
  protection_fault: TRANS_PROTECTION_FAULT {
    style.fill: "#B91C1C"
    condition: "Permission violation"
    action: "Log error, deny access"
  }
}
# Statistics
statistics: Statistics Collection {
  shape: rectangle
  style.fill: "#6B7280"
  style.font-color: white
  counters: |md
    
    stats_t {
      uint64_t total_accesses;
      uint64_t page_faults;
      uint64_t protection_faults;
    }
    
  |
  reporter: stats_print() {
    shape: rectangle
    style.fill: "#4B5563"
  }
}
# Flow Connections
trace_input.trace_parser -> translation_core.addr_decomp: memory_access_t {
  label: "is_write, virtual_address"
  style.stroke: "${colors.data}"
  style.stroke-width: 2
}
translation_core.addr_decomp -> translation_core.page_table: vpn {
  label: "page_table[vpn]"
  style.stroke: "${colors.pointer}"
  style.stroke-width: 2
}
translation_core.page_table -> translation_core.translation_logic: pte_t* {
  style.stroke: "${colors.header}"
  style.stroke-width: 2
}
translation_core.translation_logic -> physical_memory.frame_pool: pfn {
  label: "Frame lookup"
  style.stroke: "${colors.data}"
  style.stroke-width: 2
  style.stroke-dash: 3
}
translation_core.translation_logic -> output_layer: trans_output_t {
  label: "result, physical_address"
  style.stroke: "${colors.control}"
  style.stroke-width: 2
}
physical_memory.frame_pool -> statistics: allocation events {
  style.stroke: "#6B7280"
  style.stroke-dash: 3
}
output_layer -> statistics: fault counts {
  style.stroke: "#6B7280"
  style.stroke-dash: 3
}
# Demand Paging Flow
output_layer.page_fault -> physical_memory.frame_pool: "handle_page_fault()" {
  style.stroke: "#DC2626"
  style.stroke-width: 2
  style.animated: true
}
physical_memory.frame_pool -> translation_core.page_table: "Update PTE\n(valid=1, pfn set)" {
  style.stroke: "${colors.control}"
  style.stroke-width: 2
  style.stroke-dash: 5
}
# Legend
legend: |md
  ## Translation Pipeline
  1. **Parse** trace file → memory_access_t
  2. **Decompose** virtual address → VPN + offset
  3. **Lookup** page_table[vpn] → PTE
  4. **Check** valid bit and permissions
  5. **Compose** physical address
  6. **Return** result with statistics
  ---
  **Key Data Sizes:**
  - Page size: 4096 bytes (4 KB)
  - VPN bits: 20 (2²⁰ = 1,048,576 pages)
  - Offset bits: 12 (2¹² = 4096 bytes)
  - PTE size: ~12 bytes (with padding)
| {
  near: bottom-center
  shape: text
  style.font-size: 14
}