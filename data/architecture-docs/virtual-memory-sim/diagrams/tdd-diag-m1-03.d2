vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: ||md
  # PTE Architectural Specification: 64-bit Virtual-to-Physical Mapping
  **Revision:** 1.0.4 | **Alignment:** 8-byte boundary | **Page Size:** 4096B (4KB)
||
title.near: top-center

direction: right

# Main memory layout container
PTE_Memory_Layout: {
  label: "Memory Map: Physical Page Table Entry (8 Bytes)"
  
  # Bit Ruler for reference
  ruler: {
    grid-columns: 8
    grid-gap: 0
    b7: "63" { style.stroke: transparent; style.font-size: 10 }
    b6: "55" { style.stroke: transparent; style.font-size: 10 }
    b5: "47" { style.stroke: transparent; style.font-size: 10 }
    b4: "39" { style.stroke: transparent; style.font-size: 10 }
    b3: "31" { style.stroke: transparent; style.font-size: 10 }
    b2: "23" { style.stroke: transparent; style.font-size: 10 }
    b1: "15" { style.stroke: transparent; style.font-size: 10 }
    b0: "7" { style.stroke: transparent; style.font-size: 10 }
  }

  # 64-bit Layout Visualization
  binary_strip: {
    grid-columns: 1
    grid-gap: 5

    upper_dword: {
      label: "Upper DWORD (Offset +0x04)"
      grid-columns: 4
      grid-gap: 0
      
      # Bytes 7, 6, 5 are Reserved (Gray)
      byte_7: "RSVD\n[63:56]" { style.fill: "#EEEEEE"; style.stroke-dash: 3 }
      byte_6: "RSVD\n[55:48]" { style.fill: "#EEEEEE"; style.stroke-dash: 3 }
      byte_5: "RSVD\n[47:40]" { style.fill: "#EEEEEE"; style.stroke-dash: 3 }
      
      # Byte 4 contains flags (Mixed Logic)
      byte_4_flags: {
        grid-columns: 8
        grid-gap: 0
        rsvd3: "RS" { style.fill: "#EEEEEE" }
        rsvd2: "RS" { style.fill: "#EEEEEE" }
        rsvd1: "RS" { style.fill: "#EEEEEE" }
        ref: "REF" { style.fill: "#E1BEE7"; tooltip: "Referenced bit" }
        dirty: "D" { style.fill: "#FFCDD2"; tooltip: "Dirty/Modified bit" }
        write: "W" { style.fill: "#FFF9C4"; tooltip: "Write enable" }
        read: "R" { style.fill: "#FFF9C4"; tooltip: "Read enable" }
        valid: "V" { style.fill: "#C8E6C9"; tooltip: "Present/Valid bit" }
      }
    }

    lower_dword: {
      label: "Lower DWORD (Offset +0x00)"
      grid-columns: 4
      grid-gap: 0
      
      # Bytes 3, 2, 1, 0 are PFN (Blue)
      byte_3: "PFN\n[31:24]" { style.fill: "#BBDEFB" }
      byte_2: "PFN\n[23:16]" { style.fill: "#BBDEFB" }
      byte_1: "PFN\n[15:8]" { style.fill: "#BBDEFB" }
      byte_0: "PFN\n[7:0]" { style.fill: "#BBDEFB" }
    }
  }
}

# Field Definitions Table
Definition_Table: ||md
  | Offset | Field | Bits | Purpose | Size |
  | :--- | :--- | :--- | :--- | :--- |
  | 0x00 | **PFN** | 0-31 | Physical Frame Number (Address >> 12) | 4 Bytes |
  | 0x04 | **Valid** | 32 | Set if page is in physical memory | 1 bit |
  | 0x04 | **Read** | 33 | Read permission bit | 1 bit |
  | 0x04 | **Write** | 34 | Write permission bit | 1 bit |
  | 0x04 | **Dirty** | 35 | Hardware-set if page is modified | 1 bit |
  | 0x04 | **Ref** | 36 | Hardware-set if page is accessed | 1 bit |
  | 0x05 | **RSVD** | 37-63 | Padding for hardware future-proofing | 27 bits |
||

Definition_Table.style: {
  fill: "#F3E5F5"
  stroke: "#7B1FA2"
}

# Implementation Reference
Implementation: |cpp
  /**
   * Intel-aligned Page Table Entry
   * Total Size: 64 bits (8 bytes)
   */
  struct __attribute__((packed, aligned(8))) pte_t {
      uint32_t pfn;          // Physical Frame Number [0:31]
      
      uint8_t  valid : 1;    // bit 32
      uint8_t  read  : 1;    // bit 33
      uint8_t  write : 1;    // bit 34
      uint8_t  dirty : 1;    // bit 35
      uint8_t  ref   : 1;    // bit 36
      uint8_t  rsvd  : 3;    // bits 37-39 (padding in byte 4)
      
      uint8_t  padding[3];   // bits 40:63 (Bytes 5, 6, 7)
  };
|

Implementation.style: {
  fill: "#1E1E1E"
  font-color: "#D4D4D4"
  stroke-width: 2
}

# Legend and Constraints
Metadata: |md
  ### Architectural Constraints
  - **Atomicity**: MMU must read all 64 bits in a single bus cycle.
  - **Endianness**: Little-endian byte order (x86-64 standard).
  - **Cache**: Entry is stored in TLB after hardware walk.
|

Metadata.near: bottom-center
Metadata.style: {
  fill: "#FAFAFA"
  stroke: "#DDDDDD"
  font-size: 14
}

# Visual Connections
PTE_Memory_Layout.binary_strip -> Definition_Table: "Schema"
Definition_Table -> Implementation: "C-Type Mapping"

# Global Styles for Hardware Precision
***.style.font: mono

PTE_Memory_Layout.binary_strip.lower_dword.byte_*: {
  style.stroke: "#1976D2"
}

PTE_Memory_Layout.binary_strip.upper_dword.byte_*: {
  style.stroke: "#616161"
}

PTE_Memory_Layout.binary_strip.upper_dword.byte_4_flags.*: {
  style.stroke: "#000000"
  style.stroke-width: 1
}