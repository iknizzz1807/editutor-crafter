layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#7C3AED"
    process: "#3B82F6"
    decision: "#F59E0B"
    success: "#10B981"
    fault: "#EF4444"
    bits: "#8B5CF6"
    pte_bg: "#FFFBEB"
    pte_stroke: "#D97706"
    mem_blue: "#EFF6FF"
  }
}

# --- GLOBAL CLASSES ---
classes: {
  step_box: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: "#F8FAFC"
    }
  }
  logic_gate: {
    shape: diamond
    style: {
      font-color: black
      stroke-width: 2
      border-radius: 0
    }
  }
  exception_state: {
    shape: diamond
    style: {
      fill: "#FEE2E2"
      stroke: "#EF4444"
      font-color: "#B91C1C"
      bold: true
    }
  }
  terminal: {
    shape: hexagon
    style: {
      font-color: white
      stroke-width: 4
      font: mono
    }
  }
}

# --- HEADER SECTION ---
title: ||md
  # Virtual Address Translation Pipeline
  **Architecture: x86-32 Legacy Paging (Single Level Simplified)**
  *Input: 32-bit VA | Output: 32-bit PA | Page Size: 4 KiB*
||
title.shape: text
title.near: top-center
title.style.font-size: 24
title.style.bold: true

# --- STAGE 0: INPUT ---
input_va: "INPUT VIRTUAL ADDRESS\n0x00401234" {
  class: terminal
  style.fill: ${colors.header}
}

# --- STAGE 1: DECOMPOSITION ---
stage1: {
  label: "Step 1: VA Segmentation"
  class: step_box
  style.stroke: ${colors.process}

  bit_layout: {
    grid-columns: 2
    grid-gap: 0
    vpn_bits: "VPN (Virtual Page Number)\nBits [31:12]" {
      style: {
        fill: ${colors.process}
        font-color: white
        font: mono
      }
    }
    offset_bits: "VPO (Page Offset)\nBits [11:0]" {
      style: {
        fill: ${colors.bits}
        font-color: white
        font: mono
      }
    }
  }

  logic: |md
    c
    vpn    = (va >> 12);     // Extract high 20 bits (0x00401)
    offset = (va & 0xFFF);   // Extract low 12 bits (0x234)
    
  |
  logic.shape: text
  logic.style.font-size: 14
}

# --- STAGE 2: PTE LOOKUP ---
stage2: {
  label: "Step 2: Page Table Walk"
  class: step_box
  style.stroke: ${colors.decision}

  lookup_math: |md
    1. **Base**: CR3 Register (0x1000)
    2. **Index**: VPN << 2 (Size of PTE is 4B)
    3. **Target**: CR3 + (VPN * 4)
  |
  lookup_math.shape: text

  pte_struct: "Page Table Entry (PTE) - 32-bit" {
    shape: sql_table
    style.fill: ${colors.pte_bg}
    style.stroke: ${colors.pte_stroke}
    
    PFN: "bits [31:12]" {constraint: Physical Frame Number}
    FLAGS: "bits [11:0]" {constraint: "Meta: G, PAT, D, A, PCD, PWT, U/S, R/W, P"}
    V: "bit 0 (P)" {constraint: "Present/Valid"}
    W: "bit 1 (RW)" {constraint: "Read=0 / Write=1"}
    U: "bit 2 (US)" {constraint: "User=1 / Supervisor=0"}
  }
}

# --- STAGE 3: PROTECTION & VALIDATION ---
validation_engine: "MMU Control Logic" {
  style.fill: "#F1F5F9"
  
  check_valid: "Is Present?\n(PTE.P == 1)" {
    class: logic_gate
    style.fill: ${colors.decision}
  }

  check_perms: "Access Allowed?\n(Ring vs RW)" {
    class: logic_gate
    style.fill: ${colors.decision}
  }
}

# --- FAULT HANDLERS ---
faults: {
  label: "Exception States"
  
  page_fault: "PAGE FAULT\n(Interrupt 14)" {
    class: exception_state
  }

  fault_handler: |md
    ### OS Page Fault Handler
    1. Check VM_AREA_STRUCT
    2. If valid addr: **Swap In** from backing store
    3. Update Page Table: `PFN=0x17, P=1`
    4. **Invalidate TLB** for this VA
    5. IRET (Retry instruction)
  |
  fault_handler.shape: text
  fault_handler.style.fill: "#FFF1F2"
  fault_handler.style.stroke: "#EF4444"

  protection_fault: "SEGMENTATION FAULT\n(SIGSEGV)" {
    class: exception_state
  }
}

# --- STAGE 4: COMPOSITION ---
stage4: {
  label: "Step 3: PA Generation"
  class: step_box
  style.stroke: ${colors.process}

  pa_layout: {
    grid-columns: 2
    grid-gap: 0
    pfn_part: "PFN (from PTE)\n[31:12]" {
      style: {
        fill: ${colors.process}
        font-color: white
      }
    }
    offset_part: "Offset (from VA)\n[11:0]" {
      style: {
        fill: ${colors.bits}
        font-color: white
      }
    }
  }

  calc: ||md
    c
    phys_addr = (PFN << 12) | offset;
    // (0x00017 << 12) | 0x234 = 0x17234

  ||
  calc.shape: text
}

# --- STAGE 5: OUTPUT ---
output_pa: "PHYSICAL ADDRESS\n0x00017234" {
  class: terminal
  style.fill: ${colors.success}
}

# --- CONNECTIONS ---

input_va -> stage1: "Memory Ref"
stage1 -> stage2: "VPN"
stage2 -> validation_engine.check_valid: "PTE Descriptor"

validation_engine.check_valid -> faults.page_fault: "NO (P=0)" {
  style: {
    stroke: ${colors.fault}
    stroke-width: 3
  }
}

faults.page_fault -> faults.fault_handler
faults.fault_handler -> validation_engine.check_valid: "Retry instruction" {
  style: {
    stroke: ${colors.success}
    stroke-dash: 5
    animated: true
  }
}

validation_engine.check_valid -> validation_engine.check_perms: "YES"
validation_engine.check_perms -> faults.protection_fault: "Access Denied" {
  style: {
    stroke: ${colors.fault}
    stroke-width: 3
  }
}

validation_engine.check_perms -> stage4: "Authorized" {
  style.stroke: ${colors.success}
  style.stroke-width: 3
}

stage4 -> output_pa: "To L1 Cache / Bus"

# --- ANNOTATIONS ---
invariants: |md
  ### Hardware Specs
  - **Word Size**: 32-bit
  - **Page Size**: 4096 Bytes ($2^{12}$)
  - **PTE Size**: 4 Bytes
  - **Max Pages**: $2^{20}$ (1,048,576)
  - **Table Size**: 4 MiB (Flat)
|
invariants.near: bottom-left
invariants.shape: text
invariants.style.fill: "#F0FDF4"
invariants.style.stroke: ${colors.success}
invariants.style.font-size: 12

legend: {
  near: bottom-right
  l1: "MMU Pipeline Stage" { 
    style.fill: ${colors.process}
    style.font-color: white 
  }
  l2: "Branch/Logic Unit" { 
    style.fill: ${colors.decision} 
  }
  l3: "CPU Exception" { 
    style.fill: "#FEE2E2"
    style.font-color: "#B91C1C" 
  }
  l4: "Control/Data Register" { 
    style.fill: ${colors.header}
    style.font-color: white 
  }
}