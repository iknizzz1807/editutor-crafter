direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
}

title: |md
  # Page Fault Handling Sequence (x86-64)
  ## Hardware Detection → OS Managed Paging → Instruction Retry
  **TDD Spec Module: Virtual Memory Simulator v1.0**
|
title.near: top-center

# -----------------------------------------------------------------------------
# 1. FAULT DETECTION (MMU/CPU)
# -----------------------------------------------------------------------------
step1: "1. FAULT DETECTION" {
  style: {
    fill: "#FFE6E6"
    stroke: "#CC0000"
    stroke-width: 2
  }

  pipeline: "CPU Execution Pipeline" {
    instr: "MOV RAX, [0x00401234]" {
      shape: rectangle
      style: {
        font: mono
        bold: true
      }
    }
  }

  mmu: "Memory Management Unit" {
    tlb: "TLB Lookup" {
      shape: diamond
      tooltip: "Translation Lookaside Buffer"
    }
    pte_walk: "Page Table Walker" {
      shape: parallelogram
      label: "PTE Valid Bit Check (PTE.V)"
    }
  }

  fault_trigger: "PAGE FAULT EXCEPTION (#PF)" {
    style: {
      fill: "#CC0000"
      font-color: white
      bold: true
      stroke-width: 4
    }
  }

  pipeline.instr -> mmu.tlb: "Virtual Address (VA)"
  mmu.tlb -> mmu.pte_walk: "TLB MISS"
  mmu.pte_walk -> fault_trigger: "PTE.V == 0 (Not Present)"
}

# -----------------------------------------------------------------------------
# 2. FAULT DELIVERY (HARDWARE TO KERNEL)
# -----------------------------------------------------------------------------
step2: "2. FAULT DELIVERY" {
  style: {
    fill: "#FFF2CC"
    stroke: "#BF8F00"
    stroke-width: 2
  }

  trap: "Trap to Ring 0 (IDT[14])" {
    shape: hexagon
  }

  k_stack: "Kernel Stack Frame" {
    shape: sql_table
    RIP: "0x00401230 (Instruction Pointer)"
    CR2: "0x00401234 (Faulting Address)"
    ERROR_CODE: "0x00000004 (U/S Bit Set)"
  }

  handler: "page_fault_handler()" {
    style: {
      fill: "#FFD966"
      bold: true
    }
  }

  trap -> k_stack: "CPU Pushes Context"
  k_stack -> handler: "Jump to ISR"
}

# -----------------------------------------------------------------------------
# 3. VPN EXTRACTION (OS LOGIC)
# -----------------------------------------------------------------------------
step3: "3. ADDRESS DECOMPOSITION" {
  style: {
    fill: "#E6F3FF"
    stroke: "#0066CC"
    stroke-width: 2
  }

  va_split: {
    grid-columns: 2
    grid-gap: 0
    
    vpn_label: "VPN (Virtual Page Number)" {
      style.fill: "#BDD7EE"
    }
    off_label: "Offset (Page-Relative)" {
      style.fill: "#D9EAD3"
    }
    
    vpn_val: "0x00401" {
      style.font: mono
      style.bold: true
    }
    off_val: "0x234" {
      style.font: mono
    }
  }

  logic: |md
    **Address Decomposition:**
    - Extract VPN from CR2
    - Search Task `mm_struct`
    - Locate VMA (Virtual Memory Area)
    - Validate Permission Flags
  |
  
  va_split -> logic
}

# -----------------------------------------------------------------------------
# 4. FRAME ALLOCATION (PHYSICAL MEMORY MGMT)
# -----------------------------------------------------------------------------
step4: "4. PHYSICAL FRAME ALLOCATION" {
  style: {
    fill: "#E6FFE6"
    stroke: "#009900"
    stroke-width: 2
  }

  free_pool: "Physical Memory Pool" {
    shape: cylinder
    style.fill: "#D0F0D0"
  }

  allocator: "buddy_allocator()" {
    shape: diamond
  }

  swap: "Page Swapping Engine" {
    shape: rectangle
    style: {
      fill: "#FCE4D6"
      stroke: "#C65911"
    }
  }

  pfn_out: "Allocated PFN: 0x17" {
    style: {
      bold: true
      stroke-width: 3
    }
  }

  free_pool -> allocator: "Request Page"
  allocator -> pfn_out: "Success"
  allocator -> swap: "OOM Condition"
  swap -> pfn_out: "Eviction Done"
}

# -----------------------------------------------------------------------------
# 5. PTE UPDATE (PAGE TABLE MGMT)
# -----------------------------------------------------------------------------
step5: "5. PAGE TABLE UPDATE" {
  style: {
    fill: "#F0E6FF"
    stroke: "#6600CC"
    stroke-width: 2
  }

  pte_entry: {
    shape: sql_table
    label: "PTE Descriptor (8-byte)"
    V: "1 (Present Bit)"
    PFN: "0x17 (Target Frame)"
    RW: "1 (Writable)"
    US: "1 (User Accessible)"
    NX: "0 (No-Execute Disabled)"
  }
  
  pte_entry.V.style.fill: "#D9D9FF"
  pte_entry.PFN.style.fill: "#D9D9FF"

  update_op: "Zero-fill Page / Load from Disk"
  update_op -> pte_entry: "Commit Atomic Write"
}

# -----------------------------------------------------------------------------
# 6. TLB UPDATE
# -----------------------------------------------------------------------------
step6: "6. TLB COHERENCY" {
  style: {
    fill: "#FFE6F0"
    stroke: "#CC0066"
    stroke-width: 2
  }

  flush: "INVLPG [0x00401234]" {
    style: {
      font: mono
      fill: "#FFCCD9"
    }
  }
  tlb_ready: "TLB Coherent" {
    style.bold: true
  }

  flush -> tlb_ready: "Pipeline Synchronized"
}

# -----------------------------------------------------------------------------
# 7. INSTRUCTION RETRY
# -----------------------------------------------------------------------------
step7: "7. INSTRUCTION RETRY" {
  style: {
    fill: "#E6FFFF"
    stroke: "#006666"
    stroke-width: 2
  }

  iret: "iretq (ISR Return)" {
    shape: hexagon
    style.fill: "#B6E3E3"
  }

  retry: "Execute: MOV RAX, [0x00401234]" {
    style: {
      fill: "#D0F0F0"
      font: mono
      bold: true
    }
  }

  pa_calc: ||md
    **Hardware Result:**
    `PA = (0x17 << 12) | 0x234`
    Target Physical Address: **0x17234**
  ||

  iret -> retry -> pa_calc
}

# -----------------------------------------------------------------------------
# GLOBAL CONTROL FLOW
# -----------------------------------------------------------------------------
step1.fault_trigger -> step2.trap: "Exception #14"
step2.handler -> step3.va_split: "Context Switch"
step3.logic -> step4.allocator: "Request Frame"
step4.pfn_out -> step5.update_op: "PFN Mapping"
step5.pte_entry -> step6.flush: "Sync Hardware"
step6.tlb_ready -> step7.iret: "Return to Ring 3"

# -----------------------------------------------------------------------------
# ANNOTATIONS & NOTES
# -----------------------------------------------------------------------------
note_alloc: |md
  ### Frame Allocation Constraints
  - PFN 0x17 is mapped from the **Buddy Allocator** O(1) free list.
  - Page is zeroed if not backed by file to prevent data leakage.
|

note_perf: ||md
  ### Latency (CPU Cycles)
  | Component      | Latency (Cycles) |
  | :---           | :---             |
  | HW Context Save| ~150             |
  | Kernel Handler | ~1500 - 3000     |
  | Buddy Alloc    | ~400             |
  | IRETQ Return   | ~150             |
||

# -----------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------
legend: {
  label: "Subsystem Context"
  near: bottom-center
  
  hw: "Silicon (Hardware) Path" {
    style.fill: "#FFE6E6"
    style.stroke: "#CC0000"
  }
  sw: "Kernel (Software) Path" {
    style.fill: "#E6F3FF"
    style.stroke: "#0066CC"
  }
  
  hw -> sw: "Exception Boundary" {
    style.stroke-dash: 3
  }
}