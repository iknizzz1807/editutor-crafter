vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  # Memory Protection & Fault Detection Flow
  ### MMU Logic: Distinguishing `valid` (Page Fault) from `permissions` (Protection Fault)
|
title.near: top-center

# --- NODES ---

start: {
  shape: circle
  label: "Memory\nAccess Request"
  tooltip: "CPU issues Virtual Address (VA) + Access Type (R/W/X)"
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

extract: {
  label: "VA Decomposition\n& PTE Lookup"
  tooltip: "Extract VPN, find PTE in Page Table (or TLB hit)"
  style.fill: "#E3F2FD"
}

# First critical decision: Presence in physical memory
valid_check: {
  shape: diamond
  label: "PTE.valid == 1?"
  tooltip: "Check if the page is currently mapped to a physical frame"
  style.fill: "#FFF3E0"
}

# --- PAGE FAULT BRANCH ---

page_fault_container: {
  label: "Page Fault Path"
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-dash: 5
  }

  page_fault_info: |md
    ### Soft/Hard Page Fault
    **Condition:** `valid = 0` (Present bit unset)
    - Page swapped to secondary storage (disk)
    - First access (zero-fill-on-demand)
    - Copy-on-Write (COW) source page missing
    - Shared memory segment not yet mapped
  |
  
  pf_handler: "Invoke OS\nPage Fault Handler" {
    style: {
      fill: "#FFCDD2"
      stroke: "#B71C1C"
      bold: true
    }
  }
}

# --- PERMISSION BRANCH ---

perm_gate: {
  label: "Permission Validation Gate"
  style.fill: "#E1F5FE"
}

# Decision: Write violation
write_check: {
  shape: diamond
  label: "Write Access\nAND\nPTE.writable == 0?"
  tooltip: "Check W bit in PTE metadata"
  style.fill: "#FFF3E0"
}

# Decision: Read violation
read_check: {
  shape: diamond
  label: "Read Access\nAND\nPTE.readable == 0?"
  tooltip: "Check R bit in PTE metadata"
  style.fill: "#FFF3E0"
}

# --- PROTECTION FAULT BRANCH ---

prot_fault_container: {
  label: "Protection Fault (Segmentation Violation)"
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-dash: 3
  }

  fault_details: |md
    ### Access Violation
    **Condition:** `valid = 1` BUT `perm = 0`
    - Attempting to write to `.text` (Code) segment
    - User-mode code access to Kernel-mode page (U/S bit)
    - Execution attempt on non-executable page (NX bit)
    - Writing to a Read-Only mapping
  |

  segfault_node: |md
    ## FATAL: SIGSEGV
    MMU signals Protection Violation.
    OS Hardware Abstraction Layer traps.
    Kernel typically sends SIGSEGV to process.
  |
  segfault_node.style: {
    fill: "#FCE4EC"
    stroke: "#D81B60"
    stroke-width: 4
  }
}

# --- SUCCESS BRANCH ---

success_box: {
  label: "Translation Finalization"
  style.fill: "#E8F5E9"
  
  math: ||md
    **Physical Address Calculation:**
    `PA = (PTE.PFN << 12) | VA.offset`

    **Hardware Metadata Updates:**
    - `PTE.Accessed = 1` (For LRU aging)
    - `If Write Access: PTE.Dirty = 1`
  ||
}

complete: {
  shape: circle
  label: "Physical\nMemory Access"
  tooltip: "PA placed on System Bus for RAM controller"
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    double-border: true
  }
}

# --- CONNECTIONS ---

start -> extract: "VA [VPN|Offset]"
extract -> valid_check: "Fetch PTE"

# Valid=0 Path
valid_check -> page_fault_container.page_fault_info: "No (0)" {
  style: {
    stroke: "#C62828"
    stroke-width: 3
    font-color: "#C62828"
    bold: true
  }
}
page_fault_container.page_fault_info -> page_fault_container.pf_handler
page_fault_container.pf_handler -> perm_gate: "Retry after I/O"

# Valid=1 Path
valid_check -> perm_gate: "Yes (1)" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: "#2E7D32"
    bold: true
  }
}

perm_gate -> write_check
write_check -> prot_fault_container.fault_details: "Fault (Perm Denied)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}
write_check -> read_check: "OK"

read_check -> prot_fault_container.fault_details: "Fault (Perm Denied)" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}
read_check -> success_box: "OK"

prot_fault_container.fault_details -> prot_fault_container.segfault_node: "Trap to OS"
success_box -> complete

# --- ANNOTATIONS & LEGEND ---

legend: {
  near: bottom-right
  style: {
    fill: "#F5F5F5"
    stroke: "#BDBDBD"
  }
  
  title: "MMU State Legend" { style.bold: true }
  
  item1: {
    label: "Hardware Path"
    style.fill: "#E3F2FD"
  }
  item2: {
    label: "Page Fault (OS Intervention)"
    style.fill: "#FFCDD2"
  }
  item3: {
    label: "Protection Fault (Violation)"
    style.fill: "#CE93D8"
  }
  item4: {
    label: "Success"
    style.fill: "#C8E6C9"
  }
}

comparison_table: ||md
  ## Architecture Comparison
  | Feature | Page Fault | Protection Fault |
  | :--- | :--- | :--- |
  | **Trigger** | `PTE.Present = 0` | `PTE.Writable/User = 0` |
  | **OS View** | Recoverable (load from disk) | Unrecoverable (security/bug) |
  | **Hardware** | Page is missing from RAM | Page is present but restricted |
||

comparison_table.near: bottom-left
comparison_table.style: {
  fill: "#FFFDE7"
  stroke: "#FBC02D"
}