vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: down
title: |md
  # Protection Fault Detection Flowchart
  ## Distinguishing Page Faults from Protection Faults
| {near: top-center}
# Start node
start: {
  shape: circle
  style.fill: "#E8F5E9"
}
start.label: "Memory\nAccess"
# Virtual Address Processing
extract: "Extract VPN & Offset\nfrom Virtual Address" {
  style.fill: "#E3F2FD"
}
# First decision: Valid bit check
valid_check: "PTE.valid == 1?" {
  shape: diamond
  style.fill: "#FFF3E0"
}
# Page Fault Path (valid=0)
page_fault_box: {
  label: "Page Fault\n(valid=0)"
  style.fill: "#FFCDD2"
  pf_type: |md
    **Page Not in Memory**
    - First access to page
    - Page was evicted to swap
    - Demand paging needed
  |
}
pf_handler: "Page Fault Handler\n(Allocate frame, load page)" {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
}
# Continue to permission check
perm_check: "Permission Check" {
  style.fill: "#E3F2FD"
}
# Permission decision
write_check: "is_write &&\nPTE.writable == 0?" {
  shape: diamond
  style.fill: "#FFF3E0"
}
read_check: "!is_write &&\nPTE.readable == 0?" {
  shape: diamond
  style.fill: "#FFF3E0"
}
# Protection Fault Path
prot_fault_box: {
  label: "Protection Fault\n(valid=1, permission denied)"
  style.fill: "#CE93D8"
  pf_reasons: |md
    **Permission Violation**
    - Write to read-only page
    - Read from non-readable page
    - Execute from non-executable
  |
}
segfault: |md
  **FATAL ERROR**
  `SIGSEGV` in user space
  Process terminated
| {
  style.fill: "#FFCDD2"
  style.stroke: "#B71C1C"
  style.stroke-width: 3
}
# Success path
success: {
  label: "Translation Success"
  style.fill: "#C8E6C9"
  compose: |md
    **Physical Address:**
    `PA = (PFN << 12) | offset`
    - Update `PTE.referenced = 1`
    - If write: `PTE.dirty = 1`
  |
}
# Continue execution
continue: {
  shape: circle
  style.fill: "#C8E6C9"
}
continue.label: "Complete\nAccess"
# Connections
start -> extract: "VA, is_write"
extract -> valid_check: "PTE lookup"
valid_check -> page_fault_box: "No (valid=0)" {
  style.stroke: "#C62828"
  style.stroke-width: 2
}
page_fault_box -> pf_handler: "Recoverable"
pf_handler -> perm_check: "Retry"
valid_check -> perm_check: "Yes (valid=1)" {
  style.stroke: "#2E7D32"
}
perm_check -> write_check
write_check -> prot_fault_box: "Yes" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
write_check -> read_check: "No"
read_check -> prot_fault_box: "Yes" {
  style.stroke: "#7B1FA2"
  style.stroke-width: 2
}
read_check -> success: "No (all checks pass)"
prot_fault_box -> segfault: "Cannot recover" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 5
}
success -> continue
# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  legend_title: "Legend" {
    style.bold: true
  }
  pf_color: "Page Fault (valid=0)" {
    style.fill: "#FFCDD2"
  }
  prot_color: "Protection Fault (valid=1)" {
    style.fill: "#CE93D8"
  }
  success_color: "Success Path" {
    style.fill: "#C8E6C9"
  }
}
# Key distinction annotation
key_diff: |md
  ## Key Distinction
  | Condition | Result | Recoverable? |
  |-----------|--------|--------------|
  | valid=0 | Page Fault | **Yes** - load page |
  | valid=1, wrong perms | Protection Fault | **No** - policy violation |
  **Order matters:** Check valid BEFORE permissions!
| {
  near: bottom-left
  style.fill: "#FFFDE7"
  style.stroke: "#FBC02D"
}