direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 25
  }
  colors: {
    header: "#673AB7"
    logic: "#1976D2"
    data: "#388E3C"
    comment: "#9E9E9E"
    example: "#F57C00"
    background: "#FAFAFA"
    padding: "#E0E0E0"
    purple_lite: "#F3E5F5"
  }
}

title: {
  label: |md
    # Trace File Format Spec v1.0
    ## Virtual Memory Simulator Interface Specification
    **Architecture:** x86-32 (32-bit Virtual Addresses) | **Page Size:** 4KB
  |
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
    font-color: "#673AB7"
    bold: true
  }
}

# 1. Input: Raw Trace File Structure
trace_file: {
  label: |md
    ### Raw Trace Stream (ASCII)
    `[Offset] | [Op] | [Address]`
    ---
    `0x00     | R    | 0x00001000`
    `0x0C     | R    | 0x00002000`
    `0x18     | W    | 0x00001400`
    `0x24     | R    | 0x00003000`
    `# End of Trace`
  |
  shape: rectangle
  tooltip: "Input file format for the simulator"
  style: {
    fill: "#F5F5F5"
    stroke: "#666666"
    font: mono
    stroke-width: 2
    double-border: true
  }
}

# 2. Parser Component Implementation
parser: "Trace Parser Logic" {
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
  }
  
  parse_line: {
    label: "parse_trace_line(string line) -> bool"
    style: { fill: "#BBDEFB"; font: mono }
  }
  skip_comment: {
    label: "is_comment(char[0] == '#')"
    style: { fill: "#90CAF9"; font: mono }
  }
  skip_blank: {
    label: "is_whitespace_only()"
    style: { fill: "#90CAF9"; font: mono }
  }
  extract_op: {
    label: "tokenize[0] -> op_type"
    style: { fill: "#64B5F6"; font: mono }
  }
  extract_addr: {
    label: "sscanf(tokenize[1], '0x%x')"
    style: { fill: "#64B5F6"; font: mono }
  }
}

# 3. Output: Internal Representation (Parsed Struct)
parsed_output: "memory_access_t" {
  shape: class
  style: {
    fill: "#E8F5E9"
    stroke: "#388E3C"
    stroke-width: 2
  }
  
  is_write: "bool (1 bit)"
  virtual_address: "uint32_t (32 bits)"
  
  "+ to_string(): string"
  "+ validate(): bool"
}

# 4. Parsed Entries Visualisation
entries: "Memory Access Sequence" {
  style: {
    fill: "#FFF3E0"
    stroke: "#F57C00"
    stroke-width: 2
  }
  
  entry1: {
    label: |md
      **Entry [0]**
      - `type: READ`
      - `vaddr: 0x00001000`
    |
    style.fill: "#FFE0B2"
  }
  entry2: {
    label: |md
      **Entry [1]**
      - `type: READ`
      - `vaddr: 0x00002000`
    |
    style.fill: "#FFCC80"
  }
  entry3: {
    label: |md
      **Entry [2]**
      - `type: WRITE`
      - `vaddr: 0x00001400`
    |
    style.fill: "#FFB74D"
  }
}

# 5. Address Decomposition Logic (Intel/x86 Style)
decomposition: "Address Decomposition (32-bit)" {
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }
  
  bit_layout: "VA Bit Breakdown" {
    grid-columns: 2
    grid-gap: 0
    style.stroke-width: 1
    
    vpn: {
      label: "VPN (Virtual Page Number)\nBits [31:12]\nSize: 20 bits"
      width: 300
      height: 80
      style: { fill: "#D1C4E9"; bold: true }
    }
    offset: {
      label: "Page Offset\nBits [11:0]\nSize: 12 bits"
      width: 150
      height: 80
      style: { fill: "#E1BEE7"; bold: true }
    }
  }

  logic: {
    label: |md
      **Hardware Logic (4KB Pages):**
      - `vpn = (va & 0xFFFFF000) >> 12;`
      - `offset = (va & 0x00000FFF);`
      
      **Example (0x00001400):**
      - `VPN: 0x00001`
      - `Offset: 0x400`
    |
    style.font: mono
  }
}

# 6. Parser Runtime Statistics
stats: "Parser Statistics" {
  style: {
    fill: "#ECEFF1"
    stroke: "#607D8B"
    stroke-width: 1
  }
  metrics: {
    label: |md
      ### Session Summary
      - `lines_processed: 7`
      - `valid_accesses: 6`
      - `comments_skipped: 2`
      - `malformed_lines: 0`
    |
    style.font: mono
  }
}

# 7. Legend and Formatting Rules
legend: "Format Legend" {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    stroke-dash: 3
  }
  rules: {
    label: |md
      **Sim-Trace Token Grammar:**
      - `R` : Memory Read Op
      - `W` : Memory Write Op
      - `0x` : Hexadecimal base 16
      
      **Hardware Constants:**
      - Page Size = 4096 Bytes
      - Alignment = 4 Byte Recommended
    |
  }
}

# Connections
trace_file -> parser.parse_line: "I/O Stream" {
  style.stroke-width: 2
}
parser.parse_line -> parser.skip_comment: "Analyze"
parser.skip_comment -> parser.skip_blank: "Process"
parser.skip_blank -> parser.extract_op: "Tokenize"
parser.extract_op -> parser.extract_addr: "Extract"
parser.extract_addr -> parsed_output: "Map to Struct"

parsed_output -> entries: "Append to List" {
  style.stroke: "#388E3C"
}

entries.entry3 -> decomposition: "Input VA: 0x1400" {
  style.stroke: "#F57C00"
  style.stroke-width: 3
  style.animated: true
}

parser -> stats: "Emit Metrics" {
  style.stroke-dash: 5
}

# Glob styling for consistency
entries.** {
  style.font: mono
}
parser.** {
  style.font: mono
}

***.style.border-radius: 4 
(*** -> ***)[*]: {
  style.font-size: 14
}