vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F97316"
    stats: "#10B981"
    fault: "#EF4444"
  }
}
title: |md
  # Statistics Collection Points
  ## Where Each Counter is Incremented in the Translation Pipeline
| {near: top-center}
direction: right
# Entry point
entry: "translate_address()" {
  shape: rectangle
  style.fill: ${colors.header}
  style.font-color: white
  style.bold: true
}
# Counter: total_accesses
counter_accesses: "total_accesses++" {
  shape: rectangle
  style.fill: ${colors.stats}
  style.font-color: white
  style.bold: true
  near: top-center
}
entry -> counter_accesses: "1. Always" {
  style.stroke: ${colors.stats}
  style.stroke-width: 3
}
# Address decomposition
decompose: "Extract VPN & Offset\nvpn = va >> 12\noffset = va & 0xFFF" {
  shape: rectangle
  style.fill: ${colors.data}
  style.font-color: white
}
counter_accesses -> decompose
# PTE lookup
pte_lookup: "Get PTE\npte = page_table[vpn]" {
  shape: rectangle
  style.fill: ${colors.data}
  style.font-color: white
}
decompose -> pte_lookup
# Valid bit check - page fault path
valid_check: "Valid Bit Check" {
  shape: diamond
  style.fill: "#FCD34D"
  style.font-color: black
}
pte_lookup -> valid_check
# Counter: page_faults
counter_page_faults: "page_faults++" {
  shape: rectangle
  style.fill: ${colors.fault}
  style.font-color: white
  style.bold: true
}
valid_check -> counter_page_faults: "valid == false" {
  style.stroke: ${colors.fault}
  style.stroke-width: 3
  label: "Page Fault Path"
}
# Demand paging handler
demand_paging: "handle_page_fault()\n• allocate_frame()\n• pte->valid = true\n• pte->pfn = pfn" {
  shape: rectangle
  style.fill: ${colors.data}
  style.font-color: white
}
counter_page_faults -> demand_paging
# Permission check
permission_check: "Permission Check" {
  shape: diamond
  style.fill: "#FCD34D"
  style.font-color: black
}
valid_check -> permission_check: "valid == true" {
  style.stroke: ${colors.stats}
}
demand_paging -> permission_check: "retry"
# Counter: protection_faults
counter_protection: "protection_faults++" {
  shape: rectangle
  style.fill: ${colors.fault}
  style.font-color: white
  style.bold: true
}
permission_check -> counter_protection: "permission denied" {
  style.stroke: ${colors.fault}
  style.stroke-width: 3
  label: "Protection Fault"
}
# Protection fault result
fault_result: "Return\nTRANS_PROTECTION_FAULT" {
  shape: rectangle
  style.fill: "#6B7280"
  style.font-color: white
}
counter_protection -> fault_result
# Access bit update
access_bits: "Update Access Bits\npte->referenced = true\nif (is_write):\n  pte->dirty = true" {
  shape: rectangle
  style.fill: ${colors.data}
  style.font-color: white
}
permission_check -> access_bits: "permissions OK"
# Compose physical address
compose: "Compose PA\npa = (pfn << 12) | offset" {
  shape: rectangle
  style.fill: ${colors.data}
  style.font-color: white
}
access_bits -> compose
# Success result
success_result: "Return\nTRANS_OK + pa" {
  shape: rectangle
  style.fill: ${colors.stats}
  style.font-color: white
  style.bold: true
}
compose -> success_result
# Legend
legend: {
  near: bottom-right
  label: "Legend"
  always: "total_accesses++" {
    shape: rectangle
    style.fill: ${colors.stats}
    style.font-color: white
  }
  fault_counter: "page_faults++\nprotection_faults++" {
    shape: rectangle
    style.fill: ${colors.fault}
    style.font-color: white
  }
  flow: "Normal Flow" {
    shape: rectangle
    style.fill: ${colors.data}
    style.font-color: white
  }
  decision: "Decision Point" {
    shape: diamond
    style.fill: "#FCD34D"
  }
}
# Statistics table
stats_table: {
  near: bottom-left
  shape: sql_table
  stats: "Statistics Structure (stats_t)" {
    shape: rectangle
    style.fill: ${colors.header}
    style.font-color: white
    style.bold: true
  }
  total: "total_accesses: uint64_t" {constraint: "Every translation entry"}
  page: "page_faults: uint64_t" {constraint: "Valid bit = 0"}
  prot: "protection_faults: uint64_t" {constraint: "Permission denied"}
  frames: "frames_used: uint64_t" {constraint: "On frame allocation"}
}
# Code reference
code_ref: |md
  c
  // Milestone 1: translate_address()
  trans_output_t translate_address(
      simulator_t *sim,
      uint32_t va,
      bool is_write
  ) {
      // 1. ALWAYS increment total_accesses
      sim->stats.total_accesses++;
      uint32_t vpn = va >> PAGE_SHIFT;
      pte_t *pte = &sim->page_table[vpn];
      // 2. Check valid bit
      if (!pte->valid) {
          sim->stats.page_faults++;  // ← HERE
          // ... handle fault ...
      }
      // 3. Check permissions
      if (is_write && !pte->writable) {
          sim->stats.protection_faults++;  // ← HERE
          return TRANS_PROTECTION_FAULT;
      }
      // ...
  }
  
| {near: bottom-center}