direction: right
layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# GLOBAL STYLING & CLASSES
# -----------------------------------------------------------------------------
classes: {
  memory_header: {
    style: {
      fill: "#6A5ACD"
      font-color: white
      bold: true
    }
  }
  vpn_segment: {
    style: {
      fill: "#B8D4E8"
      stroke: "#4A90D9"
      stroke-width: 2
    }
  }
  offset_segment: {
    style: {
      fill: "#E8D4B8"
      stroke: "#D9A04A"
      stroke-width: 2
    }
  }
  pfn_segment: {
    style: {
      fill: "#90EE90"
      stroke: "#228B22"
      stroke-width: 2
    }
  }
  logic_block: {
    style: {
      fill: "#F8F9FA"
      stroke: "#CCCCCC"
      font-size: 14
      border-radius: 4
    }
  }
}

# -----------------------------------------------------------------------------
# DIAGRAM CONTENT
# -----------------------------------------------------------------------------

title: |md
  # MMU: Virtual to Physical Address Translation
  **Scenario**: Translating VA `0x00001234` (Page Size: 4KB)
|
title.near: top-center

# 1. Virtual Address Decomposition
va_container: "Virtual Address (VA)" {
  style: {
    fill: "#FFFFFF"
    stroke: "#333333"
    stroke-width: 3
    double-border: true
  }

  va_val: "0x00001234" {
    shape: text
    style.font: mono
    style.font-size: 24
    style.bold: true
  }

  bits_layout: {
    shape: sql_table
    "Bits 31..12 (VPN)": "0x00001" { class: vpn_segment }
    "Bits 11..0 (Offset)": "0x234" { class: offset_segment }
  }

  extraction_logic: |md
    ### Extraction Logic
    - **VPN** = `VA >> 12` (Shift out offset)
    - **Offset** = `VA & 0xFFF` (Mask lower 12 bits)
  |
  extraction_logic.class: logic_block
}

# 2. Page Table Lookup
page_table_lookup: "MMU Page Table Lookup" {
  style: {
    fill: "#F0F4F8"
    stroke: "#4A90D9"
    stroke-width: 3
    shadow: true
  }

  lookup_op: "INDEX = VPN (0x1)" {
    shape: text
    style.font: mono
    style.bold: true
    style.font-color: "#4A90D9"
  }

  pte_entry: "Page Table Entry (PTE)" {
    shape: sql_table
    "PFN (Physical Frame)": "0x0007F" { class: pfn_segment }
    "V (Valid)": "1" { style.fill: "#90EE90" }
    "R/W (Permissions)": "READ/WRITE"
    "U (User Mode)": "0"
    "D (Dirty Bit)": "0"
  }

  pte_logic: |cpp
    // MMU Hardware Traversal
    PTE* entry = &PAGE_TABLE_BASE[vpn];
    if (!entry->valid) {
        raise_exception(PAGE_FAULT);
    }
    physical_frame = entry->pfn;
  |
  pte_logic.class: logic_block
}

# 3. Physical Address Composition
pa_container: "Physical Address (PA)" {
  style: {
    fill: "#E8F4E8"
    stroke: "#228B22"
    stroke-width: 3
    double-border: true
  }

  composition_table: {
    shape: sql_table
    "PFN Base (PFN << 12)": "0x0007F000" { class: pfn_segment }
    "Page Offset": "0x234" { class: offset_segment }
    "Final PA Result": "0x0007F234" { 
      style: {
        bold: true
        fill: "#98FB98"
        stroke-width: 3
      }
    }
  }

  pa_formula: ||md
    ### Address Assembly
    1. **Base**: PFN `0x7F` shifted left 12 bits
    2. **Or**: Bitwise OR with Offset `0x234`
    `PA = (0x7F << 12) | 0x234 = 0x7F234`
  ||
  pa_formula.class: logic_block
}

# -----------------------------------------------------------------------------
# CONNECTIONS (SEQUENTIAL FLOW)
# -----------------------------------------------------------------------------

# 1. VPN to Lookup
va_container.bits_layout."Bits 31..12 (VPN)" -> page_table_lookup.lookup_op: "1. Index into RAM" {
  style: {
    stroke: "#4A90D9"
    stroke-width: 3
    animated: true
  }
}

# 2. PFN Extraction to PA assembly
page_table_lookup.pte_entry."PFN (Physical Frame)" -> pa_container.composition_table."PFN Base (PFN << 12)": "2. Extract PFN" {
  style: {
    stroke: "#228B22"
    stroke-width: 3
  }
}

# 3. Offset pass-through (The Offset never changes in translation)
va_container.bits_layout."Bits 11..0 (Offset)" -> pa_container.composition_table."Page Offset": "3. Pass-through" {
  style: {
    stroke: "#D9A04A"
    stroke-dash: 5
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# SUPPLEMENTARY DATA & LEGEND
# -----------------------------------------------------------------------------

memory_ref: |md
  ### MMU Translation Specs
  - **Architecture**: x86-32 (Non-PAE)
  - **Page Size**: 4096 Bytes (4KB)
  - **VPN Bits**: 20 (1 Million Pages)
  - **Offset Bits**: 12 (Internal Address)
|
memory_ref.near: bottom-left
memory_ref.style: {
  fill: "#FAFAFA"
  stroke: "#CCCCCC"
  stroke-dash: 2
}

legend: {
  near: bottom-right
  style: {
    fill: "#FFFFFF"
    stroke: "#EEEEEE"
    shadow: true
  }
  
  l_vpn: "Virtual Page Number (VPN)" { class: vpn_segment }
  l_pfn: "Physical Frame Number (PFN)" { class: pfn_segment }
  l_off: "Byte Offset (12-bit)" { class: offset_segment }
}