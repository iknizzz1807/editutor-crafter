vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  # Technical Design Palette
  colors: {
    bg-unset: "#F8FAFC"
    bg-set: "#FEF2F2"
    stroke-unset: "#64748B"
    stroke-set: "#EF4444"
    text-main: "#1E293B"
    action-write: "#B91C1C"
    action-read: "#0369A1"
  }
}

direction: right

# -----------------------------------------------------------------------------
# GLOBAL ANNOTATIONS
# -----------------------------------------------------------------------------
title: |md
  # MMU Bit State Transitions
  **Dirty (D) and Referenced (R) Bit Logic**
  *Intel x86-64 / ARMv8 translation table compatibility*
| {
  near: top-left
  shape: text
}

# -----------------------------------------------------------------------------
# STATE DEFINITIONS
# -----------------------------------------------------------------------------
states: {
  UNSET: {
    label: "BIT UNSET\n(Logical 0)"
    shape: circle
    style: {
      fill: "${colors.bg-unset}"
      stroke: "${colors.stroke-unset}"
      stroke-width: 4
      font-size: 18
      bold: true
      font-color: "${colors.text-main}"
    }
    tooltip: "Bit is cleared. No access of targeted type has occurred since last OS reset."
  }

  SET: {
    label: "BIT SET\n(Logical 1)"
    shape: circle
    style: {
      fill: "${colors.bg-set}"
      stroke: "${colors.stroke-set}"
      stroke-width: 4
      font-size: 18
      bold: true
      font-color: "${colors.text-main}"
      double-border: true
    }
    tooltip: "Sticky bit. Remains 1 until explicitly cleared by the Operating System."
  }
}

# -----------------------------------------------------------------------------
# ENTRY POINT
# -----------------------------------------------------------------------------
entry: "" {
  shape: circle
  width: 15
  height: 15
  style: {
    fill: "${colors.text-main}"
  }
}
entry -> states.UNSET: "OS Page Allocation / TLB Flush" {
  style: {
    stroke-width: 2
    stroke: "${colors.stroke-unset}"
    font-size: 11
    italic: true
  }
}

# -----------------------------------------------------------------------------
# TRANSITION LOGIC
# -----------------------------------------------------------------------------

# Primary Transition: UNSET -> SET
states.UNSET -> states.SET: "WRITE ACCESS" {
  label: "WRITE ACCESS\n(Trigger: D=1, R=1)"
  style: {
    stroke: "${colors.action-write}"
    stroke-width: 5
    bold: true
    font-color: "${colors.action-write}"
    font-size: 14
  }
  target-arrowhead: {
    shape: triangle
    style.filled: true
  }
}

states.UNSET -> states.SET: "READ ACCESS" {
  label: "READ ACCESS\n(Trigger: R=1 only)"
  style: {
    stroke: "${colors.action-read}"
    stroke-width: 3
    stroke-dash: 4
    font-color: "${colors.action-read}"
    font-size: 14
  }
}

# Persistence / Self-Loops
states.UNSET -> states.UNSET: "READ ACCESS\n(D-Bit: No Change)" {
  style: {
    stroke: "${colors.stroke-unset}"
    stroke-width: 1
    font-size: 11
    font-color: "${colors.stroke-unset}"
  }
}

states.SET -> states.SET: "ANY ACCESS\n(Sticky Bit Policy)" {
  style: {
    stroke: "${colors.stroke-set}"
    stroke-width: 2
    font-size: 11
    font-color: "${colors.stroke-set}"
  }
}

# Illegal / OS Only Transition
states.SET -> states.UNSET: "HARDWARE RESET (ILLEGAL)" {
  style: {
    stroke: "#EF4444"
    stroke-dash: 2
    stroke-width: 2
    font-color: "#EF4444"
    font-size: 10
  }
  source-arrowhead: {
    shape: cross
  }
}

# -----------------------------------------------------------------------------
# SPECIFICATION TABLES & LEGENDS
# -----------------------------------------------------------------------------
logic_specs: {
  near: bottom-center
  
  dirty_logic: |md
    ### Dirty (D) Bit
    - **Trigger**: Set on **Write** operations.
    - **Persistence**: Hardware only sets; OS must clear.
    - **Purpose**: Indicates page must be flushed to disk before eviction.
  | {
    shape: rectangle
    style: {
      fill: "#FFF1F2"
      stroke: "#FECACA"
      border-radius: 4
    }
  }

  referenced_logic: |md
    ### Referenced (R) Bit
    - **Trigger**: Set on **Read OR Write** operations.
    - **Persistence**: Hardware only sets; OS clears during clock sweep.
    - **Purpose**: Used by LRU algorithms for eviction decisions.
  | {
    shape: rectangle
    style: {
      fill: "#F0F9FF"
      stroke: "#BAE6FD"
      border-radius: 4
    }
  }
}

# Metadata Footer
footer: |md
  **Legend**:
  - <span style="color:#B91C1C"><b>Red Bold</b></span>: Destructive/State-Changing (Dirtying)
  - <span style="color:#0369A1"><b>Blue Dashed</b></span>: Access-only (Referencing)
  - <span style="color:#64748B"><b>Gray</b></span>: Passive / No Bit Change
| {
  near: bottom-left
  shape: text
}