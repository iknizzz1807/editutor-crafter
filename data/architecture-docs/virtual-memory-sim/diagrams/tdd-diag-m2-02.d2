layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

title: "VIRTUAL MEMORY SIMULATOR: SYSTEM ARCHITECTURE & DATA LAYOUT" {
  shape: text
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

direction: right

classes: {
  container: {
    style: {
      fill: "#F8F9FA"
      stroke: "#DEE2E6"
      stroke-width: 3
      border-radius: 8
    }
  }
  component: {
    style: {
      fill: "#FFFFFF"
      stroke: "#6C757D"
      stroke-width: 2
      shadow: true
    }
  }
  hardware: {
    style: {
      fill: "#FFF3E0"
      stroke: "#F57C00"
      stroke-width: 2
    }
  }
  software: {
    style: {
      fill: "#E8F5E9"
      stroke: "#388E3C"
      stroke-width: 2
    }
  }
  flow_hit: {
    style: {
      stroke: "#4CAF50"
      stroke-width: 3
      animated: true
    }
  }
  flow_miss: {
    style: {
      stroke: "#F44336"
      stroke-width: 3
      stroke-dash: 5
    }
  }
}

CPU: {
  class: hardware
  label: "Central Processing Unit (CPU)"
  
  MMU: Memory Management Unit {
    class: component
    label: "MMU (HW Logic)"
    tooltip: "Handles address translation and TLB lookup"
  }
  
  Registers: {
    class: component
    label: "Control Registers"
    CR3: "CR3: Page Directory Base (Phys Addr)" {
      style.font: mono
    }
    ASID: "ASID: Address Space ID"
  }
}

Memory_Subsystem: {
  class: container
  label: "Memory Hierarchy & Structures"
  
  TLB: {
    class: hardware
    label: "Translation Lookaside Buffer (TLB)"
    
    Entry_Structure: {
      shape: sql_table
      vpn: "VPN (20 bits)" {constraint: "Key (Tag)"}
      asid: "ASID (8 bits)" {constraint: "Key (Tag)"}
      pfn: "PFN (20 bits)" {constraint: "Value (Data)"}
      flags: "V | W | U | D | A" {constraint: "Control"}
      lru_bits: "LRU Priority"
    }
    
    Stats: {
      capacity: "32-64 Entries"
      associativity: "Full Associativity"
      lookup_time: "< 1 cycle"
    }
  }

  Page_Tables: {
    class: software
    label: "Multi-Level Page Tables (Radix Tree)"
    
    PDE: "Page Directory (L1)" {
      shape: sql_table
      pde_0: "PT_Addr_0 | P | W | U"
      pde_1: "PT_Addr_1 | P | W | U"
      pde_n: "PT_Addr_1023 | P | W | U"
      note: "Size: 4096B (1024 entries)"
    }
    
    PTE: "Page Table (L2)" {
      shape: sql_table
      pte_0: "PFN_0 | P | W | U | D | A"
      pte_1: "PFN_1 | P | W | U | D | A"
      pte_n: "PFN_1023 | P | W | U | D | A"
      note: "Size: 4096B (1024 entries)"
    }
  }
}

Physical_Memory: {
  class: hardware
  label: "RAM (Physical Address Space)"
  
  Frame_Pool: {
    shape: cylinder
    label: "Physical Frames [0..N]"
    f0: "Frame 0 (Reserved)"
    f1: "Frame 1 (Page Table)"
    f2: "Frame 2 (User Data)"
    fn: "Frame N (User Data)"
    style.fill: "#BBDEFB"
  }
  
  Metadata: "Frame Database" {
    free_list: "Free Frame Stack"
    rev_map: "PTE Inverse Map (for Eviction)"
    ref_counts: "Share Counts"
  }
}

Swap_System: {
  class: hardware
  label: "Backing Store (Disk/Swap)"
  
  Slots: {
    shape: sql_table
    slot_0: "Process_ID | VPN | Data_Blob"
    slot_1: "Process_ID | VPN | Data_Blob"
    slot_n: "Process_ID | VPN | Data_Blob"
  }
  
  Manager: "Swap Bitmap" {
    usage: "Total Slots Occupied"
    io_queue: "Pending Disk I/O"
  }
}

OS_Kernel: {
  class: software
  label: "Kernel Memory Manager"
  
  Page_Fault_Handler: "PF Handler" {
    style.fill: "#FFEB3B"
  }
  
  Policy_Engine: {
    label: "Eviction Policies"
    FIFO: "FIFO Queue"
    LRU: "LRU (Last Used Timestamps)"
    Clock: "Clock (Second Chance Bit)"
  }
}

Statistics: {
  label: "Real-time Metrics"
  style.fill: "#ECEFF1"
  counters: |md
    ### Simulation Counters
    - **TLB_Hits**: uint64
    - **TLB_Misses**: uint64
    - **Page_Faults**: uint64
    - **Disk_IO_Ops**: uint64
    - **Evictions**: uint64
  |
}

# --- PROCESS FLOWS ---

CPU.MMU -> Memory_Subsystem.TLB: "1. Virtual Address (VPN) Lookup" {
  class: flow_hit
}

Memory_Subsystem.TLB -> Memory_Subsystem.Page_Tables.PDE: "2. [MISS] MMU Hardware Walk" {
  class: flow_miss
}

Memory_Subsystem.Page_Tables.PDE -> Memory_Subsystem.Page_Tables.PTE: "3. Resolve L2 Table" {
  style.stroke: "#F44336"
}

Memory_Subsystem.Page_Tables.PTE -> OS_Kernel.Page_Fault_Handler: "4. [FAULT] Present Bit == 0" {
  style.stroke: "#D32F2F"
  style.stroke-width: 4
}

OS_Kernel.Page_Fault_Handler -> Swap_System.Slots: "5. Retrieve Page from Disk" {
  style.animated: true
}

OS_Kernel.Policy_Engine -> Physical_Memory.Frame_Pool: "Selection of Victim Frame" {
  style.stroke-dash: 3
}

Physical_Memory.Frame_Pool -> Swap_System.Slots: "Evict Dirty Page" {
  style.stroke: "#7B1FA2"
}

Memory_Subsystem.TLB -> Physical_Memory.Frame_Pool: "6. [HIT] Direct Phys Access" {
  style.stroke: "#4CAF50"
  style.stroke-width: 4
}

CPU.Registers.CR3 -> Memory_Subsystem.Page_Tables.PDE: "Set Paging Context" {
  style.stroke: "#607D8B"
  style.stroke-dash: 3
}

# --- DOCUMENTATION ANNOTATIONS ---

Summary_Box: {
  near: bottom-center
  label: |md
    ## Simulator Translation Pipeline
    1. **VA Generation**: CPU generates 32-bit Virtual Address.
    2. **TLB Search**: MMU checks TLB using `VPN` + `ASID`. 
       - *Hit*: Return `PFN` immediately.
       - *Miss*: Proceed to Page Table Walk.
    3. **Radix Walk**: CR3 points to L1 Directory. Use bits [31-22] for PDE, [21-12] for PTE.
    4. **Fault Logic**: If `Present` bit is 0, trap to Kernel.
    5. **Swap I/O**: Kernel fetches data from Disk, updates `PTE`, and refills `TLB`.
    6. **Final Access**: Concatenate `PFN` with `Offset` [11-0] to access RAM.
  |
}