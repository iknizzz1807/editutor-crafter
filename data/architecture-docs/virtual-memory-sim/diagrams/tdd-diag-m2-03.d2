vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    hit: "#4CAF50"
    miss: "#F44336"
    check: "#2196F3"
    entry: "#FF9800"
    text_dim: "#666666"
  }
}

direction: down

title: |md
  # TLB Lookup Decision Tree
  **Logic Flow:** Fully-Associative Search: O(capacity) Linear Scan
| {
  near: top-center
  shape: text
}

# Core Logic Implementation
tlb_algorithm: {
  # Entry point
  start: {
    shape: circle
    style.fill: "${colors.check}"
    label: "TLB\nLookup"
  }

  # Input Specification
  input_box: {
    label: |md
      ### Input Vector
      - `tlb_state *tlb` : Internal TLB structure
      - `vpn_t vpn` : Target Virtual Page Number
      - `asid_t active_asid` : current_asid context
    |
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "${colors.check}"
  }

  # Loop initialization
  loop_init: {
    label: |md
      ### Initialize Iterator
      c
      tlb->clock++;
      for (int i = 0; i < capacity; i++)
      
    |
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "${colors.entry}"
  }

  # Pointer Arithmetic
  entry_ptr: {
    label: |md
      **Fetch Reference**
      `entry = &tlb->entries[i]`
    |
    shape: rectangle
    style.fill: "#F5F5F5"
  }

  # Decision 1: Valid bit
  valid_check: {
    label: "entry->valid\n== true ?"
    shape: diamond
    style.fill: "${colors.check}"
  }

  # Decision 2: VPN match
  vpn_check: {
    label: "entry->vpn\n== vpn ?"
    shape: diamond
    style.fill: "${colors.check}"
  }

  # Decision 3: ASID match
  asid_check: {
    label: "entry->asid\n== asid ?"
    shape: diamond
    style.fill: "${colors.check}"
  }

  # HIT path
  hit_box: {
    label: |md
      ## TLB HIT ✓
      - `entry->last_used = tlb->clock`
      - `entry->referenced = true`
      - `tlb->stats.hits++`
      - **RETURN** `entry`
    |
    shape: rectangle
    style.fill: "${colors.hit}"
    style.stroke: "#2E7D32"
    style.bold: true
  }

  # Continue loop
  continue_loop: {
    label: "i++\nScan Next"
    shape: rectangle
    style.fill: "#E0E0E0"
  }

  # Check if loop done
  loop_done: {
    label: "i < capacity ?"
    shape: diamond
    style.fill: "#9E9E9E"
  }

  # MISS path
  miss_box: {
    label: |md
      ## TLB MISS ✗
      - `tlb->stats.misses++`
      - **RETURN** `NULL` (Invoke PTW)
    |
    shape: rectangle
    style.fill: "${colors.miss}"
    style.stroke: "#C62828"
    style.bold: true
  }

  # Output summary
  output_box: {
    label: |md
      ### Handler Resolution
      - **On HIT:** Extract PFN from entry
      - **On MISS:** Initiate Hardware Page Table Walk
    |
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.double-border: true
  }

  # Routing Logic
  start -> input_box
  input_box -> loop_init
  loop_init -> entry_ptr
  entry_ptr -> valid_check

  valid_check -> vpn_check: "Yes"
  valid_check -> continue_loop: "No (Invalid)" {
    style.stroke: "${colors.miss}"
  }

  vpn_check -> asid_check: "Yes"
  vpn_check -> continue_loop: "No (Mismatch)" {
    style.stroke: "${colors.miss}"
  }

  asid_check -> hit_box: "Match ✓" {
    style.stroke: "${colors.hit}"
    style.stroke-width: 2
  }
  asid_check -> continue_loop: "No (ASID)" {
    style.stroke: "${colors.miss}"
  }

  continue_loop -> loop_done
  loop_done -> entry_ptr: "Yes"
  loop_done -> miss_box: "No (Scanned All)"

  hit_box -> output_box
  miss_box -> output_box
}

# Annotations (Fixed: Using connections instead of near:object for ELK)
note_1: |md
  **Bit 0: Valid**
  Entry must be warm and
  mapped to valid memory.
| { shape: text; style.font-size: 11; style.font-color: "${colors.text_dim}" }

note_2: |md
  **The Tag**
  Virtual Page Number is
  the primary search key.
| { shape: text; style.font-size: 11; style.font-color: "${colors.text_dim}" }

note_3: |md
  **Isolation**
  ASID match avoids TLB
  flushes on context switch.
| { shape: text; style.font-size: 11; style.font-color: "${colors.text_dim}" }

note_1 -- tlb_algorithm.valid_check: { style.stroke-dash: 3 }
note_2 -- tlb_algorithm.vpn_check: { style.stroke-dash: 3 }
note_3 -- tlb_algorithm.asid_check: { style.stroke-dash: 3 }

# Complexity Metadata
complexity_stats: |md
  ### Search Complexity
  - **Temporal:** O(N) Linear Scan
  - **Spatial:** O(1) extra space
  - **Note:** Real CPUs use CAM (Content Addressable Memory)
    to perform these checks in parallel (O(1)).
| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#F9F9F9"
    stroke-dash: 1
    font-size: 11
  }
}