vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Context Switch with ASID Tagging
| {near: top-center}
direction: right
legend: {
  near: bottom-right
  style.fill: "#f5f5f5"
  style.stroke: "#cccccc"
  label: |md
    **Legend**
    - 🔵 Old Process (ASID 1)
    - 🟢 New Process (ASID 2)
    - ⬜ Hardware Register
  |
}
row1: {
  grid-columns: 4
  grid-gap: 0
  time_t0: |md
    **T0: Before Switch**
  | {class: header}
  blank1: "" {style.fill: transparent; style.stroke: transparent}
  blank2: "" {style.fill: transparent; style.stroke: transparent}
  blank3: "" {style.fill: transparent; style.stroke: transparent}
}
row2: {
  grid-columns: 4
  grid-gap: 10
  old_proc: "Old Process\nASID = 1\n(Running)" {
    shape: rectangle
    style.fill: "#DBEEF3"
    style.stroke: "#2196F3"
    style.bold: true
  }
  cr3_before: "CR3 Register\nvalue = 0x1000" {
    shape: hexagon
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
  }
  tlb_before: "TLB (16 entries)\n\nEntry 0: VPN=0x10, ASID=1 ✓\nEntry 1: VPN=0x20, ASID=1 ✓\nEntry 2: VPN=0x05, ASID=1 ✓\nEntry 3: VPN=0x30, ASID=2 ✓\n..." {
    shape: cylinder
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  new_proc: "New Process\nASID = 2\n(Ready)" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-dash: 5
  }
}
arrow1: {
  grid-columns: 1
  grid-gap: 0
  step1: |md
    **Step 1: Save Old ASID**
    `saved_asid ← current_asid`
  | {style.fill: "#FFF3E0"}
}
row3: {
  grid-columns: 4
  grid-gap: 10
  old_proc_saved: "Old Process\nASID = 1\n(Saved)" {
    shape: rectangle
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-dash: 3
  }
  cr3_step1: "CR3 Register\nvalue = 0x1000\n(saved)" {
    shape: hexagon
    style.fill: "#FFF9C4"
    style.stroke: "#F9A825"
    style.stroke-dash: 3
  }
  tlb_step1: "TLB (PRESERVED)\n\nEntry 0: VPN=0x10, ASID=1 ✓\nEntry 1: VPN=0x20, ASID=1 ✓\nEntry 2: VPN=0x05, ASID=1 ✓\nEntry 3: VPN=0x30, ASID=2 ✓\n..." {
    shape: cylinder
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  new_proc_step1: "New Process\nASID = 2\n(Ready)" {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-dash: 5
  }
}
arrow2: {
  grid-columns: 1
  grid-gap: 0
  step2: |md
    **Step 2: Load New ASID → CR3**
    `current_asid ← 2`
    `CR3 ← new_process.page_dir`
  | {style.fill: "#E8F5E9"}
}
row4: {
  grid-columns: 4
  grid-gap: 10
  old_proc_after: "Old Process\nASID = 1\n(Inactive)" {
    shape: rectangle
    style.fill: "#ECEFF1"
    style.stroke: "#90A4AE"
    style.stroke-dash: 5
  }
  cr3_after: "CR3 Register\nvalue = 0x2000\n(new)" {
    shape: hexagon
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.bold: true
  }
  tlb_after: "TLB (NO FLUSH!)\n\nEntry 0: VPN=0x10, ASID=1 🔒\nEntry 1: VPN=0x20, ASID=1 🔒\nEntry 2: VPN=0x05, ASID=1 🔒\nEntry 3: VPN=0x30, ASID=2 ✓ ACTIVE\n..." {
    shape: cylinder
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.bold: true
  }
  new_proc_active: "New Process\nASID = 2\n(Running)" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
    style.bold: true
  }
}
note_box: |md
  **Key Insight:** With ASID tagging, TLB entries from the old process
  **remain in the TLB** but are marked with ASID=1. When the new process
  (ASID=2) performs lookups, entries with ASID=1 won't match → treated as misses.
  **Benefit:** No TLB flush required → instant context switch!
  **Without ASIDs:** Full TLB flush would clear all entries → cold TLB → performance penalty.
| {near: bottom-center; style.fill: "#FFF8E1"; style.stroke: "#FFB300"}
old_proc -> cr3_before: "owns"
cr3_before -> tlb_before: "indexes"
new_proc_step1 -> cr3_after: "switches to" {style.stroke: "#4CAF50"; style.bold: true; style.animated: true}
cr3_after -> tlb_after: "lookups use\nASID=2 filter" {style.stroke: "#4CAF50"}
classes: {
  header: {
    style.fill: "#E3F2FD"
    style.underline: true
    style.bold: true
  }
}