vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # TLB Invalidation Flow
  Write-back → Invalidate → Statistics Update
| {near: top-center}
direction: right
# Input state
input: {
  label: "TLB Entry\n(Before)"
  shape: rectangle
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  vpn_label: "VPN: 0x0010"
  pfn_label: "PFN: 0x42"
  asid_label: "ASID: 0x01"
  valid_true: "valid: TRUE"
  dirty_true: "dirty: TRUE"
  ref_true: "referenced: TRUE"
}
# Step 1: Write Back
step1_container: {
  label: "Step 1: Write Back"
  style.fill: "#FFF9E6"
  style.stroke: "#D4A017"
  check_dirty: {
    label: "Check\nentry->dirty"
    shape: diamond
    style.fill: "#FFE680"
  }
  check_ref: {
    label: "Check\nentry->referenced"
    shape: diamond
    style.fill: "#FFE680"
  }
  write_dirty: {
    label: |md
      `page_table[vpn].dirty = true`
    |
    shape: rectangle
    style.fill: "#E6F3FF"
  }
  write_ref: {
    label: |md
      `page_table[vpn].referenced = true`
    |
    shape: rectangle
    style.fill: "#E6F3FF"
  }
  check_dirty -> write_dirty: "true"
  check_dirty -> check_ref: "false"
  check_ref -> write_ref: "true"
  check_ref -> skip: "false"
  skip: {
    label: "Skip"
    shape: circle
    style.fill: "#F0F0F0"
  }
}
# Step 2: Invalidate
step2_container: {
  label: "Step 2: Invalidate Entry"
  style.fill: "#FFE6E6"
  style.stroke: "#CC0000"
  set_invalid: {
    label: |md
      `entry->valid = false`
    |
    shape: rectangle
    style.fill: "#FFCCCC"
    style.bold: true
    style.font-color: "#990000"
  }
  clear_fields: {
    label: |md
      Clear cached data:
      - vpn: undefined
      - pfn: undefined
      - dirty: false
      - referenced: false
    |
    shape: rectangle
    style.fill: "#FFE6E6"
  }
  set_invalid -> clear_fields
}
# Step 3: Update Stats
step3_container: {
  label: "Step 3: Update Statistics"
  style.fill: "#E6FFE6"
  style.stroke: "#00AA00"
  increment_stats: {
    label: |md
      `tlb->stats.partial_flushes++`
      `tlb->stats.dirty_writebacks++` (if dirty)
    |
    shape: rectangle
    style.fill: "#CCFFCC"
  }
}
# Output state
output: {
  label: "TLB Entry\n(After)"
  shape: rectangle
  style.fill: "#F0F0F0"
  style.stroke: "#999999"
  style.stroke-dash: 3
  valid_false: "valid: FALSE"
  undefined: "other fields: undefined"
}
# Connections
input -> step1_container: "Begin\nInvalidation"
step1_container -> step2_container: "Bits\nPropagated"
step2_container -> step3_container: "Entry\nInvalidated"
step3_container -> output: "Complete"
# Page Table side effect
page_table: {
  label: "Page Table\n(Side Effect)"
  shape: cylinder
  style.fill: "#E6E6FF"
  pte_updated: {
    label: "PTE updated:\ndirty=true\nreferenced=true"
    shape: rectangle
    style.fill: "#CCCCFF"
  }
}
step1_container.write_dirty -> page_table.pte_updated: "propagates"
step1_container.write_ref -> page_table.pte_updated: "propagates"
# Legend
legend: {
  near: bottom-right
  style.fill: transparent
  legend_title: "Legend" {shape: text; style.bold: true}
  purple_box: {
    label: "Check/Decision"
    shape: diamond
    style.fill: "#FFE680"
  }
  blue_box: {
    label: "Write Operation"
    shape: rectangle
    style.fill: "#E6F3FF"
  }
  red_box: {
    label: "Invalidation"
    shape: rectangle
    style.fill: "#FFCCCC"
  }
  green_box: {
    label: "Statistics"
    shape: rectangle
    style.fill: "#CCFFCC"
  }
}
# Annotation
annotation: |md
  **Critical Invariant**: Write-back MUST occur  
  BEFORE `valid` is set to false.  
  Failure → Lost dirty/referenced metadata.
| {near: bottom-center}