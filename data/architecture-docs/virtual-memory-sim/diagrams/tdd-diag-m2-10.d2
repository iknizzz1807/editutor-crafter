direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    flow: "#10B981"
    miss: "#EF4444"
    hardware: "#F59E0B"
    background: "#F8FAFC"
    border: "#CBD6E1"
    padding: "#F1F5F9"
  }
}

title: {
  shape: text
  label: |md
    # Translation Pipeline with TLB (MMU Logic)
    **Objective:** Implementation of Virtual-to-Physical Address Translation
  |
  near: top-center
  style: {
    font-size: 28
    bold: true
  }
}

# -----------------------------------------------------------------------------
# 1. ADDRESS COMPONENTS
# -----------------------------------------------------------------------------

va_input: {
  label: ||md
    **Virtual Address (VA)**
    `0x00401234`
    | Bits | Field | Value |
    | :--- | :--- | :--- |
    | 31:12 | VPN | `0x00401` |
    | 11:0 | Offset | `0x234` |
  ||
  style: {
    fill: "${colors.data}"
    stroke: "${colors.border}"
    font-color: white
    border-radius: 8
  }
}

extract_logic: {
  label: |md
    **Step 1: Bitwise Extraction**
    c
    uint32_t vpn = (va >> 12) & 0xFFFFF;
    uint32_t off = va & 0xFFF;
    
  |
  style: {
    fill: "${colors.header}"
    stroke: "${colors.border}"
    font-color: white
    border-radius: 4
  }
}

# -----------------------------------------------------------------------------
# 2. HARDWARE: TLB
# -----------------------------------------------------------------------------

tlb_subsystem: {
  label: "Hardware Cache: TLB"
  
  tlb_storage: {
    shape: sql_table
    label: "TLB Content (Fully Associative)"
    "Entry 0": "VPN: 0x00401 | PFN: 0x0007F {constraint: HIT}"
    "Entry 1": "VPN: 0x00ABC | PFN: 0x00012 {constraint: VALID}"
    "Entry N": "... 32 Entries Total ..."
  }

  lookup_logic: {
    shape: diamond
    label: "TLB Lookup\n(Parallel Search)"
    style: {
      fill: "${colors.hardware}"
      stroke: "${colors.border}"
      font-color: white
    }
  }

  style: {
    fill: "${colors.padding}"
    stroke: "${colors.hardware}"
    stroke-width: 2
  }
}

# Highlight specific hit entry
tlb_subsystem.tlb_storage."Entry 0".style.fill: "${colors.flow}"

# -----------------------------------------------------------------------------
# 3. PATHWAYS: HIT vs MISS
# -----------------------------------------------------------------------------

hit_logic: {
  label: |md
    **TLB HIT ✓ (Fast Path)**
    1. Extract PFN from TLB Tag
    2. Pass to Concatenator
    3. Update LRU bits
  |
  style: {
    fill: "${colors.flow}"
    stroke: "${colors.border}"
    font-color: white
    border-radius: 8
  }
}

miss_logic: {
  label: |md
    **TLB MISS ✗ (Slow Path)**
    1. Signal Page Table Walker
    2. Stall Pipeline (if necessary)
  |
  style: {
    fill: "${colors.miss}"
    stroke: "${colors.border}"
    font-color: white
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------
# 4. MEMORY: PAGE TABLE WALK
# -----------------------------------------------------------------------------

ptw_subsystem: {
  label: "Memory Management Unit (PTW)"
  
  walk_logic: {
    label: |md
      **Step 3: PTW Walk**
      c
      // Locate PTE in Main Memory
      uint32_t* pte_addr = pt_base + (vpn * 4);
      pte_t pte = load_mem(pte_addr);
      if (!pte.v) raise(PAGE_FAULT);
      
    |
    style: {
      fill: "${colors.header}"
      stroke: "${colors.border}"
      font-color: white
    }
  }

  tlb_refill: {
    label: |md
      **Step 4: Refill TLB**
      1. Evict LRU entry
      2. Write new VPN/PFN pair
      3. Set Valid bit
    |
    style: {
      fill: "${colors.header}"
      stroke: "${colors.border}"
      font-color: white
    }
  }

  style: {
    fill: "${colors.padding}"
    stroke: "${colors.header}"
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# 5. FINALIZATION
# -----------------------------------------------------------------------------

concatenator: {
  label: ||md
    **Step 5: Address Composition**
    c
    pa = (pfn << 12) | offset;
    // Result: 0x0007F234

  ||
  style: {
    fill: "${colors.data}"
    stroke: "${colors.border}"
    font-color: white
    border-radius: 8
  }
}

pa_output: {
  label: ||md
    **Physical Address (PA)**
    `0x0007F234`
    | Bits | Field | Value |
    | :--- | :--- | :--- |
    | 31:12 | PFN | `0x0007F` |
    | 11:0 | Offset | `0x234` |
  ||
  style: {
    fill: "${colors.flow}"
    stroke: "${colors.border}"
    font-color: white
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------
# 6. AUXILIARY / TELEMETRY
# -----------------------------------------------------------------------------

stats_monitor: {
  label: |md
    **MMU Telemetry**
    - `access_count++`
    - `hit_rate = hits / total`
    - `latency_sum += cycles`
  |
  style: {
    fill: "${colors.background}"
    stroke: "${colors.border}"
    stroke-dash: 3
    font-size: 11
  }
}

tlb_struct_spec: {
  label: ||md
    **TLB Entry Layout (32-bit)**
    | Field | Size | Offset |
    | :--- | :--- | :--- |
    | VPN | 20b | 0 |
    | PFN | 20b | 20 |
    | ASID | 8b | 40 |
    | Flags | 4b | 48 |
    | LRU | 4b | 52 |
  ||
  style: {
    font-size: 10
    fill: "${colors.background}"
    stroke: "${colors.border}"
  }
}
tlb_struct_spec.near: bottom-right

# -----------------------------------------------------------------------------
# 7. CONNECTIONS
# -----------------------------------------------------------------------------

va_input -> extract_logic: "Input VA"
extract_logic -> tlb_subsystem.lookup_logic: "VPN"

tlb_subsystem.lookup_logic -> hit_logic: "HIT" {
  style: {
    stroke: "${colors.flow}"
    stroke-width: 4
  }
}

tlb_subsystem.lookup_logic -> miss_logic: "MISS" {
  style: {
    stroke: "${colors.miss}"
    stroke-width: 4
    stroke-dash: 5
  }
}

miss_logic -> ptw_subsystem.walk_logic: "VPN"
ptw_subsystem.walk_logic -> ptw_subsystem.tlb_refill: "Load PTE"
ptw_subsystem.tlb_refill -> tlb_subsystem.tlb_storage: "Update Cache"

hit_logic -> concatenator: "PFN"
ptw_subsystem.tlb_refill -> concatenator: "PFN"

concatenator -> pa_output: "Compose"

# Global Legend
legend: {
  near: bottom-right
  label: |md
    ### Timing Legend
    - **Fast Path:** ~1 Clock Cycle
    - **PTW Path:** ~50-200 Cycles
    - **Page Fault:** ~Millions (Disk)
  |
}