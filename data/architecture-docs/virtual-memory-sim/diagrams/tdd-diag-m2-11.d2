layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    purple: "#B5AFF6"
    blue: "#88DCF7"
    gray: "#DEE1EB"
    header: "#C7F1FF"
    data: "#E4DBFE"
    red: "#ef4444"
    orange: "#f97316"
    green: "#22c55e"
    padding: "#f1f5f9"
    pointer: "#f97316"
  }
}

title: |'md
# TLB Statistics State Machine & Memory Layout
**Ref: Virtual Memory Simulation Milestone 2**
*Intel-manual grade specification for PTE and TLB transitions.*
'| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# --- Section 1: Memory Layout Specification ---

Memory_Structures: {
  TLB_Struct: {
    shape: sql_table
    label: "tlb_t Structure Layout (sizeof=64 bytes, Cache Line Aligned)"
    
    "0x00": "entries (tlb_entry_t*)" {constraint: "8 Bytes"; style.fill: ${colors.pointer}}
    "0x08": "capacity (uint32_t)" {constraint: "4 Bytes"}
    "0x0C": "current_asid (uint32_t)" {constraint: "4 Bytes"}
    "0x10": "clock_counter (uint64_t)" {constraint: "8 Bytes"}
    "0x18": "stats (tlb_stats_t struct)" {constraint: "24 Bytes"; style.fill: ${colors.data}}
    "0x30": "page_table_base (pte_t*)" {constraint: "8 Bytes"; style.fill: ${colors.pointer}}
    "0x38": "padding/reserved" {constraint: "8 Bytes"; style.fill: ${colors.padding}}
    
    style.fill: ${colors.header}
  }

  PTE_Layout: {
    shape: sql_table
    label: "PTE Bit Layout (32-bit Hardware Word)"
    
    "Bits 00-19": "Page Frame Number (PFN)" {constraint: "20 bits"}
    "Bits 20-25": "Reserved / OS-Specific" {constraint: "6 bits"; style.fill: ${colors.padding}}
    "Bit 26": "Referenced (R)" {style.fill: ${colors.purple}}
    "Bit 27": "Dirty (D)" {style.fill: ${colors.orange}}
    "Bit 28": "Writable (W)"
    "Bit 29": "Readable (R)"
    "Bit 30": "Valid (V)" {style.fill: ${colors.blue}}
    "Bit 31": "Global (G)"
    
    style.stroke: "#334155"
    style.stroke-width: 2
  }
}

# --- Section 2: TLB Entry State Machine ---

State_Machine: {
  direction: right

  initial_state: {
    label: "● INVALID\n(V=0, R=0, D=0)"
    shape: circle
    style: {
      fill: ${colors.gray}
      stroke-dash: 3
    }
  }

  valid_clean: {
    label: "VALID-CLEAN\n(V=1, R=0, D=0)"
    shape: circle
    style.fill: ${colors.blue}
  }

  valid_accessed: {
    label: "VALID-ACCESSED\n(V=1, R=1, D=0)"
    shape: circle
    style.fill: ${colors.purple}
  }

  valid_dirty: {
    label: "VALID-DIRTY\n(V=1, R=1, D=1)"
    shape: circle
    style: {
      fill: ${colors.orange}
      stroke: ${colors.red}
      stroke-width: 3
    }
  }

  # --- Transitions ---

  initial_state -> valid_clean: "tlb_insert()\n[TLB Miss]" {
    style.stroke: ${colors.blue}
    style.bold: true
  }

  valid_clean -> valid_accessed: "mem_read()\n[Hit]" {
    style.stroke: ${colors.purple}
    style.stroke-width: 2
  }

  valid_accessed -> valid_dirty: "mem_write()\n[Hit]" {
    style.stroke: ${colors.red}
    style.animated: true
    style.stroke-width: 2
  }
  
  valid_clean -> valid_dirty: "mem_write()\n[Hit]" {
    style.stroke: ${colors.red}
    style.stroke-width: 2
  }

  # --- Eviction paths ---

  valid_clean -> initial_state: "tlb_evict()\n[Discard]" {
    target-arrowhead: triangle
    style.stroke-dash: 5
  }

  valid_accessed -> initial_state: "tlb_evict()\n[Discard]" {
    style.stroke-dash: 5
  }

  valid_dirty -> initial_state: "tlb_evict()\n[Write-Back Required]" {
    style: {
      stroke: ${colors.red}
      stroke-width: 4
      animated: true
    }
  }

  # Control Ops
  valid_dirty -> valid_clean: "sys_flush()\n[Sync]" {
    style.stroke-dash: 5
  }
}

# --- Section 3: Truth Table & Notes ---

Legend_Truth_Table: |'md
### Operational Truth Table
| State | Valid | Ref | Dirty | Action on Evict |
| :--- | :---: | :---: | :---: | :--- |
| **INVALID** | 0 | 0 | 0 | No-op |
| **CLEAN** | 1 | 0 | 0 | Silent Discard |
| **ACCESSED**| 1 | 1 | 0 | Silent Discard |
| **DIRTY** | 1 | 1 | 1 | **Memory Write-Back** |
'| {
  near: bottom-right
  style: {
    fill: "#f8fafc"
    stroke: "#cbd5e1"
  }
}

Implementation_Notes: |'md
### Statistics Counter Logic
1. **tlb_hits**: Incremented for every request where V=1 (Clean, Accessed, or Dirty).
2. **tlb_misses**: Incremented on transition from INVALID.
3. **write_backs**: Triggered specifically on Dirty -> INVALID eviction.
4. **dirty_flushes**: Counted during sys_flush() or context switches.
'| {
  near: bottom-left
  style: {
    stroke: ${colors.blue}
    stroke-width: 2
    fill: "#f8fafc"
  }
}

# Linking logic indicators
(State_Machine.valid_dirty -> State_Machine.initial_state)[0].style.stroke: ${colors.red}

State_Machine.valid_dirty -> Implementation_Notes: "triggers\nwrite_backs++" {
  style: {
    stroke-dash: 5
    stroke: ${colors.red}
    opacity: 0.6
  }
}

State_Machine.initial_state -> Implementation_Notes: "triggers\ntlb_misses++" {
  style: {
    stroke-dash: 5
    stroke: ${colors.blue}
    opacity: 0.6
  }
}

# Illegal transition marking
State_Machine.initial_state -> State_Machine.valid_dirty: "ILLEGAL" {
  style: {
    stroke: ${colors.red}
    stroke-dash: 2
    opacity: 0.4
  }
}