layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9370DB"
    data: "#4a90E2"
    free: "#ACE1AF"
    swap: "#F4A261"
    arrow: "#6772e5"
    eviction: "#E74C3C"
    error: "#DC3545"
    border: "#2C3E50"
    annotation_bg: "#FFFFFF"
    padding: "#E5E7EB"
  }
}

title: |md
  # ASID Allocation and Frame Eviction Logic
  ### Virtual Memory Subsystem: Memory Management Unit (MMU) Implementation
  **Engineer Reference: MMU-REF-042**
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    fill: "${colors.header}"
    font-color: white
  }
}

# 1. Legend Section
legend: {
  near: bottom-center
  shape: rectangle
  style: {
    fill: white
    stroke: "${colors.border}"
    stroke-width: 2
    border-radius: 8
    shadow: true
  }
  
  l_title: "Legend" {
    style: {
      bold: true
      fill: "${colors.header}"
      font-color: white
    }
  }
  l_data: "Register / Cache" {
    style: {
      fill: "${colors.data}"
      font-color: white
    }
  }
  l_free: "Available Resource" {
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
    }
  }
  l_swap: "I/O / Disk State" {
    style: {
      fill: "${colors.swap}"
      font-color: white
    }
  }
  l_evict: "Destructive Operation" {
    style: {
      fill: "${colors.eviction}"
      font-color: white
    }
  }
}

# 2. Memory Layout: Page Table Entry (PTE) Definition
# Intel x86-64 inspired layout for implementation reference
pte_layout: {
  label: "PTE Structure (64-bit)"
  shape: sql_table
  style.fill: "${colors.header}"
  
  00-11: "Protection Bits (R/W/X/U)" {constraint: "bits 0-11"}
  12-51: "Physical Page Frame Number (PFN)" {constraint: "bits 12-51"}
  52-62: "Software Defined / Reserved" {constraint: "bits 52-62"}
  63: "Present / Valid Bit (V)" {constraint: "bit 63"}
}

# 3. Main Flow: Page Fault Handler Algorithm
flow: {
  shape: rectangle
  label: "Kernel ISR: Page Fault Handler (IDT[14])"
  style: {
    fill: "#f8f9fa"
    stroke: "${colors.border}"
    stroke-width: 3
    border-radius: 12
  }

  start: ● {
    shape: circle
    width: 30
    height: 30
    style: {
      fill: "${colors.header}"
      stroke-width: 0
    }
  }

  check_free: "1. Check free_count\n(Atomic Load)" {
    style: {
      fill: "${colors.data}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  decision: "free_count > 0?" {
    shape: diamond
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
      stroke: "${colors.border}"
    }
  }

  fast_path: "FAST PATH: Allocation" {
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
      bold: true
    }
  }

  allocate_free: "2. Pop pfn\npfn = free_list[--free_count]" {
    style: {
      fill: "${colors.data}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  no_path: "SLOW PATH: Eviction Required" {
    style: {
      fill: "${colors.eviction}"
      font-color: white
      bold: true
    }
  }

  select_victim: "3. replacement_select_victim()\n[LRU Counter Scan]" {
    style: {
      fill: "${colors.swap}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  get_victim: "4. victim_pte = &page_table[vpn]" {
    style: {
      fill: "${colors.data}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  dirty_check: "5. victim_pte->dirty?" {
    shape: diamond
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
      stroke: "${colors.border}"
    }
  }

  dirty_path: "DIRTY: Sync Needed" {
    style: {
      fill: "${colors.eviction}"
      font-color: white
      border-radius: 4
    }
  }

  clean_path: "CLEAN: Drop Page" {
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
      border-radius: 4
    }
  }

  swap_write: "6a. swap_write_page()\nstats.swap_writes++" {
    style: {
      fill: "${colors.swap}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  swap_discard: "6b. Skip Write-back\nstats.discards++" {
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
      border-radius: 4
      font: mono
    }
  }

  invalidate_pte: "7. victim_pte->valid = 0\nvictim_pte->pfn = 0" {
    style: {
      fill: "${colors.data}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  invalidate_tlb: "8. tlb_inv_entry(vpn)\n[LOCK STEP]" {
    style: {
      fill: "${colors.data}"
      font-color: white
      border-radius: 4
      font: mono
      stroke: "${colors.error}"
      stroke-width: 2
    }
  }

  update_swap_map: "9. swap_map[vpn].in_swap = 1" {
    style: {
      fill: "${colors.swap}"
      font-color: white
      border-radius: 4
      font: mono
    }
  }

  return_pfn: "10. Return PFN\n(Frame Available)" {
    shape: rectangle
    style: {
      fill: "${colors.free}"
      font-color: "#1a472a"
      border-radius: 4
      bold: true
    }
  }

  end: ◎ {
    shape: circle
    width: 30
    height: 30
    style: {
      fill: "${colors.header}"
      stroke-width: 0
    }
  }

  # Transitions
  start -> check_free: "HW Page Fault Exception"
  check_free -> decision
  decision -> fast_path: "count > 0"
  decision -> no_path: "count == 0"
  fast_path -> allocate_free
  allocate_free -> end
  no_path -> select_victim
  select_victim -> get_victim
  get_victim -> dirty_check
  dirty_check -> dirty_path: "Dirty=1"
  dirty_check -> clean_path: "Dirty=0"
  dirty_path -> swap_write
  swap_write -> invalidate_pte
  clean_path -> swap_discard
  swap_discard -> invalidate_pte
  invalidate_pte -> invalidate_tlb
  invalidate_tlb -> update_swap_map
  update_swap_map -> return_pfn
  return_pfn -> end

  # Annotations moved to container children but without 'near' positioning on the shape itself
  # to satisfy compiler constraints while maintaining proximity in ELK layout.
  annotate_dirty_check: |md
    ### MMU DIRTY BIT LOGIC
    - **DIRTY (1)**: Modified. Write-back.
    - **CLEAN (0)**: Match disk. Drop.
  | {
    shape: text
    style: {
      fill: "${colors.annotation_bg}"
      stroke: "${colors.border}"
      border-radius: 4
      font-size: 11
    }
  }

  annotate_tlb_inv: |md
    ### TLB CONSISTENCY
    `INV_TLB` must finish before
    `PTE_PFN` reuse.
  | {
    shape: text
    style: {
      fill: "#FFF5F5"
      stroke: "${colors.error}"
      border-radius: 4
      font-size: 11
      font-color: "${colors.error}"
    }
  }
}

# 4. Storage Panel: Secondary Storage (Swap Space)
swap_panel: {
  label: "BLOCK STORAGE: SWAP PARTITION (/dev/nvme0n1p2)"
  style: {
    stroke: "${colors.swap}"
    stroke-width: 2
    fill: "#FFF9F0"
  }
  
  swap_space: "Disk Block Mapping Table" {
    style: {
      fill: "${colors.swap}"
      font-color: white
      bold: true
    }
  }
  swap_slot_0: "Offset 0x0000: [vpn=0x10]" { style.fill: "${colors.data}"; style.font-color: white }
  swap_slot_1: "Offset 0x1000: [vpn=0x20]" { style.fill: "${colors.data}"; style.font-color: white }
  swap_slot_2: "Offset 0x2000: [--- FREE ---]" { style.fill: "${colors.free}"; style.font-color: "#1a472a" }
  swap_slot_3: "Offset 0x3000: [vpn=0x05]" { style.fill: "${colors.data}"; style.font-color: white }
  
  swap_write_op: "EXT4_WRITE_BLOCK(slot_id, frame_ptr)" {
    shape: rectangle
    style: {
      fill: "${colors.eviction}"
      font-color: white
      border-radius: 4
      stroke: "${colors.border}"
      stroke-dash: 3
    }
  }
  
  swap_space -> swap_slot_0
  swap_space -> swap_slot_1
  swap_space -> swap_slot_2
  swap_space -> swap_slot_3
  swap_write_op -> swap_slot_2: "Atomic Write" {
    style: { stroke: "${colors.swap}"; stroke-width: 3; animated: true }
  }

  annotate_swap_write: |md
    ### DISK I/O SEQUENCE
    1. Direct Memory Access (DMA)
    2. Block Header Checksum
    3. IRQ Callback on Completion
  | {
    shape: text
    style: {
      fill: "${colors.annotation_bg}"
      stroke: "${colors.swap}"
      border-radius: 4
      font-size: 11
    }
  }
}

# 5. Kernel Data Structures
tracking_panel: {
  label: "KERNEL MEMORY MAPS"
  style: {
    stroke: "${colors.header}"
    stroke-width: 2
    fill: "#F5F3FF"
  }

  tracking: "System Address Space" {
    style: { fill: "${colors.header}"; font-color: white }
  }
  swap_map: "swap_map_array" {
    style.fill: "${colors.swap}"
    style.font-color: white
    entry: "VPN[0x42] -> {sector: 4096, state: IN_DISK}" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
  }
  frame_to_vpn: "Reverse Mapping (RMAP)" {
    style.fill: "${colors.data}"
    style.font-color: white
    frame_entry: "PFN 0x4 -> VPN 0x42" {
      style.fill: "${colors.free}"
      style.font-color: "#1a472a"
    }
  }
  
  tracking -> swap_map
  tracking -> frame_to_vpn

  asid_box: {
    label: "ASID Context Mapping (HW TLB Tags)"
    shape: sql_table
    style: {
      fill: white
      stroke: "${colors.header}"
    }
    context_0: "PID 1001 | ASID 0x01 | STATE: ACTIVE"
    context_1: "PID 1024 | ASID 0x02 | STATE: ACTIVE"
    context_2: "PID 5005 | ASID 0x03 | STATE: EVICTED"
  }
}

# 6. Performance Telemetry
stats_panel: {
  label: "MMU TELEMETRY (PMC)"
  style: {
    stroke: "${colors.border}"
    fill: "#F8FAFC"
  }
  
  stats: "Counters" { style.fill: "${colors.header}"; style.font-color: white }
  stat_writes: "Total Swaps: 1,402" { style.fill: "${colors.eviction}"; style.font-color: white }
  stat_discards: "Total Discards: 894" { style.fill: "${colors.free}"; style.font-color: "#1a472a" }
  stat_evictions: "Fault Rate: 0.02%" { style.fill: "${colors.eviction}"; style.font-color: white }
  
  stats -> stat_writes
  stats -> stat_discards
  stats -> stat_evictions
}

# Inter-Panel Logical Links
flow.swap_write -> swap_panel.swap_write_op: "Commit Page" {
  style: { stroke: "${colors.swap}"; stroke-dash: 4; stroke-width: 2 }
}

flow.update_swap_map -> tracking_panel.swap_map: "Metadata Sync" {
  style: { stroke: "${colors.swap}"; stroke-dash: 4 }
}

flow.return_pfn -> stats_panel.stat_evictions: "Log Success" {
  style: { stroke: "${colors.arrow}"; stroke-dash: 4 }
}