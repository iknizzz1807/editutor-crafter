layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    pad: 30
    sketch: false
    center: true
  }
}

title: |md
  # PAGE REPLACEMENT ALGORITHM ARCHITECTURE
  ### Implementation-Grade State Transitions and Memory Layouts
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# =============================================================================
# 1. MEMORY LAYOUT: 64-bit Page Table Entry (PTE)
# =============================================================================
PTE_Layout: {
  label: "Intel x86-64 Page Table Entry (PTE) Layout"
  shape: sql_table
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    stroke-width: 2
  }

  # Field Definition: Offset (Visual) | Bit Range | Description
  header: "Bit Index" {constraint: "Architectural Field Description"}
  
  b00: "bit 0 (P)" {constraint: "Present; 1 = Page in Physical RAM"}
  b01: "bit 1 (R/W)" {constraint: "Read/Write; 0 = Read-Only, 1 = Read/Write"}
  b02: "bit 2 (U/S)" {constraint: "User/Supervisor; 0 = Kernel, 1 = User"}
  b03: "bit 3 (PWT)" {constraint: "Page-level Write-Through Cache Policy"}
  b04: "bit 4 (PCD)" {constraint: "Page-level Cache Disable"}
  b05: "bit 5 (A)" {constraint: "Accessed; Set by Hardware MMU on Read/Write"}
  b06: "bit 6 (D)" {constraint: "Dirty; Set by Hardware MMU on Write Access"}
  b07: "bit 7 (PAT)" {constraint: "Page Attribute Table Index"}
  b08: "bit 8 (G)" {constraint: "Global Page Indicator (CR4.PGE)"}
  b09_11: "bits 9..11" {constraint: "Available for Operating System Use"}
  b12_51: "bits 12..51" {constraint: "Physical Frame Number (PFN) - 4KB Aligned"}
  b52_62: "bits 52..62" {constraint: "Available for Operating System Use"}
  b63: "bit 63 (NX)" {constraint: "No-Execute (Execute Disable) Bit"}

  style.fill: "#EDE7F6"
  header.style.fill: "#7B1FA2"
  header.style.font-color: "#FFFFFF"
}

# =============================================================================
# 2. ALGORITHM: Clock (Second-Chance) Implementation
# =============================================================================
Clock_Subsystem: {
  label: "Clock Algorithm Execution Environment"
  
  State_Transition: {
    direction: right
    
    T_N: {
      label: "T=N: Page Fault Triggered (VPN 0xF)"
      shape: sql_table
      
      header: "Ring Buffer [Index]" {constraint: "Status [VPN | R-Bit]"}
      e0: "[0]" {constraint: "VPN: 0xA | R=1 (Skip)"}
      e1: "[1] < HAND" {constraint: "VPN: 0xB | R=0 (CANDIDATE)"}
      e2: "[2]" {constraint: "VPN: 0xC | R=1"}
      e3: "[3]" {constraint: "VPN: 0xD | R=1"}
      
      e1.style.stroke: red
      e1.style.stroke-width: 4
      e1.style.shadow: true
      
      style.fill: "#FFFDE7"
      header.style.fill: "#FBC02D"
    }

    T_N_PLUS_1: {
      label: "T=N+1: Post-Replacement State"
      shape: sql_table
      
      header: "Ring Buffer [Index]" {constraint: "Status [VPN | R-Bit]"}
      e0: "[0]" {constraint: "VPN: 0xA | R=1"}
      e1: "[1]" {constraint: "VPN: 0xF | R=1 (NEW PAGE)"}
      e2: "[2] < HAND" {constraint: "VPN: 0xC | R=1"}
      e3: "[3]" {constraint: "VPN: 0xD | R=1"}
      
      e1.style.fill: "#C8E6C9"
      e2.style.stroke: green
      e2.style.stroke-width: 4
      
      style.fill: "#E8F5E9"
      header.style.fill: "#2E7D32"
    }

    T_N -> T_N_PLUS_1: "1. Evict 0xB\n2. Load 0xF\n3. Inc Hand" {
      style.stroke: orange
      style.stroke-width: 4
      style.animated: true
    }
  }

  Clock_Sequence: {
    shape: sequence_diagram
    MMU: "Hardware MMU"
    OS: "Kernel Pager"
    Buffer: "Clock Buffer"

    MMU -> OS: "Page Fault Exception (VPN: 0xF)"
    OS -> Buffer: "Query hand_ptr position"
    Buffer -> OS: "Return Candidate: VPN 0xB (R=0)"
    OS -> MMU: "TLB_Invalidate(0xB)"
    OS -> Buffer: "Write(0xF) at hand_ptr"
    OS -> Buffer: "Update hand_ptr = (hand_ptr + 1) % N"
    OS -> MMU: "IRET (Resume Execution)"
  }
}

# =============================================================================
# 3. ALGORITHM: LRU Stack-Based Tracking
# =============================================================================
LRU_Subsystem: {
  label: "LRU (Least Recently Used) Stack Logic"
  
  LRU_Stack: {
    shape: sql_table
    label: "Physical Frame Access Stack"
    
    ptr0: "Stack Top (0x0)" {constraint: "MRU (Most Recently Used)"}
    page1: "Frame: 0x221" {constraint: "Accessed T-1"}
    page2: "Frame: 0x105" {constraint: "Accessed T-2"}
    page3: "Frame: 0x00A" {constraint: "Accessed T-3"}
    ptrN: "Stack Bottom (0x18)" {constraint: "LRU (EVICTION TARGET)"}
    
    style.fill: "#E3F2FD"
    ptr0.style.fill: "#BBDEFB"
    ptrN.style.fill: "#FFCDD2"
  }

  LRU_Logic: {
    shape: sequence_diagram
    CPU: "CPU Pipeline"
    Logic: "Access Monitor"
    Stack: "LRU Stack Hardware"

    CPU -> Logic: "Memory_Read(0x105)"
    Logic -> Stack: "Move_To_Top(Frame_ID: 0x105)"
    Stack -> Stack: "Shift higher elements down"
    Stack -> Logic: "Update Complete"
  }
}

# =============================================================================
# 4. COMPARISON: Algorithm Performance Matrix
# =============================================================================
Comparison: {
  label: "Algorithm Benchmarks & Complexity Matrix"
  grid-columns: 4
  grid-gap: 0
  
  # Row 1: Header Row
  h1: "Algorithm Type" { style.fill: "#424242"; style.font-color: "#FFFFFF"; style.bold: true }
  h2: "Search Complexity" { style.fill: "#424242"; style.font-color: "#FFFFFF"; style.bold: true }
  h3: "Hardware Reqs" { style.fill: "#424242"; style.font-color: "#FFFFFF"; style.bold: true }
  h4: "Known Anomalies" { style.fill: "#424242"; style.font-color: "#FFFFFF"; style.bold: true }

  # Row 2: FIFO
  r1c1: "FIFO"
  r1c2: "O(1)"
  r1c3: "None"
  r1c4: "Belady's Anomaly"

  # Row 3: LRU
  r2c1: "LRU"
  r2c2: "O(1) with Hash"
  r2c3: "High (Counters/Stack)"
  r2c4: "Strict Temporal"

  # Row 4: Clock
  r3c1: "Clock (NRU)"
  r3c2: "O(1) Amortized"
  r3c3: "1-bit (Accessed)"
  r3c4: "None"

  # Row 5: Optimal
  r4c1: "Optimal (MIN)"
  r4c2: "N/A (Offline)"
  r4c3: "Clairvoyance"
  r4c4: "Ideal Baseline"

  style.fill: "#F5F5F5"
}

# =============================================================================
# CONNECTIONS & GLOBAL STYLING
# =============================================================================

# Structural Relationships
PTE_Layout.b05 -> Clock_Subsystem: "Inputs Accessed Bit"
PTE_Layout.b06 -> LRU_Subsystem: "Dirty Bit Tracking"
Clock_Subsystem -> Comparison: "Benchmark Data"
LRU_Subsystem -> Comparison: "Benchmark Data"

# Corrected Global Styles
***: {
  style: {
    font: mono
    stroke-width: 2
    border-radius: 4
  }
}

# Annotations
Architecture_Note: |md
  ### Hardware/Software Contract
  The **Accessed (A)** and **Dirty (D)** bits are set by hardware. 
  The **Operating System** is responsible for clearing these bits 
  during the Clock Algorithm's sweep to reset the 'Second Chance' timer.
| {
  near: bottom-left
  shape: text
  style.font-size: 14
}

# Visualization for Cache Line (64 Bytes)
Cache_Boundary: "64B CACHE LINE BOUNDARY" {
  style: {
    stroke: "#607D8B"
    stroke-dash: 5
    stroke-width: 2
    fill: transparent
  }
  near: bottom-right
}