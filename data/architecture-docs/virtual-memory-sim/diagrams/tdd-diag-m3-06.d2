vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#6B4C9A"
    data: "#2E5A88"
    pointer: "#D35400"
    free: "#27AE60"
    padding: "#7F8C8D"
    text: "#2C3E50"
    highlight: "#E74C3C"
  }
}
title: |md
  # Virtual Memory Simulator: System Overview
| {near: top-center}
direction: right
CPU: {
  label: CPU
  style.fill: "${colors.header}"
  style.font-color: white
  style.stroke: "${colors.header}"
  registers: {
    label: "Registers"
    style.fill: white
    style.stroke: "${colors.header}"
    VA: "VA Register\n0x00401234" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
  }
}
MMU: {
  label: "Memory Management Unit"
  style.fill: "${colors.header}"
  style.font-color: white
  style.stroke: "${colors.header}"
  decompose: {
    label: "Address\nDecomposition"
    style.fill: white
    style.stroke: "${colors.header}"
    vpn: "VPN: 0x00401" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
    offset: "Offset: 0x234" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
  }
  tlb_check: {
    label: "TLB\nLookup"
    style.fill: "${colors.pointer}"
    style.font-color: white
  }
  pt_walk: {
    label: "Page Table\nWalk"
    style.fill: "${colors.pointer}"
    style.font-color: white
  }
}
TLB: {
  label: "Translation Lookaside Buffer"
  style.fill: "${colors.free}"
  style.font-color: white
  style.stroke: "${colors.free}"
  entries: {
    label: "32 Entries\n(Cache)"
    style.fill: white
    style.stroke: "${colors.free}"
  }
}
PageTable: {
  label: "Page Table"
  style.fill: "${colors.header}"
  style.font-color: white
  style.stroke: "${colors.header}"
  pte_array: {
    label: "PTE Array\n[VPN → PFN]"
    style.fill: white
    style.stroke: "${colors.header}"
    valid_check: {
      label: "valid=1?\npermissions?"
      style.fill: "${colors.free}"
      style.font-color: white
    }
  }
}
PhysicalMemory: {
  label: "Physical Memory"
  style.fill: "${colors.data}"
  style.font-color: white
  style.stroke: "${colors.data}"
  frames: {
    label: "Frame Pool\n(64 frames × 4KB)"
    style.fill: white
    style.stroke: "${colors.data}"
    frame0: "Frame 0" {style.fill: "${colors.padding}"}
    frame1: "Frame 1" {style.fill: "${colors.free}"}
    frame42: "Frame 42" {style.fill: "${colors.pointer}"}
  }
}
SwapSpace: {
  label: "Swap Space"
  style.fill: "${colors.padding}"
  style.font-color: white
  style.stroke: "${colors.padding}"
  slots: {
    label: "Swap Slots\n(256 × 4KB)"
    style.fill: white
    style.stroke: "${colors.padding}"
  }
}
fault_handler: {
  label: "Page Fault Handler"
  style.fill: "${colors.highlight}"
  style.font-color: white
  style.stroke: "${colors.highlight}"
  demand_paging: {
    label: "Demand Paging\n& Replacement"
    style.fill: white
    style.stroke: "${colors.highlight}"
  }
}
CPU.registers.VA -> MMU.decompose: "virtual address"
MMU.decompose.vpn -> MMU.tlb_check: "VPN"
MMU.decompose.offset -> MMU.tlb_check: "offset"
MMU.tlb_check -> TLB.entries: "lookup" {
  style.stroke: "${colors.free}"
}
TLB.entries -> MMU.tlb_check: "HIT: PFN" {
  style.stroke: "${colors.free}"
  style.stroke-dash: 3
}
MMU.tlb_check -> MMU.pt_walk: "MISS" {
  style.stroke: "${colors.highlight}"
  style.stroke-dash: 5
}
MMU.pt_walk -> PageTable.pte_array: "walk"
PageTable.pte_array.valid_check -> fault_handler.demand_paging: "valid=0\n(page fault)" {
  style.stroke: "${colors.highlight}"
  style.stroke-dash: 5
}
fault_handler.demand_paging -> PageTable.pte_array: "allocate frame\nupdate PTE" {
  style.stroke: "${colors.free}"
  style.stroke-dash: 3
}
PageTable.pte_array.valid_check -> PhysicalMemory.frames: "PFN" {
  style.stroke: "${colors.data}"
}
fault_handler.demand_paging -> SwapSpace.slots: "evict to swap\n(if dirty)" {
  style.stroke: "${colors.padding}"
  style.stroke-dash: 3
}
SwapSpace.slots -> fault_handler.demand_paging: "reload from swap\n(on fault)" {
  style.stroke: "${colors.padding}"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  style.fill: white
  style.stroke: "${colors.padding}"
  l1: "→ Data Flow" {style.fill: transparent}
  l2: "⇢ Conditional/Slow Path" {style.fill: transparent}
  l3: "HIT: Fast Path" {style.fill: "${colors.free}"}
  l4: "Fault Handler" {style.fill: "${colors.highlight}"}
}