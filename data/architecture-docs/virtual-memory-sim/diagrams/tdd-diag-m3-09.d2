vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |'md
# Multi-Level Page Table Walk: Failure Cases (Intel x86-32 Style)
## Detailed Exception Logic for PDE/PTE Address Translation
'| {near: top-center}

direction: right

# Input Virtual Address Decomposition
start: "Virtual Address (VA)\n0x00401234" {
  shape: rectangle
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
}

decompose: "Bit-Field Extraction\n───────────────\nVPN1 [31:22] = 0x001\nVPN2 [21:12] = 0x001\nOffset [11:0] = 0x234" {
  shape: rectangle
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
  }
}

# 1. Page Directory Phase
pd_lookup: "Page Directory Access\n───────────────\nCR3 -> Base Address\nIndex = VPN1 * 4\npde = [CR3 + Index]" {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
  }
}

pde_check: "PDE bit 0 set?\n(P-bit)" {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
  }
  width: 140
}

# FAILURE CASE 1: Directory Not Present
failure1_container: "EXCEPTION: DIR_NOT_PRESENT" {
  style: {
    fill: "#FFEBEE"
    stroke: "#D32F2F"
    stroke-width: 3
  }
  
  dir_not_present: "Hardware Logic\n──────────────\nPDE.P == 0\n\nEntire 4MB region\nis currently unmapped." {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
    }
  }
  
  result1: "SIGNAL: #PF (Error Code: 0)" {
    shape: rectangle
    style: {
      fill: "#D32F2F"
      font-color: white
      bold: true
    }
  }
  
  dir_not_present -> result1
}

on_demand: "Memory Manager\n──────────────\nPage Table Allocation\n(OS Intervention)\n\nSUCCESS -> Continue\nFAILURE -> OOM" {
  shape: rectangle
  style: {
    fill: "#E1F5FE"
    stroke: "#03A9F4"
    stroke-dash: 3
  }
}

# 2. Page Table Phase
pt_lookup: "Page Table Access\n───────────────\nBase = PDE & ~0xFFF\nIndex = VPN2 * 4\npte = [Base + Index]" {
  shape: rectangle
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
  }
}

pte_check: "PTE bit 0 set?\n(P-bit)" {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
  }
  width: 140
}

# FAILURE CASE 2: Page Not Valid
failure2_container: "EXCEPTION: PAGE_FAULT" {
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 3
  }
  
  page_not_valid: "Hardware Logic\n──────────────\nPTE.P == 0\n\nPage data is on Disk\n(Swap) or unallocated." {
    shape: rectangle
    style: {
      fill: "#FFE0B2"
      stroke: "#E65100"
    }
  }
  
  result2: "SIGNAL: #PF (Error Code: 0)" {
    shape: rectangle
    style: {
      fill: "#E65100"
      font-color: white
      bold: true
    }
  }
  
  page_not_valid -> result2
}

# 3. Protection Phase
perm_check: "Permission Unit\n───────────────\nMatch CPU CPL\nagainst PTE.U/S\nand PTE.R/W bits" {
  shape: rectangle
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
  }
}

perm_decision: "Access Valid?" {
  shape: diamond
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
  }
  width: 120
}

# FAILURE CASE 3: Protection Violation
failure3_container: "EXCEPTION: PROT_FAULT" {
  style: {
    fill: "#EDE7F6"
    stroke: "#6A1B9A"
    stroke-width: 3
  }
  
  protection: "Hardware Logic\n──────────────\nPTE.P == 1\nBUT\nAccess violates bits\n(R/W=0 on Write)" {
    shape: rectangle
    style: {
      fill: "#D1C4E9"
      stroke: "#6A1B9A"
    }
  }
  
  result3: "SIGNAL: #PF (Error Code: 1)" {
    shape: rectangle
    style: {
      fill: "#6A1B9A"
      font-color: white
      bold: true
    }
  }
  
  protection -> result3
}

# Final Success State
success: "SUCCESS: PHYSICAL ADDR\n───────────────\nPA = (PTE & ~0xFFF) | Offset\n\nTranslation Loaded to TLB" {
  shape: rectangle
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
    bold: true
    stroke-width: 4
  }
}

# Control Flow Connections
start -> decompose
decompose -> pd_lookup
pd_lookup -> pde_check

pde_check -> failure1_container.dir_not_present: "NO (P=0)" {
  style: {
    stroke: "#D32F2F"
    stroke-width: 3
    bold: true
  }
}

pde_check -> on_demand: "YES (P=1)" {
  style.stroke: "#4CAF50"
}

on_demand -> pt_lookup
pt_lookup -> pte_check

pte_check -> failure2_container.page_not_valid: "NO (P=0)" {
  style: {
    stroke: "#E65100"
    stroke-width: 3
    bold: true
  }
}

pte_check -> perm_check: "YES (P=1)"

perm_check -> perm_decision

perm_decision -> failure3_container.protection: "NO" {
  style: {
    stroke: "#6A1B9A"
    stroke-width: 3
    bold: true
  }
}

perm_decision -> success: "YES" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 4
  }
}

# Implementation Specification Table
legend: |'md
## Translation Implementation Reference

| Step | Fault Type | HW Condition | SW Recovery Action |
| :--- | :--- | :--- | :--- |
| **PDE Lookup** | `DIR_NOT_PRESENT` | `PDE.P == 0` | `vm_alloc_table()`: Allocate 4KB and update PD |
| **PTE Lookup** | `PAGE_FAULT` | `PTE.P == 0` | `do_page_fault()`: Pull from disk/swap into RAM |
| **Access Check** | `PROT_VIOLATION` | `PTE.R/W == 0` | `SIGSEGV`: Protection violation (often fatal) |

### Page Table Entry Bitmask (x86)
- **Bit 0 [P]**: Present
- **Bit 1 [R/W]**: Read/Write (0=Read-only, 1=Read/Write)
- **Bit 2 [U/S]**: User/Supervisor (0=Kernel, 1=User)
- **Bits 12-31**: Page Frame Number (PFN)
'| {
  near: bottom-center
  style: {
    stroke: "#333333"
    fill: "#F5F5F5"
  }
}