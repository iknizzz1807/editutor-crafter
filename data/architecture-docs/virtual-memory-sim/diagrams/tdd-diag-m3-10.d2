vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B59B6"
    data: "#3498DB"
    free: "#2ECC71"
    padding: "#95A5A6"
    pointer: "#E67E22"
    page-boundary: "#E74C3C"
    cache-line: "#F39C12"
  }
}
title: |md
  # Virtual Memory Simulator
  # System Overview
| {
  near: top-center
  shape: text
}
direction: right
cpu: CPU {
  style.fill: "${colors.header}"
  va_gen: VA Generator {
    style.fill: "${colors.data}"
    label: Virtual Address\nGenerator
  }
  mmu: MMU {
    style.fill: "${colors.header}"
    label: Memory Management\nUnit
  }
  va_gen -> mmu: "VA: 0x1000"
}
mmu.tlb: TLB Cache {
  style.fill: "${colors.data}"
  label: Translation\nLookaside Buffer\n(64 entries)"
}
mmu.page_table: Page Table{
  style.fill: "${colors.data}"
  label: Page Table\n(Flat/Multi-Level)"
}
physical_mem: Physical Memory{
  style.fill: "${colors.data}"
  label: Physical RAM\n(Frames 0-255)"
}
swap: Swap Space{
  style.fill: "${colors.padding}"
  label: Swap/Disk\n(Evicted Pages)"
}
mmu.tlb -> mmu.page_table: "TLB Miss:\nWalk Page Table" {
  style.stroke-dash: 3
}
mmu -> physical_mem: "PA: 0x7F3A2000" {
  style.stroke: "${colors.pointer}"
}
physical_mem <-> swap: "Page Fault:\nEvict/Reload" {
  style.stroke: "${colors.page-boundary}"
  style.stroke-dash: 5
  style.animated: true
}
stats: Statistics {
  style.fill: "${colors.padding}"
  accesses: "Total Accesses: 10,000"
  faults: "Page Faults: 156"
  tlb_hits: "TLB Hit Rate: 98.4%"
}
physical_mem -> stats: "Collect Metrics"
legend: |md
  **Color Key:**
  - 🟣 Purple: Control/Translation
  - 🔵 Blue: Data Structures
  - 🟢 Green: Free Resources
  - 🟡 Yellow: Secondary Storage
| {
  near: bottom-left
  shape: text
}