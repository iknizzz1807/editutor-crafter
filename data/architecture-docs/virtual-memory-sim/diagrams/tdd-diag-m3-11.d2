layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    header: "#D1C4E9"
    data: "#BBDEFB"
    free: "#C8E6C9"
    padding: "#F5F5F5"
    pointers: "#FFE0B2"
    swap: "#E1BEE7"
    phys_mem: "#F0F2F5"
    error: "#FFCDD2"
  }
}

title: |md
  # Memory Translation Pipeline
  ### Three-Level Demand Paging System (Intel x86-64 Inspired)
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

# --- VIRTUAL ADDRESS DECOMPOSITION ---
virtual_address: {
  label: "Virtual Address (32-bit) Register"
  grid-columns: 3
  grid-gap: 0
  
  vpn_segment: "VPN [31:12]" {
    style.fill: ${colors.header}
    tooltip: "Virtual Page Number: Index into Page Table"
  }
  offset_segment: "Offset [11:0]" {
    style.fill: ${colors.data}
    tooltip: "Byte Offset within 4KB Page"
  }
  padding_bits: "Unused/Reserved" {
    style.fill: ${colors.padding}
    style.stroke-dash: 2
  }
}

# --- PAGE TABLE STRUCTURES ---
page_table_entry: {
  shape: sql_table
  label: "PTE Structure (32-bit Word)"
  style.fill: ${colors.header}
  style.stroke-width: 2
  
  "0-19": "PFN (Physical Frame Number)" {constraint: "20 bits"}
  "20": "V (Valid)" {constraint: "1 bit"}
  "21": "R (Read)" {constraint: "1 bit"}
  "22": "W (Write)" {constraint: "1 bit"}
  "23": "X (Execute)" {constraint: "1 bit"}
  "24": "D (Dirty)" {constraint: "1 bit"}
  "25": "A (Accessed)" {constraint: "1 bit"}
  "26": "CD (Cache Disable)" {constraint: "1 bit"}
  "27-31": "Reserved/OS" {constraint: "5 bits"}
}

# --- PAGE FAULT STATE MACHINE ---
mmu_logic: MMU Translation Logic Flow {
  style.stroke-dash: 5
  style.fill: "#FAFAFA"
  
  start: ● {
    shape: circle
    style.fill: black
  }
  check_tlb: "Search TLB (L1 Cache)" {
    shape: diamond
  }
  check_pt: "Walk Page Table (In Memory)" {
    shape: rectangle
  }
  page_fault: "PAGE FAULT EXCEPTION" {
    style.fill: ${colors.error}
    style.bold: true
    style.stroke: red
  }
  access_phys: "Physical Address Calculation" {
    style.fill: ${colors.free}
  }
  
  start -> check_tlb: "Virtual Addr Received"
  check_tlb -> access_phys: "TLB Hit" { style.stroke: green; style.bold: true }
  check_tlb -> check_pt: "TLB Miss" { style.stroke: orange }
  check_pt -> access_phys: "PTE Valid" { style.stroke: green }
  check_pt -> page_fault: "PTE Invalid (P=0)" { 
    style.stroke: red
    style.animated: true 
  }
  page_fault -> swap_logic.disk_read: "TRAP to Kernel: Page In"
}

# --- PHYSICAL MEMORY LAYOUT ---
physical_memory: Physical RAM Layout (8GB Total) {
  style.fill: ${colors.phys_mem}
  style.stroke-width: 4
  
  frame_0: "Frame 0: Kernel Space" { 
    style.fill: ${colors.padding}
    tooltip: "Base Address: 0x00000000"
  }
  frame_1: "Frame 1: Page Directory" { 
    style.fill: ${colors.header}
    style.double-border: true
  }
  frame_2: "Frame 2: User Process A Stack" { 
    style.fill: ${colors.data} 
  }
  frame_3: "Frame 3: Available/Free" { 
    style.fill: ${colors.free}
    style.stroke-dash: 4
  }
  frame_n: "Frame N: User Process B Heap" { 
    style.fill: ${colors.data} 
  }

  frame_1 -> frame_2: "Pointer to Page Table" { 
    style.stroke: orange
    style.stroke-width: 2
  }
}

# --- SWAP SPACE ---
swap_logic: Swap Space Controller (/dev/sda2) {
  style.fill: ${colors.swap}
  
  disk_read: "Disk I/O Controller" {
    shape: cylinder
    style.fill: white
  }
  
  swap_slots: {
    shape: sql_table
    label: "Kernel Swap Slot Map"
    "Slot 0": "VPN 0x00412" {constraint: "PID 101"}
    "Slot 1": "VPN 0x0088A" {constraint: "PID 101"}
    "Slot 2": "Free" {constraint: "AVAILABLE"}
    "Slot 3": "VPN 0x112FA" {constraint: "PID 205"}
  }
}

# --- REPLACEMENT ALGORITHMS ---
algorithms: Paging Replacement Strategies {
  grid-columns: 2
  
  fifo: FIFO Queue {
    tooltip: "First-In First-Out"
    label: "Head [ P3 | P2 | P1 ] Tail"
    style.fill: white
  }
  lru: LRU Stack {
    tooltip: "Least Recently Used"
    label: "Top [ P1 | P3 | P2 ] Bottom"
    style.stroke: blue
    style.fill: white
  }
  clock: "Clock Algorithm" {
    shape: circle
    label: "Pointer -> PTE Index 5 (Second Chance)"
    style.fill: white
  }
  optimal: "MIN (Optimal)" {
    style.double-border: true
    label: "Oracle Selection (Theoretical)"
    style.fill: white
  }
}

# --- C DATA STRUCTURE REPRESENTATION ---
internal_structs: |md
  ### Hardware Definitions
  c
  // Page Table Entry (Standard x86)
  typedef struct {
      uint32_t pfn : 20;      // Physical Frame Number
      uint32_t valid : 1;    // Present bit
      uint32_t readable : 1;
      uint32_t writable : 1;
      uint32_t dirty : 1;    // Written since last load
      uint32_t ref : 1;      // Used for LRU/Clock
      uint32_t unused : 7;   // OS Defined / Reserved
  } pte_t;

  // Replacement Context
  typedef enum {
      REPL_FIFO,
      REPL_LRU,
      REPL_CLOCK,
      REPL_OPTIMAL
  } repl_algo_t;
  
| {
  near: bottom-right
  shape: text
}

# --- GLOBAL CONNECTIONS ---
virtual_address.vpn_segment -> mmu_logic.check_tlb: "1. Virtual Index Request" {
  style.stroke-width: 2
  style.animated: true
}
mmu_logic.access_phys -> physical_memory.frame_2: "2. Calculated Physical Addr" {
  style.stroke: green
}
swap_logic.disk_read -> physical_memory.frame_3: "3. DMA: Transfer to RAM" {
  style.stroke: blue
}

# --- LEGEND ---
legend: {
  near: bottom-left
  style.fill: "#FFFFFF"
  style.stroke: "#000000"
  
  l1: "Header / Meta" { 
    style.fill: ${colors.header} 
  }
  l2: "Data / User" { 
    style.fill: ${colors.data} 
  }
  l3: "Free / Available" { 
    style.fill: ${colors.free} 
  }
  l4: "Swap / Disk" { 
    style.fill: ${colors.swap} 
  }
  l5: "Fault / Error" { 
    style.fill: ${colors.error} 
  }
}

# --- STATS ---
statistics: Real-time Translation Metrics {
  near: top-right
  style.fill: "#FFFDE7"
  
  total_access: "Total Accesses: 1,024,882"
  hits: "TLB Hit Ratio: 98.2%" { style.font-color: "#2E7D32" }
  faults: "Hard Page Faults: 12" { style.font-color: "#C62828" }
}