vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Memory Overhead: Multi-Level vs Flat Page Tables
| {near: top-center}
direction: right
container: "Process Address Space (Sparse)" {
  style.fill: "#E8F4FD"
  style.stroke: "#4A90D9"
  code: "Code Segment\n0x00400000\n(~4 MB)" {
    style.fill: "#C5E1A5"
    style.stroke: "#7CB342"
  }
  heap: "Heap Segment\n0x01000000\n(~50 MB)" {
    style.fill: "#FFCC80"
    style.stroke: "#F57C00"
  }
  stack: "Stack Segment\n0x7FFF0000\n(~8 MB)" {
    style.fill: "#B39DDB"
    style.stroke: "#7E57C2"
  }
  gap1: "Unmapped\n(empty)" {
    style.fill: "#E0E0E0"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 3
  }
  gap2: "Unmapped\n(empty)" {
    style.fill: "#E0E0E0"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 3
  }
  code -> gap1
  gap1 -> heap
  heap -> gap2
  gap2 -> stack
}
arrow: "│" {
  shape: text
  style.font-size: 40
}
flat: "Flat Page Table" {
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  label: "4 MB allocated\n(1,048,576 × 4 bytes)\n\n99%+ wasted on\nsparse address space"
  usage: "████████████████████████████████████████████████████████████████" {
    shape: text
    style.font-size: 20
    style.font-color: "#C62828"
  }
  stats_flat: |md
    **Total: 4,194,304 bytes**
    - Directory: N/A
    - Page tables: 4 MB
  |
}
multi: "Multi-Level Page Tables" {
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  dir: "Page Directory\n8 KB (1 × 1024 × 8)" {
    style.fill: "#81C784"
    style.stroke: "#388E3C"
  }
  pt1: "Page Table\n12 KB" {
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
  }
  pt2: "Page Table\n12 KB" {
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
  }
  pt3: "Page Table\n12 KB" {
    style.fill: "#A5D6A7"
    style.stroke: "#388E3C"
  }
  dir -> pt1
  dir -> pt2
  dir -> pt3
  stats_multi: |md
    **Total: 44 KB**
    - Directory: 8 KB
    - Page tables: 36 KB (3 tables)
    **Savings: 95× smaller**
  |
}
container -> arrow
arrow -> flat: "Wasteful\nallocation" {
  style.stroke: "#C62828"
  style.stroke-width: 3
  style.stroke-dash: 5
}
arrow -> multi: "On-demand\nallocation" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
legend: |md
  **Key Insight:** Multi-level tables only allocate
  storage for regions that are actually used.
  - Sparse address space → Massive savings
  - Dense address space → Modest overhead
  Real processes use <1% of their 4 GB address space.
| {near: bottom-center}