layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 20
  }
}

title: {
  shape: text
  label: |md
    # Virtual Memory Simulator: Address Translation Pipeline
    **Architecture Specification v1.0**
  |
  near: top-center
}

# ==================== STAGE 1: VIRTUAL ADDRESS ====================
VA: "Virtual Address: 0x00401234" {
  style: {
    fill: "#E8DFF5"
    stroke: "#8B5CF6"
    stroke-width: 2
  }
  
  va_bits: {
    shape: text
    label: |md
      ### 32-bit Virtual Address Decomposition
      | Field | Directory (10b) | Table (10b) | Offset (12b) |
      | :--- | :--- | :--- | :--- |
      | **Binary** | 0000000001 | 0000000001 | 001000110100 |
      | **Value** | Index: 1 | Index: 1 | 0x234 |
    |
    style.font-size: 12
  }
}

# ==================== STAGE 2: MMU & TLB ====================
MMU: "Memory Management Unit" {
  style: {
    stroke-dash: 5
    fill: "#F8FAFC"
  }
  
  TLB: "Translation Lookaside Buffer" {
    shape: hexagon
    style: {
      fill: "#FEF3C7"
      stroke: "#F59E0B"
      stroke-width: 2
    }
    specs: {
      shape: text
      label: |md
        **L1 TLB Cache Parameters**
        - Associativity: Fully-Associative
        - Tag: VPN (Virtual Page Number)
        - Value: PFN (Physical Frame Number)
        - ASID: Address Space ID Support
      |
      style.font-size: 10
    }
  }

  TLB_Hit: "TLB HIT\n(Fast Path)" {
    shape: diamond
    style: {
      fill: "#D1FAE5"
      stroke: "#10B981"
      stroke-width: 2
    }
  }

  TLB_Miss: "TLB MISS\n(Slow Path)" {
    shape: diamond
    style: {
      fill: "#FEE2E2"
      stroke: "#EF4444"
      stroke-width: 2
    }
  }
}

# ==================== STAGE 3: HIERARCHICAL PAGE WALK ====================
Page_Walk_Engine: {
  CR3: "CR3 Register\n(PDBR)" {
    shape: stored_data
    tooltip: "Control Register 3: Points to Page Directory Base"
    style: {
      fill: "#DBEAFE"
      stroke: "#3B82F6"
    }
  }

  PageDir: "Page Directory" {
    style: {
      fill: "#E0E7FF"
      stroke: "#6366F1"
      stroke-width: 2
    }
    PDE: "PDE [Dir Index 1]" {
      style: {
        fill: "#C7D2FE"
        stroke: "#4F46E5"
      }
      details: {
        shape: text
        label: |md
          **PDE Metadata:**
          - PT Base PFN: 0x2A
          - Present: 1
          - Read/Write: 1
          - User/Super: 0
        |
        style.font-size: 10
      }
    }
  }

  PageTable: "Page Table" {
    style: {
      fill: "#CCFBF1"
      stroke: "#14B8A6"
      stroke-width: 2
    }
    PTE: "PTE [Table Index 1]" {
      style: {
        fill: "#99F6E4"
        stroke: "#0D9488"
      }
      details: {
        shape: text
        label: |md
          **PTE Metadata:**
          - Frame PFN: 0x7F
          - Valid: 1
          - Dirty: 0
          - Accessed: 1
          - Protection: RWX
        |
        style.font-size: 10
      }
    }
  }
}

# ==================== STAGE 4: PHYSICAL ADDRESS ====================
PA: "Physical Address: 0x7F234" {
  style: {
    fill: "#DCFCE7"
    stroke: "#22C55E"
    stroke-width: 3
  }
  calc: {
    shape: text
    label: |md
      ### Final Physical Mapping
      | Component | PFN (20 bits) | Offset (12 bits) |
      | :--- | :--- | :--- |
      | **Hex Value** | 0x0007F | 0x234 |
      | **RAM Address** | 0x7F | 000 |
    |
    style.font-size: 12
  }
}

# ==================== INTERRUPTS & KERNEL ====================
OS_Kernel: "Kernel Mode Space" {
  PageFault: "ISR 14: Page Fault Handler" {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-dash: 3
    }
    actions: {
      shape: text
      label: |md
        **Exception Flow:**
        1. Context Switch to Ring 0
        2. Load CR2 with Faulting Address
        3. Identify Backing Store (Swap)
        4. Perform Disk I/O to PFN
      |
      style.font-size: 10
    }
  }

  Swap: "Swap Partition" {
    shape: cylinder
    style: {
      fill: "#F3E8FF"
      stroke: "#A855F7"
    }
  }

  ReplAlgo: "Page Eviction Logic" {
    style: {
      fill: "#FFF7ED"
      stroke: "#EA580C"
      stroke-dash: 3
    }
    desc: {
      shape: text
      label: |md
        **Policies:**
        - LRU (Least Recently Used)
        - Second Chance (Clock)
      |
    }
  }
}

ProtectionFault: "SIGSEGV\nProtection Violation" {
  shape: octagon
  style: {
    fill: "#FCA5A5"
    stroke: "#B91C1C"
    stroke-width: 2
  }
}

# ==================== CONNECTIONS ====================
VA -> MMU.TLB: "1. Virtual Tag Lookup" {
  style.stroke: "#8B5CF6"
}

MMU.TLB -> MMU.TLB_Hit: "Match Found"
MMU.TLB -> MMU.TLB_Miss: "Cache Miss"

MMU.TLB_Hit -> PA: "2a. Bypass Walk: Return PFN 0x7F" {
  style: {
    stroke: "#10B981"
    stroke-width: 4
  }
}

MMU.TLB_Miss -> Page_Walk_Engine.CR3: "2b. Page Walk Start" {
  style.stroke-dash: 3
}

Page_Walk_Engine.CR3 -> Page_Walk_Engine.PageDir: "Fetch Dir Base"
Page_Walk_Engine.PageDir -> Page_Walk_Engine.PageTable: "Fetch PT via PDE"
Page_Walk_Engine.PageTable -> PA: "3. Resolved PFN via PTE" {
  style.stroke: "#14B8A6"
}

Page_Walk_Engine.PageTable -> OS_Kernel.PageFault: "Present Bit = 0" {
  style: {
    stroke: "#DC2626"
    stroke-dash: 3
  }
}

Page_Walk_Engine.PageTable -> ProtectionFault: "ACL Permission Mismatch" {
  style.stroke: "#B91C1C"
}

OS_Kernel.PageFault <-> OS_Kernel.Swap: "Demand Paging I/O"
OS_Kernel.ReplAlgo -> OS_Kernel.Swap: "Select Victim Page"

# ==================== LEGEND & METRICS ====================
Legend: {
  near: bottom-right
  style.fill: "#F8FAFC"
  content: {
    shape: text
    label: |md
      ### Translation Architecture Legend
      - **Purple**: Virtual Context / Process Space
      - **Yellow**: Hardware Cache (TLB)
      - **Indigo/Teal**: Hierarchical Translation Structures
      - **Green**: Valid Physical Addressing
      - **Red**: Exceptions / Faults / Interrupts
    |
  }
}

Stats: "System Performance Telemetry" {
  near: bottom-left
  style.fill: "#F1F5F9"
  metrics: {
    shape: text
    label: |md
      ### Live Translation Metrics
      - **TLB Hit Rate**: 99.2%
      - **Mean Walk Latency**: 45 cycles
      - **Hard Fault Rate**: 0.002%
    |
  }
}

VA -> Stats: "Monitoring" {
  style: {
    stroke-dash: 5
    animated: true
  }
}