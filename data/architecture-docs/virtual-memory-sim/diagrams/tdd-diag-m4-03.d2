direction: right
title: |md
  # Virtual Memory Simulator
  **Complete Translation Pipeline**
| {near: top-center}
Virtual_Address: "0x00401234" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  style.font: mono
}
VA_decomposition: {
  grid-columns: 3
  grid-gap: 0
  header_row: {
    style.fill: "#4A4A4A"
    style.font-color: white
    style.bold: true
    label: "Bit Range | Field | Value"
  }
  dir_bits: "31-22 (10 bits)"
  table_bits: "21-12 (10 bits)"  
  offset_bits: "11-0 (12 bits)"
  dir_val: "Directory Index = 0x1"
  table_val: "Table Index = 0x1"
  offset_val: "Offset = 0x234"
}
VA_decomposition.header_row: "│ Bit Range │ Field │ Value │"
VA_decomposition.dir_bits: "│ 31-22 │ Dir Index │ 10 bits │"
VA_decomposition.table_bits: "│ 21-12 │ Table Index │ 10 bits │"
VA_decomposition.offset_bits: "│ 11-0 │ Offset │ 12 bits │"
translation_pipeline: {
  style.fill: "#F5F5F5"
  TLB: "TLB Lookup" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  TLB_hit: "HIT: Return PFN" {
    style.fill: "#90EE90"
  }
  TLB_miss: "MISS: Walk Page Table" {
    style.fill: "#FFB6C1"
  }
  check_PDE: "Check PDE\n(CR3 → dir[idx])" {
    shape: rectangle
    style.fill: "#E6E6FA"
  }
  PDE_present: "PDE.present?" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  alloc_table: "Allocate\nPage Table" {
    style.fill: "#87CEEB"
  }
  check_PTE: "Check PTE\n(table[idx])" {
    shape: rectangle
    style.fill: "#E6E6FA"
  }
  PTE_valid: "PTE.valid?" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  page_fault: "Page Fault\n(allocate frame)" {
    style.fill: "#FF6B6B"
  }
  check_perm: "Check\nPermissions" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  prot_fault: "Protection\nFault" {
    style.fill: "#FF6B6B"
  }
  update_bits: "Update\nref/dirty bits" {
    style.fill: "#87CEEB"
  }
  compose_PA: "Compose PA\n(pfn<<12)|offset" {
    style.fill: "#90EE90"
  }
  TLB -> TLB_hit: "found"
  TLB -> TLB_miss: "not found"
  TLB_hit -> compose_PA
  TLB_miss -> check_PDE
  check_PDE -> PDE_present
  PDE_present -> check_PTE: "yes"
  PDE_present -> alloc_table: "no"
  alloc_table -> check_PTE
  check_PTE -> PTE_valid
  PTE_valid -> check_perm: "yes"
  PTE_valid -> page_fault: "no"
  page_fault -> check_perm: "frame allocated"
  check_perm -> update_bits: "OK"
  check_perm -> prot_fault: "violation"
  update_bits -> compose_PA
}
stats_panel: {
  near: bottom-right
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
  stats_title: "Statistics" {
    style.bold: true
    style.underline: true
  }
  stat1: "• total_accesses: 1,247"
  stat2: "• tlb_hits: 1,198"
  stat3: "• tlb_misses: 49"
  stat4: "• page_faults: 23"
  stat5: "• tlb_hit_rate: 96.1%"
}
memory_hierarchy: {
  near: bottom-left
  L1_TLB: "L1 TLB\n(32 entries)" {
    shape: cylinder
    style.fill: "#FFE4B5"
  }
  Page_Tables: "Page Tables\n(in RAM)" {
    shape: cylinder
    style.fill: "#E6E6FA"
  }
  Physical_RAM: "Physical RAM\n(frame pool)" {
    shape: cylinder
    style.fill: "#87CEEB"
  }
  Swap: "Swap Space\n(disk)" {
    shape: cylinder
    style.fill: "#D3D3D3"
  }
  L1_TLB -> Page_Tables: "miss" {style.stroke-dash: 3}
  Page_Tables -> Physical_RAM: "translate"
  Physical_RAM -> Swap: "evict" {style.stroke-dash: 3; style.stroke: red}
  Swap -> Physical_RAM: "reload" {style.stroke-dash: 3; style.stroke: green}
}
legend: {
  near: top-right
  style.fill: "#F0F0F0"
  leg_title: "Pipeline Legend" {
    style.bold: true
  }
  fast: "Fast Path (TLB hit)" {
    style.fill: "#90EE90"
  }
  slow: "Slow Path (walk)" {
    style.fill: "#FFB6C1"
  }
  decision: "Decision Point" {
    style.fill: "#FFE4B5"
  }
  action: "Action/Update" {
    style.fill: "#87CEEB"
  }
  error: "Error/Fault" {
    style.fill: "#FF6B6B"
  }
}
Virtual_Address -> translation_pipeline.TLB