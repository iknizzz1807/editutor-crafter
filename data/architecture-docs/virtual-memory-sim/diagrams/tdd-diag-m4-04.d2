direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
}

classes: {
  memory_field: {
    style: {
      font: mono
      stroke-width: 1
    }
  }
  header: {
    style: {
      fill: "#6b46c1"
      font-color: white
      bold: true
    }
  }
  dirty: {
    style: {
      fill: "#feb2b2"
      stroke: red
      bold: true
    }
  }
  pointer: {
    style: {
      stroke: "#ed8936"
      stroke-width: 3
    }
  }
}

"FIFO Queue State Evolution": {
  "T0: Initial State": {
    shape: sql_table
    style.fill: "#f7fafc"
    header: "Queue Status: Empty" {class: header}
    slot0: "Frame 0: [ Empty ]"
    slot1: "Frame 1: [ Empty ]"
    slot2: "Frame 2: [ Empty ]"
  }

  "T1: Access VPN 1, 2, 3": {
    shape: sql_table
    style.fill: "#f7fafc"
    header: "Queue Status: Full" {class: header}
    slot0: "Frame 0: VPN 1" {style.fill: "#bee3f8"}
    slot1: "Frame 1: VPN 2" {style.fill: "#bee3f8"}
    slot2: "Frame 2: VPN 3" {style.fill: "#bee3f8"}
    
    "Head Pointer" -> slot0: "Next Victim" {class: pointer}
  }

  "T2: Page Fault (VPN 4)": {
    shape: sql_table
    style.fill: "#f7fafc"
    header: "Action: Evict VPN 1" {class: header}
    slot0: "Frame 0: VPN 4" {class: dirty}
    slot1: "Frame 1: VPN 2" {style.fill: "#bee3f8"}
    slot2: "Frame 2: VPN 3" {style.fill: "#bee3f8"}
    
    "Head Pointer" -> slot1: "Next Victim" {class: pointer}
    slot0 -> "Swap Disk": "Evict VPN 1" {style.stroke-dash: 5}
  }
}

"Memory Structure Definition": {
  "Page Table Entry (PTE)": {
    shape: sql_table
    style.stroke: "#4a5568"
    
    offset_0: "00: Physical Frame Number (PFN)" {class: memory_field}
    offset_20: "20: Valid Bit (V)" {style.fill: "#c6f6d5"}
    offset_21: "21: Referenced Bit (R)" {style.fill: "#c6f6d5"}
    offset_22: "22: Dirty Bit (D)" {style.fill: "#fed7d7"}
    offset_23: "23: Protection Bits" {style.fill: "#e2e8f0"}
    offset_31: "31: Reserved" {style.fill: gray}
    
    "Size: 32 bits (4 Bytes)": {
      near: bottom-center
      shape: text
    }
  }

  "Swap Map Entry": {
    shape: sql_table
    in_swap: "In Swap (Boolean)"
    slot_id: "Swap Slot Index (int)"
    vpn_ref: "Source VPN"
  }
}

"Page Fault Handler Flow": {
  shape: sequence_diagram
  
  "MMU"; "OS Kernel"; "Page Table"; "Swap Disk"
  
  "MMU" -> "OS Kernel": "Trap: Page Fault (VPN=4)"
  "OS Kernel" -> "OS Kernel": "replacement_select_victim()"
  "OS Kernel" -> "Page Table": "Invalidate Victim PTE"
  "OS Kernel" -> "Swap Disk": "Async Write (if dirty)"
  "OS Kernel" -> "Swap Disk": "Read VPN 4 into Frame"
  "Swap Disk" -> "OS Kernel": "I/O Complete"
  "OS Kernel" -> "Page Table": "Update PTE (PFN, Valid=1)"
  "OS Kernel" -> "MMU": "Invalidate TLB Entry"
  "OS Kernel" -> "MMU": "Retry Instruction"
}

"Bélády's Anomaly Analysis": {
  "Scenario: FIFO with 3 Frames": {
    "Access Pattern: 1, 2, 3, 4, 1, 2, 5, 1, 2, 3, 4, 5"
    "Total Faults: 9" {style.font-color: red}
  }
  
  "Scenario: FIFO with 4 Frames": {
    "Access Pattern: 1, 2, 3, 4, 1, 2, 5, 1, 2, 3, 4, 5"
    "Total Faults: 10 (Anomaly Detected!)" {style.font-color: red; style.bold: true}
  }
  
  "Scenario: FIFO with 3 Frames" -> "Scenario: FIFO with 4 Frames": "Comparison"
}

"Simulator Statistics": {
  shape: rectangle
  style: {
    stroke-dash: 3
    fill: "#edf2f7"
  }
  label: |md
    ### Runtime Counters
    - `stats.page_faults`: Total traps
    - `stats.swap_writes`: Dirty pages evicted
    - `stats.swap_reads`: Reloads from disk
    - `stats.tlb_hits`: Performance metric
    - `stats.clean_evictions`: Discarded pages
  |
}

"Page Table Entry (PTE)" -> "FIFO Queue State Evolution"."T2: Page Fault (VPN 4)": "Pfn Mapping"
"Memory Structure Definition"."Swap Map Entry" -> "Swap Disk": "Metadata"