layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    new: "#E53935"
    changed: "#FF9800"
    header: "#7B1FA2"
    data: "#1976D2"
    pointer: "#F57C00"
    free: "#388E3C"
    padding: "#BDBDBD"
    text: "#212121"
  }
}

title: |'md
  # LRU Replacement Algorithm State Transitions
  ## Implementation: Parallel Arrays with Monotonic Clock
  **sizeof(PageEntry) = 16 bytes (8B VPN + 8B Timestamp)**
'| {
  near: top-center
  style.stroke-width: 0
  style.font-size: 24
}

direction: right

# -----------------------------------------------------------------------------
# STEP 1: INITIAL INSERTION
# -----------------------------------------------------------------------------
step1: "STEP 1: INSERT (VPN 0x50)" {
  style.fill: "#F3E5F5"
  style.stroke: ${colors.header}
  style.stroke-width: 4
  
  explanation1: |'md
    ### New Page Load
    When a page fault occurs and a free frame is available, the new Virtual Page Number (VPN) is appended to the tracking structure.
    
    **Invariants:**
    - `count` incremented (4 -> 5)
    - `clock` reflects arrival time (500)
    - Free slot at `idx 4` is consumed
  '|
  
  state1: "Memory State @ Clock 500" {
    style.fill: white
    style.border-radius: 8
    
    vpns_arr1: "vpns[0..4] (Buffer: 0x1000)" {
      shape: sql_table
      style.fill: ${colors.data}
      "0x00 (+0B)": "0x10"
      "0x01 (+8B)": "0x20"
      "0x02 (+16B)": "0x30"
      "0x03 (+24B)": "0x40"
      "0x04 (+32B)": "0x50" {style.bold: true; style.stroke: ${colors.new}; style.stroke-width: 3}
    }
    
    ts_arr1: "timestamps[0..4] (Buffer: 0x2000)" {
      shape: sql_table
      style.fill: ${colors.data}
      "0x00 (+0B)": "100"
      "0x01 (+8B)": "200"
      "0x02 (+16B)": "300"
      "0x03 (+24B)": "400"
      "0x04 (+32B)": "500" {style.bold: true; style.stroke: ${colors.new}; style.stroke-width: 3}
    }
    
    meta1: "Management Block" {
      style.fill: ${colors.free}
      count: "count: 5"
      clock: "clock: 500"
    }
    
    vpns_arr1 -> ts_arr1: "Parallel Correlation" {style.stroke-dash: 3}
  }
}

# -----------------------------------------------------------------------------
# STEP 2: CACHE ACCESS (HIT)
# -----------------------------------------------------------------------------
step2: "STEP 2: ACCESS (VPN 0x40)" {
  style.fill: "#E3F2FD"
  style.stroke: ${colors.data}
  style.stroke-width: 4
  
  explanation2: |'md
    ### Page Hit Update
    VPN `0x40` is accessed. To maintain LRU order, its timestamp must be updated to the current global `clock`.
    
    **State Changes:**
    - Search `vpns[]` for `0x40` (Index 3)
    - Set `timestamps[3] = clock++`
    - VPN itself remains stationary (no reshuffling)
  '|
  
  state2: "Memory State @ Clock 600" {
    style.fill: white
    style.border-radius: 8
    
    vpns_arr2: "vpns[0..4]" {
      shape: sql_table
      style.fill: ${colors.data}
      "idx 0": "0x10"
      "idx 1": "0x20"
      "idx 2": "0x30"
      "idx 3": "0x40" {style.bold: true; style.stroke: ${colors.changed}; style.stroke-width: 3}
      "idx 4": "0x50"
    }
    
    ts_arr2: "timestamps[0..4]" {
      shape: sql_table
      style.fill: ${colors.data}
      "idx 0": "100"
      "idx 1": "200"
      "idx 2": "300"
      "idx 3": "**600**" {style.fill: ${colors.changed}; style.bold: true; style.stroke: black}
      "idx 4": "500"
    }
    
    meta2: "Management Block" {
      style.fill: ${colors.free}
      count: "count: 5"
      clock: "clock: **600**" {style.bold: true; style.stroke: ${colors.changed}}
    }
  }
}

# -----------------------------------------------------------------------------
# STEP 3: EVICTION SELECTION
# -----------------------------------------------------------------------------
step3: "STEP 3: EVICT (Select Victim)" {
  style.fill: "#FFEBEE"
  style.stroke: ${colors.new}
  style.stroke-width: 4
  
  explanation3: |'md
    ### Victim Selection
    Capacity reached. We must evict the page with the **minimum** timestamp.
    
    **Algorithm:**
    1. Scan `timestamps[]` -> Min is `100` @ Index 0.
    2. Evict VPN `0x10`.
    3. Swap tail (`idx 4`) to `idx 0` to maintain contiguous array.
    4. Set `count = 4`.
  '|
  
  state3: "Post-Eviction State" {
    style.fill: white
    style.border-radius: 8
    
    vpns_arr3: "vpns[0..3]" {
      shape: sql_table
      style.fill: ${colors.data}
      "idx 0": "0x50" {style.fill: ${colors.changed}; style.bold: true; style.stroke: black}
      "idx 1": "0x20"
      "idx 2": "0x30"
      "idx 3": "0x40"
      "idx 4": "FREE" {style.fill: ${colors.padding}; style.stroke-dash: 5}
    }
    
    ts_arr3: "timestamps[0..3]" {
      shape: sql_table
      style.fill: ${colors.data}
      "idx 0": "500" {style.fill: ${colors.changed}; style.bold: true; style.stroke: black}
      "idx 1": "200"
      "idx 2": "300"
      "idx 3": "600"
      "idx 4": "NULL" {style.fill: ${colors.padding}; style.stroke-dash: 5}
    }
    
    meta3: "Management Block" {
      style.fill: ${colors.free}
      count: "count: **4**" {style.bold: true; style.stroke: ${colors.new}}
      clock: "clock: 600"
    }
  }
}

# -----------------------------------------------------------------------------
# EVICTION PIPELINE (TECHNICAL DETAIL)
# -----------------------------------------------------------------------------
eviction_pipeline: "Victim Processing Pipeline" {
  style.stroke-dash: 5
  style.fill: "#FAFAFA"
  
  entry: ● {shape: circle}
  
  find_min: "Search Loop" {
    shape: parallelogram
    label: "arg_min(timestamps[])"
  }
  
  get_pte: "Load PTE" {
    label: "PTE = PageTable[victim_vpn]"
  }
  
  is_dirty: "PTE.dirty?" {
    shape: diamond
  }
  
  write_back: "Disk Swap Write" {
    style.fill: ${colors.new}
    style.font-color: white
    label: "io_submit(WRITE, swap_dev, page)"
  }
  
  inv_tlb: "TLB Shootdown" {
    label: "tlb_flush_addr(victim_vpn)"
    style.fill: ${colors.pointer}
    style.font-color: white
  }
  
  free_pfn: "Release PFN" {
    label: "buddy_free_page(PFN)"
    style.fill: ${colors.free}
    style.font-color: white
  }
  
  entry -> find_min -> get_pte -> is_dirty
  is_dirty -> write_back: "Yes (Dirty)"
  is_dirty -> inv_tlb: "No (Clean)"
  write_back -> inv_tlb
  inv_tlb -> free_pfn
}

# -----------------------------------------------------------------------------
# GLOBAL CONNECTIONS & LEGEND
# -----------------------------------------------------------------------------
step1 -> step2: "Page Hit: 0x40" {style.stroke-width: 3; style.animated: true}
step2 -> step3: "Capacity Full" {style.stroke-width: 3; style.animated: true}
step3 -> eviction_pipeline: "Execute Eviction" {
  style.stroke: ${colors.pointer}
  style.stroke-width: 2
}

time_complexity: |'md
  ### Performance Metrics
  | Operation | Complexity | Implementation Detail |
  | :--- | :--- | :--- |
  | **Insert** | O(1) | Append to `vpns[count++]` |
  | **Access** | O(N) | Sequential scan to find VPN index |
  | **Evict** | O(N) | Sequential scan for `min(timestamps)` |
  
  *Optimization Note: Replace parallel arrays with a Hash Map + Doubly Linked List for O(1) across all operations.*
'| {
  near: bottom-right
  style.fill: "#E8F5E9"
  style.stroke: ${colors.free}
}

legend: "Legend" {
  near: bottom-left
  
  l1: "New Data" { style.fill: ${colors.new}; style.font-color: white }
  l2: "Updated Value" { style.fill: ${colors.changed} }
  l3: "System Meta" { style.fill: ${colors.free}; style.font-color: white }
  l4: "HW Control" { style.fill: ${colors.pointer}; style.font-color: white }
  l5: "Padding / Free" { style.fill: ${colors.padding} }
}