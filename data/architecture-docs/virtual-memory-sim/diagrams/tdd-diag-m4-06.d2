layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
    pad: 40
  }
}

title: |md
  # Clock Algorithm: Victim Selection Process
  ## OS Virtual Memory Management - Page Replacement Logic
  ### Target: Intel x86-64 Memory Architecture
| {near: top-center}

# -----------------------------------------------------------------------------------------
# Legend: Engineering Specification
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-right
  style.fill: "#F8F9FA"
  style.stroke: "#B0B0B0"
  style.stroke-width: 1
  
  step_box: "Process Step" {
    shape: rectangle
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  
  decision_box: "Binary Decision" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#FFC107"
  }

  eviction_box: "Termination/Eviction" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#F44336"
    style.bold: true
  }

  boundary: "Page Boundary (4KB)" {
    style.stroke-width: 4
    style.stroke: "#333333"
  }
}

# -----------------------------------------------------------------------------------------
# Clock State Visualization: Physical Frames in Memory
# -----------------------------------------------------------------------------------------
clock_state: {
  label: "Clock Buffer State (Circular Frame Array)"
  style.fill: "#FFFFFF"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true

  # Circular buffer representation with ref bit status
  vpn0: "Frame 0\n[VPN: 0x0A]\nREF=1" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    tooltip: "Recently accessed. Will be skipped but REF bit will be reset."
  }
  vpn1: "Frame 1\n[VPN: 0x12]\nREF=0" {
    shape: rectangle
    style.fill: "#FFCDD2"
    style.stroke: "#C62828"
    style.stroke-width: 2
    tooltip: "Not accessed since last sweep. Primary candidate for eviction."
  }
  vpn2: "Frame 2\n[VPN: 0xBC]\nREF=1" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }
  vpn3: "Frame 3\n[VPN: 0x4F]\nREF=1" {
    shape: rectangle
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
  }

  # Pointer indicating current scan position
  hand: "CLOCK HAND" {
    shape: circle
    style.fill: "#D84315"
    style.font-color: white
    style.bold: true
  }

  hand -> vpn0: "Current Scan"
  vpn0 -> vpn1 -> vpn2 -> vpn3 -> vpn0: {
    style.stroke: "#9E9E9E"
    style.stroke-dash: 4
  }
}

# -----------------------------------------------------------------------------------------
# Algorithm Implementation Steps
# -----------------------------------------------------------------------------------------

# Step 1: Pre-condition Validation
step1: {
  label: "1.0 Validate Page Residency"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  width: 280
  content: |md
    **Interrupt Context:**
    - `page_fault_exception` triggered
    - `CR2` register contains fault addr
    - `lock(global_page_table)` acquired
  |
}

# Step 2: Iterator Initialization
step2: {
  label: "2.0 Initialize Sweep Cursor"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  width: 280
  content: |md
    c
    cursor = current_clock_hand;
    traversed_count = 0;
    max_frames = system.physical_pages;
    
  |
}

# Decision: Evaluate Reference Bit
decision1: {
  label: "3.0 Check\nREF[cursor]"
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#FFC107"
  width: 160
}

# Step 4a: Selection Path
step4a: {
  label: "4a. EVICT FRAME"
  style.fill: "#FFCDD2"
  style.stroke: "#F44336"
  style.bold: true
  width: 280
  content: |md
    **MMU Actions:**
    1. `victim_vpn = cursor.vpn`
    2. `INVPCID` / `INVLPG` (Flush TLB)
    3. `disk_write()` if `Dirty == 1`
    4. Update Reverse Mapping Table
  |
}

# Step 4b: Second Chance Path
step4b: {
  label: "4b. Reset Reference Bit"
  style.fill: "#FFE0B2"
  style.stroke: "#FF9800"
  width: 280
  content: |md
    **Hardware Update:**
    - `PTE.Accessed = 0`
    - Logic: "Second Chance" granted.
    - Cursor continues sweep.
  |
}

# Step 5: Advance Iteration
step5: {
  label: "5.0 Increment Cursor"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  width: 240
  content: |md
    c
    cursor = (cursor + 1) % max_frames;
    traversed_count++;
    
  |
}

# Decision: Boundary Check
decision2: {
  label: "6.0 Full Circle\nCompleted?"
  shape: diamond
  style.fill: "#FFF9C4"
  style.stroke: "#FFC107"
  width: 140
}

# Step 6: Fallback Strategy
step6: {
  label: "7.0 Force Eviction"
  style.fill: "#FFCDD2"
  style.stroke: "#F44336"
  width: 240
  content: |md
    **Overflow Handling:**
    All pages were recently used.
    Selection falls back to `cursor`
    to guarantee completion.
  |
}

# Step 7: Finalize State
step7: {
  label: "8.0 Update Global Pointer"
  style.fill: "#C8E6C9"
  style.stroke: "#4CAF50"
  width: 280
  content: |md
    **State Persistence:**
    - `current_clock_hand = cursor + 1`
    - Release page table lock
    - Signal page-in thread
  |
}

# Entry/Exit Nodes
START: {
  shape: circle
  style.fill: "#4CAF50"
  style.font-color: white
}
END: {
  shape: circle
  style.fill: "#212121"
  style.font-color: white
}

# -----------------------------------------------------------------------------------------
# Logical Flow Connections
# -----------------------------------------------------------------------------------------
START -> step1
step1 -> step2
step2 -> decision1

decision1 -> step4a: "REF == 0" {
  style.stroke: "#F44336"
  style.stroke-width: 3
}

decision1 -> step4b: "REF == 1" {
  style.stroke: "#FF9800"
  label: "Reset Accessed Bit"
}

step4b -> step5
step5 -> decision2

decision2 -> step6: "Yes (All REF were 1)" {
  style.stroke: "#F44336"
}

decision2 -> decision1: "No (Next Frame)" {
  style.stroke: "#2196F3"
  style.stroke-dash: 3
}

step4a -> step7
step6 -> step7
step7 -> END

# -----------------------------------------------------------------------------------------
# Documentation and Metadata
# -----------------------------------------------------------------------------------------
note: |md
  ### Algorithm Specification
  - **Complexity:** $O(n)$ worst case, $O(1)$ amortized.
  - **Hardware Support:** Requires 1-bit hardware 'Accessed' flag in PTE.
  - **Behavior:** Approximates LRU (Least Recently Used) via a single-pass circular sweep.
| {
  near: bottom-left
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#333333"
  style.stroke-dash: 2
}

# -----------------------------------------------------------------------------------------
# x86-64 Memory Layout (Root Level Shape)
# -----------------------------------------------------------------------------------------
PTE_LAYOUT: {
  near: bottom-center
  shape: sql_table
  style.fill: "#607D8B"
  style.font-color: white
  
  header: "Intel x86-64 Page Table Entry (4KB Page Mapping)"
  bit_63: "EXB: Execute-Disable (Bit 63)" {constraint: "1 bit"}
  bit_62_52: "OS Available / Protection Key" {constraint: "11 bits"}
  bit_51_12: "Page Frame Number (PFN)" {constraint: "40 bits"}
  bit_11_9: "OS Available" {constraint: "3 bits"}
  bit_8: "Global (G)" {constraint: "Bit 8"}
  bit_7: "PAT / Page Size (PS)" {constraint: "Bit 7"}
  bit_6: "Dirty (D)" {constraint: "Bit 6"}
  bit_5: "**Accessed (REF BIT)**" {style.fill: "#FFF176"; style.font-color: black; constraint: "Bit 5"}
  bit_4: "Cache Disable (PCD)" {constraint: "Bit 4"}
  bit_3: "Write Through (PWT)" {constraint: "Bit 3"}
  bit_2: "User/Supervisor (U/S)" {constraint: "Bit 2"}
  bit_1: "Read/Write (R/W)" {constraint: "Bit 1"}
  bit_0: "Present (P)" {constraint: "Bit 0"}
}