vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Page Reload from Swap
  ## Algorithm Flow: Restoring Evicted Pages to Physical Memory
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# STEP 1: INITIAL CHECK
# -----------------------------------------------------------------------------------------
step1: "1. CHECK SWAP MAP" {
  style.fill: "#F5F5F5"
  style.stroke: "#616161"
  style.border-radius: 10
  
  check: "swap_map[vpn].in_swap?" {
    shape: diamond
    style.fill: "#FFF9C4"
    style.stroke: "#FBC02D"
  }
  
  state: "State: [vpn=0x42]" {
    shape: rectangle
    label: |md
      **vpn_to_slot**: 0x42 -> Slot 721
      **in_swap**: true
    |
  }
}

# -----------------------------------------------------------------------------------------
# STEP 2: FRAME ALLOCATION
# -----------------------------------------------------------------------------------------
step2: "2. ALLOCATE FRAME" {
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.border-radius: 10
  
  alloc_logic: "Get Free Frame" {
    shape: rectangle
    label: |md
      **pfn = pop(free_list)**
      *Result: pfn=0x10A*
    |
    style.fill: "#BBDEFB"
  }
  
  free_list: "Free List" {
    shape: queue
    f1: "0x10A" { style.fill: "#C8E6C9"; style.bold: true; style.font-color: red }
    f2: "0x10B"
    f3: "0x10C"
  }
}

# -----------------------------------------------------------------------------------------
# STEP 3: DATA TRANSFER (MEMCPY)
# -----------------------------------------------------------------------------------------
step3: "3. MEMCPY FROM SWAP" {
  style.fill: "#F5F5F5"
  style.stroke: "#616161"
  style.border-radius: 10

  mem_ops: {
    grid-columns: 3
    grid-gap: 20
    
    src_addr: "SRC: Swap Slot 721" {
      style.fill: "#E1F5FE"
      style.stroke: "#03A9F4"
    }
    
    op: "== memcpy (4KB) ==>" {
      shape: text
      style.font-size: 14
      style.bold: true
    }
    
    dst_addr: "DST: Phys Frame 0x10A" {
      style.fill: "#E1F5FE"
      style.stroke: "#03A9F4"
    }
  }
  
  timing: "Latency: ~500 cycles" {
    shape: text
    style.italic: true
  }
}

# -----------------------------------------------------------------------------------------
# STEP 4: SWAP CLEANUP
# -----------------------------------------------------------------------------------------
step4: "4. FREE SWAP SLOT" {
  style.fill: "#F5F5F5"
  style.stroke: "#616161"
  style.border-radius: 10

  free_call: "swap_free(721)" {
    style.fill: "#C8E6C9"
    style.stroke: "#388E3C"
    style.bold: true
  }
  
  update_map: {
    label: |md
      **swap_map[0x42].in_swap** = <font color="red">**false**</font>
      **swap_map[0x42].slot** = <font color="red">**INVALID**</font>
    |
  }
}

# -----------------------------------------------------------------------------------------
# STEP 5: PAGE TABLE COMMIT
# -----------------------------------------------------------------------------------------
step5: "5. UPDATE PTE" {
  style.fill: "#EDE7F6"
  style.stroke: "#512DA8"
  style.border-radius: 10

  pte_64: "PTE Layout (64-bit)" {
    shape: sql_table
    00_47: "PFN (Page Frame Number)" { label: "0x10A"; style.fill: "#C8E6C9"; style.bold: true; style.font-color: red }
    48_62: "Reserved/Soft" { label: "0" }
    63_63: "Valid Bit" { label: "1 (SET)"; style.fill: "#C8E6C9"; style.bold: true; style.font-color: red }
  }
}

# -----------------------------------------------------------------------------------------
# FLOW CONNECTIONS
# -----------------------------------------------------------------------------------------
step1.check -> step2.alloc_logic: "True" {
  style.stroke: "#43A047"
  style.stroke-width: 3
}

step2.alloc_logic -> step3.mem_ops: "pfn assigned"
step3.mem_ops -> step4.free_call: "transfer complete"
step4.update_map -> step5.pte_64: "slot available"

# -----------------------------------------------------------------------------------------
# ANNOTATIONS & LEGEND (FIXED: CONSTANT VALUES FOR NEAR)
# -----------------------------------------------------------------------------------------
annotation: |md
  ## Hardware/Software Invariants
  1. **Atomicity**: The PTE Valid bit is the *final* operation. 
     If a fault occurs before Step 5, the state remains "In Swap".
  2. **Coherency**: Physical memory is not marked valid 
     until `memcpy` is fully fenced.
  3. **Zero-Fill**: If `in_swap` was false, Step 3 would be 
     `memset(dst, 0, PAGE_SIZE)`.

  ## Performance Targets
  - **L1/L2 Cache Pressure**: High during memcpy.
  - **I/O Wait**: Zero (assuming slot is in Kernel buffer cache).
  - **TLB**: Hardware automatically refills TLB on next access.
| {
  near: bottom-left
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 8
}

legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  style.border-radius: 8
  label: |md
    ### Legend
    - 🔴 **Red Text**: Mutated state / Changed value
    - 🟢 **Green Box**: Write Operation
    - 🟡 **Yellow Diamond**: Control Logic
    - 🔵 **Blue Box**: Resource Allocation
    - 🟣 **Purple Box**: Architectural Data Structure
  |
}

# -----------------------------------------------------------------------------------------
# STATISTICS (SIDEBAR)
# -----------------------------------------------------------------------------------------
stats: "Kernel Stats" {
  near: top-right
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  
  counters: {
    shape: sql_table
    faults: "page_faults_total"
    swap_in: "pg_swap_in" { label: "++ (Step 3)"; style.font-color: red }
    free_mem: "mem_free_kb" { label: "-4 KB"; style.font-color: red }
  }
}