vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

# ---------------------------------------------------------------------------------------
# DIAGRAM: COMPLETE FRAME EVICTION AND REPLACEMENT SEQUENCE
# DESCRIPTION: Detailed lifecycle of a physical frame during memory pressure.
# ---------------------------------------------------------------------------------------

MemoryManagementUnit: "MMU / Page Fault Handler" {
  shape: person
  tooltip: "Hardware component or trap handler managing address translation failures."
}

Kernel: "OS Kernel: Frame Manager" {
  style: {
    fill: "#E4DBFE"
    stroke: "#6772E5"
    stroke-width: 2
  }
}

FreeList: "Physical Free List" {
  shape: cylinder
  style.fill: "#D1FADF"
  label: "Free Frame Stack / Bitmap"
}

ReplacementEngine: "Replacement Algorithm\n(e.g., Clock / LRU)" {
  style.fill: "#C7F1FF"
}

PageTable: "Architectural Page Table" {
  shape: sql_table
  style.fill: "#DEE1EB"
  
  header: "PTE Layout"
  0: "PFN (bits 12-51)"
  1: "Reserved (bits 9-11)"
  2: "Dirty Bit (bit 6)"
  3: "Accessed Bit (bit 5)"
  4: "Present Bit (bit 0)"
}

SwapDisk: "Backing Store (Swap)" {
  shape: cylinder
  style.fill: "#FCE7C6"
}

# ---------------------------------------------------------------------------------------
# SEQUENCE START
# ---------------------------------------------------------------------------------------

shape: sequence_diagram

MemoryManagementUnit.t1 -> Kernel.allocate_frame: "1. allocate_frame()" {
  style: {
    stroke: "#2196F3"
    bold: true
  }
}

Kernel.t2 -> FreeList: "2. pop_free_frame()"
FreeList -> Kernel.t2: "3. return NULL (Full)" {
  style.stroke-dash: 5
}

# Phase: Eviction Triggered
Eviction_Process: "Eviction Logic Triggered" {
  Kernel.t3 -> Kernel.evict: "4. initiate_eviction_routine()"
  
  Kernel.t3 -> ReplacementEngine: "5. select_victim()"
  ReplacementEngine -> Kernel.t3: "6. victim_pfn (PFN 0x4A2)" {
    style.stroke-dash: 5
  }
}

# Phase: Consistency Check
Consistency_Check: "Dirty Bit Verification" {
  Kernel.t4 -> PageTable: "7. check_dirty_bit(victim_pfn)" {
    style.stroke-width: 3
  }
  PageTable -> Kernel.t4: "8. status: IS_DIRTY" {
    style.stroke-dash: 5
  }

  # Conditional Write to Disk
  Sync_To_Disk: "Write to Swap (If Dirty)" {
    Kernel.t5 -> SwapDisk: "9. write_page_to_disk(pfn_data)" {
      style: {
        stroke: orange
        animated: true
      }
    }
    SwapDisk -> Kernel.t5: "10. IO_COMPLETE" {
      style.stroke-dash: 5
    }
  }
}

# Phase: Finalization
Finalization: "Frame Reclamation" {
  Kernel.t6 -> PageTable: "11. invalidate_pte(victim_vpn)" {
    style: {
      stroke: "#F44336"
      stroke-width: 3
    }
  }
  
  Kernel.t6 -> Kernel.clear_frame: "12. zero_memory_contents()"
  
  Kernel.t7 -> MemoryManagementUnit.t7: "13. return_pfn(0x4A2)" {
    style: {
      stroke: "#4CAF50"
      bold: true
    }
  }
}

# ---------------------------------------------------------------------------------------
# ANNOTATIONS & INVARIANTS
# ---------------------------------------------------------------------------------------

# Global participant styling for consistency
*.style.font: mono

Legend: {
  near: bottom-right
  
  Invariants: |md
    ### Architectural Invariants
    - **PTE_INVALID**: Bit 0 must be cleared *before* PFN is returned to caller to prevent stale access.
    - **ATOMICITY**: The replacement engine state (Clock hand position/LRU list) must be updated immediately after selection.
    - **TLB_FLUSH**: A global or process-specific TLB shootdown (invlpg) is required across all cores after Step 11.
    - **ZERO_FILL**: Frame scrubbing (Step 12) is mandatory to prevent cross-process info leakage.
  |
}

# Metadata positioning
title: "Intel x86-64 Memory Management - Frame Eviction Lifecycle" {
  near: top-center
  style.font-size: 24
  style.bold: true
}