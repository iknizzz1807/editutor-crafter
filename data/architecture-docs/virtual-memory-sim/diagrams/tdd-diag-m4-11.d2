vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 20
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    free: "#10B981"
    padding: "#9CA3AF"
    pointer: "#F59E0B"
    highlight: "#EF4444"
    text: "#1F2937"
    bg_light: "#F9FAFB"
  }
}

title: |'md
  # Bélády's Anomaly Demonstration
  ### Algorithm Analysis: FIFO Page Replacement
  **Access String:** `1, 2, 3, 4, 1, 2, 5, 1, 2, 3, 4, 5`
'| {
  near: top-center
  style: {
    font-size: 28
    bold: true
    font-color: ${colors.header}
  }
}

direction: right

simulation: "Simulation Workspace" {
  style: {
    fill: "#FFFFFF"
    stroke: "#D1D5DB"
    stroke-width: 1
    stroke-dash: 5
  }

  c3: "3 Physical Frames (Base Case)" {
    style: {
      fill: ${colors.bg_light}
      stroke: ${colors.data}
      stroke-width: 2
      border-radius: 8
    }

    step1: |'md
      **Step 1-3**: Warmup
      Frames: `[1] [2] [3]`
      *Initial Page Faults: 3*
    '| {shape: text}
    
    step2: |'md
      **Step 4**: Request [4]
      Frames: `[4] [2] [3]` 
      *(Evicted 1 - Oldest)*
    '| {shape: text}
    
    step3: |'md
      **Step 5-6**: Req [1, 2]
      `[4] [1] [3]` (Evict 2)
      `[4] [1] [2]` (Evict 3)
    '| {shape: text}
    
    step4: |'md
      **Step 7**: Request [5]
      `[5] [1] [2]` 
      *(Evicted 4 - Oldest)*
    '| {shape: text}
    
    step5: |'md
      **Step 8-9**: Req [1, 2]
      `[5] [1] [2]`
      **STATUS: HIT** (No faults)
    '| {shape: text}
    
    step6: |'md
      **Step 10-12**: Final
      `[5] [3] [2]` (Evict 1)
      `[5] [3] [4]` (Evict 2)
      `[5] [3] [4]` **HIT**
    '| {shape: text}
    
    result1: |'md
      ### TOTAL: 9 Page Faults
    '| {
      shape: text
      style: {
        bold: true
        fill: ${colors.free}
        font-color: white
        border-radius: 4
      }
    }
    
    step1 -> step2 -> step3 -> step4 -> step5 -> step6 -> result1
  }

  c4: "4 Physical Frames (Anomaly Case)" {
    style: {
      fill: ${colors.bg_light}
      stroke: ${colors.highlight}
      stroke-width: 4
      border-radius: 8
      shadow: true
    }

    step7: |'md
      **Step 1-4**: Warmup
      Frames: `[1] [2] [3] [4]`
      *Initial Page Faults: 4*
    '| {shape: text}
    
    step8: |'md
      **Step 5-6**: Req [1, 2]
      `[1] [2] [3] [4]`
      **STATUS: HIT**
    '| {shape: text}
    
    step9: |'md
      **Step 7**: Request [5]
      `[5] [2] [3] [4]` 
      *(Evicted 1 - Oldest)*
    '| {shape: text}
    
    step10: |'md
      **Step 8-10**: Req [1, 2, 3]
      `[5] [1] [3] [4]` (Evict 2)
      `[5] [1] [2] [4]` (Evict 3)
      `[5] [1] [2] [3]` (Evict 4)
    '| {shape: text}
    
    step11: |'md
      **Step 11**: Req [4]
      `[4] [1] [2] [3]`
      *(Evicted 5 - Oldest)*
    '| {shape: text}
    
    step12: |'md
      **Step 12**: Req [5]
      `[4] [5] [2] [3]`
      *(Evicted 1 - Oldest)*
    '| {shape: text}
    
    result2: |'md
      ### TOTAL: 10 Page Faults
      ⚠️ **ANOMALY DETECTED**
    '| {
      shape: text
      style: {
        bold: true
        fill: ${colors.highlight}
        font-color: white
        border-radius: 4
      }
    }
    
    step7 -> step8 -> step9 -> step10 -> step11 -> step12 -> result2
  }

  c5: "5 Physical Frames (Optimal Limit)" {
    style: {
      fill: ${colors.bg_light}
      stroke: ${colors.free}
      stroke-width: 2
      border-radius: 8
    }

    step13: |'md
      **Step 1-5**: Fill all
      Frames: `[1] [2] [3] [4] [5]`
      *Initial Page Faults: 5*
    '| {shape: text}
    
    step14: |'md
      **Step 6-12**: Sequence
      Working Set fits entirely.
      **All subsequent requests are hits.**
    '| {shape: text}
    
    result3: |'md
      ### TOTAL: 5 Page Faults
    '| {
      shape: text
      style: {
        bold: true
        fill: ${colors.free}
        font-color: white
        border-radius: 4
      }
    }
    
    step13 -> step14 -> result3
  }
}

summary: |'md
  ## Deterministic Analysis
  **Bélády's Anomaly** occurs when increasing the number of page frames results in an increase in the number of page faults for certain access patterns. This is primarily a characteristic of non-stack-based replacement algorithms like **FIFO**.

  ### Fault Comparison Table
  | Frame Count | FIFO Faults | LRU (Stack-based) | Anomaly? |
  |-------------|-------------|-------------------|----------|
  | 3 Frames    | 9           | 9                 | No       |
  | 4 Frames    | **10**      | 8                 | **YES**  |
  | 5 Frames    | 5           | 5                 | No       |

  **Root Cause:** FIFO does not respect the "Stack Property". In stack algorithms (like LRU), the set of pages in memory for $n$ frames is always a subset of the pages in memory for $n+1$ frames. FIFO violates this, leading to the anomaly where more memory equals worse performance.
'| {
  near: bottom-center
  shape: text
  style: {
    fill: "#F3F4F6"
    border-radius: 12
    stroke: "#D1D5DB"
  }
}

c3 -> c4: "Increase Available RAM" {
  style: {
    stroke: ${colors.pointer}
    stroke-width: 2
  }
}

c4 -> c5: "Increase Available RAM" {
  style: {
    stroke: ${colors.pointer}
    stroke-width: 2
  }
}

c4 -> summary: "Observed Behavior" {
  style: {
    stroke-dash: 5
    stroke: ${colors.highlight}
  }
}