vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Virtual Memory Simulator
  ## Module 4: Statistics Collection Points & Metrics Definition
| {
  near: top-center
  shape: text
}

Collection_Points: "Statistics Collection Logic" {
  style: {
    stroke: "#333333"
    fill: "#f8f9fa"
    stroke-width: 2
  }

  Hot_Path: "High Frequency (Hot Path)" {
    style.fill: "#fff5f5"
    
    Working_Set_Update: "Working Set Update" {
      tooltip: "Updated on every memory access"
      performance: "1 cycle"
      temperature: "Hot (热)"
    }
    
    Swap_Slot_Allocation: "Swap Slot Allocation" {
      tooltip: "Bitmap search for free swap page"
      performance: "1 cycle"
      temperature: "Hot (热)"
    }
    
    Stats_Counter_Increment: "Statistics Update" {
      tooltip: "Atomic increment of global counters"
      performance: "1 cycle"
      temperature: "Hot (热)"
    }
  }

  Warm_Path: "Medium Frequency (Warm Path)" {
    style.fill: "#fffaf0"
    
    Thrashing_Detection: "Thrashing Detection" {
      tooltip: "Scan of page fault frequency window"
      performance: "Sequential scan"
      temperature: "Warm (暖)"
    }
    
    Replacement_Algorithm: "Replacement Logic" {
      tooltip: "LRU/FIFO/Clock pointer movement"
      performance: "Varying"
      temperature: "Warm (暖)"
    }
  }

  Cold_Path: "Low Frequency (Cold Path / I/O)" {
    style.fill: "#f0f7ff"
    
    Swap_Write_Page: "Swap Page Write" {
      tooltip: "Memcpy to buffer + Disk I/O + Metadata Update"
      performance: "Cold"
      temperature: "Cold (冷)"
    }
    
    Swap_Read_Page: "Swap Page Read" {
      tooltip: "Disk I/O + Page Table Update"
      performance: "Cold"
      temperature: "Cold (冷)"
    }
    
    Eviction_Process: "Eviction + Write-back" {
      tooltip: "Selection of victim and dirty bit check"
      performance: "Many"
      temperature: "Cold (冷)"
    }
  }
}

Metric_Registry: {
  shape: sql_table
  label: "Stats Counter Definitions (u64)"
  
  swap_writes: "Dirty pages written to disk" {constraint: "u64_counter"}
  swap_reads: "Pages retrieved from disk" {constraint: "u64_counter"}
  swap_discards: "Clean pages dropped" {constraint: "u64_counter"}
  total_evictions: "Sum of all page evictions" {constraint: "u64_counter"}
  dirty_evictions: "Evictions requiring write" {constraint: "u64_counter"}
  clean_evictions: "Evictions without write" {constraint: "u64_counter"}
  thrashing_events: "Detection triggers" {constraint: "u64_counter"}
}

Fault_Analysis: "Algorithm Fault Tracking" {
  grid-columns: 2
  grid-gap: 20
  
  FIFO: "FIFO Faults" {
    style.fill: "#DEE1EB"
  }
  LRU: "LRU Faults" {
    style.fill: "#DEE1EB"
  }
  CLOCK: "Clock Faults" {
    style.fill: "#DEE1EB"
  }
  OPTIMAL: "Optimal Faults" {
    style.fill: "#DEE1EB"
  }
}

# Documentation and Descriptions
Implementation_Notes: |md
  ### Latency Definitions
  - **Hot (热):** Executed in the critical path of memory access. Must be O(1).
  - **Warm (暖):** Executed periodically (e.g., every T ticks) or on page faults.
  - **Cold (冷):** Involves physical I/O or heavy metadata updates.
  
  ### Counter Logic
  - `dirty_evictions` incremented only if `PTE_DIRTY` bit is set.
  - `thrashing_warnings` triggered when fault frequency > `THRASH_THRESHOLD`.
| {
  near: bottom-center
  shape: text
}

# Logical Data Flow Connections
Collection_Points.Cold_Path.Swap_Write_Page -> Metric_Registry.swap_writes: "inc()"
Collection_Points.Cold_Path.Swap_Read_Page -> Metric_Registry.swap_reads: "inc()"
Collection_Points.Warm_Path.Thrashing_Detection -> Metric_Registry.thrashing_events: "inc()"
Collection_Points.Cold_Path.Eviction_Process -> Metric_Registry.total_evictions: "inc()"

Collection_Points.Warm_Path.Replacement_Algorithm -> Fault_Analysis: "Update Counts" {
  style.stroke-dash: 3
}