direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  # Technical Color Palette - Intel Manual Grade
  colors: {
    header: "#5B33FF"
    data: "#4A90E2"
    free: "#90EE90"
    pointer: "#F4A261"
    padding: "#9E9E9E"
    error: "#ca052b"
    success: "#3d9069"
    border: "#2C3E50"
  }
}

# -----------------------------------------------------------------------------------------
# 1. MEMORY LAYOUT DIAGRAM (64-BYTE CACHE LINE / PAGE FRAME METADATA)
# -----------------------------------------------------------------------------------------

memory_metadata: "Physical Memory Layout (Page Frame)" {
  tooltip: "Structure of a single 64B Cache Line / Page Metadata Block"
  grid-columns: 1
  grid-gap: 0
  
  # sizeof=64 bytes (one cache line)

  pte_header: "0x00 | PTE_HEADER (8B)" {
    tooltip: "Page Table Entry Metadata: [V|D|A|W|U|G]"
    height: 40
    style: {
      fill: ${vars.colors.header}
      font-color: white
      bold: true
      stroke: ${vars.colors.border}
    }
  }

  frame_0: "0x08 | FRAME_0 (RESIDENT) (8B)" {
    tooltip: "Active Memory Page - Ref Count: 4"
    height: 40
    style.fill: ${vars.colors.data}
    style.stroke: ${vars.colors.border}
  }

  frame_1: "0x10 | FRAME_1 (RESIDENT) (8B)" {
    height: 40
    style.fill: ${vars.colors.data}
    style.stroke: ${vars.colors.border}
  }

  frame_2_free: "0x18 | FRAME_2 (FREE) (8B)" {
    tooltip: "Available for Allocation"
    height: 40
    style: {
      fill: ${vars.colors.free}
      stroke-dash: 3
      stroke: ${vars.colors.border}
    }
  }

  frame_3: "0x20 | FRAME_3 (RESIDENT) (8B)" {
    height: 40
    style.fill: ${vars.colors.data}
    style.stroke: ${vars.colors.border}
  }

  padding_block: "0x28 | ALIGNMENT_PAD (8B)" {
    height: 20
    style.fill: ${vars.colors.padding}
    style.stroke: ${vars.colors.border}
  }

  control_ptr: "0x30 | LRU_META_PTR (8B)" {
    tooltip: "Virtual Address of Eviction Logic State"
    height: 40
    style: {
      fill: ${vars.colors.pointer}
      double-border: true
      stroke: ${vars.colors.border}
    }
  }

  crc_footer: "0x38 | CRC_FOOTER (8B)" {
    height: 40
    style.fill: ${vars.colors.header}
    style.font-color: white
    style.stroke: ${vars.colors.border}
  }
}

annotation_block: |md
  ### Block Specification
  - **Total Size:** 64 Bytes (aligned to cache line)
  - **PTE Flags:** `0x00000001` (Present)
  - **Dirty Bit:** `0x00000040` (Set on Write)
|
annotation_block.shape: text
annotation_block.near: memory_metadata.bottom-center

# -----------------------------------------------------------------------------------------
# 2. ALGORITHM STATE (LRU EVICTION SIMULATION)
# -----------------------------------------------------------------------------------------

algorithm_analysis: "Replacement Algorithm Analysis" {
  style.fill: "#fdfdfd"
  style.stroke: "#BDC3C7"
  
  reference_string: |md
    ### Demand Paging Trace
    `[1, 2, 5, 1, 2, 3, 4, 1, 2, 5]`
    
    **Current State:** T=6
    **Input:** Request Page 3
  |
  reference_string.shape: sticky_note

  lru_stack: "LRU Aging Stack State" {
    direction: down
    
    mru: "MRU (Most Recently Used): Page 5" {
      style.fill: ${vars.colors.data}
    }
    page_2: "Page 2" {
      style.fill: ${vars.colors.data}
    }
    victim: "Victim Candidate: Page 1" {
      tooltip: "Oldest access timestamp. Evicting..."
      style: {
        fill: white
        stroke: ${vars.colors.error}
        stroke-width: 5
        bold: true
      }
    }
    
    mru -> page_2 -> victim: "Age Increase"
  }
}

# -----------------------------------------------------------------------------------------
# 3. ARCHITECTURE / PIPELINE (EVICTION LOGIC)
# -----------------------------------------------------------------------------------------

eviction_pipeline: "Eviction Management Pipeline" {
  style.fill: "#F4F7F6"
  style.stroke: "#2C3E50"
  
  controller: "EvictionController::Process()" {
    shape: rectangle
    style.fill: "#F8F9F9"
    style.bold: true

    pipeline_grid: {
      grid-columns: 3
      grid-gap: 20
      
      select_victim: "1. Select Victim\n(LRU/Clock)" {
        shape: diamond
        style.fill: white
      }
      
      dirty_check: "2. Is Page Dirty?" {
        shape: diamond
        style.fill: white
      }
      
      write_swap: "3. Write to NVMe\n(Swap Device)" {
        shape: rectangle
        style.stroke: ${vars.colors.error}
      }
      
      update_pte: "4. Clear Valid Bit\n(PTE.V = 0)" {
        style.fill: ${vars.colors.header}
        style.font-color: white
      }
      
      tlb_inval: "5. INVLPG" {
        tooltip: "Invalidate TLB hardware cache for consistency"
        shape: parallelogram
      }
      
      release_frame: "6. Free List\nUpdate" {
        style.fill: ${vars.colors.free}
      }
    }

    # Internal Logic Flow
    pipeline_grid.select_victim -> pipeline_grid.dirty_check: "Candidate ID"
    pipeline_grid.dirty_check -> pipeline_grid.write_swap: "Dirty == 1"
    pipeline_grid.dirty_check -> pipeline_grid.update_pte: "Clean"
    pipeline_grid.write_swap -> pipeline_grid.update_pte: "I/O Done"
    pipeline_grid.update_pte -> pipeline_grid.tlb_inval
    pipeline_grid.tlb_inval -> pipeline_grid.release_frame
  }
}

# -----------------------------------------------------------------------------------------
# 4. EXTERNAL INTERFACES & STORAGE
# -----------------------------------------------------------------------------------------

swap_device: "NVMe Swap Storage\n/dev/nvme0n1p2" {
  shape: cylinder
  style.fill: "#FFF3E0"
  style.stroke: "#E67E22"
}

kernel_telemetry: "Kernel Stats / SNMP" {
  style.fill: "#E8F5E9"
}

kernel_metrics_md: |md
  | Metric | Current |
  | :--- | :--- |
  | Page Faults | 1,402 |
  | Swap Outs | 243 |
  | IO Wait | 0.8ms |
|
kernel_metrics_md.shape: text
kernel_metrics_md.near: kernel_telemetry.center-center

# -----------------------------------------------------------------------------------------
# 5. INTEGRATED COMPONENT FLOWS
# -----------------------------------------------------------------------------------------

# Trigger eviction from memory pointer to Controller
memory_metadata.control_ptr -> eviction_pipeline.controller.pipeline_grid.select_victim: "ACCESS_THRES_INT" {
  style: {
    stroke: ${vars.colors.pointer}
    stroke-width: 4
    animated: true
  }
}

# Swap Write Interaction
eviction_pipeline.controller.pipeline_grid.write_swap -> swap_device: "DMA_PWRITE" {
  style.stroke: ${vars.colors.error}
  style.stroke-width: 2
}

# Swap-In flow to the free frame
swap_device -> memory_metadata.frame_2_free: "PAGE_REFILL" {
  style: {
    stroke: ${vars.colors.success}
    stroke-width: 3
    stroke-dash: 5
  }
}

# Logic provider link
algorithm_analysis.lru_stack.victim -> eviction_pipeline.controller.pipeline_grid.select_victim: "Victim_ID" {
  style.stroke-dash: 5
}

# Telemetry Updates
eviction_pipeline.controller.pipeline_grid.release_frame -> kernel_metrics_md: "PUSH_STATS" {
  style: {
    stroke: grey
    opacity: 0.6
  }
}

# -----------------------------------------------------------------------------------------
# 6. LEGEND & ANNOTATIONS
# -----------------------------------------------------------------------------------------

legend: "System Legend" {
  near: bottom-right
  l_meta: "Metadata / Header" {
    shape: rectangle
    style.fill: ${vars.colors.header}
    style.font-color: white
  }
  l_data: "Resident Memory" {
    shape: rectangle
    style.fill: ${vars.colors.data}
  }
  l_free: "Unallocated Frame" {
    shape: rectangle
    style.fill: ${vars.colors.free}
  }
  l_flow: "Critical Data Path" {
    style.stroke: ${vars.colors.pointer}
    style.stroke-width: 3
  }
}