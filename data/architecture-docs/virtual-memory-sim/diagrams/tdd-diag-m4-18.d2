vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#8B5CF6"
    data: "#3B82F6"
    pointer: "#F59E0B"
    free: "#10B981"
    padding: "#9CA3AF"
    swap-bg: "#1E1B4B"
    swap-data: "#6366F1"
    swap-meta: "#A78BFA"
    flag-true: "#22C55E"
    flag-false: "#EF4444"
    border: "#4B5563"
  }
}

title: |md
  # swap_mapping_t Memory Layout
  ### Per-VPN Swap Tracking Structure (Intel-Manual Quality Spec)
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# 1. MEMORY LAYOUT DEFINITION
# -----------------------------------------------------------------------------------------
swap_mapping_structure: {
  shape: sql_table
  label: "swap_mapping_t (sizeof=8 bytes / 64-bit aligned)"
  style: {
    stroke: ${colors.header}
    stroke-width: 4
    fill: "#1F2937"
    font-color: white
    shadow: true
  }

  # Offset | Field Name | Type/Size | Description
  0x00: "swap_slot: int32_t (4 Bytes)" {constraint: "Data"}
  0x04: "in_swap: bool (1 Byte)" {constraint: "Flag"}
  0x05: "_padding: uint8_t[3] (3 Bytes)" {constraint: "Padding"}
  0x08: "Total: 8 Bytes" {constraint: "[END_OF_STRUCT]"}
}

# Row-level styling for the SQL Table
swap_mapping_structure.0x00.style.fill: ${colors.data}
swap_mapping_structure.0x04.style.fill: ${colors.flag-true}
swap_mapping_structure.0x05.style.fill: ${colors.padding}
swap_mapping_structure.0x08.style.fill: ${colors.header}

# -----------------------------------------------------------------------------------------
# 2. RUNTIME STATE MACHINE
# -----------------------------------------------------------------------------------------
state_diagram: {
  near: top-right
  label: "Runtime State Transitions (swap_mapping_t)"
  style: {
    fill: "#0F172A"
    stroke: ${colors.header}
    stroke-width: 2
    border-radius: 8
  }

  not_in_swap: |md
    **NOT_IN_SWAP**
    ---
    `in_swap` = false
    `swap_slot` = -1
  | {
    shape: rectangle
    style: {
      fill: "#1E293B"
      stroke: ${colors.free}
      font-color: white
      stroke-width: 3
    }
  }

  in_swap_state: |md
    **IN_SWAP**
    ---
    `in_swap` = true
    `swap_slot` = [0..n]
  | {
    shape: rectangle
    style: {
      fill: "#1E293B"
      stroke: ${colors.swap-meta}
      font-color: white
      stroke-width: 3
    }
  }

  illegal_state: "INVALID" {
    style: {
      fill: "#450A0A"
      stroke: ${colors.flag-false}
      font-color: white
    }
  }

  not_in_swap -> in_swap_state: "Page Eviction\nAlloc slot + Disk Write" {
    style: {
      stroke: ${colors.swap-meta}
      animated: true
      stroke-width: 2
    }
  }
  
  in_swap_state -> not_in_swap: "Page Fault\nDisk Read + Free slot" {
    style: {
      stroke: ${colors.free}
      animated: true
      stroke-width: 2
    }
  }

  not_in_swap -> illegal_state: "ILLEGAL" {
    style: {
      stroke: ${colors.flag-false}
      stroke-dash: 3
    }
  }
}

# -----------------------------------------------------------------------------------------
# 3. TECHNICAL SPECIFICATIONS & LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent

  grid: {
    grid-columns: 1
    grid-gap: 10
    
    title: "**Field Purpose & Architectural Invariants**" {shape: text}

    item1: "swap_slot (4B): Primary index into global swap_space. Required for disk sector calculation." {
      shape: rectangle
      style.fill: ${colors.data}
      style.font-color: white
      width: 600
    }

    item2: "in_swap (1B): Atomic flag. If true, MMU must trigger Page Fault for disk fetching." {
      shape: rectangle
      style.fill: ${colors.flag-true}
      style.font-color: white
      width: 600
    }

    item3: "_padding (3B): Ensures the next struct in an array is 8-byte (64-bit) aligned." {
      shape: rectangle
      style.fill: ${colors.padding}
      style.font-color: white
      width: 600
    }
  }
}

# -----------------------------------------------------------------------------------------
# 4. IMPLEMENTATION CODE (C-SPEC)
# -----------------------------------------------------------------------------------------
code_implementation: |go
  /* swap_types.h - Implementation Grade C struct */
  #include <stdint.h>
  #include <stdbool.h>

  /**
   * Represents the swap metadata for a single virtual page.
   * Packed to 8 bytes for cache efficiency and VPN indexing.
   */
  typedef struct {
      int32_t swap_slot;   /* 0:4 - Index into backing storage */
      bool    in_swap;     /* 4:5 - Validity flag */
      uint8_t _padding[3]; /* 5:8 - 64-bit alignment padding */
  } swap_mapping_t;

  /* Static Assertion: Validate structure layout for Intel x86_64 */
  _Static_assert(sizeof(swap_mapping_t) == 8, "swap_mapping_t size mismatch");
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#1E1B4B"
    font-color: "#E2E8F0"
    font: mono
    stroke: ${colors.pointer}
    stroke-width: 2
  }
}

# -----------------------------------------------------------------------------------------
# 5. GLOBAL CALLOUTS
# -----------------------------------------------------------------------------------------
size_callout: |md
  ### TOTAL SIZE: 8 BYTES
  **Natural Alignment: 4-byte**
  **Padded Alignment: 8-byte**
  **Cache Line Usage: 1/8th of 64B**
| {
  near: bottom-right
  shape: text
  style: {
    font-color: ${colors.header}
    bold: true
    font-size: 18
  }
}

# Annotations for Engineers
swap_mapping_structure.0x00 -> state_diagram.not_in_swap: "Value is -1" {
  style.stroke: ${colors.pointer}
  style.stroke-dash: 5
}

swap_mapping_structure.0x04 -> state_diagram.in_swap_state: "Flag is 0x01" {
  style.stroke: ${colors.pointer}
  style.stroke-dash: 5
}