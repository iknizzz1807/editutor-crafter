vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#7C3AED"
    data: "#3B82F6"
    free: "#10B981"
    padding: "#9CA3AF"
    pointer: "#F59E0B"
    highlight: "#EF4444"
    swap: "#8B5CF6"
    flow: "#6366F1"
    success: "#22C55E"
    fault: "#F97316"
    intel_bg: "#f8f9fa"
  }
}

title: |md
  # MMU Translation Pipeline: VA [31:0] → PA [31:0]
  **Hardware Interface Specification**
  Architecture: 32-bit x86-like (Two-level Page Table)
  Page Size: 4096 Bytes (12-bit offset)
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------
# Input Stage: Virtual Address Decomposition
# -----------------------------------------------------------------------------
input: {
  style.fill: "${colors.header}"
  style.stroke: "${colors.header}"
  style.font-color: white
  style.border-radius: 8
  label: "Stage 0: CPU VA Generation"

  trace: {
    shape: hexagon
    style.fill: "${colors.intel_bg}"
    style.stroke: "${colors.header}"
    style.font-color: black
    label: "Memory Trace\nFETCH 0xADDR"
  }

  va_extract: {
    shape: class
    label: "VA Decomposition [32-bit]"
    vpn_high: "Directory Index [31:22] (10 bits)"
    vpn_low: "Table Index [21:12] (10 bits)"
    offset: "Page Offset [11:0] (12 bits)"
  }
}

# -----------------------------------------------------------------------------
# TLB Stage: Associative Cache Lookup
# -----------------------------------------------------------------------------
tlb_stage: {
  style.fill: "${colors.data}"
  style.stroke: "${colors.data}"
  style.font-color: white
  style.border-radius: 8
  label: "Stage 1: TLB Cache (Associative Search)"

  tlb_search: {
    shape: diamond
    label: "VPN Tag\nMatch?"
    style.fill: white
    style.font-color: black
  }

  tlb_hit: {
    shape: oval
    style.fill: "${colors.success}"
    label: "HIT"
  }

  tlb_miss: {
    shape: oval
    style.fill: "${colors.fault}"
    label: "MISS"
  }

  tlb_entry: {
    shape: class
    label: "TLB Slot Layout (64-bits)"
    vpn: "Tag (VPN): 20 bits"
    pfn: "Data (PFN): 20 bits"
    asid: "ASID: 8 bits"
    v: "Valid: 1 bit"
    prot: "R/W/X: 3 bits"
    status: "D/A (Dirty/Accessed): 2 bits"
    lru: "LRU Counter: 10 bits"
  }
}

# -----------------------------------------------------------------------------
# Page Table Stage: Radix Tree Walk
# -----------------------------------------------------------------------------
pt_stage: {
  style.fill: "${colors.pointer}"
  style.stroke: "${colors.pointer}"
  style.font-color: white
  style.border-radius: 8
  label: "Stage 2: Page Table Walk (Hardware MMU)"

  cr3: {
    shape: cylinder
    label: "CR3 Control Reg\n(Page Dir Base PFN)"
    style.fill: white
    style.font-color: black
  }

  walk_logic: {
    shape: sequence_diagram
    MMU
    RAM
    MMU -> RAM: "Read PDE [CR3 + Index1*4]"
    RAM -> MMU: "Return PDE (PFN of PT)"
    MMU -> RAM: "Read PTE [PT_PFN + Index2*4]"
    RAM -> MMU: "Return PTE (Final PFN)"
  }

  pde: {
    shape: class
    label: "PDE (4 Bytes)"
    pt_base: "PT PFN [31:12]"
    flags: "G/PS/A/CD/WT/U/W/P"
  }

  pte: {
    shape: class
    label: "PTE (4 Bytes)"
    pfn: "Physical Frame [31:12]"
    flags: "G/PAT/D/A/CD/WT/U/W/P"
  }
}

# -----------------------------------------------------------------------------
# Physical Memory & Replacement
# -----------------------------------------------------------------------------
memory_subsystem: {
  phys_mem: {
    style.fill: "${colors.free}"
    style.stroke: "${colors.free}"
    style.font-color: white
    style.border-radius: 8
    label: "Physical RAM"

    frame_pool: {
      shape: class
      label: "Frame Metadata"
      free_list: "Next Free: 0xXXXX"
      usage_map: "Bitmap[PFN]"
    }

    frame_data: {
      shape: rectangle
      width: 150
      label: "Frame [4KB]\nRaw Bytes"
      style.fill: white
      style.font-color: black
    }
  }

  replacement: {
    style.fill: "${colors.fault}"
    style.stroke: "${colors.fault}"
    style.font-color: white
    label: "Replacement Logic"

    check_free: {
      shape: diamond
      label: "RAM Full?"
    }

    algorithms: {
      grid-columns: 2
      grid-gap: 5
      fifo: "FIFO (Queue)"
      lru: "LRU (Stack)"
      clock: "Clock (Ref Bit)"
      opt: "Optimal"
      fifo.style.fill: "${colors.intel_bg}"
      lru.style.fill: "${colors.intel_bg}"
      clock.style.fill: "${colors.intel_bg}"
      opt.style.fill: "${colors.intel_bg}"
      fifo.style.font-color: black
      lru.style.font-color: black
      clock.style.font-color: black
      opt.style.font-color: black
    }
  }
}

# -----------------------------------------------------------------------------
# Swap Stage: Disk Backing Store
# -----------------------------------------------------------------------------
swap_stage: {
  style.fill: "${colors.swap}"
  style.stroke: "${colors.swap}"
  style.font-color: white
  style.border-radius: 8
  label: "Secondary Storage (Swap)"

  dirty_check: {
    shape: diamond
    label: "Is Victim\nDirty?"
    style.fill: white
    style.font-color: black
  }

  io_ops: {
    write: "DISK WRITE\n(Store Victim)"
    read: "DISK READ\n(Fetch Required)"
    write.style.fill: "${colors.highlight}"
    read.style.fill: "${colors.success}"
  }

  swap_struct: {
    shape: class
    label: "Swap Slot Table"
    slot_id: "slot: uint32"
    location: "LBA Offset: uint64"
  }
}

# -----------------------------------------------------------------------------
# Final PA Output
# -----------------------------------------------------------------------------
output: {
  style.fill: "${colors.success}"
  style.stroke: "${colors.success}"
  style.font-color: white
  label: "Stage 3: PA Generation"

  compose: {
    shape: rectangle
    label: "PA = (PFN << 12) | Offset"
    style.fill: white
    style.font-color: black
  }

  pa_final: {
    shape: hexagon
    label: "Physical Address"
  }
}

# -----------------------------------------------------------------------------
# Connections
# -----------------------------------------------------------------------------
input.trace -> input.va_extract
input.va_extract -> tlb_stage.tlb_search

tlb_stage.tlb_search -> tlb_stage.tlb_hit: "Tag Match"
tlb_stage.tlb_search -> tlb_stage.tlb_miss: "Tag Mismatch"

tlb_stage.tlb_hit -> output.compose: "PFN Found" {
  style.stroke: "${colors.success}"
  style.stroke-width: 4
}

tlb_stage.tlb_miss -> pt_stage.cr3: "Walk Trigger"

pt_stage.cr3 -> pt_stage.walk_logic
pt_stage.walk_logic -> pt_stage.pte

pt_stage.pte -> memory_subsystem.phys_mem.frame_data: "Present=1"
pt_stage.pte -> memory_subsystem.replacement.check_free: "Present=0 (Fault)"

memory_subsystem.replacement.check_free -> memory_subsystem.replacement.algorithms: "Full"
memory_subsystem.replacement.algorithms -> swap_stage.dirty_check: "Victim Chosen"

swap_stage.dirty_check -> swap_stage.io_ops.write: "Dirty=1"
swap_stage.dirty_check -> memory_subsystem.phys_mem.frame_data: "Dirty=0 (Evict)"

swap_stage.io_ops.write -> swap_stage.swap_struct
swap_stage.swap_struct -> swap_stage.io_ops.read: "Load New Page"
swap_stage.io_ops.read -> memory_subsystem.phys_mem.frame_data

memory_subsystem.phys_mem.frame_data -> output.compose
output.compose -> output.pa_final

# -----------------------------------------------------------------------------
# Footnotes & Legends (ELK Compatible)
# -----------------------------------------------------------------------------
technical_notes: {
  near: bottom-left
  style.stroke: "${colors.padding}"
  style.fill: white
  label: "Technical Implementation Notes"

  tlb_note: |md
    **TLB Policy**
    Fully associative lookup. 
    Parallel tag comparison 
    against all 64-1024 entries.
  |
  fault_note: |md
    **Fault Latency**
    L1 TLB: ~1 cycle
    PT Walk: ~30-100 cycles
    Swap IO: ~5ms - 20ms
  |
}

pipeline_legend: {
  near: bottom-right
  style.stroke: "${colors.padding}"
  style.fill: white
  label: "Pipeline Legend"

  hit: "━━━ Fast Path" {
    style.font-color: "${colors.success}"
  }
  miss: "━━━ PT Walk" {
    style.font-color: "${colors.flow}"
  }
  fault: "━━━ IO/Swap" {
    style.font-color: "${colors.swap}"
  }
}

# Counters
stats: {
  near: top-right
  shape: class
  label: "Simulation Monitors"
  tlb_hr: "TLB Hit Rate: %"
  pf_count: "Page Faults: N"
  wb_count: "Writebacks: N"
  cycles: "Total Cycles: uint64"
}