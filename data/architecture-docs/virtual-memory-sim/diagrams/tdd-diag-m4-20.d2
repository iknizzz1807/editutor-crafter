vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#7C3AED"
    data: "#3B82F6"
    pointer: "#F59E0B"
    free: "#10B981"
    padding: "#6B7280"
    transition: "#DC2626"
    stat_normal: "#3B82F6"
    stat_error: "#EF4444"
    stat_swap: "#8B5CF6"
  }
}
title: |md
  # Statistics State Transitions
  When Each Counter Increments During Memory Operations
| {near: top-center}
direction: right
# ============================================
# STATISTICS CATEGORIES
# ============================================
stats_categories: {
  label: ""
  access_stats: "Access Statistics" {
    style.fill: "${colors.data}"
    style.font-color: white
    total: "total_accesses\nuint64_t" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
    tlb_hits: "tlb_hits\nuint64_t" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
    tlb_misses: "tlb_misses\nuint64_t" {
      style.fill: "${colors.data}"
      style.font-color: white
    }
  }
  fault_stats: "Fault Statistics" {
    style.fill: "${colors.header}"
    style.font-color: white
    page_faults: "page_faults\nuint64_t" {
      style.fill: "${colors.header}"
      style.font-color: white
    }
    protection: "protection_faults\nuint64_t" {
      style.fill: "${colors.header}"
      style.font-color: white
    }
    dir_not_present: "dir_not_present\nuint64_t" {
      style.fill: "${colors.header}"
      style.font-color: white
    }
  }
  swap_stats: "Swap Statistics" {
    style.fill: "${colors.stat_swap}"
    style.font-color: white
    swap_writes: "swap_writes\nuint64_t" {
      style.fill: "${colors.stat_swap}"
      style.font-color: white
    }
    swap_reads: "swap_reads\nuint64_t" {
      style.fill: "${colors.stat_swap}"
      style.font-color: white
    }
    swap_discards: "swap_discards\nuint64_t" {
      style.fill: "${colors.stat_swap}"
      style.font-color: white
    }
  }
  eviction_stats: "Eviction Statistics" {
    style.fill: "${colors.pointer}"
    style.font-color: white
    evictions: "evictions\nuint64_t" {
      style.fill: "${colors.pointer}"
      style.font-color: white
    }
    dirty_evictions: "dirty_evictions\nuint64_t" {
      style.fill: "${colors.pointer}"
      style.font-color: white
    }
  }
  thrashing_stats: "Thrashing Statistics" {
    style.fill: "${colors.stat_error}"
    style.font-color: white
    thrashing_warnings: "thrashing_warnings\nuint64_t" {
      style.fill: "${colors.stat_error}"
      style.font-color: white
    }
  }
}
# ============================================
# TRANSITION TRIGGERS
# ============================================
triggers: {
  label: ""
  # M1 Triggers
  m1_translate: "translate_address()\nCalled" {
    shape: circle
    style.fill: "${colors.data}"
    style.font-color: white
    style.stroke-width: 2
  }
  m1_valid_check: "PTE.valid == false" {
    shape: diamond
    style.fill: "${colors.header}"
    style.font-color: white
  }
  m1_perm_check: "Permission\nViolation" {
    shape: diamond
    style.fill: "${colors.stat_error}"
    style.font-color: white
  }
  # M2 Triggers
  m2_tlb_lookup: "TLB Lookup" {
    shape: diamond
    style.fill: "${colors.data}"
    style.font-color: white
  }
  m2_tlb_hit: "TLB Entry\nFound" {
    shape: circle
    style.fill: "${colors.free}"
    style.font-color: white
  }
  m2_tlb_miss: "TLB Entry\nNot Found" {
    shape: circle
    style.fill: "${colors.header}"
    style.font-color: white
  }
  # M3 Triggers
  m3_pde_check: "PDE.present == false" {
    shape: diamond
    style.fill: "${colors.header}"
    style.font-color: white
  }
  # M4 Triggers
  m4_eviction: "Eviction\nRequired" {
    shape: circle
    style.fill: "${colors.pointer}"
    style.font-color: white
  }
  m4_dirty_check: "PTE.dirty == true" {
    shape: diamond
    style.fill: "${colors.stat_swap}"
    style.font-color: white
  }
  m4_reload_check: "swap_map[vpn].in_swap" {
    shape: diamond
    style.fill: "${colors.stat_swap}"
    style.font-color: white
  }
  m4_ws_check: "working_set_size > frames" {
    shape: diamond
    style.fill: "${colors.stat_error}"
    style.font-color: white
  }
}
# ============================================
# CONNECTIONS - Transition Flow
# ============================================
# M1 Flow
m1_translate -> m1_valid_check: "Check valid bit"
m1_valid_check -> stats_categories.fault_stats.page_faults: "YES: ++page_faults" {
  style.stroke: "${colors.header}"
  style.stroke-width: 3
  style.bold: true
}
m1_valid_check -> m1_perm_check: "NO: Check permissions"
m1_perm_check -> stats_categories.fault_stats.protection: "Violation: ++protection_faults" {
  style.stroke: "${colors.stat_error}"
  style.stroke-width: 3
}
m1_translate -> stats_categories.access_stats.total: "Always: ++total_accesses" {
  style.stroke: "${colors.data}"
  style.stroke-width: 3
  style.bold: true
}
# M2 Flow
m2_tlb_lookup -> m2_tlb_hit: "Entry found"
m2_tlb_lookup -> m2_tlb_miss: "Entry not found"
m2_tlb_hit -> stats_categories.access_stats.tlb_hits: "++tlb_hits" {
  style.stroke: "${colors.free}"
  style.stroke-width: 3
  style.bold: true
}
m2_tlb_miss -> stats_categories.access_stats.tlb_misses: "++tlb_misses" {
  style.stroke: "${colors.header}"
  style.stroke-width: 3
  style.bold: true
}
# M3 Flow
m3_pde_check -> stats_categories.fault_stats.dir_not_present: "++dir_not_present" {
  style.stroke: "${colors.header}"
  style.stroke-width: 3
}
# M4 Flow - Eviction
m4_eviction -> stats_categories.eviction_stats.evictions: "++evictions" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 3
  style.bold: true
}
m4_eviction -> m4_dirty_check: "Check dirty bit"
m4_dirty_check -> stats_categories.swap_stats.swap_writes: "Dirty: ++swap_writes" {
  style.stroke: "${colors.stat_swap}"
  style.stroke-width: 3
  style.bold: true
}
m4_dirty_check -> stats_categories.swap_stats.swap_discards: "Clean: ++swap_discards" {
  style.stroke: "${colors.padding}"
  style.stroke-width: 2
}
# M4 Flow - Reload
m4_reload_check -> stats_categories.swap_stats.swap_reads: "In swap: ++swap_reads" {
  style.stroke: "${colors.stat_swap}"
  style.stroke-width: 3
  style.bold: true
}
# M4 Flow - Thrashing
m4_ws_check -> stats_categories.thrashing_stats.thrashing_warnings: "Thrashing: ++warnings" {
  style.stroke: "${colors.stat_error}"
  style.stroke-width: 3
  style.bold: true
}
# ============================================
# LEGEND
# ============================================
legend: {
  label: "Transition Rules"
  near: bottom-center
  rule1: "total_accesses: EVERY translate call" {
    style.fill: "${colors.data}"
    style.font-color: white
  }
  rule2: "page_faults: PTE.valid == false" {
    style.fill: "${colors.header}"
    style.font-color: white
  }
  rule3: "tlb_hits/misses: TLB lookup result" {
    style.fill: "${colors.free}"
    style.font-color: white
  }
  rule4: "swap_writes: Dirty page eviction" {
    style.fill: "${colors.stat_swap}"
    style.font-color: white
  }
  rule5: "swap_reads: Page reload from swap" {
    style.fill: "${colors.stat_swap}"
    style.font-color: white
  }
  rule6: "thrashing_warnings: WS > frames" {
    style.fill: "${colors.stat_error}"
    style.font-color: white
  }
}
# ============================================
# MILESTONE ANNOTATIONS
# ============================================
milestone_labels: {
  label: ""
  m1_label: "M1: Single-Level\nPage Table" {
    shape: text
    style.font-color: "${colors.data}"
    style.bold: true
  }
  m2_label: "M2: TLB\nCaching" {
    shape: text
    style.font-color: "${colors.free}"
    style.bold: true
  }
  m3_label: "M3: Multi-Level\nPage Tables" {
    shape: text
    style.font-color: "${colors.header}"
    style.bold: true
  }
  m4_label: "M4: Page\nReplacement" {
    shape: text
    style.font-color: "${colors.stat_swap}"
    style.bold: true
  }
}
milestone_labels.m1_label -> stats_categories.access_stats.total: "M1" {
  style.stroke-dash: 3
  style.stroke: "${colors.padding}"
}
milestone_labels.m2_label -> m2_tlb_lookup: "M2" {
  style.stroke-dash: 3
  style.stroke: "${colors.padding}"
}
milestone_labels.m3_label -> m3_pde_check: "M3" {
  style.stroke-dash: 3
  style.stroke: "${colors.padding}"
}
milestone_labels.m4_label -> m4_eviction: "M4" {
  style.stroke-dash: 3
  style.stroke: "${colors.padding}"
}