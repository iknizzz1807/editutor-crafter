direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Analysis Phase: Building Transaction & Dirty Page Tables
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  log_segment: {
    direction: down
    label: Log Segment (scan forward from checkpoint_lsn)
    rec1: {
      label: "LSN 100"
      shape: rectangle
      width: 200
      code: |'c
        BEGIN {txn_id: 1}
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    rec2: {
      label: "LSN 150"
      shape: rectangle
      width: 200
      code: |'c
        UPDATE {txn:1, page:5, offset:0}
      '|
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    rec3: {
      label: "LSN 200"
      shape: rectangle
      width: 200
      code: |'c
        BEGIN {txn_id: 2}
      '|
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
    }
    rec4: {
      label: "LSN 250"
      shape: rectangle
      width: 200
      code: |'c
        UPDATE {txn:2, page:7, offset:16}
      '|
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    rec5: {
      label: "LSN 300"
      shape: rectangle
      width: 200
      code: |'c
        COMMIT {txn_id: 1}
      '|
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
    rec6: {
      label: "LSN 350"
      shape: rectangle
      width: 200
      code: |'c
        UPDATE {txn:1, page:5, offset:32}
      '|
      style.fill: "#E3F2FD"
      style.stroke: "#2196F3"
    }
    rec7: {
      label: "LSN 400"
      shape: rectangle
      width: 200
      code: |'c
        [END OF LOG]
      '|
      style.fill: "#FAFAFA"
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
    }
    rec1 -> rec2 -> rec3 -> rec4 -> rec5 -> rec6 -> rec7: {style.stroke: transparent}
  }
  processing: {
    direction: down
    label: Processing Rules
    width: 280
    rule_begin: {
      label: "On BEGIN"
      shape: rectangle
      code: |'c
        // Add to txn_table
        txn_table[txn_id] = {
          status: ACTIVE,
          first_lsn: record.lsn,
          last_lsn: record.lsn
        }
      '|
      style.fill: "#E8F5E9"
    }
    rule_update: {
      label: "On UPDATE"
      shape: rectangle
      code: |'c
        // Update txn last_lsn
        txn_table[txn_id].last_lsn = lsn;
        // Add page to DPT if absent
        if (!dpt.contains(page_id)) {
          dpt[page_id] = {rec_lsn: lsn};
        }
      '|
      style.fill: "#E3F2FD"
    }
    rule_commit: {
      label: "On COMMIT"
      shape: rectangle
      code: |'c
        // Mark committed
        txn_table[txn_id].status = COMMITTED;
        txn_table[txn_id].last_lsn = lsn;
      '|
      style.fill: "#FFF3E0"
    }
    rule_begin -> rule_update -> rule_commit: {style.stroke: transparent}
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  txn_table_final: {
    label: "Transaction Table (after scan)"
    shape: sql_table
    style.fill: "#E8F5E9"
    h1: "txn_id | status | first_lsn | last_lsn"
    t1r1: "1 | COMMITTED | 100 | 300"
    t1r2: "2 | ACTIVE | 200 | 250"
    note1: "Only ACTIVE txns need undo"
  }
  dpt_final: {
    label: "Dirty Page Table (after scan)"
    shape: sql_table
    style.fill: "#E3F2FD"
    h2: "page_id | rec_lsn"
    dpt1: "5 | 150"
    dpt2: "7 | 250"
    note2: "min(rec_lsn) = redo start point"
  }
  recovery_state: {
    label: "Recovery State Summary"
    shape: rectangle
    width: 300
    summary: |md
      **After Analysis Phase:**
      - **T1**: Committed → No undo needed
      - **T2**: Active → Will need undo
      **Redo Start Point:**
      `min_rec_lsn = min(150, 250) = 150`
      Redo will replay from LSN 150 forward
    |
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
  }
}
legend: {
  near: bottom-center
  direction: right
  style.stroke: transparent
  style.fill: transparent
  leg1: {
    label: "BEGIN"
    shape: rectangle
    width: 80
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
  }
  leg2: {
    label: "UPDATE"
    shape: rectangle
    width: 80
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
  }
  leg3: {
    label: "COMMIT"
    shape: rectangle
    width: 80
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
  }
}
log_segment.rec1 -> processing.rule_begin: "scan" {style.stroke-dash: 3}
log_segment.rec2 -> processing.rule_update: "scan" {style.stroke-dash: 3}
log_segment.rec5 -> processing.rule_commit: "scan" {style.stroke-dash: 3}
processing.rule_begin -> txn_table_final: "builds" {style.stroke: "#4CAF50"}
processing.rule_update -> dpt_final: "builds" {style.stroke: "#2196F3"}
processing.rule_commit -> txn_table_final: "updates" {style.stroke: "#FF9800"}