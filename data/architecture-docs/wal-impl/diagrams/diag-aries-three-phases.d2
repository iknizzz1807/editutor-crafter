direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: ARIES Three-Phase Recovery Overview {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  log_store: {
    label: WAL Log Storage
    direction: down
    style.fill: "#E8F4FD"
    checkpoint_rec: {
      label: "Checkpoint Record"
      shape: rectangle
      style.fill: "#FFE4B5"
      width: 140
    }
    log_records: {
      label: "Log Records\n(BEGIN/UPDATE/\nCOMMIT/CLR/ABORT)"
      shape: cylinder
      style.fill: "#E8F4FD"
      width: 140
    }
    checkpoint_rec -> log_records: "scan forward"
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  analysis_phase: {
    label: "PHASE 1: Analysis"
    direction: down
    style.fill: "#D4EDDA"
    width: 220
    scan_log: {
      label: "Scan log from\ncheckpoint_lsn"
      shape: rectangle
      style.fill: "#C3E6CB"
    }
    build_tables: {
      label: "Build Tables"
      shape: rectangle
      style.fill: "#C3E6CB"
      width: 180
    }
    txn_table: {
      shape: sql_table
      label: "Transaction Table"
      f1: "txn_id | uint32"
      f2: "status | ACTIVE/COMMITTED/ABORTED"
      f3: "first_lsn | uint64"
      f4: "last_lsn | uint64"
      sz: "Active txns need undo"
    }
    dpt: {
      shape: sql_table
      label: "Dirty Page Table"
      f1: "page_id | uint64"
      f2: "rec_lsn | uint64"
      note: "rec_lsn = first dirty LSN"
    }
    scan_log -> build_tables
    build_tables -> txn_table
    build_tables -> dpt
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  redo_phase: {
    label: "PHASE 2: Redo"
    direction: down
    style.fill: "#FFF3CD"
    width: 240
    find_start: {
      label: "Find min(rec_lsn)\nfrom Dirty Page Table"
      shape: diamond
      style.fill: "#FFEAA7"
    }
    replay_all: {
      label: "Replay ALL Updates\n(committed + uncommitted)"
      shape: rectangle
      style.fill: "#FFEAA7"
      width: 200
    }
    idempotency: {
      label: "Skip if pageLSN >= record.lsn\n(idempotency check)"
      shape: diamond
      style.fill: "#FFEAA7"
    }
    apply_change: {
      label: "Apply after-image\nUpdate pageLSN"
      shape: rectangle
      style.fill: "#FFEAA7"
    }
    find_start -> replay_all
    replay_all -> idempotency
    idempotency -> apply_change: "pageLSN < lsn"
  }
}
row4: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  undo_phase: {
    label: "PHASE 3: Undo"
    direction: down
    style.fill: "#F8D7DA"
    width: 220
    find_active: {
      label: "Find ACTIVE txns\nfrom Transaction Table"
      shape: diamond
      style.fill: "#F5C6CB"
    }
    priority_queue: {
      label: "Priority Queue\nby LSN descending\n(across ALL active txns)"
      shape: queue
      style.fill: "#F5C6CB"
    }
    undo_record: {
      label: "Apply before-image\nWrite CLR record"
      shape: rectangle
      style.fill: "#F5C6CB"
    }
    follow_chain: {
      label: "Follow prev_lsn chain\n(or undo_next_lsn from CLR)"
      shape: rectangle
      style.fill: "#F5C6CB"
    }
    find_active -> priority_queue: "has active"
    priority_queue -> undo_record
    undo_record -> follow_chain
    follow_chain -> priority_queue: "more to undo"
  }
}
row5: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  consistent_db: {
    label: "Consistent Database"
    direction: down
    style.fill: "#D4EDDA"
    width: 200
    committed: {
      label: "✓ Committed txns\npresent"
      shape: rectangle
      style: {
        fill: "#C3E6CB"
        font-color: "#155724"
      }
    }
    uncommitted: {
      label: "✗ Uncommitted txns\nrolled back"
      shape: rectangle
      style: {
        fill: "#F8D7DA"
        font-color: "#721C24"
      }
    }
    ready: {
      label: "Ready for\nnormal operation"
      shape: oval
      style.fill: "#C3E6CB"
    }
    committed -> ready
    uncommitted -> ready
  }
}
row1.log_store -> row2.analysis_phase: "checkpoint_lsn" {
  style: {
    stroke: "#0066CC"
    stroke-width: 2
  }
}
row2.analysis_phase -> row3.redo_phase: "Dirty Page Table\nmin(rec_lsn)" {
  style: {
    stroke: "#28A745"
    stroke-width: 2
  }
}
row3.redo_phase -> row4.undo_phase: "Transaction Table\nACTIVE status" {
  style: {
    stroke: "#FFC107"
    stroke-width: 2
  }
}
row4.undo_phase -> row5.consistent_db: "All ACTIVE rolled back" {
  style: {
    stroke: "#DC3545"
    stroke-width: 2
  }
}
legend: {
  near: bottom-center
  direction: right
  style: {
    fill: "#F8F9FA"
    stroke: "#DEE2E6"
    border-radius: 4
  }
  l1: {
    label: "Redo: Replays ALL changes"
    shape: text
    style.font-color: "#856404"
  }
  l2: {
    label: "Undo: Only ACTIVE txns"
    shape: text
    style.font-color: "#721C24"
  }
  l3: {
    label: "CLR: Crash-safe undo"
    shape: text
    style.font-color: "#004085"
  }
}