direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# --- ROOT LEVEL DEFINITIONS ---

title: |md
  # Checkpoint Interval Tradeoff Curve
  Balancing Recovery Time vs Runtime Overhead
| {
  shape: rectangle
  style: {
    stroke: transparent
    fill: transparent
    font-size: 18
    bold: true
  }
}

y_axis_label: "Time / Overhead" {
  shape: rectangle
  style: {
    stroke: transparent
    fill: transparent
    bold: true
  }
}

x_axis_label: "Checkpoint Frequency (checkpoints/second)" {
  shape: rectangle
  style: {
    stroke: transparent
    fill: transparent
    bold: true
  }
}

# --- NEAR PLACEMENT (ROOT ONLY) ---
y_axis_label.near: center-left
x_axis_label.near: bottom-center

# --- MAIN DIAGRAM AREA ---

graph_container: {
  style.fill: transparent
  style.stroke: transparent
  
  graph_area: {
    style.fill: "#FAFAFA"
    style.stroke: "#333333"
    style.stroke-width: 2
    
    # Grid and Ticks Layer
    axes: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      
      y_ticks: {
        direction: down
        style.stroke: transparent
        style.fill: transparent
        t100: "100%" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
        t75: "75%" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
        t50: "50%" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
        t25: "25%" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
      }

      plot_window: {
        direction: down
        style.stroke: "#CCCCCC"
        style.stroke-dash: 1
        
        # Recovery Curve Visualization (Logic-based)
        recovery_path: {
          direction: right
          style.stroke: transparent
          style.fill: transparent
          r1: "High Recovery Time" { 
            shape: parallelogram
            style.fill: "#FFEBEE"
            style.stroke: "#D32F2F"
          }
          r2: "Moderate Recovery" {
            shape: parallelogram
            style.fill: "#FFEBEE"
            style.stroke: "#D32F2F"
          }
          r3: "Minimal Recovery" {
            shape: parallelogram
            style.fill: "#FFEBEE"
            style.stroke: "#D32F2F"
          }
          r1 -> r2 -> r3: "Decreasing RTO" { style.stroke: "#D32F2F"; style.stroke-width: 3 }
        }

        # Overhead Curve Visualization (Logic-based)
        overhead_path: {
          direction: right
          style.stroke: transparent
          style.fill: transparent
          o1: "Low Overhead" {
            shape: rectangle
            style.fill: "#E3F2FD"
            style.stroke: "#1976D2"
          }
          o2: "Moderate Overhead" {
            shape: rectangle
            style.fill: "#E3F2FD"
            style.stroke: "#1976D2"
          }
          o3: "High Overhead" {
            shape: rectangle
            style.fill: "#E3F2FD"
            style.stroke: "#1976D2"
          }
          o1 -> o2 -> o3: "Increasing CPU/IO" { style.stroke: "#1976D2"; style.stroke-width: 3 }
        }
        
        optimal_zone: {
          label: "★ Optimal Range"
          shape: callout
          style: {
            fill: "#C8E6C9"
            stroke: "#2E7D32"
            stroke-width: 2
            opacity: 0.8
          }
        }
      }
    }
    
    x_ticks: {
      direction: right
      style.stroke: transparent
      style.fill: transparent
      rare: "Rare" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
      mod: "Moderate" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
      freq: "Frequent" { shape: rectangle; style: { fill: transparent; stroke: transparent } }
    }
  }
}

legend_container: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  legend_box: {
    direction: right
    style: {
      fill: white
      stroke: "#CCCCCC"
      stroke-dash: 3
    }
    leg1: "━━ Recovery Time" { shape: rectangle; style: { font-color: "#D32F2F"; stroke: transparent; fill: transparent; bold: true } }
    leg2: "━━ Runtime Overhead" { shape: rectangle; style: { font-color: "#1976D2"; stroke: transparent; fill: transparent; bold: true } }
    leg3: "█ Optimal Zone" { shape: rectangle; style: { font-color: "#2E7D32"; stroke: transparent; fill: transparent; bold: true } }
  }
}

metrics_row: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  scenario_rare: {
    label: "Rare Checkpoints\n(every 5 min)"
    style.fill: "#FFCDD2"
    style.stroke: "#D32F2F"
    rec_time: "Recovery: ~60-120 sec"
    overhead: "Overhead: ~0.1%"
    rec_time.style.font-size: 11
    overhead.style.font-size: 11
  }
  
  scenario_optimal: {
    label: "Optimal Checkpoints\n(every 30 sec)"
    style.fill: "#C8E6C9"
    style.stroke: "#2E7D32"
    rec_time: "Recovery: ~5-15 sec"
    overhead: "Overhead: ~1-2%"
    rec_time.style.font-size: 11
    overhead.style.font-size: 11
  }
  
  scenario_frequent: {
    label: "Frequent Checkpoints\n(every 1 sec)"
    style.fill: "#BBDEFB"
    style.stroke: "#1976D2"
    rec_time: "Recovery: ~1-2 sec"
    overhead: "Overhead: ~5-10%"
    rec_time.style.font-size: 11
    overhead.style.font-size: 11
  }
}

# --- DOCUMENTATION AND INSIGHTS ---

sla_container: {
  label: "SLA-Based Tuning"
  style.fill: "#FFF8E1"
  style.stroke: "#FFA000"
  sla_formula: |'md
    **Recovery SLA Formula:**
    `checkpoint_interval = (records_per_sec × recovery_sla_ms) / (2 × 1000)`
    - Higher SLA tolerance → Less frequent checkpoints → Lower overhead
    - Stricter SLA → More frequent checkpoints → Higher overhead
  '|
}

insight_box: {
  label: "Key Implementation Insight"
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  insight_text: |'md
    The optimal checkpoint interval depends on your **Recovery Time Objective (RTO)**:
    - **Production OLTP**: 30-60 second intervals (RTO ~30s, overhead ~1-2%)
    - **Analytics/DW**: 5-10 minute intervals (RTO ~5min, overhead <0.5%)  
    - **High-Availability**: 5-10 second intervals (RTO ~10s, overhead ~3-5%)
    There is no universally optimal point — tune based on your specific SLA requirements and resource costs.
  '|
}

# --- FLOW ---
graph_container -> legend_container: { style.stroke: transparent }
legend_container -> metrics_row: { style.stroke: transparent }
metrics_row -> sla_container: { style.stroke: transparent }
sla_container -> insight_box: { style.stroke: transparent }