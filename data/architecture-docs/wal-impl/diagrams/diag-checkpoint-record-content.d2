direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: CHECKPOINT_END Record Payload Structure {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row1: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  header_section: {
    direction: down
    label: "Log Record Header (28 bytes)"
    style.fill: "#E8E8E8"
    h1: {
      shape: sql_table
      label: "Header Fields"
      f0: "0x00 | uint64 | lsn"
      f1: "0x08 | uint32 | type = CHECKPOINT_END"
      f2: "0x0C | uint32 | txn_id = 0 (system)"
      f3: "0x10 | uint64 | prev_lsn"
      f4: "0x18 | uint32 | length"
    }
  }
  payload_section: {
    direction: down
    label: "Checkpoint Payload"
    style.fill: "#E3F2FD"
    counts: {
      shape: sql_table
      label: "Array Counts"
      c0: "0x1C | uint32 | num_active_txns"
      c1: "0x20 | uint32 | num_dirty_pages"
    }
  }
}
row2: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  txn_table_section: {
    direction: down
    label: "Active Transaction Table (Variable Length)"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    txn_header: {
      shape: sql_table
      label: "TxnTableEntry (16 bytes each)"
      t0: "txn_id    | uint32 | Transaction ID"
      t1: "status    | uint32 | ACTIVE/COMMITTED/ABORTED"
      t2: "first_lsn | uint64 | LSN of BEGIN record"
      t3: "last_lsn  | uint64 | Most recent record LSN"
    }
    txn_array: {
      label: "Array: num_active_txns entries"
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke-dash: 4
      width: 320
    }
  }
  dpt_section: {
    direction: down
    label: "Dirty Page Table (Variable Length)"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    dpt_header: {
      shape: sql_table
      label: "DirtyPageEntry (16 bytes each)"
      d0: "page_id | uint64 | Page identifier"
      d1: "rec_lsn | uint64 | First LSN that dirtied page"
    }
    dpt_array: {
      label: "Array: num_dirty_pages entries"
      shape: rectangle
      style.fill: "#C8E6C9"
      style.stroke-dash: 4
      width: 280
    }
  }
}
row3: "" {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  crc_section: {
    direction: down
    label: "Trailer"
    style.fill: "#FFEBEE"
    crc_field: {
      shape: sql_table
      label: "CRC32 Checksum"
      crc: "N-4 | uint32 | crc32 (covers header + payload)"
    }
  }
  serialization: {
    label: "Serialization Layout"
    width: 450
    code: |'c
      // Byte offset calculation
      offset = 0;
      write_le64(&buf[offset], lsn);       offset += 8;
      write_le32(&buf[offset], type);      offset += 4;
      // ... header fields ...
      write_le32(&buf[offset], num_txns);  offset += 4;
      write_le32(&buf[offset], num_pages); offset += 4;
      // Transaction table entries
      for (i = 0; i < num_txns; i++) {
        write_le32(&buf[offset], entries[i].txn_id);
        write_le32(&buf[offset+4], entries[i].status);
        write_le64(&buf[offset+8], entries[i].first_lsn);
        write_le64(&buf[offset+16], entries[i].last_lsn);
        offset += 24;  // 16 bytes per entry (padded)
      }
      // Dirty page table entries
      for (i = 0; i < num_pages; i++) {
        write_le64(&buf[offset], pages[i].page_id);
        write_le64(&buf[offset+8], pages[i].rec_lsn);
        offset += 16;
      }
      // CRC covers everything before it
      crc = crc32(0, buf, offset);
      write_le32(&buf[offset], crc);
    '|
  }
}
header_section -> payload_section: "28 bytes"
payload_section.counts -> txn_table_section: "count = N"
payload_section.counts -> dpt_section: "count = M"
txn_table_section -> dpt_section: "offset += N * 16"
dpt_section -> crc_section: "offset += M * 16"
legend: {
  near: bottom-right
  label: "Field Size Legend"
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  l1: "uint32 = 4 bytes (little-endian)"
  l2: "uint64 = 8 bytes (little-endian)"
  l3: "Total = 28 + 8 + (N * 16) + (M * 16) + 4"
}