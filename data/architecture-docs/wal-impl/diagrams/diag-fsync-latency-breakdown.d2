direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # fsync Latency: Where Time Goes
  **The 10,000x Gap Between write() and Durability**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  userspace: {
    direction: down
    label: "User Space"
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    app: {
      label: "Application"
      shape: rectangle
      style.fill: "#BBDEFB"
      width: 140
    }
    write_call: {
      label: "write() syscall"
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      width: 140
    }
    fsync_call: {
      label: "fsync() syscall"
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      width: 140
    }
    app -> write_call: "buffer" {
      style.stroke: "#666"
      style.stroke-width: 2
    }
    write_call -> fsync_call: "returns\nimmediately" {
      style.stroke: "#4CAF50"
      style.stroke-width: 2
      style.stroke-dash: 3
    }
  }
  kernel: {
    direction: down
    label: "Kernel Space"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    page_cache: {
      label: "OS Page Cache\n(DRAM)"
      shape: cylinder
      style.fill: "#FFE0B2"
      width: 160
    }
    vfs: {
      label: "VFS / Block Layer"
      shape: rectangle
      style.fill: "#FFCC80"
      width: 160
    }
    write_call_k: {
      label: "~1 μs"
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.font-size: 20
      style.bold: true
      width: 80
    }
    fsync_trigger: {
      label: "fsync triggers\nflush"
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      width: 160
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  hardware: {
    direction: down
    label: "Hardware"
    style.fill: "#F3E5F5"
    style.stroke: "#9C27B0"
    style.stroke-width: 2
    controller: {
      label: "Disk Controller\nCache (SRAM)"
      shape: cylinder
      style.fill: "#E1BEE7"
      width: 160
    }
    storage: {
      label: "Storage Media"
      shape: cylinder
      style.fill: "#CE93D8"
      width: 160
    }
    controller -> storage: "commit" {
      style.stroke: "#9C27B0"
      style.stroke-width: 2
    }
  }
  timing: {
    direction: down
    label: "Latency Comparison"
    style.fill: "#FAFAFA"
    style.stroke: "#9E9E9E"
    t1: {
      label: "write()\n~1 μs"
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      width: 100
    }
    t2: {
      label: "HDD fsync()\n5-15 ms"
      shape: rectangle
      style.fill: "#F44336"
      style.font-color: white
      width: 100
    }
    t3: {
      label: "SSD fsync()\n0.1-3 ms"
      shape: rectangle
      style.fill: "#FF9800"
      style.font-color: white
      width: 100
    }
    ratio: {
      label: "Gap: 1,000x - 15,000x"
      shape: rectangle
      style.fill: "#9E9E9E"
      style.font-color: white
      style.bold: true
      width: 160
    }
  }
}
row1.userspace.write_call -> row1.kernel.page_cache: "copy" {
  label: "1 μs"
  style.stroke: "#4CAF50"
  style.stroke-width: 3
}
row1.kernel.page_cache -> row1.kernel.vfs: {
  style.stroke: transparent
}
row1.userspace.fsync_call -> row1.kernel.fsync_trigger: "blocks\nhere" {
  style.stroke: "#F44336"
  style.stroke-width: 3
  style.animated: true
}
row1.kernel.fsync_trigger -> row2.hardware.controller: "flush\ncommand" {
  label: "~0.1 ms"
  style.stroke: "#F44336"
  style.stroke-width: 2
}
row2.hardware.storage -> row1.userspace.fsync_call: "returns" {
  label: "durability\nachieved"
  style.stroke: "#4CAF50"
  style.stroke-width: 2
  style.stroke-dash: 5
}
legend: {
  near: bottom-center
  label: "Why fsync Dominates"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.stroke-width: 2
  l1: |md
    - **write()** copies to kernel memory — no disk I/O
    - **fsync()** waits for physical media confirmation
    - HDD: Seek time (5-10ms) + rotational latency (0-8ms)
    - SSD: FTL commit, capacitor drain, NAND programming
    - This is physics — no algorithm can fix it
  |
}
classes: {
  fast: {
    style.fill: "#4CAF50"
    style.font-color: white
  }
  slow: {
    style.fill: "#F44336"
    style.font-color: white
  }
  medium: {
    style.fill: "#FF9800"
    style.font-color: white
  }
}