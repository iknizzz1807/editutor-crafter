direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title_node: {
  label: "Group Commit: Before vs After"
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
  }
}

comparison_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  before_container: {
    label: "Before (Naive: Per-Commit fsync)"
    direction: down
    style.fill: "#FFF5F5"
    style.stroke: "#E53E3E"
    style.stroke-width: 2

    b_header: {
      shape: text
      label: "3 transactions = 3 fsyncs"
      style.font-color: "#C53030"
      style.bold: true
    }

    t1_before: "T1 Commit" {
      width: 160
      style.fill: "#FED7D7"
      style.stroke: "#FC8181"
    }

    fsync1_before: "fsync #1" {
      width: 160
      style.fill: "#FEB2B2"
      style.stroke: "#E53E3E"
      style.font: mono
    }

    t2_before: "T2 Commit" {
      width: 160
      style.fill: "#FED7D7"
      style.stroke: "#FC8181"
    }

    fsync2_before: "fsync #2" {
      width: 160
      style.fill: "#FEB2B2"
      style.stroke: "#E53E3E"
      style.font: mono
    }

    t3_before: "T3 Commit" {
      width: 160
      style.fill: "#FED7D7"
      style.stroke: "#FC8181"
    }

    fsync3_before: "fsync #3" {
      width: 160
      style.fill: "#FEB2B2"
      style.stroke: "#E53E3E"
      style.font: mono
    }

    ack_before: "ACK to clients" {
      width: 160
      style.fill: "#FED7D7"
      style.stroke: "#FC8181"
    }

    total_before: "Total: ~30ms" {
      width: 160
      shape: rectangle
      style.fill: "#E53E3E"
      style.font-color: white
      style.bold: true
    }

    t1_before -> fsync1_before
    fsync1_before -> t2_before: "10ms"
    t2_before -> fsync2_before
    fsync2_before -> t3_before: "10ms"
    t3_before -> fsync3_before
    fsync3_before -> ack_before: "10ms"
    ack_before -> total_before
  }

  spacer: "" {
    width: 60
    style.fill: transparent
    style.stroke: transparent
  }

  after_container: {
    label: "After (Group Commit: Batched fsync)"
    direction: down
    style.fill: "#F0FFF4"
    style.stroke: "#38A169"
    style.stroke-width: 2

    a_header: {
      shape: text
      label: "3 transactions = 1 fsync"
      style.font-color: "#276749"
      style.bold: true
    }

    concurrent_node: "T1, T2, T3\nCommit Concurrently" {
      width: 160
      style.fill: "#C6F6D5"
      style.stroke: "#68D391"
    }

    wait_window: "Wait Window\n(max 1ms)" {
      width: 160
      style.fill: "#9AE6B4"
      style.stroke: "#48BB78"
      style.stroke-dash: 3
    }

    batch_fsync: "Single fsync" {
      width: 160
      style.fill: "#68D391"
      style.stroke: "#38A169"
      style.font: mono
      style.bold: true
    }

    broadcast_node: "Broadcast to\nall waiters" {
      width: 160
      style.fill: "#C6F6D5"
      style.stroke: "#68D391"
    }

    ack_all: "ACK all clients" {
      width: 160
      style.fill: "#C6F6D5"
      style.stroke: "#68D391"
    }

    total_after: "Total: ~11ms" {
      width: 160
      shape: rectangle
      style.fill: "#38A169"
      style.font-color: white
      style.bold: true
    }

    concurrent_node -> wait_window
    wait_window -> batch_fsync: "1ms"
    batch_fsync -> broadcast_node: "10ms"
    broadcast_node -> ack_all
    ack_all -> total_after
  }
}

savings_box: {
  direction: down
  style.fill: "#EBF8FF"
  style.stroke: "#3182CE"
  style.stroke-width: 2
  
  savings_title: {
    shape: text
    label: "Performance Metrics"
    style: {
      font-size: 20
      bold: true
      font-color: "#2B6CB0"
    }
  }

  metrics_row: "" {
    direction: right
    style.fill: transparent
    style.stroke: transparent

    m1: "Before\n~30ms" {
      shape: rectangle
      width: 120
      style.fill: "#FED7D7"
      style.stroke: "#FC8181"
      style.font: mono
    }

    arrow_node: "→" {
      shape: text
      style.font-size: 28
      style.font-color: "#3182CE"
    }

    m2: "After\n~11ms" {
      shape: rectangle
      width: 120
      style.fill: "#C6F6D5"
      style.stroke: "#68D391"
      style.font: mono
    }

    result_summary: "≈ 3x faster\n(5-8x typical)" {
      shape: rectangle
      width: 160
      style.fill: "#BEE3F8"
      style.stroke: "#3182CE"
      style.bold: true
    }
  }

  explanation_node: {
    shape: rectangle
    width: 600
    style.fill: white
    text: |md
      **fsync amortization**: One disk sync covers multiple commits.
      The fixed ~10ms fsync cost is shared across all concurrent transactions.
    |
  }
}

legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  style.stroke: transparent
  
  l1: "fsync operation" {
    shape: rectangle
    width: 140
    style.fill: "#FEB2B2"
    style.stroke: "#E53E3E"
  }
  l2: "group commit" {
    shape: rectangle
    width: 140
    style.fill: "#68D391"
    style.stroke: "#38A169"
  }
  l3: "wait/batching" {
    shape: rectangle
    width: 140
    style.stroke-dash: 3
    style.fill: "#9AE6B4"
    style.stroke: "#48BB78"
  }
}

comparison_row -> savings_box: "Optimization Result"
savings_box -> legend: "Key"