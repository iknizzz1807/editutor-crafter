direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8F4FD"
    payload: "#FFF3E0"
    crc: "#FFEBEE"
    begin: "#E8F5E9"
    update: "#F3E5F5"
    commit: "#E0F2F1"
    abort: "#FCE4EC"
    clr: "#FFF8E1"
    checkpoint: "#E3F2FD"
  }
}
title: |md
  # Log Record Binary Format (Microscopic View)
  Byte-by-byte layout with alignment, endianness, and field boundaries
| {near: top-center}
# ================== HEADER SECTION ==================
header_section: {
  label: "HEADER (Fixed 25 bytes)"
  style.fill: ${colors.header}
  style.stroke: "#1976D2"
  style.stroke-width: 2
  header_grid: {
    grid-columns: 5
    grid-gap: 0
    lsn: {
      label: "LSN\n8 bytes\noffset 0x00"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      width: 120
    }
    type: {
      label: "type\n1 byte\noffset 0x08"
      style.fill: "#90CAF9"
      style.stroke: "#1976D2"
      width: 100
    }
    txn_id: {
      label: "txn_id\n4 bytes\noffset 0x09"
      style.fill: "#64B5F6"
      style.stroke: "#1976D2"
      width: 110
    }
    prev_lsn: {
      label: "prev_lsn\n8 bytes\noffset 0x0D"
      style.fill: "#42A5F5"
      style.stroke: "#1976D2"
      width: 120
    }
    length: {
      label: "length\n4 bytes\noffset 0x15"
      style.fill: "#2196F3"
      style.stroke: "#1976D2"
      width: 110
    }
  }
  header_legend: {
    label: |md
      **All integers: Little-Endian**
      - LSN: Log Sequence Number (monotonically increasing)
      - type: Record type discriminator (0-5)
      - txn_id: Owning transaction identifier
      - prev_lsn: Previous record in same transaction (0 = first)
      - length: Total record size including header + payload + CRC
    |
    style.fill: transparent
    style.stroke: transparent
  }
}
# ================== TYPE-SPECIFIC PAYLOADS ==================
payload_section: {
  label: "TYPE-SPECIFIC PAYLOAD (Variable Length)"
  style.fill: ${colors.payload}
  style.stroke: "#F57C00"
  style.stroke-width: 2
  direction: down
  # BEGIN Record
  begin_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    begin_label: {
      label: "type = 0\nBEGIN"
      style.fill: ${colors.begin}
      style.stroke: "#4CAF50"
      width: 100
    }
    begin_payload: {
      label: "(no payload)"
      style.fill: ${colors.begin}
      style.stroke: "#4CAF50"
      style.stroke-dash: 3
      width: 150
    }
    begin_total: {
      label: "Total: 29 bytes\n(25 header + 0 payload + 4 CRC)"
      style.fill: ${colors.begin}
      style.stroke: "#4CAF50"
      width: 250
    }
  }
  # UPDATE Record
  update_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    update_label: {
      label: "type = 1\nUPDATE"
      style.fill: ${colors.update}
      style.stroke: "#7B1FA2"
      width: 100
    }
    update_grid: {
      grid-columns: 6
      grid-gap: 0
      style.fill: transparent
      u_page_id: {
        label: "page_id\n8 bytes"
        style.fill: "#E1BEE7"
        style.stroke: "#7B1FA2"
        width: 80
      }
      u_offset: {
        label: "offset\n4 bytes"
        style.fill: "#CE93D8"
        style.stroke: "#7B1FA2"
        width: 75
      }
      u_old_len: {
        label: "old_len\n4 bytes"
        style.fill: "#BA68C8"
        style.stroke: "#7B1FA2"
        width: 75
      }
      u_old_val: {
        label: "old_value\n[old_len]"
        style.fill: "#AB47BC"
        style.stroke: "#7B1FA2"
        width: 90
      }
      u_new_len: {
        label: "new_len\n4 bytes"
        style.fill: "#9C27B0"
        style.stroke: "#7B1FA2"
        width: 75
      }
      u_new_val: {
        label: "new_value\n[new_len]"
        style.fill: "#8E24AA"
        style.stroke: "#7B1FA2"
        width: 90
      }
    }
  }
  # COMMIT Record
  commit_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    commit_label: {
      label: "type = 2\nCOMMIT"
      style.fill: ${colors.commit}
      style.stroke: "#00897B"
      width: 100
    }
    commit_payload: {
      label: "(no payload)"
      style.fill: ${colors.commit}
      style.stroke: "#00897B"
      style.stroke-dash: 3
      width: 150
    }
    commit_total: {
      label: "Total: 29 bytes"
      style.fill: ${colors.commit}
      style.stroke: "#00897B"
      width: 250
    }
  }
  # ABORT Record
  abort_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    abort_label: {
      label: "type = 3\nABORT"
      style.fill: ${colors.abort}
      style.stroke: "#C2185B"
      width: 100
    }
    abort_payload: {
      label: "(no payload)"
      style.fill: ${colors.abort}
      style.stroke: "#C2185B"
      style.stroke-dash: 3
      width: 150
    }
    abort_total: {
      label: "Total: 29 bytes"
      style.fill: ${colors.abort}
      style.stroke: "#C2185B"
      width: 250
    }
  }
  # CLR Record
  clr_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    clr_label: {
      label: "type = 4\nCLR"
      style.fill: ${colors.clr}
      style.stroke: "#F9A825"
      width: 100
    }
    clr_grid: {
      grid-columns: 5
      grid-gap: 0
      style.fill: transparent
      c_page_id: {
        label: "page_id\n8 bytes"
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
        width: 80
      }
      c_offset: {
        label: "offset\n4 bytes"
        style.fill: "#FFF176"
        style.stroke: "#F9A825"
        width: 75
      }
      c_undo_len: {
        label: "undo_len\n4 bytes"
        style.fill: "#FFEE58"
        style.stroke: "#F9A825"
        width: 80
      }
      c_undo_data: {
        label: "undo_data\n[undo_len]"
        style.fill: "#FDD835"
        style.stroke: "#F9A825"
        width: 95
      }
      c_undo_next: {
        label: "undo_next\n8 bytes"
        style.fill: "#FBC02D"
        style.stroke: "#F9A825"
        width: 90
      }
    }
  }
  # CHECKPOINT Record
  checkpoint_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    checkpoint_label: {
      label: "type = 5\nCHECKPOINT"
      style.fill: ${colors.checkpoint}
      style.stroke: "#1565C0"
      width: 100
    }
    checkpoint_grid: {
      grid-columns: 4
      grid-gap: 0
      style.fill: transparent
      ch_num_txn: {
        label: "num_txns\n4 bytes"
        style.fill: "#BBDEFB"
        style.stroke: "#1565C0"
        width: 85
      }
      ch_txns: {
        label: "txn_table\n[num_txns]\nentries"
        style.fill: "#90CAF9"
        style.stroke: "#1565C0"
        width: 100
      }
      ch_num_pages: {
        label: "num_pages\n4 bytes"
        style.fill: "#64B5F6"
        style.stroke: "#1565C0"
        width: 90
      }
      ch_pages: {
        label: "dirty_pages\n[num_pages]\nentries"
        style.fill: "#42A5F5"
        style.stroke: "#1565C0"
        width: 110
      }
    }
  }
}
# ================== CRC SECTION ==================
crc_section: {
  label: "CRC32 (4 bytes)"
  style.fill: ${colors.crc}
  style.stroke: "#C62828"
  style.stroke-width: 2
  crc_grid: {
    grid-columns: 3
    grid-gap: 0
    crc_bytes: {
      label: "crc32\n4 bytes\noffset [length-4]"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
      width: 150
    }
    crc_algo: {
      label: "CRC-32 (ISO 3309)\nCovers: header + payload\nExcludes: CRC field itself"
      style.fill: "#EF9A9A"
      style.stroke: "#C62828"
      width: 200
    }
    crc_purpose: {
      label: "Detects:\n• Torn writes (partial records)\n• Disk corruption\n• Memory corruption"
      style.fill: "#E57373"
      style.stroke: "#C62828"
      width: 180
    }
  }
}
# ================== BINARY LAYOUT EXAMPLE ==================
binary_example: {
  label: "Example: UPDATE Record (old='A', new='BB')"
  style.fill: "#FAFAFA"
  style.stroke: "#424242"
  binary_grid: {
    grid-columns: 16
    grid-gap: 0
    b00: {label: "00"; style.fill: "#BBDEFB"; width: 35}
    b01: {label: "01"; style.fill: "#BBDEFB"; width: 35}
    b02: {label: "02"; style.fill: "#BBDEFB"; width: 35}
    b03: {label: "00"; style.fill: "#BBDEFB"; width: 35}
    b04: {label: "00"; style.fill: "#BBDEFB"; width: 35}
    b05: {label: "00"; style.fill: "#BBDEFB"; width: 35}
    b06: {label: "00"; style.fill: "#BBDEFB"; width: 35}
    b07: {label: "00"; style.fill: "#BBDEFB"; width: 35}
    b08: {label: "01"; style.fill: "#90CAF9"; width: 35}
    b09: {label: "05"; style.fill: "#64B5F6"; width: 35}
    b0A: {label: "00"; style.fill: "#64B5F6"; width: 35}
    b0B: {label: "00"; style.fill: "#64B5F6"; width: 35}
    b0C: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b0D: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b0E: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b0F: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b10: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b11: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b12: {label: "00"; style.fill: "#42A5F5"; width: 35}
    b13: {label: "00"; style.fill: "#2196F3"; width: 35}
    b14: {label: "2C"; style.fill: "#2196F3"; width: 35}
    b15: {label: "00"; style.fill: "#2196F3"; width: 35}
    b16: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b17: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b18: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b19: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b1A: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b1B: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b1C: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b1D: {label: "00"; style.fill: "#E1BEE7"; width: 35}
    b1E: {label: "00"; style.fill: "#CE93D8"; width: 35}
    b1F: {label: "00"; style.fill: "#CE93D8"; width: 35}
    b20: {label: "00"; style.fill: "#CE93D8"; width: 35}
    b21: {label: "00"; style.fill: "#CE93D8"; width: 35}
    b22: {label: "01"; style.fill: "#BA68C8"; width: 35}
    b23: {label: "00"; style.fill: "#BA68C8"; width: 35}
    b24: {label: "00"; style.fill: "#BA68C8"; width: 35}
    b25: {label: "00"; style.fill: "#BA68C8"; width: 35}
    b26: {label: "41"; style.fill: "#AB47BC"; width: 35}
    b27: {label: "02"; style.fill: "#9C27B0"; width: 35}
    b28: {label: "00"; style.fill: "#9C27B0"; width: 35}
    b29: {label: "00"; style.fill: "#9C27B0"; width: 35}
    b2A: {label: "00"; style.fill: "#9C27B0"; width: 35}
    b2B: {label: "42"; style.fill: "#8E24AA"; width: 35}
    b2B2: {label: "42"; style.fill: "#8E24AA"; width: 35}
    b2C: {label: "XX"; style.fill: "#FFCDD2"; width: 35}
    b2D: {label: "XX"; style.fill: "#FFCDD2"; width: 35}
    b2E: {label: "XX"; style.fill: "#FFCDD2"; width: 35}
    b2F: {label: "XX"; style.fill: "#FFCDD2"; width: 35}
  }
  binary_labels: {
    grid-columns: 4
    grid-gap: 10
    style.fill: transparent
    l1: {
      label: "LSN=256 (0x100)"
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
    }
    l2: {
      label: "type=1 (UPDATE)"
      style.fill: "#90CAF9"
      style.stroke: "#1976D2"
    }
    l3: {
      label: "txn_id=5"
      style.fill: "#64B5F6"
      style.stroke: "#1976D2"
    }
    l4: {
      label: "prev_lsn=0"
      style.fill: "#42A5F5"
      style.stroke: "#1976D2"
    }
    l5: {
      label: "length=44 (0x2C)"
      style.fill: "#2196F3"
      style.stroke: "#1976D2"
    }
    l6: {
      label: "page_id=0"
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    l7: {
      label: "offset=0"
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
    }
    l8: {
      label: "old_len=1"
      style.fill: "#BA68C8"
      style.stroke: "#7B1FA2"
    }
    l9: {
      label: "old='A' (0x41)"
      style.fill: "#AB47BC"
      style.stroke: "#7B1FA2"
    }
    l10: {
      label: "new_len=2"
      style.fill: "#9C27B0"
      style.stroke: "#7B1FA2"
    }
    l11: {
      label: "new='BB'"
      style.fill: "#8E24AA"
      style.stroke: "#7B1FA2"
    }
    l12: {
      label: "CRC32"
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }
  }
}
# ================== ALIGNMENT NOTES ==================
alignment_notes: {
  label: "Alignment & Serialization Rules"
  style.fill: "#F5F5F5"
  style.stroke: "#616161"
  notes: |md
    **Endianness**: All multi-byte integers stored **little-endian** (x86/ARM native)
    **Alignment**: No padding in serialized form — fields are tightly packed
    **Variable-length fields**: Length-prefixed (4-byte length precedes data)
    **String encoding**: Raw bytes, NOT null-terminated
    **Total length formula**: `25 (header) + payload_size + 4 (CRC)`
    **LSN as offset**: LSN equals byte offset in log file (enables O(1) record lookup)
  |
}
# ================== CONNECTIONS ==================
header_section -> payload_section: "25 bytes fixed"
payload_section -> crc_section: "variable"