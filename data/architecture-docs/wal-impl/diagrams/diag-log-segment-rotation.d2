direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Log Segment Rotation
  **File System View — 64MB Segments**
|
title.near: top-center

row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  seg1: "segment_001.log" {
    width: 280
    style.fill: "#E8E8E8"
    style.stroke: "#888888"
    style.stroke-width: 2
    header: "SEGMENT 001 (0x000000 - 0x3FFFFFF)"
    meta: {
      shape: sql_table
      label: "Segment Metadata"
      f1: "start_lsn | 0x00000000"
      f2: "end_lsn   | 0x03FFFFFF"
      f3: "size      | 64 MB"
      f4: "state     | SEALED"
      f5: "records   | ~1.5M"
    }
    status: "READ-ONLY | FULL" {
      style.italic: true
      style.font-color: "#666666"
    }
  }

  seg2: "segment_002.log" {
    width: 280
    style.fill: "#E8E8E8"
    style.stroke: "#888888"
    style.stroke-width: 2
    header: "SEGMENT 002 (0x04000000 - 0x07FFFFFF)"
    meta: {
      shape: sql_table
      label: "Segment Metadata"
      f1: "start_lsn | 0x04000000"
      f2: "end_lsn   | 0x07FFFFFF"
      f3: "size      | 64 MB"
      f4: "state     | SEALED"
      f5: "records   | ~1.8M"
    }
    status: "READ-ONLY | FULL" {
      style.italic: true
      style.font-color: "#666666"
    }
  }

  seg3: "segment_003.log" {
    width: 280
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
    style.stroke-width: 3
    header: "SEGMENT 003 (ACTIVE)"
    meta: {
      shape: sql_table
      label: "Segment Metadata"
      f1: "start_lsn | 0x08000000"
      f2: "end_lsn   | 0x08C34F00"
      f3: "size      | 12.2 MB"
      f4: "state     | ACTIVE"
      f5: "records   | ~312K"
    }
    write_ptr: {
      label: "Write Pointer | Offset: 0x00C34F00"
      style.fill: "#FFF3CD"
      style.stroke: "#FFC107"
      style.stroke-width: 2
    }
  }
}

arrow_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  growth: "→ Sequential Growth →" {
    style.font-size: 18
    style.font-color: "#666666"
  }
}

logic_row: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent

  rotation_logic: {
    label: "Rotation Trigger (wal.c)"
    width: 450
    code: |'c
      if (segment.size >= LIMIT) {
          fsync(segment.fd);
          close(segment.fd);
          segment.state = SEALED;
          
          new_id = current_id + 1;
          fd = open(path(new_id), O_APPEND);
      }
    '|
  }

  fsync_order: {
    shape: sql_table
    label: "Durability Guarantee"
    step1: "1 | write() | Records to OS cache"
    step2: "2 | fsync() | Force to disk"
    step3: "3 | close() | Seal segment"
    step4: "4 | open()  | Create next file"
    total: "Crash-safe ordering"
  }
}

seg1 -> seg2: "sealed" { style.stroke-dash: 4 }
seg2 -> seg3: "sealed" { style.stroke-dash: 4 }
seg3 -> logic_row.rotation_logic: "size >= 64MB"
logic_row.rotation_logic -> logic_row.fsync_order

legend: {
  label: "Legend"
  sealed_box: "SEALED (Read-Only)" {
    style.fill: "#E8E8E8"
    style.stroke: "#888888"
  }
  active_box: "ACTIVE (Appending)" {
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
}
legend.near: bottom-center

file_layout: {
  label: "Physical Layout (/data/wal/)"
  list: |md
    - wal.000001 (64MB) [SEALED]
    - wal.000002 (64MB) [SEALED]
    - wal.000003 (12MB) [ACTIVE]
    - wal.master (Checkpoint)
  |
}
file_layout.near: bottom-right