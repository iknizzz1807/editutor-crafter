direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    safe: "#90EE90"
    danger: "#FFB6C1"
    checkpoint: "#FFD700"
    active_txn: "#87CEEB"
  }
}

title_section: {
  style.stroke: transparent
  style.fill: transparent
  title: "Log Truncation: Safety Calculation (wal_mgr.c)" {
    shape: text
    style: {
      font-size: 28
      bold: true
    }
  }
}

legend_container: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  safe_legend: "CAN DELETE" {
    style.fill: "#90EE90"
    width: 150
    style.stroke: "#228B22"
    style.stroke-width: 2
  }
  danger_legend: "MUST KEEP" {
    style.fill: "#FFB6C1"
    width: 150
    style.stroke: "#DC143C"
    style.stroke-width: 2
  }
}

middle_section: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  segments_container: "Log Segments on Disk (/var/lib/wal/)" {
    direction: down
    style.fill: "#F5F5F5"
    style.stroke: "#666666"
    style.stroke-width: 2

    seg1: "Segment 1 | LSN 0-199" {
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 3
      width: 220
    }
    seg2: "Segment 2 | LSN 200-399" {
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 3
      width: 220
    }
    seg3: "Segment 3 | LSN 400-499" {
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 3
      width: 220
    }
    checkpoint_boundary: "← CHECKPOINT recLSN=500 →" {
      shape: diamond
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
      width: 220
    }
    seg4: "Segment 4 | LSN 500-699" {
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
      style.stroke-width: 3
      width: 220
    }
    seg5: "Segment 5 | LSN 700-899 (Active)" {
      style.fill: "#FFB6C1"
      style.stroke: "#DC143C"
      style.stroke-width: 3
      width: 220
    }
  }

  rules_container: "Truncation Safety Rules" {
    direction: down
    style.fill: "#FFFAF0"
    style.stroke: "#D2691E"
    style.stroke-width: 2
    width: 420

    rule1: {
      label: "Rule 1: Redo Safety"
      code: |md
        Segment can be deleted if:
        `segment.end_lsn < checkpoint.min_rec_lsn`
        **Checkpoint recLSN = 500**
        Segments 1-3 end at LSN 499
        `499 < 500` -> **SAFE TO DELETE**
      |
    }
    rule2: {
      label: "Rule 2: Undo Safety"
      code: |md
        Segment can be deleted if:
        No active txn's `first_lsn` in segment
        **Active T1 firstLSN = 600**
        T1 started in Segment 4 (LSN 500-699)
        Segments 1-3: No active txn -> **SAFE**
      |
    }
  }
}

bottom_section: "" {
  direction: down
  style.stroke: transparent
  style.fill: transparent

  calculation: "Safety Matrix Implementation" {
    direction: down
    style.fill: "#F0FFF0"
    style.stroke: "#2E8B57"
    style.stroke-width: 2
    
    calc_header: "Inputs: checkpoint.min_rec_lsn=500 | active_txn[T1].first_lsn=600" {
      shape: text
      style.bold: true
      style.font-color: "#006400"
    }

    calc_table: {
      shape: sql_table
      label: "Truncation Decision Matrix"
      header: "Segment | Range | end_lsn < 500 | T1_firstLSN in range | Verdict"
      row1: "1 | 0-199 | 199 < 500 (T) | 600 in [0,199] (F) | DELETE"
      row2: "2 | 200-399 | 399 < 500 (T) | 600 in [200,399] (F) | DELETE"
      row3: "3 | 400-499 | 499 < 500 (T) | 600 in [400,499] (F) | DELETE"
      row4: "4 | 500-699 | 699 < 500 (F) | 600 in [500,699] (T) | KEEP"
      row5: "5 | 700-899 | 899 < 500 (F) | 600 in [700,899] (F) | KEEP"
      footer: "Truncation LSN set to 500 (Checkpoint Bound)"
    }
  }

  result_summary: {
    label: "RESULT: Segments 1-3 cleared for background deletion. Segments 4-5 pinned for recovery."
    shape: rectangle
    style.fill: "#E6E6FA"
    style.stroke: "#4B0082"
    style.stroke-width: 2
    style.bold: true
  }
}

# Fixed: near set to constant 'top-right' at root level
active_txn_note: {
  label: "T1 State: ACTIVE\nfirstLSN: 600\nBlocks truncation of Segment 4"
  shape: callout
  style.fill: "#87CEEB"
  style.stroke: "#4682B4"
}
active_txn_note.near: top-right

middle_section.segments_container -> middle_section.rules_container: "Check Redo/Undo"
middle_section.rules_container -> bottom_section.calculation: "Apply Logic"
bottom_section.calculation -> bottom_section.result_summary: "Final Verdict"