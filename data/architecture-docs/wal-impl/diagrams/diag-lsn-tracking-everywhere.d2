direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# TITLE SECTION
# -----------------------------------------------------------------------------
header: {
  label: "LSN Tracking: The Connective Tissue (Steal/No-Force Policy)"
  shape: rectangle
  style: {
    fill: "#E5E7EB"
    stroke: "#111827"
    stroke-width: 2
    font-size: 20
    bold: true
  }
}

# -----------------------------------------------------------------------------
# ROW 1: POLICY DEFINITIONS
# -----------------------------------------------------------------------------
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  steal_policy: {
    label: "Buffer Manager: Steal Policy"
    direction: down
    can_evict: "STEAL = YES (Standard)" {
      shape: diamond
      style.fill: "#FEE2E2"
      tooltip: "Buffer pool can evict dirty pages to disk before transaction commits."
    }
    no_evict: "STEAL = NO" {
      shape: diamond
      style.fill: "#DCFCE7"
      tooltip: "Dirty pages must stay pinned in memory until EOT."
    }
  }

  force_policy: {
    label: "Commit Manager: Force Policy"
    direction: down
    no_force: "FORCE = NO (Standard)" {
      shape: diamond
      style.fill: "#FEE2E2"
      tooltip: "Commit does not require flushing modified pages to data files."
    }
    force: "FORCE = YES" {
      shape: diamond
      style.fill: "#DCFCE7"
      tooltip: "All modified pages must be synced to disk at commit time."
    }
  }
}

# -----------------------------------------------------------------------------
# ROW 2: ARCHITECTURAL IMPLICATIONS
# -----------------------------------------------------------------------------
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  recovery_requirements: {
    label: "ARIES Recovery Implications"
    direction: down
    style.fill: "#F9FAFB"

    undo_requirement: {
      label: "Need UNDO Logic"
      shape: rectangle
      style.fill: "#FFCDD2"
      note: "Required to roll back dirty data on disk from aborted Xacts"
    }

    redo_requirement: {
      label: "Need REDO Logic"
      shape: rectangle
      style.fill: "#C8E6C9"
      note: "Required to replay committed changes missing from data files"
    }

    wal_lsn: {
      label: "WAL + LSN Tracking"
      shape: hexagon
      style: {
        stroke-width: 4
        fill: "#B3E5FC"
      }
      note: "The connective tissue linking Log to Data Pages"
    }
  }
}

# -----------------------------------------------------------------------------
# DATA FLOW & LOGIC CONNECTIONS
# -----------------------------------------------------------------------------
row1.steal_policy.can_evict -> row2.recovery_requirements.undo_requirement: "Uncommitted Disk Write"
row1.force_policy.no_force -> row2.recovery_requirements.redo_requirement: "Volatile Commit"

row2.recovery_requirements.undo_requirement -> row2.recovery_requirements.wal_lsn: "Atomicity"
row2.recovery_requirements.redo_requirement -> row2.recovery_requirements.wal_lsn: "Durability"

# -----------------------------------------------------------------------------
# ANNOTATIONS (Root level per Rule G)
# -----------------------------------------------------------------------------
wal_principle: {
  shape: callout
  label: "The WAL Fundamental"
  details: "Before a dirty page (LSN_page) is flushed to disk, the log up to that LSN must be flushed first."
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
  }
}
wal_principle.near: bottom-right

implementation_note: {
  shape: rectangle
  label: "Implementation Note"
  details: "Steal/No-Force minimizes I/O stalls but increases recovery complexity."
  style: {
    italic: true
    stroke-dash: 3
  }
}
implementation_note.near: top-right