direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    t1: "#4A90D9"
    t2: "#E67E22"
    t3: "#27AE60"
    header: "#2C3E50"
    lsn_box: "#ECF0F1"
    arrow: "#7F8C8D"
    highlight: "#E74C3C"
  }
}
title: {
  label: "prevLSN Chain: Transaction-Local Backpointers"
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
    underline: true
  }
}
row_timeline: {
  direction: right
  style: {
    fill: transparent
    stroke: transparent
  }
  lsn_column: {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    lsn_header: {
      label: "LSN"
      shape: rectangle
      width: 60
      style: {
        fill: ${colors.header}
        font-color: white
        bold: true
      }
    }
    lsn_1: { label: "1"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_2: { label: "2"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_3: { label: "3"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_4: { label: "4"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_5: { label: "5"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_6: { label: "6"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_7: { label: "7"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_8: { label: "8"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_9: { label: "9"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
    lsn_10: { label: "10"; shape: rectangle; width: 60; style.fill: ${colors.lsn_box} }
  }
  records_column: {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    rec_header: {
      label: "Log Record"
      shape: rectangle
      width: 200
      style: {
        fill: ${colors.header}
        font-color: white
        bold: true
      }
    }
    rec_1: {
      label: "T1 BEGIN"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t1}; font-color: white; bold: true }
    }
    rec_2: {
      label: "T2 BEGIN"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t2}; font-color: white; bold: true }
    }
    rec_3: {
      label: "T1 UPDATE pg:5"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t1}; font-color: white }
    }
    rec_4: {
      label: "T3 BEGIN"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t3}; font-color: white; bold: true }
    }
    rec_5: {
      label: "T2 UPDATE pg:7"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t2}; font-color: white }
    }
    rec_6: {
      label: "T1 UPDATE pg:3"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t1}; font-color: white }
    }
    rec_7: {
      label: "T3 UPDATE pg:9"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t3}; font-color: white }
    }
    rec_8: {
      label: "T2 COMMIT"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t2}; font-color: white; bold: true }
    }
    rec_9: {
      label: "T1 UPDATE pg:2"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t1}; font-color: white }
    }
    rec_10: {
      label: "T3 UPDATE pg:1"
      shape: rectangle
      width: 200
      style: { fill: ${colors.t3}; font-color: white }
    }
  }
  prevlsn_column: {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    prev_header: {
      label: "prevLSN"
      shape: rectangle
      width: 80
      style: {
        fill: ${colors.header}
        font-color: white
        bold: true
      }
    }
    prev_1: { label: "0"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box} }
    prev_2: { label: "0"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box} }
    prev_3: { label: "1"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t1}; style.stroke-width: 3 }
    prev_4: { label: "0"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box} }
    prev_5: { label: "2"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t2}; style.stroke-width: 3 }
    prev_6: { label: "3"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t1}; style.stroke-width: 3 }
    prev_7: { label: "4"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t3}; style.stroke-width: 3 }
    prev_8: { label: "5"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t2}; style.stroke-width: 3 }
    prev_9: { label: "6"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t1}; style.stroke-width: 3 }
    prev_10: { label: "7"; shape: rectangle; width: 80; style.fill: ${colors.lsn_box}; style.stroke: ${colors.t3}; style.stroke-width: 3 }
  }
}
legend_section: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  legend_t1: {
    label: "T1 (Blue)"
    shape: rectangle
    width: 80
    style.fill: ${colors.t1}
    style.font-color: white
  }
  legend_t2: {
    label: "T2 (Orange)"
    shape: rectangle
    width: 80
    style.fill: ${colors.t2}
    style.font-color: white
  }
  legend_t3: {
    label: "T3 (Green)"
    shape: rectangle
    width: 80
    style.fill: ${colors.t3}
    style.font-color: white
  }
}
chains_section: {
  direction: down
  style.fill: transparent
  style.stroke: transparent
  chain_title: {
    label: "Transaction Chains (prevLSN → prevLSN → ...)"
    shape: text
    style: { font-size: 20; bold: true; underline: true }
  }
  chains_row: {
    direction: right
    style.fill: transparent
    style.stroke: transparent
    t1_chain: {
      label: "T1 Chain"
      direction: down
      style.fill: "#EBF5FB"
      t1_c9: {
        label: "LSN 9 → LSN 6"
        shape: rectangle
        width: 120
        style.fill: ${colors.t1}
        style.font-color: white
      }
      t1_c6: {
        label: "LSN 6 → LSN 3"
        shape: rectangle
        width: 120
        style.fill: ${colors.t1}
        style.font-color: white
      }
      t1_c3: {
        label: "LSN 3 → LSN 1"
        shape: rectangle
        width: 120
        style.fill: ${colors.t1}
        style.font-color: white
      }
      t1_c1: {
        label: "LSN 1 → 0 (BEGIN)"
        shape: rectangle
        width: 120
        style.fill: ${colors.t1}
        style.font-color: white
      }
      t1_c9 -> t1_c6: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t1} }
      t1_c6 -> t1_c3: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t1} }
      t1_c3 -> t1_c1: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t1} }
    }
    t2_chain: {
      label: "T2 Chain"
      direction: down
      style.fill: "#FEF5E7"
      t2_c8: {
        label: "LSN 8 → LSN 5"
        shape: rectangle
        width: 120
        style.fill: ${colors.t2}
        style.font-color: white
      }
      t2_c5: {
        label: "LSN 5 → LSN 2"
        shape: rectangle
        width: 120
        style.fill: ${colors.t2}
        style.font-color: white
      }
      t2_c2: {
        label: "LSN 2 → 0 (BEGIN)"
        shape: rectangle
        width: 120
        style.fill: ${colors.t2}
        style.font-color: white
      }
      t2_c8 -> t2_c5: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t2} }
      t2_c5 -> t2_c2: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t2} }
    }
    t3_chain: {
      label: "T3 Chain"
      direction: down
      style.fill: "#E9F7EF"
      t3_c10: {
        label: "LSN 10 → LSN 7"
        shape: rectangle
        width: 120
        style.fill: ${colors.t3}
        style.font-color: white
      }
      t3_c7: {
        label: "LSN 7 → LSN 4"
        shape: rectangle
        width: 120
        style.fill: ${colors.t3}
        style.font-color: white
      }
      t3_c4: {
        label: "LSN 4 → 0 (BEGIN)"
        shape: rectangle
        width: 120
        style.fill: ${colors.t3}
        style.font-color: white
      }
      t3_c10 -> t3_c7: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t3} }
      t3_c7 -> t3_c4: "follow" { style.stroke-dash: 3; style.stroke: ${colors.t3} }
    }
  }
}
insight_box: {
  label: |md
    ## Key Insight: O(1) Undo Per Transaction
    **Without prevLSN chain:**
    - Undo T1 requires scanning ALL 10 records
    - Filter for txn_id = T1
    - O(N) where N = total log size
    **With prevLSN chain:**
    - Start at T1's last_lsn = 9
    - Follow: 9 → 6 → 3 → 1 → 0
    - Only 4 hops, regardless of log size
    - O(k) where k = T1's record count
  |
  shape: rectangle
  width: 400
  style: {
    fill: "#FDF2E9"
    stroke: ${colors.highlight}
    stroke-width: 2
  }
}