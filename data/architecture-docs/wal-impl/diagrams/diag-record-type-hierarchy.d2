direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  ## Log Record Type Hierarchy
  Discriminated union with 16-byte base header
| {near: top-center}
# Base header shared by all record types
header_container: {
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
  header: {
    shape: sql_table
    label: "LogRecordHeader (16 bytes)"
    f0: "0x00 | uint64_t | lsn"
    f1: "0x08 | uint32_t | type"
    f2: "0x0C | uint32_t | txn_id"
    f3: "0x10 | uint64_t | prev_lsn"
    f4: "0x18 | uint32_t | length"
  }
}
# Discriminator
discriminator: {
  label: "type field determines payload"
  shape: diamond
  style.fill: "#FFF3E0"
  style.stroke: "#FF9800"
}
header_container -> discriminator: "header.type"
# Record type branches
record_types: {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  # Minimal records column
  minimal: {
    direction: down
    begin: {
      shape: sql_table
      label: "BEGIN (32 bytes)"
      p0: "0x1C | uint32_t | crc32"
      note: "No payload"
    }
    begin.style.fill: "#E8F5E9"
    commit: {
      shape: sql_table
      label: "COMMIT (32 bytes)"
      p0: "0x1C | uint32_t | crc32"
      note: "No payload"
    }
    commit.style.fill: "#C8E6C9"
    abort: {
      shape: sql_table
      label: "ABORT (32 bytes)"
      p0: "0x1C | uint32_t | crc32"
      note: "No payload"
    }
    abort.style.fill: "#FFCDD2"
  }
  # UPDATE record
  update: {
    direction: down
    update_rec: {
      shape: sql_table
      label: "UPDATE (variable)"
      f0: "0x1C | uint64_t  | page_id"
      f1: "0x24 | uint32_t | offset"
      f2: "0x28 | uint32_t | old_value_len"
      f3: "var  | uint8_t[] | old_value"
      f4: "var  | uint32_t | new_value_len"
      f5: "var  | uint8_t[] | new_value"
      f6: "var  | uint32_t | crc32"
    }
    update_rec.style.fill: "#E1F5FE"
    update_note: {
      label: "before-image: undo\nafter-image: redo"
      shape: rectangle
      style.fill: transparent
      style.stroke-dash: 3
      style.font-size: 12
    }
  }
  # CLR record
  clr: {
    direction: down
    clr_rec: {
      shape: sql_table
      label: "CLR (variable)"
      f0: "0x1C | uint64_t  | page_id"
      f1: "0x24 | uint32_t | offset"
      f2: "0x28 | uint32_t | undo_data_len"
      f3: "var  | uint8_t[] | undo_data"
      f4: "var  | uint64_t  | undo_next_lsn"
      f5: "var  | uint32_t | crc32"
    }
    clr_rec.style.fill: "#F3E5F5"
    clr_note: {
      label: "undo_next_lsn: next to undo\n(points to prev_lsn of undone UPDATE)"
      shape: rectangle
      style.fill: transparent
      style.stroke-dash: 3
      style.font-size: 11
    }
  }
  # CHECKPOINT record
  checkpoint: {
    direction: down
    ckpt_rec: {
      shape: sql_table
      label: "CHECKPOINT (variable)"
      f0: "0x1C | uint32_t | num_active_txns"
      f1: "0x20 | TxnEntry[] | active_txns"
      f2: "var  | uint32_t | num_dirty_pages"
      f3: "var  | DirtyEntry[] | dirty_pages"
      f4: "var  | uint32_t | crc32"
    }
    ckpt_rec.style.fill: "#FFF8E1"
    ckpt_note: {
      label: "TxnEntry: {txn_id, status, last_lsn}\nDirtyEntry: {page_id, rec_lsn}"
      shape: rectangle
      style.fill: transparent
      style.stroke-dash: 3
      style.font-size: 11
    }
  }
}
# Connections from discriminator
discriminator -> record_types.minimal.begin: "type=0\nBEGIN"
discriminator -> record_types.update.update_rec: "type=1\nUPDATE"
discriminator -> record_types.minimal.commit: "type=2\nCOMMIT"
discriminator -> record_types.minimal.abort: "type=3\nABORT"
discriminator -> record_types.clr.clr_rec: "type=4\nCLR"
discriminator -> record_types.checkpoint.ckpt_rec: "type=5\nCHECKPOINT"
# Legend
legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#BDBDBD"
  title: "Color Legend"
  minimal_legend: "Minimal (32B)"
  minimal_legend.style.fill: "#E8F5E9"
  update_legend: "UPDATE (redo+undo)"
  update_legend.style.fill: "#E1F5FE"
  clr_legend: "CLR (crash-safe undo)"
  clr_legend.style.fill: "#F3E5F5"
  ckpt_legend: "CHECKPOINT (recovery bound)"
  ckpt_legend.style.fill: "#FFF8E1"
}
# Size summary
sizes: {
  near: bottom-left
  label: |md
    **Fixed Sizes:**
    - Header: 16 bytes
    - Minimal records: 32 bytes (header + CRC)
    **Variable Records:**
    - UPDATE: 48 + old_len + new_len
    - CLR: 56 + undo_len
    - CHECKPOINT: depends on active txn/dirty page count
  |
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#9E9E9E"
  style.stroke-dash: 2
}