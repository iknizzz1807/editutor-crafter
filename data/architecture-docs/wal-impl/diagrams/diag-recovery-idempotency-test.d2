direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Recovery Idempotency Verification
  **Running recovery N times produces identical state S1**
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  crash_state: {
    direction: down
    label: "Crashed Database State"
    log_file: {
      shape: cylinder
      label: "WAL Log File\n(50 GB)"
    }
    pages_disk: {
      label: "Pages on Disk\n(Uncertain State)"
      shape: rectangle
      width: 180
      p1: {
        label: "Page 1\npageLSN: ???\nvalue: ???"
        shape: rectangle
        style.fill: "#FFE4E1"
        style.stroke: "#CD5C5C"
      }
      p2: {
        label: "Page 2\npageLSN: ???\nvalue: ???"
        shape: rectangle
        style.fill: "#FFE4E1"
        style.stroke: "#CD5C5C"
      }
      p3: {
        label: "Page 3\npageLSN: ???\nvalue: ???"
        shape: rectangle
        style.fill: "#FFE4E1"
        style.stroke: "#CD5C5C"
      }
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recovery1: {
    direction: down
    label: "Recovery Run #1"
    width: 350
    analysis1: {
      label: "Analysis Phase"
      code: |'c
        // Scan log from checkpoint
        // Build txn_table, dirty_page_table
        // Find: T1 committed, T2 active
      '|
      width: 320
      style.fill: "#E6E6FA"
    }
    redo1: {
      label: "Redo Phase (Replay ALL)"
      code: |'c
        for each record from min_rec_lsn:
          if (pageLSN >= record.lsn) {
            continue;  // SKIP - already on disk
          }
          apply_change(page, new_value);
          pageLSN = record.lsn;
      '|
      width: 320
      style.fill: "#E0FFFF"
    }
    undo1: {
      label: "Undo Phase (Rollback T2)"
      code: |'c
        while (has_active_txns):
          undo_record = pop_highest_lsn();
          apply_before_image();
          write_CLR(undo_next_lsn);
      '|
      width: 320
      style.fill: "#FFE4B5"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_s1: {
    direction: down
    label: "State S1 (After Recovery #1)"
    pages_s1: {
      label: "Consistent Pages"
      shape: rectangle
      width: 200
      p1_s1: {
        label: "Page 1\npageLSN: 300\nvalue: B (committed)"
        shape: rectangle
        style.fill: "#98FB98"
        style.stroke: "#228B22"
      }
      p2_s1: {
        label: "Page 2\npageLSN: 450\nvalue: X (rolled back)"
        shape: rectangle
        style.fill: "#98FB98"
        style.stroke: "#228B22"
      }
      p3_s1: {
        label: "Page 3\npageLSN: 200\nvalue: unchanged"
        shape: rectangle
        style.fill: "#98FB98"
        style.stroke: "#228B22"
      }
    }
    log_s1: {
      label: "Log After Recovery #1"
      shape: cylinder
      code: |'
        LSN 100: T1 BEGIN
        LSN 150: T1 UPDATE P1 (A→B)
        LSN 200: T1 COMMIT
        LSN 250: T2 BEGIN
        LSN 300: T2 UPDATE P2 (X→Y)
        LSN 350: CLR undo LSN 300
                 undo_next_lsn: 0
        LSN 400: T2 ABORT
      '|
      width: 280
      style.fill: "#F0F8FF"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recovery2: {
    direction: down
    label: "Recovery Run #2 (Same DB)"
    width: 350
    analysis2: {
      label: "Analysis Phase"
      code: |'c
        // Scan log from checkpoint
        // T1: COMMITTED (LSN 200)
        // T2: ABORTED (LSN 400)
        // No active transactions!
      '|
      width: 320
      style.fill: "#E6E6FA"
    }
    redo2: {
      label: "Redo Phase"
      code: |'c
        // LSN 150: pageLSN(300) >= 150 → SKIP
        // LSN 300: pageLSN(450) >= 300 → SKIP
        // LSN 350: pageLSN(450) >= 350 → SKIP
        // All records skipped!
      '|
      width: 320
      style.fill: "#E0FFFF"
    }
    undo2: {
      label: "Undo Phase"
      code: |'c
        // No ACTIVE transactions
        // Nothing to undo
        // Immediate completion
      '|
      width: 320
      style.fill: "#FFE4B5"
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  state_s1_again: {
    direction: down
    label: "State S1 (After Recovery #2)"
    pages_s1_2: {
      label: "Identical Pages"
      shape: rectangle
      width: 200
      p1_s1_2: {
        label: "Page 1\npageLSN: 300\nvalue: B"
        shape: rectangle
        style.fill: "#98FB98"
        style.stroke: "#228B22"
      }
      p2_s1_2: {
        label: "Page 2\npageLSN: 450\nvalue: X"
        shape: rectangle
        style.fill: "#98FB98"
        style.stroke: "#228B22"
      }
      p3_s1_2: {
        label: "Page 3\npageLSN: 200\nvalue: unchanged"
        shape: rectangle
        style.fill: "#98FB98"
        style.stroke: "#228B22"
      }
    }
    verify: {
      label: "Verification"
      code: |'c
        assert(S1_after_run1 == S1_after_run2);
        // pageLSN identical
        // page values identical
        // PASS: Idempotency verified
      '|
      width: 280
      style.fill: "#90EE90"
    }
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recovery_n: {
    direction: down
    label: "Recovery Run #N"
    loop_box: {
      label: "Run Recovery N Times"
      shape: rectangle
      width: 300
      iteration: {
        label: "Each iteration:"
        code: |'c
          for (i = 0; i < N; i++) {
            state_i = crash_recovery(log, pool);
          }
          assert(all states equal S1);
        '|
        width: 280
        style.fill: "#F5F5F5"
      }
    }
  }
}
mechanisms: {
  direction: right
  label: "Idempotency Guarantees"
  pagelsn_box: {
    label: "pageLSN Skip Logic"
    code: |'c
      // In redo_phase():
      if (disk_page.pageLSN >= record.lsn) {
        // Already applied - skip
        continue;
      }
      // Key insight: higher pageLSN means
      // this or later change already on disk
    '|
    width: 320
    style.fill: "#E0FFFF"
    style.stroke: "#008B8B"
  }
  clr_box: {
    label: "CLR Crash Resumption"
    code: |'c
      // In undo_phase():
      if (record.type == CLR) {
        // Follow undo_next_lsn
        // Skip already-undone work
        next = clr.undo_next_lsn;
        continue;
      }
      // Key insight: CLR records what
      // was undone, prevents re-undo
    '|
    width: 320
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
  }
}
crash_state -> recovery1: "Start recovery"
recovery1 -> state_s1: "Produces S1"
state_s1 -> recovery2: "Run again"
recovery2 -> state_s1_again: "Produces S1"
state_s1_again -> recovery_n: "Repeat N times"
recovery_n -> mechanisms: "Why it works"
legend: {
  near: bottom-right
  label: "Legend"
  uncertain: {
    label: "Uncertain state"
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
  }
  consistent: {
    label: "Consistent state"
    style.fill: "#98FB98"
    style.stroke: "#228B22"
  }
  skip: {
    label: "Skip (pageLSN check)"
    style.fill: "#E0FFFF"
  }
  undo: {
    label: "Undo + CLR write"
    style.fill: "#FFE4B5"
  }
}