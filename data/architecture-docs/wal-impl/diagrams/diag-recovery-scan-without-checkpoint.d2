direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Recovery Scan: With vs Without Checkpoint
  Checkpoint bounds recovery time by providing a known starting point
| {near: top-center}
row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  without_checkpoint: {
    direction: down
    label: "WITHOUT CHECKPOINT"
    log_full: {
      label: "Log File (100%)"
      shape: rectangle
      width: 500
      height: 60
      style.fill: "#E8E8E8"
      style.stroke: "#666666"
    }
    scan_arrow: {
      label: "↓ Analysis scans ENTIRE log ↓"
      shape: text
      style.font-color: "#CC0000"
      style.bold: true
    }
    scan_region: {
      label: ""
      shape: rectangle
      width: 500
      height: 40
      style.fill: "#FFCCCC"
      style.stroke: "#CC0000"
      style.stroke-width: 2
    }
    time_box: {
      label: |md
        **Recovery Time: 100%**
        (Full log scan required)
      |
      shape: rectangle
      width: 500
      style.fill: "#FFE0E0"
      style.stroke: "#CC0000"
      style.font-color: "#990000"
    }
  }
  with_checkpoint: {
    direction: down
    label: "WITH CHECKPOINT (50%)"
    log_half: {
      label: ""
      shape: rectangle
      width: 500
      height: 60
      style.fill: "#E8E8E8"
      style.stroke: "#666666"
    }
    checkpoint_marker: {
      label: "CHECKPOINT"
      shape: diamond
      width: 100
      height: 50
      style.fill: "#4CAF50"
      style.stroke: "#2E7D32"
      style.font-color: white
      style.bold: true
    }
    ignored_region: {
      label: "Ignored (already on disk)"
      shape: rectangle
      width: 240
      height: 35
      style.fill: "#E0E0E0"
      style.stroke: "#9E9E9E"
      style.stroke-dash: 3
      style.font-color: "#666666"
    }
    scan_region_half: {
      label: "Analysis scans from checkpoint"
      shape: rectangle
      width: 240
      height: 35
      style.fill: "#C8E6C9"
      style.stroke: "#4CAF50"
      style.stroke-width: 2
    }
    time_box_half: {
      label: |md
        **Recovery Time: ~50%**
        (Checkpoint provides start point)
      |
      shape: rectangle
      width: 500
      style.fill: "#E8F5E9"
      style.stroke: "#4CAF50"
      style.font-color: "#1B5E20"
    }
  }
}
comparison_arrow: {
  label: "50% TIME REDUCTION"
  shape: rectangle
  width: 200
  style.fill: "#E3F2FD"
  style.stroke: "#1976D2"
  style.font-color: "#0D47A1"
  style.bold: true
}
legend: {
  near: bottom-center
  direction: right
  red_box: {
    label: "Full Scan"
    shape: rectangle
    width: 80
    height: 25
    style.fill: "#FFCCCC"
    style.stroke: "#CC0000"
  }
  green_box: {
    label: "Partial Scan"
    shape: rectangle
    width: 80
    height: 25
    style.fill: "#C8E6C9"
    style.stroke: "#4CAF50"
  }
  gray_box: {
    label: "Ignored"
    shape: rectangle
    width: 80
    height: 25
    style.fill: "#E0E0E0"
    style.stroke: "#9E9E9E"
    style.stroke-dash: 3
  }
}
without_checkpoint.log_full -> without_checkpoint.scan_region: "LSN 0" {
  style.stroke: "#CC0000"
  style.stroke-width: 2
}
without_checkpoint.scan_region -> without_checkpoint.time_box: "scan entire log" {
  style.stroke: "#CC0000"
}
with_checkpoint.log_half -> with_checkpoint.checkpoint_marker: "LSN 0 → Checkpoint" {
  style.stroke-dash: 3
  style.stroke: "#9E9E9E"
}
with_checkpoint.checkpoint_marker -> with_checkpoint.scan_region_half: "start here" {
  style.stroke: "#4CAF50"
  style.stroke-width: 2
}
with_checkpoint.scan_region_half -> with_checkpoint.time_box_half: "scan 50%" {
  style.stroke: "#4CAF50"
}
without_checkpoint.time_box -> comparison_arrow: "vs"
comparison_arrow -> with_checkpoint.time_box_half