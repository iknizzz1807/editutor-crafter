direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: {
  label: |md
    # Three-Transaction Recovery Test Scenario
    ARIES crash recovery with mixed transaction states
  |
  near: top-center
  shape: text
  style.font-size: 28
}
row_timeline: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  timeline: {
    direction: down
    label: "Log Timeline (LSN →)"
    t1_start: {
      shape: circle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      width: 60
      label: "T1\nBEGIN"
    }
    t1_update: {
      shape: rectangle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      width: 100
      label: "T1 UPDATE\npage 5\nA→B"
    }
    t1_commit: {
      shape: diamond
      style.fill: "#228B22"
      style.stroke: "#228B22"
      style.font-color: white
      width: 70
      label: "T1\nCOMMIT"
    }
    t2_start: {
      shape: circle
      style.fill: "#FFE4B5"
      style.stroke: "#FF8C00"
      width: 60
      label: "T2\nBEGIN"
    }
    t2_update: {
      shape: rectangle
      style.fill: "#FFE4B5"
      style.stroke: "#FF8C00"
      width: 100
      label: "T2 UPDATE\npage 7\nX→Y"
    }
    t2_clr: {
      shape: hexagon
      style.fill: "#FF6B6B"
      style.stroke: "#CC0000"
      width: 80
      label: "T2 CLR\nundo\nY→X"
    }
    t2_abort: {
      shape: diamond
      style.fill: "#CC0000"
      style.stroke: "#CC0000"
      style.font-color: white
      width: 70
      label: "T2\nABORT"
    }
    t3_start: {
      shape: circle
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
      width: 60
      label: "T3\nBEGIN"
    }
    t3_update: {
      shape: rectangle
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
      width: 100
      label: "T3 UPDATE\npage 3\nP→Q"
    }
    crash_marker: {
      shape: diamond
      style.fill: "#8B0000"
      style.stroke: "#8B0000"
      style.font-color: white
      width: 80
      label: "💥\nCRASH"
    }
    t1_start -> t1_update -> t1_commit
    t1_commit -> t2_start -> t2_update -> t2_clr -> t2_abort
    t2_abort -> t3_start -> t3_update -> crash_marker
  }
}
row_recovery: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  recovery: {
    direction: down
    label: "Recovery Analysis"
    analysis: {
      shape: rectangle
      style.fill: "#E8E8E8"
      style.stroke: "#666"
      width: 200
      label: |md
        **ANALYSIS PHASE**
        Scan log → build tables
        T1: COMMITTED ✓
        T2: ABORTED ✓
        T3: ACTIVE (needs undo)
      |
    }
    redo: {
      shape: rectangle
      style.fill: "#E8E8E8"
      style.stroke: "#666"
      width: 200
      label: |md
        **REDO PHASE**
        Replay ALL changes
        T1 UPDATE: page 5 = B
        T2 UPDATE: page 7 = Y
        T3 UPDATE: page 3 = Q
      |
    }
    undo: {
      shape: rectangle
      style.fill: "#E8E8E8"
      style.stroke: "#666"
      width: 200
      label: |md
        **UNDO PHASE**
        Rollback ACTIVE only
        T3: undo page 3 Q→P
        write CLR, write ABORT
      |
    }
    analysis -> redo -> undo
  }
  state_table: {
    direction: down
    label: "Transaction Table @ Crash"
    shape: sql_table
    txn_id: "txn_id | status | first_lsn | last_lsn"
    t1_row: "1 | COMMITTED | 100 | 300"
    t2_row: "2 | ABORTED | 350 | 550"
    t3_row: "3 | ACTIVE | 600 | 700"
    note: "Only T3 needs undo"
  }
}
row_result: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  result: {
    direction: down
    label: "Post-Recovery Page State"
    page5: {
      shape: rectangle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
      style.stroke-width: 3
      width: 140
      height: 80
      label: |md
        **Page 5**
        Value: **B**
        ✓ T1 committed
      |
    }
    page7: {
      shape: rectangle
      style.fill: "#FFE4B5"
      style.stroke: "#FF8C00"
      style.stroke-width: 3
      width: 140
      height: 80
      label: |md
        **Page 7**
        Value: **X**
        ↩ T2 rolled back
      |
    }
    page3: {
      shape: rectangle
      style.fill: "#ADD8E6"
      style.stroke: "#4169E1"
      style.stroke-width: 3
      width: 140
      height: 80
      label: |md
        **Page 3**
        Value: **P**
        ↩ T3 rolled back
      |
    }
  }
}
row_timeline -> row_recovery: "Recovery Process"
row_recovery -> row_result: "Final State"
legend: {
  near: bottom-right
  direction: right
  style.fill: "#F5F5F5"
  style.stroke: "#CCC"
  committed: {
    shape: circle
    style.fill: "#228B22"
    width: 20
    label: ""
  }
  committed_label: "Committed"
  aborted: {
    shape: circle
    style.fill: "#CC0000"
    width: 20
    label: ""
  }
  aborted_label: "Aborted"
  active: {
    shape: circle
    style.fill: "#4169E1"
    width: 20
    label: ""
  }
  active_label: "Active @ crash"
}
committed -> committed_label
aborted -> aborted_label
active -> active_label