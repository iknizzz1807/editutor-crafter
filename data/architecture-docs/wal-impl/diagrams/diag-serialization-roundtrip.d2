direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Serialization/Deserialization Round-Trip
  Log Record Binary Format Transformation Pipeline
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c_struct: {
    label: "C Struct (Memory)"
    width: 320
    struct: {
      shape: class
      label: "UpdateRecord"
      header_lsn: "uint64_t"
      header_type: "uint32_t"
      header_txn_id: "uint32_t"
      header_prev_lsn: "uint64_t"
      header_length: "uint32_t"
      page_id: "uint64_t"
      offset: "uint32_t"
      old_value_len: "uint32_t"
      old_value: "uint8_t*"
      new_value_len: "uint32_t"
      new_value: "uint8_t*"
    }
    example: {
      shape: sql_table
      label: "Example Values"
      f1: "lsn = 1000"
      f2: "type = UPDATE (0x02)"
      f3: "txn_id = 42"
      f4: "prev_lsn = 500"
      f5: "page_id = 7"
      f6: "offset = 24"
      f7: "old = {0xDE,0xAD}"
      f8: "new = {0xCA,0xFE}"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  serialize_step: {
    width: 180
    label: "serialize_update_record()"
    code: |'c
      // Write little-endian
      write_le64(rec->lsn);
      write_le32(rec->type);
      write_le32(rec->txn_id);
      // ... length-prefix
      // variable fields
      memcpy(buf, old_val);
      memcpy(buf, new_val);
      // CRC last
      write_le32(crc32(buf));
    '|
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  byte_buffer: {
    label: "Byte Buffer (Serialized)"
    width: 400
    hex_dump: {
      shape: sql_table
      label: "Hex Dump (Little-Endian)"
      offset0: "0x00 | e8 03 00 00 00 00 00 00 | lsn=1000"
      offset8: "0x08 | 02 00 00 00             | type=UPDATE"
      offset12: "0x0c | 2a 00 00 00             | txn_id=42"
      offset16: "0x10 | f4 01 00 00 00 00 00 00 | prev_lsn=500"
      offset24: "0x18 | 30 00 00 00             | length=48"
      offset28: "0x1c | 07 00 00 00 00 00 00 00 | page_id=7"
      offset36: "0x24 | 18 00 00 00             | offset=24"
      offset40: "0x28 | 02 00 00 00             | old_len=2"
      offset44: "0x2c | de ad                   | old_value"
      offset46: "0x2e | 02 00 00 00             | new_len=2"
      offset50: "0x32 | ca fe                   | new_value"
      offset52: "0x34 | a3 b7 c1 09             | CRC32"
      total: "Total: 56 bytes"
    }
    note: {
      shape: rectangle
      width: 380
      label: |md
        **Key Points:**
        - All integers in little-endian
        - Variable fields length-prefixed
        - No padding between fields
        - CRC covers bytes 0-51
      |
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  file_ops: {
    label: "File I/O"
    direction: right
    width: 500
    write_op: {
      label: "write()"
      code: |'c
        ssize_t written = 
          write(log_fd, buffer, 56);
        // OS copies to page cache
        // ~1μs latency
      '|
    }
    disk: {
      shape: cylinder
      label: "Log File\n(wal.000001)"
    }
    read_op: {
      label: "read()"
      code: |'c
        ssize_t n = 
          read(log_fd, buffer, 56);
        // OS copies from page cache
        // ~1μs latency
      '|
    }
  }
}
row5: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  deserialize_step: {
    width: 180
    label: "deserialize_update_record()"
    code: |'c
      // Read header first
      rec->lsn = read_le64(buf);
      rec->type = read_le32(buf+8);
      // ...
      // Verify CRC BEFORE use
      stored = read_le32(buf+len-4);
      computed = crc32(buf, len-4);
      if (stored != computed)
        return ERR_CORRUPT;
      // Allocate + copy var fields
      rec->old = malloc(old_len);
      memcpy(rec->old, ...);
    '|
  }
}
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  c_struct_out: {
    label: "C Struct (Reconstructed)"
    width: 320
    struct_out: {
      shape: class
      label: "UpdateRecord (deserialized)"
      header_lsn: "uint64_t = 1000"
      header_type: "uint32_t = 2"
      header_txn_id: "uint32_t = 42"
      header_prev_lsn: "uint64_t = 500"
      header_length: "uint32_t = 56"
      page_id: "uint64_t = 7"
      offset: "uint32_t = 24"
      old_value_len: "uint32_t = 2"
      old_value: "uint8_t* → {0xDE,0xAD}"
      new_value_len: "uint32_t = 2"
      new_value: "uint8_t* → {0xCA,0xFE}"
    }
    verify: {
      shape: diamond
      label: "Round-Trip\nVerified?"
    }
  }
}
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  verification: {
    width: 450
    label: "Round-Trip Verification"
    code: |'c
      void test_update_roundtrip(void) {
        UpdateRecord original = { .lsn=1000, .type=RECORD_UPDATE,
          .txn_id=42, .prev_lsn=500, .page_id=7, .offset=24,
          .old_value = {0xDE,0xAD}, .new_value = {0xCA,0xFE} };
        uint8_t buffer[256];
        ssize_t written = serialize_update_record(&original, buffer);
        UpdateRecord parsed = {0};
        ssize_t consumed = deserialize_update_record(buffer, written, &parsed);
        assert(consumed == written);
        assert(parsed.lsn == original.lsn);
        assert(memcmp(parsed.old_value, original.old_value, 2) == 0);
        assert(memcmp(parsed.new_value, original.new_value, 2) == 0);
        // Byte-perfect round-trip achieved!
      }
    '|
  }
}
legend: {
  near: bottom-right
  label: "Data Sizes"
  sizes: {
    shape: sql_table
    label: "Record Component Sizes"
    h: "Header: 28 bytes"
    p: "Page info: 12 bytes"
    o: "Old value: 4 + 2 = 6 bytes"
    n: "New value: 4 + 2 = 6 bytes"
    c: "CRC32: 4 bytes"
    t: "Total: 56 bytes"
  }
}
c_struct -> serialize_step: "struct*"
serialize_step -> byte_buffer: "uint8_t[]"
byte_buffer -> file_ops.write_op: "buffer"
file_ops.write_op -> file_ops.disk: "56 bytes"
file_ops.disk -> file_ops.read_op: "56 bytes"
file_ops.read_op -> deserialize_step: "buffer"
deserialize_step -> c_struct_out: "UpdateRecord*"
c_struct_out.verify -> verification: "PASS"
serialize_step -> byte_buffer: {
  style.stroke: blue
  style.stroke-width: 2
  label: "transforms"
}
deserialize_step -> c_struct_out: {
  style.stroke: green
  style.stroke-width: 2
  label: "reconstructs"
}
file_ops.write_op -> file_ops.disk: {
  style.stroke: purple
  style.animated: true
}
file_ops.disk -> file_ops.read_op: {
  style.stroke: purple
  style.animated: true
}