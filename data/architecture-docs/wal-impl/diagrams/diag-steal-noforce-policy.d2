direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Steal/No-Force Buffer Pool Policy
  **Why WAL is Necessary for Durability**
| {near: top-center}
row_compare: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  left_panel: "STEAL Policy" {
    direction: down
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    steal_title: |md
      **Steal = YES**
      Uncommitted changes CAN be written to disk
    |
    steal_mem: "Memory (Buffer Pool)" {
      style.fill: "#BBDEFB"
      style.stroke: "#1976D2"
      txn_t1: "T1 (ACTIVE)\nPage 5: A→B\nuncommitted" {
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        style.bold: true
      }
      txn_t2: "T2 (COMMITTED)\nPage 7: X→Y" {
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
    }
    steal_disk: "Disk (Data Files)" {
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
      disk_p5: "Page 5\n= B (T1's uncommitted!)" {
        style.fill: "#FFCDD2"
        style.stroke: "#C62828"
        style.bold: true
      }
      disk_p7: "Page 7\n= Y (committed)" {
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
    }
    steal_arrow: steal_mem.txn_t1 -> steal_disk.disk_p5: "evict dirty page\n(steal allowed)" {
      style.stroke: "#C62828"
      style.stroke-width: 3
      style.stroke-dash: 4
      style.animated: true
    }
  }
  right_panel: "NO-FORCE Policy" {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    force_title: |md
      **Force = NO**
      Commit does NOT flush pages to disk
    |
    force_mem: "Memory (Buffer Pool)" {
      style.fill: "#FFE0B2"
      style.stroke: "#F57C00"
      f_txn_t1: "T1 (COMMITTED)\nPage 5: A→B" {
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
      f_txn_t2: "T2 (COMMITTED)\nPage 7: X→Y" {
        style.fill: "#C8E6C9"
        style.stroke: "#2E7D32"
      }
    }
    force_disk: "Disk (Data Files)" {
      style.fill: "#FFCC80"
      style.stroke: "#EF6C00"
      f_disk_p5: "Page 5\n= A (old value!)" {
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
        style.bold: true
      }
      f_disk_p7: "Page 7\n= X (old value!)" {
        style.fill: "#FFF9C4"
        style.stroke: "#F9A825"
      }
    }
    force_gap: "commit returns\nWITHOUT flush" {
      style.fill: transparent
      style.stroke: transparent
    }
    force_noarrow: force_mem -> force_disk: "NOT flushed!\n(no-force policy)" {
      style.stroke: "#F57C00"
      style.stroke-width: 2
      style.stroke-dash: 6
      style.font-color: "#E65100"
    }
  }
}
danger_zone: "THE DANGER ZONE" {
  direction: right
  style.fill: "#FFEBEE"
  style.stroke: "#B71C1C"
  style.stroke-width: 3
  danger_content: "" {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    danger_title: |md
      ## After Crash, Disk State is Uncertain:
    |
    danger_table: {
      shape: sql_table
      label: "Disk State After Crash"
      row1: "Uncommitted data | May be present (steal wrote it)"
      row2: "Committed data | May be MISSING (no-force didn't flush)"
      row3: "Problem | No way to distinguish or fix without WAL"
    }
  }
  danger_example: "" {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    example_title: |md
      ### Concrete Example:
    |
    scenario: {
      shape: class
      label: "Crash Scenario"
      step1: "T1 updates Page 5: A → B (uncommitted)"
      step2: "Buffer pool evicts Page 5 → disk has B"
      step3: "T1 commits → client told 'success'"
      step4: "CRASH before Page 5 re-flushed"
      step5: "Recovery: disk has B, but T1 committed"
      step6: "Without WAL: Is B correct? Corrupted? Unknown!"
    }
  }
}
solution: "THE WAL SOLUTION" {
  direction: right
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 3
  solution_content: "" {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    wal_title: |md
      ## Write-Ahead Logging Guarantees:
    |
    wal_rules: {
      shape: sql_table
      label: "WAL Rules"
      rule1: "UNDO Rule | Log before-image BEFORE page write | Enables rollback of uncommitted"
      rule2: "REDO Rule | Log after-image BEFORE commit | Enables replay of committed"
      rule3: "WAL Protocol | Log record must be on disk BEFORE data page"
    }
  }
  solution_diagram: "" {
    direction: down
    style.fill: transparent
    style.stroke: transparent
    sol_flow: {
      shape: class
      label: "Recovery with WAL"
      step1: "REDO: Replay all logged changes (committed + uncommitted)"
      step2: "UNDO: Roll back uncommitted using before-images"
      step3: "Result: Committed preserved, uncommitted removed"
    }
  }
}
left_panel -> danger_zone: "creates" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
right_panel -> danger_zone: "creates" {
  style.stroke: "#B71C1C"
  style.stroke-dash: 4
}
danger_zone -> solution: "solved by" {
  style.stroke: "#2E7D32"
  style.stroke-width: 3
}
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#9E9E9E"
  l_title: "Legend"
  l_red: "Red = Uncommitted/Danger" {style.fill: "#FFCDD2"}
  l_green: "Green = Committed/Safe" {style.fill: "#C8E6C9"}
  l_yellow: "Yellow = Stale/Unknown" {style.fill: "#FFF9C4"}
}