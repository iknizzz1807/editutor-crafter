direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Transaction State Machine with Log Records
| {near: top-center}
# State definitions
active: {
  shape: circle
  label: ACTIVE
  style: {
    fill: "#E8F5E9"
    stroke: "#2E7D32"
    stroke-width: 3
    font-color: "#1B5E20"
    bold: true
  }
  log_record: {
    label: "BEGIN record written"
    shape: rectangle
    width: 180
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#666666"
      font-size: 14
      italic: true
    }
  }
}
committing: {
  shape: oval
  label: COMMITTING
  style: {
    fill: "#FFF3E0"
    stroke: "#E65100"
    stroke-width: 3
    font-color: "#BF360C"
    bold: true
  }
  log_record: {
    label: "COMMIT record written\nawaiting fsync()"
    shape: rectangle
    width: 200
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#666666"
      font-size: 14
      italic: true
    }
  }
}
committed: {
  shape: circle
  label: COMMITTED
  style: {
    fill: "#C8E6C9"
    stroke: "#1B5E20"
    stroke-width: 4
    font-color: "#1B5E20"
    bold: true
    shadow: true
  }
  log_record: {
    label: "fsync() complete\nTransaction durable"
    shape: rectangle
    width: 180
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#2E7D32"
      font-size: 14
      italic: true
    }
  }
}
aborting: {
  shape: oval
  label: ABORTING
  style: {
    fill: "#FFEBEE"
    stroke: "#C62828"
    stroke-width: 3
    font-color: "#B71C1C"
    bold: true
  }
  log_record: {
    label: "CLR records written\nfor each UPDATE"
    shape: rectangle
    width: 200
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#666666"
      font-size: 14
      italic: true
    }
  }
}
aborted: {
  shape: circle
  label: ABORTED
  style: {
    fill: "#FFCDD2"
    stroke: "#B71C1C"
    stroke-width: 4
    font-color: "#B71C1C"
    bold: true
    shadow: true
  }
  log_record: {
    label: "ABORT record written\nRollback complete"
    shape: rectangle
    width: 180
    style: {
      fill: transparent
      stroke: transparent
      font-color: "#C62828"
      font-size: 14
      italic: true
    }
  }
}
# Transitions
active -> committing: {
  label: "commit_txn()\nwrite COMMIT"
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    font-color: "#1B5E20"
  }
}
committing -> committed: {
  label: "fsync() returns"
  style: {
    stroke: "#1B5E20"
    stroke-width: 3
    font-color: "#1B5E20"
    bold: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
  }
}
active -> aborting: {
  label: "abort_txn()\nor rollback trigger"
  style: {
    stroke: "#C62828"
    stroke-width: 2
    font-color: "#B71C1C"
  }
}
aborting -> aborted: {
  label: "All CLRs written\nABORT record logged"
  style: {
    stroke: "#B71C1C"
    stroke-width: 3
    font-color: "#B71C1C"
    bold: true
  }
  source-arrowhead: {
    shape: triangle
    style.filled: true
  }
}
# Self-loop for active state (UPDATE records)
active -> active: {
  label: "write_txn()\nwrite UPDATE"
  style: {
    stroke: "#1976D2"
    stroke-width: 2
    font-color: "#0D47A1"
    stroke-dash: 3
  }
}
# Legend
legend: {
  near: bottom-center
  label: "Log Record Types"
  begin_box: {
    shape: rectangle
    label: "BEGIN"
    width: 70
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      font-size: 12
    }
  }
  update_box: {
    shape: rectangle
    label: "UPDATE"
    width: 70
    style: {
      fill: "#E3F2FD"
      stroke: "#1976D2"
      font-size: 12
    }
  }
  commit_box: {
    shape: rectangle
    label: "COMMIT"
    width: 70
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      font-size: 12
    }
  }
  clr_box: {
    shape: rectangle
    label: "CLR"
    width: 70
    style: {
      fill: "#FCE4EC"
      stroke: "#C2185B"
      font-size: 12
    }
  }
  abort_box: {
    shape: rectangle
    label: "ABORT"
    width: 70
    style: {
      fill: "#FFEBEE"
      stroke: "#C62828"
      font-size: 12
    }
  }
  legend_row: "" {
    direction: right
    style: {
      fill: transparent
      stroke: transparent
    }
    begin_box
    update_box
    commit_box
    clr_box
    abort_box
  }
}
# Note about prev_lsn chain
note: {
  near: bottom-right
  label: |md
    **prev_lsn Chain:**
    - Each record links to previous
    - BEGIN: prev_lsn = 0
    - UPDATE N: prev_lsn = UPDATE N-1
    - COMMIT/ABORT: prev_lsn = last UPDATE
  |
  shape: rectangle
  width: 220
  style: {
    fill: "#F5F5F5"
    stroke: "#9E9E9E"
    stroke-dash: 2
    font-size: 12
  }
}