log_file.lsn250 -> txn_chains.t5_chain.t5_l250: "T5" {style.stroke-dash: 3}
log_file.lsn300 -> txn_chains.t3_chain.t3_l300: "T3" {style.stroke-dash: 3}
log_file.lsn350 -> txn_chains.t5_chain.t5_l350: "T5" {style.stroke-dash: 3}
log_file.lsn400 -> txn_chains.t2_chain.t2_l400: "T2" {style.stroke-dash: 3}
log_file.lsn450 -> txn_chains.t3_chain.t3_l450: "T3" {style.stroke-dash: 3}
log_file.lsn500 -> txn_chains.t5_chain.t5_l500: "T5" {style.stroke-dash: 3}