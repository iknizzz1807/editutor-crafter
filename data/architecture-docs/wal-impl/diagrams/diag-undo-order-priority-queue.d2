row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  wrong_order: {
    direction: down
    label: "WRONG: Per-Transaction Undo"
    style.stroke: "#F44336"
    style.stroke-dash: 4
    style.fill: "#FFEBEE"
    wrong_explain: {
      label: "Undo T2 fully, then T3, then T5"
      shape: text
      style.font-color: "#C62828"
    }
    wrong_seq: {
      direction: down
      label: ""
      w1: "Undo 400 (T2 page 5: E→F)"
      w2: "Undo 200 (T2 page 3: C→D)"
      w3: "Undo 100 (T2 page 1: A→B)"
      w4: "Undo 450 (T3 page 5: K→L)"
      w5: "Undo 300 (T3 page 4: I→J)"
      w6: "Undo 150 (T3 page 2: G→H)"
      w7: "Undo 500 (T5 page 5: O→P)"
      w8: "Undo 350 (T5 page 4: M→N)"
      w9: "Undo 250 (T5 page 3: ???)"
    }
    wrong_problem: {
      label: |md
        **PROBLEM:** Page 5 modified by:
        - LSN 400 (T2)
        - LSN 450 (T3)
        Undo 400 restores page 5 to "E".
        Undo 450 then restores to "K".
        But T3's before-image "K" assumes
        page 5 has T2's after-image "F"!
        **Wrong value! Data corruption!**
      |
      shape: rectangle
      style.fill: "#FFCDD2"
      width: 280
    }
  }
  right_order: {
    direction: down
    label: "CORRECT: Global LSN Priority"
    style.stroke: "#4CAF50"
    style.fill: "#E8F5E9"
    right_explain: {
      label: "Priority queue: highest LSN first"
      shape: text
      style.font-color: "#2E7D32"
    }
    pq: {
      direction: down
      label: "Priority Queue (max-heap by LSN)"
      pq_init: {
        direction: right
        label: "Initial: [500, 450, 400]"
        pq500: {
          label: "500"
          shape: circle
          style.fill: "#FF9800"
          style.font-color: white
          width: 45
        }
        pq450: {
          label: "450"
          shape: circle
          style.fill: "#2196F3"
          style.font-color: white
          width: 45
        }
        pq400: {
          label: "400"
          shape: circle
          style.fill: "#4CAF50"
          style.font-color: white
          width: 45
        }
      }
    }
    right_seq: {
      direction: down
      label: "Correct Undo Sequence"
      r1: {
        label: "1. Pop 500 → Undo T5 (page 5: O→P)"
        style.fill: "#FFF3E0"
      }
      r2: {
        label: "2. Pop 450 → Undo T3 (page 5: K→L)"
        style.fill: "#E3F2FD"
      }
      r3: {
        label: "3. Pop 400 → Undo T2 (page 5: E→F)"
        style.fill: "#E8F5E9"
      }
      r4: {
        label: "4. Pop 350 → Undo T5 (page 4: M→N)"
        style.fill: "#FFF3E0"
      }
      r5: {
        label: "5. Pop 300 → Undo T3 (page 4: I→J)"
        style.fill: "#E3F2FD"
      }
      r6: {
        label: "6. Pop 250 → Undo T5 (page 3: ???)"
        style.fill: "#FFF3E0"
      }
      r7: {
        label: "7. Pop 200 → Undo T2 (page 3: C→D)"
        style.fill: "#E8F5E9"
      }
      r8: {
        label: "8. Pop 150 → Undo T3 (page 2: G→H)"
        style.fill: "#E3F2FD"
      }
      r9: {
        label: "9. Pop 100 → Undo T2 (page 1: A→B)"
        style.fill: "#E8F5E9"
      }
    }
    right_correct: {
      label: |md
        **CORRECT:** Page 5 undo order:
        1. LSN 500 (T5) - most recent
        2. LSN 450 (T3) - second most recent
        3. LSN 400 (T2) - oldest modification
        Each undo sees the correct before-image
        because we undo in **reverse chronological
        order across ALL transactions**.
      |
      shape: rectangle
      style.fill: "#C8E6C9"
      width: 280
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  algorithm: {
    direction: down
    label: "Priority Queue Algorithm (wal_recovery.c)"
    code: |'c
      // Build priority queue from active transactions
      PriorityQueue pq;
      pq_init(&pq);
      for (each ACTIVE txn in txn_table) {
          // Push last_lsn with txn_id for tracking
          pq_push(&pq, (UndoWork){
              .txn_id = entry->txn_id,
              .lsn = entry->last_lsn
          });
      }
      while (!pq_empty(&pq)) {
          // Always pop highest LSN across ALL txns
          UndoWork work = pq_pop_max(&pq);
          UpdateRecord rec = read_record(work.lsn);
          apply_before_image(rec);  // Undo
          write_clr(rec);           // Log the undo
          // Add prev record to queue if exists
          if (rec.header.prev_lsn > 0) {
              pq_push(&pq, (UndoWork){
                  .txn_id = work.txn_id,
                  .lsn = rec.header.prev_lsn
              });
          }
      }
    '|
    width: 420
  }
  key_insight: {
    direction: down
    label: "Key Insight"
    insight_box: {
      label: |md
        ### Why Global Order Matters
        When multiple transactions modify the **same page**,
        each transaction's before-image assumes the page
        is in the state left by the **previous modification**.
        If T2 modified page 5 at LSN 400, and T3 modified
        page 5 at LSN 450, then:
        - T3's before-image is the state **after** LSN 400
        - T2's before-image is the state **before** LSN 400
        Undo T2 first? You overwrite T3's before-image.
        Undo T3 first? You restore correct intermediate state.
        **Always undo most recent first (highest LSN).**
      |
      shape: rectangle
      style.fill: "#E8EAF6"
      width: 340
    }
  }
}
log_file.lsn100 -> txn_chains.t2_chain.t2_l100: "T2" {style.stroke-dash: 3}
