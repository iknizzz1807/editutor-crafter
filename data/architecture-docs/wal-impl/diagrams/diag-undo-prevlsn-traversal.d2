direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Undo Phase: prevLSN Chain Traversal
  Backward walk through log for transaction T5
| {near: top-center}
row1: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  txn_state: {
    label: "Active Transaction Entry"
    shape: class
    txn_id: "uint32"
    status: "TxnStatus"
    first_lsn: "uint64"
    last_lsn: "uint64"
  }
  txn_example: {
    label: "T5 State at Crash"
    shape: sql_table
    f0: "txn_id | 5"
    f1: "status | ACTIVE"
    f2: "first_lsn | 100"
    f3: "last_lsn | 250"
  }
}
row2: "" {
  direction: right
  style.fill: transparent
  style.stroke: transparent
  log_chain: {
    direction: down
    label: "Log Records (LSN → Record)"
    rec100: {
      label: "LSN 100"
      shape: rectangle
      width: 200
      code: |'c
        BEGIN {txn_id=5, prev_lsn=0}
      '|
      style.fill: "#E8F5E9"
    }
    rec150: {
      label: "LSN 150"
      shape: rectangle
      width: 200
      code: |'c
        UPDATE {txn_id=5, prev_lsn=100,
          page=7, old='X', new='Y'}
      '|
      style.fill: "#FFF3E0"
    }
    rec200: {
      label: "LSN 200"
      shape: rectangle
      width: 200
      code: |'c
        UPDATE {txn_id=5, prev_lsn=150,
          page=3, old='A', new='B'}
      '|
      style.fill: "#FFF3E0"
    }
    rec250: {
      label: "LSN 250"
      shape: rectangle
      width: 200
      code: |'c
        UPDATE {txn_id=5, prev_lsn=200,
          page=9, old='P', new='Q'}
      '|
      style.fill: "#FFF3E0"
    }
    rec100 -> rec150: "prev_lsn chain" {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
    rec150 -> rec200: "prev_lsn chain" {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
    rec200 -> rec250: "prev_lsn chain" {
      style.stroke: "#1976D2"
      style.stroke-width: 2
    }
  }
  undo_process: {
    direction: down
    label: "Undo Process (Reverse Order)"
    step1: {
      label: "Step 1: Undo LSN 250"
      shape: rectangle
      width: 280
      code: |'c
        // Start at last_lsn=250
        apply(page=9, old='P')  // Undo
        write CLR {lsn=300,
          undo_next_lsn=200}
      '|
      style.fill: "#FFEBEE"
    }
    step2: {
      label: "Step 2: Undo LSN 200"
      shape: rectangle
      width: 280
      code: |'c
        // Follow prev_lsn=200
        apply(page=3, old='A')  // Undo
        write CLR {lsn=350,
          undo_next_lsn=150}
      '|
      style.fill: "#FFEBEE"
    }
    step3: {
      label: "Step 3: Undo LSN 150"
      shape: rectangle
      width: 280
      code: |'c
        // Follow prev_lsn=150
        apply(page=7, old='X')  // Undo
        write CLR {lsn=400,
          undo_next_lsn=100}
      '|
      style.fill: "#FFEBEE"
    }
    step4: {
      label: "Step 4: Reached BEGIN"
      shape: rectangle
      width: 280
      code: |'c
        // prev_lsn=100 is BEGIN
        // No more to undo
        write ABORT {txn_id=5}
      '|
      style.fill: "#E8F5E9"
    }
    step1 -> step2: "follow prev_lsn" {
      style.stroke: "#D32F2F"
      style.stroke-dash: 4
    }
    step2 -> step3: "follow prev_lsn" {
      style.stroke: "#D32F2F"
      style.stroke-dash: 4
    }
    step3 -> step4: "follow prev_lsn" {
      style.stroke: "#D32F2F"
      style.stroke-dash: 4
    }
  }
}
txn_example -> log_chain.rec250: "start here\n(last_lsn)" {
  style.stroke: "#388E3C"
  style.stroke-width: 3
  style.bold: true
}
log_chain.rec100 -> undo_process.step4: "BEGIN found\nundo complete" {
  style.stroke: "#388E3C"
  style.stroke-dash: 3
}
legend: {
  near: bottom-center
  direction: right
  style.fill: transparent
  l1: "BEGIN record" {
    shape: rectangle
    style.fill: "#E8F5E9"
    width: 100
  }
  l2: "UPDATE record" {
    shape: rectangle
    style.fill: "#FFF3E0"
    width: 100
  }
  l3: "Undo action" {
    shape: rectangle
    style.fill: "#FFEBEE"
    width: 100
  }
}
note: |md
  **Key Insight**: prev_lsn forms a backward-linked list within each transaction.
  Undo traverses this chain from `last_lsn` to `first_lsn`, applying before-images
  and writing CLRs to enable crash-safe recovery resumption.
| {near: bottom-center}