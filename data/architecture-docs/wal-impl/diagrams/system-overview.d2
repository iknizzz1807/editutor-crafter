      checkpoint_count: "uint64_t | statistics"
      active_txn_table: "TransactionTable*"
      active_dpt: "DirtyPageTable*"
      wal_writer: "WalWriter*"
      master_record_path: "char[256]"
      "+checkpoint_manager_init(mgr, ...)": "int"
      +checkpoint_take(mgr, trigger, lsn): "int"
      +checkpoint_is_in_progress(mgr): "bool"
    }
    checkpoint_flow: {
      shape: class
      label: "Fuzzy Checkpoint Flow"
      step1: "1. Write CHECKPOINT_BEGIN"
      step2: "2. Capture txn_table snapshot (<100us)"
      step3: "3. Capture DPT snapshot (<100us)"
      step4: "4. Write CHECKPOINT_END"
      step5: "5. fsync log"
      step6: "6. Update master record (atomic)"
      note: "Transactions continue during 2-6"
    }
  }
}
# =====================================
# ROW 9: TRUNCATION (M4)
# =====================================
row9: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_truncator: {
    direction: down
    label: "LOG TRUNCATOR  [M4]"
    segment_metadata: {
      shape: sql_table
      label: "struct SegmentMetadata (wal_truncate.h)  [M4]"
      segment_id: "uint32_t"
      file_path: "char[512]"
      start_lsn: "uint64_t"
      end_lsn: "uint64_t"
      file_size: "uint64_t"
      is_active: "bool"
    }
    log_truncator: {
      shape: class
      label: "LogTruncator (wal_truncate.h)"
      base_path: "const char*"
      segments: "SegmentMetadata*"
      segment_count: "size_t"
      +truncator_init(truncator, base_path): "int"
      +truncator_scan_segments(truncator): "int"
      "+truncator_can_delete_segment(...)": "bool"
      +truncator_truncate(truncator, snapshot, result): "int"
    }
    truncation_result: {
      shape: sql_table
      label: "TruncationResult"
      segments_deleted: "uint32_t"
      bytes_freed: "uint64_t"
      segments_blocked: "uint32_t"
      blocking_txns: "uint32_t"
    }
  }
  layer_truncation_rules: {
    direction: down
    label: "TRUNCATION SAFETY  [M4]"
    truncation_rules: {
      shape: class
      label: "Safety Rules"
      rule1: "Rule 1: segment.end_lsn < checkpoint.min_rec_lsn"
      reason1: "Segment not needed for redo"
      rule2: "Rule 2: No active txn first_lsn in segment"
      reason2: "Segment not needed for undo"
      active: "Active segment: never delete"
      long_txn: "Long-running txn blocks truncation"
    }
    truncation_example: {
      shape: rectangle
      label: |md
        **Example**:
        - Checkpoint min_rec_lsn = 1500
        - Segment 1: end_lsn = 1000, no active txns
        - Segment 2: end_lsn = 2000
        - Result: Segment 1 deleted, Segment 2 kept
      |
    }
  }
  layer_checkpoint_system: {
    direction: down
    label: "CHECKPOINT SYSTEM  [M4]"
    checkpoint_system: {
      shape: class
      label: "CheckpointSystem (wal_checkpoint.h)  [M4]"
      manager: "CheckpointManager"
      scheduler: "CheckpointScheduler"
      truncator: "LogTruncator"
      checkpoint_thread: "pthread_t"
      thread_running: "bool"
      shutdown_requested: "bool"
      check_interval_ms: "uint64_t"
      "+checkpoint_system_create(...)": "CheckpointSystem*"
      +checkpoint_system_destroy(sys): "void"
      +checkpoint_system_force_checkpoint(sys, lsn): "int"
    }
    scheduler: {
      shape: class
      label: "CheckpointScheduler"
      time_interval_ms: "uint64_t"
      record_count_interval: "uint64_t"
      last_checkpoint_time_ms: "uint64_t"
      last_checkpoint_lsn: "Lsn"
      records_since_checkpoint: "uint64_t"
      "+checkpoint_scheduler_should_checkpoint(...)": "CheckpointTrigger"
    }
  }
}
# =====================================
# CONNECTIONS
# =====================================
# M1 Connections
layer_records.log_record_header -> layer_update.update_record: "header field"
layer_records.log_record_header -> layer_clr.clr_record: "header field"
layer_records.record_types -> layer_records.log_record_header: "type enum"
layer_txn_table.txn_table -> layer_txn_mgr.txn_manager: "member"
layer_txn_mgr.txn_manager -> layer_txn_mgr.serialized_record: "returns"
layer_update.update_record -> layer_txn_mgr.txn_manager: "write_txn generates"
layer_clr.clr_record -> layer_txn_mgr.txn_manager: "abort generates"
layer_prev_lsn.prev_lsn_example -> layer_txn_table.txn_entry: "links via last_lsn"
# M2 Connections
layer_write_buffer.write_buffer -> layer_wal_writer.wal_writer: "member"
layer_segment.segment_manager -> layer_wal_writer.wal_writer: "member"
layer_group_commit.group_commit_mgr -> layer_wal_writer.wal_writer: "member"
layer_wal_writer.wal_writer -> layer_lsn_offset.lsn_design: "implements"
layer_wal_writer.wal_writer -> layer_torn_write.torn_write_fn: "uses on startup"
layer_segment.segment_manager -> layer_segment.segment_naming: "creates files"
layer_group_commit.group_commit_mgr -> layer_group_commit.group_commit_protocol: "implements"
# M3 Connections
layer_recovery_txn.recovery_txn_table -> layer_recovery_mgr.recovery_manager: "member"
layer_dpt.dirty_page_table -> layer_recovery_mgr.recovery_manager: "member"
layer_buffer_pool.buffer_pool -> layer_recovery_mgr.recovery_manager: "reference"
layer_undo_work.undo_queue -> layer_recovery_mgr.recovery_manager: "member"
layer_recovery_mgr.recovery_manager -> layer_analysis.analysis_algo: "runs"
layer_recovery_mgr.recovery_manager -> layer_redo.redo_algo: "runs"
layer_recovery_mgr.recovery_manager -> layer_undo.undo_algo: "runs"
layer_undo.undo_order_example -> layer_undo_work.undo_queue: "justifies max-heap"
layer_undo.undo_clr_write -> layer_clr.clr_record: "generates during undo"
# M4 Connections
layer_master_record.master_record -> layer_checkpoint_mgr.checkpoint_manager: "updates"
layer_checkpoint_snapshot.checkpoint_snapshot -> layer_checkpoint_mgr.checkpoint_manager: "captures"
layer_checkpoint_mgr.checkpoint_manager -> layer_checkpoint_system.checkpoint_system: "member"
layer_truncator.log_truncator -> layer_checkpoint_system.checkpoint_system: "member"
layer_scheduler.scheduler -> layer_checkpoint_system.checkpoint_system: "member"
layer_checkpoint_mgr.checkpoint_flow -> layer_master_record.master_record_fns: "calls"
layer_truncator.truncation_rules -> layer_truncator.log_truncator: "implemented by"
layer_truncation_rules.truncation_example -> layer_truncation_result: "produces"
# Cross-milestone connections
layer_txn_mgr.txn_manager -> layer_wal_writer.wal_writer: "M1 -> M2 | writes via"
layer_wal_writer.wal_writer -> layer_recovery_mgr.recovery_manager: "M2 -> M3 | log consumed by"
layer_checkpoint_mgr.checkpoint_manager -> layer_recovery_mgr.recovery_manager: "M4 -> M3 | provides checkpoint_lsn"
layer_segment.segment_manager -> layer_truncator.log_truncator: "M2 -> M4 | segments deleted by"
# =====================================
# MILESTONE INDEX
# =====================================
milestone_index: {
  shape: sql_table
  label: "Milestone Index"
  m1: "M1 | wal-impl-m1 | Log Record Format & Transaction API"
  m2: "M2 | wal-impl-m2 | Log Writer with Group Commit"
  m3: "M3 | wal-impl-m3 | ARIES Crash Recovery with CLRs"
  m4: "M4 | wal-impl-m4 | Fuzzy Checkpointing & Log Truncation"
}