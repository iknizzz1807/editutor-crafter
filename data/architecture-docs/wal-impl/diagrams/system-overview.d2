}
# =====================================
# ROW 6: UNDO QUEUE (M3)
# =====================================
row6: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_undo_work: {
    direction: down
    label: "UNDO WORK  [M3]"
    undo_work_item: {
      shape: sql_table
      label: "struct UndoWorkItem (wal_undo.h)  [M3]"
      txn_id: "TxnId | transaction"
      record_lsn: "Lsn | record to undo"
      record_type: "RecordType | UPDATE or CLR"
    }
    undo_queue: {
      shape: class
      label: "UndoQueue - Max Heap (wal_undo.h)"
      items: "UndoWorkItem*"
      capacity: "size_t | MAX_UNDO_QUEUE_SIZE"
      count: "size_t"
      invariant: "max-heap: parent >= children"
      +undo_queue_init(queue, cap): "int"
      +undo_queue_push(queue, item): "int"
      +undo_queue_pop(queue, out_item): "bool"
      +undo_queue_is_empty(queue): "bool"
    }
  }
  layer_undo_order: {
    direction: down
    label: "UNDO ORDER  [M3]"
    undo_order_example: {
      shape: class
      label: "Why Global LSN Order?"
      scenario: "T1: UPDATE page 5 at LSN 100"
      scenario2: "T2: UPDATE page 5 at LSN 200"
      wrong: "Wrong: undo T1 first, then T2"
      wrong_result: "Result: wrong before-image"
      correct: "Correct: undo LSN 200 first, then 100"
      correct_result: "Result: correct rollback"
    }
    undo_priority: {
      shape: rectangle
      label: |md
        **Undo uses max-heap ordered by LSN**
        - Pop returns highest LSN first
        - Ensures correct before-image application
        - Works across all active transactions
      |
    }
  }
  layer_recovery_mgr: {
    direction: down
    label: "RECOVERY MANAGER  [M3]"
    recovery_manager: {
      shape: class
      label: "RecoveryManager (wal_recovery.h)  [M3]"
      state: "RecoveryState | ANALYZING/REDOING/..."
      txn_table: "RecoveryTxnTable"
      dpt: "DirtyPageTable"
      pool: "BufferPool*"
      log_base_path: "const char*"
      undo_queue: "UndoQueue"
      checkpoint_lsn: "Lsn | from M4"
      records_analyzed: "uint64_t | statistics"
      records_redone: "uint64_t"
      records_undone: "uint64_t"
      clrs_written: "uint64_t"
      +recovery_manager_init(mgr, pool, log_path): "int"
      +recovery_run(mgr): "int"
      +recovery_analysis_phase(mgr): "int"
      +recovery_redo_phase(mgr): "int"
      +recovery_undo_phase(mgr): "int"
    }
  }
}
# =====================================
# ROW 7: ARIES PHASES (M3)
# =====================================
row7: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_analysis: {
    direction: down
    label: "ANALYSIS PHASE  [M3]"
    analysis_algo: {
      shape: class
      label: "Analysis Algorithm"
      start: "Start at checkpoint_lsn (or 0)"
      begin: "BEGIN: add txn, status=ACTIVE"
      update: "UPDATE: update last_lsn, add page to DPT"
      clr: "CLR: update last_lsn, add page to DPT"
      commit: "COMMIT: mark status=COMMITTED"
      abort: "ABORT: mark status=ABORTED"
      result: "ACTIVE txns need undo"
    }
    analysis_output: {
      shape: rectangle
      label: |md
        **Analysis Output**:
        - Transaction Table: all active txns
        - Dirty Page Table: pages needing redo
        - min_rec_lsn: redo starting point
      |
    }
  }
  layer_redo: {
    direction: down
    label: "REDO PHASE  [M3]"
    redo_algo: {
      shape: class
      label: "Redo Algorithm"
      start: "Start at min_rec_lsn from DPT"
      scan: "Scan forward through log"
      check_dpt: "If page not in DPT: skip"
      check_pagelsn: "If page_lsn >= record_lsn: skip"
      apply: "Apply after-image to page"
      update: "Update page_lsn = record_lsn"
      flush: "Flush all modified pages"
    }
    redo_idempotent: {
      shape: rectangle
      label: |md
        **Idempotency Check**:
        
        page_lsn = read_page_lsn(page)
        if page_lsn >= record_lsn:
            skip  # already applied
        
        Running redo N times = same result
      |
    }
  }
  layer_undo: {
    direction: down
    label: "UNDO PHASE  [M3]"
    undo_algo: {
      shape: class
      label: "Undo Algorithm"
      build: "Build queue from ACTIVE txns"
      pop: "Pop highest LSN from queue"
      read: "Read record at that LSN"
      if_update: "UPDATE: apply before-image, write CLR"
      if_clr: "CLR: follow undo_next_lsn"
      if_begin: "BEGIN: write ABORT record"
      push: "Push prev_lsn/undo_next_lsn to queue"
      flush: "Flush pages, sync log"
    }
    undo_clr_write: {
      shape: class
      label: "CLR Generation"
      apply_before: "1. Apply before-image to page"
      write_clr: "2. Write CLR with undo_next_lsn"
      set_pagelsn: "3. page_lsn = CLR's LSN"
      continue: "4. If prev_lsn > 0: push to queue"
      abort: "5. Else: write ABORT record"
    }
  }
}
