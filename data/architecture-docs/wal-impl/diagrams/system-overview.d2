      rec_lsn: "Lsn"
      sz: "16 bytes each"
    }
    checkpoint_snapshot: {
      shape: class
      label: "CheckpointSnapshot (wal_checkpoint.h)"
      begin_lsn: "Lsn | CHECKPOINT_BEGIN"
      end_lsn: "Lsn | CHECKPOINT_END"
      num_active_txns: "uint32_t"
      txn_entries: "CheckpointTxnEntry*"
      num_dirty_pages: "uint32_t"
      dirty_page_entries: "CheckpointDirtyPageEntry*"
      capture_time_us: "uint64_t"
    }
  }
  layer_checkpoint_mgr: {
    direction: down
    label: "CHECKPOINT MANAGER  [M4]"
    checkpoint_manager: {
      shape: class
      label: "CheckpointManager (wal_checkpoint.h)  [M4]"
      state: "CheckpointState | INACTIVE/..."
      state_lock: "pthread_mutex_t"
