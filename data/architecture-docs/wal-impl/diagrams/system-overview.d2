direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 3
  }
}
# =====================================
# ROW 1: CORE DATA STRUCTURES (M1)
# =====================================
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_records: {
    direction: down
    label: "LOG RECORD FORMAT  [M1]"
    log_record_header: {
      shape: sql_table
      label: "struct LogRecordHeader (wal_record.h)  [M1]"
      lsn: "uint64_t | byte offset 0x00"
      type: "uint32_t | RecordType enum"
      txn_id: "uint32_t | transaction ID"
      prev_lsn: "uint64_t | chain link"
      length: "uint32_t | total size"
      sz: "Total: 28 bytes (0x1C)"
    }
    record_types: {
      shape: class
      label: "RecordType enum (wal_types.h)"
      RECORD_INVALID: "0"
      RECORD_BEGIN: "1 | 32 bytes total"
      RECORD_UPDATE: "2 | var length"
      RECORD_COMMIT: "3 | 32 bytes total"
      RECORD_ABORT: "4 | 32 bytes total"
      RECORD_CLR: "5 | min 56 bytes"
      RECORD_CHECKPOINT: "6 | var length"
    }
  }
  layer_update: {
    direction: down
    label: "UPDATE RECORD  [M1]"
    update_record: {
      shape: sql_table
      label: "struct UpdateRecord (wal_record.h)  [M1]"
      header: "LogRecordHeader | 28 bytes"
      page_id: "uint64_t | 8 bytes"
      offset: "uint32_t | 4 bytes"
      old_value_len: "uint32_t | 4 bytes"
      old_value: "uint8_t* | ptr to before-img"
      new_value_len: "uint32_t | 4 bytes"
      new_value: "uint8_t* | ptr to after-img"
      min_size: "Min: 52 bytes"
    }
    update_layout: {
      shape: class
      label: "Serialized UPDATE Layout"
      offset_00: "+0x00: header (28B)"
      offset_1c: "+0x1C: page_id (8B)"
      offset_24: "+0x24: offset (4B)"
      offset_28: "+0x28: old_len + old_val"
      offset_var: "+var: new_len + new_val"
      offset_crc: "+end: CRC32 (4B)"
    }
  }
  layer_clr: {
    direction: down
    label: "CLR RECORD  [M1]"
    clr_record: {
      shape: sql_table
      label: "struct ClrRecord (wal_record.h)  [M1]"
      header: "LogRecordHeader | 28 bytes"
      page_id: "uint64_t | 8 bytes"
      offset: "uint32_t | 4 bytes"
      undo_data_len: "uint32_t | 4 bytes"
      undo_data: "uint8_t* | before-image"
      undo_next_lsn: "uint64_t | CRITICAL: next to undo"
      min_size: "Min: 56 bytes"
    }
    clr_distinction: {
      shape: class
      label: "CLR Key Distinction"
      header_prev_lsn: "header.prev_lsn: prev in txn"
      undo_next_lsn: "undo_next_lsn: next to undo"
      example: "UPDATE LSN=200, prev=150"
      result: "CLR: prev=200, undo_next=150"
    }
  }
}
# =====================================
# ROW 2: TRANSACTION API (M1)
# =====================================
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_txn_table: {
    direction: down
    label: "TRANSACTION TABLE  [M1]"
    txn_entry: {
      shape: sql_table
      label: "struct TransactionEntry (wal_transaction.h)  [M1]"
      txn_id: "TxnId | uint32_t"
      status: "TxnStatus | ACTIVE/COMMIT/ABORT"
      first_lsn: "Lsn | BEGIN record LSN"
      last_lsn: "Lsn | most recent record"
      sz: "Total: 28 bytes"
    }
    txn_table: {
      shape: class
      label: "TransactionTable (wal_transaction.h)"
      entries: "TransactionEntry* | array"
      capacity: "size_t | max entries"
      count: "size_t | current count"
      +txn_table_init(table, cap): "int"
      +txn_table_find(table, id): "TransactionEntry*"
      "+txn_table_add(table, ...)": "TransactionEntry*"
      +txn_table_remove(table, id): "int"
    }
  }
  layer_txn_mgr: {
    direction: down
    label: "TRANSACTION MANAGER  [M1]"
    txn_manager: {
      shape: class
      label: "TransactionManager (wal_transaction.h)  [M1]"
      next_lsn: "Lsn | monotonically increasing"
      txn_table: "TransactionTable | active txns"
      write_record_fn: "int (*)(mgr, data, len)"
      +txn_manager_create(): "TransactionManager*"
      +txn_manager_destroy(mgr): "void"
      +txn_begin(mgr, record): "TxnId"
      "+txn_write(mgr, id, page, off, ...)": "int"
      +txn_commit(mgr, id, record): "int"
      +txn_abort_simple(mgr, id, rec): "int"
    }
    serialized_record: {
      shape: sql_table
      label: "struct SerializedRecord"
      data: "uint8_t* | caller must free"
      len: "size_t | record size"
      lsn: "Lsn | assigned LSN"
    }
  }
  layer_prev_lsn: {
    direction: down
    label: "PREV_LSN CHAIN  [M1]"
    prev_lsn_example: {
      shape: class
      label: "prev_lsn Chain Example"
      t1_begin: "T1 BEGIN: LSN=100, prev=0"
      t2_begin: "T2 BEGIN: LSN=150, prev=0"
      t1_update: "T1 UPDATE: LSN=200, prev=100"
      t2_update: "T2 UPDATE: LSN=250, prev=150"
      t1_commit: "T1 COMMIT: LSN=300, prev=200"
      chain_t1: "T1 chain: 300->200->100->0"
      chain_t2: "T2 chain: 250->150->0"
    }
    prev_lsn_invariant: {
      shape: rectangle
      label: |md
        **Invariant**: prev_lsn points to previous
        record of the SAME transaction, not the
        previous record in the log.
      |
    }
  }
}
# =====================================
# ROW 3: LOG WRITER (M2)
# =====================================
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_write_buffer: {
    direction: down
    label: "WRITE BUFFER  [M2]"
    write_buffer: {
      shape: sql_table
      label: "struct WriteBuffer (wal_writer.h)  [M2]"
      buffer: "uint8_t* | allocated memory"
      capacity: "size_t | 1MB default"
      used: "size_t | bytes in buffer"
      first_buffered_lsn: "Lsn | first record LSN"
      last_buffered_lsn: "Lsn | last record LSN"
      needs_flush: "bool | COMMIT buffered"
    }
    write_buffer_fns: {
      shape: class
      label: "Write Buffer API (wal_writer.h)"
      +write_buffer_init(buf, cap): "int"
      +write_buffer_destroy(buf): "void"
      +write_buffer_append(buf, data, len, lsn, is_commit): "int"
      +write_buffer_needs_flush(buf): "bool"
      +write_buffer_clear(buf): "void"
    }
  }
  layer_segment: {
    direction: down
    label: "LOG SEGMENTS  [M2]"
    log_segment: {
      shape: sql_table
      label: "struct LogSegment (wal_segment.h)  [M2]"
      segment_id: "uint32_t | 1, 2, 3, ..."
      fd: "int | file descriptor"
      start_lsn: "uint64_t | first record LSN"
      current_offset: "uint64_t | write position"
      size_limit: "uint64_t | 64MB default"
    }
    segment_manager: {
      shape: class
      label: "LogSegmentManager (wal_segment.h)"
      base_path: "char[256] | /data/wal"
      current: "LogSegment | active segment"
      segment_count: "uint32_t | total created"
      segment_size_limit: "uint64_t | rotation threshold"
      +segment_manager_init(mgr, path, limit): "int"
      +segment_manager_write(mgr, data, len): "int"
      +segment_manager_rotate(mgr): "int"
      +segment_manager_get_fd(mgr): "int"
    }
    segment_naming: {
      shape: rectangle
      label: |md
        **Naming Convention**:
        
        /data/wal.000001  [LSN 0-64MB]
        /data/wal.000002  [LSN 64MB-128MB]
        /data/wal.000003  [active]
        
      |
    }
  }
  layer_group_commit: {
    direction: down
    label: "GROUP COMMIT  [M2]"
    group_commit_mgr: {
      shape: sql_table
      label: "struct GroupCommitManager (wal_writer.h)  [M2]"
      lock: "pthread_mutex_t | state protection"
      sync_complete: "pthread_cond_t | signal waiters"
      state: "GroupCommitState | INACTIVE/LEADER/..."
      log_fd: "int | fd to fsync"
      pending_sync_lsn: "uint64_t | max LSN needing sync"
      last_synced_lsn: "uint64_t | confirmed durable"
      waiter_count: "uint32_t | followers waiting"
      total_syncs: "uint64_t | statistics"
    }
    group_commit_protocol: {
      shape: class
      label: "Group Commit Protocol"
      leader_step1: "1. First caller becomes LEADER"
      leader_step2: "2. Leader releases lock"
      leader_step3: "3. Leader calls fsync(log_fd)"
      leader_step4: "4. Leader updates last_synced_lsn"
      leader_step5: "5. Leader broadcasts to waiters"
      follower_step1: "Follower: increment waiter_count"
      follower_step2: "Follower: wait on condition var"
      follower_step3: "Follower: check last_synced >= my_lsn"
    }
  }
}
# =====================================
# ROW 4: WAL WRITER (M2)
# =====================================
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  layer_wal_writer: {
    direction: down
    label: "WAL WRITER  [M2]"
    wal_writer: {
      shape: class
      label: "WalWriter (wal_writer.h)  [M2]"
      segments: "LogSegmentManager"
      write_buffer: "WriteBuffer | 1MB default"
      group_commit: "GroupCommitManager"
      append_lock: "pthread_mutex_t | serializes appends"
      next_lsn: "uint64_t | = current file offset"
      fsync_interval: "uint64_t | auto-sync bytes"
      is_shutdown: "bool"
      +wal_writer_create(path, seg_sz, buf_sz): "WalWriter*"
      +wal_writer_destroy(writer): "void"
      +wal_append(writer, data, len, lsn): "int"
      +wal_commit_sync(writer, commit_lsn, timeout): "GroupCommitResult"
      +wal_flush_buffer(writer): "int"
      +wal_force_sync(writer): "int"
    }
  }
  layer_lsn_offset: {
    direction: down
    label: "LSN-AS-OFFSET  [M2]"
    lsn_design: {
      shape: sql_table
      label: "LSN = Byte Offset Design"
      next_lsn: "uint64_t | current file size"
      after_append: "next_lsn += record_length"
      invariant: "LSN is unique, monotonically increasing"
      lookup: "LSN N -> seek to offset N"
    }
    append_flow: {
      shape: class
      label: "Append Flow"
      step1: "1. Acquire append_lock"
      step2: "2. lsn = next_lsn"
      step3: "3. Add to write_buffer"
      step4: "4. next_lsn += record_len"
      step5: "5. Release append_lock"
      step6: "6. Return assigned LSN"
    }
  }
  layer_torn_write: {
    direction: down
    label: "TORN WRITE DETECTION  [M2]"
    torn_write_algo: {
      shape: class
      label: "Torn Write Detection"
      scan: "Scan log from beginning"
      read_header: "Read 28-byte header"
      validate_len: "Check length in valid range"
      read_full: "Read full record"
      verify_crc: "Compute CRC, compare stored"
      truncate: "ftruncate at last valid offset"
    }
    torn_write_fn: {
      shape: class
      label: "API (wal_writer.h)"
      +wal_detect_truncate_torn_writes(path, last_valid_lsn): "int"
      +wal_validate_record(fd, lsn): "ssize_t"
    }
  }
}
