      page_id_hash: "uint64_t* | O(1) lookup"
      +dpt_init(dpt, cap): "int"
      +dpt_find(dpt, page_id): "DirtyPageEntry*"
      +dpt_add(dpt, page_id, rec_lsn): "int"
