      pin_count: "uint32_t | ref count"
      sz: "Total: 4128 bytes"
    }
    buffer_pool: {
      shape: class
      label: "BufferPool (wal_buffer_pool.h)"
      pages: "BufferPage*"
      capacity: "size_t"
      page_hash: "BufferPage** | lookup"
      db_fd: "int | database file"
      +buffer_pool_init(pool, cap, db_path): "int"
      +buffer_pool_get_page(pool, page_id, page): "int"
      +buffer_pool_flush_all(pool): "int"
      +buffer_pool_get_page_lsn(page): "Lsn"
      +buffer_pool_set_page_lsn(page, lsn): "void"
