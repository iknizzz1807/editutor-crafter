vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Log Record Header Binary Layout
  **Total Size: 28 bytes (0x1C)**
  *Standard WAL Implementation - Intel Manual Quality Specification*
  *All multi-byte fields are stored in Little-Endian format*
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
  }
}

direction: right

# Main Header Visualization Grid
header_container: {
  style: {
    fill: "#F4F4F4"
    stroke: "#333333"
    stroke-width: 2
    shadow: true
  }
  
  # 1 Label Column + 5 Data Columns = 6 total
  grid-columns: 6
  grid-gap: 0

  # --- ROW 1: BYTE OFFSETS ---
  row1_label: |md
    **Offset**
  | { style: { fill: "#2D2D2D"; font-color: white; bold: true; border-radius: 0 } }
  
  bytes_0_7: |md
    **0x00-0x07**
    (8 bytes)
  | { style: { fill: "#4B3F72"; font-color: white; border-radius: 0 } }
  
  bytes_8_11: |md
    **0x08-0x0B**
    (4 bytes)
  | { style: { fill: "#1F7A8C"; font-color: white; border-radius: 0 } }
  
  bytes_12_15: |md
    **0x0C-0x0F**
    (4 bytes)
  | { style: { fill: "#E28413"; font-color: white; border-radius: 0 } }
  
  bytes_16_23: |md
    **0x10-0x17**
    (8 bytes)
  | { style: { fill: "#00507D"; font-color: white; border-radius: 0 } }
  
  bytes_24_27: |md
    **0x18-0x1B**
    (4 bytes)
  | { style: { fill: "#606C38"; font-color: white; border-radius: 0 } }

  # --- ROW 2: FIELD NAMES ---
  row2_label: |md
    **Field**
  | { style: { fill: "#2D2D2D"; font-color: white; bold: true; border-radius: 0 } }
  
  lsn_field: |md
    **lsn**
    `uint64_t`
  | { style: { fill: "#4B3F72"; font-color: white; bold: true; border-radius: 0 } }
  
  type_field: |md
    **type**
    `uint32_t`
  | { style: { fill: "#1F7A8C"; font-color: white; bold: true; border-radius: 0 } }
  
  txn_id_field: |md
    **txn_id**
    `uint32_t`
  | { style: { fill: "#E28413"; font-color: white; bold: true; border-radius: 0 } }
  
  prev_lsn_field: |md
    **prev_lsn**
    `uint64_t`
  | { style: { fill: "#00507D"; font-color: white; bold: true; border-radius: 0 } }
  
  length_field: |md
    **length**
    `uint32_t`
  | { style: { fill: "#606C38"; font-color: white; bold: true; border-radius: 0 } }

  # --- ROW 3: SIZES ---
  row3_label: |md
    **Size**
  | { style: { fill: "#2D2D2D"; font-color: white; bold: true; border-radius: 0 } }
  
  lsn_size: "8 bytes" { style: { fill: "#4B3F72"; font-color: white; border-radius: 0 } }
  type_size: "4 bytes" { style: { fill: "#1F7A8C"; font-color: white; border-radius: 0 } }
  txn_id_size: "4 bytes" { style: { fill: "#E28413"; font-color: white; border-radius: 0 } }
  prev_lsn_size: "8 bytes" { style: { fill: "#00507D"; font-color: white; border-radius: 0 } }
  length_size: "4 bytes" { style: { fill: "#606C38"; font-color: white; border-radius: 0 } }

  # --- ROW 4: DESCRIPTIONS ---
  row4_label: |md
    **Description**
  | { style: { fill: "#2D2D2D"; font-color: white; bold: true; border-radius: 0 } }
  
  lsn_desc: |md
    Log Sequence Number.
    Monotonic identity.
  | { style: { fill: "#4B3F72"; font-color: white; border-radius: 0; font-size: 11 } }
  
  type_desc: |md
    Record type (1..6).
    Enables state recovery.
  | { style: { fill: "#1F7A8C"; font-color: white; border-radius: 0; font-size: 11 } }
  
  txn_id_desc: |md
    Owning Transaction ID.
  | { style: { fill: "#E28413"; font-color: white; border-radius: 0; font-size: 11 } }
  
  prev_lsn_desc: |md
    Chain pointer to
    last txn record.
  | { style: { fill: "#00507D"; font-color: white; border-radius: 0; font-size: 11 } }
  
  length_desc: |md
    Total bytes:
    Hdr + Data + CRC32.
  | { style: { fill: "#606C38"; font-color: white; border-radius: 0; font-size: 11 } }
}

# Documentation and Supplemental Information
notes: {
  near: center-right
  style: {
    fill: "#FFFEE0"
    stroke: "#BDBB00"
    stroke-width: 2
    border-radius: 10
  }
  
  # Using advanced block string delimiter |' to handle internal pipes
  note_content: |'md
    ### Key Invariants
    1. **LSN > 0**: Zero is reserved as `INVALID_LSN`.
    2. **type ∈ {1..6}**:
       - 1: BEGIN, 2: UPDATE, 3: COMMIT
       - 4: ABORT, 5: CLR, 6: CHECKPOINT
    3. **prev_lsn**: Points to the previous record LSN in the **same transaction**. 0 if head.
    4. **Minimum Length**: 32 bytes (28 Header + 4 CRC32).

    ### Segment Visualization (32-bit width)
    text
    +--------+--------+--------+--------+
    |           LSN (High 32)           |
    +--------+--------+--------+--------+
    |           LSN (Low 32)            |
    +--------+--------+--------+--------+
    |    type        |      txn_id      |
    +--------+--------+--------+--------+
    |        prev_lsn (High 32)         |
    +--------+--------+--------+--------+
    |        prev_lsn (Low 32)          |
    +--------+--------+--------+--------+
    |           length                  |
    +--------+--------+--------+--------+
    
  '|
}

legend: {
  near: bottom-center
  style.fill: transparent
  style.stroke: transparent
  
  legend_box: {
    style: {
      fill: "#E1F5FE"
      stroke: "#01579B"
      stroke-dash: 3
    }
    
    label: |'md
      **Encoding Detail: Little-Endian (LE)**
      If LSN = `0x0102030405060708`
      - Offset 0x00: `0x08` (LSB)
      - Offset 0x07: `0x01` (MSB)
    '|
  }
}

static_assert: {
  near: bottom-left
  style: {
    fill: "#F3E5F5"
    stroke: "#7B1FA2"
    border-radius: 4
  }
  
  # Using advanced block string for code containing quotes
  assert_content: |'c
    #include <assert.h>
    #include <stdint.h>

    _Static_assert(
      sizeof(LogRecordHeader) == 28,
      "LogRecordHeader must be exactly 28 bytes for disk compatibility"
    );
  '|
}