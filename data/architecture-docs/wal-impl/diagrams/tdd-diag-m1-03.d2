vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 0
  }
  # Technical Color Palette - Memory Layout Compliance
  colors: {
    purple_header: "#E8D5F2"
    blue_data: "#D4E6F1"
    green_free: "#D5F5E3"
    gray_padding: "#E5E7E9"
    orange_pointer: "#FCF3CF"
    red_crc: "#FADBD8"
  }
}

title: "UPDATE Record Binary Layout"
title.shape: text
title.near: top-center
title.style: {
  font-size: 32
  bold: true
}

# 1. Byte Layout Container
# Represents the serialized structure of a WAL UPDATE record
record_container: {
  grid-columns: 8
  grid-gap: 0
  direction: right
  
  header: "LogRecordHeader\n(28 bytes)" {
    style.fill: "${colors.purple_header}"
    style.stroke: "#9B59B6"
    style.stroke-width: 2
    width: 280
  }
  page_id: "page_id\n(8 bytes)" {
    style.fill: "${colors.blue_data}"
    style.stroke: "#2980B9"
    style.stroke-width: 2
    width: 140
  }
  offset: "offset\n(4 bytes)" {
    style.fill: "${colors.blue_data}"
    style.stroke: "#2980B9"
    style.stroke-width: 2
    width: 100
  }
  old_len: "old_len\n(4 bytes)" {
    style.fill: "${colors.orange_pointer}"
    style.stroke: "#F39C12"
    style.stroke-width: 2
    width: 100
  }
  old_val: "old_value\n(variable)" {
    style.fill: "${colors.green_free}"
    style.stroke: "#27AE60"
    style.stroke-width: 2
    style.stroke-dash: 4
    width: 180
  }
  new_len: "new_len\n(4 bytes)" {
    style.fill: "${colors.orange_pointer}"
    style.stroke: "#F39C12"
    style.stroke-width: 2
    width: 100
  }
  new_val: "new_value\n(variable)" {
    style.fill: "${colors.green_free}"
    style.stroke: "#27AE60"
    style.stroke-width: 2
    style.stroke-dash: 4
    width: 180
  }
  crc: "CRC32\n(4 bytes)" {
    style.fill: "${colors.red_crc}"
    style.stroke: "#E74C3C"
    style.stroke-width: 2
    width: 80
  }
}

# 2. Offset Labeling Row
# Precise byte-offset mapping for implementation
offset_row: {
  grid-columns: 8
  grid-gap: 0
  
  o00: "0x00" { shape: text; width: 280; style.font: mono; style.font-size: 16 }
  o1c: "0x1C" { shape: text; width: 140; style.font: mono; style.font-size: 16 }
  o24: "0x24" { shape: text; width: 100; style.font: mono; style.font-size: 16 }
  o28: "0x28" { shape: text; width: 100; style.font: mono; style.font-size: 16 }
  o2c: "0x2C" { shape: text; width: 180; style.font: mono; style.font-size: 16 }
  ov1: "+old_len" { shape: text; width: 100; style.font: mono; style.font-size: 16; style.font-color: "#666666" }
  ov2: "+4" { shape: text; width: 180; style.font: mono; style.font-size: 16; style.font-color: "#666666" }
  oen: "+new_len" { shape: text; width: 80; style.font: mono; style.font-size: 16; style.font-color: "#666666" }
}

# 3. Comprehensive Technical Annotations
# Intel-manual style specifications
offset_spec: |md
  ### Field Specifications
  - **HeaderSection**: Fixed size metadata (LSN, RecordType, TransactionID).
  - **page_id**: uint64_t identifier of the targeted storage page.
  - **offset**: uint32_t byte offset within the page where the update occurs.
  - **old_len / new_len**: uint32_t sizes of payload buffers.
  - **CRC32**: IEEE 802.3 polynomial, computed over bytes [0, N-4].
|
offset_spec.near: center-left
offset_spec.shape: text
offset_spec.style: {
  fill: "#FDFEFE"
  stroke: "#BDC3C7"
}
offset_spec.width: 400

size_annotation: |md
  ### Record Sizing & Alignment
  - **Fixed Overhead**: 52 Bytes total.
  - **Variable Data**: `old_len + new_len` bytes.
  - **Memory Alignment**: If record exceeds 4096B, it spans multiple log segments.
  - **Padding**: No implicit padding; alignment must be handled by the LogManager.
|
size_annotation.near: bottom-right
size_annotation.shape: text
size_annotation.style: {
  fill: "#FFFFFF"
  stroke: "#CCCCCC"
  stroke-dash: 3
}
size_annotation.width: 350

encoding_rules: |md
  ### Implementation Notes
  1. **Byte Order**: All multi-byte integers are stored as **Little-Endian**.
  2. **Zero-Length**: If `old_len` or `new_len` is 0, the corresponding variable field is omitted (0 bytes consumed).
  3. **Atomic Writes**: Records are intended to be written in a single `pwrite` call to the WAL log.
|
encoding_rules.near: center-right
encoding_rules.shape: text
encoding_rules.style: {
  fill: "#E8F8F5"
  stroke: "#27AE60"
}
encoding_rules.width: 350

# Visual Constraints
direction: down
record_container -> offset_row: { style.stroke-width: 0 }
offset_row -> size_annotation: { style.stroke-width: 0 }