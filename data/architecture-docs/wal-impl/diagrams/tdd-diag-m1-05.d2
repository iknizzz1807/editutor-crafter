direction: right
vars: {
  d2-config: {
    theme-id: 4
    layout-engine: elk
  }
}
classes: {
  record-box: {
    style: {
      fill: "#f0f4f8"
      stroke: "#333"
      stroke-width: 2
      border-radius: 4
    }
  }
  header-text: {
    style: {
      fill: "#4a4a4a"
      font-color: "#ffffff"
      font-size: 14
      bold: true
    }
  }
  field-label: {
    style: {
      font-size: 12
      fill: "#666"
    }
  }
  type-label: {
    style: {
    font-size: 11
      italic: true
      fill: "#0066cc"
    }
  }
  size-label: {
    style: {
    font-size: 10
      fill: "#999"
    }
  }
  pointer-arrow: {
    source-arrowhead.shape: triangle
    target-arrowhead.shape: triangle
  }
}
title: |md
  # Log Record Header Binary Layout
| {near: top-center}
header: Log Record Header (28 bytes) {
  class: record-box
  width: 600
  lsn_label: LSN {
    class: field-label
    style.fill: "#e8e8e8"
  }
  lsn_label -> type_label: type{
    class: field-label
  }
  type_label -> txn_id_label: txn_id{
    class: field-label
  }
  txn_id_label -> prev_lsn_label: prev_lsn{
    class: field-label
  }
  prev_lsn_label -> length_label: length{
    class: field-label
  }
  length_label -> crc_label: CRC32{
    class: field-label
    style.fill: "#ffe0e0"
  }
  lsn: 0x00-0x07 (8 bytes) {
    class: header-text
    label: "lsn"
    tooltip: "uint64_t LE\nMonotonically increasing"
  }
  type: 0x08-0x0B (4 bytes) {
    class: type-label
    label: "type"
    tooltip: "RecordType enum\nBEGIN=1, UPDATE=2,\nCOMMIT=3, ABORT=4,\nCLR=5, CHECKPOINT=6"
  }
  txn_id: 0x0C-0x0F (4 bytes) {
    class: type-label
    label: "txn_id"
    tooltip: "uint32_t\nTransaction identifier"
  }
  prev_lsn: 0x10-0x17 (8 bytes) {
    class: type-label
    label: "prev_lsn"
    tooltip: "uint64_t\nPrevious record in same txn\n(0 for first record)"
  }
  length: 0x18-0x1B (4 bytes) {
    class: type-label
    label: "length"
    tooltip: "uint32_t\nTotal record size\n(header + payload + CRC)"
  }
  crc: 0x1C+ (varies) {
    class: field-label
    label: "CRC32"
    tooltip: "uint32_t\nCRC32 of header + payload"
    style.fill: "#ffe0e0"
  }
}
legend: |md
  **Header Size:** 28 bytes fixed
  **Total Minimum Record:** 32 bytes (header + CRC)
  **All multi-byte fields are little-endian**
| {near: bottom-center}