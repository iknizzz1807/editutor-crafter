vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: Transaction State Machine {
  near: top-center
  shape: text
  style: {
    font-size: 32
    bold: true
    underline: true
  }
}
states: {
  INVALID: {
    shape: circle
    style: {
      fill: "#E8E8E8"
      stroke: "#888888"
      stroke-width: 2
    }
    label: "INVALID\n(not tracked)"
  }
  ACTIVE: {
    shape: rectangle
    style: {
      fill: "#FFF9C4"
      stroke: "#F9A825"
      stroke-width: 3
    }
    label: "ACTIVE\n\n• Transaction in progress\n• Accepts write operations\n• Can commit or abort"
  }
  COMMITTED: {
    shape: rectangle
    style: {
      fill: "#C8E6C9"
      stroke: "#388E3C"
      stroke-width: 3
    }
    label: "COMMITTED\n\n• All changes durable\n• Transaction complete\n• No further operations"
  }
  ABORTED: {
    shape: rectangle
    style: {
      fill: "#FFCDD2"
      stroke: "#D32F2F"
      stroke-width: 3
    }
    label: "ABORTED\n\n• All changes undone\n• CLRs written to log\n• Transaction complete"
  }
}
transitions: {
  begin_transition: {
    label: "txn_begin()\n\nWrites:\n• BEGIN record\n• prev_lsn = 0"
    style: {
      stroke: "#1976D2"
      stroke-width: 2
      font-color: "#1976D2"
    }
  }
  commit_transition: {
    label: "txn_commit()\n\nWrites:\n• COMMIT record\n• fsync() log\n• Update status"
    style: {
      stroke: "#388E3C"
      stroke-width: 2
      font-color: "#388E3C"
    }
  }
  abort_transition: {
    label: "txn_abort()\n\nWrites:\n• CLR per UPDATE\n  (undo_next_lsn chain)\n• ABORT record"
    style: {
      stroke: "#D32F2F"
      stroke-width: 2
      font-color: "#D32F2F"
    }
  }
  write_self: {
    label: "txn_write()\n\nWrites:\n• UPDATE record\n• prev_lsn links chain\n• No state change"
    style: {
      stroke: "#F9A825"
      stroke-width: 2
      stroke-dash: 3
      font-color: "#F9A825"
    }
  }
}
INVALID -> ACTIVE: begin_transition
ACTIVE -> COMMITTED: commit_transition
ACTIVE -> ABORTED: abort_transition
ACTIVE -> ACTIVE: write_self
legend: {
  near: bottom-right
  legend_box: {
    shape: rectangle
    style: {
      fill: "#FAFAFA"
      stroke: "#BDBDBD"
      stroke-width: 1
    }
    title: "Log Records" {
      shape: text
      style: { bold: true }
    }
    begin_rec: "BEGIN: Marks transaction start (prev_lsn=0)" {
      shape: text
      style: { font-color: "#1976D2" }
    }
    update_rec: "UPDATE: Page modification with before/after images" {
      shape: text
      style: { font-color: "#F9A825" }
    }
    commit_rec: "COMMIT: Durability point (fsync required)" {
      shape: text
      style: { font-color: "#388E3C" }
    }
    clr_rec: "CLR: Compensation record during undo" {
      shape: text
      style: { font-color: "#7B1FA2" }
    }
    abort_rec: "ABORT: Marks transaction rolled back" {
      shape: text
      style: { font-color: "#D32F2F" }
    }
  }
}
invariants: {
  near: bottom-left
  inv_box: {
    shape: rectangle
    style: {
      fill: "#FFF8E1"
      stroke: "#FFB300"
      stroke-width: 1
    }
    inv_title: "State Invariants" {
      shape: text
      style: { bold: true }
    }
    inv1: "• INVALID → ACTIVE only via txn_begin()" {
      shape: text
    }
    inv2: "• ACTIVE → COMMITTED only via txn_commit()" {
      shape: text
    }
    inv3: "• ACTIVE → ABORTED only via txn_abort()" {
      shape: text
    }
    inv4: "• COMMITTED/ABORTED are terminal states" {
      shape: text
    }
    inv5: "• No transitions from terminal states" {
      shape: text
    }
  }
}