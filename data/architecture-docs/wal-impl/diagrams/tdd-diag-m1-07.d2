direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Serialization/Deserialization Round-Trip
  ### Intel Manual Quality Specification - WAL Record Layout
| {near: top-center}

# --- Classes & Types ---
classes: {
  header_field: {
    style: {
      fill: "#E8D5E8" # Purple (Header)
      stroke: "#8B5A8B"
    }
  }
  data_field: {
    style: {
      fill: "#B5D5E8" # Blue (Data)
      stroke: "#4A90A4"
    }
  }
  pointer_field: {
    style: {
      fill: "#FFE4B5" # Orange (Pointers)
      stroke: "#CD853F"
    }
  }
}

# --- In-Memory Structure (Original) ---
original: {
  shape: class
  label: "Original UpdateRecord Struct\n(sizeof=72 bytes)"
  
  lsn: "uint64_t (Offset 0)" { class: header_field }
  type: "RecordType (Offset 8)" { class: header_field }
  txn_id: "uint32_t (Offset 12)" { class: header_field }
  prev_lsn: "uint64_t (Offset 16)" { class: header_field }
  
  page_id: "uint64_t (Offset 24)" { class: data_field }
  offset: "uint32_t (Offset 32)" { class: data_field }
  
  old_value: "uint8_t* (Offset 40)" { class: pointer_field }
  old_value_len: "uint32_t (Offset 48)" { class: data_field }
  new_value: "uint8_t* (Offset 56)" { class: pointer_field }
  new_value_len: "uint32_t (Offset 64)" { class: data_field }
  
  style.stroke-width: 2
}

# --- Serialize Process ---
serialize: {
  label: "serialize_update()\nO(N) Complexity"
  shape: rectangle
  style: {
    fill: "#FFF5E6"
    stroke: "#CD853F"
    stroke-width: 3
    double-border: true
  }
}

serialize_note: |md
  **Serialization Logic (TDD-07-A):**
  1. **Fixed Header:** Write `lsn` to `prev_lsn` (24 bytes).
  2. **Identity:** Write `page_id` and `offset` (12 bytes).
  3. **Variable Segment 1:** 
     - Write `old_value_len` (4 bytes).
     - `memcpy` `old_value` buffer (N bytes).
  4. **Variable Segment 2:**
     - Write `new_value_len` (4 bytes).
     - `memcpy` `new_value` buffer (M bytes).
  5. **Footer:** Compute `CRC32` over all previous bytes and append.
| {near: top-right}

# --- Physical Disk Buffer Layout ---
buffer: {
  label: "Serialized Byte Stream (LE Order)"
  
  h: {
    label: "Static Header [0-27]"
    grid-columns: 4
    lsn: "LSN (8B)" { style.fill: "#E8D5E8" }
    type: "Type (4B)" { style.fill: "#E8D5E8" }
    txn: "TxID (4B)" { style.fill: "#E8D5E8" }
    plsn: "PrevLSN (8B)" { style.fill: "#E8D5E8" }
  }
  
  p: {
    label: "Payload [28-39]"
    grid-columns: 2
    pid: "PageID (8B)" { style.fill: "#B5D5E8" }
    off: "Offset (4B)" { style.fill: "#B5D5E8" }
  }
  
  v: {
    label: "Variable Blobs [40-...]"
    grid-columns: 4
    ov_l: "OldLen (4B)" { style.fill: "#B5D5E8" }
    ov: "OldValue (N B)" { style.fill: "#B5D5E8"; style.stroke-dash: 3 }
    nv_l: "NewLen (4B)" { style.fill: "#B5D5E8" }
    nv: "NewValue (M B)" { style.fill: "#B5D5E8"; style.stroke-dash: 3 }
  }
  
  f: {
    label: "Footer"
    crc: "CRC32 (4B)" { style.fill: "#E8E8B5" }
  }
  
  style.fill: "#F0F0F0"
}

# --- Deserialize Process ---
deserialize: {
  label: "deserialize_update()\nSafe Memory Allocation"
  shape: rectangle
  style: {
    fill: "#E6FFF5"
    stroke: "#4AA48B"
    stroke-width: 3
    double-border: true
  }
}

deserialize_note: |md
  **Deserialization Logic (TDD-07-B):**
  1. **Integrity Check:** Extract `CRC32`, recalculate over buffer, and compare.
  2. **Header Parse:** Read fixed-width fields into local stack.
  3. **Blob Reconstruction:**
     - `malloc(old_len)` -> Copy from buffer.
     - `malloc(new_len)` -> Copy from buffer.
  4. **Structure Assembly:** Populate `Parsed Struct` fields.
| {near: bottom-right}

# --- Parsed Structure (Reconstructed) ---
parsed: {
  shape: class
  label: "Parsed UpdateRecord Struct\n(Reconstructed)"
  
  lsn: "uint64_t" { class: header_field }
  type: "RecordType" { class: header_field }
  txn_id: "uint32_t" { class: header_field }
  prev_lsn: "uint64_t" { class: header_field }
  page_id: "uint64_t" { class: data_field }
  offset: "uint32_t" { class: data_field }
  old_value: "uint8_t* (NEW MALLOC)" { class: pointer_field }
  old_value_len: "uint32_t" { class: data_field }
  new_value: "uint8_t* (NEW MALLOC)" { class: pointer_field }
  new_value_len: "uint32_t" { class: data_field }
  
  style.stroke-width: 2
}

# --- Validation Logic ---
verify: {
  shape: diamond
  label: "memcmp_equal?\n(Deep Compare)"
  style: {
    fill: "#FFE6E6"
    stroke: "#A44A4A"
    bold: true
  }
}

result: {
  pass: "✓ Round-Trip Verified" {
    style: {
      fill: "#D5E8D5"
      stroke: "#2D7D2D"
      font-color: "#2D7D2D"
      bold: true
    }
  }
  fail: "✗ Data Corruption" {
    style: {
      fill: "#E8D5D5"
      stroke: "#A44A4A"
      font-color: "#7D2D2D"
      stroke-dash: 5
    }
  }
}

# --- Global Annotations ---
field_map: |md
  ### Field Mapping Invariants:
  - `parsed.lsn == original.lsn` (Value Copy)
  - `parsed.old_value != original.old_value` (Pointer mismatch expected)
  - `memcmp(parsed.old_value, original.old_value, len) == 0` (Content Match)
| {near: bottom-center}

memory_management: |md
  ### Ownership & Lifecycle:
  - **Stage 1:** `original` owns `old_value/new_value`.
  - **Stage 2:** `deserialize` performs `malloc`.
  - **Stage 3:** Caller MUST call `wal_free_record(parsed)` to prevent leaks.
| {near: bottom-left}

# --- Connections ---
original -> serialize: "Object Reference" {
  style.stroke: "#8B5A8B"
  style.stroke-width: 2
}

serialize -> buffer: "Byte Generation" {
  style.stroke: "#CD853F"
  style.stroke-width: 2
}

buffer -> deserialize: "Stream Input" {
  style.stroke: "#666666"
  style.stroke-width: 2
}

deserialize -> parsed: "Object Instantiation" {
  style.stroke: "#4AA48B"
  style.stroke-width: 2
}

original -> verify: "Reference" {
  style.stroke-dash: 3
  style.opacity: 0.6
}

parsed -> verify: "Target" {
  style.stroke-dash: 3
  style.opacity: 0.6
}

verify -> result.pass: "Success (0)" {
  style.stroke: "#2D7D2D"
  style.stroke-width: 3
}

verify -> result.fail: "Error (!=0)" {
  style.stroke: "#A44A4A"
  style.stroke-dash: 5
}