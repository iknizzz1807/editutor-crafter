vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Transaction Table (T-Table) Structure
  **Invariant:** `txn_id` → `(status, first_lsn, last_lsn)`
  *Scope: In-Memory Runtime Metadata for ARIES-based Recovery*
| {
  near: top-center
}

direction: right

# Transaction Table Container
TransactionTable: "In-Memory Recovery Transaction Table" {
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    stroke-width: 2
  }

  header: "Transaction Table Descriptor\n(Shared Registry)" {
    style: {
      fill: "#A389D4"
      font-color: white
      stroke: "#2E86AB"
      bold: true
    }
  }

  entries: "Entry Array (Static Allocation)" {
    style.fill: white
    style.stroke: "#2E86AB"

    entry0: "Slot [0] - Offset 0x00" {
      style.fill: "#F0F7FA"
      style.stroke: "#2E86AB"
      e0_id: "0x00: txn_id: 1 [4B]" { style.fill: "#04A9F5"; style.font-color: white }
      e0_status: "0x04: status: ACTIVE [4B]" { style.fill: "#FFF3CD" }
      e0_first: "0x08: first_lsn: 100 [8B]" { style.fill: "#04A9F5"; style.font-color: white }
      e0_last: "0x10: last_lsn: 350 [8B]" { style.fill: "#04A9F5"; style.font-color: white }
    }

    entry1: "Slot [1] - Offset 0x18" {
      style.fill: "#F0F7FA"
      style.stroke: "#2E86AB"
      e1_id: "0x00: txn_id: 2 [4B]" { style.fill: "#04A9F5"; style.font-color: white }
      e1_status: "0x04: status: COMMITTED [4B]" { style.fill: "#D4EDDA" }
      e1_first: "0x08: first_lsn: 150 [8B]" { style.fill: "#04A9F5"; style.font-color: white }
      e1_last: "0x10: last_lsn: 400 [8B]" { style.fill: "#04A9F5"; style.font-color: white }
    }

    entry2: "Slot [2] - Offset 0x30" {
      style.fill: "#F0F7FA"
      style.stroke: "#2E86AB"
      e2_id: "0x00: txn_id: 3 [4B]" { style.fill: "#04A9F5"; style.font-color: white }
      e2_status: "0x04: status: ABORTED [4B]" { style.fill: "#F8D7DA" }
      e2_first: "0x08: first_lsn: 200 [8B]" { style.fill: "#04A9F5"; style.font-color: white }
      e2_last: "0x10: last_lsn: 500 [8B]" { style.fill: "#04A9F5"; style.font-color: white }
    }

    entryN: "Slot [N-1] - Unallocated" {
      style.fill: "#E8E8E8"
      style.stroke: "#999999"
      style.stroke-dash: 3
      en_id: "txn_id: 0 (FREE)"
      en_status: "status: 0 (NULL)"
    }
  }

  hash_index: "Hash Index\nMap<txn_id, Entry*>" {
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
    shape: cylinder
  }
}

# Operation Sources
BEGIN_Op: "BEGIN\nOperation" {
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  shape: diamond
}

UPDATE_Op: "UPDATE\nOperation" {
  style.fill: "#CCE5FF"
  style.stroke: "#004085"
  shape: diamond
}

COMMIT_Op: "COMMIT\nOperation" {
  style.fill: "#D4EDDA"
  style.stroke: "#28A745"
  shape: diamond
}

ABORT_Op: "ABORT\nOperation" {
  style.fill: "#F8D7DA"
  style.stroke: "#721C24"
  shape: diamond
}

# Status Values Legend
StatusLegend: "Status Definitions" {
  style.fill: "#F8F9FA"
  style.stroke: "#6C757D"
  active_status: "TXN_ACTIVE (1)" {
    style.fill: "#FFF3CD"
    style.stroke: "#856404"
  }
  committed_status: "TXN_COMMITTED (2)" {
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
  }
  aborted_status: "TXN_ABORTED (3)" {
    style.fill: "#F8D7DA"
    style.stroke: "#721C24"
  }
}

# Field Descriptions
FieldDesc: "Field Semantics" {
  style.fill: "#F8F9FA"
  style.stroke: "#6C757D"
  first_lsn_desc: |'md
    **first_lsn**: Address of the initial log record.
    - Established during `BEGIN` processing.
    - Defines the Analysis phase bounds.
  '|
  last_lsn_desc: |'md
    **last_lsn**: Head of the transaction's undo chain.
    - Updated atomically on every `UPDATE`.
    - Facilitates backwards pointer traversal.
  '|
}

# Connections
BEGIN_Op -> TransactionTable.hash_index: "Allocate Entry\nSet ACTIVE" {
  style.stroke: "#28A745"
  style.stroke-width: 2
}

UPDATE_Op -> TransactionTable.hash_index: "Update last_lsn" {
  style.stroke: "#004085"
  style.stroke-width: 2
}

COMMIT_Op -> TransactionTable.hash_index: "Finalize Status" {
  style.stroke: "#28A745"
  style.stroke-width: 2
  style.stroke-dash: 5
}

ABORT_Op -> TransactionTable.hash_index: "Mark Rollback" {
  style.stroke: "#721C24"
  style.stroke-width: 2
  style.stroke-dash: 5
}

TransactionTable.hash_index -> TransactionTable.entries: "O(1) Direct Map" {
  style.stroke: "#856404"
  style.stroke-dash: 3
}

# Global Layout
TransactionTable -> StatusLegend
StatusLegend -> FieldDesc

# Fixed Size Annotation (Intel Manual Format)
# Using tick-pipe syntax to allow pipe characters inside the Markdown table
size_note: |`md
  ### RecoveryTxnEntry Struct Layout
  | Offset | Field | Type | Size |
  | :--- | :--- | :--- | :--- |
  | 0x00 | `txn_id` | `uint32_t` | 4B |
  | 0x04 | `status` | `enum32` | 4B |
  | 0x08 | `first_lsn` | `lsn_t` | 8B |
  | 0x10 | `last_lsn` | `lsn_t` | 8B |
  | **0x18** | **Total Size** | | **24B** |
`| {
  near: bottom-right
  style.fill: "#F1F1F1"
  style.stroke: "#333333"
  style.font-size: 14
}