vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 50
  }
}

direction: right

title: |md
  # fsync() Latency Breakdown & Technical Specification
  *Analysis of the transaction commit path bottleneck in distributed systems.*
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

# --- SYSTEM STACK REPRESENTATION ---
# This container represents the transition from User Space memory to Durable Media
latency_stack: "Execution Pipeline: write() → fsync()" {
  direction: down
  style: {
    fill: "#F8F9FA"
    stroke: "#333333"
    stroke-width: 2
    border-radius: 8
  }
  
  # Step 1: User Space Context
  step1: "0x00: write() syscall" {
    tooltip: "Memory-to-memory copy: App buffer to Kernel page cache"
    style: {
      fill: "#90EE90" # Green: Fast/Header
      stroke: "#2E8B57"
      stroke-width: 2
    }
    label: "write() syscall\n[Memory-to-Memory]\nOffset: 0B\nLatency: ~1 μs\nState: VOLATILE"
  }

  # Step 2: Kernel Page Cache
  step2: "0x40: OS Page Cache" {
    tooltip: "Dirty page residency in physical RAM"
    style: {
      fill: "#87CEEB" # Blue: Data
      stroke: "#4682B4"
      stroke-dash: 3
    }
    label: "Kernel Page Cache\n[Dirty Page Residency]\nLatency: N/A\nState: NON-DURABLE"
  }

  # Step 3: Call to Persistence
  step3: "fsync() Entry" {
    tooltip: "Thread context switch to kernel; initiation of I/O barrier"
    style: {
      fill: "#FFD700" # Yellow/Gold: Blocking
      stroke: "#DAA520"
      stroke-width: 3
    }
    label: "fsync() syscall\n[Flush Barrier]\nLatency: ~0.1 ms\nMode: BLOCKING"
  }

  # Step 4: Storage Media Interaction (The Bottleneck)
  step4: "Physical Disk I/O" {
    tooltip: "NAND Flash Program (SSD) or Magnetic Platter Write (HDD)"
    style: {
      fill: "#FF6347" # Red: Critical/Padding (Slow)
      stroke: "#DC143C"
      stroke-width: 4
      double-border: true
    }
    label: "Physical Storage I/O\n[NAND/Platter Wait]\nSSD: 0.5-3.0 ms\nHDD: 5.0-15.0 ms\nCritical Path: YES"
  }

  # Step 5: Persistence Confirmed
  step5: "fsync() ACK" {
    tooltip: "Interrupt received; system call returns to User space"
    style: {
      fill: "#9370DB" # Purple: Durable
      stroke: "#6A5ACD"
      stroke-width: 2
    }
    label: "fsync() returns\n[Success ACK]\nLatency: Variable\nState: DURABLE"
  }

  # Defining the sequence within the stack
  step1 -> step2: "1. Buffer Copy"
  step2 -> step3: "2. Flush Signal"
  step3 -> step4: "3. Hardware I/O" {
    style: {
      stroke: "#DC143C"
      stroke-width: 4
      animated: true
    }
    label: "BOTTLENECK"
  }
  step4 -> step5: "4. Return Control"
}

# --- PERFORMANCE SPECIFICATION DATA ---
# Fixed 'near' to a constant value for ELK compatibility
timing_annotation: ||md
  ## fsync() Engineering Metrics

  | Operation Stage | Latency (Nominal) | Magnitude Factor | Operational Domain |
  | :--- | :--- | :--- | :--- |
  | **write()** | ~1,000 ns | 1x | L1/L2 Cache / RAM |
  | **Context Switch** | ~100,000 ns | 100x | OS Scheduler |
  | **SSD Commit** | 1-3 ms | 1,000x | NAND Flash Cell |
  | **HDD Commit** | 10-15 ms | 10,000x | Mechanical Seek |

  ### Architectural Observations
  - **Magnitude Delta**: Transitioning from `write()` to `fsync()` introduces a **1000x to 10,000x** increase in latency.
  - **Throughput Optimization**: High-performance databases utilize **Group Commit** (batching multiple logical commits into a single physical fsync) to amortize the I/O cost.
  - **Write-Ahead Log (WAL)**: The critical path only flushes the WAL sequentially. Data-file flushes are performed lazily in the background to hide latency.
|| {
  near: center-right
  style: {
    stroke: "#4682B4"
    stroke-width: 1
    fill: "#FFFFFF"
  }
}

# --- PERFORMANCE LEGEND ---
legend: {
  shape: package
  label: "Latency & Durability Legend"
  
  fast: "CPU/RAM (~1μs)\n[Volatile]" {
    style.fill: "#90EE90"
  }
  moderate: "Kernel/Bus (~100μs)\n[In-Transit]" {
    style.fill: "#FFD700"
  }
  slow: "Storage Media (1ms+)\n[Wait State]" {
    style: {
      fill: "#FF6347"
      bold: true
    }
  }
  done: "Durable State\n[Safe]" {
    style.fill: "#9370DB"
  }

  fast -> moderate -> slow -> done
}
legend.near: bottom-center

# --- GLOBAL STYLING ---
***.style.font: mono
(*** -> ***)[*].style.font-size: 13
(*** -> ***)[*].style.stroke: "#555555"