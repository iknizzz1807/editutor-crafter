direction: right
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# ----------------------------------------------------------------------------
# CLASS DEFINITIONS
# ----------------------------------------------------------------------------
classes: {
  record: {
    shape: rectangle
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      font: mono
      font-size: 14
      border-radius: 2
    }
  }
  offset_marker: {
    shape: rectangle
    width: 140
    height: 40
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 1
      font: mono
      font-size: 12
      bold: true
    }
  }
  growth_arrow: {
    style: {
      stroke: "#10B981"
      stroke-width: 4
      animated: true
    }
  }
  code_block: {
    style: {
      fill: "#1F2937"
      font-color: "#F9FAFB"
      font-size: 12
      border-radius: 4
      stroke-width: 0
    }
  }
  warning_panel: {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 2
      border-radius: 6
    }
  }
}

# ----------------------------------------------------------------------------
# HEADER SECTION
# ----------------------------------------------------------------------------
header_doc: {
  label: |md
    # Append-Only Log File Growth Implementation
    ### LSN = Byte Offset | Sequential I/O | O(1) Append
  |
  shape: rectangle
  style.stroke-width: 0
  style.fill: transparent
}
header_doc.near: top-center

# ----------------------------------------------------------------------------
# LOG FILE CONTAINER
# ----------------------------------------------------------------------------
log_file: "Physical Log File on Disk (WAL)" {
  style: {
    fill: "#F9FAFB"
    stroke: "#374151"
    stroke-width: 3
    border-radius: 8
  }
  direction: right

  # Data Records
  r0: {
    class: record
    label: |md
      ### [LSN 0]
      **OP:** BEGIN
      **TXID:** 101
      **LEN:** 100B
    |
  }

  r100: {
    class: record
    label: |md
      ### [LSN 100]
      **OP:** UPDATE
      **PAGE:** 0xAF4
      **LEN:** 100B
    |
  }

  r200: {
    class: record
    label: |md
      ### [LSN 200]
      **OP:** UPDATE
      **PAGE:** 0xBF9
      **LEN:** 100B
    |
  }

  r300: {
    class: record
    label: |md
      ### [LSN 300]
      **OP:** COMMIT
      **TXID:** 101
      **LEN:** 32B
    |
  }

  r332: {
    class: record
    label: |md
      ### [LSN 332]
      **OP:** BEGIN
      **TXID:** 102
      **LEN:** 32B
    |
  }

  r364: {
    class: record
    label: |md
      ### [LSN 364]
      **OP:** UPDATE
      **PAGE:** 0xCC1
      **LEN:** 56B
    |
  }

  next_append: "Buffer Slot\n(Offset 420)" {
    shape: rectangle
    style: {
      fill: "#D1FAE5"
      stroke: "#10B981"
      stroke-width: 3
      stroke-dash: 6
      font: mono
      font-size: 13
      bold: true
    }
  }

  # Backbone to ensure sequential layout
  r0 -> r100 -> r200 -> r300 -> r332 -> r364 -> next_append: {
    style: {
      stroke: "#D1D5DB"
      stroke-width: 2
      stroke-dash: 4
    }
  }
}

# ----------------------------------------------------------------------------
# OFFSET POINTERS (LOGICAL LAYER)
# ----------------------------------------------------------------------------
pointers: {
  near: top-center
  
  ptr_0: "OFFSET: 0" { class: offset_marker }
  ptr_100: "OFFSET: 100" { class: offset_marker }
  ptr_200: "OFFSET: 200" { class: offset_marker }
  ptr_300: "OFFSET: 300" { class: offset_marker }
  ptr_332: "OFFSET: 332" { class: offset_marker }
  ptr_364: "OFFSET: 364" { class: offset_marker }
  ptr_420: "TAIL: 420" { 
    class: offset_marker
    style.fill: "#10B981"
    style.font-color: "#FFFFFF"
  }
}

# ----------------------------------------------------------------------------
# MAPPING POINTERS TO PHYSICAL SLOTS
# ----------------------------------------------------------------------------
pointers.ptr_0 -> log_file.r0: "Seek(0)" { 
  style.stroke: "#D97706"
  style.stroke-dash: 2 
}
pointers.ptr_100 -> log_file.r100: "Seek(100)" { 
  style.stroke: "#D97706"
  style.stroke-dash: 2 
}
pointers.ptr_200 -> log_file.r200: "Seek(200)" { 
  style.stroke: "#D97706"
  style.stroke-dash: 2 
}
pointers.ptr_300 -> log_file.r300: "Seek(300)" { 
  style.stroke: "#D97706"
  style.stroke-dash: 2 
}
pointers.ptr_332 -> log_file.r332: "Seek(332)" { 
  style.stroke: "#D97706"
  style.stroke-dash: 2 
}
pointers.ptr_364 -> log_file.r364: "Seek(364)" { 
  style.stroke: "#D97706"
  style.stroke-dash: 2 
}
pointers.ptr_420 -> log_file.next_append: "Active Write" { 
  style.stroke: "#059669"
  style.stroke-width: 3
}

# ----------------------------------------------------------------------------
# OPERATIONS & ANNOTATIONS
# ----------------------------------------------------------------------------
append_call: "System Write Call\nwrite(fd, buf, 56)" {
  shape: parallelogram
  style: {
    fill: "#DBEAFE"
    stroke: "#3B82F6"
    stroke-width: 2
    font: mono
    bold: true
  }
}
append_call.near: top-right

append_call -> log_file.next_append: "Atomic Write" {
  class: growth_arrow
  target-arrowhead: triangle
}

growth_indicator: "Growth Vector: Sequential Append Only" {
  shape: text
  style.font-size: 18
  style.bold: true
  style.font-color: "#10B981"
}
growth_indicator.near: bottom-right

# ----------------------------------------------------------------------------
# INVARIANTS & PSEUDOCODE
# ----------------------------------------------------------------------------
system_logic: {
  near: bottom-left
  
  pseudocode: {
    label: |go
      // Core WAL Append Logic
      func AppendToLog(data []byte) (lsn int64) {
          lsn = logFile.Size()     // LSN is current EOF
          n, err := logFile.Write(data) 
          if err != nil { panic(err) }
          return lsn               // Return byte offset
      }
      
      // Recovery Property
      // Record @ Offset X has LSN X
    |
    class: code_block
  }
}

invariants: {
  label: |md
    ### WAL Implementation Invariants
    1. **Strict Ordering**: Records are never written out of order.
    2. **Immutability**: Once a byte is written at an offset, it is never modified.
    3. **LSN Property**: LSN[n+1] = LSN[n] + Length[n].
    4. **Zero Padding**: File gaps are prohibited to maintain LSN continuity.
  |
  class: warning_panel
}
invariants.near: bottom-center

# ----------------------------------------------------------------------------
# LEGEND / METADATA
# ----------------------------------------------------------------------------
legend: {
  near: top-left
  
  hdr: "Component Legend" { 
    shape: text
    style.bold: true 
  }
  
  blue_box: "Committed Data Record" { 
    style.fill: "#E8F4FD"
    style.stroke: "#2563EB"
  }
  yellow_box: "LSN (Logical Seq Number)" { 
    style.fill: "#FEF3C7"
    style.stroke: "#D97706"
  }
  green_box: "Tail (Write Cursor)" { 
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    style.stroke-dash: 5
  }
  
  hdr -> blue_box: {style.stroke: transparent}
  blue_box -> yellow_box: {style.stroke: transparent}
  yellow_box -> green_box: {style.stroke: transparent}
}