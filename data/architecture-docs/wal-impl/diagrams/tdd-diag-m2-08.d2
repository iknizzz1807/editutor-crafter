vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Torn Write Detection via CRC32
  **Recovery scans log, detects partial write from crash, truncates at last valid record**
| {near: top-center}
direction: right
// ========== CRASH SCENARIO ==========
crash_scenario: {
  label: "CRASH SCENARIO\nMid-Write Corruption"
  style.fill: "#FFE4E1"
  style.stroke: "#CD5C5C"
  style.stroke-width: 2
  disk_before: {
    label: "Disk Before Crash"
    style.fill: white
    record_1: "Record @ LSN 100\n✓ Valid CRC"
    record_2: "Record @ LSN 200\n✓ Valid CRC"
    record_3_partial: "Record @ LSN 300\n⚠ BEING WRITTEN..."
    record_1.style.fill: "#90EE90"
    record_2.style.fill: "#90EE90"
    record_3_partial.style.fill: "#FFB6C1"
    record_3_partial.style.stroke: "#FF0000"
    record_3_partial.style.stroke-dash: 3
    record_3_partial.style.animated: true
  }
  crash: "💥 POWER FAILURE\nSystem crashes mid-write" {
    shape: diamond
    style.fill: "#FF6B6B"
    style.font-color: white
    style.bold: true
  }
  disk_after: {
    label: "Disk After Crash"
    style.fill: white
    record_1_after: "Record @ LSN 100\n✓ Valid CRC"
    record_2_after: "Record @ LSN 200\n✓ Valid CRC"
    record_3_torn: "Record @ LSN 300\n❌ TORN WRITE\n(Partial data + garbage CRC)"
    record_1_after.style.fill: "#90EE90"
    record_2_after.style.fill: "#90EE90"
    record_3_torn.style.fill: "#FFB6C1"
    record_3_torn.style.stroke: "#8B0000"
    record_3_torn.style.stroke-width: 2
  }
  disk_before -> crash: "Write in progress"
  crash -> disk_after: "Power lost"
}
// ========== RECOVERY SCAN ==========
recovery_scan: {
  label: "RECOVERY PHASE\nLog Scan & CRC Validation"
  style.fill: "#E6F3FF"
  style.stroke: "#4169E1"
  style.stroke-width: 2
  step_1: {
    label: "Step 1: Read Record @ LSN 100"
    data_1: "Read 64 bytes\nfrom offset 100"
    crc_compute_1: "Compute CRC32\nover bytes 0-59"
    crc_compare_1: "Compare:\nComputed: 0xABCD1234\nStored:   0xABCD1234"
    result_1: "✓ MATCH\nRecord VALID"
    data_1 -> crc_compute_1
    crc_compute_1 -> crc_compare_1
    crc_compare_1 -> result_1
    result_1.style.fill: "#90EE90"
    result_1.style.bold: true
  }
  step_2: {
    label: "Step 2: Read Record @ LSN 200"
    data_2: "Read 64 bytes\nfrom offset 200"
    crc_compute_2: "Compute CRC32\nover bytes 0-59"
    crc_compare_2: "Compare:\nComputed: 0x5678ABCD\nStored:   0x5678ABCD"
    result_2: "✓ MATCH\nRecord VALID"
    data_2 -> crc_compute_2
    crc_compute_2 -> crc_compare_2
    crc_compare_2 -> result_2
    result_2.style.fill: "#90EE90"
    result_2.style.bold: true
  }
  step_3: {
    label: "Step 3: Read Record @ LSN 300"
    data_3: "Read 64 bytes\nfrom offset 300"
    crc_compute_3: "Compute CRC32\nover partial data\n+ garbage bytes"
    crc_compare_3: "Compare:\nComputed: 0xDEADBEEF\nStored:   0x??Garbage??"
    result_3: "❌ MISMATCH\nTORN WRITE DETECTED"
    data_3 -> crc_compute_3
    crc_compute_3 -> crc_compare_3
    crc_compare_3 -> result_3
    data_3.style.fill: "#FFB6C1"
    crc_compute_3.style.fill: "#FFB6C1"
    crc_compare_3.style.fill: "#FFB6C1"
    result_3.style.fill: "#FF6B6B"
    result_3.style.font-color: white
    result_3.style.bold: true
    result_3.style.stroke: "#8B0000"
    result_3.style.stroke-width: 2
  }
  step_1 -> step_2: "Continue scan"
  step_2 -> step_3: "Continue scan"
}
// ========== TRUNCATION ACTION ==========
truncation: {
  label: "TRUNCATION\nRecovery Action"
  style.fill: "#FFF8DC"
  style.stroke: "#DAA520"
  style.stroke-width: 2
  decision: "CRC Mismatch\nDetected?" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  action_truncate: {
    label: "Truncate Log File"
    truncate_call: "ftruncate(fd, 264)\n// Truncate to end of\n// last valid record"
    log_after: {
      label: "Log After Truncation"
      rec_1: "Record @ 100 ✓"
      rec_2: "Record @ 200 ✓"
      free_space: "Free space\n(ready for new writes)"
      rec_1.style.fill: "#90EE90"
      rec_2.style.fill: "#90EE90"
      free_space.style.fill: "#E8E8E8"
      free_space.style.stroke-dash: 3
    }
    truncate_call -> log_after
  }
  action_continue: "Continue normal\nrecovery (Analysis,\nRedo, Undo phases)" {
    style.fill: "#90EE90"
  }
  decision -> action_truncate: "Yes"
  decision -> action_continue: "No (all valid)"
  action_truncate -> action_continue: "Proceed with\nrecovery"
}
// ========== CRC DETAIL ==========
crc_detail: {
  label: "CRC32 Checksum Detail"
  style.fill: "#F5F5F5"
  style.stroke: "#A9A9A9"
  record_layout: {
    label: "Record Binary Layout"
    header: "Header\n(28 bytes)\nlsn, type, txn_id,\nprev_lsn, length"
    payload: "Payload\n(variable)\npage_id, offset,\nold_value, new_value"
    crc_field: "CRC32\n(4 bytes)\nCovers header\n+ payload"
    header -> payload -> crc_field
    header.style.fill: "#DDA0DD"
    payload.style.fill: "#87CEEB"
    crc_field.style.fill: "#FFA500"
  }
  formula: |md
    **CRC Computation:**
    
    stored_crc = read_le32(record + length - 4)
    computed_crc = crc32(0, record, length - 4)
    if (stored_crc != computed_crc) {
        // Corruption detected!
        ftruncate(log_fd, current_offset);
    }
    
  | {shape: text}
  record_layout -> formula
}
// ========== FLOW CONNECTIONS ==========
crash_scenario -> recovery_scan: "Recovery starts\nRead master record,\nthen scan log"
recovery_scan.step_3 -> truncation.decision: "CRC result"
truncation -> crc_detail: "Reference"