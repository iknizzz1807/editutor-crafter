layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

classes: {
  benchmark_bar: {
    width: 120
    style: {
      stroke-width: 2
      shadow: true
    }
  }
  axis_text: {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 14
      font-color: "#2C3E50"
      bold: true
    }
  }
  callout_box: {
    style: {
      fill: "#F8F9FA"
      stroke: "#3498DB"
      stroke-width: 3
      border-radius: 8
    }
  }
  metric_table: {
    style: {
      fill: "#E8F6F3"
      stroke: "#1ABC9C"
      stroke-width: 2
      border-radius: 8
    }
  }
  annotation_label: {
    shape: text
    style: {
      font-size: 16
      bold: true
      font-color: "#FFFFFF"
    }
  }
}

# ------------------------------------------------------------------------------------------
# Header Section
# ------------------------------------------------------------------------------------------
title: {
  label: |md
    # Performance Benchmark: WAL Group Commit Implementation
    **Test Environment:** 100 Concurrent Write Requests • 10 Active Worker Threads • NVMe SSD (Avg Latency 2ms)
    **Metric:** Total Latency per 100 Transactions (Amortized vs. Individual)
  |
  near: top-center
  style: {
    stroke: transparent
    fill: transparent
  }
}

# ------------------------------------------------------------------------------------------
# Visual Benchmark Section
# ------------------------------------------------------------------------------------------
chart_area: {
  grid-columns: 2
  grid-gap: 40
  
  # Y-Axis Scale Reference
  y_axis_labels: {
    grid-columns: 1
    grid-gap: 20
    
    y_200ms: "200ms —" { class: axis_text }
    y_150ms: "150ms —" { class: axis_text }
    y_100ms: "100ms —" { class: axis_text }
    y_50ms: "50ms —" { class: axis_text }
    y_0ms: "0ms —" { class: axis_text }
  }

  # Bar chart representation
  bars_container: {
    direction: right
    style: {
      stroke: "#BDC3C7"
      stroke-dash: 3
      fill: "#FBFCFC"
      stroke-width: 1
    }
    
    # Per-commit fsync bar (High Latency)
    bar_per_commit: "200ms" {
      height: 400 
      class: benchmark_bar
      style: {
        fill: "#E74C3C" 
        stroke: "#C0392B"
        font-color: white
        bold: true
      }
      tooltip: "100 fsync calls (1 per transaction)"
    }

    # Spacer to separate bars
    spacer: {
      width: 60
      style.opacity: 0
    }

    # Group commit bar (Low Latency)
    bar_group_commit: "25ms" {
      height: 50 
      class: benchmark_bar
      style: {
        fill: "#27AE60" 
        stroke: "#1E8449"
        font-color: white
        bold: true
      }
      tooltip: "10 fsync calls (1 per batch of 10)"
    }
  }

  # X-Axis Labels positioned below the bars
  empty_corner: { style.opacity: 0 }
  x_axis: {
    grid-columns: 2
    x_per: "Individual fsync (Baseline)" { 
      class: axis_text
      width: 150
    }
    x_grp: "Group Commit (Optimized)" { 
      class: axis_text
      width: 150
    }
  }
}

# ------------------------------------------------------------------------------------------
# Analysis Section
# ------------------------------------------------------------------------------------------
analysis_section: {
  grid-columns: 2
  grid-gap: 50

  # Speedup Detail Callout
  speedup_box: {
    label: |md
      ## 8.0× Performance Speedup
      
      **Architecture Analysis:**
      - **Baseline Path:** Thread acquires mutex → appends to WAL → calls `fsync()` → releases mutex.
      - **Optimized Path:** Thread appends to buffer → enters 'Wait Queue' → **Leader Thread** performs single `fsync()` for all buffered transactions → signals completion to followers.
      
      **I/O Efficiency:**
      - Mechanical overhead (fsync) is amortized.
      - 100 Requests = 10 Batch I/Os.
    |
    class: callout_box
    width: 500
  }

  # Quantitative Results Table
  throughput_table: {
    label: ||md
      ### Comparative Throughput
      | Metric | Individual | Group Commit |
      | :--- | :--- | :--- |
      | Commits Processed | 100 | 100 |
      | Hardware I/O Ops | 100 | 10 |
      | Avg Ops/Sec | 500 | 4,000 |
      | **I/O Efficiency** | 1.0× | **8.0×** |
    ||
    class: metric_table
    width: 400
  }
}

# ------------------------------------------------------------------------------------------
# Footer / Documentation Section
# ------------------------------------------------------------------------------------------
footer: {
  grid-columns: 1
  grid-gap: 20
  
  legend_box: {
    grid-columns: 4
    grid-gap: 10
    style: {
      stroke: "#BDC3C7"
      fill: "#FDFEFE"
    }
    
    red_icon: "" {
      style: {
        fill: "#E74C3C"
        stroke-width: 0
      }
      width: 20
      height: 20
    }
    red_text: "High Latency (Overhead Bound)" { shape: text }
    
    green_icon: "" {
      style: {
        fill: "#27AE60"
        stroke-width: 0
      }
      width: 20
      height: 20
    }
    green_text: "Low Latency (Amortized Cost)" { shape: text }
  }
  
  technical_note: {
    label: |md
      **Implementation Insight:** The system utilizes a *Fixed-Window Batching* algorithm. 
      The leader thread waits for either 1ms or 16 pending transactions before triggering 
      the hardware flush to maximize SATA/NVMe bandwidth utilization.
    |
    shape: text
    style: {
      font-size: 13
      italic: true
      font-color: "#34495E"
    }
  }
}

# ------------------------------------------------------------------------------------------
# Logic / Data Flow Connections
# ------------------------------------------------------------------------------------------
chart_area.bars_container.bar_per_commit -> analysis_section.speedup_box: "Captured Latency" {
  style: {
    stroke: "#BDC3C7"
    stroke-dash: 4
  }
}

chart_area.bars_container.bar_group_commit -> analysis_section.speedup_box: "Measured Performance" {
  style: {
    stroke: "#BDC3C7"
    stroke-dash: 4
  }
}

analysis_section.speedup_box -> analysis_section.throughput_table: "Derives" {
  style: {
    stroke: "#1ABC9C"
    stroke-width: 2
  }
}