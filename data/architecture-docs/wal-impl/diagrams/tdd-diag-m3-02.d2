vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Analysis Phase: Building Transaction Table
  Log scan from checkpoint_lsn → reconstruct in-flight state
| {near: top-center}
direction: right
log_scan: {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  label: Log Scan Sequence
  rec1: "LSN 100\nBEGIN T1" {
    shape: rectangle
    style.fill: "#D4E5F7"
  }
  rec2: "LSN 150\nUPDATE T1\n(page=5)" {
    shape: rectangle
    style.fill: "#C1DFF0"
  }
  rec3: "LSN 200\nCOMMIT T1" {
    shape: rectangle
    style.fill: "#A8D5BA"
  }
  rec4: "LSN 250\nBEGIN T2" {
    shape: rectangle
    style.fill: "#D4E5F7"
  }
  rec5: "LSN 300\nUPDATE T2\n(page=7)" {
    shape: rectangle
    style.fill: "#C1DFF0"
  }
  rec6: "LSN 350\nUPDATE T2\n(page=3)" {
    shape: rectangle
    style.fill: "#C1DFF0"
    style.stroke: "#E74C3C"
    style.stroke-width: 3
    style.bold: true
  }
  rec1 -> rec2 -> rec3 -> rec4 -> rec5 -> rec6
}
processing: {
  style.fill: "#FDF6E3"
  style.stroke: "#B58900"
  label: Processing Rules
  rule1: |md
    **BEGIN record**
    → Add entry to txn_table
    → status = ACTIVE
    → first_lsn = record.lsn
    → last_lsn = record.lsn
  | {shape: rectangle; style.fill: "#D4E5F7"}
  rule2: |md
    **UPDATE record**
    → Find txn in table
    → Update last_lsn = record.lsn
    → Add page to DirtyPageTable
  | {shape: rectangle; style.fill: "#C1DFF0"}
  rule3: |md
    **COMMIT record**
    → Find txn in table
    → status = COMMITTED
    → Update last_lsn
  | {shape: rectangle; style.fill: "#A8D5BA"}
  rule4: |md
    **ABORT record**
    → Find txn in table
    → status = ABORTED
    → Update last_lsn
  | {shape: rectangle; style.fill: "#F5B7B1"}
}
txn_table: {
  style.fill: "#E8DAEF"
  style.stroke: "#8E44AD"
  label: Transaction Table (Final State)
  header: {
    grid-columns: 4
    grid-gap: 0
    style.fill: "#8E44AD"
    style.font-color: white
    style.bold: true
    h1: "txn_id"
    h2: "status"
    h3: "first_lsn"
    h4: "last_lsn"
  }
  row1: {
    grid-columns: 4
    grid-gap: 0
    style.fill: "#D5F5E3"
    t1_id: "1"
    t1_status: "COMMITTED ✓"
    t1_first: "100"
    t1_last: "200"
  }
  row2: {
    grid-columns: 4
    grid-gap: 0
    style.fill: "#FADBD8"
    style.stroke: "#E74C3C"
    style.stroke-width: 2
    style.bold: true
    t2_id: "2"
    t2_status: "ACTIVE ⚠"
    t2_first: "250"
    t2_last: "350"
  }
}
undo_decision: {
  style.fill: "#FDEDEC"
  style.stroke: "#E74C3C"
  label: |md
    ## Undo Decision
    **T1 (COMMITTED)** → No action needed
    Changes are durable
    **T2 (ACTIVE)** → **NEEDS UNDO**
    Transaction was in-flight at crash
    Follow prev_lsn chain: 350 → 300 → 250
  |
}
legend: {
  near: bottom-center
  style.fill: "transparent"
  l1: "🟢 COMMITTED = Keep changes" {shape: text}
  l2: "🔴 ACTIVE = Roll back via undo" {shape: text}
  l3: "🟡 ABORTED = Already rolled back" {shape: text}
}
log_scan.rec1 -> processing.rule1 {style.stroke-dash: 3}
log_scan.rec2 -> processing.rule2 {style.stroke-dash: 3}
log_scan.rec3 -> processing.rule3 {style.stroke-dash: 3}
log_scan.rec6 -> processing.rule2 {style.stroke-dash: 3; style.stroke: "#E74C3C"}
processing.rule1 -> txn_table.row1 {style.stroke-dash: 3}
processing.rule3 -> txn_table.row1 {style.stroke-dash: 3; style.stroke: "#27AE60"}
processing.rule1 -> txn_table.row2 {style.stroke-dash: 3; style.stroke: "#E74C3C"}
txn_table.row2 -> undo_decision {style.stroke: "#E74C3C"; style.bold: true}