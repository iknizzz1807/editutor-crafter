vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Why Redo Replays Uncommitted Changes
  ## The Steal Policy Creates an Impossible Situation
| {near: top-center}
direction: right
scenario: {
  label: "Scenario\n\nT1 updates page P\nBuffer pool evicts P (steal policy)\nSystem crashes\n\nQuestion: What's on disk?"
  style.fill: "#E8F4FD"
  style.stroke: "#2196F3"
  style.stroke-width: 2
}
timeline: {
  grid-rows: 4
  grid-columns: 4
  grid-gap: 0
  header_time: "" {style.fill: "#90CAF9"; style.font-color: "#1A237E"; style.bold: true}
  header_action: "Action" {style.fill: "#90CAF9"; style.font-color: "#1A237E"; style.bold: true}
  header_memory: "Memory" {style.fill: "#90CAF9"; style.font-color: "#1A237E"; style.bold: true}
  header_disk: "Disk" {style.fill: "#90CAF9"; style.font-color: "#1A237E"; style.bold: true}
  t1_label: "t0" {style.fill: "#E3F2FD"}
  t1_action: "T1 begins" {style.fill: "#E3F2FD"}
  t1_mem: "T1: ACTIVE" {style.fill: "#C8E6C9"}
  t1_disk: "P = A (clean)" {style.fill: "#FFF9C4"}
  t2_label: "t1" {style.fill: "#E3F2FD"}
  t2_action: "T1 updates P" {style.fill: "#E3F2FD"}
  t2_mem: "P = B (dirty)\nT1: ACTIVE" {style.fill: "#FFCDD2"; style.font-color: "#B71C1C"; style.bold: true}
  t2_disk: "P = A" {style.fill: "#FFF9C4"}
  t3_label: "t2" {style.fill: "#E3F2FD"}
  t3_action: "Buffer evicts P\n(steal policy)" {style.fill: "#E3F2FD"}
  t3_mem: "P evicted" {style.fill: "#E3F2FD"}
  t3_disk: "P = B (stolen!)" {style.fill: "#FFCDD2"; style.font-color: "#B71C1C"; style.bold: true}
  t4_label: "t3" {style.fill: "#FFCDD2"; style.bold: true}
  t4_action: "💥 CRASH\nT1 uncommitted" {style.fill: "#FFCDD2"; style.font-color: "#B71C1C"; style.bold: true}
  t4_mem: "Lost!" {style.fill: "#FFCDD2"; style.font-color: "#B71C1C"; style.bold: true}
  t4_disk: "P = B\n(uncommitted!)" {style.fill: "#FFCDD2"; style.font-color: "#B71C1C"; style.bold: true}
}
problem: {
  label: "The Problem\n\nDisk contains B (T1's uncommitted change)\nT1 never committed\nB should NOT persist\n\nBut B is ALREADY on disk!"
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-width: 3
}
wrong_approach: {
  label: "❌ WRONG: Skip Uncommitted During Redo"
  step1: "If Redo skips T1's UPDATE..."
  step2: "Page P still has B on disk"
  step3: "Undo tries to restore 'before-image'"
  step4: "But what IS the current state?"
  step5: "We don't know if B is from:\n  • T1's update (needs undo)\n  • Some other transaction\n  • Garbage"
  conclusion: "Cannot reliably undo without\nknowing current state!"
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-dash: 3
}
correct_approach: {
  label: "✓ CORRECT: Redo ALL Changes"
  principle: |md
    **Redo Principle:**
    Replay EVERYTHING from min_rec_lsn
    This establishes a KNOWN state
    Then Undo can work correctly
  |
  step1: "Redo T1's UPDATE → P = B"
  step2: "Now we KNOW P = B (from T1)"
  step3: "Undo applies before-image → P = A"
  step4: "Final state: P = A (correct!)"
  style.fill: "#C8E6C9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
insight: {
  label: |md
    ### Key Insight
    **You can't "skip" something that's already on disk.**
    The steal policy means uncommitted changes may have been written. Redo must replay them to establish a known state that Undo can then work with.
    **Redo ≠ "replay committed"**
    **Redo = "replay to known state"**
  |
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-width: 2
}
scenario -> timeline
timeline -> problem: "After crash..."
problem -> wrong_approach: "Naive approach"
problem -> correct_approach: "ARIES approach"
correct_approach -> insight
wrong_approach -> insight: "Leads to insight"
legend: {
  near: bottom-center
  grid-columns: 3
  grid-gap: 10
  committed: "Committed/Clean" {style.fill: "#C8E6C9"}
  uncommitted: "Uncommitted/Dirty" {style.fill: "#FFCDD2"; style.font-color: "#B71C1C"}
  neutral: "Neutral/Initial" {style.fill: "#FFF9C4"}
}