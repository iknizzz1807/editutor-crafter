vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Undo Phase: Priority Queue Construction
  Global LSN Order Across Transactions
| {near: top-center}
direction: right
Transaction_Table: "Transaction Table\n(Analysis Output)" {
  style.fill: "#E8E8E8"
  style.stroke: "#666666"
  T1_Entry: "T1: COMMITTED\nfirst_lsn=100\nlast_lsn=400" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  T2_Entry: "T2: ACTIVE\nfirst_lsn=150\nlast_lsn=500" {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    style.bold: true
  }
  T3_Entry: "T3: ACTIVE\nfirst_lsn=200\nlast_lsn=350" {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    style.bold: true
  }
  T4_Entry: "T4: ABORTED\nfirst_lsn=250\nlast_lsn=300" {
    style.fill: "#D3D3D3"
    style.stroke: "#696969"
  }
}
Filter: "Filter ACTIVE\nTransactions" {
  shape: diamond
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
}
Undo_Queue: "Undo Queue\n(Max-Heap by LSN)" {
  style.fill: "#E6E6FA"
  style.stroke: "#4B0082"
  Heap_Array: "Heap Array\n(priority by LSN descending)" {
    style.fill: transparent
    style.stroke-dash: 3
    Item_0: "Item[0]\n━━━━━━━━\ntxn_id=2\nlsn=500" {
      style.fill: "#DDA0DD"
      style.bold: true
    }
    Item_1: "Item[1]\n━━━━━━━━\ntxn_id=3\nlsn=350" {
      style.fill: "#DDA0DD"
    }
    Item_2: "Item[2]\n━━━━━━━━\n(empty)" {
      style.fill: "#F5F5F5"
      style.font-color: "#999999"
    }
  }
}
Pop_Order: "Pop Order\n(Highest LSN First)" {
  style.fill: "#F0FFF0"
  style.stroke: "#2E8B57"
  Step1: "1. Pop T2 (lsn=500)" {
    style.fill: "#98FB98"
    style.bold: true
  }
  Step2: "2. Pop T3 (lsn=350)" {
    style.fill: "#98FB98"
  }
}
Heap_Property: "Max-Heap Property\n(parent ≥ children)" {
  shape: text
  style.fill: transparent
  near: bottom-center
  Explanation: |md
    
         [500]           ← Root (max)
         /    \
      [350]  [ ]         ← Children
    Pop returns highest LSN first
    Enables correct global undo order
    |
}
Transaction_Table.T2_Entry -> Filter: "ACTIVE" {
  style.stroke: "#DC143C"
  style.stroke-width: 3
  style.bold: true
}
Transaction_Table.T3_Entry -> Filter: "ACTIVE" {
  style.stroke: "#DC143C"
  style.stroke-width: 3
  style.bold: true
}
Transaction_Table.T1_Entry -> Filter: "skip\n(COMMITTED)" {
  style.stroke: "#999999"
  style.stroke-dash: 3
  style.font-color: "#999999"
}
Transaction_Table.T4_Entry -> Filter: "skip\n(ABORTED)" {
  style.stroke: "#999999"
  style.stroke-dash: 3
  style.font-color: "#999999"
}
Filter -> Undo_Queue.Heap_Array.Item_0: "push(T2, lsn=500)" {
  style.stroke: "#4B0082"
  style.stroke-width: 2
  label: "First push\n→ becomes root"
}
Filter -> Undo_Queue.Heap_Array.Item_1: "push(T3, lsn=350)" {
  style.stroke: "#4B0082"
  style.stroke-width: 2
  label: "Second push\n→ bubble down"
}
Undo_Queue.Heap_Array.Item_0 -> Pop_Order.Step1: "pop()" {
  style.stroke: "#2E8B57"
  style.stroke-width: 2
  style.animated: true
}
Undo_Queue.Heap_Array.Item_1 -> Pop_Order.Step2: "pop()" {
  style.stroke: "#2E8B57"
  style.stroke-width: 2
}
Legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  Active_Txn: "ACTIVE Transaction\n(needs undo)" {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
  }
  Completed_Txn: "COMMITTED/ABORTED\n(skip undo)" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
  }
  Queue_Item: "Undo Queue Item\n(txn_id, lsn)" {
    style.fill: "#DDA0DD"
    style.stroke: "#4B0082"
  }
}
Algorithm: |md
  c
  // Build undo queue from ACTIVE transactions
  for (entry in txn_table) {
      if (entry.status == TXN_ACTIVE) {
          UndoWorkItem item = {
              .txn_id = entry.txn_id,
              .record_lsn = entry.last_lsn
          };
          undo_queue_push(&queue, &item);  // Max-heap insert
      }
  }
  // Process in reverse LSN order
  while (!undo_queue_is_empty(&queue)) {
      UndoWorkItem item = undo_queue_pop(&queue);  // Highest LSN
      process_undo_item(&item);
  }
  
| {near: bottom-center}