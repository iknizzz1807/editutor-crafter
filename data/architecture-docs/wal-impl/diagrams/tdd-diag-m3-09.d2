vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # CLR Prevents Recovery Loop
  Transaction T1 with UPDATEs at LSN 100, 150, 200
  Crash during undo → CLR enables resumption
| {near: top-center}
before_crash: {
  label: "BEFORE CRASH: T1 Active (3 UPDATEs)"
  style.fill: "#E8F4E8"
  style.stroke: "#2D5A2D"
  style.stroke-width: 2
  log_before: {
    label: "Log File"
    shape: rectangle
    style.fill: white
    rec100: {
      label: "LSN 100\nUPDATE T1\npage=5\nprev_lsn=0"
      shape: rectangle
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
    }
    rec150: {
      label: "LSN 150\nUPDATE T1\npage=7\nprev_lsn=100"
      shape: rectangle
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
    }
    rec200: {
      label: "LSN 200\nUPDATE T1\npage=3\nprev_lsn=150"
      shape: rectangle
      style.fill: "#B8D4E8"
      style.stroke: "#4A90A4"
    }
    rec100 -> rec150 -> rec200
  }
  txn_state_before: {
    label: "Transaction Table"
    shape: rectangle
    style.fill: "#FFF8DC"
    t1_entry: {
      label: "T1: ACTIVE\nfirst_lsn=100\nlast_lsn=200"
      shape: rectangle
      style.fill: "#FFE4B5"
    }
  }
  undo_phase: {
    label: "Undo Phase Starts"
    shape: rectangle
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 2
    undo_action: {
      label: "Undo LSN 200\n(apply before-image)"
      shape: rectangle
      style.fill: "#FFB6C1"
    }
    clr_write: {
      label: "Write CLR at LSN 250\nundo_next_lsn = 150"
      shape: rectangle
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
      style.stroke-width: 2
    }
    undo_action -> clr_write
  }
  log_after_undo: {
    label: "Log After Partial Undo"
    shape: rectangle
    style.fill: white
    rec100b: {
      label: "100"
      shape: rectangle
      style.fill: "#B8D4E8"
    }
    rec150b: {
      label: "150"
      shape: rectangle
      style.fill: "#B8D4E8"
    }
    rec200b: {
      label: "200"
      shape: rectangle
      style.fill: "#B8D4E8"
    }
    rec250: {
      label: "250\nCLR\nundo_next=150"
      shape: rectangle
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
      style.stroke-width: 3
    }
    rec100b -> rec150b -> rec200b -> rec250
  }
  crash_marker: {
    label: "💥 CRASH!"
    shape: diamond
    style.fill: "#FF4444"
    style.font-color: white
    style.stroke: "#8B0000"
    style.stroke-width: 2
  }
  log_after_undo -> crash_marker
}
after_crash: {
  label: "AFTER CRASH: Recovery Resumes"
  style.fill: "#E8E8F4"
  style.stroke: "#4A4A8A"
  style.stroke-width: 2
  recovery_phase: {
    label: "Recovery Analysis"
    shape: rectangle
    style.fill: "#E6E6FA"
    analysis_result: {
      label: "T1: ACTIVE\n(no COMMIT record)"
      shape: rectangle
      style.fill: "#FFE4B5"
    }
  }
  recovery_redo: {
    label: "Redo Phase"
    shape: rectangle
    style.fill: "#E0FFE0"
    redo_note: {
      label: "Replays ALL records\nincluding CLR at 250"
      shape: text
      style.font-color: "#2D5A2D"
    }
  }
  recovery_undo: {
    label: "Undo Phase"
    shape: rectangle
    style.fill: "#FFE4E1"
    style.stroke: "#CD5C5C"
    style.stroke-width: 2
    undo_start: {
      label: "Start from T1.last_lsn = 250"
      shape: rectangle
      style.fill: "#FFB6C1"
    }
    clr_check: {
      label: "LSN 250 is CLR\nundo_next_lsn = 150"
      shape: rectangle
      style.fill: "#FFD700"
      style.stroke: "#B8860B"
      style.stroke-width: 2
    }
    skip_200: {
      label: "✓ SKIP LSN 200\n(already undone!)"
      shape: rectangle
      style.fill: "#90EE90"
      style.stroke: "#228B22"
    }
    undo_150: {
      label: "Undo LSN 150\nWrite CLR at 300\nundo_next_lsn = 100"
      shape: rectangle
      style.fill: "#FFB6C1"
    }
    undo_100: {
      label: "Undo LSN 100\nWrite CLR at 350\nundo_next_lsn = 0"
      shape: rectangle
      style.fill: "#FFB6C1"
    }
    abort_write: {
      label: "Write ABORT record"
      shape: rectangle
      style.fill: "#DDA0DD"
    }
    undo_start -> clr_check -> skip_200 -> undo_150 -> undo_100 -> abort_write
  }
  final_log: {
    label: "Final Log State"
    shape: rectangle
    style.fill: white
    fl100: {label: "100"; shape: rectangle; style.fill: "#B8D4E8"}
    fl150: {label: "150"; shape: rectangle; style.fill: "#B8D4E8"}
    fl200: {label: "200"; shape: rectangle; style.fill: "#B8D4E8"}
    fl250: {label: "250 CLR"; shape: rectangle; style.fill: "#FFD700"}
    fl300: {label: "300 CLR"; shape: rectangle; style.fill: "#FFD700"}
    fl350: {label: "350 CLR"; shape: rectangle; style.fill: "#FFD700"}
    fl400: {label: "400 ABORT"; shape: rectangle; style.fill: "#DDA0DD"}
    fl100 -> fl150 -> fl200 -> fl250 -> fl300 -> fl350 -> fl400
  }
}
legend: {
  label: "Legend"
  style.fill: "#F5F5F5"
  style.stroke: "#666666"
  update_rec: {
    label: "UPDATE Record"
    shape: rectangle
    style.fill: "#B8D4E8"
  }
  clr_rec: {
    label: "CLR Record\n(critical for crash-safe undo)"
    shape: rectangle
    style.fill: "#FFD700"
    style.stroke: "#B8860B"
    style.stroke-width: 2
  }
  abort_rec: {
    label: "ABORT Record"
    shape: rectangle
    style.fill: "#DDA0DD"
  }
  skipped: {
    label: "Skipped (already undone)"
    shape: rectangle
    style.fill: "#90EE90"
  }
  update_rec -> clr_rec -> abort_rec -> skipped
}
before_crash -> after_crash: "System Restart" {
  style.stroke-dash: 5
  style.stroke: "#666666"
  style.animated: true
}
explanation: |md
  ## Key Insight: undo_next_lsn Field
  The CLR at LSN 250 contains:
  - `header.prev_lsn = 200` (links CLR into T1's chain)
  - `undo_next_lsn = 150` (points to next record to undo)
  Recovery follows `undo_next_lsn`, **not** `prev_lsn`:
  - `prev_lsn` would lead back to 200 (already undone!)
  - `undo_next_lsn` leads to 150 (correct next step)
  Without CLRs, recovery would re-undo LSN 200, potentially
  corrupting data or causing infinite loops.
| {near: bottom-center}