vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Recovery Idempotency Test Flow
  Verifies that running crash_recovery() multiple times produces identical database state
| {near: top-center}
direction: right
classes: {
  phase: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 8
    }
  }
  state: {
    style: {
      fill: "#F3E8FF"
      stroke: "#7C3AED"
      stroke-width: 2
    }
  }
  action: {
    style: {
      fill: "#ECFDF5"
      stroke: "#059669"
      stroke-width: 2
    }
  }
  assert: {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
      bold: true
    }
  }
  clear: {
    style: {
      fill: "#FEE2E2"
      stroke: "#DC2626"
      stroke-width: 2
    }
  }
}
step1: "Step 1: Initial Setup" {
  class: phase
  create_log: "Create test log with:\n• T1: BEGIN, UPDATE, COMMIT\n• T2: BEGIN, UPDATE (no commit)" {
    class: action
  }
  create_pages: "Create pages:\n• Page 1: initial value 'A'\n• Page 2: initial value 'X'" {
    class: state
  }
}
step2: "Step 2: First Recovery Run" {
  class: phase
  run_recovery_1: "Run crash_recovery()" {
    class: action
    style.fill: "#DBEAFE"
    style.stroke: "#1D4ED8"
    style.bold: true
  }
  analysis_1: "Analysis Phase:\n• T1 → COMMITTED\n• T2 → ACTIVE" {
    class: state
  }
  redo_1: "Redo Phase:\n• Replay T1's UPDATE\n• Replay T2's UPDATE\n• Page 1 = 'B'\n• Page 2 = 'Y'" {
    class: state
  }
  undo_1: "Undo Phase:\n• Rollback T2\n• Write CLR for T2\n• Page 2 = 'X'" {
    class: state
  }
}
step3: "Step 3: Capture State #1" {
  class: phase
  capture_1: "Capture page contents:\n• state1_p1 = 'B' (T1 committed)\n• state1_p2 = 'X' (T2 rolled back)" {
    class: state
    style.fill: "#DDD6FE"
    style.stroke: "#6D28D9"
  }
}
step4: "Step 4: Simulate Restart" {
  class: phase
  clear_memory: "Clear in-memory state:\n• Reset transaction table\n• Reset dirty page table\n• Reload pages from disk" {
    class: clear
  }
  note: |md
    This simulates a system restart\nwhere all in-memory state is lost\nbut disk state is preserved
  | {
    shape: text
    style.font-size: 12
    style.font-color: "#6B7280"
  }
}
step5: "Step 5: Second Recovery Run" {
  class: phase
  run_recovery_2: "Run crash_recovery() again" {
    class: action
    style.fill: "#DBEAFE"
    style.stroke: "#1D4ED8"
    style.bold: true
  }
  analysis_2: "Analysis Phase:\n• Sees T1 COMMIT record\n• Sees T2's CLR records\n• T2 → ABORTED" {
    class: state
  }
  redo_2: "Redo Phase (idempotent):\n• pageLSN check skips\n  already-applied changes\n• Page 1 = 'B' (unchanged)\n• Page 2 = 'X' (unchanged)" {
    class: state
  }
  undo_2: "Undo Phase:\n• No ACTIVE transactions\n• Nothing to undo" {
    class: state
  }
}
step6: "Step 6: Capture State #2" {
  class: phase
  capture_2: "Capture page contents:\n• state2_p1 = 'B'\n• state2_p2 = 'X'" {
    class: state
    style.fill: "#DDD6FE"
    style.stroke: "#6D28D9"
  }
}
step7: "Step 7: Verification" {
  class: phase
  compare: "Compare states:\n• state1_p1 == state2_p1 ?\n• state1_p2 == state2_p2 ?" {
    class: assert
  }
  result: "ASSERT: Both comparisons PASS\n\nRecovery is IDEMPOTENT:\nRunning N times produces\nidentical database state" {
    class: assert
    style.fill: "#D1FAE5"
    style.stroke: "#059669"
    style.font-color: "#047857"
  }
}
// Flow connections
step1.create_log -> step2.run_recovery_1
step2.run_recovery_1 -> step2.analysis_1
step2.analysis_1 -> step2.redo_1
step2.redo_1 -> step2.undo_1
step2.undo_1 -> step3.capture_1
step3.capture_1 -> step4.clear_memory
step4.clear_memory -> step5.run_recovery_2
step5.run_recovery_2 -> step5.analysis_2
step5.analysis_2 -> step5.redo_2
step5.redo_2 -> step5.undo_2
step5.undo_2 -> step6.capture_2
step6.capture_2 -> step7.compare
step7.compare -> step7.result
// Legend
legend: {
  near: bottom-center
  label: ""
  l1: "Action" {class: action}
  l2: "State" {class: state}
  l3: "Assertion" {class: assert}
  l4: "Clear/Reset" {class: clear}
  l1 -- l2 -- l3 -- l4
}