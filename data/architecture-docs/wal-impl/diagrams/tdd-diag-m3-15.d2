vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Dirty Page Table (DPT)
  **rec_lsn = First LSN that dirtied each page**
  **Minimum rec_lsn = Redo start point**
| {near: top-center}
direction: right
dpt_container: Dirty Page Table {
  style.fill: "#E8F4FD"
  style.stroke: "#2E86AB"
  style.stroke-width: 2
  header: {
    shape: rectangle
    style.fill: "#2E86AB"
    style.font-color: white
    style.bold: true
    label: "Dirty Page Table\n(page_id → rec_lsn)"
  }
  entry1: {
    grid-columns: 2
    grid-gap: 0
    style.fill: "#FFFFFF"
    p1_label: "page_id" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p1_value: "5" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
    p1_lsn_label: "rec_lsn" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p1_lsn_value: "100" {
      style.fill: "#FFF3CD"
      style.font: mono
      style.bold: true
    }
  }
  entry2: {
    grid-columns: 2
    grid-gap: 0
    style.fill: "#FFFFFF"
    p2_label: "page_id" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p2_value: "7" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
    p2_lsn_label: "rec_lsn" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p2_lsn_value: "150" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
  }
  entry3: {
    grid-columns: 2
    grid-gap: 0
    style.fill: "#FFFFFF"
    p3_label: "page_id" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p3_value: "3" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
    p3_lsn_label: "rec_lsn" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p3_lsn_value: "200" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
  }
  entry4: {
    grid-columns: 2
    grid-gap: 0
    style.fill: "#FFFFFF"
    p4_label: "page_id" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p4_value: "12" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
    p4_lsn_label: "rec_lsn" {
      style.fill: "#B8D4E8"
      style.bold: true
      style.font: mono
    }
    p4_lsn_value: "250" {
      style.fill: "#D4E5F7"
      style.font: mono
    }
  }
  header -> entry1 -> entry2 -> entry3 -> entry4
}
min_rec_lsn_box: {
  style.fill: "#FFF3CD"
  style.stroke: "#856404"
  style.stroke-width: 3
  style.border-radius: 8
  label: |md
    **MIN(rec_lsn) = 100**
    Redo starts from LSN 100
    (skip all earlier records)
  |
}
log_file: Log File {
  style.fill: "#F5F5F5"
  style.stroke: "#666666"
  segment_label: "LSN Range" {
    style.fill: "#E0E0E0"
    style.bold: true
  }
  before_min: "< LSN 100" {
    style.fill: "#90EE90"
    style.stroke: "#228B22"
    label: "Before min_rec_lsn\n(Safe to skip)"
  }
  redo_range: "≥ LSN 100" {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
    label: "Redo range\n(Must process)"
  }
  segment_label -> before_min -> redo_range
}
dpt_container.entry1.p1_lsn_value -> min_rec_lsn_box: "Minimum" {
  style.stroke: "#856404"
  style.stroke-width: 3
  style.stroke-dash: 5
  style.bold: true
}
min_rec_lsn_box -> log_file.redo_range: "Redo starts here" {
  style.stroke: "#DC143C"
  style.stroke-width: 2
  style.animated: true
}
legend: {
  near: bottom-center
  style.fill: transparent
  l1: "Yellow = Minimum rec_lsn (redo start)" {
    shape: text
    style.font-size: 14
  }
  l2: "Green = Before min (already on disk)" {
    shape: text
    style.font-size: 14
    style.font-color: "#228B22"
  }
  l3: "Pink = Redo range (needs replay)" {
    shape: text
    style.font-size: 14
    style.font-color: "#DC143C"
  }
}
annotation: |md
  **rec_lsn Semantics:**
  - Added to DPT when first UPDATE touches the page
  - Records LSN of *first* dirtying operation
  - Later updates to same page don't change rec_lsn
  - min(rec_lsn) bounds redo scan
| {near: center-left}