vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# === DIAGRAM HEADER ===
title: |md
  # TECHNICAL SPEC: Recovery Scan Analysis (LSN-Based)
  **Scenario A (Naive):** Full sequential scan from Log Start (LSN 0). Linear time complexity O(N).
  **Scenario B (Checkpoint):** Bootstrap from Master Record. Partial scan from Last Checkpoint. Constant-bounded recovery O(log size - checkpoint).
| {
  style.font-size: 18
}

direction: right

# === GLOBAL CLASSES & STYLING ===
classes: {
  log_segment: {
    shape: rectangle
    style: {
      stroke-width: 2
      border-radius: 4
    }
  }
  marker: {
    shape: circle
    width: 65
    height: 65
    style: {
      font-size: 11
      bold: true
    }
  }
  header_text: {
    shape: text
    style: {
      font-size: 16
      bold: true
    }
  }
  table_cell: {
    style: {
      stroke: "#6666CC"
      fill: "white"
      font-size: 12
      text-transform: none
    }
  }
  table_header: {
    style: {
      fill: "#E1E1FF"
      bold: true
      font-size: 13
      stroke: "#6666CC"
      text-transform: uppercase
    }
  }
  annotation: {
    shape: text
    style: {
      font-size: 10
      font: mono
    }
  }
}

# === SCENARIO A: COLD RECOVERY ===
without_checkpoint: {
  label: "SCENARIO A: NO CHECKPOINT (COLD RECOVERY)"
  style: {
    fill: "#FFF0F0"
    stroke: "#CC0000"
    stroke-width: 3
    double-border: true
  }

  offset_start: "OFFSET: 0x0000" { class: annotation }

  log_stream: {
    direction: right
    style.fill: transparent
    
    lsn_0: "LSN: 0\n(Genesis)" {
      class: marker
      style.fill: "#E8E8E8"
      style.stroke: "#999999"
    }

    dirty_pages: "UNSETTLED WAL DATA\nSIZE: 50.0 GB" {
      class: log_segment
      style: {
        fill: "#FFCCCC"
        stroke: "#CC0000"
        fill-pattern: lines
        stroke-dash: 2
      }
    }

    lsn_tail: "LSN: 50M\n(Tail)" {
      class: marker
      style.fill: "#E8E8E8"
      style.stroke: "#CC0000"
    }

    lsn_0 -> dirty_pages: "Next"
    dirty_pages -> lsn_tail: "Next"
  }

  recovery_process: {
    label: "RECOVERY ANALYSIS PHASE"
    shape: rectangle
    style: {
      fill: "#FFEEEE"
      stroke: "#CC0000"
      stroke-dash: 5
    }
    scan_op: "Full Sequential Scan\nComplexity: O(N)" {
      style.italic: true
      style.bold: true
    }
  }

  log_stream -> recovery_process: "Scan Range [0, 50M]" {
    style: {
      stroke: "#CC0000"
      stroke-width: 4
      stroke-dash: 0
    }
  }

  metrics: "RECOVERY MTTR: ~600.0s" {
    class: header_text
    style.font-color: "#CC0000"
  }
}

# === SCENARIO B: OPTIMIZED RECOVERY ===
with_checkpoint: {
  label: "SCENARIO B: OPTIMIZED (CHECKPOINT RECOVERY)"
  style: {
    fill: "#F0FFF0"
    stroke: "#00AA00"
    stroke-width: 3
    double-border: true
  }

  # Fixed "near" issue by moving note inside or using constant value
  bootstrap_note: |md
    ### Master Record Bootstrap
    - `last_checkpoint_lsn`: 25,000,000
    - Skips redo for pages already flushed to heap.
    - Bounds Scan Time to active segment.
  | {
    style: {
      fill: "#FFFACD"
      stroke: "#DAA520"
      font-size: 11
    }
  }

  master_record: "CONTROL FILE\n(global/pg_control)" {
    shape: cylinder
    style: {
      fill: "#FFFACD"
      stroke: "#DAA520"
      stroke-width: 2
      shadow: true
    }
    checkpoint_ptr: "LSN_START: 0x17D7840" {
      style.font: mono
      style.font-size: 11
      style.bold: true
    }
  }

  log_stream_opt: {
    direction: right
    style.fill: transparent

    skipped_log: "FLUSHED DATA\n(0-25GB)" {
      class: log_segment
      style: {
        fill: "#F5F5F5"
        stroke: "#CCCCCC"
        opacity: 0.5
      }
    }

    cp_marker: "✓ CHECKPOINT\nLSN 25M" {
      shape: diamond
      width: 120
      height: 120
      style: {
        fill: "#90EE90"
        stroke: "#00AA00"
        bold: true
      }
    }

    active_log: "ACTIVE REDO TARGET\n(25GB - 50GB)" {
      class: log_segment
      style: {
        fill: "#D0F0D0"
        stroke: "#00AA00"
        bold: true
        stroke-width: 3
      }
    }

    lsn_tail_2: "LSN: 50M\n(Tail)" {
      class: marker
      style.stroke: "#00AA00"
    }

    skipped_log -> cp_marker: "Previous"
    cp_marker -> active_log: "Redo Start"
    active_log -> lsn_tail_2: "Scan End"
  }

  master_record -> log_stream_opt.cp_marker: "Bootstrap Pointer" {
    style: {
      stroke: "#DAA520"
      stroke-width: 3
      stroke-dash: 4
      animated: true
    }
  }

  recovery_process_opt: {
    label: "DELTA ANALYSIS"
    shape: rectangle
    style: {
      fill: "#EEFFEE"
      stroke: "#00AA00"
    }
    op: "Targeted Scan from Checkpoint\nComplexity: O(Δ)" {
      style.bold: true
    }
  }

  log_stream_opt.active_log -> recovery_process_opt: "Partial Scan [25M, 50M]" {
    style: {
      stroke: "#00AA00"
      stroke-width: 5
    }
  }

  metrics: "RECOVERY MTTR: ~242.5s" {
    class: header_text
    style.font-color: "#00AA00"
  }
}

# === PERFORMANCE METRICS ===
comparison_table: {
  label: "Recovery Performance Comparison (50GB WAL Set)"
  grid-columns: 4
  grid-gap: 0
  style: {
    fill: "#F5F5FF"
    stroke: "#6666CC"
  }
  
  # Row 1: Headers
  h1: "Configuration" { class: table_header }
  h2: "Scan Volume" { class: table_header }
  h3: "Est. MTTR" { class: table_header }
  h4: "IO Saturation" { class: table_header }
  
  # Row 2: Scenario A
  r1_c1: "Naive (No Checkpoint)" { class: table_cell; style.bold: true; style.font-color: "#CC0000" }
  r1_c2: "50 GB (Full Scan)" { class: table_cell }
  r1_c3: "10.0 min" { class: table_cell }
  r1_c4: "Critical (Linear)" { class: table_cell }
  
  # Row 3: Scenario B
  r2_c1: "Optimized (Checkpoint)" { class: table_cell; style.bold: true; style.font-color: "#00AA00" }
  r2_c2: "25 GB (Delta Scan)" { class: table_cell }
  r2_c3: "4.2 min" { class: table_cell }
  r2_c4: "Bounded (Constant)" { class: table_cell }
}

# === GLOBAL SUMMARY ===
summary_box: |md
  ### System Invariants & MTTR Controls
  1. **Persistence:** Checkpoints force dirty memory buffers to persistent storage (Fsync).
  2. **Truncation:** Logs older than the last `last_checkpoint_lsn` are eligible for recycling.
  3. **Availability:** Higher checkpoint frequency reduces recovery time but increases steady-state I/O pressure.
| {
  style: {
    fill: "#E1F5FE"
    stroke: "#01579B"
    border-radius: 8
    font-size: 12
  }
}

# High-level sequence/flow connections
without_checkpoint -> with_checkpoint: "Optimization Logic" {
  style.stroke-dash: 8
  style.stroke: grey
}
with_checkpoint -> comparison_table: "Stat collection" {
  style.stroke: grey
}