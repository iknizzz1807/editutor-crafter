vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    safe: "#90EE90"
    redo_needed: "#FFE4B5"
    undo_needed: "#FFB6C1"
    checkpoint_color: "#4169E1"
    boundary: "#333333"
    text_muted: "#666666"
  }
}
title: |md
  # Log Truncation Safety Regions
  Segments before `min_rec_lsn` are safe to delete.\
  Segments between `min_rec_lsn` and checkpoint may be needed for REDO.\
  Segments containing `first_lsn` of active transactions are needed for UNDO.
| {near: top-center}
log_timeline: {
  direction: right
  segment_1: {
    shape: rectangle
    label: "Segment 1\nLSN 0 - 999"
    style.fill: "${colors.safe}"
    style.stroke: "${colors.boundary}"
    width: 120
    height: 80
  }
  segment_2: {
    shape: rectangle
    label: "Segment 2\nLSN 1000 - 1999"
    style.fill: "${colors.safe}"
    style.stroke: "${colors.boundary}"
    width: 120
    height: 80
  }
  min_rec_lsn_boundary: {
    shape: diamond
    label: "min_rec_lsn\n= 2000"
    style.fill: "${colors.checkpoint_color}"
    style.font-color: white
    width: 100
    height: 100
  }
  segment_3: {
    shape: rectangle
    label: "Segment 3\nLSN 2000 - 2999"
    style.fill: "${colors.redo_needed}"
    style.stroke: "${colors.boundary}"
    width: 120
    height: 80
  }
  segment_4: {
    shape: rectangle
    label: "Segment 4\nLSN 3000 - 3999"
    style.fill: "${colors.redo_needed}"
    style.stroke: "${colors.boundary}"
    width: 120
    height: 80
  }
  checkpoint_boundary: {
    shape: diamond
    label: "CHECKPOINT\nLSN = 4000"
    style.fill: "${colors.checkpoint_color}"
    style.font-color: white
    style.bold: true
    width: 110
    height: 110
  }
  segment_5: {
    shape: rectangle
    label: "Segment 5\nLSN 4000 - 4999"
    style.fill: "${colors.undo_needed}"
    style.stroke: "${colors.boundary}"
    width: 120
    height: 80
  }
  segment_6: {
    shape: rectangle
    label: "Segment 6\n(ACTIVE)\nLSN 5000+"
    style.fill: "${colors.undo_needed}"
    style.stroke: "${colors.boundary}"
    style.stroke-dash: 4
    width: 120
    height: 80
  }
  segment_1 -> segment_2: " " {style.stroke-width: 2}
  segment_2 -> min_rec_lsn_boundary: " " {style.stroke-width: 2}
  min_rec_lsn_boundary -> segment_3: " " {style.stroke-width: 2}
  segment_3 -> segment_4: " " {style.stroke-width: 2}
  segment_4 -> checkpoint_boundary: " " {style.stroke-width: 2}
  checkpoint_boundary -> segment_5: " " {style.stroke-width: 2}
  segment_5 -> segment_6: " " {style.stroke-width: 2}
}
safe_region: {
  label: "✓ SAFE TO DELETE"
  style.fill: transparent
  style.stroke: "${colors.safe}"
  style.stroke-width: 3
  style.font-color: "#228B22"
  style.bold: true
  width: 280
  height: 40
}
redo_region: {
  label: "⚠ NEEDED FOR REDO"
  style.fill: transparent
  style.stroke: "${colors.redo_needed}"
  style.stroke-width: 3
  style.font-color: "#D2691E"
  style.bold: true
  width: 280
  height: 40
}
undo_region: {
  label: "⚠ NEEDED FOR UNDO\n(if active txn first_lsn here)"
  style.fill: transparent
  style.stroke: "${colors.undo_needed}"
  style.stroke-width: 3
  style.font-color: "#DC143C"
  style.bold: true
  width: 280
  height: 50
}
legend: {
  direction: right
  safe_box: {
    shape: square
    style.fill: "${colors.safe}"
    width: 20
    height: 20
  }
  safe_label: "Safe to Delete\n(all dirty pages flushed)"
  redo_box: {
    shape: square
    style.fill: "${colors.redo_needed}"
    width: 20
    height: 20
  }
  redo_label: "Needed for REDO\n(dirty pages not yet flushed)"
  undo_box: {
    shape: square
    style.fill: "${colors.undo_needed}"
    width: 20
    height: 20
  }
  undo_label: "Needed for UNDO\n(contains active txn first_lsn)"
  checkpoint_box: {
    shape: diamond
    style.fill: "${colors.checkpoint_color}"
    width: 20
    height: 20
  }
  checkpoint_label: "Boundary Marker"
  safe_box -> safe_label
  redo_box -> redo_label
  undo_box -> undo_label
  checkpoint_box -> checkpoint_label
}
active_txn_example: {
  label: |md
    **Example: Active Transaction T1**
    - `first_lsn = 4500` (in Segment 5)
    - Segment 5 cannot be deleted until T1 commits/aborts
  |
  style.fill: "#FFF8DC"
  style.stroke: "${colors.undo_needed}"
  style.stroke-width: 2
  width: 300
}
truncation_rules: {
  label: |md
    **Truncation Safety Rules:**
    1. `segment.end_lsn < checkpoint.min_rec_lsn`
    2. No active txn has `first_lsn` in segment range
    3. Segment is not currently active (being written)
  |
  style.fill: "#F0F8FF"
  style.stroke: "${colors.checkpoint_color}"
  style.stroke-width: 2
  width: 320
}
log_timeline -> safe_region: " " {style.stroke: transparent}
safe_region -> redo_region: " " {style.stroke: transparent}
redo_region -> undo_region: " " {style.stroke: transparent}
legend -> active_txn_example: " " {style.stroke: transparent}
active_txn_example -> truncation_rules: " " {style.stroke: transparent}