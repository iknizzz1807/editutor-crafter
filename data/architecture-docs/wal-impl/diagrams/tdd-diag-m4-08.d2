vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
}

title: |md
  # Checkpoint Interval Tradeoff Curve
  ## Optimization of Recovery Time vs. Runtime Overhead
| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 24
  }
}

# === GRAPH TERMINOLOGY LEGEND ===
terminology: {
  near: top-right
  RTO: Recovery Time Objective {
    style: {
      fill: "#F8D7DA"
      stroke: "#DC3545"
    }
  }
  Overhead: CPU/IO Impact {
    style: {
      fill: "#CCE5FF"
      stroke: "#0D6EFD"
    }
  }
}

# === MAIN PERFORMANCE GRAPH ===
graph: {
  style: {
    fill: "#FFFFFF"
    stroke: "#333333"
    stroke-width: 2
    double-border: true
  }

  # Axis Labels
  y_axis: "Recovery Latency / CPU %" {
    shape: text
    style.bold: true
  }

  # Internal Plotting Area
  plot: {
    direction: right
    style.stroke-dash: 2

    # Recovery Time Curve (Exponential Decay)
    # Visualizing as a series of connected nodes for Elk pathing
    recovery_curve: {
      style.stroke: transparent
      style.fill: transparent

      rc1: "." { style.opacity: 0 }
      rc2: "." { style.opacity: 0 }
      rc3: "." { style.opacity: 0 }
      rc4: "." { style.opacity: 0 }
      rc5: "." { style.opacity: 0 }

      rc1 -> rc2 -> rc3 -> rc4 -> rc5: {
        style: {
          stroke: "#DC3545"
          stroke-width: 5
        }
      }
    }

    # Overhead Curve (Linear Growth)
    overhead_curve: {
      style.stroke: transparent
      style.fill: transparent

      oc1: "." { style.opacity: 0 }
      oc2: "." { style.opacity: 0 }
      oc3: "." { style.opacity: 0 }
      oc4: "." { style.opacity: 0 }
      oc5: "." { style.opacity: 0 }

      oc1 -> oc2 -> oc3 -> oc4 -> oc5: {
        style: {
          stroke: "#0D6EFD"
          stroke-width: 5
          stroke-dash: 3
        }
      }
    }
  }

  # The Intersection Point (Sweet Spot)
  # Positioned relatively using connections
  optimal_zone: "OPTIMAL WINDOW\n(20s - 45s)" {
    style: {
      fill: "#D4EDDA"
      stroke: "#28A745"
      stroke-width: 2
      stroke-dash: 5
      fill-pattern: dots
    }
  }

  # Annotations
  limit: "SLA THRESHOLD (RTO < 60s)" {
    shape: text
    style: {
      font-color: "#DC3545"
      italic: true
    }
  }
}

# === X-AXIS LEGEND ===
x_axis: "Checkpoint Frequency (Seconds) →" {
  near: bottom-center
  style: {
    stroke-width: 0
    font-size: 16
    bold: true
  }
}

# === INTEL-STYLE DATA METRICS TABLE ===
# Using grid layout for high-density technical specs
metrics_table: {
  label: "Performance Benchmarks: WAL Checkpoint Optimization"
  grid-rows: 6
  grid-columns: 4
  grid-gap: 0 # Clean tabular look
  
  style: {
    fill: "#F1F3F5"
    stroke: "#ADB5BD"
    stroke-width: 1
  }

  # -- Header Row (Purple Header as per spec) --
  h_interval: "**Interval**" { style.fill: "#E4DBFE" }
  h_recovery: "**Recovery (s)**" { style.fill: "#E4DBFE" }
  h_cpu: "**CPU %**" { style.fill: "#E4DBFE" }
  h_io: "**IOPS Avg**" { style.fill: "#E4DBFE" }

  # -- Data Row 1 --
  r1_1: "1s (Freq)" 
  r1_2: "1.2s" { style.font-color: "#28A745" }
  r1_3: "14.5%" { style.font-color: "#DC3545" }
  r1_4: "2450"

  # -- Data Row 2 --
  r2_1: "10s"
  r2_2: "8.4s"
  r2_3: "5.1%"
  r2_4: "820"

  # -- Data Row 3 (The Sweet Spot - Bold Green) --
  r3_1: "30s ★" { style.bold: true; style.fill: "#D4EDDA" }
  r3_2: "24.2s" { style.bold: true; style.fill: "#D4EDDA" }
  r3_3: "1.9%" { style.bold: true; style.fill: "#D4EDDA" }
  r3_4: "310" { style.bold: true; style.fill: "#D4EDDA" }

  # -- Data Row 4 --
  r4_1: "60s"
  r4_2: "52.0s"
  r4_3: "0.8%"
  r4_4: "145"

  # -- Data Row 5 --
  r5_1: "300s (Rare)"
  r5_2: ">300s" { style.font-color: "#DC3545" }
  r5_3: "0.2%" { style.font-color: "#28A745" }
  r5_4: "28"
}

# === ARCHITECTURAL CONSTRAINTS BOX ===
analysis_box: {
  label: "System Design Constraints"
  style: {
    fill: "#FFF3CD"
    stroke: "#FFC107"
    stroke-width: 2
    border-radius: 4
  }
  
  content: |md
    ### Recurrent Findings
    1. **Context Switching**: Intervals < 5s incur a 15% context-switch penalty.
    2. **Log Bloat**: Intervals > 120s lead to disk pressure on `/var/lib/wal`.
    3. **Optimal Constant**: `k = 0.5 * sqrt( (2 * C) / W )` where C is checkpoint cost and W is write rate.
  | {
    shape: text
  }
}

# === CONNECTIONS & ALIGNMENT ===
# Layout flow: Legend -> Graph -> Data Table -> Analysis
terminology -> graph: { style.opacity: 0 }
graph -> x_axis: { style.opacity: 0 }
x_axis -> metrics_table: { style.opacity: 0 }
metrics_table -> analysis_box: { style.opacity: 0 }

# Mapping data points to graph zones
metrics_table.r3_1 -> graph.optimal_zone: "Benchmark Cross-Ref" {
  style: {
    stroke: "#6C757D"
    stroke-dash: 5
    opacity: 0.4
  }
}

graph.plot.recovery_curve.rc3 -> graph.optimal_zone: {
  style.stroke: "#ADB5BD"
}
graph.plot.overhead_curve.oc3 -> graph.optimal_zone: {
  style.stroke: "#ADB5BD"
}