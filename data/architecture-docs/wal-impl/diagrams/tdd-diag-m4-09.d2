vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 6
    pad: 40
  }
}

title: |md
  # Checkpoint State Machine
  ## Technical Implementation Specification: WAL & Persistence Layer
| {
  near: top-center
  shape: text
  style: {
    font-size: 28
    bold: true
  }
}

states: {
  INACTIVE: "STATE: INACTIVE\n(IDLE)" {
    shape: circle
    tooltip: "System is quiescent. No checkpointing logic is active."
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 4
      double-border: true
    }
  }

  IN_PROGRESS: "STATE: IN_PROGRESS\n(LOCK_HELD)" {
    shape: circle
    tooltip: "Checkpoint logic is executing. Global mutation lock is held."
    style: {
      fill: "#FFF3E0"
      stroke: "#E65100"
      stroke-width: 4
      shadow: true
    }
  }
}

# Initial State Entry Point (Pseudo-state)
entry: "" {
  shape: circle
  width: 20
  height: 20
  style: {
    fill: "#2E7D32"
    stroke: "#2E7D32"
  }
}

entry -> states.INACTIVE: "system_init\nLoad Master Record (0x00)"

# Nominal Transitions
states.INACTIVE -> states.IN_PROGRESS: "checkpoint_begin()\n[trigger: WAL_THRESHOLD_REACHED]" {
  tooltip: "Triggered by timer or WAL threshold (0x80 bytes remaining)"
  style: {
    stroke: "#1976D2"
    stroke-width: 3
    bold: true
  }
  target-arrowhead: triangle {
    shape: triangle
    style.filled: true
  }
}

states.IN_PROGRESS -> states.INACTIVE: "checkpoint_end()\n[SUCCESS: ATOMIC_SWAP]" {
  tooltip: "Atomic swap of Master Record pointer successful."
  style: {
    stroke: "#2E7D32"
    stroke-width: 3
  }
  target-arrowhead: triangle {
    shape: triangle
    style.filled: true
  }
}

# Error/Recovery Transitions
states.IN_PROGRESS -> states.INACTIVE: "error / rollback\n[revert WAL offset]" {
  tooltip: "Failure in IO or checksum verification. Reverting to previous WAL offset."
  style: {
    stroke: "#C62828"
    stroke-width: 3
    stroke-dash: 5
  }
  target-arrowhead: triangle {
    shape: triangle
    style.filled: true
    style.fill: "#C62828"
  }
}

# Illegal / Error Loop: Attempting to start a checkpoint while one is already running
states.IN_PROGRESS -> states.IN_PROGRESS: "checkpoint_begin()\n❌ ERR_BUSY_REJECTED" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 2
  }
  target-arrowhead: cross {
    style.fill: "#C62828"
  }
}

# Detailed Module Explanations (Engineering Reference)
state_descriptions: {
  near: bottom-left
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    border-radius: 8
  }
  inactive_desc: |md
    ### INACTIVE (IDLE)
    - **Invariants**: `checkpoint_id == last_successful_id`
    - **IO**: Read-only access to checkpoint buffers allowed.
    - **Locks**: No checkpoint-specific mutexes held.
    - **Memory**: Buffers may be deallocated or marked for reuse.
  |
  in_progress_desc: |md
    ### IN_PROGRESS (LOCKED)
    - **Invariants**: `current_wal_offset > checkpoint_start_offset`
    - **Snapshot**: Point-in-time capture of dirty page list.
    - **Persistence**: Streaming `DIRTY_PAGE_SET` to secondary storage.
    - **Finalization**: `fsync()` must return before pointer swap.
  |
}

invariants: {
  near: top-right
  style: {
    fill: "#FFF8E1"
    stroke: "#F57C00"
    border-radius: 8
  }
  content: |md
    **Operational Constraints:**
    1. **Exclusivity**: Only the Checkpoint Coordinator thread can mutate state.
    2. **Atomicity**: The linearization point is the 8-byte write to the Master Record.
    3. **Resilience**: Any exception results in an immediate rollback to the last stable LSN.
    4. **WAL Usage**: New log entries are buffered but not flushed during the final sync phase.
  |
}

# Legend for Engineers - Corrected Shapes
legend: {
  label: "DIAGRAM LEGEND"
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    stroke-dash: 2
    border-radius: 12
  }
  
  l1: "Nominal Path" {
    shape: text
    style.font-color: "#2E7D32"
    style.bold: true
  }
  l1_icon: "" {
    shape: rectangle
    height: 4
    width: 40
    style: {
      fill: "#2E7D32"
      stroke: "#2E7D32"
      stroke-width: 1
    }
  }

  l2: "Recovery Path" {
    shape: text
    style.font-color: "#C62828"
  }
  l2_icon: "" {
    shape: rectangle
    height: 4
    width: 40
    style: {
      fill: "#C62828"
      stroke: "#C62828"
      stroke-dash: 2
    }
  }

  l3: "Rejected Request" {
    shape: text
    style.font-color: "#C62828"
    style.italic: true
  }
  l3_icon: "" {
    shape: rectangle
    height: 2
    width: 40
    style: {
      fill: "#C62828"
      stroke: "#C62828"
      stroke-dash: 1
    }
  }
  
  l1_icon -> l1: { style.stroke-width: 0 }
  l2_icon -> l2: { style.stroke-width: 0 }
  l3_icon -> l3: { style.stroke-width: 0 }
}