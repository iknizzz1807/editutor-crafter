vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Recovery Time Benchmark Setup
  Test: 10000 records → baseline recovery → checkpoint at 50% → compare recovery times
| {near: top-center}
direction: right
classes: {
  phase: {
    style: {
      fill: "#E8F4FD"
      stroke: "#2563EB"
      stroke-width: 2
      border-radius: 8
    }
  }
  measurement: {
    style: {
      fill: "#FEF3C7"
      stroke: "#D97706"
      stroke-width: 2
      border-radius: 8
    }
  }
  checkpoint: {
    style: {
      fill: "#D1FAE5"
      stroke: "#059669"
      stroke-width: 2
      border-radius: 8
    }
  }
  compare: {
    style: {
      fill: "#F3E8FF"
      stroke: "#7C3AED"
      stroke-width: 2
      border-radius: 8
    }
  }
}
phase1: "Phase 1:\nBaseline Test\n(No Checkpoint)" {
  class: phase
  write_records: "Write 10,000 records\n(Transaction 1-10000)" {
    style.fill: "#DBEAFE"
  }
  measure_baseline: "Measure Recovery\nTime (T₁)" {
    class: measurement
  }
  write_records -> measure_baseline: "Simulate crash\nRun recovery"
}
phase2: "Phase 2:\nWith Checkpoint\n(At 50%)" {
  class: phase
  write_first_half: "Write 5,000 records\n(Transaction 1-5000)" {
    style.fill: "#DBEAFE"
  }
  take_checkpoint: "Take Checkpoint\n(CHECKPOINT_END)" {
    class: checkpoint
  }
  write_second_half: "Write 5,000 records\n(Transaction 5001-10000)" {
    style.fill: "#DBEAFE"
  }
  measure_checkpoint: "Measure Recovery\nTime (T₂)" {
    class: measurement
  }
  write_first_half -> take_checkpoint: "At 50%"
  take_checkpoint -> write_second_half: "Continue"
  write_second_half -> measure_checkpoint: "Simulate crash\nRun recovery"
}
phase1 -> phase2: "Reset and\nrepeat"
comparison: "Comparison" {
  class: compare
  formula: |md
    
    Speedup = T₁ / T₂
    Target: T₂ ≤ 0.60 × T₁
    (Recovery time must be
     ≤ 60% of baseline)
    
|
  result: |md
    
    Expected:
    T₂ ≈ 0.50 × T₁
    Recovery scans from
    checkpoint LSN, not
    from log start
    
|
  formula -> result
}
measure_baseline -> comparison.formula: "T₁"
measure_checkpoint -> comparison.formula: "T₂"
legend: |md
  **Legend:**
  - 🔵 Blue: Write operations
  - 🟡 Yellow: Recovery measurements  
  - 🟢 Green: Checkpoint operation
  - 🟣 Purple: Comparison/analysis
| {near: bottom-center}