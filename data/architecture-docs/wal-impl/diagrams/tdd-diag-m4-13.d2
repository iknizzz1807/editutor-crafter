vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#6f42c1"
    data: "#007bff"
    active: "#28a745"
    padding: "#6c757d"
    pointer: "#fd7e14"
    logic: "#dc3545"
    text_on_dark: "#ffffff"
  }
}

classes: {
  segment: {
    shape: rectangle
    style: {
      stroke: black
      stroke-width: 2
      border-radius: 4
    }
  }
  in_memory: {
    style: {
      fill: "#f8f9fa"
      stroke: "#dee2e6"
      stroke-dash: 5
    }
  }
}

# --- HEADER SECTION ---
title: |md
  # WAL Truncation: Two-Condition Decision Logic
  **Rule 1:** Segment must be rotated and immutable (CLOSED).
  **Rule 2:** `min_rec_lsn` (Checkpoint) must exceed Segment's `max_lsn`.
| {
  near: top-center
  shape: text
}

# --- ON-DISK SEGMENT MANAGER ---
segment_manager: Segment Manager (On-Disk Storage) {
  style.fill: white
  direction: right

  wal_001: "WAL.000001\n(Truncatable)" {
    class: segment
    style.fill: "#e9ecef"
    
    layout: {
      grid-columns: 1
      header: "Header: Offset 0x00" { style.fill: ${colors.header}; style.font-color: ${colors.text_on_dark} }
      records: "Records: LSN [0..5000]" { style.fill: ${colors.data}; style.font-color: ${colors.text_on_dark} }
      footer: "Max LSN: 5000" { style.fill: "#ced4da"; style.bold: true }
    }
  }

  wal_002: "WAL.000002\n(Pinned by DPT)" {
    class: segment
    style.fill: "#fff3cd"
    style.stroke: ${colors.logic}
    style.stroke-width: 3
    
    layout: {
      grid-columns: 1
      header: "Header: Offset 0x00" { style.fill: ${colors.header}; style.font-color: ${colors.text_on_dark} }
      records: "Records: LSN [5001..10000]" { style.fill: ${colors.data}; style.font-color: ${colors.text_on_dark} }
      footer: "Max LSN: 10000" { style.fill: "#ced4da"; style.bold: true }
    }
  }

  wal_003: "WAL.000003\n(Active / Append-Only)" {
    class: segment
    style.fill: "#d4edda"
    
    layout: {
      grid-columns: 1
      header: "Header: Offset 0x00" { style.fill: ${colors.active}; style.font-color: ${colors.text_on_dark} }
      data_stream: "Incoming Writes..." { style.fill: ${colors.data}; style.font-color: ${colors.text_on_dark} }
      free_space: "Free: 64MB Default" { 
        style.fill: ${colors.padding}
        style.font-color: ${colors.text_on_dark}
        style.fill-pattern: lines 
      }
    }
  }

  wal_001 -> wal_002 -> wal_003: "Physical Linkage" {
    style.stroke-width: 2
  }
}

# --- IN-MEMORY STATE ---
memory_state: In-Memory Engine State {
  class: in_memory
  
  dpt: Dirty Page Table (DPT) {
    shape: sql_table
    style.fill: ${colors.header}
    style.font-color: ${colors.text_on_dark}
    
    # Columns represent PageID and RecLSN
    Page_A: "7500" {constraint: "rec_lsn (MIN)"}
    Page_B: "8200" {constraint: "rec_lsn"}
    Page_C: "12000" {constraint: "rec_lsn"}
  }

  checkpointer: Checkpointer Thread {
    style.fill: "#ffffff"
    min_rec_lsn: "Global min_rec_lsn: 7500" {
      style.bold: true
      style.font-color: ${colors.logic}
      style.stroke: ${colors.logic}
    }
  }

  memory_state.dpt.Page_A -> memory_state.checkpointer.min_rec_lsn: "Calculate min()" {
    style.stroke: ${colors.logic}
    style.animated: true
  }
}

# --- TRUNCATION LOGIC GATE ---
logic_gate: Truncation Condition Check {
  shape: diamond
  label: "Can Truncate\nSegment S?"
  style.fill: "#f8d7da"
  style.bold: true

  condition_1: "S.Status == CLOSED" { 
    shape: parallelogram 
    style.fill: white
  }
  condition_2: "S.Max_LSN < Global.min_rec_lsn" { 
    shape: parallelogram 
    style.fill: white
    tooltip: "Ensures no redo logs needed for recovery"
  }
}

# --- CONNECTIONS & FLOW ---
memory_state.checkpointer.min_rec_lsn -> logic_gate.condition_2: "Read Threshold" {
  style.stroke: ${colors.pointer}
  style.stroke-width: 2
}

segment_manager.wal_001 -> logic_gate.condition_1: "Check Metadata"
segment_manager.wal_002 -> logic_gate.condition_1: "Check Metadata"

logic_gate -> deletion_service: "RESULT: TRUE\nUnlink File" {
  style.stroke: ${colors.active}
  style.stroke-width: 4
}

deletion_service: "File System: rm -rf" {
  shape: package
  style.fill: "#f1f3f5"
}

# --- GROUP COMMIT STATE MACHINE ---
group_commit: Group Commit State Machine {
  direction: right
  style.stroke: "#333"
  
  idle: "● Idle" {
    style.fill: white
  }
  
  buffering: Buffering {
    style.fill: ${colors.data}
    style.font-color: ${colors.text_on_dark}
  }
  
  leader_wait: "Leader: Wait for I/O" {
    style.fill: ${colors.pointer}
    style.font-color: ${colors.text_on_dark}
  }
  
  ack: "ACK: Notify Followers" {
    style.fill: ${colors.active}
    style.font-color: ${colors.text_on_dark}
  }

  idle -> buffering: "Log Write"
  buffering -> leader_wait: "Timer / Size limit"
  leader_wait -> ack: "fdatasync() Success"
  ack -> idle: "Complete"
}

# --- LEGEND ---
legend: |md
  ### Implementation Notes
  - **DPT Entry:** `rec_lsn` is the LSN of the first log record that made a page dirty.
  - **Checkpoint:** Global `min_rec_lsn` is the point where recovery starts.
  - **Truncation Safety:** Only segments where `Max_LSN < min_rec_lsn` are safe to delete because 
    no dirty pages in memory require their redo records.
  - **WAL.000002 Note:** Max_LSN (10000) > min_rec_lsn (7500). Pinned.
| {
  near: bottom-right
  shape: text
  style.font-size: 14
}