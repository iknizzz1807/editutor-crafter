vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

CheckpointSystem: {
  style: {
    fill: "#F0F4F8"
    stroke: "#64748B"
    stroke-width: 2
    border-radius: 8
  }

  CheckpointManager: {
    style.fill: "#E0E7FF"
    style.stroke: "#6366F1"
    
    state: "state: INACTIVE\n→ BEGIN_WRITTEN\n→ END_WRITING\n→ SYNCING"
    current_snapshot: "CheckpointSnapshot {\n  begin_lsn\n  end_lsn\n  txn_entries[]\n  dirty_page_entries[]\n}"
    checkpoint_count: "checkpoint_count: uint64"
    
    state.style.fill: "#DBEAFE"
    current_snapshot.style.fill: "#DBEAFE"
    checkpoint_count.style.fill: "#DBEAFE"
  }

  CheckpointScheduler: {
    style.fill: "#FEF3C7"
    style.stroke: "#F59E0B"
    
    triggers: "Triggers:\n• time_interval_ms\n• record_count_interval"
    tracking: "State:\n• last_checkpoint_time_ms\n• last_checkpoint_lsn\n• records_since_checkpoint"
    
    triggers.style.fill: "#FFFBEB"
    tracking.style.fill: "#FFFBEB"
  }

  LogTruncator: {
    style.fill: "#D1FAE5"
    style.stroke: "#10B981"
    
    segments: "SegmentMetadata[] {\n  segment_id\n  start_lsn / end_lsn\n  file_size\n  is_active\n}"
    safety: "Safety Checks:\n• end_lsn < min_rec_lsn\n• no active txn in range"
    
    segments.style.fill: "#ECFDF5"
    safety.style.fill: "#ECFDF5"
  }

  BackgroundThread: {
    style.fill: "#FCE7F3"
    style.stroke: "#EC4899"
    shape: rectangle
    
    loop: |md
      **Main Loop (64-byte stack frame):**
      1. Sleep(check_interval_ms)
      2. Check scheduler triggers
      3. If triggered → checkpoint_take()
      4. After checkpoint → truncator_truncate()
      5. Log results to diagnostics
    |
    loop.style.fill: "#FDF2F8"
  }

  CheckpointManager -> CheckpointScheduler: "should_checkpoint()"
  CheckpointManager -> LogTruncator: "truncate after checkpoint"
  BackgroundThread -> CheckpointManager: "checkpoint_take(trigger)"
  BackgroundThread -> CheckpointScheduler: "check triggers"
  BackgroundThread -> LogTruncator: "truncator_truncate()"
}

ExternalReferences: {
  style.fill: transparent
  style.stroke-dash: 3
  
  WalWriter: {
    style.fill: "#F3E8FF"
    style.stroke: "#A855F7"
    label: "WalWriter (M2)\nAppend-only persistent log"
    append: "wal_append(data, lsn)"
    sync: "wal_force_sync()"
  }
  
  TransactionTable: {
    style.fill: "#FFF7ED"
    style.stroke: "#EA580C"
    label: "TransactionTable (M1)\nIn-memory state"
    entries: "entries[] {\n  txn_id, status\n  first_lsn, last_lsn\n}"
  }
  
  DirtyPageTable: {
    style.fill: "#ECFEFF"
    style.stroke: "#0891B2"
    label: "DirtyPageTable (M3)\nBuffer pool tracking"
    entries: "entries[] {\n  page_id, rec_lsn\n}"
  }
  
  MasterRecord: {
    style.fill: "#FEF2F2"
    style.stroke: "#EF4444"
    label: "MasterRecord File\nOn-disk anchor"
    content: "64 bytes {\n  magic, version\n  last_checkpoint_lsn\n  checkpoint_count\n  crc32\n}"
  }
}

CheckpointSystem.CheckpointManager -> ExternalReferences.WalWriter: "append CHECKPOINT_*\nfsync log" {
  style.stroke: "#A855F7"
  style.stroke-dash: 5
}

CheckpointSystem.CheckpointManager -> ExternalReferences.TransactionTable: "snapshot (lock <100µs)" {
  style.stroke: "#EA580C"
  style.stroke-dash: 5
}

CheckpointSystem.CheckpointManager -> ExternalReferences.DirtyPageTable: "snapshot (lock <100µs)" {
  style.stroke: "#0891B2"
  style.stroke-dash: 5
}

CheckpointSystem.CheckpointManager -> ExternalReferences.MasterRecord: "atomic update\n(temp + rename)" {
  style.stroke: "#EF4444"
  style.animated: true
}

CheckpointSystem.LogTruncator -> ExternalReferences.WalWriter: "scan segments\ndelete old files" {
  style.stroke: "#A855F7"
  style.stroke-dash: 5
}

DataFlowLegend: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#000000"
  style.stroke-width: 1
  
  sync: "Solid arrow = synchronous call"
  async: "Dashed arrow = cross-module dependency"
  atomic_flow: "Animated = atomic file system operation"
  
  sync.style.fill: white
  async.style.fill: white
  atomic_flow.style.fill: white
}

title: |md
  # Checkpoint System Component Architecture (M4)
  **Design Intent:** Fuzzy checkpointing with non-blocking snapshot capture and safe log truncation.
  Background thread orchestrates automatic checkpoint scheduling based on time or LSN growth.
| {
  near: top-center
  shape: text
  style.font-size: 18
}