vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Recovery with Checkpoint Bootstrap
  Flow: Master Record → Checkpoint → Recovery Tables
| {near: top-center}
# Data flow nodes
master_record_file: "wal.master\n(64 bytes)" {
  shape: cylinder
  style.fill: "#E8D5E8"
  style.stroke: "#8B5A8B"
  magic: "magic: 0x57414C4D"
  version: "version: 1"
  checkpoint_lsn: "last_checkpoint_lsn"
  crc_field: "crc32"
}
validate_crc: "Validate CRC32" {
  shape: diamond
  style.fill: "#FFE4B5"
  style.stroke: "#D2691E"
  computed: "computed_crc =\ncrc32(data[0:40])"
  compare: "stored_crc ==\ncomputed_crc ?"
}
checkpoint_lsn_value: "checkpoint_lsn" {
  shape: hexagon
  style.fill: "#98FB98"
  style.stroke: "#228B22"
}
checkpoint_end_record: "CHECKPOINT_END Record" {
  shape: rectangle
  style.fill: "#87CEEB"
  style.stroke: "#4169E1"
  header: "header: LSN, type, length"
  num_txns: "num_active_txns"
  num_pages: "num_dirty_pages"
  txn_array: "txn_entries[]"
  page_array: "dirty_page_entries[]"
}
txn_table: "TransactionTable\n(txn_table)" {
  shape: class
  style.fill: "#F0E68C"
  style.stroke: "#DAA520"
  entries: "entries[]"
  capacity: "capacity"
  count: "count"
}
dpt: "DirtyPageTable\n(dpt)" {
  shape: class
  style.fill: "#F0E68C"
  style.stroke: "#DAA520"
  entries: "entries[]"
  capacity: "capacity"
  count: "count"
}
analysis_phase: "Analysis Phase\n(scan from checkpoint_lsn)" {
  shape: rectangle
  style.fill: "#90EE90"
  style.stroke: "#228B22"
  style.stroke-dash: 5
  scan_forward: "Scan log forward"
  process_records: "Process BEGIN/UPDATE/\nCOMMIT/ABORT/CLR"
  update_tables: "Update txn_table & dpt"
}
# Recovery table entry structures
txn_entry: "TxnTableEntry (24 bytes)" {
  shape: rectangle
  style.fill: "#FFFACD"
  style.stroke: "#BDB76B"
  txn_id: "txn_id: uint32"
  status: "status: TxnStatus"
  first_lsn: "first_lsn: uint64"
  last_lsn: "last_lsn: uint64"
}
dpt_entry: "DirtyPageEntry (16 bytes)" {
  shape: rectangle
  style.fill: "#FFFACD"
  style.stroke: "#BDB76B"
  page_id: "page_id: uint64"
  rec_lsn: "rec_lsn: uint64"
}
# Error paths
crc_fail: "CRC Mismatch\n(Fall back to LSN 0)" {
  shape: rectangle
  style.fill: "#FFB6C1"
  style.stroke: "#DC143C"
  fallback: "Start recovery from\nbeginning of log"
}
no_checkpoint: "No Valid Checkpoint\n(LSN = 0)" {
  shape: rectangle
  style.fill: "#FFB6C1"
  style.stroke: "#DC143C"
  full_scan: "Full log scan from\nLSN 1"
}
# Connections
master_record_file -> validate_crc: "read 64 bytes"
validate_crc -> checkpoint_lsn_value: "CRC valid ✓" {
  style.stroke: "#228B22"
  style.stroke-width: 3
}
validate_crc -> crc_fail: "CRC invalid ✗" {
  style.stroke: "#DC143C"
  style.stroke-dash: 3
}
checkpoint_lsn_value -> checkpoint_end_record: "read record at LSN" {
  label: "checkpoint_lsn > 0"
}
checkpoint_lsn_value -> no_checkpoint: "checkpoint_lsn == 0" {
  style.stroke: "#DC143C"
  style.stroke-dash: 3
}
checkpoint_end_record -> txn_table: "deserialize\ntxn_entries[]" {
  style.stroke: "#4169E1"
}
checkpoint_end_record -> dpt: "deserialize\ndirty_page_entries[]" {
  style.stroke: "#4169E1"
}
txn_table -> analysis_phase: "initialized from\ncheckpoint snapshot"
dpt -> analysis_phase: "initialized from\ncheckpoint snapshot"
# Legend
legend: |md
  **Color Key:**
  - 🟣 Purple: Persistent storage (files)
  - 🟠 Orange: Validation/decision
  - 🟢 Green: LSN value, success path
  - 🔵 Blue: Log records
  - 🟡 Yellow: In-memory tables
  - 🔴 Red: Error/fallback paths
| {near: bottom-left}
# Annotations
master_record_file.annotate: |md
  **Master Record Fields:**
  - `magic`: 0x57414C4D ("WALM")
  - `version`: Format version
  - `last_checkpoint_lsn`: Bootstrap LSN
  - `checkpoint_count`: Total checkpoints
  - `crc32`: Integrity check
|
checkpoint_end_record.annotate: |md
  **CHECKPOINT_END Payload:**
  - `num_active_txns`: Active transaction count
  - `num_dirty_pages`: Dirty page count
  - Arrays serialized inline
|
analysis_phase.annotate: |md
  **Analysis continues forward:**
  - Starts at `checkpoint_lsn`
  - Merges new records into tables
  - Updates status on COMMIT/ABORT
|