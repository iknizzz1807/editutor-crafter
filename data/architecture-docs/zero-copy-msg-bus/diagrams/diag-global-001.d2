direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Zero-Copy Message Bus: System Satellite Map
  Click any milestone region to navigate
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  producer: {
    direction: down
    label: "Producer Process"
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    app_producer: {
      label: "Application\nProducer"
      shape: rectangle
      style.fill: "#C8E6C9"
    }
    producer_api: {
      label: "MessageBus API"
      shape: rectangle
      style.fill: "#A5D6A7"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m5_layer: {
    direction: down
    label: "M5: Crash Recovery & Durability"
    link: "#zcmb-m5"
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 3
    style.stroke-dash: 5
    m5_desc: {
      label: |md
        - Heartbeat monitoring
        - Write-ahead logging
        - Checkpoint/restart
        - Orphaned slot recovery
      |
      shape: rectangle
      style.fill: "#FFE0B2"
      style.stroke: transparent
    }
    m4_layer: {
      direction: down
      label: "M4: Publish-Subscribe & Topics"
      link: "#zcmb-m4"
      style.fill: "#E1F5FE"
      style.stroke: "#03A9F4"
      style.stroke-width: 3
      m4_desc: {
        label: |md
          - Topic trie router
          - Zero-copy fan-out
          - Reference counting
          - Per-subscriber filters
        |
        shape: rectangle
        style.fill: "#B3E5FC"
        style.stroke: transparent
      }
      m3_layer: {
        direction: down
        label: "M3: Multi-Producer Multi-Consumer"
        link: "#zcmb-m3"
        style.fill: "#F3E5F5"
        style.stroke: "#9C27B0"
        style.stroke-width: 3
        m3_desc: {
          label: |md
            - Vyukov MPMC algorithm
            - Sequence numbers
            - CAS contention handling
            - Sharded queues
          |
          shape: rectangle
          style.fill: "#E1BEE7"
          style.stroke: transparent
        }
        m1_layer: {
          direction: down
          label: "M1: Shared Memory Ring Buffer"
          link: "#zcmb-m1"
          style.fill: "#FFEBEE"
          style.stroke: "#F44336"
          style.stroke-width: 3
          m1_desc: {
            label: |md
              - POSIX shm_open + mmap
              - Lock-free SPSC queue
              - Cache-line alignment
              - Memory barriers
            |
            shape: rectangle
            style.fill: "#FFCDD2"
            style.stroke: transparent
          }
          shared_mem: {
            label: "Shared Memory\n(Ring Buffer)"
            shape: cylinder
            style.fill: "#FFCDD2"
            style.stroke: "#F44336"
            style.stroke-width: 2
          }
        }
      }
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  m2_layer: {
    direction: down
    label: "M2: Zero-Copy Serialization"
    link: "#zcmb-m2"
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    style.stroke-width: 3
    m2_desc: {
      label: |md
        - Flat buffer format
        - VTable schema evolution
        - Direct field access
        - No parsing overhead
      |
      shape: rectangle
      style.fill: "#FFECB3"
      style.stroke: transparent
    }
    flatbuf_msg: {
      label: "FlatBuffer Message\n(Zero-Copy Layout)"
      shape: rectangle
      style.fill: "#FFE082"
      style.stroke: "#FFC107"
    }
  }
}
row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  consumer: {
    direction: down
    label: "Consumer Process"
    style.fill: "#E3F2FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2
    consumer_api: {
      label: "MessageBus API"
      shape: rectangle
      style.fill: "#BBDEFB"
    }
    app_consumer: {
      label: "Application\nConsumer"
      shape: rectangle
      style.fill: "#90CAF9"
    }
  }
}
legend: {
  near: bottom-center
  label: "Layer Hierarchy"
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  l1: "M5 (Crash Recovery) → wraps all layers" {shape: text}
  l2: "M4 (Pub/Sub) → routing layer" {shape: text}
  l3: "M3 (MPMC) → multi-producer/consumer" {shape: text}
  l4: "M1 (Ring Buffer) → core transport" {shape: text}
  l5: "M2 (Serialization) → message format" {shape: text}
}
producer.app_producer -> producer.producer_api: "TradeOrder\nstruct"
producer.producer_api -> m5_layer: "publish(topic, msg)"
m5_layer -> m4_layer: "with\nrecovery"
m4_layer -> m3_layer: "route to\nsubscribers"
m3_layer -> m1_layer: "claim slot\nCAS"
m1_layer.shared_mem: {
  width: 200
  height: 120
}
m1_layer -> m2_layer: "write\nto slot"
m2_layer.flatbuf_msg -> m1_layer.shared_mem: "zero-copy\nbytes"
m1_layer.shared_mem -> m3_layer: "ref_count\ntracking"
m3_layer -> m4_layer: "fan-out\nnotification"
m4_layer -> m5_layer: "heartbeat\nmonitoring"
m5_layer -> consumer.consumer_api: "deliver"
consumer.consumer_api -> consumer.app_consumer: "TradeOrderView\n(zero-copy read)"
m2_layer.flatbuf_msg -> consumer.app_consumer: "direct\naccess" {
  style.stroke-dash: 4
  style.stroke: "#FFC107"
}