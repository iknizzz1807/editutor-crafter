direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Hardware Soul: Cache Line Movement
  ### MESI Protocol & Inter-Core Coherency Latency
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step1: {
    direction: down
    label: "1. Producer Write"
    width: 280
    producer_cpu: {
      label: "Producer CPU Core"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      l1_cache: {
        label: "L1 Cache (32KB)"
        shape: rectangle
        style.fill: "#C8E6C9"
        cache_line: {
          label: "Slot[5] Cache Line\n64 bytes @ 0x7F00\nState: M (Modified)"
          shape: rectangle
          style.fill: "#4CAF50"
          style.font-color: white
          style.bold: true
        }
      }
    }
    store_instr: {
      label: "Store Instruction"
      width: 250
      code: |'c
        // Producer writes to slot
        slot->ref_count = 2;
        // mov [rdi+0], 2
      '|
    }
    latency1: {
      label: "Latency: 1-4 cycles\n(~0.5-1 ns)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
  }
  arrow1: {
    label: "Write\nPropagates"
    shape: text
    style.font-color: "#666"
  }
  step2: {
    direction: down
    label: "2. L2/L3 Propagation"
    width: 280
    shared_cache: {
      label: "Shared Last-Level Cache (LLC)"
      shape: rectangle
      style.fill: "#E3F2FD"
      style.stroke: "#1976D2"
      l3_slice: {
        label: "L3 Cache Slice (2MB)\nRing/Mesh Interconnect"
        shape: rectangle
        style.fill: "#BBDEFB"
        l3_line: {
          label: "Slot[5] @ L3\nState: M (Modified)\nWaiting for writeback"
          shape: rectangle
          style.fill: "#2196F3"
          style.font-color: white
        }
      }
    }
    writeback: {
      label: "Writeback Buffer"
      width: 250
      code: |'c
        // CPU commits store to L2
        // L2 marks line dirty
        // Eventually drains to L3
      '|
    }
    latency2: {
      label: "Latency: 10-40 cycles\n(~3-12 ns)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step3: {
    direction: down
    label: "3. MESI Invalidation"
    width: 320
    mesi_box: {
      label: "MESI Coherency Protocol"
      shape: rectangle
      style.fill: "#FCE4EC"
      style.stroke: "#C2185B"
      mesi_states: {
        shape: sql_table
        label: "MESI States (Cache Line)"
        m: "M | Modified | Dirty, exclusive"
        e: "E | Exclusive | Clean, exclusive"
        s: "S | Shared | Clean, multiple copies"
        i: "I | Invalid | Not usable"
      }
      invalidation: {
        label: "Invalidation Broadcast"
        width: 280
        code: |'c
          // Producer's L1 has line in M state
          // MESI controller broadcasts:
          //   BusUpgr / Invalidate
          // All other caches must invalidate
        '|
      }
    }
    latency3: {
      label: "Latency: 20-80 cycles\n(~6-25 ns)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
  }
  arrow2: {
    label: "Invalidate\nSignal"
    shape: text
    style.font-color: "#C2185B"
    style.bold: true
  }
  step4: {
    direction: down
    label: "4. Consumer Cache Miss"
    width: 280
    consumer_cpu: {
      label: "Consumer CPU Core"
      shape: rectangle
      style.fill: "#FFEBEE"
      style.stroke: "#C62828"
      consumer_l1: {
        label: "L1 Cache (32KB)"
        shape: rectangle
        style.fill: "#FFCDD2"
        invalid_line: {
          label: "Slot[5] Cache Line\nState: I (INVALID)\n❌ Cannot read!"
          shape: rectangle
          style.fill: "#F44336"
          style.font-color: white
          style.bold: true
        }
      }
    }
    load_instr: {
      label: "Load Instruction (Cache Miss)"
      width: 250
      code: |'c
        // Consumer reads slot
        uint32_t ref = slot->ref_count;
        // mov eax, [rsi+0]
        // → L1 MISS (line is Invalid)
      '|
    }
    latency4: {
      label: "Latency: 1-4 cycles\n(to detect miss)"
      shape: rectangle
      style.fill: "#FFF3E0"
      style.stroke: "#FF9800"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  step5: {
    direction: down
    label: "5. Cache Line Transfer"
    width: 380
    transfer_box: {
      label: "Inter-Core / Inter-Socket Transfer"
      shape: rectangle
      style.fill: "#F3E5F5"
      style.stroke: "#7B1FA2"
      same_socket: {
        label: "Same Socket (Shared LLC)"
        shape: rectangle
        style.fill: "#E1BEE7"
        same_desc: {
          label: "L3 → Consumer L1\nMESI: M → S (both share)"
          shape: text
        }
        same_lat: {
          label: "Latency: 40-80 cycles\n(~12-25 ns)"
          shape: rectangle
          style.fill: "#4CAF50"
          style.font-color: white
          style.bold: true
        }
      }
      cross_socket: {
        label: "Cross-Socket (NUMA)"
        shape: rectangle
        style.fill: "#CE93D8"
        cross_desc: {
          label: "UPI/QPI Interconnect\n~10-20 GB/s bandwidth"
          shape: text
        }
        cross_lat: {
          label: "Latency: 150-300 cycles\n(~50-100 ns)"
          shape: rectangle
          style.fill: "#F44336"
          style.font-color: white
          style.bold: true
        }
      }
    }
    transfer_code: {
      label: "RFO (Read For Ownership)"
      width: 340
      code: |'c
        // Consumer's L1 sends RFO
        // Producer's cache:
        //   If M: writeback to memory, send data
        //   If S: just invalidate, data from L3
        // Consumer receives 64-byte cache line
      '|
    }
  }
  result: {
    direction: down
    label: "Consumer Can Now Read"
    width: 280
    final_state: {
      label: "Final Cache State"
      shape: rectangle
      style.fill: "#E8F5E9"
      style.stroke: "#2E7D32"
      producer_final: {
        label: "Producer L1: Slot[5]\nState: S (Shared)"
        shape: rectangle
        style.fill: "#81C784"
      }
      consumer_final: {
        label: "Consumer L1: Slot[5]\nState: S (Shared)"
        shape: rectangle
        style.fill: "#81C784"
      }
    }
    success: {
      label: "✓ ref_count = 2\nSuccessfully read!"
      shape: rectangle
      style.fill: "#4CAF50"
      style.font-color: white
      style.bold: true
    }
  }
}
latency_summary: {
  label: "Total Latency Breakdown (Same Socket)"
  shape: rectangle
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  style.double-border: true
  width: 600
  summary_table: {
    shape: sql_table
    label: "Latency Analysis"
    step1: "1. Producer store to L1 | 1-4 cycles | 0.5-1 ns"
    step2: "2. L2/L3 propagation | 10-40 cycles | 3-12 ns"
    step3: "3. MESI invalidation | 20-80 cycles | 6-25 ns"
    step4: "4. Consumer detects miss | 1-4 cycles | 0.5-1 ns"
    step5: "5. Cache line transfer (same socket) | 40-80 cycles | 12-25 ns"
    total_same: "TOTAL (Same Socket) | 70-200 cycles | 20-60 ns"
    total_cross: "TOTAL (Cross-Socket NUMA) | 200-400 cycles | 60-130 ns"
  }
  note: {
    label: |md
      **Key Insight**: False sharing occurs when producer and consumer
      access *different* variables on the *same* cache line.
      Each write by producer invalidates consumer's cache, forcing
      the entire 64-byte line to bounce between cores.
      **Fix**: `alignas(64)` separates head and tail to different lines.
    |
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#FFC107"
    width: 580
  }
}
latency_summary.near: bottom-center
step1.producer_cpu -> step2.shared_cache: "Writeback\n( async )"
step2.shared_cache -> step3.mesi_box: "Broadcast\nInvalidate"
step3.mesi_box -> step4.consumer_cpu: "Invalidate\nL1 Line" {
  style.stroke: "#C2185B"
  style.stroke-dash: 4
  style.animated: true
}
step4.consumer_cpu -> step5.transfer_box: "RFO\n(Read For\nOwnership)" {
  style.stroke: "#7B1FA2"
  style.bold: true
}
step5.transfer_box -> result.final_state: "64 bytes\ntransferred" {
  style.stroke: "#2E7D32"
  style.animated: true
}