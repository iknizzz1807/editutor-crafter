insights: Key Insights {
  direction: right
  style.fill: "#FFF8E1"
  style.stroke: "#FF8F00"
  insight1: {
    label: |md
      **Shared Foundation**
      All systems use ring buffer as core:
      - Circular array with head/tail indices
      - Power-of-2 sizes for fast modulo
      - Cache-line alignment for performance
    |
    style.fill: "#FFECB3"
  }
  insight2: {
    label: |md
      **Latency vs Durability Trade-off**
      Memory: sub-μs → Network: 10-100μs → Disk: 1-10ms
      Each layer adds 10-1000× latency
    |
    style.fill: "#FFE082"
  }
  insight3: {
    label: |md
      **Zero-Copy Spectrum**
      Full: Same physical memory
      I/O: DMA directly to NIC
      Partial: Kernel copies remain
      API: User-space only
    |
    style.fill: "#FFD54F"
  }
}
legend: {
  near: bottom-right
  style.fill: white
  style.stroke: "#9E9E9E"
  title: "Transport Types"
  inproc: {
    label: |md
      **Inproc**: In-process (shared heap)
      **IPC**: Inter-process (shared mem / pipes)
      **TCP**: Network sockets
      **UDP**: Unreliable datagrams
      **Multi***: Inproc + IPC + TCP + UDP
    |
  }
}
