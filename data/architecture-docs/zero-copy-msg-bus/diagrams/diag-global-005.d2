direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Alternative Reality: Industry Comparisons
  ## Zero-Copy Message Bus Design Choices vs. Industry Standards
| {near: top-center}
row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  zcmb: Zero-Copy Message Bus {
    direction: down
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
    style.stroke-width: 2
    header: {
      label: |md
        **This Project**
        *Sub-μs IPC, zero-copy*
      |
      style.fill: "#C8E6C9"
      style.stroke: "#2E7D32"
    }
    features: {
      label: |md
        ✓ Shared memory ring buffer
        ✓ Lock-free SPSC, CAS-based MPMC
        ✓ Flat buffer zero-copy serialization
        ✓ Trie-based pub/sub with wildcards
        ✓ Reference-counted fan-out
        ✓ At-least-once + idempotent consumers
        ✓ Checkpoint + WAL recovery
        ✓ Sub-microsecond latency
      |
    }
    optimize: {
      label: |md
        **Optimizes For:**
        - Same-machine IPC latency
        - CPU cache efficiency
        - Zero serialization overhead
      |
      style.fill: "#A5D6A7"
      style.stroke: "#2E7D32"
    }
  }
  lmax: LMAX Disruptor {
    direction: down
    style.fill: "#E3F2FD"
    style.stroke: "#1565C0"
    style.stroke-width: 2
    header: {
      label: |md
        **LMAX Disruptor**
        *6M+ events/sec, Java-based*
      |
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
    }
    features: {
      label: |md
        ✓ Ring buffer (same pattern)
        ✓ Single-threaded claim
        ✓ Multi-producer via CAS
        ✓ Pre-allocated event objects
        ✓ Dependency barriers
        ✓ Sequencer pattern
        ✗ Intra-process only (JVM)
        ✗ No cross-process shared memory
      |
    }
    optimize: {
      label: |md
        **Optimizes For:**
        - JVM garbage collection avoidance
        - Intra-process throughput
        - Event processing pipelines
      |
      style.fill: "#90CAF9"
      style.stroke: "#1565C0"
    }
  }
}
row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  aeron: Aeron {
    direction: down
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
    style.stroke-width: 2
    header: {
      label: |md
        **Aeron**
        *High-throughput messaging, UDP/TCP*
      |
      style.fill: "#FFE0B2"
      style.stroke: "#E65100"
    }
    features: {
      label: |md
        ✓ Ring buffer at core
        ✓ Zero-copy I/O
        ✓ Back-pressure via credits
        ✓ Media driver isolation
        ✓ Reliable UDP (retransmission)
        ✓ IPC + network transport
        ✓ Flow control strategies
        ✗ Network latency (10-100μs+)
      |
    }
    optimize: {
      label: |md
        **Optimizes For:**
        - Network messaging efficiency
        - Predictable tail latency
        - Cross-machine distribution
      |
      style.fill: "#FFCC80"
      style.stroke: "#E65100"
    }
  }
  kafka: Apache Kafka {
    direction: down
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
    style.stroke-width: 2
    header: {
      label: |md
        **Apache Kafka**
        *Distributed log, disk-backed*
      |
      style.fill: "#E1BEE7"
      style.stroke: "#7B1FA2"
    }
    features: {
      label: |md
        ✓ Partitioned ring buffer
        ✓ Zero-copy sendfile()
        ✓ Offset-based consumption
        ✓ Consumer groups
        ✓ Log compaction
        ✓ Exactly-once (transactions)
        ✓ Replication factor
        ✗ Disk latency (ms)
        ✗ Not zero-copy receive
      |
    }
    optimize: {
      label: |md
        **Optimizes For:**
        - Durability and replay
        - Horizontal scalability
        - Event sourcing / streaming
      |
      style.fill: "#CE93D8"
      style.stroke: "#7B1FA2"
    }
  }
}
row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent
  redis: Redis Pub/Sub {
    direction: down
    style.fill: "#FFEBEE"
    style.stroke: "#C62828"
    style.stroke-width: 2
    header: {
      label: |md
        **Redis Pub/Sub**
        *In-memory, TCP-based*
      |
      style.fill: "#FFCDD2"
      style.stroke: "#C62828"
    }
    features: {
      label: |md
        ✓ In-memory processing
        ✓ Pattern matching (PSUBSCRIBE)
        ✓ O(1) publish, O(N) pattern match
        ✓ Fire-and-forget delivery
        ✗ No persistence (no backlog)
        ✗ TCP serialization overhead
        ✗ Kernel copies (not zero-copy)
        ✗ Lost messages on disconnect
      |
    }
    optimize: {
      label: |md
        **Optimizes For:**
        - Simplicity and ease of use
        - Integration with Redis ecosystem
        - Real-time notifications
      |
      style.fill: "#EF9A9A"
      style.stroke: "#C62828"
    }
  }
  nanomsg: nanomsg / nng {
    direction: down
    style.fill: "#E0F2F1"
    style.stroke: "#00695C"
    style.stroke-width: 2
    header: {
      label: |md
        **nanomsg / nng**
        *Socket compatibility layer*
      |
      style.fill: "#B2DFDB"
      style.stroke: "#00695C"
    }
    features: {
      label: |md
        ✓ Multiple patterns (PUB/SUB, REQ/REP)
        ✓ Zero-copy API (iovecs)
        ✓ Inproc, IPC, TCP transports
        ✓ Socket-compatible API
        ✓ Reconnect logic built-in
        ✓ Survey, pipeline patterns
        ✗ Kernel copies on network
        ✗ Not truly zero-copy
      |
    }
    optimize: {
      label: |md
        **Optimizes For:**
        - POSIX socket compatibility
        - Protocol pattern flexibility
        - Developer ergonomics
      |
      style.fill: "#80CBC4"
      style.stroke: "#00695C"
    }
  }
}
