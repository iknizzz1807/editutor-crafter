vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#E8D5F2"
    data: "#D5E8F2"
    free: "#D5F2E8"
    padding: "#F2E8D5"
    pointer: "#F2D5E8"
    process-a: "#C5CAE9"
    process-b: "#FFCCBC"
    kernel: "#FAFAFA"
  }
}

title: |md
  # Shared Memory Ring Buffer Architecture
  ### Zero-Copy IPC via POSIX Shared Memory
  **Design Spec**: Single-Producer Single-Consumer (SPSC) lock-free queue with cache-line isolation.
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# PRODUCER PROCESS
# -----------------------------------------------------------------------------------------
producer_process: "Producer Process (PID: 1234)" {
  style.fill: ${colors.process-a}
  style.stroke: "#3F51B5"
  style.stroke-width: 4

  producer_thread: "Producer Thread (Core 0)" {
    shape: rectangle
    style.fill: white
    style.bold: true
    
    produce_fn: |cpp
      void produce(const Msg& msg) {
        uint64_t h = head.load(relaxed);
        uint64_t t = tail.load(acquire);
        if ((h + 1) % N == t) return; // Full
        memcpy(&slots[h % N], &msg, sizeof(Msg));
        head.store(h + 1, release);
      }
    |
    produce_fn.shape: code
  }

  vaddr_box: "Virtual Address Space" {
    style.fill: "#E8EAF6"
    style.stroke-dash: 3
    vaddr_label: "vaddr: 0x7F00_0000_0000" {
      shape: text
      style.font: mono
      style.font-size: 14
    }
    vaddr_ptr: "uint8_t* shared_mem_ptr" {
      shape: text
      style.font: mono
      style.bold: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# CONSUMER PROCESS
# -----------------------------------------------------------------------------------------
consumer_process: "Consumer Process (PID: 5678)" {
  style.fill: ${colors.process-b}
  style.stroke: "#E64A19"
  style.stroke-width: 4

  consumer_thread: "Consumer Thread (Core 1)" {
    shape: rectangle
    style.fill: white
    style.bold: true

    consume_fn: |cpp
      bool consume(Msg& out) {
        uint64_t t = tail.load(relaxed);
        uint64_t h = head.load(acquire);
        if (h == t) return false; // Empty
        memcpy(&out, &slots[t % N], sizeof(Msg));
        tail.store(t + 1, release);
        return true;
      }
    |
    consume_fn.shape: code
  }

  vaddr_box2: "Virtual Address Space" {
    style.fill: "#FBE9E7"
    style.stroke-dash: 3
    vaddr_label2: "vaddr: 0x7F00_1000_0000" {
      shape: text
      style.font: mono
      style.font-size: 14
    }
    vaddr_ptr2: "uint8_t* shared_mem_ptr" {
      shape: text
      style.font: mono
      style.bold: true
    }
  }
}

# -----------------------------------------------------------------------------------------
# SHARED MEMORY REGION
# -----------------------------------------------------------------------------------------
shared_memory_region: "Shared Memory Region (POSIX shm_open)" {
  style.fill: white
  style.stroke: "#333"
  style.stroke-width: 3
  style.double-border: true

  header_section: "RingBufferHeader (256 bytes)" {
    style.fill: ${colors.header}
    style.stroke: "#7B1FA2"

    head_cache_line: "Cache Line 0 (64B)" {
      style.fill: "#F3E5F5"
      style.stroke-dash: 2
      head_field: "head: atomic<uint64>" {
        shape: rectangle
        style.fill: "#E1BEE7"
        style.font: mono
        width: 200
      }
      pad0: "padding[56] (Avoid False Sharing)" {
        shape: rectangle
        style.fill: ${colors.padding}
        style.opacity: 0.6
      }
    }

    tail_cache_line: "Cache Line 1 (64B)" {
      style.fill: "#F3E5F5"
      style.stroke-dash: 2
      tail_field: "tail: atomic<uint64>" {
        shape: rectangle
        style.fill: "#E1BEE7"
        style.font: mono
        width: 200
      }
      pad1: "padding[56] (Avoid False Sharing)" {
        shape: rectangle
        style.fill: ${colors.padding}
        style.opacity: 0.6
      }
    }

    metadata: "Metadata (64B)" {
      style.fill: "#F3E5F5"
      num_slots: "uint64_t num_slots"
      slot_size: "uint64_t slot_size"
      mask: "uint64_t mask"
      seq: "uint64_t sequence"
    }

    proc_coord: "Process Coordination (64B)" {
      style.fill: "#F3E5F5"
      p_pid: "producer_pid"
      c_pid: "consumer_pid"
      p_hb: "producer_heartbeat"
      c_hb: "consumer_heartbeat"
    }
  }

  slots_section: "Message Slots Array (Data)" {
    style.fill: ${colors.data}
    style.stroke: "#1976D2"
    
    slot_0: "Slot 0" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      label: "Msg 0 Data"
    }
    slot_1: "Slot 1" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      label: "Msg 1 Data"
    }
    slot_2: "Slot 2" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
      label: "Msg 2 Data"
    }
    slot_dots: "..." {
      shape: text
    }
    slot_n: "Slot N-1" {
      style.fill: "#BBDEFB"
      style.stroke: "#1565C0"
    }
  }
}

# -----------------------------------------------------------------------------------------
# KERNEL / HARDWARE LAYER
# -----------------------------------------------------------------------------------------
kernel_layer: "Kernel / Hardware Layer" {
  style.fill: ${colors.kernel}
  style.stroke: "#757575"
  style.stroke-dash: 5

  page_tables: "Page Tables" {
    style.fill: "#E0E0E0"
    proc_a_pt: "Process A Page Table Entry" {
      label: "V:0x7F00_0000_0000 -> P:0x1234_5000"
      shape: rectangle
    }
    proc_b_pt: "Process B Page Table Entry" {
      label: "V:0x7F00_1000_0000 -> P:0x1234_5000"
      shape: rectangle
    }
  }

  physical_mem: "Physical Memory (RAM)" {
    style.fill: "#BDBDBD"
    phys_page: "Physical Page @ 0x1234_5000" {
      shape: rectangle
      style.fill: "#9E9E9E"
      style.bold: true
    }
  }

  cache_hierarchy: "Cache Coherency (MESI)" {
    style.fill: "#EEEEEE"
    l1_0: "L1 Cache (Core 0)"
    l1_1: "L1 Cache (Core 1)"
    l3: "L3 Shared Cache"
    l1_0 -> l3
    l1_1 -> l3
  }
}

# -----------------------------------------------------------------------------------------
# API / CLASSES
# -----------------------------------------------------------------------------------------
api_definitions: "Implementation Components" {
  shm_alloc: "SharedMemory" {
    shape: class
    style.fill: ${colors.pointer}
    name: "string"
    size: "size_t"
    fd: "int"
    data: "uint8_t*"
    + "SharedMemory(name, size, create)"
    + "data(): void*"
  }

  ring_buf: "SpscRingBuffer" {
    shape: class
    style.fill: ${colors.pointer}
    header: "Header*"
    slots: "uint8_t*"
    + "attach(void* memory)"
    + "try_produce(const void* data): bool"
    + "try_consume(void* out): bool"
  }
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS
# -----------------------------------------------------------------------------------------

# IPC Mapping
producer_process.vaddr_box.vaddr_ptr -> shared_memory_region: "mmap(MAP_SHARED)" {
  style.stroke: "#3F51B5"
  style.stroke-width: 2
}
consumer_process.vaddr_box2.vaddr_ptr2 -> shared_memory_region: "mmap(MAP_SHARED)" {
  style.stroke: "#E64A19"
  style.stroke-width: 2
}

# Atomic Interactions
producer_process.producer_thread -> shared_memory_region.header_section.head_cache_line.head_field: "Update Head (Release)" {
  style.stroke: "#3F51B5"
  style.stroke-width: 2
}
consumer_process.consumer_thread -> shared_memory_region.header_section.tail_cache_line.tail_field: "Update Tail (Release)" {
  style.stroke: "#E64A19"
  style.stroke-width: 2
}

# Cross-reading for full/empty checks
producer_process.producer_thread -> shared_memory_region.header_section.tail_cache_line.tail_field: "Check Tail (Acquire)" {
  style.stroke: "#3F51B5"
  style.stroke-dash: 3
}
consumer_process.consumer_thread -> shared_memory_region.header_section.head_cache_line.head_field: "Check Head (Acquire)" {
  style.stroke: "#E64A19"
  style.stroke-dash: 3
}

# Kernel Mapping
producer_process -> kernel_layer.page_tables.proc_a_pt
consumer_process -> kernel_layer.page_tables.proc_b_pt
kernel_layer.page_tables.proc_a_pt -> kernel_layer.physical_mem.phys_page
kernel_layer.page_tables.proc_b_pt -> kernel_layer.physical_mem.phys_page

# Cache Coherency
shared_memory_region -> kernel_layer.cache_hierarchy.l3: "Hardware Synchronization"

# -----------------------------------------------------------------------------------------
# MEMORY LAYOUT GRID
# -----------------------------------------------------------------------------------------
mem_layout_summary: "Exact Byte Offsets" {
  near: bottom-left
  grid-columns: 2
  grid-gap: 0
  
  h_0: "Offset" { style.bold: true; style.fill: "#CCC" }
  h_1: "Field / Section" { style.bold: true; style.fill: "#CCC" }
  
  r0_0: "0x00" { style.font: mono }
  r0_1: "head (uint64) [CL 0 Start]" { style.fill: ${colors.header} }
  
  r1_0: "0x08" { style.font: mono }
  r1_1: "padding[56]" { style.fill: ${colors.padding} }
  
  r2_0: "0x40" { style.font: mono }
  r2_1: "tail (uint64) [CL 1 Start]" { style.fill: ${colors.header} }
  
  r3_0: "0x48" { style.font: mono }
  r3_1: "padding[56]" { style.fill: ${colors.padding} }
  
  r4_0: "0x80" { style.font: mono }
  r4_1: "Metadata + Coordination" { style.fill: ${colors.header} }
  
  r5_0: "0x100" { style.font: mono }
  r5_1: "Start of Message Slots" { style.fill: ${colors.data} }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: "Architecture Legend" {
  near: bottom-right
  style.fill: white
  
  items: {
    grid-columns: 2
    l1: "" { style.fill: ${colors.header} }
    d1: "Control Header (Shared)"
    
    l2: "" { style.fill: ${colors.data} }
    d2: "Payload Area (Message Slots)"
    
    l3: "" { style.fill: ${colors.padding} }
    d3: "Cache Padding (Prevents False Sharing)"
    
    l4: "" { style.stroke-dash: 5 }
    d4: "Virtual Boundary"
  }
}