vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: ||md
  # Ring Buffer Memory Layout (Architecture: ARMv8-A / M1)
  **Zero-Copy Shared Memory Message Bus — Technical Specification**
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

direction: right

# Main Memory Container
memory_region: "Shared Memory Space (Mapped Region)" {
  style: {
    fill: "#F8F9FA"
    stroke: "#343A40"
    stroke-width: 4
  }

  # Offset Column Indicators
  offsets: {
    style: {
      stroke: transparent
      fill: transparent
    }
    o1: "0x00" { shape: text }
    o2: "0x40" { shape: text }
    o3: "0x80" { shape: text }
    o4: "0xC0" { shape: text }
    o5: "0x100" { shape: text }
  }

  # --- HEADER SECTION ---
  header: "RingBufferHeader (Total Size: 256B / 4 Cache Lines)" {
    style: {
      fill: "#E8DAEF"
      stroke: "#8E44AD"
      stroke-width: 3
    }

    # Cache line 0: Head Pointer (Orange for Pointers)
    cl0: "Cache Line 0 (Producer Control)" {
      style: {
        fill: "#FAE5D3"
        stroke: "#E67E22"
        stroke-dash: 4
      }
      head: {
        label: |md
          **head** `_Atomic uint64_t`
          Offset: 0x00 | Size: 8B
          *Producer Write Cursor*
        ||
        style.fill: "#F5CBA7"
# REMOVED (extra closing brace):       }
      pad0: {
        label: ||md
          **padding[56]**
          Offset: 0x08 | Size: 56B
          *Prevents head/tail false sharing*
        ||
        style: {
          fill: "#D5DBDB"
          font-color: "#7F8C8D"
        }
      }
# REMOVED (extra closing brace):     }

    # Cache line 1: Tail Pointer (Orange for Pointers)
    cl1: "Cache Line 1 (Consumer Control)" {
      style: {
        fill: "#FAE5D3"
        stroke: "#E67E22"
        stroke-dash: 4
      }
      tail: {
        label: ||md
          **tail** `_Atomic uint64_t`
          Offset: 0x40 | Size: 8B
          *Consumer Read Cursor*
        ||
        style.fill: "#F5CBA7"
      }
      pad1: {
        label: ||md
          **padding[56]**
          Offset: 0x48 | Size: 56B
          *Isolation buffer*
        ||
        style: {
          fill: "#D5DBDB"
          font-color: "#7F8C8D"
        }
      }
    }

    # Cache line 2: Static Configuration (Purple Header Data)
    cl2: "Cache Line 2 (Bus Configuration)" {
      style: {
        fill: "#F4ECF7"
        stroke: "#8E44AD"
        stroke-dash: 4
      }
      grid-columns: 2
      num_slots: {
        label: "**num_slots** `uint64_t` (0x80)"
        style.fill: "#D1F2EB"
      }
      slot_size: {
        label: "**slot_size** `uint64_t` (0x88)"
        style.fill: "#D1F2EB"
      }
      mask: {
        label: "**mask** `uint64_t` (0x90)"
        style.fill: "#D1F2EB"
      }
      seq_base: {
        label: "**sequence_base** `uint64_t` (0x98)"
        style.fill: "#D1F2EB"
      }
      pad2: {
        label: "**reserved[32]** (0xA0-0xBF)"
        style.fill: "#D5DBDB"
      }
    }

    # Cache line 3: Inter-Process Coordination
    cl3: "Cache Line 3 (Liveness & Coordination)" {
      style: {
        fill: "#D6EAF8"
        stroke: "#3498DB"
        stroke-dash: 4
      }
      grid-columns: 2
      p_pid: {
        label: "**producer_pid** `uint32_t` (0xC0)"
        style.fill: "#AED6F1"
      }
      c_pid: {
        label: "**consumer_pid** `uint32_t` (0xC4)"
        style.fill: "#AED6F1"
      }
      p_hb: {
        label: "**prod_heartbeat** `uint64_t` (0xC8)"
        style.fill: "#85C1E9"
      }
      c_hb: {
        label: "**cons_heartbeat** `uint64_t` (0xD0)"
        style.fill: "#85C1E9"
      }
      gen: {
        label: "**generation** `uint32_t` (0xD8)"
        style.fill: "#5DADE2"
      }
      pad3: {
        label: "**coord_padding[36]** (0xDC-0xFF)"
        style.fill: "#D5DBDB"
      }
    }
# REMOVED (extra closing brace):   }

  # --- DATA SECTION (Blue for Data) ---
  slot_array: "Message Slot Data Array (Payloads)" {
    style: {
      fill: "#EBF5FB"
      stroke: "#2E86AB"
      stroke-width: 3
    }
    slot_0: "Slot 0" {
      style: { 
        fill: "#AED6F1"
        stroke: "#2980B9" 
      }
      label: |md
        **Offset: 0x100**
        Data: [64 - 1024 bytes]
        *Primary Message Buffer*
      |
    }
    slot_1: "Slot 1" {
      style: { 
        fill: "#AED6F1"
        stroke: "#2980B9" 
      }
      label: |md
        **Offset: 0x100 + S**
        Data: [64 - 1024 bytes]
      |
    }
    gap: "..." {
      shape: text
    }
    slot_last: "Slot N-1" {
      style: { 
        fill: "#AED6F1"
        stroke: "#2980B9" 
      }
      label: |md
        **Offset: 0x100 + (N-1)S**
        *End of mapped region*
      |
    }
  }
# REMOVED (extra closing brace): }

# Documentation & Engineering Notes
formula: ||md
  ### Address Calculation
  `HeaderOffset = 0x00`
  `SlotArrayOffset = 0x100 (256B)`
  `Slot(i)_Addr = Base + 0x100 + (i * slot_size)`
  `Slots must be cache-line aligned (S % 64 == 0)`
| { 
  near: top-left 
}

legend: {
  label: |md
    ### Memory Regions
    - 🟣 **Header Metadata**: 256B control block
    - 🟠 **Atomic Pointers**: head/tail cursors
    - 🟢 **Static Config**: Read-only after init
    - 🔵 **Dynamic State**: Coordination fields
    - ⬜ **Padding**: Avoids L1 false sharing
    - 🩵 **Payloads**: Raw message slots
  ||
  style: { 
    fill: "#FFFFFF"
    stroke: "#343A40" 
  }
  near: top-right
# REMOVED (extra closing brace): }

cache_coherency_note: ||md
  ### L1 Cache Isolation (64B)
  - `head` (CL0) and `tail` (CL1) occupy distinct cache lines.
  - This prevents **False Sharing** where Producer/Consumer CPUs fight for ownership of the same line.
  - Crucial for low-latency ARM M1/M2 interconnects.
| { 
  near: center-left 
}

memory_ordering: |md
  ### Barriers & Fences
  **Producer (Write):**
  1. Write Slot Data
  2. `atomic_store_explicit(head, next, memory_order_release)`
  
  **Consumer (Read):**
  1. `atomic_load_explicit(head, memory_order_acquire)`
  2. Read Slot Data
  3. `atomic_store_explicit(tail, next, memory_order_release)`
| { 
  near: bottom-right 
}

implementation_spec: |md
  ### Implementation Spec
  - **Inter-process**: Map with `shm_open` and `mmap`
  - **Memory Protection**: `PROT_READ | PROT_WRITE`
  - **Page Alignment**: Header should ideally start at page boundary (4KB)
| { 
  near: bottom-left 
}

# Connect the structural relationship
memory_region.header -> memory_region.slot_array: "Array index via head/tail" {
  style: { 
    stroke: "#8E44AD"
    stroke-width: 2
    stroke-dash: 3
    animated: true 
  }
}
||