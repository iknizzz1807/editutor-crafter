vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Producer State Machine
  Zero-Copy Message Bus вҖ” Slot Lifecycle with Memory Barriers
| {near: top-center}

direction: right

states: {
  IDLE: {
    shape: circle
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
      stroke-width: 3
    }
    label: IDLE
    width: 120
  }
  CLAIMING_SLOT: {
    shape: circle
    style: {
      fill: "#E3F2FD"
      stroke: "#1565C0"
      stroke-width: 3
    }
    label: "CLAIMING_SLOT\n\nCAS(ref_count, 0 вҶ’ N)"
    width: 160
  }
  WRITING_DATA: {
    shape: circle
    style: {
      fill: "#FFF3E0"
      stroke: "#EF6C00"
      stroke-width: 3
    }
    label: "WRITING_DATA\n\nmemcpy(slot, msg)"
    width: 160
  }
  PUBLISHING: {
    shape: circle
    style: {
      fill: "#F3E5F5"
      stroke: "#7B1FA2"
      stroke-width: 3
    }
    label: "PUBLISHING\n\nstore(head, next)"
    width: 160
  }
}

# Transitions
IDLE -> CLAIMING_SLOT: "try_produce()\n[buffer not full]" {
  style: {
    stroke: "#1565C0"
    stroke-width: 2
    animated: true
  }
}

CLAIMING_SLOT -> WRITING_DATA: "CAS success\n[slot claimed]" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
  }
}

CLAIMING_SLOT -> IDLE: "CAS failure\n[buffer full]" {
  style: {
    stroke: "#C62828"
    stroke-width: 2
    stroke-dash: 4
  }
}

WRITING_DATA -> PUBLISHING: "memcpy complete\nв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\nв”Ӯ RELEASE FENCE   в”Ӯ\nв”Ӯ atomic_thread_  в”Ӯ\nв”Ӯ fence(release)  в”Ӯ\nв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ" {
  style: {
    stroke: "#7B1FA2"
    stroke-width: 3
  }
}

PUBLISHING -> IDLE: "head updated\n[message visible]" {
  style: {
    stroke: "#2E7D32"
    stroke-width: 2
    animated: true
  }
}

# ILLEGAL transition
WRITING_DATA -> IDLE: "ILLEGAL\n[no release fence]\n[data not visible]" {
  style: {
    stroke: "#B71C1C"
    stroke-width: 3
    stroke-dash: 6
    fill: "#FFEBEE"
    font-color: "#B71C1C"
    bold: true
  }
}

# Memory barrier explanation
memory_barrier_box: {
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#424242"
    stroke-dash: 3
  }
  barrier_note: |md
    ## Memory Barrier Placement
    **RELEASE fence** ensures:
    - All prior writes (memcpy) complete
    - Before head update becomes visible
    - Consumer's acquire load sees all data

    **Without fence**: Consumer may see:
    - Updated head pointer
    - But stale/unwritten slot data
    - вҶ’ Message corruption
  |
}

# Initial state indicator
initial: {
  shape: circle
  width: 20
  style.fill: "#2E7D32"
}
initial -> states.IDLE: "" {
  style: {
    stroke-width: 2
    stroke: "#2E7D32"
  }
}

# Legend
legend: {
  near: bottom-center
  style: {
    fill: "#FAFAFA"
    stroke: "#BDBDBD"
    border-radius: 4
  }
  valid: "в”Җв”Җв”Җв–ә Valid transition" {
    style.font-color: "#2E7D32"
  }
  illegal: "- - -> ILLEGAL transition" {
    style: {
      font-color: "#B71C1C"
      bold: true
    }
  }
  barrier: "в–Ј Memory barrier" {
    style.font-color: "#7B1FA2"
  }
}

# State invariants - Fixed using double-pipe block string to handle internal table pipes
invariants: ||md
  ## State Invariants
  | State | `ref_count` | `head` | Data |
  |-------|-------------|--------|------|
  | IDLE | unchanged | unchanged | N/A |
  | CLAIMING_SLOT | CAS in progress | unchanged | N/A |
  | WRITING_DATA | > 0 (claimed) | unchanged | being written |
  | PUBLISHING | > 0 | being updated | complete |

  **Key invariant**: `head` only advances after data is fully written
|| {near: bottom-right}