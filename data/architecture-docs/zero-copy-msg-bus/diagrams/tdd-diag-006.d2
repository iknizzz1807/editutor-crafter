layout-engine: elk
vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    center: true
  }
  colors: {
    header: "#9C27B0"
    data: "#2196F3"
    free: "#4CAF50"
    padding: "#9E9E9E"
    pointer: "#FF9800"
    barrier: "#E91E63"
      header: "#607D8B"
      pointer: "#607D8B"
      padding: "#607D8B"
      barrier: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      data: "#607D8B"
      data: "#607D8B"
      data: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      pointer: "#607D8B"
      header: "#607D8B"
      pointer: "#607D8B"
      padding: "#607D8B"
      barrier: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      data: "#607D8B"
      data: "#607D8B"
      data: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      pointer: "#607D8B"
      header: "#607D8B"
      pointer: "#607D8B"
      padding: "#607D8B"
      barrier: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      data: "#607D8B"
      data: "#607D8B"
      data: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
      free: "#607D8B"
