vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Cross-Process Memory Visibility Flow
  Write from Process A → Process B with barrier synchronization points
| {near: top-center}
# Process A (Producer)
Process_A: {
  label: "Process A\n(Producer)"
  style.fill: "#E8D5E8"
  style.stroke: "#8B5A8B"
  cpu_core_0: "CPU Core 0" {
    style.fill: "#D4B8D4"
  }
  store_buffer: "Store Buffer\n(pending writes)" {
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
  }
  register: "Register\nmov [addr], value" {
    shape: square
    style.fill: "#98FB98"
  }
  register -> store_buffer: "1. Store issued\n(speculative)"
}
# Memory Subsystem
Memory_Hierarchy: {
  label: "Memory Hierarchy"
  style.fill: "#F0F8FF"
  style.stroke: "#4682B4"
  L1_cache_A: "L1 Cache\n(Core 0 Private)" {
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  L2_cache_A: "L2 Cache\n(Core 0 Private)" {
    style.fill: "#87CEEB"
    style.stroke: "#4682B4"
  }
  L3_cache: "L3 Cache (LLC)\nShared Across Cores" {
    style.fill: "#6495ED"
    style.stroke: "#4169E1"
    style.font-color: white
  }
  main_memory: "Main Memory\n(DRAM)" {
    shape: cylinder
    style.fill: "#708090"
    style.font-color: white
  }
  L3_cache <-> main_memory: "Memory Controller\n(~100ns latency)"
}
# Process B (Consumer)
Process_B: {
  label: "Process B\n(Consumer)"
  style.fill: "#E8D5E8"
  style.stroke: "#8B5A8B"
  cpu_core_1: "CPU Core 1" {
    style.fill: "#D4B8D4"
  }
  load_buffer: "Load Buffer\n(pending reads)" {
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
  }
  invalidate_queue: "Invalidate Queue\n(pending invalidations)" {
    style.fill: "#FFB6C1"
    style.stroke: "#DC143C"
  }
  register_B: "Register\nvalue loaded" {
    shape: square
    style.fill: "#98FB98"
  }
  load_buffer -> register_B: "9. Load completes"
}
# Flow connections with timing
Process_A.store_buffer -> Memory_Hierarchy.L1_cache_A: "2. Store drains\nto L1 (commit)" {
  style.stroke: "#228B22"
  style.stroke-width: 3
}
Memory_Hierarchy.L1_cache_A -> Memory_Hierarchy.L2_cache_A: "3. L1 → L2\nwrite-through/write-back"
Memory_Hierarchy.L2_cache_A -> Memory_Hierarchy.L3_cache: "4. L2 → L3\ncoherency traffic"
# Cache coherency broadcast
Memory_Hierarchy.L3_cache -> Process_B.invalidate_queue: "5. Invalidate\nbroadcast (MESI)" {
  style.stroke: "#DC143C"
  style.stroke-dash: 4
  label: "RFO - Request For Ownership"
}
# Memory write path
Memory_Hierarchy.L3_cache -> Memory_Hierarchy.main_memory: "6. Write-back\nto DRAM" {
  style.stroke: "#4682B4"
}
# Read path for Process B
Process_B.load_buffer -> Memory_Hierarchy.L3_cache: "7. Load request\n(cache miss)" {
  style.stroke: "#FF8C00"
}
Memory_Hierarchy.main_memory -> Memory_Hierarchy.L3_cache: "8a. DRAM → L3\n(cache fill)" {
  style.stroke: "#4682B4"
  style.stroke-dash: 3
}
Memory_Hierarchy.L3_cache -> Process_B.load_buffer: "8b. Data returned\nto load buffer" {
  style.stroke: "#228B22"
}
# Barrier markers
barrier_release: "RELEASE BARRIER\natomic_thread_fence(release)" {
  shape: diamond
  style.fill: "#FFD700"
  style.stroke: "#B8860B"
}
barrier_acquire: "ACQUIRE BARRIER\natomic_thread_fence(acquire)" {
  shape: diamond
  style.fill: "#FFD700"
  style.stroke: "#B8860B"
}
# Position barriers
Process_A -> barrier_release: "Before\npublishing" {
  style.stroke-dash: 3
  style.animated: true
}
barrier_release -> Process_A.store_buffer: "Ensures ordering\nall prior writes visible" {
  style.stroke: "#B8860B"
}
Process_B.load_buffer -> barrier_acquire: "After\nloading" {
  style.stroke-dash: 3
}
barrier_acquire -> Process_B.register_B: "Ensures ordering\nall subsequent reads see data" {
  style.stroke: "#B8860B"
}
# Legend
legend: {
  near: bottom-right
  label: "Timing Legend"
  timing: |md
    
    Step 1: Store issued      ~1 cycle
    Step 2: L1 commit         ~4 cycles
    Step 3-4: L1→L2→L3        ~20-40 cycles
    Step 5: Invalidate        ~40-80 cycles
    Step 6: DRAM write        ~100-300 cycles
    Step 7-8: DRAM read       ~100-300 cycles
    Step 9: Load complete     ~4 cycles
    Total: 200-700+ cycles
    (depends on cache state)
    
  |
  style.fill: "#F5F5F5"
  style.stroke: "#808080"
}
# Cross-process visibility annotation
visibility_note: |md
  **Key Insight**: Without barriers, steps 2-6 may be
  reordered by CPU. The RELEASE barrier ensures the
  store buffer drains before the head index update.
  The ACQUIRE barrier ensures invalidation queue is
  processed before reading message data.
| {
  near: bottom-center
  style.fill: "#FFFACD"
  style.stroke: "#DAA520"
}
# Shared memory indicator
shared_mem_region: "Shared Memory Region\n(mapped via mmap with MAP_SHARED)" {
  shape: parallelogram
  style.fill: "#E6E6FA"
  style.stroke: "#9370DB"
}
Memory_Hierarchy -> shared_mem_region: "Physical pages\nshared between processes" {
  style.stroke-dash: 5
  style.stroke: "#9370DB"
}