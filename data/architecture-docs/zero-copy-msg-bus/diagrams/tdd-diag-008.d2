vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Cache Line Movement: False Sharing vs. Aligned Fix
  ## Cache coherence operates at 64-byte granularity (MESI Protocol)
| {near: top-center}

direction: right

classes: {
  mem_header: { style.fill: "#673AB7"; style.font-color: white; style.bold: true }
  mem_data: { style.fill: "#2196F3"; style.font-color: white }
  mem_padding: { style.fill: "#bdbdbd"; style.font-color: "#616161" }
  core_producer: { style.fill: "#00d4ff"; style.font-color: black; style.stroke: "#00acc1" }
  core_consumer: { style.fill: "#ff6b35"; style.font-color: black; style.stroke: "#e65100" }
}

# ============================================
# LEFT SIDE: FALSE SHARING SCENARIO
# ============================================
FalseSharing: "❌ FALSE SHARING SCENARIO" {
  direction: right
  style.stroke: "#ff4444"
  style.stroke-width: 4
  
  BadLayout: "Memory Layout (BAD)" {
    direction: down
    style.fill: "#2d1b1b"
    style.stroke: "#ff6b6b"
    style.stroke-width: 2
    
    CacheLine0Bad: "Cache Line 0 [Offset 0x00]" {
      direction: right
      style.fill: "#4a1a1a"
      style.stroke: "#ff4444"
      style.stroke-dash: 4
      
      ByteLayoutBad: {
        grid-columns: 8
        grid-gap: 0
        b0: "0x00" { class: mem_data; label: "head\n8B" }
        b1: "0x08" { class: mem_data; label: "tail\n8B" }
        b2: "0x10" { class: mem_padding; label: "pad\n48B" }
        b3: "0x18" { class: mem_padding; label: "..." }
        b4: "0x20" { class: mem_padding; label: "..." }
        b5: "0x28" { class: mem_padding; label: "..." }
        b6: "0x30" { class: mem_padding; label: "..." }
        b7: "0x38" { class: mem_padding; label: "0x3F" }
      }
      
      ProblemArrow: |md
        ⚠️ **CRITICAL PROBLEM**
        Both `head` and `tail` reside on the **SAME** 64-byte line.
        Any write to `tail` invalidates `head` for Core 0.
      | {
        style.font-color: "#ff6b6b"
        style.stroke: "#ff4444"
        style.fill: "#3d1414"
      }
    }
  }

  PingPong: "Cache Coherency Ping-Pong" {
    direction: down
    style.fill: "#1a1a2e"
    style.stroke: "#e94560"
    
    Core0: "Core 0 (Producer)" {
      class: core_producer
      WriteHead: "Write head" {
        tooltip: "Acquires EXCLUSIVE ownership of entire 64B line"
        style.bold: true
      }
    }
    
    Core1: "Core 1 (Consumer)" {
      class: core_consumer
      ReadHead: "Read head" {
        tooltip: "Cache MISS! Must wait for Core 0 to flush"
      }
      WriteTail: "Write tail" {
        tooltip: "Invalidates Core 0's line to write tail"
        style.bold: true
      }
    }
    
    Core0.ReadTail: "Read tail" {
      class: core_producer
      tooltip: "Cache MISS! Must wait for Core 1"
    }

    Core0.WriteHead -> Core1.ReadHead: "MESI: Invalidate Core 1" {
      style.stroke: "#ff0000"
      style.stroke-width: 4
      style.animated: true
      label: "❌ Ping!"
    }
    Core1.WriteTail -> Core0.ReadTail: "MESI: Invalidate Core 0" {
      style.stroke: "#ff0000"
      style.stroke-width: 4
      style.animated: true
      label: "❌ Pong!"
    }
  }

  Impact: "Performance Degradation" {
    style.fill: "#2d1b1b"
    LatencyBad: "Latency" {
      shape: rectangle
      style.fill: "#ff4444"
      label: |md
        **Inter-core Snoop:**
        200ns → 20μs
        (100x Degradation)
      |
    }
    CyclesBad: "Stalls" {
      shape: rectangle
      style.fill: "#ff4444"
      label: |md
        **Pipeline Stalls:**
        ~400 cycles per
        cache miss.
      |
    }
  }
}

# ============================================
# RIGHT SIDE: FIXED WITH ALIGNAS
# ============================================
FixedSharing: "✅ FIXED WITH alignas(64)" {
  direction: right
  style.stroke: "#44ff44"
  style.stroke-width: 4

  GoodLayout: "Memory Layout (ALIGNED)" {
    direction: down
    style.fill: "#1b2d1b"
    style.stroke: "#6bff6b"
    style.stroke-width: 2
    
    CacheLine0Good: "Cache Line 0 [Offset 0x00]" {
      direction: right
      style.fill: "#1a4a1a"
      style.stroke: "#44ff44"
      style.stroke-dash: 4
      
      ByteLayoutGood0: {
        grid-columns: 8
        grid-gap: 0
        g0_0: "0x00" { class: mem_data; label: "head\n8B" }
        g0_1: "0x08" { class: mem_padding; label: "pad\n56B" }
        g0_2: "0x10" { class: mem_padding; label: "..." }
        g0_3: "0x20" { class: mem_padding; label: "..." }
        g0_4: "0x30" { class: mem_padding; label: "..." }
        g0_5: "0x38" { class: mem_padding; label: "..." }
        g0_6: "0x3C" { class: mem_padding; label: "..." }
        g0_7: "0x3F" { class: mem_padding; label: "end" }
      }
      
      Owner0: |md
        **Core 0 Exclusive**
        Line stays in 'M' state.
      | { style.font-color: "#aaffaa" }
    }

    CacheLine1Good: "Cache Line 1 [Offset 0x40]" {
      direction: right
      style.fill: "#1a4a3a"
      style.stroke: "#44ffaa"
      style.stroke-dash: 4
      
      ByteLayoutGood1: {
        grid-columns: 8
        grid-gap: 0
        g1_0: "0x40" { class: mem_data; label: "tail\n8B" }
        g1_1: "0x48" { class: mem_padding; label: "pad\n56B" }
        g1_2: "0x50" { class: mem_padding; label: "..." }
        g1_3: "0x60" { class: mem_padding; label: "..." }
        g1_4: "0x70" { class: mem_padding; label: "..." }
        g1_5: "0x78" { class: mem_padding; label: "..." }
        g1_6: "0x7C" { class: mem_padding; label: "..." }
        g1_7: "0x7F" { class: mem_padding; label: "end" }
      }
      
      Owner1: |md
        **Core 1 Exclusive**
        No cross-core traffic.
      | { style.font-color: "#aaffaa" }
    }
  }

  NoContention: "Independent Ownership" {
    direction: down
    style.fill: "#1a2e1a"
    style.stroke: "#45e960"
    
    Core0Good: "Core 0" {
      class: core_producer
      WriteHeadGood: "Write head" { style.bold: true }
    }
    
    Core1Good: "Core 1" {
      class: core_consumer
      WriteTailGood: "Write tail" { style.bold: true }
    }

    CrossRead: "Zero Conflict" {
      shape: rectangle
      style.fill: "#2a5a2a"
      label: |md
        Each thread writes to its
        own cache line.
        **No hardware stalls.**
      |
    }
    
    Core0Good.WriteHeadGood -- Core1Good.WriteTailGood: "✅ Independent" {
      style.stroke: "#44ff44"
      style.stroke-width: 2
      style.stroke-dash: 5
      label: "No Contention"
    }
  }

  ImpactGood: "Performance Gain" {
    style.fill: "#1b2d1b"
    LatencyGood: "Latency" {
      shape: rectangle
      style.fill: "#44ff44"
      label: |md
        **L1 Latency:**
        ~1ns (4 cycles)
        Stable throughput.
      |
    }
  }
}

# ============================================
# CODE EXAMPLE
# ============================================
CodeExample: "Implementation Details" {
  direction: right
  style.fill: "#1a1a1a"
  style.stroke: "#888"
  
  Before: "❌ False Sharing" {
    shape: rectangle
    style.fill: "#2d1b1b"
    style.font: mono
    label: |cpp
      struct RingBuffer {
        atomic<uint64_t> head; // 0x00
        atomic<uint64_t> tail; // 0x08
      }; // Shared Cache Line!
    |
  }
  
  After: "✅ Properly Aligned" {
    shape: rectangle
    style.fill: "#1b2d1b"
    style.font: mono
    label: |cpp
      struct AlignedBuffer {
        alignas(64) atomic<uint64_t> head;
        // Offset 0x00 -> 0x3F
        alignas(64) atomic<uint64_t> tail;
        // Offset 0x40 -> 0x7F
      };
    |
  }
  
  Before -> After: "Optimization" {
    style.stroke: "#44ff44"
    style.stroke-width: 3
    style.animated: true
  }
}

# ============================================
# ROOT ANNOTATIONS
# ============================================
Legend: "MESI Cache Coherency States" {
  direction: right
  near: bottom-center
  style.fill: "#1a1a1a"
  style.stroke: "#666"
  M: "Modified" { style.fill: "#ff6b6b"; style.font-color: white }
  E: "Exclusive" { style.fill: "#ffaa00"; style.font-color: black }
  S: "Shared" { style.fill: "#6bff6b"; style.font-color: black }
  I: "Invalid" { style.fill: "#666"; style.font-color: white }
  M -- E -- S -- I
}

KeyInsight: |md
  ### 🔑 Implementation Rule
  Threads writing to high-frequency variables must have those variables 
  isolated to separate cache lines (typically **64 bytes**).
  Use `alignas(64)` in C++11, `__attribute__((aligned(64)))` in C, 
  or `@Contended` in Java (JVM dependent).
| {near: bottom-center; style.fill: "#2a2a3a"; style.stroke: "#6b8aff"}