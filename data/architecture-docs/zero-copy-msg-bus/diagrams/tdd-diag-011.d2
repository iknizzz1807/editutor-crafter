layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#5C9FE6"
    free: "#6BC97A"
    padding: "#A0A8B8"
    pointer: "#E8A855"
    changed: "#E85D5D"
  }
}

title: |md
  # Ring Buffer Memory Layout
  ### Power-of-2 Size Enables Bitmask Wraparound
  *Intel Manual Style Specification*
| {near: top-center}

direction: right

memory_layout: {
  label: "Shared Memory Region (sizeof=4096B Page)"
  style: {
    stroke-width: 4
    stroke: black
  }

  header_section: {
    label: "Header Section (256 bytes)"
    style.fill: "${colors.header}"
    
    cl0: "Cache Line 0 (0x00-0x3F)" {
      style.stroke-dash: 3
      head_field: "head: atomic<uint64>\nOffset: 0x00\n[Producer RW]" {
        style.fill: "#B8A4D9"
        style.bold: true
      }
      pad0: "padding[56B]\n(Prevents False Sharing)" {
        style.fill: "${colors.padding}"
        style.opacity: 0.6
      }
    }

    cl1: "Cache Line 1 (0x40-0x7F)" {
      style.stroke-dash: 3
      tail_field: "tail: atomic<uint64>\nOffset: 0x40\n[Consumer RW]" {
        style.fill: "#B8A4D9"
        style.bold: true
      }
      pad1: "padding[56B]\n(Prevents False Sharing)" {
        style.fill: "${colors.padding}"
        style.opacity: 0.6
      }
    }

    metadata: {
      label: "Metadata (0x80-0xBF)"
      style.fill: "${colors.header}"
      fields: |md
        - **num_slots**: 8 (uint64)
        - **slot_size**: 512 (uint64)
        - **mask**: 7 (0x07)
        - **seq_base**: 0x1000
      |
    }
  }

  slots_section: {
    label: "Circular Message Slots"
    
    slot_0: "Slot 0\n[DATA]" { style.fill: "${colors.data}" }
    slot_1: "Slot 1\n[FREE]" { style.fill: "${colors.free}" }
    slot_2: "Slot 2\n[DATA]" { style.fill: "${colors.data}" }
    slot_3: "Slot 3\n[FREE]" { style.fill: "${colors.free}" }
    slot_4: "Slot 4\n[DATA]" { style.fill: "${colors.data}" }
    slot_5: "Slot 5\n[FREE]" { style.fill: "${colors.free}" }
    slot_6: "Slot 6\n[DATA]" { style.fill: "${colors.data}" }
    slot_7: "Slot 7\n[RESERVED]" { 
      style.fill: "${colors.padding}"
      tooltip: "Invariant: Always keep 1 slot empty"
    }

    slot_0 -> slot_1 -> slot_2 -> slot_3 -> slot_4 -> slot_5 -> slot_6 -> slot_7 -> slot_0
  }

  header_section -> slots_section: "Physical Layout Map"
}

wraparound_logic: {
  label: "Wraparound Computation Analysis"
  
  modulo_approach: {
    label: "❌ Modulo (Slow)"
    style.fill: "#FFB4B4"
    code: |cpp
      // IDIV instruction
      // Latency: 20-80 cycles
      size_t idx = pos % buffer_size;
    |
  }

  bitmask_approach: {
    label: "✓ Bitmask (Fast)"
    style.fill: "#B4FFB4"
    code: |cpp
      // AND instruction
      // Latency: 1 cycle
      size_t idx = pos & (buffer_size - 1);
    |
  }

  modulo_approach -> bitmask_approach: "Optimization" {
    style.stroke-dash: 5
    target-arrowhead: triangle
  }
}

size_table: {
  label: "Power-of-2 Bitmask Reference"
  style.fill: "#F0F4F8"
  
  # Using || to safely wrap the markdown table containing pipe characters
  content: ||md
    | Slots | Mask (binary) | Mask (hex) | Invariant |
    |-------|---------------|------------|-----------|
    | 8     | `0b0111`      | `0x7`      | n-1       |
    | 16    | `0b1111`      | `0xF`      | n-1       |
    | 32    | `0b11111`     | `0x1F`     | n-1       |
    | 64    | `0b111111`    | `0x3F`     | n-1       |
    | 1024  | `0x3FF`       | `0x3FF`    | n-1       |
  ||
}

cycle_example: {
  label: "Algorithm State: Index Wraparound"
  
  step_1: {
    label: "State: Buffer Full (n-1)"
    head: "head = 7" { style.stroke: "${colors.pointer}"; style.stroke-width: 3 }
    tail: "tail = 0" { style.stroke: "${colors.pointer}"; style.stroke-width: 3 }
    desc: "Next write requires wraparound"
  }

  step_2: {
    label: "State: Post-Increment"
    head_calc: "head = (7 + 1) & 7" {
      style.fill: "${colors.changed}"
      style.bold: true
    }
    result: "head = 0" {
      style.fill: "${colors.free}"
      style.bold: true
    }
    head_calc -> result: "Bitwise AND"
  }

  step_1 -> step_2: "Producer Enqueue"
}

invariant_note: |md
  ### Critical Implementation Note
  **Key Invariant**: `(head + 1) & mask == tail` indicates a **FULL** buffer.
  A single slot must remain unallocated to distinguish between full and empty states when `head == tail`.
| {
  near: bottom-center
  style.stroke: orange
  style.fill: "#FFF9E6"
}

# Explicit connections for layout flow
memory_layout -> wraparound_logic
wraparound_logic -> cycle_example
size_table -> cycle_example