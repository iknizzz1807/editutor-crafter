vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |'md
# FlatBuffer Binary Wire Format
### Zero-Copy Memory Layout Implementation Spec
'| {
  near: top-center
  shape: text
}

# -----------------------------------------------------------------------------
# MEMORY REGIONS (PHYSICAL LAYOUT)
# -----------------------------------------------------------------------------

memory_buffer: "FlatBuffer Wire Data (Binary Buffer)" {
  style: {
    stroke: "#6B7280"
    stroke-width: 2
    fill: "#F9FAFB"
  }

  # Offset 0: Root Pointer (Purple/Orange - Header/Pointer)
  header: "0x00 | Root Offset Header | 4B" {
    label: |'md
      ### 0x00: Root Pointer
      `uint32_t soffset_to_root`
      *(Signed offset from current position)*
      **Value: 0x0000000C**
    '|
    style.fill: "#E8D5E8"
    style.stroke: "#EA580C"
    style.stroke-width: 4
  }

  # VTable Section (Purple - Metadata)
  vtable_block: "0x04 | VTable (TradeOrder Schema) | 12B" {
    vtable_data: |'md
      **Physical Layout: VTable**
      ───────────────────────
      `+0`  uint16 v_size: 12
      `+2`  uint16 t_size: 24
      `+4`  uint16 f_sym:  16
      `+6`  uint16 f_prc:  8
      `+8`  uint16 f_qty:  4
      `+10` uint16 f_ts:   0
    '|
    style.fill: "#E8D5E8"
    style.stroke: "#8B5CF6"
    style.stroke-width: 2
    style.double-border: true
  }

  # Table Data Section (Blue - Data)
  table_block: "0x10 | Table Instance (TradeOrder) | 24B" {
    table_data: |'md
      **Physical Layout: Object Data**
      ──────────────────────────
      `+0`  int32 voffset: -12
      `+4`  int32 quantity: 100
      `+8`  double price: 150.25
      `+16` uint32 sym_ptr: 28
    '|
    style.fill: "#CCE5FF"
    style.stroke: "#007BFF"
    style.stroke-width: 2
  }

  # Data Heap Section (Green - Variable Length)
  heap_block: "0x28 | Heap (String Allocation) | 9B" {
    string_data: |'md
      **Physical Layout: AAPL**
      ─────────────────────────
      `+0` uint32 length: 4
      `+4` char[5] data: "AAPL\0"
    '|
    style.fill: "#D4EDDA"
    style.stroke: "#28A745"
    style.stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# DETAILED BYTE OFFSETS (IMPLEMENTATION VIEW)
# -----------------------------------------------------------------------------

byte_spec: {
  label: |'md
    ## Physical Byte Layout Map
    | Offset | Size | Field | Physical Value | Alignment |
    | :--- | :--- | :--- | :--- | :--- |
    | **0x00** | 4 | `root_offset` | 0x0000000C | 4-byte |
    | **0x04** | 2 | `vtable_size` | 0x000C | 2-byte |
    | **0x06** | 2 | `object_size` | 0x0018 | 2-byte |
    | **0x08** | 2 | `offset_sym` | 0x0010 (16) | 2-byte |
    | **0x0A** | 2 | `offset_prc` | 0x0008 (8) | 2-byte |
    | **0x0C** | 4 | `vtable_ptr` | 0xFFFFFFF4 (-12) | 4-byte |
    | **0x10** | 4 | `quantity` | 0x00000064 (100) | 4-byte |
    | **0x14** | 8 | `price` | 0x4062C80000000000 | 8-byte |
    | **0x1C** | 4 | `symbol_ptr` | 0x0000001C (28) | 4-byte |
    | **0x20** | 4 | `str_len` | 0x00000004 | 4-byte |
    | **0x24** | 5 | `str_data` | "AAPL\0" | 1-byte |
  '|
  shape: rectangle
  style: {
    fill: white
    stroke: "#1F2937"
    font-size: 14
  }
}

# -----------------------------------------------------------------------------
# LEGEND & LOGIC
# -----------------------------------------------------------------------------

logic_legend: {
  label: |'md
    ### FlatBuffer Logic Rules
    1. **VTable**: Precedes the table in serial sequence. Multiple tables can share the same VTable.
    2. **Offsets**: Most offsets are relative to the location of the pointer itself.
    3. **Alignment**: Fields padded to natural power-of-two (doubles on 8-byte boundaries).
    4. **Absence**: Missing fields in VTable (offset 0) use schema defaults.
  '|
  style: {
    fill: "#FEFCE8"
    stroke: "#EAB308"
    border-radius: 8
  }
}

# -----------------------------------------------------------------------------
# POINTER RELATIONSHIPS
# -----------------------------------------------------------------------------

# Table to VTable link
memory_buffer.table_block -> memory_buffer.vtable_block: "voffset (-12)" {
  style: {
    stroke: "#8B5CF6"
    stroke-width: 3
    stroke-dash: 5
  }
}

# Table to String (Heap) link
memory_buffer.table_block -> memory_buffer.heap_block: "symbol_off (relative 28)" {
  style: {
    stroke: "#28A745"
    stroke-width: 3
    stroke-dash: 5
  }
}

# Root link
memory_buffer.header -> memory_buffer.table_block: "Initial Root Access" {
  style: {
    stroke: "#EA580C"
    stroke-width: 4
  }
}

# Annotations (FIXED: ELK doesn't support relative near)
growth_marker: |'md
  **Memory Construction Order**
  1. Strings/Vectors (Down)
  2. VTables
  3. Tables
  4. Root Header
'| {
  shape: text
  style.font-color: "#4B5563"
  near: top-right
}

# Boundary Annotations
cache_line_marker: "---- 64B Cache Line Boundary ----" {
  shape: text
  style: {
    font-color: gray
    stroke-dash: 5
  }
  near: bottom-center
}