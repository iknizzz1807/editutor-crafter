direction: right
layout-engine: elk

vars: {
  d2-config: {
    theme-id: 4
    sketch: false
    pad: 20
  }
  colors: {
    header: "#6B5B95"
    data: "#BBDEFB"
    not_present: "#FFCDD2"
    pointer: "#FF9800"
    padding: "#E0E0E0"
    text_inv: "#FFFFFF"
    border: "#455A64"
  }
}

title: |md
  # VTable Structure & Memory Layout
  ## Zero-Copy Binary Field Offset Resolution (FlatBuffers Style)
| {near: top-center}

# ------------------------------------------------------------------------------------------
# VTABLE MEMORY BLOCK (Header + Field Offsets)
# ------------------------------------------------------------------------------------------
VTable_Memory: {
  label: "VTable Layout (Metadata @ Offset -12)"
  style: {
    fill: "#F3F0F7"
    stroke: "${colors.header}"
    stroke-width: 2
  }

  header_v: "VTable Start (Absolute Offset)" {
    style: {
      fill: "${colors.header}"
      font-color: "${colors.text_inv}"
      bold: true
    }
  }

  v_size: "00B | vtable_size (uint16) | 2B" {
    style.fill: "#D1C4E9"
    tooltip: "Total size of this vtable header (2B size + 2B table_size + N*2B offsets)"
  }
  t_size: "02B | table_size (uint16) | 2B" {
    style.fill: "#D1C4E9"
    tooltip: "Size of the actual data table including the vtable pointer preamble"
  }

  f_offset_0: "04B | offset[0]: 16 | 2B" {
    style.fill: "${colors.data}"
    style.stroke: "${colors.border}"
  }
  f_offset_1: "06B | offset[1]: 8 | 2B" {
    style.fill: "${colors.data}"
    style.stroke: "${colors.border}"
  }
  f_offset_2: "08B | offset[2]: 4 | 2B" {
    style.fill: "${colors.data}"
    style.stroke: "${colors.border}"
  }
  f_offset_3: "10B | offset[3]: 0 | 2B" {
    style.fill: "${colors.not_present}"
    style.stroke: red
    style.stroke-dash: 2
  }

  header_v -> v_size -> t_size -> f_offset_0 -> f_offset_1 -> f_offset_2 -> f_offset_3
}

# ------------------------------------------------------------------------------------------
# DATA TABLE MEMORY BLOCK (Object Data)
# ------------------------------------------------------------------------------------------
Table_Data_Layout: {
  label: "Object Data Memory (Table Start @ 0x00)"
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
    stroke-width: 2
  }

  preamble: "-04B | soffset: -12 (vtable_ptr) | 4B" {
    style: {
      fill: "${colors.pointer}"
      font-color: "${colors.text_inv}"
      bold: true
    }
  }

  table_root: "Table Root (0x00)" {
    shape: circle
    width: 25
    height: 25
    style.fill: black
  }

  field_2: "04B | quantity (int32) | 4B" {
    style.fill: "${colors.data}"
    style.stroke: "${colors.border}"
  }

  field_1: "08B | price (float64) | 8B" {
    style.fill: "${colors.data}"
    style.stroke: "${colors.border}"
  }

  field_0: "16B | symbol (string_offset) | 4B" {
    style.fill: "${colors.data}"
    style.stroke: "${colors.border}"
  }

  padding: "20B | alignment padding | 4B" {
    style.fill: "${colors.padding}"
    style.stroke-dash: 3
    style.stroke: "#9E9E9E"
  }

  preamble -> table_root -> field_2 -> field_1 -> field_0 -> padding
}

# ------------------------------------------------------------------------------------------
# RESOLUTION LOGIC MAP
# ------------------------------------------------------------------------------------------
Resolution_Map: {
  shape: sql_table
  style.fill: "#F1F8E9"
  style.stroke: "#558B2F"
  
  Field_ID: "uint16 {constraint: PK}"
  Name: "string"
  Offset_Value: "uint16"
  Status: "string"

  row_0: "0 | 'symbol' | 16 | PRESENT"
  row_1: "1 | 'price' | 8 | PRESENT"
  row_2: "2 | 'quantity' | 4 | PRESENT"
  row_3: "3 | 'timestamp' | 0 | NOT_PRESENT"
}

# ------------------------------------------------------------------------------------------
# CONNECTIONS & INTER-BLOCK MAPPING
# ------------------------------------------------------------------------------------------

# Preamble points to VTable Start
Table_Data_Layout.preamble -> VTable_Memory.header_v: "vtable_ptr = cur_pos - 12" {
  style: {
    stroke: "${colors.pointer}"
    stroke-width: 4
    animated: true
  }
}

# Offset mapping to data locations
VTable_Memory.f_offset_0 -> Table_Data_Layout.field_0: "Relative Offset 16" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 4
}
VTable_Memory.f_offset_1 -> Table_Data_Layout.field_1: "Relative Offset 8" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 4
}
VTable_Memory.f_offset_2 -> Table_Data_Layout.field_2: "Relative Offset 4" {
  style.stroke: "#2E7D32"
  style.stroke-width: 2
  style.stroke-dash: 4
}

# Algorithm Annotation
Access_Logic: {
  near: bottom-center
  label: "O(1) Access Resolution Algorithm"
  content: |md
    ### Field Lookup Pipeline:
    1. **VTable Discovery**: Read `int32` at `table_ptr - 4` to find VTable start.
    2. **Bound Check**: If `field_id * 2 + 4 >= vtable_size`, return default (Null).
    3. **Offset Retrieval**: Read `uint16` at `vtable_ptr + 4 + (field_id * 2)`.
    4. **Existence Check**: If `offset == 0`, field is not encoded (use schema default).
    5. **Data Reference**: Data exists at `table_ptr + offset`.
  |
  style: {
    fill: "#FFFDE7"
    stroke: "#FBC02D"
    font-size: 14
  }
}

# Memory Invariants Block
Invariants: {
  near: center-right
  label: "Memory Invariants & Alignment"
  shape: package
  style.fill: "#FAFAFA"
  style.stroke: "#455A64"
  
  inv1: "1. Byte Alignment: Data fields aligned to natural size (float64 to 8B)."
  inv2: "2. Schema Evolution: Append-only field IDs ensure VTable compatibility."
  inv3: "3. Compactness: VTables are shared across identical object instances."
  inv4: "4. Endianness: Little-Endian standard for cross-platform portability."
}

# High-level Structural Flow
Resolution_Map -> VTable_Memory: "Schema Definition"
VTable_Memory -> Table_Data_Layout: "Runtime Indexing"
Table_Data_Layout -> Access_Logic: "Memory Access"

# Highlighting specific error state
Resolution_Map.row_3.style.font-color: red
VTable_Memory.f_offset_3.style.stroke-width: 3