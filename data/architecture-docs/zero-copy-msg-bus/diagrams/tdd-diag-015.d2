direction: right

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 40
  }
  colors: {
    schema: "#9B59B6"
    ast: "#3498DB"
    layout: "#1ABC9C"
    codegen: "#E67E22"
    cpp: "#2ECC71"
    arrow: "#7F8C8D"
    padding: "#BDC3C7"
  }
}

title: |md
  # Zero-Copy Serialization Data Flow
  ### Pipeline for FlatBuffer Schema to C++ Runtime
| {
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

classes: {
  process_node: {
    style: {
      fill: white
      stroke: "${colors.arrow}"
      stroke-width: 2
      font-size: 14
      border-radius: 4
    }
  }
  data_flow: {
    style: {
      stroke: "${colors.arrow}"
      stroke-width: 2
      animated: true
    }
  }
  label_box: {
    style: {
      fill: "${colors.schema}"
      stroke: transparent
      font-color: white
      font-size: 10
      border-radius: 2
    }
  }
  hex_cell: {
    style: {
      font-size: 10
      font: mono
      text-transform: uppercase
      stroke-width: 1
    }
  }
}

// === INPUT: Schema Definition ===
Schema_File: "trading.fbs" {
  class: process_node
  shape: rectangle
  style.fill: "${colors.schema}"
  style.font-color: white
  
  label_box: "INPUT SOURCE" {
    class: label_box
  }
  
  content: |md
    fbs
    table Order {
      id: uint64;
      px: double;
      qty: int32;
    }
    
  |
}

// === PHASE 1: Parsing ===
Schema_Parser: "SchemaParser\n(Lexer/Parser)" {
  class: process_node
  shape: hexagon
  style.fill: "${colors.ast}"
  style.font-color: white
}

Schema_File -> Schema_Parser: "parse()" {
  class: data_flow
  tooltip: "Converts raw text to internal representation"
}

// === PHASE 2: AST (Intermediate) ===
Schema_AST: "Schema AST\nIntermediate Representation" {
  class: process_node
  shape: rectangle
  style.fill: "${colors.ast}"
  style.font-color: white
  style.stroke-dash: 3
  
  details: {
    TableDef: "Order"
    Fields: "id (U64), px (F64), qty (I32)"
    Attributes: "force_align: 8"
  }
}

Schema_Parser -> Schema_AST: "produces" {class: data_flow}

// === PHASE 3: Layout Calculation ===
Layout_Calculator: "LayoutCalculator\n(Alignment Logic)" {
  class: process_node
  shape: hexagon
  style.fill: "${colors.layout}"
  style.font-color: white
}

Schema_AST -> Layout_Calculator: "process tables" {class: data_flow}

// === PHASE 4: Layout Output ===
Field_Offsets: "vTable & Field Offsets" {
  class: process_node
  shape: rectangle
  style.fill: "${colors.layout}"
  style.font-color: white
  style.stroke-dash: 3
  
  layout_table: {
    shape: sql_table
    id: "uint64" {constraint: "offset: 4"}
    px: "double" {constraint: "offset: 12"}
    qty: "int32" {constraint: "offset: 20"}
  }
}

Layout_Calculator -> Field_Offsets: "compute" {class: data_flow}

// === PHASE 5: Code Generation ===
Code_Generator: "CodeGenerator\n(Jinja2/Emitters)" {
  class: process_node
  shape: hexagon
  style.fill: "${colors.codegen}"
  style.font-color: white
}

Field_Offsets -> Code_Generator: "use layout" {class: data_flow}

// === OUTPUT: Generated C++ Headers ===
Generated_Headers: "Generated C++ Headers\n(trade_order.fbs.h)" {
  class: process_node
  shape: rectangle
  style.fill: "${colors.cpp}"
  style.font-color: white
  
  label_box2: "OUTPUT ARTIFACT" {
    class: label_box
    style.fill: "${colors.cpp}"
  }
  
  snippet: |cpp
    struct Order : private Table {
      uint64_t id() { return GetField<uint64_t>(4, 0); }
      double px() { return GetField<double>(12, 0.0); }
    };
  |
}

Code_Generator -> Generated_Headers: "emit code" {class: data_flow}

// === RUNTIME PATH ===
Runtime_Application: "High-Frequency\nTrading App" {
  class: process_node
  shape: rectangle
  style.fill: "${colors.cpp}"
  style.font-color: white
  style.opacity: 0.8
}

Generated_Headers -> Runtime_Application: "#include" {
  style.stroke-dash: 5
  style.stroke: "${colors.cpp}"
  style.animated: false
}

// === FLAT BUFFER MEMORY LAYOUT ===
FlatBuffer_Data: "Buffer Memory Layout (Zero-Copy Window)" {
  style.fill: "#FDFEFE"
  style.stroke: "${colors.arrow}"
  style.stroke-width: 1
  
  grid: {
    grid-columns: 8
    grid-gap: 0
    
    // Header
    h0: "Offset" {style.bold: true; style.fill: "${colors.padding}"}
    h1: "+0" {style.bold: true; style.fill: "${colors.padding}"}
    h2: "+1" {style.bold: true; style.fill: "${colors.padding}"}
    h3: "+2" {style.bold: true; style.fill: "${colors.padding}"}
    h4: "+3" {style.bold: true; style.fill: "${colors.padding}"}
    h5: "+4" {style.bold: true; style.fill: "${colors.padding}"}
    h6: "+5" {style.bold: true; style.fill: "${colors.padding}"}
    h7: "+6" {style.bold: true; style.fill: "${colors.padding}"}
    
    // Row 1
    r0: "0x00" {class: hex_cell}
    r1: "VTable" {grid-columns: 4; style.fill: "#D5F5E3"}
    r2: "ID (Low)" {grid-columns: 3; style.fill: "#D6EAF8"}
    
    // Row 2
    r3: "0x08" {class: hex_cell}
    r4: "ID (High)" {grid-columns: 1; style.fill: "#D6EAF8"}
    r5: "Price (F64)" {grid-columns: 6; style.fill: "#FCF3CF"}
  }
}

Runtime_Application <-> FlatBuffer_Data: "Direct mmap access" {
  style.stroke: "${colors.cpp}"
  style.stroke-width: 3
  target-arrowhead: diamond
  source-arrowhead: diamond
}

// === LEGEND ===
legend: {
  near: bottom-right
  shape: rectangle
  style.fill: white
  style.stroke: "${colors.arrow}"
  style.stroke-width: 1
  
  leg_title: "Pipeline Legend" {
    shape: text
    style.font-size: 12
    style.bold: true
  }
  
  item1: "Schema Input" {
    shape: rectangle
    style.fill: "${colors.schema}"
    style.font-color: white
    style.font-size: 10
  }
  item2: "AST / Parser" {
    shape: rectangle
    style.fill: "${colors.ast}"
    style.font-color: white
    style.font-size: 10
  }
  item3: "Layout Computing" {
    shape: rectangle
    style.fill: "${colors.layout}"
    style.font-color: white
    style.font-size: 10
  }
  item4: "Code Generation" {
    shape: rectangle
    style.fill: "${colors.codegen}"
    style.font-color: white
    style.font-size: 10
  }
  item5: "C++ Runtime Artifact" {
    shape: rectangle
    style.fill: "${colors.cpp}"
    style.font-color: white
    style.font-size: 10
  }
}

// Global Glob for connecting all pipeline stages specifically
(Schema_File -> Schema_Parser -> Schema_AST -> Layout_Calculator -> Field_Offsets -> Code_Generator -> Generated_Headers)[*]: {
  style.stroke: "${colors.arrow}"
}