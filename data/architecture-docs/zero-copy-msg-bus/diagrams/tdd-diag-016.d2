vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Field Access Algorithm
  **Technical Specification: Zero-copy Field Resolution**
  *This diagram details the logic for resolving field addresses within a flat-buffer structure.*
| {near: top-center}

direction: right

# --- ALGORITHM STEPS ---

step1: {
  label: "1. Load VTable Offset"
  shape: rectangle
  style.fill: "#E8D5F2"
  style.stroke: "#7B2D8E"
  style.stroke-width: 2
  code1: |md
    cpp
    // Offset is at the start of the table instance
    const int32_t soffset = 
      *reinterpret_cast<const int32_t*>(table_start_);
    
  |
}

step2: {
  label: "2. Compute VTable Address"
  shape: rectangle
  style.fill: "#E8D5F2"
  style.stroke: "#7B2D8E"
  style.stroke-width: 2
  code2: |md
    cpp
    // soffset is negative, VTable resides before Table
    const VTable* vtable = 
      reinterpret_cast<const VTable*>(table_start_ + soffset);
    
  |
}

step3: {
  label: "3. Load Field Offset"
  shape: rectangle
  style.fill: "#E8D5F2"
  style.stroke: "#7B2D8E"
  style.stroke-width: 2
  code3: |md
    cpp
    // field_id indexes into the vtable's offset array
    uint16_t offset = vtable->field_offsets[field_id];
    
  |
}

step4: {
  label: "4. Check Presence"
  shape: diamond
  style.fill: "#FFE4B5"
  style.stroke: "#D2691E"
  style.stroke-width: 3
  width: 220
  height: 120
  check: |md
    cpp
    // If offset is 0, field is absent
    if (offset == 0) {
      return default_value;
    }
    
  |
}

step5: {
  label: "5. Compute Field Address"
  shape: rectangle
  style.fill: "#E8D5F2"
  style.stroke: "#7B2D8E"
  style.stroke-width: 2
  code5: |md
    cpp
    // Final pointer: base address + positive offset
    const uint8_t* field_ptr = table_start_ + offset;
    
  |
}

step6: {
  label: "6. Load Typed Value"
  shape: rectangle
  style.fill: "#C8E6C9"
  style.stroke: "#388E3C"
  style.bold: true
  style.stroke-width: 4
  code6: |md
    cpp
    T value;
    std::memcpy(&value, field_ptr, sizeof(T));
    return value;
    
  |
}

default_return: {
  label: "Return Default Value"
  shape: rectangle
  style.fill: "#FFCDD2"
  style.stroke: "#C62828"
  style.stroke-dash: 5
  default_code: |md
    cpp
    // Fallback for schema evolution
    return default_value;
    
  |
}

# --- CONNECTIONS ---

step1 -> step2: "soffset (int32)" {
  style.stroke: "#7B2D8E"
}
step2 -> step3: "vtable*" {
  style.stroke: "#7B2D8E"
}
step3 -> step4: "offset (uint16)" {
  style.stroke: "#7B2D8E"
}

step4 -> step5: "TRUE (offset > 0)" {
  style.stroke: "#388E3C"
  style.bold: true
  style.font-color: "#388E3C"
}

step4 -> default_return: "FALSE (offset == 0)" {
  style.stroke: "#C62828"
  style.stroke-dash: 3
  style.font-color: "#C62828"
}

step5 -> step6: "field_ptr" {
  style.stroke: "#388E3C"
  style.animated: true
}

# --- MEMORY LAYOUT REFERENCE ---

memory_layout: {
  label: "Memory Layout Reference (Byte-Level)"
  style.fill: "#FDFDFD"
  style.stroke: "#9E9E9E"
  style.stroke-width: 2

  buffer_viz: {
    direction: right
    
    vtable: "VTable Region" {
      style.fill: "#E8D5F2"
      style.stroke-dash: 3
      width: 150
      height: 80
    }
    
    gap: "Unrelated Data / Padding" {
      shape: text
      width: 150
      style.font-color: "#9E9E9E"
      style.italic: true
    }
    
    table_start_ptr: "table_start_" {
      shape: circle
      width: 20
      style.fill: "#FFA500"
    }
    
    table_data: "Table Data Region" {
      style.fill: "#BBDEFB"
      width: 250
      height: 80
    }
    
    vtable <- table_start_ptr: "soffset (-ve)" {
      style.stroke: "#7B2D8E"
      source-arrowhead: triangle
    }
    
    table_start_ptr -> table_data: "offset (+ve)" {
      style.stroke: "#D2691E"
    }
  }

  layout_note: |md
    ### Memory Constraints
    - **VTable**: Pre-computed metadata stored before the data. Contains field offsets.
    - **soffset**: 4-byte signed integer at `table_start_`. Points back to VTable.
    - **field_ptr**: `table_start_` + `offset` (always non-negative).
    - **Alignment**: Fields are typically aligned to their natural width (2/4/8 bytes).
  |
}

memory_layout.near: bottom-center

# --- LEGEND ---

legend: {
  label: "Key"
  purple_box: "Ptr Operation" {
    shape: rectangle
    style.fill: "#E8D5F2"
  }
  orange_dia: "Branch / Check" {
    shape: diamond
    style.fill: "#FFE4B5"
  }
  green_box: "Success / Load" {
    shape: rectangle
    style.fill: "#C8E6C9"
  }
  red_box: "Default / Error" {
    shape: rectangle
    style.fill: "#FFCDD2"
  }
}
legend.near: bottom-right

# --- PERFORMANCE NOTES ---

assembly_note: |md
  ### Optimized Assembly (x86-64)
  asm
  ; rdi = table_start_
  ; esi = field_id
  movsxd  rax, dword ptr [rdi]         ; 1. Load soffset (signed extend)
  lea     rcx, [rdi + rax]             ; 2. Compute vtable addr
  movzx   eax, word ptr [rcx + rsi*2]  ; 3. Load uint16 field offset
  test    ax, ax                       ; 4. Check if offset is zero
  je      .return_default
  add     rdi, rax                     ; 5. Final field_ptr
  mov     eax, [rdi]                   ; 6. Actual value load
  ret
  .return_default:
  mov     eax, [rdx]                   ; Load fallback default
  ret
  
| {near: bottom-left}

# --- GLOBAL STYLING ---
***.style.font: mono
***.style.border-radius: 4