vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
    pad: 30
  }
}

# -----------------------------------------------------------------------------
# GLOBAL CLASSES (Root Scope Fix)
# -----------------------------------------------------------------------------
classes: {
  offset_marker: {
    style: {
      font: mono
      font-size: 14
      stroke-width: 1
      fill: "#ECEFF1"
      stroke: "#B0BEC5"
      text-transform: uppercase
    }
  }
  header_field: {
    style: {
      fill: "#7E57C2" # Purple per spec
      font-color: white
      bold: true
      stroke: "#4A148C"
      stroke-width: 2
    }
  }
  data_field: {
    style: {
      fill: "#1E88E5" # Blue per spec
      font-color: white
      stroke: "#0D47A1"
      stroke-width: 2
    }
  }
  meta_label: {
    style: {
      font: mono
      font-size: 12
      fill: "#F5F5F5"
      stroke: "#B0BEC5"
      stroke-dash: 3
    }
  }
  intel_container: {
    style: {
      stroke-width: 2
      border-radius: 4
      fill: white
      shadow: true
    }
  }
}

title: ||md
  # Vector Memory Access Pattern
  **Zero-copy layout with direct element indexing**
  *Intel® 64 and IA-32 Architectures Optimization Reference Manual Style*
|| {
  near: top-center
  style: {
    stroke-width: 0
    font-size: 20
    bold: true
  }
}

# -----------------------------------------------------------------------------
# PHYSICAL MEMORY VIEW
# -----------------------------------------------------------------------------
memory_view: {
  label: "Linear Address Space Layout"
  class: intel_container
  grid-columns: 3
  grid-gap: 0

  # Header Row
  h1: "BYTE OFFSET" { style.bold: true; style.fill: "#CFD8DC"; style.stroke-width: 1 }
  h2: "FIELD / VALUE" { style.bold: true; style.fill: "#CFD8DC"; style.stroke-width: 1 }
  h3: "FIELD SIZE" { style.bold: true; style.fill: "#CFD8DC"; style.stroke-width: 1 }

  # Length Prefix (Header)
  row1_off: "0x00" { class: offset_marker }
  row1_val: "uint32_t element_count" { class: header_field }
  row1_size: "4 Bytes" { class: meta_label }

  # Element 0
  row2_off: "0x04" { class: offset_marker }
  row2_val: "Element[0]" { class: data_field }
  row2_size: "sizeof(T)" { class: meta_label }

  # Element 1
  row3_off: "0x04 + S" { class: offset_marker }
  row3_val: "Element[1]" { class: data_field }
  row3_size: "sizeof(T)" { class: meta_label }

  # Boundary Indicator
  row_cache_line: "---" { style.stroke-dash: 5; style.fill: "#FAFAFA" }
  row_cache_text: "L1 Cache Line Boundary (64B)" { style.italic: true; style.font-size: 10; style.stroke-dash: 5 }
  row_cache_gap: "---" { style.stroke-dash: 5; style.fill: "#FAFAFA" }

  # Element 2
  row4_off: "0x04 + 2S" { class: offset_marker }
  row4_val: "Element[2]" { class: data_field }
  row4_size: "sizeof(T)" { class: meta_label }

  # Ellipsis
  row5_off: "..." { class: offset_marker }
  row5_val: "..." { style.fill: white; style.stroke-dash: 2 }
  row5_size: "..." { class: meta_label }

  # Element N
  row6_off: "0x04 + (n*S)" { class: offset_marker }
  row6_val: "Element[n]" { class: data_field }
  row6_size: "sizeof(T)" { class: meta_label }
}

# -----------------------------------------------------------------------------
# ADDRESS COMPUTATION LOGIC
# -----------------------------------------------------------------------------
arithmetic_logic: {
  label: "Effective Address Computation"
  class: intel_container
  
  logic_md: |md
    ### Address Calculation Pipeline
    asm
    ; Calculate EA for Element[i]
    ; Base Pointer in RAX
    ; Index in RCX
    ; Element Size (S) as immediate

    MOV EBX, [RAX]          ; Fetch element_count (Offset 0)
    ADD RAX, 4              ; Skip header to reach Element[0]
    IMUL RCX, S             ; Scale index by sizeof(T)
    LEA RDI, [RAX + RCX]    ; Final Effective Address
    
    **Base Formula:**
    $EA = Base + 4 + (Index \times sizeof(T))$
  |
  style.fill: "#FFF9C4"
}

# -----------------------------------------------------------------------------
# ARCHITECTURAL CONSTRAINTS
# -----------------------------------------------------------------------------
technical_spec_grid: {
  grid-columns: 2
  grid-gap: 20

  complexity_box: {
    label: ||md
      ### Performance Attributes
      - **Access Time**: $O(1)$ constant time
      - **Instruction Count**: ~4 cycles (L1 hit)
      - **Memory Overhead**: 4 bytes fixed prefix
      - **Prefetchability**: High (Hardware prefetcher compatible)
    ||
    style: {
      fill: "#E1F5FE"
      stroke: "#0288D1"
    }
  }

  alignment_box: {
    label: ||md
      ### Memory Alignment (SIMD)
      - **Padding**: Gray (Required for AVX-512)
      - **Page Boundary**: 4096B (Dashed Bold)
      - **Direct Addressing**: Pointer offset only
      - **Cache Line Utilization**: $100\%$ (Contiguous)
    ||
    style: {
      fill: "#E8F5E9"
      stroke: "#2E7D32"
    }
  }
}

# -----------------------------------------------------------------------------
# TYPE SCALING EXAMPLES
# -----------------------------------------------------------------------------
examples_table: {
  label: ||md
    ### Scale Table (S)
    | Type (T) | Byte Width (S) | Element[1] Offset | Element[10] Offset |
    | :--- | :--- | :--- | :--- |
    | **int32** | 4 | 0x08 | 0x2C |
    | **float64** | 8 | 0x0C | 0x54 |
    | **__m256** | 32 | 0x24 | 0x144 |
  ||
  style: {
    fill: "#FCE4EC"
    stroke: "#C2185B"
  }
}

# -----------------------------------------------------------------------------
# CONNECTIONS & ANNOTATIONS
# -----------------------------------------------------------------------------
memory_view.row2_val -> arithmetic_logic: "Direct Index" {
  style: {
    stroke: "#FF9800" # Orange Pointer
    stroke-width: 2
    animated: true
  }
}

arithmetic_logic -> technical_spec_grid: "Perf Constraints"
technical_spec_grid -> examples_table: "Scaling Validation"

# Footer Summary
foot_note: "Total Allocation Size = 4 + (n * sizeof(T))" {
  shape: text
  style: {
    font: mono
    font-size: 18
    bold: true
    font-color: "#37474F"
  }
}

examples_table -> foot_note: "Size Check"