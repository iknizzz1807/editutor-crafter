direction: right
layout-engine: elk

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header_purple: "#d7bde2"
    data_blue: "#85c1e9"
    padding_gray: "#d5dbdb"
    pointer_orange: "#f39c12"
    highlight_red: "#e74c3c"
  }
}

title: {
  label: |md
    # ALIGNMENT CALCULATOR & MEMORY LAYOUT
    **Intel® Architecture Manual Field Offset Assignment & Data Structure Packing**
  |
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# -----------------------------------------------------------------------------
# 1. ALGORITHM DEFINITION (Logic Flow)
# -----------------------------------------------------------------------------

algorithm_steps: "Field Placement Algorithm (TDD-020)" {
  style: {
    fill: "#f8f9fa"
    stroke: "#333333"
    stroke-width: 2
  }

  step1: "01. Initialize" {
    shape: rectangle
    style.fill: "#e8e8e8"
    label: |md
      **Input State**
      - `max_align` = 1
      - `curr_off` = **4** (Start after 32-bit msg_id)
      - `queue` = SortByAlignDesc(price, ts, qty, sym)
    |
  }

  step2: "02. Alignment Loop" {
    style.fill: "#d4e6f1"
    
    align_logic: "Align Cursor" {
      label: |md
        `f = queue.pop()`
        `aligned = (curr_off + (f.align - 1)) & ~(f.align - 1)`
        `padding = aligned - curr_off`
      |
      style.fill: "#aed6f1"
    }

    assign_logic: "Assign Offset" {
      label: |md
        `field.offset = aligned`
        `curr_off = aligned + field.size`
        `max_align = max(max_align, f.align)`
      |
      style.fill: "#aed6f1"
    }

    align_logic -> assign_logic: "Next Field"
  }

  step3: "03. Tail Padding" {
    style.fill: "#d5f5e3"
    label: |md
      **Finalize Structure**
      `total_size = (curr_off + (max_align - 1)) & ~(max_align - 1)`
    |
  }

  step1 -> step2.align_logic: "Sorted Queue"
  step2.assign_logic -> step3: "End of Fields"
}

# -----------------------------------------------------------------------------
# 2. EXECUTION TRACE
# -----------------------------------------------------------------------------

trace_container: "Execution Trace: TradeOrder Struct" {
  grid-columns: 1
  grid-gap: 20
  style.fill: "#fdfefe"

  trace_table: {
    grid-rows: 6
    grid-gap: 0
    style.stroke: "#2c3e50"

    h: {
      label: "| Step | Field Name | Align | Size | Calculation | Result Offset |"
      style: { bold: true; fill: "#2c3e50"; font-color: white }
    }
    r1: { label: "| 1 | **price** | 8 | 8 | `align(4, 8)` | **8** |" }
    r2: { label: "| 2 | **timestamp** | 8 | 8 | `align(16, 8)` | **16** |" }
    r3: { label: "| 3 | **quantity** | 4 | 4 | `align(24, 4)` | **24** |" }
    r4: { label: "| 4 | **symbol_off**| 4 | 4 | `align(28, 4)` | **28** |" }
    f: {
      label: "**Final Structure Result:** Size: 32 Bytes | Max Align: 8"
      style: { bold: true; fill: "#d5f5e3" }
    }
  }

  state_v1: "State Post-Assignment (Field: Price)" {
    label: |md
      `curr_off`: <span style="color:red">**16**</span>
      `max_align`: <span style="color:red">**8**</span>
      `padding_total`: <span style="color:red">**4**</span>
    |
    style.stroke: red
    style.stroke-width: 2
  }
}

# -----------------------------------------------------------------------------
# 3. MEMORY LAYOUT (INTEL MANUAL GRADE)
# -----------------------------------------------------------------------------

memory_layout: "Physical Memory Layout: TradeOrder (sizeof=32B)" {
  style.fill: white
  style.stroke: black
  style.stroke-width: 3

  container: {
    direction: right
    grid-gap: 0

    # Left Margin: Offsets
    offsets: {
      grid-columns: 1
      grid-gap: 0
      t0: "0x00"; t4: "0x04"; t8: "0x08"; t16: "0x10"; t24: "0x18"; t28: "0x1C"; t32: "0x20"
      *.shape: text
      *.style.font-size: 14
      *.style.font: mono
      *.style.bold: true
    }

    # Center: Memory Blocks
    bytes: {
      grid-columns: 1
      grid-gap: 0
      
      header: "Message Header (msg_id)" {
        style.fill: ${colors.header_purple}
        height: 40; width: 400
        tooltip: "4 Bytes: Msg Type + Protocol Version"
      }
      
      pad1: "ALIGNMENT PADDING" {
        style.fill: ${colors.padding_gray}
        style.stroke-dash: 3
        height: 40; width: 400
        label: "INTERNAL PADDING [4B]"
      }

      f1: "price (f64)" {
        style.fill: ${colors.data_blue}
        height: 80; width: 400
        label: "price [8B] - (IEEE 754)"
      }

      f2: "timestamp (u64)" {
        style.fill: ${colors.data_blue}
        height: 80; width: 400
        label: "timestamp [8B] - (Nanoseconds)"
      }

      f3: "quantity (i32)" {
        style.fill: ${colors.data_blue}
        height: 40; width: 400
        label: "quantity [4B]"
      }

      f4: "symbol_offset (u32)" {
        style.fill: ${colors.data_blue}
        height: 40; width: 400
        label: "symbol_offset [4B] - (SOffset into Heap)"
      }
    }

    # Right Margin: Field Sizes
    sizes: {
      grid-columns: 1
      grid-gap: 0
      s1: "4 Bytes"; s2: "4 Bytes"; s3: "8 Bytes"; s4: "8 Bytes"; s5: "4 Bytes"; s6: "4 Bytes"
      *.shape: text
      *.style.font-size: 12
      *.style.font-color: "#666"
    }
  }

  # Connection-based alignment for the layout grid
  container.offsets.t0 -- container.bytes.header
  container.offsets.t4 -- container.bytes.pad1
  container.offsets.t8 -- container.bytes.f1
  container.offsets.t16 -- container.bytes.f2
  container.offsets.t24 -- container.bytes.f3
  container.offsets.t28 -- container.bytes.f4

  boundary: "-------------------------- Page Boundary / Cache Line (64B Window) --------------------------" {
    shape: text
    style.stroke-dash: 5
    style.font-color: "#7f8c8d"
    near: bottom-center
  }
}

# -----------------------------------------------------------------------------
# GLOBAL CONNECTIONS & LEGEND
# -----------------------------------------------------------------------------

algorithm_steps -> trace_container: "Apply to Struct Definition"
trace_container -> memory_layout: "Synthesized Memory Layout"

# Specific alignment logic highlight
algorithm_steps.step2.align_logic -> trace_container.trace_table.r1: "Sets Padding to 4B" {
  style: {
    stroke: ${colors.pointer_orange}
    stroke-width: 3
    stroke-dash: 5
    animated: true
  }
}

legend: "Intel Layout Legend" {
  near: bottom-right
  h: "Header (Purple)" { style.fill: ${colors.header_purple} }
  d: "Data (Blue)" { style.fill: ${colors.data_blue} }
  p: "Padding (Gray)" { style.fill: ${colors.padding_gray} }
}