vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # FlatBuffers Schema Evolution & Compatibility Matrix
  **Technical Specification for Zero-Copy Binary Wire Format**
| {near: top-center}

direction: right

# -----------------------------------------------------------------------------------------
# CLASSES & STYLING
# -----------------------------------------------------------------------------------------
classes: {
  header: {
    style: {
      fill: "#6f42c1"
      font-color: white
      bold: true
      underline: true
    }
  }
  vtable: {
    style: {
      fill: "#e2e3e5"
      stroke: "#6c757d"
      stroke-dash: 3
    }
  }
  data_buffer: {
    style: {
      fill: "#cce5ff"
      stroke: "#004085"
    }
  }
  code_block: {
    style: {
      font: mono
      fill: "#f8f9fa"
      stroke: "#17a2b8"
    }
  }
}

# -----------------------------------------------------------------------------------------
# LEGEND
# -----------------------------------------------------------------------------------------
legend: {
  near: top-right
  compatible: "✓ Binary Compatible" {
    style.fill: "#d4edda"
    style.stroke: "#28a745"
  }
  degraded: "⚠ Semantic Risk / Defaults" {
    style.fill: "#fff3cd"
    style.stroke: "#ffc107"
  }
  broken: "✗ Breaking Change" {
    style.fill: "#f8d7da"
    style.stroke: "#dc3545"
  }
}

# -----------------------------------------------------------------------------------------
# SCENARIO 1: FORWARD COMPATIBILITY
# -----------------------------------------------------------------------------------------
scenario_1: "Scenario 1: Forward Compatibility (Old Code + New Data)" {
  style.fill: "#f0f7f9"
  
  v1_reader: "V1 Compiled Reader" {
    shape: class
    Known_Fields: "id, symbol, price"
    Methods: "get_id(), get_symbol(), get_price()"
    style.fill: "#d1ecf1"
  }

  v2_buffer: "V2 Wire Buffer (Extended)" {
    vtable_v2: "VTable V2" {
      shape: sql_table
      style.fill: "#e2e3e5"
      0x00: "vtable_size: 16"
      0x02: "table_size: 32"
      0x04: "f[0] (id): 8"
      0x06: "f[1] (symbol): 20"
      0x08: "f[2] (price): 16"
      0x0A: "f[3] (quantity): 4" {style.bold: true; style.stroke: green}
    }

    table_v2: "Table Data V2" {
      shape: sql_table
      style.fill: "#cce5ff"
      0x00: "vtable_offset: -16"
      0x04: "quantity: 500 (int32)" {style.fill: "#d4edda"}
      0x08: "id: 101 (uint64)"
      0x10: "price: 45.5 (float64)"
      0x18: "symbol_offset: +8"
    }
  }

  v1_reader -> v2_buffer.vtable_v2: "1. Lookup field ID"
  v1_reader -> v2_buffer.table_v2: "2. Read via offset"

  outcome: "RESULT: SUCCESS" {
    style.fill: "#d4edda"
    details: |md
      **Mechanics:**
      - V1 code only requests IDs 0, 1, 2.
      - VTable size (16) > requested ID offset (4, 6, 8).
      - Field 3 is simply ignored by the older binary.
    |
  }
}

# -----------------------------------------------------------------------------------------
# SCENARIO 2: BACKWARD COMPATIBILITY
# -----------------------------------------------------------------------------------------
scenario_2: "Scenario 2: Backward Compatibility (New Code + Old Data)" {
  style.fill: "#fffdf5"

  v2_reader: "V2 Compiled Reader" {
    shape: class
    Known_Fields: "id, symbol, price, quantity"
    Methods: "get_quantity() -> default 0"
    style.fill: "#d1ecf1"
  }

  v1_buffer: "V1 Wire Buffer (Original)" {
    vtable_v1: "VTable V1" {
      shape: sql_table
      style.fill: "#e2e3e5"
      0x00: "vtable_size: 12"
      0x02: "table_size: 24"
      0x04: "f[0] (id): 8"
      0x06: "f[1] (symbol): 20"
      0x08: "f[2] (price): 16"
    }

    table_v1: "Table Data V1" {
      shape: sql_table
      style.fill: "#cce5ff"
      0x00: "vtable_offset: -12"
      0x04: "id: 99 (uint64)"
      0x0C: "price: 12.0 (float64)"
      0x14: "symbol_offset: +4"
    }
  }

  v2_reader -> v1_buffer.vtable_v1: "Request field 3 (quantity)"
  
  outcome_2: "RESULT: DEFAULT VALUE" {
    style.fill: "#fff3cd"
    details: |md
      **Mechanics:**
      - Reader checks `field_id * 2 + 4` (10).
      - VTable size is only 12. Offset 10 exists but value is checked.
      - If ID was totally missing, size check `10 < vtable_size` might fail if older.
      - Reader detects missing field -> returns schema default (e.g., 0).
    |
  }
}

# -----------------------------------------------------------------------------------------
# INCOMPATIBLE CHANGES (THE "NEVER" LIST)
# -----------------------------------------------------------------------------------------
illegal_ops: "❌ CRITICAL: Breaking Changes" {
  style.fill: "#f8d7da"
  
  grid-columns: 2
  
  type_mismatch: "Type Change" {
    v1: "price: float64 (8b)"
    v2: "price: float32 (4b)"
    consequence: "Reader interprets 4 bytes as 8 -> Offset Shift + Memory Corruption"
  }
  
  id_reuse: "ID Reuse" {
    v1: "ID[2]: price"
    v2: "ID[2]: timestamp"
    consequence: "Old reader gets timestamp and thinks it is a price value."
  }
}

# -----------------------------------------------------------------------------------------
# COMPATIBILITY MATRIX TABLE
# -----------------------------------------------------------------------------------------
matrix: "Reference: Evolution Compatibility Matrix" {
  near: bottom-center
  grid-rows: 6
  grid-columns: 4
  grid-gap: 0

  # Headers
  h1: "Evolution Action" { class: header }
  h2: "Old Code / New Data" { class: header }
  h3: "New Code / Old Data" { class: header }
  h4: "Constraint" { class: header }

  # Row 1: Add Field
  r1c1: "Add Non-Required Field"
  r1c2: "✓ Ignored" { style.fill: "#d4edda" }
  r1c3: "✓ Return Default" { style.fill: "#d4edda" }
  r1c4: "Append to end of table"

  # Row 2: Rename Field
  r2c1: "Rename Field"
  r2c2: "✓ Binary OK" { style.fill: "#d4edda" }
  r2c3: "✓ Binary OK" { style.fill: "#d4edda" }
  r2c4: "Semantic matching only"

  # Row 3: Reorder (Schema)
  r3c1: "Reorder in Schema"
  r3c2: "✗ BREAK" { style.fill: "#f8d7da" }
  r3c3: "✗ BREAK" { style.fill: "#f8d7da" }
  r3c4: "IDs must be explicit"

  # Row 4: Change Type
  r4c1: "Change Bit-Width"
  r4c2: "✗ BREAK" { style.fill: "#f8d7da" }
  r4c3: "✗ BREAK" { style.fill: "#f8d7da" }
  r4c4: "Changes VTable offsets"
  
  # Row 5: Required Fields
  r5c1: "Add 'Required' Field"
  r5c2: "✓ OK" { style.fill: "#d4edda" }
  r5c3: "✗ RUNTIME ERR" { style.fill: "#f8d7da" }
  r5c4: "Breaks backward compat"
}

# -----------------------------------------------------------------------------------------
# ALGORITHM - LOGIC BLOCK
# -----------------------------------------------------------------------------------------
lookup_logic: "VTable Pointer Logic" {
  near: bottom-right
  class: code_block
  logic: |cpp
template<typename T>
T ReadField(const Table *table, voffset_t field_id, T default_val) {
  // 1. Find VTable
  auto vtable = table->GetVTable();
  
  // 2. Check if field_id is within this specific buffer's vtable
  voffset_t vtable_offset = 4 + (field_id * 2);
  if (vtable_offset >= vtable->length()) {
    return default_val; // Field added in newer schema
  }

  // 3. Get offset into data table
  voffset_t data_offset = vtable->get_offset(vtable_offset);
  if (data_offset == 0) {
    return default_val; // Field was explicitly set to null/default
  }

  // 4. Return typed value
  return table->Read<T>(data_offset);
}
  |
}

# -----------------------------------------------------------------------------------------
# CONNECTIONS & ANNOTATIONS
# -----------------------------------------------------------------------------------------
scenario_1.v1_reader -> scenario_1.v2_buffer: "Request ID 0..2"
scenario_2.v2_reader -> scenario_2.v1_buffer: "Request ID 3"

# FIX: Set near to a constant to avoid the "near to an object with constant near" compiler error
annotation: |md
  ### The Golden Rule
  **FlatBuffer field IDs are immutable.** 
  Once a field is assigned an index in the VTable, that index belongs to that field forever. 
  Changing the type or re-using the ID is a catastrophic failure in zero-copy systems.
| {
  near: bottom-left
  style.fill: "#fff3cd"
  style.stroke: "#ffc107"
}

# Global glob to ensure all rectangles have specific border radius
***.style.border-radius: 4