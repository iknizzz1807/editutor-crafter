vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
direction: right
title: |md
  # Code Generator Architecture
  Schema-driven zero-copy accessor generation
| {near: top-center}
# Input Layer
SchemaAST: {
  style.fill: "#E8D5E8"
  style.stroke: "#8B5A8B"
  label: "Schema AST\n(Input)"
  tables: "TableDef[]"
  fields: "FieldDef[]"
  types: "TypeId enum"
  |md
    Parsed from `.fbs` files:
    - Table definitions
    - Field names & types  
    - Default values
    - Namespace hierarchy
  |
}
# Processing Pipeline
TemplateEngine: {
  style.fill: "#B8D4E8"
  style.stroke: "#4A90A4"
  label: "Template Engine"
  parser: "Schema Traversal"
  layout_calc: "LayoutCalculator"
  emitter: "Code Emitter"
  parser -> layout_calc: "visit tables"
  layout_calc -> emitter: "offsets assigned"
  |md
    - Traverses AST nodes
    - Computes field offsets
    - Applies alignment rules
    - Generates code templates
  |
}
# Code Emission
CppCodeEmitter: {
  style.fill: "#D4E8D4"
  style.stroke: "#5A8B5A"
  label: "C++ Code Emitter"
  view_gen: "View Class Generator"
  builder_gen: "Builder Class Generator"
  vtable_gen: "VTable Emitter"
  view_gen -> builder_gen: "field IDs"
  builder_gen -> vtable_gen: "layout info"
}
# Generated Output
GeneratedCode: {
  style.fill: "#F5F5DC"
  style.stroke: "#8B8B6A"
  style.stroke-dash: 3
  label: "Generated Code\n(Output)"
  # Base class
  BufferView: {
    style.fill: "#E6E6FA"
    shape: class
    "+buffer": "const uint8_t*"
    "+table_start": "const uint8_t*"
    "+vtable": "const VTable*"
    "+has_field(field_id)": "bool"
    "+get_scalar<T>(id, default)": "T"
    "+get_offset(field_id)": "uint32_t"
  }
  # Derived class
  TradeOrderView: {
    style.fill: "#E0FFE0"
    shape: class
    "FIELD_ID": "static constexpr uint16_t = 0"
    "FIELD_SYMBOL": "static constexpr uint16_t = 1"
    "FIELD_PRICE": "static constexpr uint16_t = 2"
    "FIELD_QUANTITY": "static constexpr uint16_t = 3"
    "+id()": "uint64_t"
    "+symbol()": "StringView"
    "+price()": "double"
    "+quantity()": "int32_t"
    "+has_id()": "bool"
  }
  # Builder class
  TradeOrderBuilder: {
    style.fill: "#FFE0E0"
    shape: class
    "-builder_": "BuilderBase"
    "-id_value_": "uint64_t"
    "-symbol_offset_": "uint32_t"
    "+set_id(value)": "void"
    "+set_symbol(str)": "void"
    "+set_price(value)": "void"
    "+finish()": "vector<uint8_t>"
  }
  # Inheritance arrow
  TradeOrderView -> BufferView: {
    target-arrowhead.shape: triangle
    target-arrowhead.style.filled: false
    style.stroke: "#666666"
    label: "inherits"
  }
}
# Data Flow
SchemaAST -> TemplateEngine: "AST nodes" {
  style.stroke: "#8B5A8B"
  style.stroke-width: 2
}
TemplateEngine -> CppCodeEmitter: "processed AST" {
  style.stroke: "#4A90A4"
  style.stroke-width: 2
}
CppCodeEmitter -> GeneratedCode: ".hpp files" {
  style.stroke: "#5A8B5A"
  style.stroke-width: 2
  style.animated: true
}
# Legend
Legend: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#CCCCCC"
  input: {
    shape: rectangle
    style.fill: "#E8D5E8"
  }
  process: {
    shape: rectangle
    style.fill: "#B8D4E8"
  }
  output: {
    shape: rectangle
    style.fill: "#D4E8D4"
  }
  generated: {
    shape: rectangle
    style.fill: "#F5F5DC"
    style.stroke-dash: 3
  }
  input.label: "Input (Schema)"
  process.label: "Processing"
  output.label: "Code Gen"
  generated.label: "Generated Output"
}