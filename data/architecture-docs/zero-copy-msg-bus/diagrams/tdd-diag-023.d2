vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    payload: "#5C9EE5"
    producer: "#E8A87C"
    consumer: "#85DCB0"
    slot: "#F8E9A1"
  }
}
title: |md
  # Ring Buffer Integration: Zero-Copy Message Flow
| {near: top-center}
direction: right
Producer: {
  shape: person
  style.fill: ${colors.producer}
  style.stroke: "#D4763D"
  builder: TradeOrderBuilder {
    shape: rectangle
    style.fill: ${colors.producer}
    style.stroke: "#D4763D"
    style.border-radius: 4
  }
  builder -> slot_ptr: "1. get_slot(head)"
}
RingBuffer: {
  SharedMemory: {
    Header: "Header\n256 bytes" {
      shape: rectangle
      style.fill: ${colors.header}
      style.stroke: "#7B5EAE"
    }
    Slot0: Slot 0 {
      shape: rectangle
      style.fill: ${colors.slot}
      style.stroke: "#C4B56E"
      style.border-radius: 4
      MessageHeader: MessageHeader {
        shape: rectangle
        style.fill: ${colors.header}
        style.stroke: "#7B5EAE"
        |md
          **32 bytes**
          - magic: 0xFB00
          - version: uint16
          - type: MessageType
          - flags: uint16
          - payload_size: uint32
          - publish_timestamp: uint64
          - topic_hash: uint32
          - sequence: uint32
        |
      }
      FlatBufferPayload: FlatBuffer Payload {
        shape: rectangle
        style.fill: ${colors.payload}
        style.stroke: "#3D7DC4"
        |md
          **Variable size**
          VTable → Table → Fields
          - id: uint64
          - price: float64
          - quantity: int32
          - symbol: string offset
        |
      }
    }
    Slot1: "Slot 1\n(empty)" {
      shape: rectangle
      style.fill: "#E8E8E8"
      style.stroke: "#B0B0B0"
      style.stroke-dash: 3
    }
    SlotN: "Slot N-1\n(empty)" {
      shape: rectangle
      style.fill: "#E8E8E8"
      style.stroke: "#B0B0B0"
      style.stroke-dash: 3
    }
    Header -> Slot0: "offset 0x100"
    Slot0 -> Slot1: "offset += slot_size"
    Slot1 -> SlotN: "..."
  }
  MemoryLayout: {
    shape: rectangle
    style.fill: transparent
    style.stroke: "#666"
    style.stroke-dash: 2
    |md
      **Memory Layout (Total: 256 + N × slot_size)**
      
      0x000: Header (head@0x00, tail@0x40)
      0x100: Sequence Array (N × 8 bytes)
      0x100+N×8: Slot 0 (32 + payload)
      ...
      
    |
  }
}
Consumer: {
  shape: person
  style.fill: ${colors.consumer}
  style.stroke: "#4BA86E"
  view: TradeOrderView {
    shape: rectangle
    style.fill: ${colors.consumer}
    style.stroke: "#4BA86E"
    style.border-radius: 4
  }
  slot_ptr -> view: "3. View(buffer, offset)"
}
Producer.builder -> RingBuffer.SharedMemory.Slot0: "2. memcpy(slot_ptr, flatbuf)" {
  label: "Direct write\nNo copy"
  style.stroke: ${colors.producer}
  style.stroke-width: 2
}
RingBuffer.SharedMemory.Slot0 -> Consumer.view: "Zero-copy read\nPointer arithmetic" {
  style.stroke: ${colors.consumer}
  style.stroke-width: 2
  style.stroke-dash: 5
}
Consumer.view -> Consumer: "4. order.price()\n   order.quantity()" {
  label: "Field access:\n~5-20 ns each"
  style.stroke: ${colors.consumer}
}
legend: {
  near: bottom-center
  shape: rectangle
  style.fill: "#F5F5F5"
  style.stroke: "#999"
  |md
    **Integration Points:**
    - `MessageHeader` (32B) prepended to each slot
    - `payload_size` determines FlatBuffer extent
    - Consumer creates `View(slot_ptr + 32, 0)` over payload
    - Reference counting in `MessageSlotHeader.ref_count`
  |
}