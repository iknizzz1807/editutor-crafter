vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: right

# ---------------------------------------------------------------------------------------
# TITLE AND HEADER
# ---------------------------------------------------------------------------------------
title: ||md
  # Zero-Copy vs Traditional Serialization
  **Instruction Count & Memory Access Comparison**
  *Technical implementation spec for high-performance messaging*
|| {
  near: top-center
  shape: rectangle
  style: {
    stroke-width: 0
    fill: transparent
    font-size: 14
  }
}

# ---------------------------------------------------------------------------------------
# TRADITIONAL JSON APPROACH (HEAVY DESERIALIZATION)
# ---------------------------------------------------------------------------------------
json_approach: JSON (Traditional) {
  style: {
    fill: "#E8E8E8"
    stroke: "#666666"
    stroke-width: 2
    double-border: true
  }

  raw_bytes: "Raw Bytes\n(256 B message)" {
    shape: hexagon
    style: {
      fill: "#B8D4E8"
      stroke: "#1976D2"
    }
  }

  parse_step: "Lexer/Parser\n(UTF-8 Validation)\n~5,000 instructions" {
    shape: rectangle
    style.fill: "#FFB366"
  }

  dom: "DOM Tree Construction\n(Map/Array Objects)\n~3,000 instructions" {
    shape: rectangle
    style.fill: "#FF9999"
  }

  field_lookup: "Key Search (strcmp)\n(O(log n) or O(n))\n~800 instructions" {
    shape: rectangle
    style.fill: "#FFCC66"
  }

  type_convert: "Type Conversion\n(atof / strtoll)\n~600 instructions" {
    shape: rectangle
    style.fill: "#FF9966"
  }

  heap_alloc: "Persistence Allocation\n(malloc/new)\n~400 instructions" {
    shape: rectangle
    style.fill: "#FF6666"
  }

  extracted: "Extracted Field\n(Memory Resident)" {
    shape: rectangle
    style: {
      fill: "#90EE90"
      bold: true
      stroke-width: 3
    }
  }

  # Connection sequence with detailed engineering annotations
  raw_bytes -> parse_step: "Read Buffer (O(n))\n1 memory access"
  parse_step -> dom: "Build Tree Structure\n~15 heap allocs"
  dom -> field_lookup: "Linear Search Keys\n~10 strcmp calls"
  field_lookup -> type_convert: "String to Numeric\n~5 conversions"
  type_convert -> heap_alloc: "Persistent Storage\n~3 malloc calls"
  heap_alloc -> extracted: "Memcpy to Object\n1 memcpy"
}

# ---------------------------------------------------------------------------------------
# FLATBUFFER ZERO-COPY APPROACH (DIRECT ACCESS)
# ---------------------------------------------------------------------------------------
flatbuffer_approach: FlatBuffer (Zero-Copy) {
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-width: 2
    double-border: true
  }

  fb_raw: "Raw Bytes\n(256 B message)" {
    shape: hexagon
    style: {
      fill: "#B8D4E8"
      stroke: "#1976D2"
    }
  }

  vtable_load: "Load VTable Offset\n(u32 relative ptr)\n~2 instructions" {
    shape: rectangle
    style.fill: "#A5D6A7"
  }

  field_offset: "Load Field Offset\n(u16 from vtable)\n~2 instructions" {
    shape: rectangle
    style.fill: "#81C784"
  }

  ptr_arith: "Pointer Arithmetic\n(Base + Offset)\n~1 instruction" {
    shape: rectangle
    style.fill: "#66BB6A"
  }

  load_value: "Register Load\n(Direct Access)\n~1 instruction" {
    shape: rectangle
    style.fill: "#4CAF50"
  }

  fb_result: "Field Value\n(CPU Register)" {
    shape: rectangle
    style: {
      fill: "#90EE90"
      bold: true
      stroke-width: 3
    }
  }

  # Direct access path
  fb_raw -> vtable_load: "Register load [RDI+0]"
  vtable_load -> field_offset: "VTable lookup [RDI+OFF]"
  field_offset -> ptr_arith: "ADD offset to base"
  ptr_arith -> load_value: "Direct load [RDI+ADD]"
  load_value -> fb_result: "Immediate Use"
}

# ---------------------------------------------------------------------------------------
# METRICS COMPARISON (Corrected 'near' property)
# ---------------------------------------------------------------------------------------
metrics: ||md
  ## Performance Metrics
  | Metric | JSON | FlatBuffer | Speedup |
  |--------|------|------------|---------|
  | **Instructions** | ~10,000 | ~6 | **1,667x** |
  | **Memory Accesses** | ~50 | 3 | **16x** |
  | **Heap Allocations** | ~18 | 0 | **∞** |
  | **Cache Misses** | ~25 | 1-2 | **12x** |
  | **Latency (typical)** | 500-2000 ns | 5-20 ns | **100x** |

  ---

  ### ASM Implementation Detail
  Accessing a field in FlatBuffers compiles to:
  asm
  mov eax, [rdi + 4]             ; load vtable offset
  movzx eax, word [rdi+eax+10]   ; load field offset from vtable
  test eax, eax                  ; check if field is present
  je .default                    ; branch to default if offset is 0
  movsd xmm0, [rdi + eax]        ; direct load from buffer
  ret
  
|| {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#F5F5F5"
    stroke: "#999999"
    border-radius: 8
  }
}

# ---------------------------------------------------------------------------------------
# MEMORY LAYOUT VISUALIZATION (Rule 1 compliance)
# ---------------------------------------------------------------------------------------
memory_detail: Memory Layout & Access Patterns {
  style: {
    fill: "#FFF9C4"
    stroke: "#FBC02D"
    stroke-dash: 2
  }

  json_mem: "JSON Heap Layout (Fragmented)" {
    style.fill: "#FFECB3"
    
    json_input: "0x1000: Raw Input Buffer [256B]" {
      shape: rectangle
      style.fill: "#B8D4E8" # Blue = Data
    }
    
    json_dom: "0x2A00: DOM Map Node [32B]" {
      shape: rectangle
      style.fill: "#D1C4E9" # Purple = Header/Metadata
    }
    
    json_string: "0x3F00: 'id_field' Key [12B]" {
      shape: rectangle
      style.fill: "#B8D4E8"
    }

    padding_gap: "0x3F0C: PADDING [4B]" {
      style.fill: "#BDBDBD" # Gray = Padding
    }

    json_output: "Stack: Final POJO/Struct [64B]" {
      shape: rectangle
      style.fill: "#C8E6C9" # Green = Clean/Target
    }

    json_input -> json_dom: "Parser Reads"
    json_dom -> json_string: "Key Pointer (Orange)" {
      style.stroke: "#FB8C00"
    }
    json_string -> json_output: "Copy & Convert"
  }

  flatbuffer_mem: "FlatBuffer Wire Layout (Sequential)" {
    style.fill: "#C8E6C9"
    
    fb_header: "0x00: VTable Offset [4B]" {
      style.fill: "#D1C4E9"
    }
    
    fb_vtable: "0x04: VTable [12B] (Offsets)" {
      style.fill: "#D1C4E9"
    }
    
    fb_data: "0x10: Field Data [8B]" {
      style.fill: "#B8D4E8"
    }
    
    fb_free: "0x18: Unread/Free Space" {
      style.fill: "#C8E6C9"
    }

    fb_header -> fb_vtable: "Read VOffset"
    fb_vtable -> fb_data: "Field Loc @ +12" {
      style.stroke: "#FB8C00"
    }
  }
}

# ---------------------------------------------------------------------------------------
# CACHE ANALYSIS SECTION
# ---------------------------------------------------------------------------------------
cache_section: CPU Cache Behavior Analysis {
  style: {
    fill: "#E3F2FD"
    stroke: "#1976D2"
  }

  json_cache: "JSON Parser Characteristics" {
    style.fill: "#BBDEFB"
    jc_miss: "L1 Data Misses: ~25 | L2 Misses: ~10 | L3 Misses: ~3" {
      style.font: mono
    }
    jc_reason: ||md
      **Root Causes of Stalls:**
      - **Linear Scan:** Every byte must be read/validated.
      - **Pointer Chasing:** DOM nodes linked via pointers, causing random access.
      - **Branch Mispredict:** Variable field order and string lengths confuse CPU.
    || {
      shape: rectangle
      style.fill: "#E3F2FD"
    }
  }

  fb_cache: "FlatBuffer Access Characteristics" {
    style.fill: "#B3E5FC"
    fc_hit: "L1 Hits: 2-3 | L1 Misses: 1-2 | L2 Misses: 0-1" {
      style.font: mono
    }
    fc_reason: ||md
      **Efficiency Drivers:**
      - **Single Load:** Only specific bytes for requested field are accessed.
      - **Locality:** VTable and data often reside in same 64B cache line.
      - **Zero Alloc:** No temporary objects = Zero pressure on GC/Heap.
    || {
      shape: rectangle
      style.fill: "#E1F5FE"
    }
  }
}

# ---------------------------------------------------------------------------------------
# LEGEND AND ANNOTATIONS
# ---------------------------------------------------------------------------------------
legend: ||md
  ### Legend
  🟦 **Data Block** - raw bytes  
  🟧 **Processing** - instructions  
  🟩 **Result** - extracted value  
  🟥 **Allocation** - costly heap ops  
  🟪 **Metadata** - VTables/Headers
|| {
  near: bottom-center
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#CCCCCC"
  }
}

# Global throughput comparison link
json_approach <-> flatbuffer_approach: ||md
  **THROUGHPUT RATIO**
  ~10,000 instructions
  vs
  **~6 instructions**
|| {
  style: {
    stroke: "#FF5722"
    stroke-width: 4
    stroke-dash: 5
    font-color: "#D84315"
    bold: true
  }
}