vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#7B68EE"
    data: "#4682B4"
    free: "#2E8B57"
    padding: "#808080"
    pointer: "#FF8C00"
    changed: "#DC143C"
    arrow-prod: "#228B22"
    arrow-cons: "#4169E1"
  }
}
title: |md
  # MPMC Ring Buffer: Vyukov Algorithm
  ## Consumer try_dequeue Sequence
| {near: top-center}
direction: right
Step_1: {
  label: "Step 1: Load Head Position"
  style.fill: "${colors.header}"
  code: |md
    cpp
    pos = head.load(relaxed)
    
  |
  note: |md
    Read consumer's claim position
    from cache line 0
  |
}
Step_2: {
  label: "Step 2: Load Sequence"
  style.fill: "${colors.data}"
  code: |md
    cpp
    seq = sequence[pos & mask]
           .load(acquire)
    
  |
  note: |md
    Get sequence number for slot
    at position % capacity
  |
}
Step_3: {
  label: "Step 3: Compute Diff"
  style.fill: "${colors.header}"
  code: |md
    cpp
    diff = seq - (pos + 1)
    
  |
  note: |md
    Compare to expected value
    seq should equal pos+1 for data
  |
}
Step_4: {
  label: "Step 4: Check Ready"
  style.fill: "${colors.changed}"
  style.bold: true
  branch: |md
    **diff == 0**
    Slot has data ready!
  |
  note: |md
    Data is available when
    sequence == position + 1
  |
}
Step_5: {
  label: "Step 5: CAS Claim"
  style.fill: "${colors.pointer}"
  code: |md
    cpp
    if (head.compare_exchange_weak(
          pos, pos + 1))
      break; // claimed!
    
  |
  note: |md
    Atomically claim slot
    Retry on CAS failure
  |
}
Step_6: {
  label: "Step 6: Check Empty"
  style.fill: "${colors.free}"
  branch: |md
    **diff < 0**
    Queue is empty!
  |
  note: |md
    Slot expects earlier position
    → no data available
  |
  return_false: {
    label: "return false"
    shape: diamond
    style.fill: "#FFE4E1"
  }
}
Step_7: {
  label: "Step 7: Read Data"
  style.fill: "${colors.data}"
  style.bold: true
  code: |md
    cpp
    slot_idx = pos & mask
    memcpy(out, slots[slot_idx], 
           min(out_size, slot_size))
    
  |
  note: |md
    Copy message from slot
    to output buffer
  |
}
Step_8: {
  label: "Step 8: Release Slot"
  style.fill: "${colors.free}"
  style.bold: true
  code: |md
    cpp
    sequence[slot_idx].store(
      pos + capacity, release)
    
  |
  note: |md
    Signal slot recycled
    Ready for next cycle
    (wraps with +capacity)
  |
}
Step_9: {
  label: "Step 9: Return Success"
  style.fill: "${colors.header}"
  return_true: {
    label: "return true"
    shape: diamond
    style.fill: "#E8F5E9"
  }
}
# Connections
Step_1 -> Step_2
Step_2 -> Step_3
Step_3 -> Step_4
Step_4 -> Step_5: "yes"
Step_4 -> Step_6: "no"
Step_5 -> Step_7: "CAS success"
Step_5 -> Step_1: "CAS fail\n(retry)"
Step_6 -> return_false
Step_7 -> Step_8
Step_8 -> Step_9
# Legend
legend: {
  near: bottom-right
  style.fill: "#F5F5F5"
  style.stroke: "#CCCCCC"
  Cache_Line_0: {
    style.fill: "${colors.header}"
    label: "Header/Metadata"
  }
  Data_Access: {
    style.fill: "${colors.data}"
    label: "Data Operation"
  }
  State_Change: {
    style.fill: "${colors.free}"
    label: "State Update"
  }
  Changed_Element: {
    style.fill: "${colors.changed}"
    label: "Changed Element"
  }
}