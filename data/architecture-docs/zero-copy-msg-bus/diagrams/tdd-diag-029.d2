vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

shape: sequence_diagram

# Participants (Producers represent CPU Cores attempting atomic operations)
P0: "Producer 0\n(Core 0)"
P1: "Producer 1\n(Core 1)"
P2: "Producer 2\n(Core 2)"
P3: "Producer 3\n(Core 3)"
P4: "Producer 4\n(Core 4)"
P5: "Producer 5\n(Core 5)"
P6: "Producer 6\n(Core 6)"
P7: "Producer 7\n(Core 7)"

Tail: "tail pointer\n(Shared Cache Line)" {
  style: {
    fill: "#DEE1EB"
    stroke-width: 2
  }
}

# PHASE 1: SIMULTANEOUS LOAD
# All cores fetch the current tail into their local L1/L2 caches
T1_Read: {
  P0 -> Tail: "load(tail) = 100"
  P1 -> Tail: "load(tail) = 100"
  P2 -> Tail: "load(tail) = 100"
  P3 -> Tail: "load(tail) = 100"
  P4 -> Tail: "load(tail) = 100"
  P5 -> Tail: "load(tail) = 100"
  P6 -> Tail: "load(tail) = 100"
  P7 -> Tail: "load(tail) = 100"

  # Style all read operations as standard blue loads
  (T1_Read -> Tail)[*].style.stroke: "#007bff"
}

# PHASE 2: ATOMIC COMPARE-AND-SWAP (CAS) CONTENTION
# Race condition: Only one core can acquire the cache line in 'Exclusive' state
T2_CAS: {
  P0 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P1 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P2 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  
  P3 -> Tail: "LOCK CAS(100→101) ✓ SUCCESS" { 
    style: {
      stroke: "#28a745"
      stroke-width: 4
      animated: true
      bold: true
    }
  }

  P4 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P5 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P6 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P7 -> Tail: "LOCK CAS(100→101) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
}

# PHASE 3: CACHE INVALIDATION & RE-READ
# P3 success triggers MESI Invalidation storm to all other cores
T3_Reread: {
  P0 -> Tail: "load(tail) = 101 (retry)"
  P1 -> Tail: "load(tail) = 101 (retry)"
  P2 -> Tail: "load(tail) = 101 (retry)"
  P4 -> Tail: "load(tail) = 101 (retry)"
  P5 -> Tail: "load(tail) = 101 (retry)"
  P6 -> Tail: "load(tail) = 101 (retry)"
  P7 -> Tail: "load(tail) = 101 (retry)"

  (T3_Reread -> Tail)[*].style.stroke: "#007bff"
}

# PHASE 4: SECOND CONTENTION CYCLE
T4_CAS2: {
  P0 -> Tail: "CAS(101→102) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  
  P1 -> Tail: "CAS(101→102) ✓ SUCCESS" { 
    style: {
      stroke: "#28a745"
      stroke-width: 4
      animated: true
      bold: true
    }
  }

  P2 -> Tail: "CAS(101→102) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P4 -> Tail: "CAS(101→102) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P5 -> Tail: "CAS(101→102) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P6 -> Tail: "CAS(101→102) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
  P7 -> Tail: "CAS(101→102) ❌ FAIL" { style.stroke: "#dc3545"; style.stroke-dash: 3 }
}

# TECHNICAL ANNOTATIONS (Intel Manual Quality Spec)
P0.bouncing: |md
### Cache Line Bouncing (Interconnect Traffic)
- **RFO (Request For Ownership):** Every failed CAS causes a cache miss/invalidation.
- **UPI Latency:** The cache line physically migrates across the CPU mesh/ring.
- **Throughput:** $O(1/N)$ where $N$ is the number of contending producers.
|

P3.winner: |md
### Winning Transaction (Slot Acquisition)
- **State:** Cache line enters **Modified (M)** state on Core 3.
- **Latency:** Success typically takes ~40 cycles in zero-contention, up to 500+ cycles under high contention.
|

P7.contention: |md
### Contention Scaling
- **8 Producers:** 87.5% failure rate per CAS attempt.
- **Interconnect Saturation:** High frequency of MESI "Invalidate" and "Read-for-Ownership" packets saturates the memory bus.
|

# Global Styles
***.style.font: mono
(*** -> Tail)[*].target-arrowhead.shape: diamond