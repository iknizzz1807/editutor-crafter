vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Backpressure Propagation Patterns
  ## High-Performance Systems Design: Thread-Blocking vs. Credit-Based Flow Control
| {near: top-center}

direction: down

# =============================================================
# BLOCKING APPROACH: TRADITIONAL SYNC
# =============================================================
Blocking: {
  label: "Pattern A: Blocking with Condition Variables (Implicit Backpressure)"
  style: {
    stroke: "#2E86AB"
    stroke-width: 2
    fill: "#F8FBFE"
  }

  Producer: {
    shape: rectangle
    label: "Producer Thread\n(app_writer_t)"
    tooltip: "Blocks on mutex/CV when queue is saturated"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
    style.bold: true
  }

  Queue: {
    shape: cylinder
    label: "Bounded Queue\n(ring_buffer_t)"
    description: "Capacity: N slots"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }

  CV: "Condition Variable\n(not_full_cv)" {
    shape: diamond
    style.fill: "#F3E5F5"
    style.stroke: "#7B1FA2"
  }

  Consumer: {
    shape: rectangle
    label: "Consumer Thread\n(app_reader_t)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }

  # Interaction Flow
  Producer -> Queue: "1. write_packet()" {
    style.stroke: "#2E86AB"
    style.stroke-width: 3
  }
  
  Queue -> CV: "2. queue.is_full()?" {
    style.stroke: "#E65100"
    style.stroke-dash: 3
  }
  
  CV -> Producer: "3. pthread_cond_wait()\n(Thread Descheduled)" {
    style.stroke: "#7B1FA2"
    style.stroke-dash: 5
    style.animated: true
  }
  
  Consumer -> Queue: "4. read_packet()" {
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }
  
  Queue -> CV: "5. space_available()" {
    style.stroke: "#E65100"
  }
  
  CV -> Producer: "6. pthread_cond_signal()\n(Thread Context Switch)" {
    style.stroke: "#7B1FA2"
    style.bold: true
  }
  
  Producer -> Queue: "7. resume_enqueue()" {
    style.stroke: "#2E86AB"
    style.stroke-dash: 2
  }
}

# =============================================================
# CREDIT-BASED APPROACH: LOCK-FREE / ZERO-COPY
# =============================================================
CreditBased: {
  label: "Pattern B: Credit-Based Flow Control (Explicit Backpressure)"
  style: {
    stroke: "#F57C00"
    stroke-width: 2
    fill: "#FFFDF9"
  }

  Producer: {
    shape: rectangle
    label: "Producer Node\n(fast_path_t)"
    tooltip: "Checks local credit cache before attempting write"
    style.fill: "#E8F4FD"
    style.stroke: "#2E86AB"
  }

  CreditPool: {
    label: "Credit Pool\n(std::atomic<int32_t>)"
    shape: rectangle
    style.fill: "#FFF8E1"
    style.stroke: "#F57C00"
    style.double-border: true
    
    Fields: {
      shape: sql_table
      avail_credits: int32 {constraint: "Atomic Counter"}
      max_capacity: int32 {constraint: "N"}
    }
  }

  Queue: {
    shape: cylinder
    label: "Shared Memory Queue\n(lock_free_ring_t)"
    style.fill: "#FFF3E0"
    style.stroke: "#E65100"
  }

  Consumer: {
    shape: rectangle
    label: "Consumer Node\n(fast_path_t)"
    style.fill: "#E8F5E9"
    style.stroke: "#2E7D32"
  }

  # Initialization
  Queue -> CreditPool: "init: credits = N" {
    style.stroke: "#E65100"
    style.stroke-dash: 3
  }

  # Producer flow
  Producer -> CreditPool: "1. fetch_sub(1, acquire)" {
    style.stroke: "#2E86AB"
    style.bold: true
  }
  
  CreditPool -> Producer: "2. result > 0?\n  OK: Decr & Proceed\n  NO: Backoff" {
    style.stroke: "#F57C00"
    style.font-size: 11
  }
  
  Producer -> Queue: "3. write_to_shm()" {
    style.stroke: "#2E86AB"
    style.stroke-width: 3
  }

  # Consumer flow
  Consumer -> Queue: "4. read_from_shm()" {
    style.stroke: "#2E7D32"
    style.stroke-width: 3
  }
  
  Consumer -> CreditPool: "5. fetch_add(batch_size, release)" {
    label: "Return Credits"
    style.stroke: "#2E7D32"
    style.bold: true
    style.animated: true
  }
}

# =============================================================
# COMPARISON TABLE (FIXED BLOCK STRING)
# =============================================================
Comparison: ||md
  ### Performance Analysis: Propagating Backpressure
  | Architectural Aspect | Thread-Blocking (CV) | Credit-Based (Atomics) |
  | :--- | :--- | :--- |
  | **Critical Path Latency** | **High** (~15μs - 100μs wake overhead) | **Ultra-Low** (~150ns - 500ns atomic op) |
  | **CPU Utilization** | Low (Thread sleeps during congestion) | High (Spin-wait) or Variable (Yield/Backoff) |
  | **Context Switches** | Frequent (OS Scheduler involved) | Zero (User-space synchronization) |
  | **Memory Consistency** | Mutex Memory Barrier | C++11 Acquire/Release Semantics |
  | **Complexity** | High (Deadlock/Priority Inversion risks) | Medium (Atomic memory ordering) |
  | **Scale** | Multi-thread (Single Machine) | Multi-process / Distributed (RDMA/PCIe) |
|| {
  near: bottom-center
  style.stroke: "#333333"
  style.fill: "#FFFFFF"
}

# =============================================================
# STATE TRANSITIONS
# =============================================================
CreditState: {
  label: "Credit Pool Lifecycle"
  style.fill: "#F1F1F1"
  
  Ready: "credits == N" {
    shape: circle
    style.fill: "#C8E6C9"
  }
  Active: "0 < credits < N" {
    shape: circle
    style.fill: "#FFF9C4"
  }
  Exhausted: "credits == 0" {
    shape: circle
    style.fill: "#FFCDD2"
    style.bold: true
  }

  Ready -> Active: "Producer: Consume credit"
  Active -> Active: "In-flight processing"
  Active -> Exhausted: "Producer: Capacity reached" {
    style.font-color: red
  }
  Exhausted -> Active: "Consumer: Batch release" {
    style.stroke: green
    style.animated: true
  }
  Active -> Ready: "All work drained"
}

# =============================================================
# LEGEND
# =============================================================
Legend: {
  near: bottom-right
  style.fill: white
  
  BlockingFlow: "───▶ Kernel Wait/Wake" {
    style.stroke-dash: 5
    style.stroke: "#7B1FA2"
  }
  CreditFlow: "───▶ Credit Management" {
    style.stroke: "#2E7D32"
    style.bold: true
  }
  AtomicOp: "───▶ Memory Fence/Bus Lock" {
    style.stroke: "#F57C00"
  }
}