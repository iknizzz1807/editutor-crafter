vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header-purple: "#9B7EDB"
    header-purple-light: "#E9D5FF"
    data-blue: "#3B82F6"
    data-blue-light: "#BFDBFE"
    free-green: "#10B981"
    padding-gray: "#6B728A"
    pointer-orange: "#F59E0B"
    cache-line: "#EF4444"
  }
}

classes: {
  mem_field: {
    style: {
      stroke-width: 1
      border-radius: 2
    }
  }
  cache_line_box: {
    style: {
      stroke: "#EF4444"
      stroke-dash: 4
      stroke-width: 2
      fill: "#FDF2F2"
    }
  }
}

title: |md
  # Shared Memory Layout: Zero-Copy Message Bus
  **Intel-Standard Memory Alignment Spec**
| {near: top-center}

# Main Memory Map Container
SharedMemoryMap: {
  grid-columns: 2
  grid-gap: 0
  vertical-gap: 0
  horizontal-gap: 20
  
  style: {
    stroke: "#94A3B8"
    stroke-width: 2
    fill: white
  }

  # --- OFFSET COLUMN ---
  offsets: {
    grid-columns: 1
    style.stroke-width: 0
    
    o000: "0x000" { height: 60; shape: text }
    o040: "0x040" { height: 60; shape: text }
    o080: "0x080" { height: 80; shape: text }
    o0C0: "0x0C0" { height: 80; shape: text }
    o100: "0x100" { height: 80; shape: text }
    oSlot1: "0x100 + S" { height: 80; shape: text }
    oPadding: "..." { height: 40; shape: text }
    oEnd: "EOF" { height: 40; shape: text }
  }

  # --- DATA FIELDS COLUMN ---
  fields: {
    grid-columns: 1
    style.stroke-width: 0

    # CL0 - Producer Write Area
    producer_head: {
      class: [mem_field; cache_line_box]
      height: 60
      label: |md
        **Cache Line 0 (Producer)**
        `atomic(uint64) head`
      |
    }

    # CL1 - Consumer Write Area
    consumer_tail: {
      class: [mem_field; cache_line_box]
      height: 60
      label: |md
        **Cache Line 1 (Consumer)**
        `atomic(uint64) tail`
      |
    }

    # Metadata Segment
    metadata: {
      class: mem_field
      height: 80
      style.fill: "${colors.header-purple-light}"
      label: |md
        **Static Metadata**
        `uint64 num_slots`, `uint64 slot_size`
        `uint64 mask`, `uint64 seq_base`
      |
    }

    # Process Coordination
    coordination: {
      class: mem_field
      height: 80
      style.fill: "${colors.header-purple}"
      label: |md
        **Process Coordination**
        `uint32 prod_pid`, `uint32 cons_pid`
        `uint64 prod_hb`, `uint64 cons_hb`
      |
    }

    # Message Buffer Slots
    slot_0: {
      class: mem_field
      height: 80
      style.fill: "${colors.data-blue-light}"
      label: |md
        **Message Slot 0**
        `char data[slot_size]`
      |
    }

    slot_1: {
      class: mem_field
      height: 80
      style.fill: "${colors.data-blue-light}"
      label: |md
        **Message Slot 1**
        `char data[slot_size]`
      |
    }

    more_slots: {
      height: 40
      shape: text
      label: "... (Repeat N Slots) ..."
    }

    padding: {
      class: mem_field
      height: 40
      style.fill: "${colors.padding-gray}"
      label: "PAGE PADDING (to 4096B)"
    }
  }
}

# Documentation Annotations
annotations: {
  near: bottom-center
  total: |md
    **Total Region Size:** `256 + (N * slot_size) + padding`
    **Cache Alignment:** Fields 0x00 and 0x40 reside in separate L1 cache lines to prevent False Sharing.
  | {shape: text}
}

# Legend
legend: {
  near: top-right
  style.fill: "#F8FAFC"
  
  header: Header/Metadata {
    style.fill: "${colors.header-purple}"
  }
  data: Message Data {
    style.fill: "${colors.data-blue-light}"
  }
  false_sharing: "Cache Line (64B)" {
    style: {
      stroke: "${colors.cache-line}"
      stroke-dash: 4
      fill: transparent
    }
  }
}

# Logic Connections (Pointers)
(SharedMemoryMap.fields.producer_head -> SharedMemoryMap.fields.slot_0): "writes to" {
  style: {
    stroke: "${colors.free-green}"
    stroke-width: 2
    animated: true
  }
}

(SharedMemoryMap.fields.consumer_tail -> SharedMemoryMap.fields.slot_1): "reading" {
  style: {
    stroke: "${colors.pointer-orange}"
    stroke-width: 2
    animated: true
  }
}