vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Zero-Copy Pub/Sub System Architecture
| {near: top-center}
direction: down
# Layer 1: Application Layer
Application: {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  Publisher: {
    shape: hexagon
    style.fill: "#C8E6C9"
    icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
  }
  Subscriber: {
    shape: hexagon
    style.fill: "#C8E6C9"
    icon: https://icons.terrastruct.com/essentials%2F005-programmer.svg
  }
  Publisher -> Subscriber: "independent\nlifecycle" {
    style.stroke-dash: 3
    style.stroke: "#81C784"
  }
}
# Layer 2: Broker Layer
PubSubBroker: {
  style.fill: "#E3F2FD"
  style.stroke: "#1565C0"
  label: "PubSubBroker\n(message routing)"
  PublishAPI: {
    shape: rectangle
    label: "publish(topic, data)"
    style.fill: "#BBDEFB"
  }
  SubscribeAPI: {
    shape: rectangle
    label: "subscribe(pattern, handler)"
    style.fill: "#BBDEFB"
  }
  PollAPI: {
    shape: rectangle
    label: "poll(subscriber_id)"
    style.fill: "#BBDEFB"
  }
  PublishAPI -> SubscribeAPI
  SubscribeAPI -> PollAPI
}
# Layer 3: Core Components
TopicRegistry: {
  style.fill: "#FFF3E0"
  style.stroke: "#E65100"
  label: "TopicRegistry\n(trie-based routing)"
  RootNode: {
    shape: diamond
    label: "Root"
    style.fill: "#FFE0B2"
  }
  StocksNode: {
    label: "stocks/"
    style.fill: "#FFCC80"
  }
  OrdersNode: {
    label: "orders/"
    style.fill: "#FFCC80"
  }
  WildcardNode: {
    label: "+/#"
    style.fill: "#FFB74D"
    style.stroke-dash: 3
  }
  RootNode -> StocksNode
  RootNode -> OrdersNode
  StocksNode -> WildcardNode
}
ZeroCopyBuffer: {
  style.fill: "#F3E5F5"
  style.stroke: "#7B1FA2"
  label: "ZeroCopyPubSubBuffer\n(ref-counted slots)"
  Header: {
    shape: rectangle
    label: "Header\n(head, tail, metadata)"
    style.fill: "#E1BEE7"
  }
  Slot0: {
    label: "Slot[0]\nref=3"
    style.fill: "#CE93D8"
  }
  Slot1: {
    label: "Slot[1]\nref=0"
    style.fill: "#F3E5F5"
  }
  Slot2: {
    label: "Slot[2]\nref=2"
    style.fill: "#CE93D8"
  }
  SlotN: {
    label: "Slot[N]\nref=1"
    style.fill: "#CE93D8"
  }
  Header -> Slot0 -> Slot1 -> Slot2 -> SlotN
}
SubscriberCursors: {
  style.fill: "#E0F7FA"
  style.stroke: "#00838F"
  label: "SubscriberCursors\n(independent positions)"
  Cursor1: {
    shape: rectangle
    label: "Sub #1\noffset: 42"
    style.fill: "#B2EBF2"
  }
  Cursor2: {
    shape: rectangle
    label: "Sub #2\noffset: 38"
    style.fill: "#B2EBF2"
  }
  Cursor3: {
    shape: rectangle
    label: "Sub #3\noffset: 45"
    style.fill: "#B2EBF2"
  }
  Cursor1 -> Cursor2 -> Cursor3
}
# Publisher Flow (Left Side)
PublisherFlow: {
  style.fill: "#FFEBEE"
  style.stroke: "#C62828"
  style.stroke-dash: 5
  label: "Publisher Flow"
  P1: "1. Find matching\nsubscribers via\nTopicRegistry"
  P2: "2. Reserve slot\n(ref_count = N)"
  P3: "3. Write message\n(zero-copy)"
  P4: "4. Advance head\n(release fence)"
  P1 -> P2 -> P3 -> P4
}
# Subscriber Flow (Right Side)
SubscriberFlow: {
  style.fill: "#E8F5E9"
  style.stroke: "#2E7D32"
  style.stroke-dash: 5
  label: "Subscriber Flow"
  S1: "1. Check bloom filter\n(quick rejection)"
  S2: "2. Load slot via\ncursor offset"
  S3: "3. Apply message\nfilter predicate"
  S4: "4. Decrement ref_count\n(acknowledge)"
  S5: "5. Advance cursor\n(acquire fence)"
  S1 -> S2 -> S3 -> S4 -> S5
}
# Vertical Connections (Layer flow)
Application.Publisher -> PubSubBroker.PublishAPI: "publish()" {
  style.stroke: "#C62828"
  style.bold: true
}
PubSubBroker -> TopicRegistry: "match(topic)" {
  style.stroke: "#E65100"
}
PubSubBroker -> ZeroCopyBuffer: "write slot" {
  style.stroke: "#7B1FA2"
}
Application.Subscriber <- PubSubBroker.PollAPI: "poll()" {
  style.stroke: "#2E7D32"
  style.bold: true
}
PubSubBroker <- SubscriberCursors: "track position" {
  style.stroke: "#00838F"
}
# Flow connections
PublisherFlow.P1 -- TopicRegistry: "trie lookup" {
  style.stroke-dash: 3
  style.stroke: "#E65100"
}
PublisherFlow.P3 -- ZeroCopyBuffer: "memcpy" {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
}
SubscriberFlow.S2 -- ZeroCopyBuffer: "read" {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
}
SubscriberFlow.S4 -- ZeroCopyBuffer: "fetch_sub" {
  style.stroke-dash: 3
  style.stroke: "#7B1FA2"
}
# Legend
Legend: {
  near: bottom-right
  style.fill: "#FAFAFA"
  style.stroke: "#9E9E9E"
  SolidLine: "Solid = synchronous call"
  DashedLine: "Dashed = data flow" {
    shape: text
  }
  CacheAligned: "Purple slots = ref_count > 0 (active)"
  FreeSlot: "White slot = ref_count = 0 (reclaimable)" {
    shape: text
  }
}
# Key Invariants
Invariants: |md
  **Core Invariants:**
  1. One message, N readers (zero-copy fan-out)
  2. Topic match: O(M) where M = topic depth
  3. Wildcards: `+` = one level, `#` = zero+
  4. Slot reclaims when ref_count reaches 0
  5. Cursors advance independently
  6. Bloom filter: no false negatives
| {near: bottom-left}