vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
classes: {
  trie-node: {
    shape: class
    style: {
      fill: "#E8F4FD"
      stroke: "#2E86AB"
    }
  }
  exact-child: {
    shape: class
    style: {
      fill: "#D4EDDA"
      stroke: "#28A745"
    }
  }
  wildcard-child: {
    shape: class
    style: {
      fill: "#FFF3CD"
      stroke: "#FFC107"
    }
  }
  container-box: {
    style: {
      fill: "#F8F9FA"
      stroke: "#6C757D"
      stroke-dash: 3
    }
  }
}
TopicTrie: "Topic Trie Structure" {
  style.fill: transparent
  RootNode: {
    class: trie-node
    label: "TopicTrieNode\n(root)"
    +exact_children: "map<string, unique_ptr<Node>>"
    +wildcard_child: "unique_ptr<TopicTrieNode>"
    +subscribers: "vector<SubscriberID>"
    +multi_level_subscribers: "vector<SubscriberID>"
    +mutex: "shared_mutex"
    +depth: "size_t = 0"
  }
  StocksNode: {
    class: exact-child
    label: "TopicTrieNode\n\"stocks\""
    +exact_children: "map<string, unique_ptr<Node>>"
    +wildcard_child: "unique_ptr<TopicTrieNode>"
    +subscribers: "vector<SubscriberID>"
    +multi_level_subscribers: "vector<SubscriberID>"
    +mutex: "shared_mutex"
    +depth: "size_t = 1"
  }
  AAPLNode: {
    class: exact-child
    label: "TopicTrieNode\n\"AAPL\""
    +exact_children: "map<string, unique_ptr<Node>>"
    +wildcard_child: "unique_ptr<TopicTrieNode>"
    +subscribers: "vector<SubscriberID>"
    +multi_level_subscribers: "vector<SubscriberID>"
    +mutex: "shared_mutex"
    +depth: "size_t = 2"
  }
  WildcardNode: {
    class: wildcard-child
    label: "TopicTrieNode\n\"+\" (wildcard)"
    +exact_children: "map<string, unique_ptr<Node>>"
    +wildcard_child: "unique_ptr<TopicTrieNode>"
    +subscribers: "vector<SubscriberID>"
    +multi_level_subscribers: "vector<SubscriberID>"
    +mutex: "shared_mutex"
    +depth: "size_t = 2"
  }
  PriceNode_AAPL: {
    class: exact-child
    label: "TopicTrieNode\n\"price\"\n(from AAPL)"
    +exact_children: "map<> (empty)"
    +wildcard_child: "nullptr"
    +subscribers: "[sub_id_1, sub_id_5]"
    +multi_level_subscribers: "[]"
    +mutex: "shared_mutex"
    +depth: "size_t = 3"
  }
  PriceNode_Wildcard: {
    class: exact-child
    label: "TopicTrieNode\n\"price\"\n(from +)"
    +exact_children: "map<> (empty)"
    +wildcard_child: "nullptr"
    +subscribers: "[sub_id_3]"
    +multi_level_subscribers: "[]"
    +mutex: "shared_mutex"
    +depth: "size_t = 3"
  }
  RootNode -> StocksNode: "exact_children[\"stocks\"]" {
    style.stroke: "#28A745"
    style.stroke-width: 2
  }
  StocksNode -> AAPLNode: "exact_children[\"AAPL\"]" {
    style.stroke: "#28A745"
    style.stroke-width: 2
  }
  StocksNode -> WildcardNode: "wildcard_child (+)" {
    style.stroke: "#FFC107"
    style.stroke-width: 2
    style.stroke-dash: 5
  }
  AAPLNode -> PriceNode_AAPL: "exact_children[\"price\"]" {
    style.stroke: "#28A745"
    style.stroke-width: 2
  }
  WildcardNode -> PriceNode_Wildcard: "exact_children[\"price\"]" {
    style.stroke: "#28A745"
    style.stroke-width: 2
  }
}
Legend: {
  near: bottom-right
  style.fill: transparent
  ExactMatch: "exact_children entry" {
    class: exact-child
    shape: rectangle
    width: 120
  }
  WildcardMatch: "wildcard_child (+)" {
    class: wildcard-child
    shape: rectangle
    width: 120
  }
  ExactArrow: "→ exact match" {
    shape: text
    style.font-color: "#28A745"
  }
  WildcardArrow: "⇢ wildcard (+)" {
    shape: text
    style.font-color: "#FFC107"
  }
  ExactMatch -- WildcardMatch
  WildcardMatch -- ExactArrow
  ExactArrow -- WildcardArrow
}
MatchPaths: "Matching Paths for 'stocks/AAPL/price'" {
  near: top-right
  style: {
    fill: "#E8F4FD"
    stroke: "#2E86AB"
    border-radius: 8
  }
  Path1: |md
    **Path 1 (Exact):**
    root → stocks → AAPL → price
    → subscribers: [sub_id_1, sub_id_5]
  |
  Path2: |md
    **Path 2 (Wildcard +):**
    root → stocks → (+) → price
    → subscribers: [sub_id_3]
  |
  Path3: |md
    **Multi-level (#):**
    At each node, check multi_level_subscribers
    (stocks/# would match here)
  |
}
DataStructures: "Key Data Structures" {
  near: bottom-left
  style: {
    fill: "#F8F9FA"
    stroke: "#6C757D"
    border-radius: 8
  }
  ExactChildrenMap: {
    shape: class
    label: "exact_children"
    "unordered_map<string, unique_ptr<TopicTrieNode>>"
    "Key: segment (e.g., \"AAPL\")"
    "Value: child node pointer"
  }
  WildcardPointer: {
    shape: class
    label: "wildcard_child"
    "unique_ptr<TopicTrieNode>"
    "Matches single level (+)"
    "nullptr if not used"
  }
  SubscribersVector: {
    shape: class
    label: "subscribers"
    "vector<SubscriberID>"
    "Exact match at this node"
    "uint64_t subscriber IDs"
  }
  MultiLevelVector: {
    shape: class
    label: "multi_level_subscribers"
    "vector<SubscriberID>"
    "Matches # (this + all descendants)"
    "Added at subscription node"
  }
}