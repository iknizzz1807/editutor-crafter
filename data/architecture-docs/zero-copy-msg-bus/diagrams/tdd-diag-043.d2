vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

# -----------------------------------------------------------------------------
# GLOBAL TITLES AND ANNOTATIONS (Intel Manual Style)
# -----------------------------------------------------------------------------
title: ||md
  # Bloom Filter Technical Specification & Memory Mapping
  **Revision**: 1.0.4 | **Target Architecture**: x86_64 / ARMv8-A
  **Memory Profile**: m=256 bits (32 bytes), k=3 hash functions
  **Properties**: Fixed-size probabilistic membership. False Positive Rate ~2%.
||
title.near: top-center

# -----------------------------------------------------------------------------
# 1. BIT ARRAY STATE (O(1) Access Segment)
# -----------------------------------------------------------------------------
filter_container: "Bloom Filter Bit Segment (m=256)" {
  style: {
    fill: "#F8F9FA"
    stroke: "#343A40"
    stroke-width: 2
  }

  bit_array: {
    grid-columns: 16
    grid-rows: 2
    grid-gap: 0
    
    # Row 1: bits 0-15
    b00: "0" {class: bit-zero}
    b01: "1" {class: bit-one}
    b02: "0" {class: bit-zero}
    b03: "1" {class: bit-one}
    b04: "0" {class: bit-zero}
    b05: "0" {class: bit-zero}
    b06: "1" {class: bit-one}
    b07: "0" {class: bit-zero}
    b08: "0" {class: bit-zero}
    b09: "1" {class: bit-one}
    b10: "0" {class: bit-zero}
    b11: "0" {class: bit-zero}
    b12: "0" {class: bit-zero}
    b13: "1" {class: bit-one}
    b14: "0" {class: bit-zero}
    b15: "0" {class: bit-zero}
    # Row 2: bits 16-31
    b16: "0" {class: bit-zero}
    b17: "0" {class: bit-zero}
    b18: "1" {class: bit-one}
    b19: "0" {class: bit-zero}
    b20: "0" {class: bit-zero}
    b21: "0" {class: bit-zero}
    b22: "0" {class: bit-zero}
    b23: "1" {class: bit-one}
    b24: "0" {class: bit-zero}
    b25: "0" {class: bit-zero}
    b26: "0" {class: bit-zero}
    b27: "0" {class: bit-zero}
    b28: "1" {class: bit-one}
    b29: "0" {class: bit-zero}
    b30: "0" {class: bit-zero}
    b31: "0" {class: bit-zero}
  }
}

bit_array_annotation: |md
  ### Bit Array Mapping
  - Indices 0-31 shown above. 
  - bit[n] is located at `byte[n >> 3]` with mask `1 << (n & 7)`.
|
bit_array_annotation.near: top-right

# -----------------------------------------------------------------------------
# 2. PHYSICAL MEMORY LAYOUT (Intel Technical Specification Format)
# -----------------------------------------------------------------------------
memory_layout: "Physical Memory Layout (32-Byte Allocation)" {
  style.fill: "#F1F3F4"
  
  header: "BloomFilter Structure" {
    shape: sql_table
    style.fill: "#E1BEE7" # Purple for Header
    "0x00": "uint64_t hash_seeds[3]" {constraint: "Seeds"}
    "0x18": "uint8_t bit_data[32]" {constraint: "Payload"}
    "0x38": "uint8_t padding[8]" {constraint: "Padding"}
  }

  layout_visual: {
    grid-columns: 8
    grid-gap: 0
    
    # Offsets
    b0: "0x00" {class: byte-header}
    b1: "0x01" {class: byte-header}
    b2: "0x02" {class: byte-header}
    b3: "0x03" {class: byte-header}
    b4: "0x04" {class: byte-header}
    b5: "0x05" {class: byte-header}
    b6: "0x06" {class: byte-header}
    b7: "0x07" {class: byte-header}

    # Data Row
    d0: "Data[0..7]" {class: byte-data}
    d1: "Data[8..15]" {class: byte-data}
    d2: "Data[16..23]" {class: byte-data}
    d3: "Data[24..31]" {class: byte-data}
    d4: "Data[32..39]" {class: byte-data}
    d5: "TARGET" {class: byte-highlight}
    d6: "Data[48..55]" {class: byte-data}
    d7: "Data[56..63]" {class: byte-data}
  }
  
  cache_boundary: "--- CACHE LINE BOUNDARY (64B) ---" {
    style: {
      stroke-dash: 5
      stroke: gray
      font-size: 10
      bold: true
    }
  }
}

size_annotation: |md
  ### Memory Allocation Profile
  - **sizeof(struct)**: 64 bytes (Cache aligned)
  - **Effective Payload**: 32 bytes (m=256)
  - **Growth Direction**: Linear increasing
|
size_annotation.near: bottom-left

# -----------------------------------------------------------------------------
# 3. ALGORITHM PIPELINE (Logic Trace)
# -----------------------------------------------------------------------------
pipeline: "Operation Trace: Insertion/Probe" {
  style.fill: "#FFFDE7"
  
  add_path: {
    h1: "k0: Murmur3(key, 0)"
    h2: "k1: Murmur3(key, 1)"
    h3: "k2: Murmur3(key, 2)"
    
    h1 -> h2: "Step 1: Hash Calculation"
    h2 -> h3
  }

  mapping_path: {
    m1: "idx1 = k0 % 256"
    m2: "idx2 = k1 % 256"
    m3: "idx3 = k2 % 256"
    
    m1 -> m2: "Step 2: Modulation"
    m2 -> m3
  }

  state_change: {
    label: "Step 3: Atomic Set (OR)"
    bitset_op: "bits |= (1 << idx)" {
      style.font-color: red
      style.bold: true
    }
  }
}

# -----------------------------------------------------------------------------
# CLASSES & STYLING
# -----------------------------------------------------------------------------
classes: {
  bit-zero: {
    width: 35; height: 35
    style: {fill: white; stroke: "#CED4DA"; font: mono; font-size: 12}
  }
  bit-one: {
    width: 35; height: 35
    style: {fill: "#0D6EFD"; stroke: "#0A58CA"; font: mono; font-size: 12; font-color: white; bold: true}
  }
  byte-header: {
    width: 60; height: 25
    style: {fill: "#E9ECEF"; stroke: "#ADB5BD"; font: mono; font-size: 9}
  }
  byte-data: {
    width: 60; height: 50
    style: {fill: "#BBDEFB"; stroke: "#1976D2"; font: mono; font-size: 10}
  }
  byte-highlight: {
    width: 60; height: 50
    style: {fill: "#FFC107"; stroke: "#997404"; stroke-width: 3; font: mono; font-size: 10; bold: true}
  }
}

# -----------------------------------------------------------------------------
# INTER-OBJECT CONNECTIONS
# -----------------------------------------------------------------------------
pipeline -> filter_container: "Write Access" {
  style: {stroke: "#0D6EFD"; stroke-width: 2; animated: true}
}
filter_container -> memory_layout: "Physical Map" {
  style: {stroke: "#6C757D"; stroke-dash: 2}
}

# -----------------------------------------------------------------------------
# TECHNICAL LEGEND
# -----------------------------------------------------------------------------
legend_box: "Technical Legend" {
  style: {fill: white; stroke: "#6C757D"}
  
  v1: "0 = Bit Clear (Initial State)" {class: bit-zero}
  v2: "1 = Bit Set (Occupied)" {class: bit-one}
  v3: "Critical Path / Hot Byte" {style: {fill: "#FFC107"; stroke: "#997404"; stroke-width: 2}}
}
legend_box.near: bottom-right