layout-engine: elk
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Message Filter Evaluation Pipeline
  Early exit at each stage for optimal throughput
| {
  near: top-center
  style: {
    font-size: 24
    bold: true
  }
}

direction: right

# Stage 1: Incoming Message
incoming: {
  shape: hexagon
  label: "Incoming\nMessage"
  style: {
    fill: "#E8F4FD"
    stroke: "#2196F3"
    stroke-width: 2
  }
}

# Stage 2: Bloom Filter Check
bloom_container: {
  label: "Stage 1: Bloom Filter"
  style: {
    fill: "#FFF3E0"
    stroke: "#FF9800"
    stroke-dash: 4
  }
  bloom_check: {
    shape: diamond
    label: "Bloom Filter\nCheck"
    style: {
      fill: "#FFE0B2"
      stroke: "#FF9800"
    }
  }
  bloom_hit: {
    label: "MIGHT match\n(continue)"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  bloom_miss: {
    label: "DEFINITELY NOT\n(early exit)"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
  bloom_reject: {
    shape: oval
    label: "REJECT\n~90% filtered"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  bloom_check -> bloom_hit: "Bits Set" {
    style: {
      stroke: "#4CAF50"
      font-color: "#2E7D32"
    }
  }
  bloom_check -> bloom_miss: "Bits Clear" {
    style: {
      stroke: "#F44336"
      font-color: "#C62828"
    }
  }
  bloom_miss -> bloom_reject
}

# Stage 3: Topic Hash Mask
hash_container: {
  label: "Stage 2: Topic Hash"
  style: {
    fill: "#E8F5E9"
    stroke: "#4CAF50"
    stroke-dash: 4
  }
  hash_check: {
    shape: diamond
    label: "Topic Hash\nMask Check"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  hash_match: {
    label: "Hash matches\n(continue)"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  hash_nomatch: {
    label: "Hash mismatch\n(early exit)"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
  hash_reject: {
    shape: oval
    label: "REJECT\n~5% additional"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  hash_check -> hash_match: "Mask & Hash ≠ 0" {
    style: {
      stroke: "#4CAF50"
      font-color: "#2E7D32"
    }
  }
  hash_check -> hash_nomatch: "Mask & Hash = 0" {
    style: {
      stroke: "#F44336"
      font-color: "#C62828"
    }
  }
  hash_nomatch -> hash_reject
}

# Stage 4: Predicate Evaluation
predicate_container: {
  label: "Stage 3: Predicate Evaluation"
  style: {
    fill: "#E3F2FD"
    stroke: "#2196F3"
    stroke-dash: 4
  }
  predicate_check: {
    shape: diamond
    label: "Filter\nPredicate"
    style: {
      fill: "#BBDEFB"
      stroke: "#2196F3"
    }
  }
  pred_pass: {
    label: "Predicate TRUE\n(deliver)"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  pred_fail: {
    label: "Predicate FALSE\n(early exit)"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
  pred_reject: {
    shape: oval
    label: "REJECT\n~5% additional"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
      stroke-width: 2
    }
  }
  predicate_check -> pred_pass: "filter(data)" {
    style: {
      stroke: "#4CAF50"
      font-color: "#2E7D32"
    }
  }
  predicate_check -> pred_fail: "!filter(data)" {
    style: {
      stroke: "#F44336"
      font-color: "#C62828"
    }
  }
  pred_fail -> pred_reject
}

# Final: Deliver
deliver: {
  shape: oval
  label: "DELIVER\nto subscriber"
  style: {
    fill: "#C8E6C9"
    stroke: "#4CAF50"
    stroke-width: 3
    shadow: true
  }
}

# Connections between stages
incoming -> bloom_container.bloom_check
bloom_container.bloom_hit -> hash_container.hash_check
hash_container.hash_match -> predicate_container.predicate_check
predicate_container.pred_pass -> deliver

# Flat Buffer Access Detail
flatbuffer_detail: {
  label: "Flat Buffer Field Access"
  style: {
    fill: "#F3E5F5"
    stroke: "#9C27B0"
  }
  note: |'cpp'
    // Zero-copy field access
    double price = view.price();      // ~5ns
    int32_t qty = view.quantity();    // ~5ns
    // Predicate example
    filter = [&](auto* data, size_t) {
      View view(data);
      return view.price() > 100.0 
          && view.quantity() > 0;
    };
  '|
}

# Performance annotations
perf_annotation: {
  near: bottom-center
  shape: text
  # Using Advanced Block Strings |' to handle the internal pipes in the Markdown table
  label: |'md'
    **Performance Characteristics:**
    | Stage | Latency | Filter Rate |
    |-------|---------|-------------|
    | Bloom Filter | <10 ns | ~90% rejected |
    | Topic Hash | <20 ns | ~5% additional |
    | Predicate | 50-200 ns | ~5% additional |
    | **Total (reject)** | **<30 ns** | **95%+ filtered** |
    | **Total (accept)** | **~250 ns** | Full pipeline |
  '|
}

# Legend
legend: {
  near: bottom-right
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
  }
  title: "Legend"
  early_exit: {
    shape: oval
    label: "Early Exit\n(rejected)"
    style: {
      fill: "#FFCDD2"
      stroke: "#F44336"
    }
  }
  continue: {
    shape: rectangle
    label: "Continue\n(passed)"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
    }
  }
  final: {
    shape: oval
    label: "Deliver"
    style: {
      fill: "#C8E6C9"
      stroke: "#4CAF50"
      stroke-width: 3
    }
  }
}