vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#5C9DC0"
    pointer: "#E8A54B"
    metadata: "#6B8E6B"
    padding: "#D3D3D3"
    highlight: "#E85D5D"
  }
}

title: |md
  # Retained Message Store Layout
  Zero-Copy Pub/Sub Implementation (zcmb-m4)
  *Internal Memory Alignment & Access Patterns*
| {near: top-center}

direction: right

classes: {
  header-cell: {
    style: {
      fill: "${colors.header}"
      stroke: "#6B4FB3"
      font-color: white
      bold: true
    }
  }
  data-cell: {
    style: {
      fill: "${colors.data}"
      stroke: "#3D7AA3"
      font-color: white
    }
  }
  pointer-cell: {
    style: {
      fill: "${colors.pointer}"
      stroke: "#C4852D"
      font-color: white
      font: mono
    }
  }
  metadata-cell: {
    style: {
      fill: "${colors.metadata}"
      stroke: "#4A6B4A"
      font-color: white
    }
  }
  padding-cell: {
    style: {
      fill: "${colors.padding}"
      stroke: "#A9A9A9"
      font-color: "#666666"
      italic: true
    }
  }
  highlight-cell: {
    style: {
      fill: "${colors.highlight}"
      stroke: "#B33A3A"
      font-color: white
      bold: true
    }
  }
}

map_container: "RetainedMessageStore" {
  style.fill: "#F5F0FA"
  style.stroke: "#9B7ED9"
  style.stroke-width: 2
  
  retained_map: "std::unordered_map<std::string, RetainedMessage*>" {
    style.fill: transparent
    style.stroke: "${colors.header}"
    
    header_row: {
      grid-columns: 3
      grid-gap: 0
      h1: "Topic Key (string)" {class: header-cell}
      h2: "Hash" {class: header-cell; width: 80}
      h3: "RetainedMessage*" {class: header-cell; width: 140}
    }
    entry_1: {
      grid-columns: 3
      grid-gap: 0
      topic1: "\"stocks/AAPL/price\"" {class: data-cell}
      hash1: "0x7A3F" {class: metadata-cell; width: 80}
      ptr1: "→ 0x1000" {class: pointer-cell; width: 140}
    }
    entry_2: {
      grid-columns: 3
      grid-gap: 0
      topic2: "\"orders/new\"" {class: data-cell}
      hash2: "0xB2E1" {class: metadata-cell; width: 80}
      ptr2: "→ 0x2000" {class: pointer-cell; width: 140}
    }
    entry_3: {
      grid-columns: 3
      grid-gap: 0
      topic3: "\"market/NYSE/#\"" {class: data-cell}
      hash3: "0x4D8C" {class: metadata-cell; width: 80}
      ptr3: "→ 0x3000" {class: pointer-cell; width: 140}
    }
  }
}

message_container: "RetainedMessage Pool (Arena Managed)" {
  style.fill: "#F0F5F0"
  style.stroke: "${colors.metadata}"
  style.stroke-width: 2
  
  msg_struct: "Memory Layout: sizeof=48 bytes" {
    style.fill: transparent
    style.stroke: "${colors.metadata}"
    
    msg_header: {
      grid-columns: 3
      grid-gap: 0
      lh0: "Offset" {class: header-cell; width: 60}
      lh1: "Field (Type)" {class: header-cell}
      lh2: "Value / Description" {class: header-cell}
    }
    
    msg_1: "msg_1 @ 0x1000" {
      grid-columns: 3
      grid-gap: 0
      
      o1: "+0x00" {class: pointer-cell; width: 60}
      f1: "data: vector<u8>" {class: data-cell}
      f1v: "[150.25, ...]" {class: data-cell; style.font: mono}
      
      o2: "+0x18" {class: pointer-cell; width: 60}
      f2: "timestamp: u64" {class: metadata-cell}
      f2v: "1697234567890" {class: metadata-cell; style.font: mono}
      
      o3: "+0x20" {class: pointer-cell; width: 60}
      f3: "hash: u32" {class: metadata-cell}
      f3v: "0x7A3F" {class: metadata-cell; style.font: mono}
      
      o4: "+0x24" {class: pointer-cell; width: 60}
      f4: "depth: u16" {class: metadata-cell}
      f4v: "3" {class: metadata-cell; style.font: mono}
      
      o5: "+0x26" {class: pointer-cell; width: 60}
      f5: "retain: bool" {class: metadata-cell}
      f5v: "true" {class: metadata-cell; style.font: mono}
      
      o6: "+0x27" {class: pointer-cell; width: 60}
      f6: "padding: u8" {class: padding-cell}
      f6v: "0x00 [ALIGN]" {class: padding-cell; style.font: mono}
    }
  }
}

flow_container: "Retained Delivery Flow" {
  style.fill: "#FFF5F0"
  style.stroke: "${colors.highlight}"
  style.stroke-width: 2
  style.stroke-dash: 3
  
  step1: "1. Subscriber Connect" {
    shape: rectangle
    class: highlight-cell
  }
  step2: "2. Check Pattern Type" {
    shape: diamond
    style.fill: "${colors.pointer}"
    style.stroke: "#C4852D"
    style.font-color: white
  }
  step3: "3a. EXACT: Topic Lookup" {
    shape: rectangle
    class: data-cell
  }
  step4: "3b. WILDCARD: Range Scan" {
    shape: rectangle
    class: metadata-cell
  }
  step5: "4. Found: Zero-Copy Copy" {
    shape: rectangle
    class: pointer-cell
  }
  
  step1 -> step2: "sub('stocks/AAPL/price')"
  step2 -> step3: "IsLiteral()"
  step2 -> step4: "IsPattern()"
  step3 -> step5: "Hash Map Hit"
  step4 -> step5: "Trie/Prefix Match"
}

# Connections
map_container.retained_map.entry_1.ptr1 -> message_container.msg_struct.msg_1: "Points to Struct" {
  style.stroke: "${colors.pointer}"
  style.stroke-width: 2
  style.animated: true
}

# Legend and Annotations
legend: {
  near: bottom-center
  grid-columns: 5
  grid-gap: 16
  l1: "Topic Data" {class: data-cell}
  l2: "Hash/Metadata" {class: metadata-cell}
  l3: "Pointer/Address" {class: pointer-cell}
  l4: "Execution Path" {class: highlight-cell}
  l5: "Alignment Padding" {class: padding-cell}
}

annotation: |md
  ### Implementation Notes (zcmb-m4)
  
  **1. Memory Alignment:**
  The `RetainedMessage` struct is aligned to 8-byte boundaries (64-bit). The trailing `padding: u8` 
  at `+0x27` ensures that an array of these structs remains aligned.
  
  **2. Key Complexity:**
  - **Literal Lookup:** `O(1)` average via `unordered_map`.
  - **Wildcard Scan:** `O(N)` where N is total retained count. For production, consider 
    a specialized Topic Trie to reduce scan time to `O(L)` where L is topic depth.
  
  **3. Concurrency:**
  - Access is governed by `std::shared_mutex`.
  - Literal lookups take a `shared_lock`.
  - Updates/Evictions take a `unique_lock`.
| {near: bottom-right}