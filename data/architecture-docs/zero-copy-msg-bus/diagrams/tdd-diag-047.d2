vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # Per-Topic Sequencing
  ## Ordering Guarantees in Zero-Copy Message Bus
| {near: top-center}
direction: right
# TopicSequencer Component
TopicSequencer: {
  label: "TopicSequencer"
  style.fill: "#E8D5B7"
  style.stroke: "#8B7355"
  style.stroke-width: 2
  style.border-radius: 8
  header: |md
    **Central Sequence Authority**
  | {
    style.fill: "#8B7355"
    style.font-color: white
    style.stroke: "#5D4E37"
  }
  global_sequence: {
    label: "global_sequence\natomic<uint64>"
    shape: hexagon
    style.fill: "#FFE4B5"
    style.stroke: "#CD853F"
    style.stroke-width: 2
  }
  topic_sequences: {
    label: "topic_sequences\nmap<hash, atomic<uint32>>"
    shape: cylinder
    style.fill: "#DEE1EB"
    style.stroke: "#7B839C"
    style.stroke-width: 2
  }
  global_sequence -- topic_sequences
}
# Message Header Structure
MessageHeader: {
  label: "Message Header\n(Per-Message Metadata)"
  style.fill: "#B5AFF6"
  style.stroke: "#6B5B95"
  style.stroke-width: 2
  style.border-radius: 8
  header_title: |md
    **Embedded in Each Message**
  | {
    style.fill: "#6B5B95"
    style.font-color: white
    style.stroke: "#4A3F6B"
  }
  global_seq: {
    label: "global_sequence: uint64\nMonotonic across ALL topics"
    shape: rectangle
    style.fill: "#E6E0F8"
    style.stroke: "#6B5B95"
  }
  topic_seq: {
    label: "topic_sequence: uint32\nMonotonic WITHIN topic"
    shape: rectangle
    style.fill: "#E6E0F8"
    style.stroke: "#6B5B95"
  }
  topic_hash: {
    label: "topic_hash: uint32\nFor quick topic lookup"
    shape: rectangle
    style.fill: "#E6E0F8"
    style.stroke: "#6B5B95"
  }
  timestamp: {
    label: "timestamp_ns: uint64\nCross-shard ordering"
    shape: rectangle
    style.fill: "#E6E0F8"
    style.stroke: "#6B5B95"
  }
  global_seq -- topic_seq -- topic_hash -- timestamp
}
# Sequence Generation Flow
TopicSequencer.global_sequence -> MessageHeader.global_seq: "fetch_add(1)\nrelaxed" {
  label: "Global\nCounter"
  style.stroke: "#CD853F"
  style.stroke-width: 2
  style.animated: true
}
TopicSequencer.topic_sequences -> MessageHeader.topic_seq: "fetch_add(1)\nper topic" {
  label: "Per-Topic\nCounter"
  style.stroke: "#7B839C"
  style.stroke-width: 2
  style.animated: true
}
# Ordering Scenarios
OrderingScenarios: {
  label: "Ordering Scenarios"
  style.fill: "#F0F4F8"
  style.stroke: "#5C7080"
  style.stroke-width: 2
  style.border-radius: 8
  scenario_title: |md
    **Sequencing Behavior**
  | {
    style.fill: "#5C7080"
    style.font-color: white
    style.stroke: "#3D4F5F"
  }
  within_topic: {
    label: "Within Same Topic\n──────────────\n• topic_sequence: 1, 2, 3, 4...\n• Strict FIFO ordering\n• Gap detection possible"
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#0891B2"
  }
  across_topics: {
    label: "Across Different Topics\n─────────────────────\n• global_sequence: monotonic\n• No total order guarantee\n• Timestamp for best-effort"
    shape: rectangle
    style.fill: "#C7F1FF"
    style.stroke: "#0891B2"
  }
  within_topic -- across_topics
}
# Topic Hash to Sequence Mapping
TopicMap: {
  label: "Topic Hash → Sequence Map"
  style.fill: "#E4DBFE"
  style.stroke: "#7C3AED"
  style.stroke-width: 2
  style.border-radius: 8
  map_title: |md
    **Internal State**
  | {
    style.fill: "#7C3AED"
    style.font-color: white
    style.stroke: "#5B21B6"
  }
  stocks_hash: {
    label: "hash(\"stocks/AAPL\")\n= 0x1A2B3C4D\n──────────────\nseq: 42"
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#7C3AED"
  }
  orders_hash: {
    label: "hash(\"orders/new\")\n= 0x5E6F7A8B\n──────────────\nseq: 17"
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#7C3AED"
  }
  market_hash: {
    label: "hash(\"market/data\")\n= 0x9C0D1E2F\n──────────────\nseq: 89"
    shape: rectangle
    style.fill: "#F3E8FF"
    style.stroke: "#7C3AED"
  }
  stocks_hash -- orders_hash -- market_hash
}
# Connections
TopicSequencer.topic_sequences -> TopicMap: "lookup" {
  style.stroke-dash: 3
  style.stroke: "#7C3AED"
}
TopicMap -> MessageHeader.topic_seq: "increment\n& return" {
  style.stroke: "#7C3AED"
  style.stroke-width: 2
}
# Gap Detection
GapDetection: {
  label: "Gap Detection"
  style.fill: "#FEE2E2"
  style.stroke: "#DC2626"
  style.stroke-width: 2
  style.border-radius: 8
  gap_title: |md
    **Consumer-Side Validation**
  | {
    style.fill: "#DC2626"
    style.font-color: white
    style.stroke: "#991B1B"
  }
  normal: {
    label: "Normal: 1 → 2 → 3 → 4"
    shape: text
    style.font-color: "#059669"
    style.bold: true
  }
  gap: {
    label: "Gap: 1 → 2 → ☠️ → 4\n(Missing seq 3!)"
    shape: text
    style.font-color: "#DC2626"
    style.bold: true
  }
  action: {
    label: "Action: Request retransmit\nor skip with warning"
    shape: text
    style.font-color: "#7C3AED"
  }
}
MessageHeader.topic_seq -> GapDetection: "Consumer\nvalidates" {
  style.stroke-dash: 3
  style.stroke: "#DC2626"
}
# Performance Note
PerformanceNote: |md
  **Performance Characteristics**
  • Global sequence: Single atomic counter
  • Per-topic: Hash map lookup + atomic increment
  • Lock-free on fast path
  • Memory: ~8 bytes per topic for sequence
| {
  near: bottom-center
  style.fill: "#FEF3C7"
  style.stroke: "#D97706"
  style.border-radius: 8
  style.stroke-width: 2
}