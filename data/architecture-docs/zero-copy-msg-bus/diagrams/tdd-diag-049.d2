vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header-bg: "#E8D5E8"
    data-bg: "#D5E8E8"
    free-bg: "#E8E8D5"
    padding-bg: "#D5D5D5"
    pointer-bg: "#E8D5B5"
    cache-line: "#FFE4B5"
  }
}

title: |md
  # Zero-Copy Message Bus
  ## System Architecture Spec v4.2
  *High-throughput inter-process messaging with sub-microsecond latency*
| {
  near: top-center
  style.stroke-width: 0
  style.font-size: 18
}

# ============== LAYER 1: APPLICATION ==============
layer1_app: "Layer 1: Application Space" {
  style.fill: "transparent"
  style.stroke-dash: 5
  
  producer_app: "Producer Process (Writer)" {
    style.fill: "${colors.data-bg}"
    style.double-border: true
    prod_code: |go
      // Zero-copy allocation in SHM
      slot := bus.NextSlot()
      builder := orders.NewBuilder(slot.Data)
      builder.SetSymbol("AAPL")
      builder.SetPrice(150.25)
      slot.Commit() // Atomic Release
    |
  }
  
  consumer_app: "Consumer Process (Reader)" {
    style.fill: "${colors.data-bg}"
    style.double-border: true
    cons_code: |go
      // Direct memory projection
      for {
        slot := bus.Poll() 
        view := orders.GetRootAsOrder(slot.Data)
        process(view.Price())
        slot.Release()
      }
    |
  }
}

# ============== LAYER 2: PUB/SUB ROUTING ==============
layer2_pubsub: "Layer 2: Pub/Sub Broker Logic" {
  style.fill: "transparent"
  
  topic_registry: "Topic Registry (Trie Structure)" {
    style.fill: "${colors.header-bg}"
    trie_structure: |md
      **Topic Namespace Map**
      root
      ├─ stocks (ID: 0x1)
      │  ├─ AAPL (ID: 0xA1)
      │  └─ MSFT (ID: 0xA2)
      └─ telemetry (ID: 0x2)
    |
    match_algo: "Match Algorithm" {
      label: "O(K) Trie Lookup"
      style.fill: "${colors.free-bg}"
    }
  }
  
  filter_engine: "Message Filter Engine" {
    style.fill: "${colors.header-bg}"
    bloom: "Bloom Filter (Fast-Reject)" {
      style.fill: "${colors.free-bg}"
    }
    predicate: "Bitmask Predicates" {
      style.fill: "${colors.free-bg}"
    }
  }
  
  subscriber_mgr: "Subscriber Session Manager" {
    style.fill: "${colors.header-bg}"
    cursor: "Subscriber Write Cursors" {
      style.fill: "${colors.free-bg}"
    }
    retained: "Retained Message Cache" {
      style.fill: "${colors.free-bg}"
    }
  }
}

# ============== LAYER 3: MPMC QUEUE ==============
layer3_mpmc: "Layer 3: MPMC Ring Buffer Implementation" {
  style.fill: "transparent"
  
  mpmc_header: "MPMC Header Control Block" {
    style.fill: "${colors.header-bg}"
    shape: sql_table
    field_head: "Head Pointer (Atomic64) | Offset 0x00" {constraint: PK}
    field_tail: "Tail Pointer (Atomic64) | Offset 0x40" {constraint: PK}
    field_cap: "Buffer Capacity (2ⁿ) | Offset 0x80"
    field_mask: "Slot Bitmask | Offset 0x88"
    field_gen: "Generation Epoch | Offset 0x90"
  }
  
  seq_array: "Atomic Sequence Array" {
    style.fill: "${colors.pointer-bg}"
    seq_desc: |md
      **Slot State Logic (Atomic64)**
      1. `seq == pos` : Slot Available (Empty)
      2. `seq == pos + 1` : Data Published (Ready)
      3. `seq == pos + cap` : Slot Recycled (Wrapped)
    |
  }
  
  slot_array: "Message Data Slots" {
    style.fill: "${colors.data-bg}"
    slot: "Physical Slots [0..N-1]" {
      style.multiple: true
      slot_header: "Header (32B Metadata)" {
        style.fill: "${colors.header-bg}"
      }
      slot_data: "Payload (FlatBuffer/SBE)" {
        style.fill: "${colors.data-bg}"
      }
    }
  }
}

# ============== LAYER 4: SHARED MEMORY ==============
layer4_shm: "Layer 4: Shared Memory Paging" {
  style.fill: "transparent"
  
  shm_layout: "Memory Segment Layout" {
    style.fill: "${colors.padding-bg}"
    offset_0: "0x000: RingBufferHeader Control" {
      style.fill: "${colors.header-bg}"
    }
    offset_100: "0x100: Sequence Atomic Index" {
      style.fill: "${colors.pointer-bg}"
    }
    offset_slots: "0x100 + (N * 8): Data Page" {
      style.fill: "${colors.data-bg}"
    }
  }
  
  process_view: "Virtual to Physical Mapping" {
    style.fill: "${colors.free-bg}"
    view_desc: |md
      **Shared Physical Page 0x12345**
      - Process A: 0x7f0000000 (RW)
      - Process B: 0x7f1000000 (RO)
      *Zero-copy via page table aliasing*
    |
  }
}

# ============== LAYER 5: CRASH RECOVERY ==============
layer5_recovery: "Layer 5: Recovery & Durability" {
  style.fill: "transparent"
  
  heartbeat: "Heartbeat & Liveness" {
    style.fill: "${colors.header-bg}"
    pid_gen: "Stale PID Detection" {
      style.fill: "${colors.free-bg}"
    }
  }
  
  orphan: "Lock-Free Reclaimer" {
    style.fill: "${colors.header-bg}"
    fence: "Memory Fence Barrier" {
      style.fill: "${colors.free-bg}"
    }
  }
  
  durability: "Persistence Engine" {
    style.fill: "${colors.header-bg}"
    wal: "Write-Ahead Log (O_DIRECT)" {
      style.fill: "${colors.free-bg}"
    }
    checkpoint: "State Snapshots" {
      style.fill: "${colors.free-bg}"
    }
  }
}

# ============== CONNECTIONS ==============

# Flow 1: Publication
layer1_app.producer_app -> layer2_pubsub.topic_registry: "1. publish(T, data)"
layer2_pubsub.topic_registry -> layer3_mpmc.mpmc_header: "2. reserve_slot()"
layer3_mpmc.mpmc_header -> layer3_mpmc.seq_array: "3. CAS update"

# Flow 2: Internal Mapping
layer3_mpmc.slot_array -> layer4_shm.shm_layout: "Hardware Mapping"
layer4_shm.shm_layout -> layer4_shm.process_view: "mmap()"

# Flow 3: Consumption
layer3_mpmc.seq_array -> layer2_pubsub.subscriber_mgr: "4. notify(pos)"
layer2_pubsub.subscriber_mgr -> layer1_app.consumer_app: "5. memory_ptr_delivered"

# Flow 4: Monitoring
layer5_recovery.heartbeat -> layer3_mpmc.mpmc_header: "Health Check"
layer5_recovery.orphan -> layer3_mpmc.seq_array: "Reset abandoned slots"
layer5_recovery.durability -> layer3_mpmc.slot_array: "Off-load to Disk"

# ============== ANNOTATIONS (Corrected for ELK) ==============

visibility_note: |md
  ### Memory Visibility Contract
  1. **Producer:** `fence(release)` before head update
  2. **Consumer:** `fence(acquire)` after head load
  3. **Atomic:** No locks; uses `MFENCE` on x86_64
| {
  near: top-right
  style.fill: "#F0F8FF"
  style.stroke: "#4682B4"
  style.font-size: 12
}

cache_note: |md
  ### Cache Line Alignment (64B)
  - **Head:** Offset 0x00 (CL 0)
  - **Tail:** Offset 0x40 (CL 1)
  - **Logic:** Prevents *False Sharing* between 
    Producer and Consumer cores.
| {
  near: bottom-right
  style.fill: "${colors.cache-line}"
  style.stroke: "#DAA520"
  style.font-size: 12
}

perf_note: |md
  **System Performance Targets (Intel Xeon Scalable):**
  - Median Latency: 120 ns
  - P99.9 Latency: < 800 ns  
  - Max Throughput: 15 Million msg/sec
| {
  near: bottom-center
  style.stroke-width: 0
  style.font-size: 14
  style.bold: true
}