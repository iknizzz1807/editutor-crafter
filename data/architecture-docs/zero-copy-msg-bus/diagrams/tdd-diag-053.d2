vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#5C9AD2"
    field: "#F5F5F5"
    text: "#333333"
    offset: "#666666"
  }
}
title: |md
  # WAL Entry Format
  **Write-Ahead Log Entry Layout (32-byte header)**
| {near: top-center}
# Container for the memory layout
entry_layout: {
  grid-rows: 8
  grid-columns: 1
  grid-gap: 0
  style.fill: transparent
  # Row 0: Magic (4 bytes)
  magic: {
    label: |md
      **magic** `uint32`
      `0xFEEDFACE`
    |
    style: {
      fill: ${colors.header}
      stroke: "#7B5FB9"
      font-color: white
      stroke-width: 2
    }
  }
  # Row 1: Entry Size (4 bytes)
  entry_size: {
    label: |md
      **entry_size** `uint32`
      Size of data payload (bytes)
    |
    style: {
      fill: ${colors.header}
      stroke: "#7B5FB9"
      font-color: white
      stroke-width: 2
    }
  }
  # Row 2: Sequence (8 bytes)
  sequence: {
    label: |md
      **sequence** `uint64`
      Monotonic sequence number
    |
    style: {
      fill: ${colors.header}
      stroke: "#7B5FB9"
      font-color: white
      stroke-width: 2
    }
  }
  # Row 3: Timestamp (8 bytes)
  timestamp: {
    label: |md
      **timestamp_ns** `uint64`
      Nanoseconds since epoch
    |
    style: {
      fill: ${colors.header}
      stroke: "#7B5FB9"
      font-color: white
      stroke-width: 2
    }
  }
  # Row 4: Checksum (4 bytes)
  checksum: {
    label: |md
      **checksum** `uint32`
      CRC32 of data payload
    |
    style: {
      fill: ${colors.header}
      stroke: "#7B5FB9"
      font-color: white
      stroke-width: 2
    }
  }
  # Row 5: Flags (4 bytes)
  flags: {
    label: |md
      **flags** `uint32`
      Entry type flags
    |
    style: {
      fill: ${colors.header}
      stroke: "#7B5FB9"
      font-color: white
      stroke-width: 2
    }
  }
  # Row 6: Divider
  divider: {
    label: ""
    height: 30
    style: {
      fill: transparent
      stroke: transparent
    }
  }
  # Row 7: Data payload
  data: {
    label: |md
      **data** `entry_size bytes`
      Message payload (FlatBuffer serialized)
    |
    style: {
      fill: ${colors.data}
      stroke: "#3C7AA2"
      font-color: white
      stroke-width: 2
      stroke-dash: 4
    }
  }
}
# Offset annotations (left side)
offsets: {
  grid-rows: 8
  grid-columns: 1
  grid-gap: 0
  style.fill: transparent
  o0: {
    label: "0x00"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  o4: {
    label: "0x04"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  o8: {
    label: "0x08"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  o16: {
    label: "0x10"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  o24: {
    label: "0x18"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  o28: {
    label: "0x1C"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  spacer: {
    label: ""
    height: 30
    style.fill: transparent
    style.stroke: transparent
  }
  o32: {
    label: "0x20"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
}
# Size annotations (right side)
sizes: {
  grid-rows: 8
  grid-columns: 1
  grid-gap: 0
  style.fill: transparent
  s4a: {
    label: "4 B"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  s4b: {
    label: "4 B"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  s8a: {
    label: "8 B"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  s8b: {
    label: "8 B"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  s4c: {
    label: "4 B"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  s4d: {
    label: "4 B"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
  spacer2: {
    label: ""
    height: 30
    style.fill: transparent
    style.stroke: transparent
  }
  svar: {
    label: "var"
    style: {
      fill: transparent
      font-color: ${colors.offset}
      font: mono
      font-size: 14
    }
  }
}
# Connect offsets to fields
offsets.o0 -> entry_layout.magic: {style.stroke: transparent}
offsets.o4 -> entry_layout.entry_size: {style.stroke: transparent}
offsets.o8 -> entry_layout.sequence: {style.stroke: transparent}
offsets.o16 -> entry_layout.timestamp: {style.stroke: transparent}
offsets.o24 -> entry_layout.checksum: {style.stroke: transparent}
offsets.o28 -> entry_layout.flags: {style.stroke: transparent}
offsets.o32 -> entry_layout.data: {style.stroke: transparent}
# Connect sizes to fields
entry_layout.magic -> sizes.s4a: {style.stroke: transparent}
entry_layout.entry_size -> sizes.s4b: {style.stroke: transparent}
entry_layout.sequence -> sizes.s8a: {style.stroke: transparent}
entry_layout.timestamp -> sizes.s8b: {style.stroke: transparent}
entry_layout.checksum -> sizes.s4c: {style.stroke: transparent}
entry_layout.flags -> sizes.s4d: {style.stroke: transparent}
entry_layout.data -> sizes.svar: {style.stroke: transparent}
# Legend box
legend: {
  label: |md
    ### Header Size: 32 bytes
    **Flags values:**
    - `0x01` MESSAGE
    - `0x02` CHECKPOINT_MARKER
    - `0x04` TRUNCATION_POINT
    - `0x08` END_OF_STREAM
  |
  near: bottom-center
  style: {
    fill: "#F8F8F8"
    stroke: "#CCCCCC"
    stroke-dash: 3
    border-radius: 8
  }
}