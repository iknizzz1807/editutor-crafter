shape: sequence_diagram
# Participants
producer
consumer
RingBuffer
WAL
# Initial setup
producer -> RingBuffer: attach()
consumer -> RingBuffer: attach()
# Phase 1: Publish with WAL logging
producer -> WAL: append(message_data)
producer <- WAL: sequence_number
producer -> WAL: sync() {
  style.stroke: green
}
# Phase 2: Write to ring buffer
producer -> RingBuffer: try_produce(message) {
  style.stroke: blue
  style.bold: true
}
RingBuffer -> RingBuffer: memcpy to slot
RingBuffer -> RingBuffer: release fence
RingBuffer -> RingBuffer: update head
# Phase 3: Consumer reads
consumer -> RingBuffer: try_desume() {
  style.stroke: orange
  style.bold: true
}
RingBuffer -> RingBuffer: acquire fence
consumer <- RingBuffer: message_data
# Phase 4: Acknowledge and WAL cleanup
consumer -> RingBuffer: subscriber_ack()
RingBuffer -> RingBuffer: ref_count.fetch_sub(1)
RingBuffer -> RingBuffer: if ref_count == 0 {
  style.stroke-dash: 5
}
producer <- RingBuffer: slot_reclaimed
producer -> WAL: truncate(sequence_number) {
  style.stroke: red
}
# Annotations
producer."At-least-once:\nConsumer must\ndeduplicate"
consumer."Process\ncrash here →\nWAL replay\non restart"