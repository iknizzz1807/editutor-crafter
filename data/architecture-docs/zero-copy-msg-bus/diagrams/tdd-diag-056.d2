direction: right
layout-engine: elk
theme-id: 4

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    header: "#9B7ED9"
    data: "#5C9AD2"
    metadata: "#6BC5A0"
    pointer: "#E8A45C"
    temp: "#E05555"
    final: "#5CAD5C"
    arrow: "#666666"
    padding: "#E0E0E0"
  }
}

title: |md
  # Checkpoint File Format (v1.0.0)
  ### Atomic Write via Temp File + Rename
  *Intel Manual Grade Specification*
| {
  near: top-center
}

# =============================================================================
# 1. FILE LAYOUT SPECIFICATION
# =============================================================================
checkpoint_file: "Checkpoint File Layout (sizeof=64B Header + Data)" {
  style.fill: "#FAFAFA"
  style.stroke: "#CCCCCC"
  style.stroke-width: 2

  header_section: "CheckpointHeader (64 bytes / One Cache Line)" {
    style.fill: "${colors.header}"
    style.stroke: "#7B5EB9"
    style.font-color: white
    style.stroke-dash: 5

    magic: "0x00: magic (4 bytes)\n0xFEEDFACE" {style.fill: "#8B6EC9"}
    version: "0x04: version (4 bytes)\nuint32" {style.fill: "#8B6EC9"}
    sequence: "0x08: sequence (8 bytes)\nWAL sequence (uint64)" {style.fill: "#8B6EC9"}
    timestamp: "0x10: timestamp_ns (8 bytes)\nuint64" {style.fill: "#8B6EC9"}
    num_entries: "0x18: num_entries (4 bytes)\nSubscriber count" {style.fill: "#8B6EC9"}
    ring_size: "0x1C: ring_state_size (4 bytes)" {style.fill: "#8B6EC9"}
    checksum: "0x20: checksum (4 bytes)\nCRC32 of data" {style.fill: "#8B6EC9"}
    padding: "0x24: padding (28 bytes)\nReserved for alignment" {style.fill: "${colors.padding}"; style.font-color: grey}

    magic -> version -> sequence -> timestamp -> num_entries -> ring_size -> checksum -> padding
  }

  data_section: "Data Section (Variable Alignment)" {
    style.fill: "${colors.data}"
    style.stroke: "#3C7AB2"

    ring_state: "Ring Buffer State\nOffset: 0x40" {
      style.fill: "#4C8AC2"
      style.font-color: white
      head: "head: uint64" {style.fill: "#3C7AB2"}
      tail: "tail: uint64" {style.fill: "#3C7AB2"}
      slots_bitmap: "slots_bitmap: byte[]" {style.fill: "#3C7AB2"}
      slot_data: "slot_data: byte[]" {style.fill: "#3C7AB2"}
    }

    subscriber_states: "Subscriber States\nSize: num_entries × 64B" {
      style.fill: "#4C8AC2"
      style.font-color: white
      sub_entry: "SubscriberCheckpointState" {
        style.fill: "#3C7AB2"
        sub_id: "subscriber_id: uint64"
        sub_offset: "current_offset: uint64"
        sub_count: "messages_received: uint64"
        sub_subs: "subscription_count: uint32"
        sub_pad: "padding: 36 bytes" {style.fill: "${colors.padding}"; style.font-color: grey}
      }
    }
  }

  header_section -> data_section: "Start Offset 0x40"
}

# =============================================================================
# 2. ATOMIC WRITE PROCESS
# =============================================================================
atomic_write: "Atomic Write Transactional Sequence" {
  style.fill: "#F5F5F5"
  style.stroke: "#999999"

  step1: "1. Create Temp File" {
    style.fill: "${colors.temp}"
    style.stroke: "#C04545"
    style.font-color: white
    temp_file: "/checkpoints/new.tmp" {
      shape: parallelogram
      style.fill: "#F8D0D0"
      style.stroke: "#C04545"
      style.font-color: black
    }
  }

  step2: "2. Write & Fsync" {
    style.fill: "${colors.metadata}"
    style.stroke: "#4BA580"
    style.font-color: white
    write_ops: {
      style.fill: "#D0E8DC"
      style.font-color: black
      write_header: "pwrite(fd, buf, 64, 0)"
      write_data: "pwrite(fd, data, len, 64)"
      fsync_file: "fsync(fd)"
      write_header -> write_data -> fsync_file
    }
  }

  step3: "3. Commit (Atomic Rename)" {
    style.fill: "${colors.final}"
    style.stroke: "#3C8A3C"
    style.font-color: white
    rename_op: "POSIX rename()" {
      style.fill: "#D0E8D0"
      style.stroke: "#3C8A3C"
      style.font-color: "#2C6A2C"
      style.bold: true
    }
    final_file: "/checkpoints/latest.ckpt" {
      shape: parallelogram
      style.fill: "#D0E8D0"
      style.stroke: "#3C8A3C"
      style.font-color: black
    }
    rename_op -> final_file
  }

  step1 -> step2: "O_CREAT | O_EXCL"
  step2 -> step3: "Descriptor Valid"
}

# =============================================================================
# 3. RECOVERY PROTOCOL
# =============================================================================
recovery_flow: "System Recovery & State Restoration" {
  style.fill: "#F8F8F8"
  style.stroke: "#AAAAAA"

  load_checkpoint: "Load Metadata" {
    style.fill: "${colors.header}"
    style.font-color: white
    find_latest: "opendir() -> Find newest .ckpt"
    validate_magic: "Verify 0xFEEDFACE"
    validate_checksum: "CRC32 Calculation"
    find_latest -> validate_magic -> validate_checksum
  }

  restore_state: "Memory Mapping" {
    style.fill: "${colors.data}"
    style.font-color: white
    restore_ring: "RingBuffer.Init(head, tail)"
    restore_subs: "SubscriberMap.Seek(offsets)"
    restore_ring -> restore_subs
  }

  continue_wal: "WAL Catch-up" {
    style.fill: "${colors.metadata}"
    style.font-color: white
    wal_replay: "WAL.replay(seq + 1)"
    apply_msgs: "Replay remaining ops"
    wal_replay -> apply_msgs
  }

  load_checkpoint -> restore_state: "Validation Pass"
  restore_state -> continue_wal: "Consistent State"
}

# =============================================================================
# 4. BYTE OFFSET REFERENCE TABLE (FIXED)
# =============================================================================
byte_offsets_table: {
  label: ||md
### Memory Layout Reference
| Offset | Size | Field | Type | Description |
|:---|:---|:---|:---|:---|
| 0x00 | 4 | magic | uint32 | 0xFEEDFACE |
| 0x04 | 4 | version | uint32 | File format version |
| 0x08 | 8 | sequence | uint64 | Last processed WAL ID |
| 0x10 | 8 | timestamp | uint64 | Unix Nanoseconds |
| 0x18 | 4 | ring_sz | uint32 | Ring buffer byte size |
| 0x1C | 4 | num_sub | uint32 | Count of sub entries |
| 0x20 | 4 | crc32 | uint32 | Checksum (Data only) |
| 0x24 | 28 | pad | byte[28] | Cache line alignment |
| 0x40 | N | ring_data | binary | Serialized Ring state |
| 0x40+N| M*64| sub_data | binary | Subscriber snapshots |
||
  near: bottom-center
  style.fill: white
  style.stroke: "#CCCCCC"
  style.stroke-width: 1
}

# =============================================================================
# GLOBAL ARCHITECTURE MAPPINGS
# =============================================================================
checkpoint_file -> atomic_write: "Persistence Pattern" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 2
}
atomic_write -> recovery_flow: "Restoration Path" {
  style.stroke: "${colors.arrow}"
  style.stroke-width: 2
}