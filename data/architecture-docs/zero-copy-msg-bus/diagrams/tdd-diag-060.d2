vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  colors: {
    decision: "#FFF3E0"
    action: "#E3F2FD"
    check: "#E8F5E9"
    data: "#F3E5F5"
  }
}
title: |md
  # At-Least-Once Deduplication Algorithm
  Consumer-side message deduplication for idempotent processing
| {near: top-center}
direction: down
classes: {
  decision: {
    shape: diamond
    style: {
      fill: ${colors.decision}
      stroke: "#E65100"
      stroke-width: 2
    }
    width: 160
    height: 100
  }
  action: {
    shape: rectangle
    style: {
      fill: ${colors.action}
      stroke: "#1565C0"
      stroke-width: 2
      border-radius: 8
    }
  }
  check: {
    shape: rectangle
    style: {
      fill: ${colors.check}
      stroke: "#2E7D32"
      stroke-width: 2
      border-radius: 8
    }
  }
  data: {
    shape: cylinder
    style: {
      fill: ${colors.data}
      stroke: "#7B1FA2"
      stroke-width: 2
    }
  }
}
start: "① RECEIVE MESSAGE" {
  class: action
  style: {
    fill: "#FFEB3B"
    stroke: "#F57F17"
  }
}
step1: "② EXTRACT MESSAGE ID\nmessage.header.sequence" {
  class: action
}
processed_set: "processed_ids\n(Set<uint64_t>)" {
  class: data
}
check_exists: "③ ID IN SET?" {
  class: decision
}
skip: "④ SKIP\n(Duplicate)" {
  class: action
  style: {
    fill: "#FFCDD2"
    stroke: "#C62828"
  }
}
process: "⑤ PROCESS MESSAGE\nhandle_message(msg)" {
  class: action
  style: {
    fill: "#C8E6C9"
    stroke: "#2E7D32"
  }
}
add_to_set: "⑥ ADD ID TO SET\nprocessed_ids.insert(msg.id)" {
  class: action
}
check_full: "⑦ SET FULL?\nsize > MAX_PROCESSED" {
  class: decision
}
evict: "⑧ EVICT OLD ENTRIES\nremove oldest MAX/2" {
  class: action
  style: {
    fill: "#FFE0B2"
    stroke: "#E65100"
  }
}
done: "⑨ COMPLETE" {
  class: action
  style: {
    fill: "#B2DFDB"
    stroke: "#00695C"
  }
}
annotation: |md
  **Deduplication Logic:**
  - Uses monotonic sequence numbers from WAL
  - Set stores last N processed message IDs
  - MAX_PROCESSED typically 100K-1M entries
  - LRU eviction when set exceeds threshold
  - **No false negatives** - if ID in set, definitely processed
  - Duplicates possible if set overflow occurred
| {
  near: bottom-right
  shape: rectangle
  style: {
    fill: "#FAFAFA"
    stroke: "#9E9E9E"
    border-radius: 8
    stroke-dash: 3
  }
}
code_example: |go
  // Consumer deduplication
  func (c *Consumer) receive(msg *Message) {
      id := msg.Header.Sequence
      // Check if already processed
      if c.processedIDs.Contains(id) {
          log.Debug("skipping duplicate", "id", id)
          return
      }
      // Process message
      c.handler.Handle(msg)
      // Record as processed
      c.processedIDs.Add(id)
      // Evict old entries if needed
      if c.processedIDs.Size() > MaxProcessed {
          c.processedIDs.EvictOldest(MaxProcessed / 2)
      }
  }
| {
  near: bottom-left
  shape: rectangle
  style: {
    fill: "#263238"
    font-color: "#ECEFF1"
    font: mono
    border-radius: 8
  }
}
start -> step1
step1 -> check_exists
processed_set -> check_exists
check_exists -> skip: "YES"
check_exists -> process: "NO"
skip -> done
process -> add_to_set
add_to_set -> check_full
check_full -> evict: "YES"
check_full -> done: "NO"
evict -> done