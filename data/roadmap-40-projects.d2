direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: {
  shape: rectangle
  label: "40 Projects — Roadmap Kỹ Sư Không Thể Thay Thế"
  style.fill: "#1a1a2e"
  style.stroke: "#4a9eff"
  style.font-color: "#ffffff"
  style.font-size: 18
  style.bold: true
}

checkpoints: {
  shape: sql_table
  label: "Milestone Checkpoints"
  p1: "Phase 1-2  (10) | Mid-level        | Backend @ startup/mid-size"
  p2: "Phase 1-4  (19) | Senior           | Senior backend, infra engineer"
  p3: "Phase 1-6  (30) | Senior @ BigTech | Google L5, Meta E5, systems"
  p4: "Phase 1-7  (36) | Senior + ML Infra | NVIDIA, ML infra @ big tech"
  p5: "Full 40         | Staff-level      | Staff/Principal, HFT"
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  phase1: {
    direction: down
    label: "Phase 1 — Nền Tảng"
    style.fill: "#0d1b2a"
    style.stroke: "#4a9eff"

    p1: {
      shape: sql_table
      label: "4 Projects | 2-3 tuần"
      r1: "1  | tokenizer         | Parsing mindset, máy tính đọc code"
      r2: "2  | hash-impl         | Bit manipulation, crypto primitives"
      r3: "3  | http-server-basic | TCP, sockets, request/response"
      r4: "4  | build-event-loop  | epoll, async I/O, non-blocking"
    }
  }

  phase2: {
    direction: down
    label: "Phase 2 — OS & Systems"
    style.fill: "#0d1b2a"
    style.stroke: "#7c3aed"

    p2: {
      shape: sql_table
      label: "6 Projects | 6-8 tuần"
      r1: "5  | build-strace       | Syscall tracing, kernel-userspace"
      r2: "6  | build-kernel-module| Code chạy trong kernel space"
      r3: "7  | container-basic    | Namespaces, cgroups, bản chất Docker"
      r4: "8  | filesystem         | Inodes, blocks, VFS"
      r5: "9  | virtual-memory-sim | Page tables, TLB, page faults"
      r6: "10 | build-shell        | Job control, piping, signals"
    }
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  phase3: {
    direction: down
    label: "Phase 3 — Networking & Observability"
    style.fill: "#0d1b2a"
    style.stroke: "#059669"

    p3: {
      shape: sql_table
      label: "4 Projects | 3-4 tuần"
      r1: "11 | message-queue     | Async patterns, pub/sub, persistence"
      r2: "12 | build-ebpf-tracer | eBPF, kernel tracing, observability"
      r3: "13 | build-tcp-stack   | TCP/IP từ zero"
      r4: "14 | profiler-tool     | CPU sampling, flame graphs, perf"
    }
  }

  phase4: {
    direction: down
    label: "Phase 4 — Language & Data Internals"
    style.fill: "#0d1b2a"
    style.stroke: "#d97706"

    p4: {
      shape: sql_table
      label: "5 Projects | 5-6 tuần"
      r1: "15 | bytecode-vm      | Compile → bytecode → interpret"
      r2: "16 | build-linker     | Symbol resolution, ELF format"
      r3: "17 | wal-impl         | Write-Ahead Log, crash recovery"
      r4: "18 | vector-database  | ANN search, embedding storage"
      r5: "19 | query-optimizer  | Cost-based planning, index selection"
    }
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  phase5: {
    direction: down
    label: "Phase 5 — Distributed Systems"
    style.fill: "#0d1b2a"
    style.stroke: "#dc2626"

    p5: {
      shape: sql_table
      label: "3 Projects | 4-5 tuần"
      r1: "20 | gossip-protocol   | Epidemic broadcast, self-healing"
      r2: "21 | distributed-cache | Consistent hashing, invalidation"
      r3: "22 | build-raft        | Consensus — distributed holy grail"
    }
  }

  phase6: {
    direction: down
    label: "Phase 6 — Performance & Nanosecond"
    style.fill: "#0d1b2a"
    style.stroke: "#ea580c"

    p6: {
      shape: sql_table
      label: "8 Projects | 8-12 tuần"
      r1: "23 | memory-pool              | Custom allocator, fragmentation"
      r2: "24 | simd-library             | CPU vectorization, instruction-level"
      r3: "25 | cache-optimized-structures| Cache line, prefetch, struct layout"
      r4: "26 | lock-free-structures     | CAS, atomics, concurrency no lock"
      r5: "27 | coroutine-runtime-engine | M:N scheduler, Go-style runtime"
      r6: "28 | io-uring-server          | Zero-syscall async I/O"
      r7: "29 | kernel-bypass-network-stack| DPDK-style, ~ns latency"
      r8: "30 | zero-copy-msg-bus        | Eliminate memcpy, IPC max speed"
    }
  }
}

row4: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  phase7: {
    direction: down
    label: "Phase 7 — AI/ML Infrastructure"
    style.fill: "#0d1b2a"
    style.stroke: "#7c3aed"

    p7: {
      shape: sql_table
      label: "6 Projects | 8-10 tuần"
      r1: "31 | neural-network-basic      | Backprop từ zero"
      r2: "32 | transformer-scratch       | Attention, hiểu LLM từ gốc"
      r3: "33 | build-gpu-compute         | CUDA programming, NVIDIA"
      r4: "34 | tensor-quantization-engine| INT8/FP16, model optimization"
      r5: "35 | ml-model-serving          | Serving, batching, KV-cache"
      r6: "36 | distributed-training-framework| Multi-GPU, gradient sync"
    }
  }

  phase8: {
    direction: down
    label: "Phase 8 — Capstone"
    style.fill: "#0d1b2a"
    style.stroke: "#4a9eff"

    p8: {
      shape: sql_table
      label: "4 Projects | 8-10 tuần"
      r1: "37 | build-redis  | Network server + data structures + persistence"
      r2: "38 | build-docker | Container runtime từ zero"
      r3: "39 | build-os     | Full OS kernel, scheduler, syscalls"
      r4: "40 | build-jit    | JIT compiler, generate native code"
    }
  }
}

tracks: {
  shape: sql_table
  label: "Dependency Tracks"
  t1: "Parsing       | tokenizer(1) → bytecode-vm(15) → build-jit(40)"
  t2: "Networking    | http-server(3) → build-ebpf(12) → tcp-stack(13) → kernel-bypass(29)"
  t3: "Async         | event-loop(4) → io-uring(28) → coroutine-runtime(27)"
  t4: "Memory        | virtual-mem(9) → memory-pool(23) → build-os(39)"
  t5: "Container     | container-basic(7) → build-docker(38)"
  t6: "Distributed   | gossip(20) → dist-cache(21) → build-raft(22)"
  t7: "ML Systems    | neural-net(31) → transformer(32) → gpu-compute(33) → ml-serving(35) → dist-training(36)"
  t8: "Performance   | hash-impl(2) → simd(24) → cache-opt(25) → zero-copy(30)"
  t9: "Observability | build-strace(5) → build-ebpf(12) → profiler(14)"
}

title -> row1
row1 -> row2
row2 -> row3
row3 -> row4
row4 -> tracks
row4 -> checkpoints
