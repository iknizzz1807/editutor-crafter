direction: down

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 5
  }
}

title_gossip: |md
  # Gossip Protocol for Cluster State
  | {near: top-center}

gossip_explanation: {near: top-center}
gossip_explanation: |md
  Nodes exchange PING/PONG every ``Gossip_Interval`` ms (default: 500ms)
  to propagate topology and detect failures. Failure confirmed after
  ``NodeTimeout`` ms without pong (default: 15000ms).
| {near: top-center}

network_layer: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  node_a: Node A (10.0.0.1:6379) {
    shape: rectangle
    style.fill: "#E8F4FD"
    style.stroke: "#2196F3"
    style.stroke-width: 2

    gossip_state_a: {
      shape: sql_table
      label: "ClusterNode A"
      n0: "node_id | str[40] | \"A1B2...\""
      n1: "ip | str[46] | \"10.0.0.1\""
      n2: "port | int16 | 6379"
      n3: "flags | uint8 | MASTER"
      n4: "ping_sent | time_t | 0"
      n5: "pong_recv | time_t | 0"
      n6: "fail_time | time_t | -1"
      n7: "slot_start | uint16 | 0"
      n8: "slot_end | uint16 | 5460"
      n9: "known_nodes[] | [B,C] | size:2"
    }

    state_exchange_a: {
      shape: sql_table
      label: "Gossip State (outbound)"
      ge0: "myself | ClusterNode* | A's info"
      ge1: "known_nodes[5] | [A,B,C,D,E] | sample 5"
      ge2: "importing_slots[] | uint16[] | in-progress"
      ge3: "migrating_slots[] | uint16[] | in-progress"
      ge4: "epoch | uint64 | monotonic"
    }
  }

  node_b: Node B (10.0.0.2:6379) {
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2

    gossip_state_b: {
      shape: sql_table
      label: "ClusterNode B"
      g0: "node_id | str[40] | \"B3C4...\""
      g1: "ip | str[46] | \"10.0.0.2\""
      g2: "port | int16 | 6379"
      g3: "flags | uint8 | MASTER"
      g4: "ping_sent | time_t | 0"
      g5: "pong_recv | time_t | 0"
      g6: "fail_time | time_t | -1"
      g7: "slot_start | uint16 | 5461"
      g8: "slot_end | uint16 | 10921"
      g9: "known_nodes[] | [A,C] | size:2"
    }
  }

  node_c: Node C (10.0.0.3:6379) {
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2

    gossip_state_c: {
      shape: sql_table
      label: "ClusterNode C"
      hc0: "node_id | str[40] | \"C5D6...\""
      hc1: "ip | str[46] | \"10.0.0.3\""
      hc2: "port | int16 | 6379"
      hc3: "flags | uint8 | REPLICA"
      hc4: "ping_sent | time_t | 0"
      hc5: "pong_recv | time_t | 0"
      hc6: "fail_time | time_t | -1"
      hc7: "slot_start | uint16 | 5461"
      hc8: "slot_end | uint16 | 10921"
      hc9: "known_nodes[] | [B] | size:1"
    }
  }
}

ping_pong_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  node_a.ping_timer -> node_a.ping_send: "Gossip_Interval"
  ping_timer: "Interval Timer" {
    shape: circle
    style.fill: "#E3F2FD"
  }
  ping_send: "Send PING" {
    shape: step
    style.fill: "#BBDEFB"
  }
  ping_payload: {
    shape: sql_table
    label: "PING Payload (~42 bytes)"
    p0: "msg_type | uint8 | 0x40 (PING)"
    p1: "sender | node_id | \"A1B2...\""
    p2: "config_epoch | uint64 | epoch_num"
    p3: "slot_map | bitmap | 16384 bits"
    p4: "gossip[] | GossipEntry[5] | state deltas"
  }
  pong_response: "PONG Response" {
    shape: step
    style.fill: "#C8E6C9"
  }
  pong_payload: {
    shape: sql_table
    label: "PONG Payload (~42 bytes)"
    r0: "msg_type | uint8 | 0x41 (PONG)"
    r1: "sender | node_id | \"B3C4...\""
    r2: "config_epoch | uint64 | epoch_num"
    r3: "slot_map | bitmap | 16384 bits"
    r4: "gossip[] | GossipEntry[5] | state deltas"
  }
  pong_recv: "Receive PONG" {
    shape: step
    style.fill: "#A5D6A7"
  }
  state_update: "Update Local State" {
    shape: step
    style.fill: "#81C784"
  }
}

gossip_entry_detail: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ge_detail: {
    shape: sql_table
    label: "GossipEntry (~12 bytes)"
    ge0: "node_id | str[40] | target node"
    ge1: "ping_sent | time_t | last ping"
    ge2: "pong_recv | time_t | last pong"
    ge3: "fail_time | time_t | if failed"
    ge4: "flags | uint16 | PFAIL/FAIL"
    note: "5 entries per PING: samples random nodes"
  }

  failure_detection: {
    shape: sql_table
    label: "Failure Detection State"
    fd0: "Gossip_Interval | 500ms | ping cadence"
    fd1: "NodeTimeout | 15000ms | fail threshold"
    fd2: "fail_reports | int | other nodes flagging"
    fd3: "min_fail_reports | 3 | quorum needed"
    fd4: "PFAIL -> FAIL | after quorum"
    fd5: "FAIL -> REMOVE | after NodeTimeout*2"
    note: "PFAIL: possibly failing, FAIL: confirmed"
  }
}

message_flow_legend: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  legend_ping: PING -> PONG {
    style.stroke: "#2196F3"
    style.stroke-width: 2
  }
  legend_state: State Delta {
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    style.animated: true
  }
  legend_fail: Failure Flag {
    style.stroke: "#F44336"
    style.stroke-dash: 4
  }
  legend_note: "Dashed = failure path"
}

topology_propagation: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  topo_step1: {
    label: "T=0ms: A knows B,C"
    shape: circle
    style.fill: "#E8F4FD"
  }
  topo_step2: {
    label: "T=500ms: B knows C (via A gossip)"
    shape: circle
    style.fill: "#E8F5E9"
  }
  topo_step3: {
    label: "T=1000ms: C knows A,B (full mesh converge)"
    shape: circle
    style.fill: "#FFF3E0"
  }
  topo_step4: {
    label: "T=1500ms: Topology converged"
    shape: diamond
    style.fill: "#C8E6C9"
  }

  time_flow: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    t0: T+0
    t1: T+500
    t2: T+1000
    t3: T+1500
  }
}

convergence_flow: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  step1: T=0 "A has 2 nodes" {
    shape: circle
    style.fill: "#E3F2FD"
  }
  step2: T=500 "A->B, B learns C" {
    shape: circle
    style.fill: "#B3E5FC"
  }
  step3: T=1000 "B->C, C learns A,B" {
    shape: circle
    style.fill: "#81D4FA"
  }
  step4: T=1500 "All 3 nodes have full view" {
    shape: diamond
    style.fill: "#4CAF50"
  }
}

node_a.ping_send -> node_b.gossip_state_b: "PING"
node_a.ping_send -> node_c.gossip_state_c: "PING"
node_b.pong_response -> node_a.state_update: "PONG + state"
node_c.pong_response -> node_a.state_update: "PONG + state"
node_b.ping_send -> node_a.gossip_state_a: "PING"
node_c.ping_send -> node_b.gossip_state_b: "PING"
node_a.pong_response -> node_b.state_update: "PONG + state"
node_a.pong_response -> node_c.state_update: "PONG + state"

topology_step1 -> topology_step2: "Gossip Delta"
topology_step2 -> topology_step3: "Gossip Delta"
topology_step3 -> topology_step4: "Converged"

ping_payload -> ge_detail: "Contains"
gossip_entry_detail -> failure_detection: "Failure detection"
ping_pong_flow.state_update -> ge_detail: "Updates"
failure_detection -> node_a.gossip_state_a: "Updates node flags"