row3: "" {
  style.stroke: transparent
  style.fill: transparent
  
  ins_detail: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    ins_code: |c
      // Insert time event
      int schedule_at_ms = now + delay;
      min_heap_push(timers, cb, schedule_at_ms);
      // Calculate next deadline
      int next_ms = timers->min - now;
    | {
      width: 340
      style.fill: "#F8F9FA"
      style.stroke: ${gray}
      style.stroke-dash: 3
    }
  }
  
  gap5: "" { style.stroke: transparent; style.fill: transparent; width: 60 }
  
  poll_detail: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    poll_code: |c
      // epoll_wait with timeout
      next_ms = get_next_timer_delta();
      ready = epoll_wait(ep, evs, MAX, next_ms);
      // evs[] = ready I/O, timeout = time event
    | {
      width: 340
      style.fill: "#F8F9FA"
      style.stroke: ${gray}
      style.stroke-dash: 3
    }
  }
  
  gap6: "" { style.stroke: transparent; style.fill: transparent; width: 60 }
  
  fire_detail: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    fire_code: |c
      // Fire expired timers
      while (timers->min <= now) {
        Timer* t = min_heap_pop(timers);
        t->callback(t->data);
        if (t->repeat_ms > 0) {
          t->when = now + t->repeat_ms;
          min_heap_push(timers, t);
        }
      }
    | {
      width: 340
      style.fill: "#FFF5F5"
      style.stroke: ${red}
      style.stroke-dash: 3
    }
  }
}

explanation: |md
  ### Three-Phase Time Event Lifecycle
  
  **1. INSERT**: Callbacks are scheduled with `schedule_at_ms`. Inserted into min-heap
  sorted by expiration time. Next deadline is cached.
  
  **2. POLL**: Event loop calls `epoll_wait` with timeout = `next_timer_delta`.
  When timeout fires, the event loop processes all expired time events.
  
  **3. FIRE**: Expired timers are popped from heap and their callbacks executed.
  If repeating, they are reinserted with new deadline.
| {near: bottom-center}

timewheel_diagram: { direction: right; near: ins_label; tooltip: |md
  ### Min-Heap (Priority Queue)
  
  - O(log n) insert
  - O(1) min lookup
  - O(log n) delete
  - Used by: Linux timerfd, BSD kqueue fallback
| }

min_heap_structure: "" {
  direction: down
  near: explanation
  tooltip: |md
    ### Min-Heap Structure
  
    - Binary heap keyed by `when` (Unix timestamp ms)
    - Parent at index `(i-1)/2`
    - Children at `2*i+1` and `2*i+2`
    - Root = earliest expiration
  |
  
  heap_label: "Min-Heap Timer Queue" {
    shape: text
    style.font-size: 24
    style.bold: true
    style.underline: true
  }
  
  heap_diagram: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    slot_0: "" {
      label: "[0] Timer_0 (earliest)"
      shape: rectangle
      style.fill: ${red}
      style.font-color: white
      width: 140
      height: 44
    }
    
    slot_1: "" {
      label: "[1] Timer_1"
      shape: rectangle
      style.fill: ${purple}
      style.font-color: white
      width: 140
      height: 44
    }
    
    slot_2: "" {
      label: "[2] Timer_2"
      shape: rectangle
      style.fill: ${purple}
      style.font-color: white
      width: 140
      height: 44
    }
    
    slot_3: "" {
      label: "[3] Timer_3"
      shape: rectangle
      style.fill: ${blue}
      style.font-color: white
      width: 140
      height: 44
    }
    
    slot_4: "" {
      label: "[4] Timer_4"
      shape: rectangle
      style.fill: ${blue}
      style.font-color: white
      width: 140
      height: 44
    }
    
    slot_5: "" {
      label: "[5] Timer_5"
      shape: rectangle
      style.fill: ${blue}
      style.font-color: white
      width: 140
      height: 44
    }
  }
  
  heap_edges: "" {
    style.stroke: ${gray}
    style.stroke-width: 1
    
    "slot_0" -> "slot_1": "left child"
    "slot_0" -> "slot_2": "right child"
    "slot_1" -> "slot_3": "left child"
    "slot_1" -> "slot_4": "right child"
    "slot_2" -> "slot_5": "left child"
  }
  
  heap_note: |md
    ```
    parent(i) = (i-1)/2
    left(i)   = 2*i+1
    right(i)  = 2*i+2
    ```
    
    **Properties:**
    - Timer[0] = earliest expiration
    - Each parent <= its children
    - O(log n) heapify after insert/delete
  | {
    shape: text
    style.font-size: 16
    style.italic: true
    width: 200
  }
}

structs: "" {
  direction: down
  near: min_heap_structure
  
  timer_struct: "" {
    shape: sql_table
    label: "struct Timer (reactor.h)"
    
    f0: "0x00 | const char*  | name"
    f1: "0x08 | uint64_t    | when_ms     // Unix timestamp"
    f2: "0x10 | uint64_t    | interval   // 0 = one-shot"
    f3: "0x18 | void*      | data       // user data"
    f4: "0x20 | TimerFn    | callback"
    f5: "0x28 | Timer*      | prev"
    f6: "0x30 | Timer*      | next"
    f7: "0x38 | int        | refcount"
    sz: "64 bytes (cache-line aligned)"
  }
  
  timer_fn: "" {
    shape: class
    label: "TimerFn Callback Type"
    
    +typedef: "typedef void (*TimerFn)(void* data)"
    +example_cb: "|c
       void my_expire_check(void* ctx) {
         RedisServer* s = ctx;
         expire_keys(s);  // Active expiration
       }
     |"
  }
  
  timer_heap: "" {
    shape: sql_table
    label: "struct TimerHeap (reactor.h)"
    
    f0: "0x00 | Timer**   | slots     // heap array"
    f1: "0x08 | size_t    | len       // current count"
    f2: "0x10 | size_t    | capacity  // allocated"
    f3: "0x18 | uint64_t  | min_when  // cached min for O(1)"
    sz: "32 bytes"
  }
}

