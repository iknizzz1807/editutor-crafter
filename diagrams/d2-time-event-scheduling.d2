      width: 100
      height: 60
    }
    
    step4: "" {
      label: "4. PROCESS I/O"
      shape: rectangle
      style.fill: ${light-yellow}
      style.stroke: ${yellow}
      width: 100
      height: 60
    }
    
    step5: "" {
      label: "5. FIRE TIMERS"
      shape: rectangle
      style.fill: "#FFE8CC"
      style.stroke: ${red}
      width: 100
      height: 60
    }
    
    step6: "" {
      label: "6. REPEAT"
      shape: rectangle
      style.fill: ${light-blue}
      style.stroke: ${blue}
      width: 100
      height: 60
    }
  }
  
  loop_code: |c
    void event_loop_run(EventLoop* loop) {
      loop->running = true;
      
      while (loop->running) {
        // Calculate next timer deadline
        int timeout_ms = timerheap_min_delta(loop->timers);
        
        // Wait for I/O or timer
        int n = epoll_wait(loop->epoll_fd,
                        loop->events,
                        MAX_EVENTS,
                        timeout_ms);
        
        // Process ready I/O events
        for (int i = 0; i < n; i++) {
          handle_io_event(loop, loop->events[i]);
        }
        
        // Fire expired timers
        uint64_t now = get_current_time_ms();
        timerheap_fire_expired(loop->timers, now);
      }
    }
  | {
    shape: text
    style.font-size: 16
    width: 500
  }
}

expiration_integration: "" {
  direction: right
  near: event_loop_integration
  
  expire_label: "Expiration Time Events" {
    shape: text
    style.font-size: 24
    style.bold: true
    style.underline: true
  }
  
  expire_diagram: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    active_expire: "" {
      label: "Active Expiration (timer)"
      shape: rectangle
      style.fill: "#FFE8CC"
      style.stroke: ${red}
      style.stroke-dash: 5
      width: 200
      
      desc: |c
        // Runs every 100ms
        timer_t* expire_timer = timer_new();
        expire_timer->callback = active_expire_cb;
        expire_timer->interval = 100;
        timer_schedule(expire_timer);
      |
    }
    
    lazy_expire: "" {
      label: "Lazy Expiration (on GET)"
      shape: rectangle
      style.fill: ${light-blue}
      style.stroke: ${blue}
      style.stroke-dash: 5
      width: 200
      
      desc: |c
        void command_get(Client* c, ...) {
          RedisObject* obj = dict_fetch(key);
          if (obj && obj->expire_at != -1
              && obj->expire_at <= now) {
            dict_delete(key);  // Delete expired
            return NULL;
          }
        }
      |
    }
  }
  
  expire_note: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    note1: "" {
      shape: text
      label: "Active: O(1) per cycle\nScans sample of keys"
      style.font-size: 16
      style.italic: true
      width: 180
    }
    
    note2: "" {
      shape: text
      label: "Lazy: O(1) on access\nCleans on read"
      style.font-size: 16
      style.italic: true
      width: 180
    }
  }
}

active_expire_detail: |c
  void active_expire_cb(void* ctx) {
    RedisServer* server = ctx;
    
    // Sample up to RUNAME keys per cycle
    for (int i = 0; i < ACTIVE_EXPIRE_SAMPLES; i++) {
      sds key = get_random_key(server->db);
      if (!key) break;
      
      RedisObject* obj = dict_fetch(server->db, key);
      if (obj && obj->expire_at != -1
          && obj->expire_at <= server->current_time) {
        dict_delete(server->db, key);
        server->expired_count++;
      }
    }
    
    // Update current time for lazy check
    server->current_time = get_current_time_ms();
  }
| {
  shape: text
  near: expiration_integration
  tooltip: |md
    ### Active Expiration Strategy
  
    - Samples a fixed number of keys per cycle
    - Redis uses 20 keys/cycle
    - If >25% expired, immediately resample
    - Combined with lazy expiration on access
  |
  style.font-size: 16
  width: 380
}

