    }

    o1_callout: "" {
      label: "Ptr update: O(1) — 4 writes only, no element moves"
      shape: callout
      style.fill: "#D4EDDA"
      style.stroke: "#28a745"
      style.font-color: "#15C724"
      style.font-size: 14
