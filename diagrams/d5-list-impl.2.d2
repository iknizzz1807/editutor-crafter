direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-Id: 4
  }
}
title: |md
  # List Implementation: Doubly-Linked vs Array
| {near: top-center}

row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  problem_ann: "" {
    label: "The Array Trap: LPUSH is O(n)"
    shape: callout
    style.fill: "#FFE7CB"
    style.font-color: "#9E2146"
    style.stroke: "#9E2146"
    style.stroke-width: 2
    width: 220
  }

  solution_ann: "" {
    label: "Doubly-Linked Solution: All End Ops O(1)"
    shape: callout
    style.fill: "#D4EDDA"
    style.font-color: "#15C724"
    style.stroke: "#15C724"
    style.stroke-width: 2
    width: 220
  }
}

array_breaker: "" {
