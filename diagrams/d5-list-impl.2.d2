  label: "ARRAY IMPLEMENTATION (BROKEN)"
  style.underline: true
  style.font-size: 22
  style.font-color: "#9E2146"
  style.bold: true

  problem_explain: "" {
    label: "O(n) shift on LPUSH: every element must move right one position"
    shape: text
    style.font-size: 16
    style.font-color: "#6c757d"
  }

  array_visual: "" {
    direction: right
    label: ""
    style.stroke: transparent
    style.fill: transparent

    slot0: "A" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1a1a1a"
    }

    slot1: "B" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1a1a1a"
    }

    slot2: "C" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1a1a1a"
    }

    slot3: "_" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#BBDEFB"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#90CAF9"
    }

    slot4: "_" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#BBDEFB"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#90CAF9"
    }
  }

  array_cost: {
    shape: sql_table
    label: "Array Operation Complexity"
    row0: "LPUSH | O(n) | must shift n-1 elements right"
    row1: "RPUSH | O(1) | append to end"
    row2: "LPOP  | O(n) | must shift n-1 elements left"
    row3: "RPOP  | O(1) | pop from end"
    row4: "LRANGE | O(n) | must traverse all"
    row5: "BROKEN: Clients expect O(1) on LPUSH"
  }
  array_cost.style.fill: "#FFF3CD"
  array_cost.style.stroke: "#856404"
}

vs_sign: "" {
  label: "vs"
  shape: text
  style.font-size: 48
  style.font-color: "#ADB5BD"
  style.bold: true
  width: 60
}

dll_breaker: "" {
  direction: down
  label: "DOUBLY-LINKED LIST (CORRECT)"
  style.underline: true
  style.font-size: 22
  style.font-color: "#15C724"
  style.bold: true

  dll_explain: "" {
    label: "All end-insert/remove at O(1): pointer updates only, no shifting"
    shape: text
    style.font-size: 16
    style.font-color: "#28a745"
  }

  list_hdr: {
    shape: sql_table
    label: "struct List (adlist.h)"
    row0: "0x00 | ListNode* | head  // first node (NULL if empty)"
    row1: "0x08 | ListNode* | tail  // last node (NULL if empty)"
    row2: "0x10 | size_t   | len    // element count"
    row3: "0x18 | void(*free)(void*) | free_  // value destructor"
    row4: "0x20 | void*(*dup)(void*) | dup_   // value duplicator"
    row5: "Total: 32 bytes + vtable ptr"
  }
  list_hdr.style.fill: "#D4EDDA"
  list_hdr.style.stroke: "#28a745"

  node_hdr: {
    shape: sql_table
    label: "struct ListNode (adlist.h)"
    row0: "0x00 | void*    | value  // element (binary-safe SDS)"
    row1: "0x08 | ListNode* | prev   // previous (NULL if head)"
    row2: "0x10 | ListNode* | next   // next (NULL if tail)"
    row3: "Total: 24 bytes (3 pointers, 8-byte aligned)"
  }
  node_hdr.style.fill: "#D4EDDA"
  node_hdr.style.stroke: "#28a745"

  ll_visual: "" {
    direction: right
    label: ""
    style.stroke: transparent
    style.fill: transparent

    head_ptr: "head" {
      shape: rectangle
      width: 60
      height: 36
      style.fill: "#28a745"
      style.stroke: "#15C724"
      style.font-size: 16
      style.font-color: white
      style.bold: true
    }

    null_prev: "NULL" {
      shape: rectangle
      width: 55
      height: 36
      style.fill: "#C8E6C9"
      style.stroke: "#28a745"
      style.font-size: 13
      style.font-color: "#2E7D32"
    }

    nd_A: "|A|" {
      shape: rectangle
      width: 60
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#28a745"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1B5E20"
      style.bold: true
    }

    nd_B: "|B|" {
      shape: rectangle
      width: 60
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#28a745"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1B5E20"
      style.bold: true
    }

    nd_C: "|C|" {
      shape: rectangle
      width: 60
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#28a745"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1B5E20"
      style.bold: true
    }

    null_next: "NULL" {
      shape: rectangle
      width: 55
      height: 36
      style.fill: "#C8E6C9"
      style.stroke: "#28a745"
      style.font-size: 13
      style.font-color: "#2E7D32"
    }

    tail_ptr: "tail" {
      shape: rectangle
      width: 60
      height: 36
      style.fill: "#28a745"
      style.stroke: "#15C724"
      style.font-size: 16
      style.font-color: white
      style.bold: true
    }

    head_ptr -> nd_A
    null_prev -> nd_A: "prev"
    nd_A -> null_prev: "prev"
    nd_A -> nd_B: "next"
    nd_B -> nd_A: "prev"
    nd_B -> nd_C: "next"
    nd_C -> nd_B: "prev"
    nd_C -> null_next: "next"
    null_next -> tail_ptr
  }

  dll_cost: {
    shape: sql_table
    label: "Doubly-Linked Operation Complexity"
    row0: "LPUSH | O(1) | prev=NULL, next=head, update head pointer"
    row1: "RPUSH | O(1) | next=NULL, prev=tail, update tail pointer"
    row2: "LPOP  | O(1) | take val, head=head->next, free old node"
    row3: "RPOP  | O(1) | take val, tail=tail->prev, free old node"
    row4: "LRANGE | O(n) | traverse n elements (unavoidable)"
    row5: "CORRECT: All end-point operations are O(1)"
  }
  dll_cost.style.fill: "#D4EDDA"
  dll_cost.style.stroke: "#28a745"
}

row_ops_code: "" {
  direction: right
  label: "LPUSH / RPUSH O(1) Logic — Pointer Updates Only, No memcpy"
  style.underline: true
  style.font-size: 20
  style.bold: true
  style.font-color: "#1a1a1a"
  width: 720

  lp_code: "" {
    direction: down
    label: "listAddNodeHead"
    shape: rectangle
    width: 340
    code: |'c
      ListNode* node = zmalloc(sizeof(ListNode));
      node->value = sdsdup(value);
      node->prev = NULL;
      node->next = head;
      if (head) head->prev = node;
      else tail = node;        // was empty
      head = node;
      len++;
      return list;
    '|
    width: 340
  }

  rp_code: "" {
    direction: down
    label: "listAddNodeTail"
    shape: rectangle
    width: 340
    code: |'c
      ListNode* node = zmalloc(sizeof(ListNode));
      node->value = sdsdup(value);
      node->next = NULL;
      node->prev = tail;
      if (tail) tail->next = node;
      else head = node;        // was empty
      tail = node;
      len++;
      return list;
    '|
    width: 340
  }
}

