  dll_noshift_visual: "" {
    direction: down
    label: "Why DLL LPUSH Is O(1): Pointer Updates Only"
    style.underline: true
    style.font-size: 19
    style.bold: true
    style.font-color: "#15C724"

    dll_before_s: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      dbstep0: "Before LPUSH('X'):" {
        shape: rectangle
        width: 155
        height: 38
        style.fill: "#D4EDDA"
        style.stroke: "#28a745"
        style.font-size: 14
      }

      ddll_before: "|A| -> |B| -> |C|" {
        shape: rectangle
        width: 165
        height: 46
        style.fill: "#C8E6C9"
        style.stroke: "#28a745"
        style.font-size: 14
        style.font-color: "#1B5E20"
      }
    }

    dll_after_s: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      dastep1: "After LPUSH('X'):" {
        shape: rectangle
        width: 155
        height: 38
        style.fill: "#D4EDDA"
        style.stroke: "#28a745"
        style.font-size: 14
      }

      ddll_after: "|X| -> |A| -> |B| -> |C|" {
        shape: rectangle
