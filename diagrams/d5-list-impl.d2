direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # List Implementation: Doubly-Linked vs Array
| {near: top-center}

row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  problem_note: "" {
    shape: callout
    label: "The Array Trap: LPUSH is O(n)"
    style.fill: "#FFE7CB"
    style.font-color: "#9E2146"
    style.stroke: "#9E2146"
    style.stroke-width: 2
    width: 220
  }

  solution_note: "" {
    shape: callout
    label: "The Linked-List Solution: O(1)"
    style.fill: "#D4EDDA"
    style.font-color: "#155724"
    style.stroke: "#155724"
    style.stroke-width: 2
    width: 220
  }
}

row1: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  array_layer: "" {
    direction: down
    label: "ARRAY IMPLEMENTATION (BROKEN)"
    style.underline: true
    style.font-size: 22
    style.font-color: "#9E2146"
    style.bold: true

    array_problem: "" {
      label: "O(n) Shift on LPUSH"
      shape: text
      style.font-size: 16
      style.font-color: "#6c757d"
    }

    array_diagram: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      idx0: "" {
        shape: rectangle
        label: "[0]"
        width: 70
        height: 50
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1a1a1a"
      }
      idx1: "" {
        shape: rectangle
        label: "[1]"
        width: 70
        height: 50
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1a1a1a"
      }
      idx2: "" {
        shape: rectangle
        label: "[2]"
        width: 70
        height: 50
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1a1a1a"
      }
      idx3: "" {
        shape: rectangle
        label: "[3]"
        width: 70
        height: 50
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1a1a1a"
      }
      dots: "" {
        label: "..."
        width: 50
        height: 50
        style.fill: "#F8F9FA"
        style.stroke: "#ADB5BD"
        style.font-size: 20
      }
      idxN: "" {
        label: "[n-1]"
        width: 70
        height: 50
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1a1a1a"
      }

      idx0: {shape: rectangle} -> idx1: "" {style.opacity: 0}
      idx1: "" {shape: rectangle} -> idx2: "" {style.opacity: 0}
      idx2: "" {shape: rectangle} -> idx3: "" {style.opacity: 0}
      idx3: "" {shape: rectangle} -> dots: "" {style.opacity: 0}
      dots: "" {shape: rectangle} -> idxN: "" {style.opacity: 0}
    }

    cost_table: "" {
      shape: sql_table
      label: "Array Operation Costs"
      idx0: "0 | LPUSH | O(n) | shift n-1 elements right"
      idx1: "1 | RPUSH | O(1) | append to end"
      idx2: "2 | LPOP  | O(n) | shift n-1 elements left"
      idx3: "3 | RPOP  | O(1) | pop from end"
      idx4: "4 | LRANGE | O(n) | must traverse all"
      sz: "Problem: Clients hammer LPUSH expecting O(1)"
    }

    cost_table.style.font-size: 15
    cost_table.style.fill: "#FFF3CD"
    cost_table.style.stroke: "#856404"
  }

  vs: "" {
    label: "vs"
    shape: text
    style.font-size: 48
    style.font-color: "#ADB5BD"
    style.bold: true
    width: 60
  }

  dll_layer: "" {
    direction: down
    label: "DOUBLY-LINKED LIST (CORRECT)"
    style.underline: true
    style.font-size: 22
    style.font-color: "#155724"
    style.bold: true

    dll_problem: "" {
      label: "All Operations O(1)"
      shape: text
      style.font-size: 16
      style.font-color: "#28a745"
    }

    list_struct: "" {
      shape: sql_table
      label: "struct List (adlist.h)"
      f0: "0x00 | ListNode* | head    // first node (NULL if empty)"
      f1: "0x08 | ListNode* | tail    // last node (NULL if empty)"
      f2: "0x10 | size_t    | len     // element count"
      f3: "0x18 | void(*free)(sds) | free_fn // value destructor"
      sz: "Total: 24 bytes + 8 (vtable ptr)"
    }
    list_struct.style.fill: "#D4EDDA"
    list_struct.style.stroke: "#28a745"

    node_struct: "" {
      shape: sql_table
      label: "struct ListNode (adlist.h)"
      f0: "0x00 | sds         | value  // element (binary-safe)"
      f1: "0x08 | ListNode*   | prev   // previous (NULL for head)"
      f2: "0x10 | ListNode*   | next   // next (NULL for tail)"
      sz: "Total: 24 bytes (3 ptrs)"
    }
    node_struct.style.fill: "#D4EDDA"
    node_struct.style.stroke: "#28a745"

    ll_diagram: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      head_ptr: "" {
        label: "head"
        shape: rectangle
        width: 60
        height: 36
        style.fill: "#28a745"
        style.stroke: "#155724"
        style.font-size: 16
        style.font-color: white
        style.bold: true
      }

      null0: "" {
        label: "NULL"
        shape: rectangle
        width: 55
        height: 36
        style.fill: "#C8E6C9"
        style.stroke: "#28a745"
        style.font-size: 13
        style.font-color: "#2E7D32"
      }

      node_a: "" {
        label: "| A |"
        shape: rectangle
        width: 60
        height: 60
        style.fill: "#E8F5E9"
        style.stroke: "#28a745"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1B5E20"
        style.bold: true
      }

      node_b: "" {
        label: "| B |"
        shape: rectangle
        width: 60
        height: 60
        style.fill: "#E8F5E9"
        style.stroke: "#28a745"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1B5E20"
        style.bold: true
      }

      node_c: "" {
        label: "| C |"
        shape: rectangle
        width: 60
        height: 60
        style.fill: "#E8F5E9"
        style.stroke: "#28a745"
        style.stroke-width: 2
        style.font-size: 16
        style.font-color: "#1B5E20"
        style.bold: true
      }

      null1: "" {
        label: "NULL"
        shape: rectangle
        width: 55
        height: 36
        style.fill: "#C8E6C9"
        style.stroke: "#28a745"
        style.font-size: 13
        style.font-color: "#2E7D32"
      }

      tail_ptr: "" {
        label: "tail"
        shape: rectangle
        width: 60
        height: 36
        style.fill: "#28a745"
        style.stroke: "#155724"
        style.font-size: 16
        style.font-color: white
        style.bold: true
      }

      head_ptr: -> node_a: "" {style.opacity: 0}
      null0: -> node_a: "" {style.opacity: 0}
      node_a: -> null0: "" {style.opacity: 0}
      node_a.prev: "" {label: "prev"; style.opacity: 0} -> null0: ""
      node_a.next: "" {label: "next"; style.opacity: 0} -> node_b: ""
      node_b.prev: "" {label: "prev"; style.opacity: 0} -> node_a: ""
      node_b.next: "" {label: "next"; style.opacity: 0} -> node_c: ""
      node_c.prev: "" {label: "prev"; style.opacity: 0} -> node_b: ""
      node_c.next: "" {label: "next"; style.opacity: 0} -> null1: ""
      node_a: -> node_b: "" {style.opacity: 0}
      node_b: -> node_c: "" {style.opacity: 0}
      node_c: -> null1: "" {style.opacity: 0}
      null1: -> tail_ptr: "" {style.opacity: 0}
    }

    cost_table2: "" {
      shape: sql_table
      label: "Doubly-Linked Operation Costs"
      f0: "0 | LPUSH | O(1) | create node, link prev=NULL, update head"
      f1: "1 | RPUSH | O(1) | create node, link next=NULL, update tail"
      f2: "2 | LPOP  | O(1) | take head->value, head=head->next, free old"
      f3: "3 | RPOP  | O(1) | take tail->value, tail=tail->prev, free old"
      f4: "4 | LRANGE | O(n) | traverse + return n elements"
      sz: "Result: All end-point ops are O(1)"
    }
    cost_table2.style.fill: "#D4EDDA"
    cost_table2.style.stroke: "#28a745"
  }
}

row2: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  ops_detail: "" {
    direction: right
    label: "LPUSH/RPUSH Code Logic (O(1) — No shift needed)"
    style.underline: true
    style.font-size: 20
    style.bold: true
    style.font-color: "#1a1a1a"
    width: 720

    lpush_code: "" {
      label: "listAddNodeHead"
      shape: rectangle
      width: 340
      height: 120
      style.fill: "#F0FFF4"
      style.stroke: "#28a745"
      style.stroke-width: 2
      code: |'c
        node->prev = NULL;
        node->next = head;
        if (head) head->prev = node;
        else tail = node;           // was empty
        head = node;
        len++;
        return list;
      '|
      width: 340
    }

    rpush_code: "" {
      label: "listAddNodeTail"
      shape: rectangle
      width: 340
      height: 120
      style.fill: "#F0FFF4"
      style.stroke: "#28a745"
      style.stroke-width: 2
      code: |'c
        node->next = NULL;
        node->prev = tail;
        if (tail) tail->next = node;
        else head = node;           // was empty
        tail = node;
        len++;
        return list;
      '|
      width: 340
    }

    lpush_code -> rpush_code: "" {style.opacity: 0}
  }
}

row3: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  array_shift_viz: "" {
    direction: right
    label: "Why Array LPUSH Is O(n): Every Element Shifts Right"
    style.underline: true
    style.font-size: 20
    style.bold: true
    style.font-color: "#9E2146"
    width: 340

    step0: "" {
      label: "Before LPUSH('X'):"
      shape: rectangle
      width: 140
      height: 38
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.font-size: 14
    }
    arr0: "" {
      label: "A| B| C| _"
      shape: rectangle
      width: 140
      height: 46
      style.fill: "#BBDEFB"
      style.stroke: "#2E86AB"
      style.font-size: 15
      style.font-color: "#0D47A1"
    }

    step1: "" {
      label: "After LPUSH('X'):"
      shape: rectangle
      width: 140
      height: 38
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.font-size: 14
    }
    arr1: "" {
      label: "X| A| B| C| _"
      shape: rectangle
      width: 160
      height: 46
      style.fill: "#BBDEFB"
      style.stroke: "#2E86AB"
      style.font-size: 15
      style.font-color: "#0D47A1"
    }

    shift_note: "" {
      label: "Shift cost: O(n) memcpy for n-1 elements"
      shape: callout
      style.fill: "#FFE7CB"
      style.stroke: "#9E2146"
      style.font-color: "#9E2146"
      style.font-size: 14
    }

    step0: -> arr0: "" {style.opacity: 0}
    step1: -> arr1: "" {style.opacity: 0}
  }

  dll_no_shift_viz: "" {
    direction: right
    label: "Why DLL LPUSH Is O(1): Pointer Updates Only"
    style.underline: true
    style.font-size: 20
    style.bold: true
    style.font-color: "#155724"
    width: 340

    dll_before: "" {
      label: "Before LPUSH('X'):"
      shape: rectangle
      width: 140
      height: 38
      style.fill: "#D4EDDA"
      style.stroke: "#28a745"
      style.font-size: 14
    }
    dll_arr0: "" {
      label: "|A| -> |B| -> |C|"
      shape: rectangle
      width: 160
      height: 46
      style.fill: "#C8E6C9"
      style.stroke: "#28a745"
      style.font-size: 14
      style.font-color: "#1B5E20"
    }

    dll_after: "" {
      label: "After LPUSH('X'):"
      shape: rectangle
      width: 140
      height: 38
      style.fill: "#D4EDDA"
      style.stroke: "#28a745"
      style.font-size: 14
    }
    dll_arr1: "" {
      label: "|X| -> |A| -> |B| -> |C|"
      shape: rectangle
      width: 190
      height: 46
      style.fill: "#C8E6C9"
      style.stroke: "#28a745"
      style.font-size: 14
      style.font-color: "#1B5E20"
    }

    o1_note: "" {
      label: "Ptr update: O(1) — 4 pointer writes"
      shape: callout
      style.fill: "#D4EDDA"
      style.stroke: "#28a745"
      style.font-color: "#155724"
      style.font-size: 14
    }

    dll_before: -> dll_arr0: "" {style.opacity: 0}
    dll_after: -> dll_arr1: "" {style.opacity: 0}
  }
}

legend_box: "" {
  near: bottom-center
  label: "LEGEND"
  style.underline: true
  style.font-size: 18
  style.bold: true

  green_box: "" {
    label: "Green = Correct O(1) Approach"
    shape: rectangle
    width: 210
    height: 38
    style.fill: "#D4EDDA"
    style.stroke: "#28a745"
    style.font-size: 15
  }

  red_box: "" {
    label: "Red = Broken O(n) Trap"
    shape: rectangle
    width: 210
    height: 38
    style.fill: "#FFE7CB"
    style.stroke: "#9E2146"
    style.font-size: 15
  }
}