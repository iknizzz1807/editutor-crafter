direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

title: |md
  # Edge-Triggered vs Level-Triggered Epoll
|
{near: top-center}

concept: {
  label: "Epoll in Linux kernel monitors file descriptors for I/O readiness"
  shape: text
  style.font-size: 16
  style.font-color: "#666"
  near: top-center
}

row_comparison: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  level_triggered: {
    label: "Level-Triggered (Default)"
    shape: rectangle
    style.fill: "#E8F5E9"
    style.stroke: "#4CAF50"
    style.stroke-width: 2
    width: 280
    height: 60

    explanation: |md
      ✓ Fires repeatedly while condition is TRUE
      ✓ Works with blocking & non-blocking I/O
      ✓ No risk of missed events
      ✗ More events processed (sometimes wasteful)
    |
  }

  edge_triggered: {
    label: "Edge-Triggered (EPOLLET)"
    shape: rectangle
    style.fill: "#FFF3E0"
    style.stroke: "#FF9800"
    style.stroke-width: 2
    width: 280
    height: 60

    explanation: |md
      ✓ Fires ONLY on transition (0 → 1 edge)
      ✓ More efficient for bulk I/O
      ✗ MUST re-arm after each notification
      ✗ Risk of MISSED EVENTS if not re-armed
    |
  }
}

row_comparison.level_triggered -> row_comparison.edge_triggered: "epoll_ctl(EPOLLET)" {
  style.stroke-dash: 3
  style.stroke: "#999"
  label.near: bottom-center
}

separator: "" {
  shape: text
  label: ""
  style.opacity: 0
}

level_section: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  level_title: {
    label: "LEVEL-TRIGGERED BEHAVIOR"
    shape: text
    style.font-size: 20
    style.font-color: "#4CAF50"
    style.bold: true
  }

  level_sequence: {
    direction: down
    width: 400

    step_lt1: {
      label: "epoll_wait() returns"
      style.fill: "#C8E6C9"
      width: 180
      height: 50

      code: |'c
        // Data arrives -> ready
        buffer has 100 bytes
        epoll_wait() returns
        epoll_event.events & EPOLLIN == TRUE
      '|
    }

    step_lt2: "→"
    step_lt3: {
      label: "read() processes partial"
      style.fill: "#A5D6A7"
      width: 180
      height: 50

      code: |'c
        read(fd, buf, 50)
        // Only 50 bytes read
        // Buffer still has 50 bytes
      '|
    }

    step_lt4: "→"
    step_lt5: {
      label: "epoll_wait() returns AGAIN"
      style.fill: "#81C784"
      width: 180
      height: 50

      code: |'c
        // Condition still TRUE
        epoll_wait() returns AGAIN
        No need to re-arm
        All data processed safely
      '|
    }
  }
}

separator2: "" {
  shape: text
  label: ""
  style.opacity: 0
}

edge_section: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  edge_title: {
    label: "EDGE-TRIGGERED BEHAVIOR"
    shape: text
    style.font-size: 20
    style.font-color: "#FF9800"
    style.bold: true
  }

  edge_sequence: {
    direction: down
    width: 400

    step_et1: {
      label: "epoll_wait() returns"
      style.fill: "#FFE0B2"
      width: 180
      height: 50

      code: |'c
        // Data arrives: empty → has data
        // EDGE DETECTED!
        epoll_wait() returns NOTIFY
      '|
    }

    step_et2: "→"
    step_et3: {
      label: "read() processes partial"
      style.fill: "#FFCC80"
      width: 180
      height: 50

      code: |'c
        read(fd, buf, 50)
        // Only 50 bytes read
        // Buffer still has 50 bytes
      '|
    }

    step_et4: {
      label: "⚠️ PROBLEM: MISSED!"
      style.fill: "#FF5722"
      style.font-color: white
      width: 180
      height: 50

      code: |'c
        // Buffer still has data!
        // BUT epoll doesn't re-notify
        // Condition was already TRUE
        // No new edge occurred!
        epoll_wait() BLOCKS forever
      '|
    }
  }
}

problem_box: {
  label: "The Edge-Triggered Re-arming Problem"
  shape: callout
  style.fill: "#FFEBEE"
  style.stroke: "#F44336"
  width: 350
  height: 120

  code: |'c
    // Solution: Loop until EAGAIN
    
    while (1) {
      n = read(fd, buf, sizeof(buf));
      if (n > 0) {
        process(buf, n);
      }
      if (n < sizeof(buf) || errno == EAGAIN) {
        // All data consumed
        break;
      }
    }

    // Key insight:
    // Edge-triggered only notifies on TRANSITION
    // Must read ALL available data to find the edge
  '|
}

diagram_notes: {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  notes1: {
    label: "When to use Level-Triggered:"
    shape: text
    style.font-size: 14
    style.bold: true
  }

  notes2: |md
    • Simple request-response patterns
    • Blocking I/O is acceptable
    • Can't miss ANY events
    • Default behavior (no EPOLLET flag)
  |

  notes3: {
    label: "When to use Edge-Triggered:"
    shape: text
    style.font-size: 14
    style.bold: true
  }

  notes4: |md
    • High-performance I/O multiplexing
    • Non-blocking I/O required
    • Must handle partial reads correctly
    • Use EPOLLET flag in epoll_ctl()
  |
}

edge_section -> problem_box: "Same bug" {
  style.stroke: "#F44336"
  style.stroke-width: 2
  style.stroke-dash: 4
  label.near: top-center
}

separator2 -> edge_section: "below the title"