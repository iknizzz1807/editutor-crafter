direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}
title: |md
  # List Implementation: Doubly-Linked vs Array
| {near: top-center}

row0: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  problem_ann: "" {
    label: "The Array Trap: LPUSH is O(n)"
    shape: callout
    style.fill: "#FFE7CB"
    style.font-color: "#9E2146"
    style.stroke: "#9E2146"
    style.stroke-width: 2
    width: 220
  }

  solution_ann: "" {
    label: "The Doubly-Linked Solution: All End Ops O(1)"
    shape: callout
    style.fill: "#D4EDDA"
    style.font-color: "#155724"
    style.stroke: "#155724"
    style.stroke-width: 2
    width: 220
  }
}

array_layer: "" {
  direction: down
  label: "ARRAY IMPLEMENTATION (BROKEN)"
  style.underline: true
  style.font-size: 22
  style.font-color: "#9E2146"
  style.bold: true

  array_note: "" {
    label: "O(n) shift on LPUSH — every element must move right"
    shape: text
    style.font-size: 16
    style.font-color: "#6c757d"
  }

  array_diagram: "" {
    direction: right
    label: ""
    style.stroke: transparent
    style.fill: transparent

    arr_i0: "A" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1a1a1a"
    }

    arr_i1: "B" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1a1a1a"
    }

    arr_i2: "C" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#D6EAF8"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1a1a1a"
    }

    arr_i3: "_" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#BBDEFB"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#90CAF9"
    }

    arr_i4: "_" {
      shape: rectangle
      width: 72
      height: 50
      style.fill: "#BBDEFB"
      style.stroke: "#2E86AB"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#90CAF9"
    }
  }

  array_cost: {
    shape: sql_table
    label: "Array Operation Complexity"
    op0: "LPUSH | O(n) | must shift n-1 elements right"
    op1: "RPUSH | O(1) | append to end"
    op2: "LPOP  | O(n) | must shift n-1 elements left"
    op3: "RPOP  | O(1) | pop from end"
    op4: "LRANGE | O(n) | must traverse all"
    warn: "BROKEN: Clients expect O(1) on LPUSH"
  }
  array_cost.style.fill: "#FFF3CD"
  array_cost.style.stroke: "#856404"
}

vs_box: "" {
  label: "vs"
  shape: text
  style.font-size: 48
  style.font-color: "#ADB5BD"
  style.bold: true
  width: 60
}

dll_layer: "" {
  direction: down
  label: "DOUBLY-LINKED LIST (CORRECT)"
  style.underline: true
  style.font-size: 22
  style.font-color: "#155724"
  style.bold: true

  dll_note: "" {
    label: "All end-insert/delete at O(1) — pointer updates only"
    shape: text
    style.font-size: 16
    style.font-color: "#28a745"
  }

  list_struct: {
    shape: sql_table
    label: "struct List (adlist.h)"
    f0: "0x00 | ListNode* | head  // first node (NULL if empty)"
    f1: "0x08 | ListNode* | tail  // last node (NULL if empty)"
    f2: "0x10 | size_t   | len    // element count"
    f3: "0x18 | void(*free)(void*) | free_fn // value destructor"
    sz: "Total: 24 bytes + vtable ptr"
  }
  list_struct.style.fill: "#D4EDDA"
  list_struct.style.stroke: "#28a745"

  node_struct: {
    shape: sql_table
    label: "struct ListNode (adlist.h)"
    f0: "0x00 | void*  | value   // element data (binary-safe)"
    f1: "0x08 | ListNode* | prev   // previous (NULL = head)""
    f2: "0x10 | ListNode* | next   // next (NULL = tail)""
    sz: "Total: 24 bytes (3 pointers)"
  }
  node_struct.style.fill: "#D4EDDA"
  node_struct.style.stroke: "#28a745"

  ll_diagram: "" {
    direction: right
    label: ""
    style.stroke: transparent
    style.fill: transparent

    head_label: "head" {
      shape: rectangle
      width: 60
      height: 36
      style.fill: "#28a745"
      style.stroke: "#155724"
      style.font-size: 16
      style.font-color: white
      style.bold: true
    }

    null_label0: "NULL" {
      shape: rectangle
      width: 55
      height: 36
      style.fill: "#C8E6C9"
      style.stroke: "#28a745"
      style.font-size: 13
      style.font-color: "#2E7D32"
    }

    node_A: "|A|" {
      shape: rectangle
      width: 60
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#28a745"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1B5E20"
      style.bold: true
    }

    node_B: "|B|" {
      shape: rectangle
      width: 60
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#28a745"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1B5E20"
      style.bold: true
    }

    node_C: "|C|" {
      shape: rectangle
      width: 60
      height: 60
      style.fill: "#E8F5E9"
      style.stroke: "#28a745"
      style.stroke-width: 2
      style.font-size: 16
      style.font-color: "#1B5E20"
      style.bold: true
    }

    null_label1: "NULL" {
      shape: rectangle
      width: 55
      height: 36
      style.fill: "#C8E6C9"
      style.stroke: "#28a745"
      style.font-size: 13
      style.font-color: "#2E7D32"
    }

    tail_label: "tail" {
      shape: rectangle
      width: 60
      height: 36
      style.fill: "#28a745"
      style.stroke: "#155724"
      style.font-size: 16
      style.font-color: white
      style.bold: true
    }

    head_label -> node_A
    null_label0 -> node_A
    node_A -> null_label0: "prev"
    node_A -> node_B: "next"
    node_B -> node_A: "prev"
    node_B -> node_C: "next"
    node_C -> node_B: "prev"
    node_C -> null_label1: "next"
    null_label1 -> tail_label
  }

  dll_cost: {
    shape: sql_table
    label: "Doubly-Linked Operation Complexity"
    op0: "LPUSH | O(1) | create node, prev=NULL, next=head, update head"
    op1: "RPUSH | O(1) | create node, next=NULL, prev=tail, update tail"
    op2: "LPOP  | O(1) | take head->value, head=head->next, free old"
    op3: "RPOP  | O(1) | take tail->value, tail=tail->prev, free old"
    op4: "LRANGE | O(n) | traverse n elements (unavoidable)""
    ok: "CORRECT: All end-point operations O(1)"
  }
  dll_cost.style.fill: "#D4EDDA"
  dll_cost.style.stroke: "#28a745"
}

row_ops: "" {
  direction: right
  label: "LPUSH / RPUSH Code Logic — O(1) Pointer Updates Only"
  style.underline: true
  style.font-size: 20
  style.bold: true
  style.font-color: "#1a1a1a"

  lpush_code: {
    label: "listAddNodeHead"
    shape: rectangle
    width: 340
    code: |'c
      ListNode* node = zmalloc(sizeof(ListNode));
      node->value = sdsdup(value);
      node->prev = NULL;
      node->next = head;
      if (head) head->prev = node;
      else tail = node;        // list was empty
      head = node;
      len++;
      return list;
    '|
    width: 340
  }

  rpush_code: {
    label: "listAddNodeTail"
    shape: rectangle
    width: 340
    code: |'c
      ListNode* node = zmalloc(sizeof(ListNode));
      node->value = sdsdup(value);
      node->next = NULL;
      node->prev = tail;
      if (tail) tail->next = node;
      else head = node;        // list was empty
      tail = node;
      len++;
      return list;
    '|
    width: 340
  }

  lpush_code -> rpush_code: "" {style.opacity: 0}
}

row_shift: "" {
  direction: right
  label: ""
  style.stroke: transparent
  style.fill: transparent

  array_shift: "" {
    direction: down
    label: "Why Array LPUSH Is O(n): Every Element Shifts Right"
    style.underline: true
    style.font-size: 19
    style.bold: true
    style.font-color: "#9E2146"

    before_arr: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      step0: "Before LPUSH('X'):" {
        shape: rectangle
        width: 155
        height: 38
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.font-size: 14
      }

      arr_before: "|A| |B| |C|" {
        shape: rectangle
        width: 160
        height: 46
        style.fill: "#BBDEFB"
        style.stroke: "#2E86AB"
        style.font-size: 15
        style.font-color: "#0D47A1"
      }

      step0 -> arr_before: "" {style.opacity: 0}
    }

    after_arr: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      step1: "After LPUSH('X'):" {
        shape: rectangle
        width: 155
        height: 38
        style.fill: "#D6EAF8"
        style.stroke: "#2E86AB"
        style.font-size: 14
      }

      arr_after: "|X| |A| |B| |C|" {
        shape: rectangle
        width: 200
        height: 46
        style.fill: "#BBDEFB"
        style.stroke: "#2E86AB"
        style.font-size: 15
        style.font-color: "#0D47A1"
      }

      step1 -> arr_after: "" {style.opacity: 0}
    }

    shift_cost: {
      label: "Shift cost: O(n) memcpy for n-1 elements"
      shape: callout
      style.fill: "#FFE7CB"
      style.stroke: "#9E2146"
      style.font-color: "#9E2146"
      style.font-size: 14
    }
  }

  dll_noshift: "" {
    direction: down
    label: "Why DLL LPUSH Is O(1): Pointer Updates Only"
    style.underline: true
    style.font-size: 19
    style.bold: true
    style.font-color: "#155724"

    before_dll: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      dlbl0: "Before LPUSH('X'):" {
        shape: rectangle
        width: 155
        height: 38
        style.fill: "#D4EDDA"
        style.stroke: "#28a745"
        style.font-size: 14
      }

      dll_before: "|A| -> |B| -> |C|" {
        shape: rectangle
        width: 165
        height: 46
        style.fill: "#C8E6C9"
        style.stroke: "#28a745"
        style.font-size: 14
        style.font-color: "#1B5E20"
      }

      dlbl0 -> dll_before: "" {style.opacity: 0}
    }

    after_dll: "" {
      direction: right
      label: ""
      style.stroke: transparent
      style.fill: transparent

      dlbl1: "After LPUSH('X'):" {
        shape: rectangle
        width: 155
        height: 38
        style.fill: "#D4EDDA"
        style.stroke: "#28a745"
        style.font-size: 14
      }

      dll_after: "|X| -> |A| -> |B| -> |C|" {
        shape: rectangle
        width: 205
        height: 46
        style.fill: "#C8E6C9"
        style.stroke: "#28a745"
        style.font-size: 14
        style.font-color: "#1B5E20"
      }

      dlbl1 -> dll_after: "" {style.opacity: 0}
    }

    o1_cost: {
      label: "Ptr update: O(1) — 4 pointer writes only"
      shape: callout
      style.fill: "#D4EDDA"
      style.stroke: "#28a745"
      style.font-color: "#155724"
      style.font-size: 14
    }
  }
}

