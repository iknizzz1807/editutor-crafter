vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
}

direction: down

title: |md
  # Startup Recovery Priority
  AOF vs RDB decision tree on server startup
| {near: top-center}

startup: Server Startup {
  shape: hexagon
  style.fill: "#E4DBFE"
  style.stroke: "#B5AFF6"
  style.stroke-width: 2
}

check_aof_enabled: {
  shape: diamond
  label: "AOF enabled?"
  style.fill: "#FFF9C9"
  style.stroke: "#9D341E"
  style.stroke-width: 2
}

check_aof_exists: {
  shape: diamond
  label: "AOF file exists?"
  style.fill: "#FFF9C9"
  style.stroke: "#9D341E"
  style.stroke-width: 2
}

check_rdb_exists: {
  shape: diamond
  label: "RDB file exists?"
  style.fill: "#FFF9C9"
  style.stroke: "#9D341E"
  style.stroke-width: 2
}

load_aof: AOF Load (aof.c:load) {
  shape: rectangle
  style.fill: "#ACE1AF"
  style.stroke: "#167c3c"
  style.stroke-width: 2
}

load_rdb: RDB Load (rdb.c:load) {
  shape: rectangle
  style.fill: "#B6DDF6"
  style.stroke: "#1E90FF"
  style.stroke-width: 2
}

start_fresh: Start Fresh (empty db) {
  shape: rectangle
  style.fill: "#DEE1EB"
  style.stroke: "#808080"
  style.stroke-width: 2
}

load_error: Load Error (corrupted file) {
  shape: rectangle
  style.fill: "#FFE7CB"
  style.stroke: "#FF4500"
  style.stroke-width: 2
}

replay_aof: AOF Replay (aof.c:replay) {
  shape: rectangle
  style.fill: "#ACE1AF"
  style.stroke: "#167c3c"
  style.stroke-width: 2
}

reconstruct_state: Reconstruct database state by re-executing all logged commands {
  shape: text
  style.font-size: 11
  style.font-color: "#555"
  near: load_aof
}

row_decision: "" {
  direction: right
  style.stroke: transparent
  style.fill: transparent

  decision_a: {
    label: "YES"
    shape: text
    style.font-color: green
    style.font-size: 14
    style.bold: true
  }

  decision_b: {
    label: "NO"
    shape: text
    style.font-color: red
    style.font-size: 14
    style.bold: true
  }
}

legend: Legend {
  near: bottom-right
  style.fill: white
  style.stroke: black
  style.stroke-width: 1

  aof_wins: AOF takes priority {
    style.fill: "#ACE1AF"
    style.stroke: green
  }

  rdb_fallback: RDB fallback {
    style.fill: "#B6DDF6"
    style.stroke: blue
  }

  fresh_start: Fresh start {
    style.fill: "#DEE1EB"
    style.stroke: gray
  }

  load_error_note: Load error {
    style.fill: "#FFE7CB"
    style.stroke: red
  }
}

startup -> check_aof_enabled: "boot"

check_aof_enabled -> check_aof_exists: "YES: check AOF file"
check_aof_enabled -> check_rdb_exists: "NO: check RDB file"

check_aof_exists -> load_aof: "YES: load AOF"
check_aof_exists -> load_error: "NO: file missing unexpectedly"
check_aof_exists -> check_rdb_exists: "NO: AOF deleted during startup"

check_rdb_exists -> load_rdb: "YES: load RDB"
check_rdb_exists -> start_fresh: "NO: no persistence files"

load_aof -> replay_aof: "replay all RESP commands"
load_aof -> reconstruct_state: ""

aof_priority_note: |md
  **Rationale:** AOF captures every write since the last RDB snapshot.
  Even if RDB was created 5 minutes ago, AOF has all changes.
  Loading AOF gives the most current database state.
| {
  near: load_aof
  shape: text
  style.font-size: 10
  style.font-color: "#333"
  style.fill: "#F0F7FF"
  style.stroke: "#1E90FF"
  style.stroke-width: 1
}