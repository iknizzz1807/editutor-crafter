direction: down
vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 4
  }
  red: "#FF6B6B"
  green: "#51CF66"
  yellow: "#FFD43B"
  blue: "#339AF0"
  purple: "#845EF7"
  gray: "#868E96"
  light-blue: "#A5D8FF"
  light-yellow: "#FFE066"
}

title: |md
  # Time Event Scheduling
  ## Event Loop Time Management & Expiration Framework
| {near: top-center}

grid-rows: 3
grid-columns: 3
grid-gap: 40

row1: "" {
  style.stroke: transparent
  style.fill: transparent
  
  ins_label: "1. INSERT" {
    shape: step
    style.fill: ${light-blue}
    style.stroke: ${blue}
  }
  
  ins_desc: "schedule callback" {
    shape: text
    style.font-size: 18
    style.font-color: ${gray}
  }
  
  gap1: "" { style.stroke: transparent; style.fill: transparent }
  
  poll_label: "2. POLL" {
    shape: step
    style.fill: ${light-yellow}
    style.stroke: ${yellow}
  }
  
  poll_desc: "wait timeout (ms)" {
    shape: text
    style.font-size: 18
    style.font-color: ${gray}
  }
  
  gap2: "" { style.stroke: transparent; style.fill: transparent }
  
  fire_label: "3. FIRE" {
    shape: step
    style.fill: "#FFE8CC"
    style.stroke: ${red}
  }
  
  fire_desc: "expired callbacks" {
    shape: text
    style.font-size: 18
    style.font-color: ${gray}
  }
}

row2: "" {
  style.stroke: transparent
  style.fill: transparent
  
  ins_arrow: "" {
    shape: arrow
    style.stroke: ${blue}
    style.stroke-width: 2
  }
  
  gap3: "" { style.stroke: transparent; style.fill: transparent; width: 100 }
  
  poll_arrow: "" {
    shape: arrow
    style.stroke: ${yellow}
    style.stroke-width: 2
  }
  
  gap4: "" { style.stroke: transparent; style.fill: transparent; width: 100 }
  
  fire_arrow: "" {
    shape: arrow
    style.stroke: ${red}
    style.stroke-width: 2
  }
}

row3: "" {
  style.stroke: transparent
  style.fill: transparent
  
  ins_detail: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    ins_code: |'c
      // Insert time event
      int schedule_at_ms = now + delay;
      min_heap_push(timers, cb, schedule_at_ms);
      // Calculate next deadline
      int next_ms = timers->min - now;
    '|
    style.fill: "#F8F9FA"
    style.stroke: ${gray}
    style.stroke-dash: 3
  }
  
  gap5: "" { style.stroke: transparent; style.fill: transparent; width: 60 }
  
  poll_detail: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    poll_code: |'c
      // epoll_wait with timeout
      next_ms = get_next_timer_delta();
      ready = epoll_wait(ep, evs, MAX, next_ms);
      // evs[] = ready I/O, timeout = time event
    '|
    style.fill: "#F8F9FA"
    style.stroke: ${gray}
    style.stroke-dash: 3
  }
  
  gap6: "" { style.stroke: transparent; style.fill: transparent; width: 60 }
  
  fire_detail: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    fire_code: |'c
      // Fire expired timers
      while (timers->min <= now) {
        Timer* t = min_heap_pop(timers);
        t->callback(t->data);
        if (t->repeat_ms > 0) {
          t->when = now + t->repeat_ms;
          min_heap_push(timers, t);
        }
      }
    '|
    style.fill: "#FFF5F5"
    style.stroke: ${red}
    style.stroke-dash: 3
  }
}

explanation: |md
  ### Three-Phase Time Event Lifecycle
  
  **1. INSERT**: Callbacks are scheduled with `schedule_at_ms`. Inserted into min-heap
  sorted by expiration time. Next deadline is cached.
  
  **2. POLL**: Event loop calls `epoll_wait` with timeout = `next_timer_delta`.
  When timeout fires, the event loop processes all expired time events.
  
  **3. FIRE**: Expired timers are popped from heap and their callbacks executed.
  If repeating, they are reinserted with new deadline.
| {near: bottom-center}

min_heap_structure: "" {
  direction: down
  near: explanation
  
  heap_label: "Min-Heap Timer Queue" {
    shape: text
    style.font-size: 24
    style.bold: true
    style.underline: true
  }
  
  heap_visual: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    t0: "Timer_0\n(earliest)" {
      shape: rectangle
      style.fill: ${red}
      style.font-color: white
      width: 100
      height: 50
    }
    
    t1: "Timer_1" {
      shape: rectangle
      style.fill: ${purple}
      style.font-color: white
      width: 100
      height: 50
    }
    
    t2: "Timer_2" {
      shape: rectangle
      style.fill: ${purple}
      style.font-color: white
      width: 100
      height: 50
    }
    
    t3: "Timer_3" {
      shape: rectangle
      style.fill: ${blue}
      style.font-color: white
      width: 100
      height: 50
    }
    
    t4: "Timer_4" {
      shape: rectangle
      style.fill: ${blue}
      style.font-color: white
      width: 100
      height: 50
    }
  }
  
  heap_edges: "" {
    style.stroke: ${gray}
    style.stroke-width: 1
    
    "t0" -> "t1": "left"
    "t0" -> "t2": "right"
    "t1" -> "t3": "left"
    "t1" -> "t4": "right"
  }
  
  heap_formulas: |'c
    parent(i) = (i-1)/2
    left(i)   = 2*i+1
    right(i)  = 2*i+2
  '|
  style.fill: "#F0F0F0"
  style.stroke: ${gray}
  
  heap_props: |md
    **Properties:**
    - Timer[0] = earliest expiration
    - Each parent <= its children
    - O(log n) heapify after insert/delete
  | { style.font-size: 16; style.italic: true }
}

structs: "" {
  direction: right
  near: min_heap_structure
  
  timer_typedef: "" {
    shape: sql_table
    label: "struct Timer (reactor.h)"
    
    f0: "0x00 | const char* | name"
    f1: "0x08 | uint64_t | when_ms  // expiration ms"
    f2: "0x10 | uint64_t | repeat_ms // 0=one-shot"
    f3: "0x18 | void*   | data"
    f4: "0x20 | TimerFn | callback"
    f5: "0x28 | Timer*  | prev"
    f6: "0x30 | Timer*  | next"
    f7: "0x38 | int     | refcount"
    sz: "64 bytes (cache-aligned)"
  }
  
  timerheap_typedef: "" {
    shape: sql_table
    label: "struct TimerHeap"
    
    f0: "0x00 | Timer** | slots    // heap array"
    f1: "0x08 | size_t  | len     // count"
    f2: "0x10 | size_t  | capacity"
    f3: "0x18 | uint64_t | min_when // cached min"
    sz: "32 bytes"
  }
}

event_loop_flow: "" {
  direction: down
  near: structs
  
  loop_title: "Event Loop Integration" {
    shape: text
    style.font-size: 24
    style.bold: true
    style.underline: true
  }
  
  loop_steps: "" {
    direction: right
    style.stroke: transparent
    style.fill: transparent
    
    step1: "1. INIT" { shape: rectangle; style.fill: ${light-blue}; style.stroke: ${blue}; width: 90; height: 50 }
    step2: "2. SCHEDULE" { shape: rectangle; style.fill: ${light-blue}; style.stroke: ${blue}; width: 90; height: 50 }
    step3: "3. WAIT" { shape: rectangle; style.fill: ${light-yellow}; style.stroke: ${yellow}; width: 90; height: 50 }
    step4: "4. I/O" { shape: rectangle; style.fill: ${light-yellow}; style.stroke: ${yellow}; width: 90; height: 50 }
    step5: "5. FIRE" { shape: rectangle; style.fill: "#FFE8CC"; style.stroke: ${red}; width: 90; height: 50 }
    step6: "6. REPEAT" { shape: rectangle; style.fill: ${light-blue}; style.stroke: ${blue}; width: 90; height: 50 }
  }
  
  loop_code: |'c
    while (loop->running) {
      int timeout_ms = timerheap_min_delta(loop->timers);
      int n = epoll_wait(loop->epoll_fd, events, MAX, timeout_ms);
      for (int i = 0; i < n; i++) handle_io(loop, events[i]);
      uint64_t now = get_time_ms();
      timerheap_fire(loop->timers, now);
    }
  '|
  style.fill: "#F8F9FA"
  style.stroke: ${gray}
}

expiration_flow: "" {
  direction: right
  near: event_loop_flow
  
  expire_title: "Expiration Integration" {
    shape: text
    style.font-size: 20
    style.bold: true
    style.underline: true
  }
  
  active_exp: "" {
    label: "Active (100ms timer)"
    shape: rectangle
    style.fill: "#FFE8CC"
    style.stroke: ${red}
    style.stroke-dash: 5
  }
  
  lazy_exp: "" {
    label: "Lazy (on GET)"
    shape: rectangle
    style.fill: ${light-blue}
    style.stroke: ${blue}
    style.stroke-dash: 5
  }
  
  active_code: |'c
    void expire_timer_cb(void* ctx) {
      for (int i = 0; i < 20; i++) {
        sds key = random_key(db);
        obj = dict_fetch(key);
        if (obj && expired(obj)) dict_delete(key);
      }
    }
  '|
  style.fill: "#FFF5F5"
  style.stroke: ${red}
  style.font-size: 14
  
  lazy_code: |'c
    RedisObject* obj = dict_fetch(key);
    if (obj && obj->expire_at != -1
        && obj->expire_at <= now) {
      dict_delete(key); return NULL;
    }
  '|
  style.fill: "#F0F8FF"
  style.stroke: ${blue}
  style.font-size: 14
  
  expire_note: |md
    **Active**: O(1) per cycle, samples 20 keys
    **Lazy**: O(1) on access
  | { style.font-size: 14; style.italic: true }
}

scale_note: "" {
  near: title
  shape: text
  style.font-size: 14
  style.italic: true
  style.font-color: ${gray}
  label: "Timer: 64B per entry | Heap: O(log n) insert"
}