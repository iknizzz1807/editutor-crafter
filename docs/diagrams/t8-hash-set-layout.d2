# Hash Set Memory Layout: Dict with Chaining Collision Handling

style.fill: "#F0F0F0"
style.stroke: "#333333"
style.stroke-width: 2
vars: {
  d2-config: {
    theme-id: 0
    layout-engine: elk
    pad: 0
  }
}

title: "Hash Set Memory Layout - Dict with Chaining" {
  shape: text
  style.font-size: 24
  near: top-center
}

# === Set Structure (top-level container) ===
set_header: "set struct" {
  shape: rectangle
  style.fill: "#9B59B6"
  style.opacity: 0.3
  width: 160
  height: 80
  
  dict_ptr: "dict* ptr (0x00)" {
    style.fill: "#E67E22"
    style.opacity: 0.4
  }
}

# Arrow showing pointer reference
set_header -> dict_container: "ptr" {
  style.stroke-dash: 4
  style.stroke: "#E67E22"
}

# === Dict Structure ===
dict_container: "dict struct" {
  shape: rectangle
  style.fill: "#9B59B6"
  style.opacity: 0.3
  width: 200
  height: 120
  
  type: "dictType* type (0x00)" {
    style.fill: "#E67E22"
  }
  ht0: "dictht ht[2] (0x08)" {
    style.fill: "#E67E22"
  }
  ht1: "dictht (0x28)" {
    style.fill: "#2C3E50"
    style.opacity: 0.2
  }
  rehashidx: "int rehashidx (0x48)" {
    style.fill: "#BDC3C7"
  }
}

# Dict points to first bucket array
dict_container.ht0 -> bucket_array: "ht[0].table" {
  style.stroke-dash: 4
  style.stroke: "#3498DB"
}

# === Bucket Array (hashtable) ===
bucket_array: "bucket[4] array" {
  shape: rectangle
  style.fill: "#3498DB"
  style.opacity: 0.2
  width: 240
  height: 100
  
  bucket_0: "bucket[0]: NULL" {
    style.fill: "#2ECC71"
  }
  bucket_1: "bucket[1]" {
    style.fill: "#27AE60"
  }
  bucket_2: "bucket[2]: CHAINED" {
    style.fill: "#27AE60"
    style.bold: true
  }
  bucket_3: "bucket[3]: NULL" {
    style.fill: "#2ECC71"
  }
}

# === Chain Collision: bucket[2] has entries ===
bucket_array.bucket_2 -> entry_head: "collision chain" {
  style.stroke: "#27AE60"
  style.stroke-width: 2
}

# === Collision Entry (chained) ===
entry_head: "dictEntry 1" {
  shape: rectangle
  style.fill: "#F39C12"
  style.opacity: 0.3
  width: 220
  height: 120
  
  key: "sds key: key1 (0x00)" {
    style.fill: "#E74C3C"
  }
  value: "val: NULL (0x08)" {
    style.fill: "#95A5A6"
  }
  next: "next*: entry2 (0x10)" {
    style.fill: "#3498DB"
  }
}

# Chain arrow
entry_head.next -> entry2: "chained" {
  style.stroke: "#3498DB"
}

# === Second collision entry ===
entry2: "dictEntry 2" {
  shape: rectangle
  style.fill: "#F39C12"
  style.opacity: 0.3
  width: 180
  height: 80
  
  key2: "sds key: key2" {
    style.fill: "#E74C3C"
  }
  next_null: "next: NULL (end)" {
    style.fill: "#BDC3C7"
  }
}

# === Annotations ===
note1: "Collision: hash(key1) == hash(key2) == bucket[2]" {
  shape: text
  style.font-size: 12
}

note2: "Hash Set: key stored, val=NULL (membership only)" {
  shape: text
  style.font-size: 12
}

note3: "dictEntry: 32 bytes (key + val + next pointer)" {
  shape: text
  style.font-size: 12
}

note4: "Purple=Header, Blue=Arrays, Orange=Pointers, Green=Entries, Red=Keys" {
  shape: text
  style.font-size: 11
  near: bottom-center
}

# Position annotations
note1 -> bucket_array.bucket_2
note2 -> set_header
note3 -> entry_head
